<div class="page-header mb-4">
    <div class="d-flex justify-space-between align-center" style="flex-wrap:wrap; gap:12px;">
        <div>
            <MudText Typo="Typo.h4" Style="color:var(--gold); font-weight:800;">
                @Title
            </MudText>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-1">
                    @Subtitle
                </MudText>
            }
        </div>
        <div>
            @ChildContent
        </div>
    </div>
</div>

<MudDivider Class="mb-4" Style="background:rgba(212,175,55,0.2);" />

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Subtitle { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}