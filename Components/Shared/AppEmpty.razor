<div style="display: flex; flex-direction: column; align-items: center; padding: 3rem 1.5rem; text-align: center; gap: 0.75rem;">
    <MudIcon Icon="@Icon" Style="font-size: 4rem; opacity: 0.15;" />
    <h4 style="margin: 0; font-weight: 700; color: var(--mud-palette-text-secondary);">@Message</h4>
    @if (!string.IsNullOrEmpty(Description))
    {
        <p style="margin: 0; font-size: 0.85rem; color: var(--mud-palette-text-disabled);">@Description</p>
    }
    @if (ActionText != null)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@ActionIcon" OnClick="OnAction" Style="margin-top: 0.5rem;">
            @ActionText
        </MudButton>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Inbox;
    [Parameter] public string Message { get; set; } = "لا توجد بيانات";
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? ActionText { get; set; }
    [Parameter] public string ActionIcon { get; set; } = Icons.Material.Filled.Add;
    [Parameter] public EventCallback OnAction { get; set; }
}
