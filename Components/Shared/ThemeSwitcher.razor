@inject IJSRuntime JS

<MudMenu Icon="@Icons.Material.Filled.Palette"
         Color="Color.Inherit"
         Title="تغيير الثيم"
         AnchorOrigin="Origin.BottomLeft"
         TransformOrigin="Origin.TopLeft">

    <MudText Typo="Typo.subtitle2" Class="px-3 py-2" Style="font-weight: 700;">
        🎨 اختر الثيم
    </MudText>
    <MudDivider />

    @foreach (var theme in _themes)
    {
        <MudMenuItem OnClick="@(() => ApplyTheme(theme.Class))">
            <div style="display:flex; align-items:center; gap:0.75rem; min-width: 200px;">
                <div class="theme-color-preview"
                     style="background: linear-gradient(135deg, @theme.Color1, @theme.Color2);"></div>
                <span style="flex:1;">@theme.Name</span>
                @if (_currentTheme == theme.Class)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Check"
                             Color="Color.Success"
                             Size="Size.Small" />
                }
            </div>
        </MudMenuItem>
    }
</MudMenu>

<style>
    .theme-color-preview {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        border: 2px solid white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.25);
        flex-shrink: 0;
    }
</style>

@code {
    private string _currentTheme = "default";

    private record ThemeOption(string Name, string Class, string Color1, string Color2);

    private List<ThemeOption> _themes = new()
    {
        new("ذهبي كلاسيك",   "default",       "#d4af37", "#b8941f"),
        new("أزرق احترافي",  "theme-blue",    "#2563eb", "#1d4ed8"),
        new("أخضر فاخر",     "theme-green",   "#059669", "#047857"),
        new("أحمر نخبة",      "theme-red",     "#dc2626", "#b91c1c"),
        new("بنفسجي ملكي",   "theme-purple",  "#7c3aed", "#6d28d9"),
        new("تركواز عصري",   "theme-teal",    "#0d9488", "#0f766e")
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _currentTheme = await JS.InvokeAsync<string>(
                    "localStorage.getItem", "app-theme") ?? "default";

                if (_currentTheme != "default")
                {
                    // طبق الثيم باستخدام eval (أكثر موثوقية)
                    await JS.InvokeVoidAsync("eval",
                        $"document.body.classList.add('{_currentTheme}');");
                }
                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task ApplyTheme(string themeClass)
    {
        try
        {
            // امسح كل الثيمات القديمة
            var clearScript = "document.body.classList.remove('theme-blue', 'theme-green', 'theme-red', 'theme-purple', 'theme-teal');";
            await JS.InvokeVoidAsync("eval", clearScript);

            // طبّق الجديد
            if (themeClass != "default")
            {
                await JS.InvokeVoidAsync("eval",
                    $"document.body.classList.add('{themeClass}');");
            }

            // احفظ
            await JS.InvokeVoidAsync("localStorage.setItem", "app-theme", themeClass);

            _currentTheme = themeClass;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ThemeSwitcher] Error: {ex.Message}");
        }
    }
}
