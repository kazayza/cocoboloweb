@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

@inject IServiceScopeFactory ScopeFactory
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<MudMenu Dense="true"
         AnchorOrigin="Origin.BottomCenter"
         TransformOrigin="Origin.TopCenter"
         PopoverClass="notif-popover-class">
    <ActivatorContent>
        <MudBadge Content="@_unreadCount"
                  Color="Color.Error"
                  Overlap="true"
                  Bordered="true"
                  Visible="@(_unreadCount > 0)">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                           Color="Color.Inherit" />
        </MudBadge>
    </ActivatorContent>
    <ChildContent>
        <div class="notif-popover">

            <div class="notif-header">
                <div class="nh-title">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Primary" Size="Size.Small" />
                    <strong>الإشعارات</strong>
                </div>
                @if (_unreadCount > 0)
                {
                    <MudButton Size="Size.Small"
                               Color="Color.Primary"
                               Variant="Variant.Text"
                               OnClick="MarkAllAsRead">
                        قراءة الكل
                    </MudButton>
                }
            </div>

            <div class="notif-body">
                @if (_notifications.Any())
                {
                    @foreach (var notif in _notifications)
                    {
                        <div class="notif-item @(!notif.IsRead ? "unread" : "")"
                             @onclick="() => HandleClick(notif)">
                            <MudIcon Icon="@(notif.IsRead ? Icons.Material.Filled.NotificationsNone : Icons.Material.Filled.NotificationsActive)"
                                     Color="@(notif.IsRead ? Color.Default : Color.Primary)"
                                     Size="Size.Small" />
                            <div class="ni-content">
                                <div class="ni-title">@notif.Title</div>
                                <div class="ni-msg">@notif.Message</div>
                                <div class="ni-time">@GetTimeAgo(notif.CreatedAt)</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="notif-empty">
                        <MudIcon Icon="@Icons.Material.Filled.NotificationsOff" />
                        <p>لا توجد إشعارات</p>
                    </div>
                }
            </div>

            <div class="notif-footer">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.OpenInNew"
                           OnClick="@(() => Navigation.NavigateTo("/notifications"))"
                           FullWidth="true">
                    عرض كل الإشعارات
                </MudButton>
            </div>
        </div>
    </ChildContent>
</MudMenu>

<style>
    ::deep .notif-popover-class {
        margin-top: 8px !important;
    }

    .notif-popover {
        width: 380px;
        max-height: 500px;
        display: flex;
        flex-direction: column;
        background: white;
    }

    .notif-header {
        padding: 1rem;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafbfc;
    }

    .nh-title {
        display: flex;
        align-items: center;
        gap: .5rem;
        color: #1e293b;
    }

    .notif-body {
        flex: 1;
        overflow-y: auto;
        max-height: 380px;
    }

    .notif-item {
        display: flex;
        gap: .75rem;
        padding: .85rem 1rem;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        transition: background .2s;
        align-items: flex-start;
    }

    .notif-item:hover {
        background: #f8fafc;
    }

    .notif-item.unread {
        background: rgba(212, 175, 55, 0.06);
        border-right: 3px solid #d4af37;
    }

    .ni-content { flex: 1; min-width: 0; }
    .ni-title {
        font-weight: 600;
        font-size: .88rem;
        color: #1e293b;
        margin-bottom: .15rem;
    }
    .ni-msg {
        font-size: .8rem;
        color: #64748b;
        margin-bottom: .25rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .ni-time {
        font-size: .7rem;
        color: #94a3b8;
    }

    .notif-empty {
        padding: 2.5rem 1rem;
        text-align: center;
        color: #94a3b8;
    }
    .notif-empty ::deep .mud-icon-root {
        font-size: 3rem !important;
        opacity: 0.4;
    }
    .notif-empty p {
        margin: .5rem 0 0;
        font-size: .9rem;
    }

    .notif-footer {
        padding: .5rem;
        border-top: 1px solid #e2e8f0;
        background: #fafbfc;
    }
</style>

@code {
    private List<Notification> _notifications = new();
    private int _unreadCount = 0;
    private int _lastNotifiedCount = 0;
    private bool _firstRender = true;
    private string? _currentUserName;
    private string? _currentUserRole;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _currentUserName = auth.User.Identity?.Name;
        _currentUserRole = auth.User.FindFirst(ClaimTypes.Role)?.Value;

        if (!string.IsNullOrEmpty(_currentUserName))
        {
            await LoadNotifications();
            _lastNotifiedCount = _unreadCount;

            _timer = new Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    try
                    {
                        await LoadNotifications();
                        if (_unreadCount > _lastNotifiedCount)
                        {
                            try { await JS.InvokeVoidAsync("playNotificationSound"); } catch { }
                        }
                        _lastNotifiedCount = _unreadCount;
                        StateHasChanged();
                    }
                    catch { }
                });
            }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _firstRender && !string.IsNullOrEmpty(_currentUserName))
        {
            _firstRender = false;
            if (_unreadCount > 0)
            {
                try { await JS.InvokeVoidAsync("playNotificationSound"); } catch { }
            }
        }
    }

    private async Task LoadNotifications()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<NotificationService>();
            _notifications = await svc.GetLatestAsync(_currentUserName!, _currentUserRole, 10);
            _unreadCount = await svc.GetUnreadCountAsync(_currentUserName!, _currentUserRole);
        }
        catch { }
    }

    private async Task HandleClick(Notification notif)
    {
        if (!notif.IsRead)
        {
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<NotificationService>();
            await svc.MarkAsReadAsync(notif.NotificationId);
            await LoadNotifications();
            _lastNotifiedCount = _unreadCount;
        }

        if (!string.IsNullOrWhiteSpace(notif.FormName) && notif.RelatedId.HasValue)
        {
            Navigation.NavigateTo($"/{notif.FormName}/{notif.RelatedId.Value}");
        }
    }

    private async Task MarkAllAsRead()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<NotificationService>();

        foreach (var n in _notifications.Where(n => !n.IsRead))
        {
            await svc.MarkAsReadAsync(n.NotificationId);
        }
        await LoadNotifications();
        _lastNotifiedCount = _unreadCount;
    }

    private string GetTimeAgo(DateTime dateTime)
    {
        var diff = DateTime.Now - dateTime;
        if (diff.TotalMinutes < 1) return "الآن";
        if (diff.TotalMinutes < 60) return $"منذ {(int)diff.TotalMinutes} دقيقة";
        if (diff.TotalHours < 24) return $"منذ {(int)diff.TotalHours} ساعة";
        return $"منذ {(int)diff.TotalDays} يوم";
    }

    public void Dispose() => _timer?.Dispose();
}
