@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

@inject IServiceScopeFactory ScopeFactory
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="bell-wrap">
    <div class="bell-button" @onclick="ToggleOpen" @onclick:stopPropagation="true">
        <MudBadge Content="@_unreadCount"
                  Color="Color.Error"
                  Overlap="true"
                  Bordered="true"
                  Visible="@(_unreadCount > 0)">
            <MudIcon Icon="@Icons.Material.Filled.Notifications" />
        </MudBadge>
    </div>

    @if (_isOpen)
    {
        <div class="bell-overlay" @onclick="Close"></div>
        <div class="bell-dropdown" @onclick:stopPropagation="true">

            <div class="bd-header">
                <div class="bd-title">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Small" />
                    <strong>الإشعارات</strong>
                </div>
                @if (_unreadCount > 0)
                {
                    <button class="bd-link-btn" @onclick="MarkAllAsRead">قراءة الكل</button>
                }
            </div>

            <div class="bd-body">
                @if (_notifications.Any())
                {
                    @foreach (var notif in _notifications)
                    {
                        <div class="bd-item @(!notif.IsRead ? "unread" : "")"
                             @onclick="() => HandleClick(notif)">
                            <div class="bd-item-icon">
                                <MudIcon Icon="@(notif.IsRead ? Icons.Material.Filled.NotificationsNone : Icons.Material.Filled.NotificationsActive)"
                                         Size="Size.Small"
                                         Color="@(notif.IsRead ? Color.Default : Color.Primary)" />
                            </div>
                            <div class="bd-item-content">
                                <div class="bd-item-title">@notif.Title</div>
                                <div class="bd-item-msg">@notif.Message</div>
                                <div class="bd-item-time">@GetTimeAgo(notif.CreatedAt)</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="bd-empty">
                        <MudIcon Icon="@Icons.Material.Filled.NotificationsOff" />
                        <p>لا توجد إشعارات</p>
                    </div>
                }
            </div>

            <div class="bd-footer">
                <button class="bd-footer-btn" @onclick="GoToAll">
                    <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                    عرض كل الإشعارات
                </button>
            </div>
        </div>
    }
</div>

<style>
    .bell-wrap {
        position: relative;
        display: inline-flex;
    }

    .bell-button {
        cursor: pointer;
        padding: 8px;
        border-radius: 50%;
        transition: background 0.2s;
        color: inherit;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .bell-button:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .bell-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: transparent;
        z-index: 9998;
    }

    .bell-dropdown {
        position: absolute;
        top: calc(100% + 12px);
        left: 0;
        width: 380px;
        max-height: 500px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        z-index: 9999;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        animation: slideDown 0.2s ease;
    }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .bd-header {
        padding: 1rem;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fafbfc;
    }

    .bd-title {
        display: flex;
        align-items: center;
        gap: .5rem;
        color: #1e293b;
    }

    .bd-link-btn {
        background: transparent;
        border: none;
        color: #d4af37;
        font-size: .8rem;
        font-weight: 600;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 6px;
        transition: background 0.2s;
    }

    .bd-link-btn:hover {
        background: rgba(212, 175, 55, 0.1);
    }

    .bd-body {
        flex: 1;
        overflow-y: auto;
        max-height: 380px;
    }

    .bd-item {
        display: flex;
        gap: .75rem;
        padding: .85rem 1rem;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        transition: background .2s;
        align-items: flex-start;
    }

    .bd-item:hover {
        background: #f8fafc;
    }

    .bd-item.unread {
        background: rgba(212, 175, 55, 0.06);
        border-right: 3px solid #d4af37;
    }

    .bd-item-icon {
        flex-shrink: 0;
        margin-top: 2px;
    }

    .bd-item-content {
        flex: 1;
        min-width: 0;
    }

    .bd-item-title {
        font-weight: 600;
        font-size: .88rem;
        color: #1e293b;
        margin-bottom: .15rem;
    }

    .bd-item-msg {
        font-size: .8rem;
        color: #64748b;
        margin-bottom: .25rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .bd-item-time {
        font-size: .7rem;
        color: #94a3b8;
    }

    .bd-empty {
        padding: 2.5rem 1rem;
        text-align: center;
        color: #94a3b8;
    }

    .bd-empty ::deep .mud-icon-root {
        font-size: 3rem !important;
        opacity: 0.4;
    }

    .bd-empty p {
        margin: .5rem 0 0;
        font-size: .9rem;
    }

    .bd-footer {
        padding: .5rem;
        border-top: 1px solid #e2e8f0;
        background: #fafbfc;
    }

    .bd-footer-btn {
        width: 100%;
        background: transparent;
        border: none;
        padding: .6rem;
        cursor: pointer;
        color: #d4af37;
        font-weight: 600;
        font-size: .88rem;
        border-radius: 6px;
        transition: background 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .bd-footer-btn:hover {
        background: rgba(212, 175, 55, 0.1);
    }
</style>

@code {
    private List<Notification> _notifications = new();
    private int _unreadCount = 0;
    private int _lastNotifiedCount = 0;
    private bool _firstRender = true;
    private bool _isOpen = false;
    private string? _currentUserName;
    private string? _currentUserRole;
    private List<string> _userRoles = new();
    private Timer? _timer;
    private DotNetObjectReference<NotificationBell>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _currentUserName = auth.User.Identity?.Name;
        _userRoles = auth.User.Claims
            .Where(c => c.Type == ClaimTypes.Role || c.Type == "role" || c.Type.EndsWith("/role"))
            .Select(c => c.Value)
            .Distinct()
            .ToList();
        _currentUserRole = _userRoles.FirstOrDefault();

        if (!string.IsNullOrEmpty(_currentUserName))
        {
            await LoadNotifications();
            _lastNotifiedCount = _unreadCount;

            // سجّل الـ callback عشان JS يناديه لما Audio يتفتح
            _dotNetRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("setOnAudioUnlocked", _dotNetRef); } catch { }

            _timer = new Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    try
                    {
                        await LoadNotifications();
                        if (_unreadCount > _lastNotifiedCount)
                        {
                            try { await JS.InvokeVoidAsync("playNotificationSound"); } catch { }
                        }
                        _lastNotifiedCount = _unreadCount;
                        StateHasChanged();
                    }
                    catch { }
                });
            }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
        }
    }

    // JS بينادي الدالة دي أول ما Audio يتفتح
    [JSInvokable]
    public async Task OnAudioUnlocked()
    {
        // لو عنده إشعارات غير مقروءة → شغّل الصوت فوراً
        if (_unreadCount > 0)
        {
            try { await JS.InvokeVoidAsync("playNotificationSound"); } catch { }
        }
    }

    private void ToggleOpen()
    {
        _isOpen = !_isOpen;
    }

    private void Close()
    {
        _isOpen = false;
    }

    private void GoToAll()
    {
        _isOpen = false;
        Navigation.NavigateTo("/notifications");
    }

    private async Task LoadNotifications()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<NotificationService>();
            _notifications = await svc.GetLatestAsync(_currentUserName!, _userRoles, 15);
            _unreadCount = await svc.GetUnreadCountAsync(_currentUserName!, _userRoles);
        }
        catch { }
    }

    private async Task HandleClick(Notification notif)
    {
        if (!notif.IsRead)
        {
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<NotificationService>();
            await svc.MarkAsReadAsync(notif.NotificationId);
            await LoadNotifications();
            _lastNotifiedCount = _unreadCount;
        }

        _isOpen = false;

        //if (!string.IsNullOrWhiteSpace(notif.FormName) && notif.RelatedId.HasValue)
        //{
          //  Navigation.NavigateTo($"/{notif.FormName}/{notif.RelatedId.Value}");
        //}
        var url = GetNotificationUrl(notif);
if (!string.IsNullOrWhiteSpace(url))
{
    Navigation.NavigateTo(url);
}
    }

    private async Task MarkAllAsRead()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<NotificationService>();

        foreach (var n in _notifications.Where(n => !n.IsRead))
        {
            await svc.MarkAsReadAsync(n.NotificationId);
        }
        await LoadNotifications();
        _lastNotifiedCount = _unreadCount;
    }
    private static string? GetNotificationUrl(Notification notif)
{
    if (string.Equals(notif.RelatedTable, "LeadsCRM", StringComparison.OrdinalIgnoreCase))
    {
        if (string.Equals(notif.FormName, "crm/leads/my", StringComparison.OrdinalIgnoreCase))
            return "/crm/leads/my";

        return "/crm/leads";
    }

    if (string.Equals(notif.RelatedTable, "PayrollRuns", StringComparison.OrdinalIgnoreCase) && notif.RelatedId.HasValue)
        return $"/hr/payroll/run/{notif.RelatedId.Value}";

    if (string.Equals(notif.RelatedTable, "Payroll", StringComparison.OrdinalIgnoreCase))
    {
        if (string.Equals(notif.FormName, "frm_PayrollPayment", StringComparison.OrdinalIgnoreCase))
            return "/hr/payroll/bonuses";

        if (string.Equals(notif.FormName, "frm_Payroll", StringComparison.OrdinalIgnoreCase))
            return "/hr/payroll";
    }

    if (string.IsNullOrWhiteSpace(notif.FormName))
        return null;

    var form = notif.FormName.Trim().TrimStart('/');

    if (notif.RelatedId.HasValue)
        return $"/{form}/{notif.RelatedId.Value}";

    return $"/{form}";
}
    private string GetTimeAgo(DateTime dateTime)
    {
        var diff = DateTime.Now - dateTime;
        if (diff.TotalMinutes < 1) return "الآن";
        if (diff.TotalMinutes < 60) return $"منذ {(int)diff.TotalMinutes} دقيقة";
        if (diff.TotalHours < 24) return $"منذ {(int)diff.TotalHours} ساعة";
        return $"منذ {(int)diff.TotalDays} يوم";
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _dotNetRef?.Dispose();
    }
}
