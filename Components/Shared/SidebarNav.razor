@using System.Security.Claims
@using COCOBOLOERPNEW.Services

@inject NavigationManager Navigation

<div class="sidebar-search">
    <div class="sidebar-search-wrapper">
        <MudIcon Icon="@Icons.Material.Rounded.Search" Class="sidebar-search-icon" />
        <input type="text"
               @bind="_sidebarSearchText"
               @bind:event="oninput"
               placeholder="ابحث في القوائم..."
               class="sidebar-search-input" />
        @if (!string.IsNullOrWhiteSpace(_sidebarSearchText))
        {
            <button class="sidebar-search-clear" @onclick='() => _sidebarSearchText = ""'>
                <MudIcon Icon="@Icons.Material.Rounded.Close" Size="Size.Small" />
            </button>
        }
    </div>
</div>

<MudNavMenu Dense="false" Class="nav-menu">

