@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.ComponentModel.DataAnnotations

@inject ISalesDeliveryStatusService DeliveryService
@inject ISnackbar Snackbar
@inject ILogger<DeliveryDetailDialog> Logger
@inject AuthenticationStateProvider AuthProvider

<MudDialog Style="min-width: 600px;">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" />
            <MudText Typo="Typo.h6">تفاصيل التسليم</MudText>
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center"
                      Justify="Justify.Center"
                      Style="min-height:240px;"
                      Spacing="2">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">جارٍ التحميل...</MudText>
            </MudStack>
        }
        else if (_detail is null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                لا توجد بيانات لهذه الفاتورة
            </MudAlert>
        }
        else
        {
            <MudForm @ref="_form" Model="@_model">

                @* ── Header Strip ─────────────────────────── *@
                <MudPaper Class="pa-4 mb-3 rounded-lg"
                          Style="background:linear-gradient(135deg,#1a237e,#283593); color:white;"
                          Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h6">فاتورة #@_detail.TransactionId</MudText>
                            <MudText Typo="Typo.caption" Style="opacity:.85;">
                                @_detail.TransactionDate.ToString("yyyy/MM/dd")
                                @if (_detail.DueDate.HasValue)
                                {
                                    <span> • استحقاق: @_detail.DueDate.Value.ToString("yyyy/MM/dd")</span>
                                }
                            </MudText>
                        </div>
                        <MudChip T="string"
                                 Variant="Variant.Filled"
                                 Color="@GetChipColor(_detail.DeliveryStatus)"
                                 Icon="@GetStatusIcon(_detail.DeliveryStatus)"
                                 Size="Size.Medium">
                            @_detail.DeliveryStatus
                        </MudChip>
                    </MudStack>
                </MudPaper>

                @* ── Customer & Salesman ─────────────────── *@
                <MudGrid Spacing="2" Class="mb-2">
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-grey);">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
                                <div style="flex:1;">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">العميل</MudText>
                                    <MudText Typo="Typo.body1"><b>@_detail.PartyName</b></MudText>
                                    @if (!string.IsNullOrWhiteSpace(_detail.PartyPhone))
                                    {
                                        <MudText Typo="Typo.body2">
                                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" /> @_detail.PartyPhone
                                        </MudText>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_detail.PartyAddress))
                                    {
                                        <MudText Typo="Typo.body2">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" /> @_detail.PartyAddress
                                        </MudText>
                                    }
                                </div>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-3" Elevation="0" Style="background:var(--mud-palette-background-grey);">
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Secondary" />
                                <div style="flex:1;">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">مندوب المبيعات</MudText>
                                    <MudText Typo="Typo.body1"><b>@(_detail.SalesEmployeeName ?? "—")</b></MudText>
                                    @if (_detail.DaysRemaining.HasValue && _detail.DeliveryStatus != "تم التسليم")
                                    {
                                        var d = _detail.DaysRemaining.Value;
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(d < 0 ? Color.Error : d <= 2 ? Color.Warning : Color.Info)">
                                            @(d < 0 ? $"متأخر {Math.Abs(d)} يوم" : $"باقي {d} يوم")
                                        </MudChip>
                                    }
                                </div>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @* ── Products Table ──────────────────────── *@
                <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                    المنتجات (@_detail.Products.Count)
                </MudText>
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="overflow:auto;">
                    <thead>
                        <tr>
                            <th>المنتج</th>
                            <th style="text-align:end;">الكمية</th>
                            <th style="text-align:end;">السعر</th>
                            <th style="text-align:end;">الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_detail.Products.Count == 0)
                        {
                            <tr><td colspan="4" style="text-align:center; color:#999;">لا توجد منتجات</td></tr>
                        }
                        @foreach (var p in _detail.Products)
                        {
                            <tr>
                                <td>@p.ProductName</td>
                                <td style="text-align:end;">@p.Quantity.ToString("N2") @p.UnitName</td>
                                <td style="text-align:end;">@(p.UnitPrice?.ToString("N2") ?? "—")</td>
                                <td style="text-align:end;"><b>@p.TotalAmount.ToString("N2")</b></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>

                @* ── Financial Summary ───────────────────── *@
                <MudPaper Class="pa-3 mt-3" Elevation="0" Style="background:var(--mud-palette-background-grey);">
                    <MudGrid>
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption">الإجمالي</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Primary">@_detail.GrandTotal.ToString("N2") ج</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption">المدفوع</MudText>
                            <MudText Typo="Typo.h6" Color="Color.Success">@_detail.PaidAmount.ToString("N2") ج</MudText>
                        </MudItem>
                        <MudItem xs="4">
                            <MudText Typo="Typo.caption">المتبقي</MudText>
                            <MudText Typo="Typo.h6"
                                     Color="@(_detail.RemainingAmount > 0 ? Color.Error : Color.Success)">
                                @_detail.RemainingAmount.ToString("N2") ج
                            </MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <MudDivider Class="my-4" />

                @* ── Update Form ─────────────────────────── *@
                <MudText Typo="Typo.subtitle1" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    تحديث حالة التسليم
                </MudText>

                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudSelect T="string"
                                   @bind-Value="_model.Status"
                                   Label="الحالة"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Required="true"
                                   RequiredError="الحالة مطلوبة"
                                   AdornmentIcon="@GetStatusIcon(_model.Status)"
                                   Adornment="Adornment.Start">
                            <MudSelectItem T="string" Value='"جارى"'>جارى</MudSelectItem>
                            <MudSelectItem T="string" Value='"متأخر"'>متأخر</MudSelectItem>
                            <MudSelectItem T="string" Value='"تم التسليم"'>تم التسليم</MudSelectItem>
                            <MudSelectItem T="string" Value='"مرتجع"'>مرتجع</MudSelectItem>
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudAutocomplete T="EmployeeLookupDto"
                                         @bind-Value="_selectedEmployee"
                                         SearchFunc="SearchEmployeesAsync"
                                         ToStringFunc="@(e => e?.FullName ?? "")"
                                         Label="مندوب التسليم"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Clearable="true"
                                         CoerceText="true"
                                         CoerceValue="true"
                                         Required="@(_model.Status == "تم التسليم")"
                                         RequiredError="المندوب مطلوب عند التسليم"
                                         AdornmentIcon="@Icons.Material.Filled.DeliveryDining"
                                         Adornment="Adornment.Start">
                            <ItemTemplate Context="emp">
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <span>@emp.FullName</span>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@emp.JobTitle</MudText>
                                </MudStack>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </MudItem>

                    @if (_model.Status == "تم التسليم")
                    {
                        <MudItem xs="12" md="6">
                            <MudDatePicker @bind-Date="_model.DeliveredAt"
                                           Label="تاريخ التسليم"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           MaxDate="DateTime.Today" />
                        </MudItem>
                    }

                    <MudItem xs="12">
                        <MudTextField T="string"
                                      @bind-Value="_model.Notes"
                                      Label="ملاحظات"
                                      Variant="Variant.Outlined"
                                      Lines="2"
                                      Margin="Margin.Dense"
                                      MaxLength="500"
                                      Counter="500" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>

    <DialogActions>
        @if (_detail is not null)
        {
            <MudButton OnClick="ResetForm"
                       StartIcon="@Icons.Material.Filled.Restore"
                       Disabled="_saving">
                إعادة تعيين
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync"
                       Disabled="_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    <span>جارٍ الحفظ...</span>
                }
                else
                {
                    <span>حفظ</span>
                }
            </MudButton>
        }
        <MudButton OnClick="Cancel" Disabled="_saving">إغلاق</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public int TransactionId { get; set; }

    private DeliveryDetailDto?     _detail;
    private MudForm?               _form;
    private bool                   _loading = true;
    private bool                   _saving  = false;

    private List<EmployeeLookupDto> _employees = new();
    private EmployeeLookupDto?      _selectedEmployee;

    private UpdateModel _model = new();

    // ─── Lifecycle ─────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var detailTask    = SafeLoadDetailAsync();
        var employeesTask = SafeLoadEmployeesAsync();
        await Task.WhenAll(detailTask, employeesTask);

        if (_detail is not null)
        {
            BindFromDetail();
        }

        _loading = false;
    }

    private async Task SafeLoadDetailAsync()
    {
        try
        {
            _detail = await DeliveryService.GetDeliveryDetailsAsync(TransactionId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load delivery {Id}", TransactionId);
            Snackbar.Add("تعذّر تحميل تفاصيل التسليم: " + ex.Message, Severity.Error);
            _detail = null;
        }
    }

    private async Task SafeLoadEmployeesAsync()
    {
        try
        {
            _employees = await DeliveryService.GetDeliveryEmployeesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load employees lookup");
            _employees = new();
        }
    }

    private void BindFromDetail()
    {
        if (_detail is null) return;

        _model = new UpdateModel
        {
            Status        = _detail.DeliveryStatus,
            Notes         = _detail.DeliveredNotes ?? "",
            DeliveredAt   = _detail.DeliveredAt ?? DateTime.Today
        };

        _selectedEmployee = _employees.FirstOrDefault(e => e.EmployeeId == _detail.DeliveryEmployeeId)
                         ?? _employees.FirstOrDefault(e => e.FullName == _detail.DeliveryEmployeeName);
    }

    private void ResetForm() => BindFromDetail();

    // ─── Autocomplete search ───────────────────────────────
    private Task<IEnumerable<EmployeeLookupDto>> SearchEmployeesAsync(string? value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<EmployeeLookupDto>>(_employees);

        var filtered = _employees
            .Where(e => e.FullName.Contains(value, StringComparison.OrdinalIgnoreCase)
                     || (e.JobTitle?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false));

        return Task.FromResult(filtered);
    }

    // ─── Save ──────────────────────────────────────────────
    private async Task SaveAsync()
    {
        if (_form is null || _detail is null) return;

        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            var userName = await GetCurrentUserNameAsync();

            var dto = new DeliveryUpdateDto
            {
                TransactionId        = TransactionId,
                Status               = _model.Status,
                DeliveryEmployeeId   = _selectedEmployee?.EmployeeId,
                DeliveryEmployeeName = _selectedEmployee?.FullName,
                DeliveredAt          = _model.Status == "تم التسليم" ? (_model.DeliveredAt ?? DateTime.Now) : null,
                Notes                = string.IsNullOrWhiteSpace(_model.Notes) ? null : _model.Notes.Trim(),
                UserName             = userName
            };

            var (success, message) = await DeliveryService.UpdateDeliveryStatusAsync(dto);

            if (success)
            {
                Snackbar.Add(message, Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update delivery {Id}", TransactionId);
            Snackbar.Add("حدث خطأ غير متوقع: " + ex.Message, Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task<string> GetCurrentUserNameAsync()
    {
        try
        {
            var state = await AuthProvider.GetAuthenticationStateAsync();
            return state.User?.Identity?.Name ?? "system";
        }
        catch
        {
            return "system";
        }
    }

    // ─── UI Helpers ────────────────────────────────────────
    private static Color GetChipColor(string? s) => s switch
    {
        "جارى"        => Color.Warning,
        "متأخر"       => Color.Error,
        "تم التسليم"  => Color.Success,
        "مرتجع"       => Color.Dark,
        _             => Color.Default
    };

    private static string GetStatusIcon(string? s) => s switch
    {
        "جارى"        => Icons.Material.Filled.Pending,
        "متأخر"       => Icons.Material.Filled.Warning,
        "تم التسليم"  => Icons.Material.Filled.CheckCircle,
        "مرتجع"       => Icons.Material.Filled.AssignmentReturn,
        _             => Icons.Material.Filled.HelpOutline
    };

    // ─── Local Form Model ──────────────────────────────────
    private class UpdateModel
    {
        [Required(ErrorMessage = "الحالة مطلوبة")]
        public string Status { get; set; } = "جارى";

        public DateTime? DeliveredAt { get; set; } = DateTime.Today;

        [StringLength(500, ErrorMessage = "الملاحظات لا تتجاوز 500 حرف")]
        public string Notes { get; set; } = "";
    }
}
