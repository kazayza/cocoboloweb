@inherits LayoutComponentBase
@implements IDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.Components.Shared
@using COCOBOLOERPNEW.Services

@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme"
                  @bind-IsDarkMode="_isDarkMode"
                  @bind-IsDarkMode:after="StateHasChanged" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@($"erp-shell {(_isDarkMode ? "dark-mode" : "light-mode")}")" dir="rtl">

    <!-- ================= TOP BAR ================= -->
    <MudAppBar Elevation="0" Fixed="true" Class="erp-topbar">
        <div class="tb-row">

            <!-- يمين: زر القائمة + البراند -->
            <div class="tb-start">
                <button class="menu-toggle" @onclick="ToggleDrawer">
                    @if (_drawerOpen)
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.MenuOpen" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.Menu" />
                    }
                </button>

                <div class="brand" @onclick='() => Navigation.NavigateTo("/")'>
                    <img src="logo.png" class="brand-logo" alt="Logo" />
                    <div class="brand-name">COCOBOLO<span class="brand-suffix">ERP</span></div>
                </div>
            </div>

            <!-- وسط: البحث -->
            <div class="tb-center">
                <div class="search-wrapper">
                    <MudIcon Icon="@Icons.Material.Rounded.Search" Class="search-icon" />
                    <input type="text"
                           @bind="_searchText"
                           @bind:event="oninput"
                           placeholder="بحث سريع..."
                           class="search-input" />
                </div>
            </div>

            <!-- يسار: أزرار + المستخدم -->
            <div class="tb-end">

                <!-- التاريخ -->
                <div class="date-chip">
                    <MudIcon Icon="@Icons.Material.Rounded.CalendarMonth" Size="Size.Small" />
                    <span>@DateTime.Now.ToString("dd MMMM, yyyy")</span>
                </div>

                <!-- Dark/Light toggle -->
                <button class="tb-icon-btn" @onclick="ToggleDarkMode"
                        title="@(_isDarkMode ? "الوضع النهاري" : "الوضع الليلي")">
                    @if (_isDarkMode)
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.LightMode" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.DarkMode" Size="Size.Small" />
                    }
                </button>

                <!-- Theme Switcher -->
                <ThemeSwitcher />

                <!-- Notifications -->
                <NotificationBell />

                <!-- معلومات المستخدم -->
                <div class="user-chip" @onclick="ToggleUserMenu">
                    <div class="user-avatar">
                        <span>@_avatarLetter</span>
                    </div>
                    <div class="user-text">
                        <span class="user-name">@_currentUserName</span>
                        <span class="user-role">@_currentUserRole</span>
                    </div>
                    <MudIcon Icon="@(_userMenuOpen
                                 ? Icons.Material.Rounded.KeyboardArrowUp
                                 : Icons.Material.Rounded.KeyboardArrowDown)"
                             Size="Size.Small"
                             Class="user-arrow" />
                </div>

                <!-- زر تسجيل الخروج المنفصل -->
                <button class="tb-icon-btn logout-btn" @onclick="Logout" title="تسجيل الخروج">
                    <MudIcon Icon="@Icons.Material.Rounded.Logout" Size="Size.Small" />
                </button>

                <MudPopover Open="_userMenuOpen"
                            AnchorOrigin="Origin.BottomLeft"
                            TransformOrigin="Origin.TopLeft"
                            Class="user-popover">
                    <MudList T="string" Dense="true" Class="user-menu-list">
                        <MudListItem Icon="@Icons.Material.Rounded.Person"
                                     OnClick='() => Navigation.NavigateTo("/profile")'>
                            الملف الشخصي
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Rounded.Lock"
                                     OnClick='() => Navigation.NavigateTo("/change-password")'>
                            تغيير كلمة السر
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Rounded.Settings"
                                     OnClick='() => Navigation.NavigateTo("/settings")'>
                            الإعدادات
                        </MudListItem>
                    </MudList>
                </MudPopover>
            </div>
        </div>
    </MudAppBar>

    <!-- ================= SIDEBAR ================= -->
    <MudDrawer @bind-Open="_drawerOpen"
               Class="erp-sidebar"
               Width="280px"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Anchor="Anchor.Right">

        <!-- بحث القوائم -->
        <div class="sidebar-search">
            <div class="sidebar-search-wrapper">
                <MudIcon Icon="@Icons.Material.Rounded.Search" Class="sidebar-search-icon" />
                <input type="text"
                       @bind="_sidebarSearchText"
                       @bind:event="oninput"
                       placeholder="ابحث في القوائم..."
                       class="sidebar-search-input" />
                @if (!string.IsNullOrWhiteSpace(_sidebarSearchText))
                {
                    <button class="sidebar-search-clear" @onclick='() => _sidebarSearchText = ""'>
                        <MudIcon Icon="@Icons.Material.Rounded.Close" Size="Size.Small" />
                    </button>
                }
            </div>
        </div>

        <MudNavMenu Dense="false" Class="nav-menu">

            @* ========== الرئيسية ========== *@
            @if (HasPermission("frmDashboard", "View") && IsVisible("الرئيسية"))
            {
                <MudNavLink Href="/" Icon="@Icons.Material.Rounded.SpaceDashboard"
                            Match="NavLinkMatch.All">
                    الرئيسية
                </MudNavLink>
            }

            @* ========== البيانات الأساسية ========== *@
            @if (HasAnyViewPermission("frm_CompanyInfo", "frm_ProductGroups")
                && IsGroupVisible("البيانات الأساسية","بيانات الشركة"))
            {
                <MudNavGroup Title="البيانات الأساسية"
                             Icon="@Icons.Material.Rounded.Dataset"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_CompanyInfo", "View") && IsVisible("بيانات الشركة"))
                    {
                        <MudNavLink Href="/company" Icon="@Icons.Material.Rounded.Business">بيانات الشركة</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== المبيعات ========== *@
            @if (HasAnyViewPermission("frm_Parties","frm_PartiesList","frm_Products","frm_SalesInvoiveNew","frm_SalesInvoiveView","frm_PartiesInvoices","frm_Payments","frm_PaymentsInvoicesNew","frm_ApproveDiscount","frmInspectionCharge","frm_SupplierInvoices","frmInvoiceDeliveryStatus")
                && IsGroupVisible("المبيعات","كافة المنتجات","إضافة عميل","مورد","كافة العملاء","الموردين","فاتورة مبيعات","فاتورة مبيعات جديدة","فواتير العملاء","فواتير الموردين","المدفوعات","مدفوعات الفواتير","خصم","خصم على الفاتورة","رسوم المعاينة","فواتير الشراء","متابعة التسليم","تسليم"))
            {
                <MudNavGroup Title="المبيعات"
                             Icon="@Icons.Material.Rounded.Storefront"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_ProductList", "View") && IsVisible("كافة المنتجات","الاصناف","منتجات"))
                    {
                        <MudNavLink Href="/products" Icon="@Icons.Material.Rounded.Inventory2">المنتجات</MudNavLink>
                    }
                    @if (HasPermission("frm_PartiesList", "View") && IsVisible("كافة العملاء","الموردين","عملاء"))
                    {
                        <MudNavLink Href="/customers" Icon="@Icons.Material.Rounded.Groups">العملاء</MudNavLink>
                    }
                    @if (HasPermission("frm_PartiesInvoices", "View") && IsVisible("فواتير العملاء","فواتير الموردين","فواتير"))
                    {
                        <MudNavLink Href="/sales/invoices" Icon="@Icons.Material.Rounded.Receipt">الفواتير</MudNavLink>
                    }
                    @if (HasPermission("frm_Payments", "View") && IsVisible("المدفوعات","دفع"))
                    {
                        <MudNavLink Href="/payments" Icon="@Icons.Material.Rounded.Payments">المدفوعات</MudNavLink>
                    }
                    
                    @if (HasPermission("frm_ApproveDiscount", "View") && IsVisible("خصم","خصم على الفاتورة"))
                    {
                        <MudNavLink Href="/discounts" Icon="@Icons.Material.Rounded.Discount">خصم على الفاتورة</MudNavLink>
                    }
                    @if (HasPermission("frmInspectionCharge", "View") && IsVisible("رسوم المعاينة","معاينة","رسوم"))
                    {
                        <MudNavLink Href="/additional-charges" Icon="@Icons.Material.Rounded.AttachMoney">رسوم المعاينة</MudNavLink>
                    }
                    
                    @if (HasPermission("frmInvoiceDeliveryStatus", "View") && IsVisible("متابعة التسليم","تسليم"))
                    {
                        <MudNavLink Href="/delivery-status" Icon="@Icons.Material.Rounded.LocalShipping">متابعة التسليم</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== المشتريات والمخزون ========== *@
            @if (HasAnyViewPermission("frm_StockLevels","frm_Bestsellingitems")
                && IsGroupVisible("المشتريات والمخزون","المشتريات","المخزون","رصيد المخزن","الاكثر مبيعا"))
            {
                <MudNavGroup Title="المشتريات والمخزون"
                             Icon="@Icons.Material.Rounded.Inventory"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_StockLevels", "View") && IsVisible("رصيد المخزن","مخزن","رصيد"))
                    {
                        <MudNavLink Href="/stock-levels" Icon="@Icons.Material.Rounded.BarChart">رصيد المخزن</MudNavLink>
                    }
                    @if (HasPermission("frm_Bestsellingitems", "View") && IsVisible("الاكثر مبيعا","مبيعات","الاكثر"))
                    {
                        <MudNavLink Href="/best-selling" Icon="@Icons.Material.Rounded.TrendingUp">الأكثر مبيعًا</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== المصروفات ========== *@
            @if (HasAnyViewPermission("frm_Expenses","frm_ExpensesList","frm_ExpensesGroup","frmExpenseTree")
                && IsGroupVisible("المصروفات","إضافة مصروف","مصروف جديد","كافة المصروفات","مجموعات المصروفات","شجرة حسابات"))
            {
                <MudNavGroup Title="المصروفات"
                             Icon="@Icons.Material.Rounded.MoneyOff"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_ExpensesList", "View") && IsVisible("كافة المصروفات","المصروفات"))
                    {
                        <MudNavLink Href="/expenses" Icon="@Icons.Material.Rounded.ReceiptLong">المصروفات</MudNavLink>
                    }
                    @if (HasPermission("frm_ExpensesGroup", "View") && IsVisible("مجموعات المصروفات","مجموعات"))
                    {
                        <MudNavLink Href="/expense-groups" Icon="@Icons.Material.Rounded.FolderOpen">مجموعات المصروفات</MudNavLink>
                    }
                    @if (HasPermission("frmExpenseTree", "View") && IsVisible("شجرة حسابات","شجرة"))
                    {
                        <MudNavLink Href="/expense-tree" Icon="@Icons.Material.Rounded.AccountTree">شجرة حسابات المصروفات</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== الخزينة ========== *@
           @* ========== 💼 الخزينة والمالية (محدّث) ========== *@
@if (HasAnyViewPermission("frmCashBox", "frmCashBoxDashboard", "frmCashBoxTransactions", 
                          "frmCashBoxManual", "frmCashBoxSummary", "frmPersonalAccounts",
                          "frm_CashBoxManual", "frm_CashBoxTransaction", "frm_TotalInOutNetCashBox", "frm_CashFlowNew")
    && IsGroupVisible("الخزينة","سندات قبض","سندات صرف","سندات","حركات الخزينة","لوحة الخزينة","Dashboard","إدارة الخزن","الذمم","حسابات شخصية","قروض","إجمالي المقبوضات","التدفقات النقدية","تدفقات"))
{
    <MudNavGroup Title="الخزينة"
                 Icon="@Icons.Material.Rounded.AccountBalanceWallet"
                 Expanded="@_isSearching">

        @* لوحة الخزينة (Dashboard) *@
        @if ((HasPermission("frmCashBoxDashboard", "View") || HasPermission("frmCashBox", "View"))
            && IsVisible("لوحة الخزينة","Dashboard","داشبورد","ملخص الخزينة"))
        {
            <MudNavLink Href="/cashbox/dashboard" Icon="@Icons.Material.Rounded.Dashboard">
                لوحة الخزينة
            </MudNavLink>
        }

        @* إدارة الخزن *@
        @if (HasPermission("frmCashBox", "View") && IsVisible("إدارة الخزن","الخزن","Cashboxes"))
        {
            <MudNavLink Href="/cashbox/manage" Icon="@Icons.Material.Rounded.AccountBalance">
                إدارة الخزن
            </MudNavLink>
        }

        @* حركات الخزينة *@
        @if ((HasPermission("frmCashBoxTransactions", "View") || HasPermission("frm_CashBoxTransaction", "View"))
            && IsVisible("حركات الخزينة","حركات"))
        {
            <MudNavLink Href="/cashbox/transactions" Icon="@Icons.Material.Rounded.SwapHoriz">
                حركات الخزينة
            </MudNavLink>
        }

        @* سندات قبض/صرف يدوية *@
        @if ((HasPermission("frmCashBoxManual", "View") || HasPermission("frm_CashBoxManual", "View"))
            && IsVisible("سندات قبض","سندات صرف","سندات","حركة يدوية","قرض","تحويل"))
        {
            <MudNavLink Href="/cashbox/manual" Icon="@Icons.Material.Rounded.Description">
                 حركة يدوية / سندات
            </MudNavLink>
        }

        @* ⭐ الذمم - حسابات شخصية ⭐ *@
        @if (HasPermission("frmPersonalAccounts", "View")
            && IsVisible("الذمم","حسابات شخصية","قروض","شخصي","شخصية"))
        {
            <MudNavLink Href="/cashbox/personal-accounts" Icon="@Icons.Material.Rounded.PeopleAlt">
                 الذمم (حسابات شخصية)
            </MudNavLink>
        }

        @* ملخص الخزن *@
        @if ((HasPermission("frmCashBoxSummary", "View") || HasPermission("frm_TotalInOutNetCashBox", "View"))
            && IsVisible("ملخص","تقرير الخزن","إجمالي المقبوضات","المدفوعات","إجمالي"))
        {
            <MudNavLink Href="/cashbox/summary" Icon="@Icons.Material.Rounded.Summarize">
                ملخص الخزن (تقرير)
            </MudNavLink>
        }

        @* قائمة التدفقات النقدية (الموجودة قبلاً) *@
        @if (HasPermission("frm_CashFlowNew", "View") && IsVisible("التدفقات النقدية","تدفقات"))
        {
            <MudNavLink Href="/cash-flow" Icon="@Icons.Material.Rounded.Wallet">
                قائمة التدفقات النقدية
            </MudNavLink>
        }
    </MudNavGroup>
}


            @* ========== الموظفين والرواتب ========== *@
            @if (HasAnyViewPermission("frm_Employees","frm_Employeeslist","frm_Payroll","frm_PayrollPayment","frmPayrollProcessor","frmPayrollReport","frm_EmpolyeeShifts","frm_AllShifts","frm_MySchedule","frm_ImportBiometric","frm_empAttendance","frmDailyExemptions","frm_MyPermissions")
                && IsGroupVisible("الموظفين والرواتب","الموظفين","الرواتب","إضافة موظف","كافة الموظفين","تسجيل راتب","راتب جماعي","شيفت","البصمة","استثناءات","إذن","حضور"))
            {
                <MudNavGroup Title="الموظفين والرواتب"
                             Icon="@Icons.Material.Rounded.People"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_Employees", "View") && IsVisible("إضافة موظف","موظف جديد","موظف"))
                    {
                        <MudNavLink Href="/employees/new" Icon="@Icons.Material.Rounded.PersonAdd">إضافة موظف</MudNavLink>
                    }
                    @if (HasPermission("frm_Employeeslist", "View") && IsVisible("كافة الموظفين","الموظفين"))
                    {
                        <MudNavLink Href="/employees" Icon="@Icons.Material.Rounded.PeopleAlt">كافة الموظفين</MudNavLink>
                    }
                    @if (HasPermission("frm_Payroll", "View") && IsVisible("تسجيل راتب","راتب"))
                    {
                        <MudNavLink Href="/payroll/new" Icon="@Icons.Material.Rounded.AddCard">تسجيل راتب</MudNavLink>
                    }
                    @if (HasPermission("frm_PayrollPayment", "View") && IsVisible("مدفوعات الرواتب","رواتب"))
                    {
                        <MudNavLink Href="/payroll/payments" Icon="@Icons.Material.Rounded.PriceCheck">مدفوعات الرواتب</MudNavLink>
                    }
                    @if (HasPermission("frmPayrollProcessor", "View") && IsVisible("راتب جماعي","جماعي"))
                    {
                        <MudNavLink Href="/payroll/batch" Icon="@Icons.Material.Rounded.GroupWork">راتب جماعي</MudNavLink>
                    }
                    @if (HasPermission("frmPayrollReport", "View") && IsVisible("الاستعلام عن الرواتب","استعلام"))
                    {
                        <MudNavLink Href="/payroll/report" Icon="@Icons.Material.Rounded.ManageSearch">الاستعلام عن الرواتب</MudNavLink>
                    }
                    @if (HasPermission("frm_EmpolyeeShifts", "View") && IsVisible("إضافة شيفت","شيفت"))
                    {
                        <MudNavLink Href="/shifts/new" Icon="@Icons.Material.Rounded.MoreTime">إضافة شيفت</MudNavLink>
                    }
                    @if (HasPermission("frm_AllShifts", "View") && IsVisible("متابعة الشيفتات","شيفتات"))
                    {
                        <MudNavLink Href="/shifts" Icon="@Icons.Material.Rounded.Schedule">متابعة الشيفتات</MudNavLink>
                    }
                    @if (HasPermission("frm_MySchedule", "View") && IsVisible("شيفتاتي","جدولي"))
                    {
                        <MudNavLink Href="/my-schedule" Icon="@Icons.Material.Rounded.CalendarViewDay">شيفتاتي</MudNavLink>
                    }
                    @if (HasPermission("frm_ImportBiometric", "View") && IsVisible("البصمة","بصمة"))
                    {
                        <MudNavLink Href="/biometric" Icon="@Icons.Material.Rounded.Fingerprint">البصمة</MudNavLink>
                    }
                    @if (HasPermission("frm_empAttendance", "View") && IsVisible("بصمة الموظف","حضور","بصمة"))
                    {
                        <MudNavLink Href="/attendance" Icon="@Icons.Material.Rounded.HowToReg">بصمة الموظف</MudNavLink>
                    }
                    @if (HasPermission("frmDailyExemptions", "View") && IsVisible("استثناءات"))
                    {
                        <MudNavLink Href="/exemptions" Icon="@Icons.Material.Rounded.EventBusy">استثناءات</MudNavLink>
                    }
                    @if (HasPermission("frm_MyPermissions", "View") && IsVisible("طلب إذن","إذن"))
                    {
                        <MudNavLink Href="/my-permissions" Icon="@Icons.Material.Rounded.RuleFolder">طلب إذن</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== CRM ========== *@
            @if (HasAnyViewPermission("frmNewInteraction","frmDailyTasks","frmSalesPipeline","frmClientCard","frmNewQuotation","frmQuotationsList","frmInteractionsLog","frmCustomerProduct","frmManamgerSales","frmCustomerDocs","frm_Commissions")
                && IsGroupVisible("CRM","تواصل","مهام المتابعة","مراحل البيع","بطاقة العميل","عرض سعر","عروض الاسعار","سجل التواصلات","التعاقد","متابعة المدير","مستندات العميل","العمولات"))
            {
                <MudNavGroup Title="CRM"
                             Icon="@Icons.Material.Rounded.ContactPhone"
                             Expanded="@_isSearching">
                    @if (HasPermission("frmNewInteraction", "View") && IsVisible("تواصل جديد","تواصل"))
                    {
                        <MudNavLink Href="/crm/interactions/new" Icon="@Icons.Material.Rounded.AddIcCall">تواصل جديد</MudNavLink>
                    }
                    @if (HasPermission("frmDailyTasks", "View") && IsVisible("مهام المتابعة","مهام"))
                    {
                        <MudNavLink Href="/crm/tasks" Icon="@Icons.Material.Rounded.TaskAlt">مهام المتابعة</MudNavLink>
                    }
                    @if (HasPermission("frmSalesPipeline", "View") && IsVisible("مراحل البيع","pipeline"))
                    {
                        <MudNavLink Href="/crm/pipeline" Icon="@Icons.Material.Rounded.FilterAlt">مراحل البيع</MudNavLink>
                    }
                    @if (HasPermission("frmClientCard", "View") && IsVisible("بطاقة العميل","عميل"))
                    {
                        <MudNavLink Href="/crm/clients" Icon="@Icons.Material.Rounded.ContactPage">بطاقة العميل</MudNavLink>
                    }
                    @if (HasPermission("frmNewQuotation", "View") && IsVisible("عرض سعر جديد","عرض سعر"))
                    {
                        <MudNavLink Href="/crm/quotations/new" Icon="@Icons.Material.Rounded.NoteAdd">عرض سعر جديد</MudNavLink>
                    }
                    @if (HasPermission("frmQuotationsList", "View") && IsVisible("عروض الاسعار","عروض"))
                    {
                        <MudNavLink Href="/crm/quotations" Icon="@Icons.Material.Rounded.ListAlt">عروض الأسعار</MudNavLink>
                    }
                    @if (HasPermission("frmInteractionsLog", "View") && IsVisible("سجل التواصلات","تواصلات"))
                    {
                        <MudNavLink Href="/crm/interactions" Icon="@Icons.Material.Rounded.Forum">سجل التواصلات</MudNavLink>
                    }
                    @if (HasPermission("frmCustomerProduct", "View") && IsVisible("التعاقد","عقد"))
                    {
                        <MudNavLink Href="/crm/contract" Icon="@Icons.Material.Rounded.Handshake">التعاقد</MudNavLink>
                    }
                    @if (HasPermission("frmManamgerSales", "View") && IsVisible("متابعة المدير","مدير"))
                    {
                        <MudNavLink Href="/crm/manager" Icon="@Icons.Material.Rounded.SupervisorAccount">متابعة المدير</MudNavLink>
                    }
                    @if (HasPermission("frmCustomerDocs", "View") && IsVisible("مستندات العميل","مستندات"))
                    {
                        <MudNavLink Href="/crm/documents" Icon="@Icons.Material.Rounded.FolderShared">مستندات العميل</MudNavLink>
                    }
                    @if (HasPermission("frm_Commissions", "View") && IsVisible("العمولات","عمولة"))
                    {
                        <MudNavLink Href="/crm/commissions" Icon="@Icons.Material.Rounded.Paid">العمولات</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== إدارة النظام ========== *@
            @if (HasAnyViewPermission("frm_AllUsers","frm_AddUser","frm_AddPermission","frmManagePermissions","Frm_MainList_Edit","frm_NotificationsAll","frm_ChangePassword","frm_AuditViewer","frmContactSourses","frmSalesStages","frmInterestCategories","frmContactStatus","frmTaskTypes","frmLostReasons","frmAdCampain","frm_PricingMargins","frm_PriceRequests","frm_PriceHistory","frm_PricingHistory")
