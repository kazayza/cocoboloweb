@inherits LayoutComponentBase
@implements IDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.Components.Shared
@using COCOBOLOERPNEW.Services

@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@inject GlobalSearchService SearchService

<MudThemeProvider Theme="_theme"
                  @bind-IsDarkMode="_isDarkMode"
                  @bind-IsDarkMode:after="StateHasChanged" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@($"erp-shell {(_isDarkMode ? "dark-mode" : "light-mode")}")" dir="rtl">

    <!-- ================= TOP BAR ================= -->
    <MudAppBar Elevation="0" Fixed="true" Class="erp-topbar">
        <div class="tb-row">

            <!-- يمين: زر القائمة + البراند -->
            <div class="tb-start">
                <button class="menu-toggle" @onclick="ToggleDrawer">
                    @if (_drawerOpen)
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.MenuOpen" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.Menu" />
                    }
                </button>

                <div class="brand" @onclick='() => Navigation.NavigateTo("/")'>
                    <img src="logo.png" class="brand-logo" alt="Logo" />
                    <div class="brand-name">COCOBOLO<span class="brand-suffix">ERP</span></div>
                </div>
            </div>

            <!-- وسط: البحث -->
            <div class="tb-center">
                <div class="search-wrapper @(_showResults ? "search-active" : "")" @onclick:stopPropagation="true">
                    <MudIcon Icon="@Icons.Material.Rounded.Search" Class="search-icon" />
                    <input type="text"
       value="@_searchText"
       @oninput="OnSearchInput"
       @onfocus="OnSearchFocus"
       placeholder="بحث في المنتجات، العملاء، الفواتير..."
       class="search-input"
       autocomplete="off" />
                    @if (!string.IsNullOrWhiteSpace(_searchText))
                    {
                        <button class="search-clear-btn" @onclick="ClearSearch">
                            <MudIcon Icon="@Icons.Material.Rounded.Close" Size="Size.Small" />
                        </button>
                    }
                    @if (_isSearching)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="search-spinner" />
                    }
                </div>

                @if (_showResults)
                {
                    <div class="search-overlay" @onclick="CloseSearch"></div>
                    <div class="search-results-panel" @onclick:stopPropagation="true">
                        @if (_isSearching)
                        {
                            <div class="sr-loading">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                                <span>جاري البحث...</span>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(_searchText) && _searchText.Length >= 2 && !_searchResults.Any())
                        {
                            <div class="sr-empty">
                                <MudIcon Icon="@Icons.Material.Rounded.SearchOff" />
                                <span>لا توجد نتائج لـ "@_searchText"</span>
                            </div>
                        }
                        else if (_searchResults.Any())
                        {
                            @foreach (var group in _searchResults.GroupBy(r => r.CategoryAr))
                            {
                                <div class="sr-group">
                                    <div class="sr-group-header">
                                        @group.First().CategoryAr
                                        <span class="sr-group-count">@group.Count()</span>
                                    </div>
                                    @foreach (var item in group)
                                    {
                                        <div class="sr-item" @onclick="() => NavigateTo(item.Url)">
                                            <div class="sr-item-icon" style="background:@(item.Color + "22");color:@item.Color">
                                                <MudIcon Icon="@item.Icon" Size="Size.Small" />
                                            </div>
                                            <div class="sr-item-text">
                                                <span class="sr-item-title">@item.Title</span>
                                                <span class="sr-item-sub">@item.SubTitle</span>
                                            </div>
                                            <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="Size.Small" Class="sr-item-arrow" />
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="sr-hint">
                                <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" />
                                <span>ابحث عن منتج، عميل، فاتورة، أو موظف...</span>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- يسار: أزرار + المستخدم -->
            <div class="tb-end">

                <!-- التاريخ -->
                <div class="date-chip">
                    <MudIcon Icon="@Icons.Material.Rounded.CalendarMonth" Size="Size.Small" />
                    <span>@DateTime.Now.ToString("dd MMMM, yyyy")</span>
                </div>

                <!-- Dark/Light toggle -->
                <button class="tb-icon-btn" @onclick="ToggleDarkMode"
                        title="@(_isDarkMode ? "الوضع النهاري" : "الوضع الليلي")">
                    @if (_isDarkMode)
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.LightMode" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.DarkMode" Size="Size.Small" />
                    }
                </button>

                <!-- Theme Switcher -->
                <ThemeSwitcher />

                <!-- Notifications -->
                <NotificationBell />

                <!-- معلومات المستخدم -->
                <div class="user-chip" @onclick="ToggleUserMenu">
                    <div class="user-avatar">
                        <span>@_avatarLetter</span>
                    </div>
                    <div class="user-text">
                        <span class="user-name">@_currentUserName</span>
                        <span class="user-role">@_currentUserRole</span>
                    </div>
                    <MudIcon Icon="@(_userMenuOpen
                                 ? Icons.Material.Rounded.KeyboardArrowUp
                                 : Icons.Material.Rounded.KeyboardArrowDown)"
                             Size="Size.Small"
                             Class="user-arrow" />
                </div>

                <!-- زر تسجيل الخروج المنفصل -->
                <button class="tb-icon-btn logout-btn" @onclick="Logout" title="تسجيل الخروج">
                    <MudIcon Icon="@Icons.Material.Rounded.Logout" Size="Size.Small" />
                </button>

                <MudPopover Open="_userMenuOpen"
                            AnchorOrigin="Origin.BottomLeft"
                            TransformOrigin="Origin.TopLeft"
                            Class="user-popover">
                    <MudList T="string" Dense="true" Class="user-menu-list">
                        <MudListItem Icon="@Icons.Material.Rounded.Person"
                                     OnClick='() => Navigation.NavigateTo("/my-attendance")'>
                            الملف الشخصي
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Rounded.Lock"
                                     OnClick='() => Navigation.NavigateTo("/account/change-password")'>
                            تغيير كلمة السر
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Rounded.Settings"
                                     OnClick='() => Navigation.NavigateTo("/")'>
                            الإعدادات
                        </MudListItem>
                    </MudList>
                </MudPopover>
            </div>
        </div>
    </MudAppBar>

    <!-- ================= SIDEBAR ================= -->
    <MudDrawer @bind-Open="_drawerOpen"
               Class="erp-sidebar"
               Width="280px"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Anchor="Anchor.Right">

        <SidebarNav CurrentUser="_currentUser" />

    </MudDrawer>

    <!-- ================= MAIN CONTENT ================= -->
    <MudMainContent Class="main-body">

        <!-- Breadcrumbs -->
        <div class="content-breadcrumbs">
            <MudBreadcrumbs Items="_breadcrumbs" Separator="/" />
        </div>

        <!-- Page Content -->
        <div class="page-content">
            @Body
        </div>

        <!-- Footer -->
        <footer class="erp-footer">
            <div class="footer-content">
                <span class="footer-copy">© 2026 COCOBOLO ERP — جميع الحقوق محفوظة</span>
                <div class="footer-links">
                    <a href="#">سياسة الخصوصية</a>
                    <a href="#">الشروط والأحكام</a>
                    <a href="#">الدعم الفني</a>
                </div>
            </div>
        </footer>

    </MudMainContent>

</MudLayout>

