@inherits LayoutComponentBase
@implements IDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.Components.Shared
@using COCOBOLOERPNEW.Services

@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme"
                  @bind-IsDarkMode="_isDarkMode"
                  @bind-IsDarkMode:after="StateHasChanged" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@($"erp-shell {(_isDarkMode ? "dark-mode" : "light-mode")}")" dir="rtl">

    <!-- ================= TOP BAR ================= -->
    <MudAppBar Elevation="0" Fixed="true" Class="erp-topbar">
        <div class="tb-row">

            <!-- يمين: زر القائمة + البراند -->
            <div class="tb-start">
                <button class="menu-toggle" @onclick="ToggleDrawer">
                    @if (_drawerOpen)
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.MenuOpen" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.Menu" />
                    }
                </button>

                <div class="brand" @onclick='() => Navigation.NavigateTo("/")'>
                    <img src="logo.png" class="brand-logo" alt="Logo" />
                    <div class="brand-name">COCOBOLO<span class="brand-suffix">ERP</span></div>
                </div>
            </div>

            <!-- وسط: البحث -->
            <div class="tb-center">
                <div class="search-wrapper">
                    <MudIcon Icon="@Icons.Material.Rounded.Search" Class="search-icon" />
                    <input type="text"
                           @bind="_searchText"
                           @bind:event="oninput"
                           placeholder="بحث سريع..."
                           class="search-input" />
                </div>
            </div>

            <!-- يسار: أزرار + المستخدم -->
            <div class="tb-end">

                <!-- التاريخ -->
                <div class="date-chip">
                    <MudIcon Icon="@Icons.Material.Rounded.CalendarMonth" Size="Size.Small" />
                    <span>@DateTime.Now.ToString("dd MMMM, yyyy")</span>
                </div>

                <!-- Dark/Light toggle -->
                <button class="tb-icon-btn" @onclick="ToggleDarkMode"
                        title="@(_isDarkMode ? "الوضع النهاري" : "الوضع الليلي")">
                    @if (_isDarkMode)
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.LightMode" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Rounded.DarkMode" Size="Size.Small" />
                    }
                </button>

                <!-- Theme Switcher -->
                <ThemeSwitcher />

                <!-- Notifications -->
                <NotificationBell />

                <!-- معلومات المستخدم -->
                <div class="user-chip" @onclick="ToggleUserMenu">
                    <div class="user-avatar">
                        <span>@_avatarLetter</span>
                    </div>
                    <div class="user-text">
                        <span class="user-name">@_currentUserName</span>
                        <span class="user-role">@_currentUserRole</span>
                    </div>
                    <MudIcon Icon="@(_userMenuOpen
                                 ? Icons.Material.Rounded.KeyboardArrowUp
                                 : Icons.Material.Rounded.KeyboardArrowDown)"
                             Size="Size.Small"
                             Class="user-arrow" />
                </div>

                <!-- زر تسجيل الخروج المنفصل -->
                <button class="tb-icon-btn logout-btn" @onclick="Logout" title="تسجيل الخروج">
                    <MudIcon Icon="@Icons.Material.Rounded.Logout" Size="Size.Small" />
                </button>

                <MudPopover Open="_userMenuOpen"
                            AnchorOrigin="Origin.BottomLeft"
                            TransformOrigin="Origin.TopLeft"
                            Class="user-popover">
                    <MudList T="string" Dense="true" Class="user-menu-list">
                        <MudListItem Icon="@Icons.Material.Rounded.Person"
                                     OnClick='() => Navigation.NavigateTo("/profile")'>
                            الملف الشخصي
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Rounded.Lock"
                                     OnClick='() => Navigation.NavigateTo("/change-password")'>
                            تغيير كلمة السر
                        </MudListItem>
                        <MudListItem Icon="@Icons.Material.Rounded.Settings"
                                     OnClick='() => Navigation.NavigateTo("/settings")'>
                            الإعدادات
                        </MudListItem>
                    </MudList>
                </MudPopover>
            </div>
        </div>
    </MudAppBar>

    <!-- ================= SIDEBAR ================= -->
    <MudDrawer @bind-Open="_drawerOpen"
               Class="erp-sidebar"
               Width="280px"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Anchor="Anchor.Right">

        <SidebarNav CurrentUser="_currentUser" />

    </MudDrawer>

    <!-- ================= MAIN CONTENT ================= -->
    <MudMainContent Class="main-body">

        <!-- Breadcrumbs -->
        <div class="content-breadcrumbs">
            <MudBreadcrumbs Items="_breadcrumbs" Separator="/" />
        </div>

        <!-- Page Content -->
        <div class="page-content">
            @Body
        </div>

        <!-- Footer -->
        <footer class="erp-footer">
            <div class="footer-content">
                <span class="footer-copy">© 2026 COCOBOLO ERP — جميع الحقوق محفوظة</span>
                <div class="footer-links">
                    <a href="#">سياسة الخصوصية</a>
                    <a href="#">الشروط والأحكام</a>
                    <a href="#">الدعم الفني</a>
                </div>
            </div>
        </footer>

    </MudMainContent>

</MudLayout>

@code {
    private const string DarkModeKey = "cocobolo.darkMode";

    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _userMenuOpen;
    private string _searchText = "";
    private string _currentUserName = "";
    private string _currentUserRole = "";
    private string _avatarLetter = "U";
    private ClaimsPrincipal? _currentUser;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private EventHandler<LocationChangedEventArgs>? _locationHandler;

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary           = "#1E293B",
            PrimaryContrastText = "#FFFFFF",
            PrimaryDarken     = "#0F172A",
            PrimaryLighten    = "#334155",

            Secondary         = "#D4AF37",
            SecondaryContrastText = "#FFFFFF",

            Success           = "#10B981",
            SuccessContrastText = "#FFFFFF",
            Warning           = "#F59E0B",
            WarningContrastText = "#FFFFFF",
            Error             = "#EF4444",
            ErrorContrastText = "#FFFFFF",
            Info              = "#3B82F6",
            InfoContrastText  = "#FFFFFF",

            Background       = "#F4F6F9",
            BackgroundGray   = "#E2E8F0",
            Surface          = "#FFFFFF",

            DrawerBackground  = "#0A1628",
            DrawerText        = "#CBD5E1",
            DrawerIcon        = "#D4AF37",
            AppbarBackground  = "#0A1628",
            AppbarText        = "#CBD5E1",

            TextPrimary       = "#1E293B",
            TextSecondary     = "#64748B",
            TextDisabled      = "#CBD5E1",

            LinesDefault      = "#E2E8F0",
            LinesInputs       = "#CBD5E1",
            TableLines        = "#E2E8F0",
            Divider           = "#E2E8F0",

            ActionDefault     = "#64748B",
            ActionDisabled    = "#CBD5E1",
            ActionDisabledBackground = "#F1F5F9",

            HoverOpacity      = 0.06,
            RippleOpacity     = 0.1,
            RippleOpacitySecondary = 0.1,

            OverlayDark       = "rgba(15, 23, 42, 0.5)",
            OverlayLight      = "rgba(255, 255, 255, 0.7)",

            GrayDefault       = "#94A3B8",
            GrayLight         = "#CBD5E1",
            GrayLighter       = "#E2E8F0",
            GrayDark          = "#475569",
            GrayDarker        = "#1E293B",

            Dark              = "#1E293B",
            DarkContrastText  = "#FFFFFF",
            DarkLighten       = "#334155",
            DarkDarken        = "#0F172A",

            White             = "#FFFFFF",
            Black             = "#0F172A",
        },

        PaletteDark = new PaletteDark()
        {
            Primary           = "#CBD5E1",
            PrimaryContrastText = "#0F172A",
            PrimaryDarken     = "#94A3B8",
            PrimaryLighten    = "#E2E8F0",

            Secondary         = "#D4AF37",
            SecondaryContrastText = "#0F172A",

            Success           = "#10B981",
            SuccessContrastText = "#FFFFFF",
            Warning           = "#F59E0B",
            WarningContrastText = "#0F172A",
            Error             = "#EF4444",
            ErrorContrastText = "#FFFFFF",
            Info              = "#3B82F6",
            InfoContrastText  = "#FFFFFF",

            Background        = "#0B1220",
            BackgroundGray    = "#162033",
            Surface           = "#1A2744",

            DrawerBackground  = "#070D1A",
            DrawerText        = "#94A3B8",
            DrawerIcon        = "#D4AF37",
            AppbarBackground  = "#070D1A",
            AppbarText        = "#E2E8F0",

            TextPrimary       = "#F1F5F9",
            TextSecondary     = "#94A3B8",
            TextDisabled      = "#475569",

            LinesDefault      = "#1E3456",
            LinesInputs       = "#2A4068",
            TableLines        = "#1E3456",
            Divider           = "#1E3456",

            ActionDefault     = "#94A3B8",
            ActionDisabled    = "#475569",
            ActionDisabledBackground = "#1E293B",

            HoverOpacity      = 0.08,
            RippleOpacity     = 0.1,
            RippleOpacitySecondary = 0.1,

            OverlayDark       = "rgba(0, 0, 0, 0.7)",
            OverlayLight      = "rgba(30, 41, 59, 0.7)",

            GrayDefault       = "#64748B",
            GrayLight         = "#475569",
            GrayLighter       = "#334155",
            GrayDark          = "#94A3B8",
            GrayDarker        = "#CBD5E1",

            Dark              = "#070D1A",
            DarkContrastText  = "#F1F5F9",
            DarkLighten       = "#1A2744",
            DarkDarken        = "#040812",

            White             = "#F1F5F9",
            Black             = "#020617",
        },

        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Helvetica Neue", "Helvetica", "Arial", "sans-serif" },
                FontSize   = "0.9rem",
                LineHeight = "1.6",
            },
            H1 = new H1Typography() { FontSize = "2rem",    FontWeight = "800" },
            H2 = new H2Typography() { FontSize = "1.75rem", FontWeight = "700" },
            H3 = new H3Typography() { FontSize = "1.5rem",  FontWeight = "700" },
            H4 = new H4Typography() { FontSize = "1.25rem", FontWeight = "600" },
            H5 = new H5Typography() { FontSize = "1rem",    FontWeight = "600" },
            H6 = new H6Typography() { FontSize = "0.875rem",FontWeight = "600" },
            Body1 = new Body1Typography() { FontSize = "0.9rem",  LineHeight = "1.6" },
            Body2 = new Body2Typography() { FontSize = "0.8rem",  LineHeight = "1.5" },
            Button = new ButtonTypography() { FontSize = "0.875rem", FontWeight = "600", TextTransform = "none" },
            Caption = new CaptionTypography() { FontSize = "0.75rem" },
        },

        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "10px",
            DrawerWidthRight    = "280px",
            DrawerWidthLeft     = "280px",
            AppbarHeight        = "64px",
        }
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User;

        if (_currentUser.Identity?.IsAuthenticated == true)
        {
            _currentUserName = _currentUser.Identity.Name ?? "";
            _currentUserRole = _currentUser.FindFirst(ClaimTypes.Role)?.Value ?? "User";
            _avatarLetter = string.IsNullOrEmpty(_currentUserName)
                ? "U"
                : _currentUserName[..1].ToUpper();
        }

        UpdateBreadcrumbs();

        _locationHandler = (_, _) =>
        {
            UpdateBreadcrumbs();
            InvokeAsync(StateHasChanged);
        };

        Navigation.LocationChanged += _locationHandler;
    }

    public void Dispose()
    {
        if (_locationHandler != null)
            Navigation.LocationChanged -= _locationHandler;
    }

    private void UpdateBreadcrumbs()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.ToLower();

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("الرئيسية", href: "/", icon: Icons.Material.Rounded.Home)
        };

        if      (path.StartsWith("/products"))       _breadcrumbs.Add(new("المنتجات",        href: null, disabled: true));
        else if (path.StartsWith("/customers"))      _breadcrumbs.Add(new("العملاء",         href: null, disabled: true));
        else if (path.StartsWith("/sales-invoices")) _breadcrumbs.Add(new("فواتير المبيعات", href: null, disabled: true));
        else if (path.StartsWith("/expenses"))       _breadcrumbs.Add(new("المصروفات",       href: null, disabled: true));
        else if (path.StartsWith("/employees"))      _breadcrumbs.Add(new("الموظفين",        href: null, disabled: true));
        else if (path.StartsWith("/payroll"))        _breadcrumbs.Add(new("الرواتب",         href: null, disabled: true));
        else if (path.StartsWith("/cashbox"))        _breadcrumbs.Add(new("الخزينة",         href: null, disabled: true));
        else if (path.StartsWith("/crm"))            _breadcrumbs.Add(new("CRM",             href: null, disabled: true));
        else if (path.StartsWith("/reports"))        _breadcrumbs.Add(new("التقارير",        href: null, disabled: true));
        else if (path.StartsWith("/admin"))          _breadcrumbs.Add(new("إدارة النظام",    href: null, disabled: true));
        else if (path.StartsWith("/complaints"))     _breadcrumbs.Add(new("الشكاوى",         href: null, disabled: true));
        else if (path.StartsWith("/analytics"))      _breadcrumbs.Add(new("تحليلات",        href: null, disabled: true));
        else if (path.StartsWith("/shifts"))         _breadcrumbs.Add(new("الشيفتات",        href: null, disabled: true));
        else if (path.StartsWith("/payments"))       _breadcrumbs.Add(new("المدفوعات",       href: null, disabled: true));
        else if (path.StartsWith("/notifications"))  _breadcrumbs.Add(new("الإشعارات",       href: null, disabled: true));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var saved = await JS.InvokeAsync<string>(
                    "localStorage.getItem", DarkModeKey);
                _isDarkMode = saved == "true";

                await JS.InvokeVoidAsync("eval",
                    _isDarkMode
                    ? "document.body.classList.add('dark-mode'); document.body.classList.remove('light-mode');"
                    : "document.body.classList.add('light-mode'); document.body.classList.remove('dark-mode');");

                StateHasChanged();
            }
            catch { }
        }
    }

    private void ToggleDrawer()   => _drawerOpen   = !_drawerOpen;

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem",
              DarkModeKey, _isDarkMode.ToString().ToLower());
        await JS.InvokeVoidAsync("eval",
              _isDarkMode
              ? "document.body.classList.add('dark-mode'); document.body.classList.remove('light-mode');"
              : "document.body.classList.add('light-mode'); document.body.classList.remove('dark-mode');");
    }

    private void ToggleUserMenu() => _userMenuOpen = !_userMenuOpen;

    private async Task Logout()
    {
        _userMenuOpen = false;
        await JS.InvokeVoidAsync("cocoboloAuth.logout");
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
