@inherits LayoutComponentBase
@implements IDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.Components.Shared
@using COCOBOLOERPNEW.Services

@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS

<MudThemeProvider Theme="_theme" 
                  @bind-IsDarkMode="_isDarkMode"
                  @bind-IsDarkMode:after="StateHasChanged" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="erp-shell" dir="rtl">

    <!-- ================= TOP BAR ================= -->
    <MudAppBar Elevation="0" Fixed="true" Class="erp-topbar">
        <div class="tb-row">

            <!-- يسار: زر القائمة + البراند -->
            <div class="tb-start">
                <MudIconButton Icon="@(_drawerOpen
                                   ? Icons.Material.Rounded.MenuOpen
                                   : Icons.Material.Rounded.Menu)"
                               OnClick="ToggleDrawer"
                               Color="Color.Primary"
                               Size="Size.Large" />

                <div class="brand" @onclick='() => Navigation.NavigateTo("/")'>
                    <img src="logo.png" class="brand-logo" alt="Logo" />
                    <div class="brand-name">COCOBOLO ERP</div>
                </div>
            </div>

            <!-- وسط: البحث -->
            <div class="tb-center">
                <MudTextField T="string"
                              @bind-Value="_searchText"
                              Placeholder="بحث..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Rounded.Search"
                              Immediate="true"
                              Color="Color.Primary"
                              Class="search-field" />
            </div>

            <!-- يمين: أزرار + المستخدم -->
            <div class="tb-end">
                <MudIconButton Icon="@(_isDarkMode
               ? Icons.Material.Rounded.LightMode
               : Icons.Material.Rounded.DarkMode)"
               OnClick="ToggleDarkMode"
               Color="Color.Primary"
               Size="Size.Medium"
               Title="@(_isDarkMode ? "الوضع النهاري" : "الوضع الليلي")" />

                <NotificationBell />

                <!-- معلومات المستخدم -->
                <div class="user-chip" @onclick="ToggleUserMenu">
                    <div class="user-avatar">
                        <span>@_avatarLetter</span>
                    </div>
                    <div class="user-text">
                        <span class="user-name">@_currentUserName</span>
                        <span class="user-role">@_currentUserRole</span>
                    </div>
                    <MudIcon Icon="@(_userMenuOpen
                                 ? Icons.Material.Rounded.KeyboardArrowUp
                                 : Icons.Material.Rounded.KeyboardArrowDown)"
                             Size="Size.Small"
                             Class="user-arrow" />
                </div>

                <MudPopover Open="_userMenuOpen"
                            AnchorOrigin="Origin.BottomLeft"
                            TransformOrigin="Origin.TopLeft"
                            Class="user-popover">
                    <MudList T="string" Dense="true" Class="user-menu-list">
                        <MudListItem Icon="@Icons.Material.Rounded.Lock"
                                     OnClick='() => Navigation.NavigateTo("/change-password")'>
                            تغيير كلمة السر
                        </MudListItem>
                        <MudDivider Class="my-1" />
                        <MudListItem Icon="@Icons.Material.Rounded.Logout"
                                     IconColor="Color.Error"
                                     OnClick="Logout">
                            تسجيل الخروج
                        </MudListItem>
                    </MudList>
                </MudPopover>
            </div>
        </div>
    </MudAppBar>

    <!-- ================= BREADCRUMBS ================= -->
    <div class="breadcrumbs-bar">
        <MudBreadcrumbs Items="_breadcrumbs" Separator=">">
            <ItemTemplate Context="item">
                <MudLink Href="@item.Href">
                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <MudIcon Icon="@item.Icon" Size="Size.Small" Style="margin-left:4px;" />
                    }
                    @item.Text
                </MudLink>
            </ItemTemplate>
        </MudBreadcrumbs>
    </div>

    <!-- ================= SIDEBAR ================= -->
    <MudDrawer @bind-Open="_drawerOpen"
               Class="erp-sidebar"
               Width="280px"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Anchor="Anchor.Right">

        <!-- بحث القوائم -->
        <div class="sidebar-search">
            <MudTextField T="string"
                          @bind-Value="_sidebarSearchText"
                          Placeholder="ابحث في القوائم..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search"
                          Immediate="true"
                          Clearable="true"
                          Class="sidebar-search-field" />
        </div>

        <MudNavMenu Dense="false" Class="nav-menu">

            @* ========== الرئيسية ========== *@
            @if (HasPermission("frmDashboard", "View") && IsVisible("الرئيسية"))
            {
                <MudNavLink Href="/" Icon="@Icons.Material.Rounded.SpaceDashboard"
                            Match="NavLinkMatch.All">
                    الرئيسية
                </MudNavLink>
            }

            @* ========== البيانات الأساسية ========== *@
            @if (HasAnyViewPermission("frm_CompanyInfo", "frm_ProductGroups")
                && IsGroupVisible("البيانات الأساسية","بيانات الشركة"))
            {
                <MudNavGroup Title="البيانات الأساسية"
                             Icon="@Icons.Material.Rounded.Dataset"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_CompanyInfo", "View") && IsVisible("بيانات الشركة"))
                    {
                        <MudNavLink Href="/company">بيانات الشركة</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== المبيعات ========== *@
            @if (HasAnyViewPermission("frm_Parties","frm_PartiesList","frm_Products","frm_SalesInvoiveNew","frm_SalesInvoiveView","frm_PartiesInvoices","frm_Payments","frm_PaymentsInvoicesNew","frm_ApproveDiscount","frmInspectionCharge","frm_SupplierInvoices","frmInvoiceDeliveryStatus")
                && IsGroupVisible("المبيعات","كافة المنتجات","إضافة عميل","مورد","كافة العملاء","الموردين","فاتورة مبيعات","فاتورة مبيعات جديدة","فواتير العملاء","فواتير الموردين","المدفوعات","مدفوعات الفواتير","خصم","خصم على الفاتورة","رسوم المعاينة","فواتير الشراء","متابعة التسليم","تسليم"))
            {
                <MudNavGroup Title="المبيعات"
                             Icon="@Icons.Material.Rounded.Storefront"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_ProductList", "View") && IsVisible("كافة المنتجات"))
                    {
                        <MudNavLink Href="/products">كافة المنتجات</MudNavLink>
                    }
                    @if (HasPermission("frm_PartiesList", "View") && IsVisible("كافة العملاء","الموردين","عملاء"))
                    {
                        <MudNavLink Href="/customers"> العملاء </MudNavLink>
                    }
                    @if (HasPermission("frm_SalesInvoiveNew", "View") && IsVisible("فاتورة مبيعات","فاتورة جديدة","مبيعات"))
                    {
                        <MudNavLink Href="/sales-invoices/new">فاتورة مبيعات جديدة</MudNavLink>
                    }
                    @if (HasPermission("frm_PartiesInvoices", "View") && IsVisible("فواتير العملاء","فواتير الموردين","فواتير"))
                    {
                        <MudNavLink Href="/customer-invoices">فواتير العملاء والموردين</MudNavLink>
                    }
                    @if (HasPermission("frm_Payments", "View") && IsVisible("المدفوعات","دفع"))
                    {
                        <MudNavLink Href="/payments">المدفوعات</MudNavLink>
                    }
                    @if (HasPermission("frm_PaymentsInvoicesNew", "View") && IsVisible("مدفوعات الفواتير","دفع فاتورة"))
                    {
                        <MudNavLink Href="/payments/invoices">مدفوعات الفواتير</MudNavLink>
                    }
                    @if (HasPermission("frm_ApproveDiscount", "View") && IsVisible("خصم","خصم على الفاتورة"))
                    {
                        <MudNavLink Href="/discounts">خصم على الفاتورة</MudNavLink>
                    }
                    @if (HasPermission("frmInspectionCharge", "View") && IsVisible("رسوم المعاينة","معاينة","رسوم"))
                    {
                        <MudNavLink Href="/inspection-charge">رسوم المعاينة</MudNavLink>
                    }
                    @if (HasPermission("frm_SupplierInvoices", "View") && IsVisible("فواتير الشراء","شراء","مورد"))
                    {
                        <MudNavLink Href="/supplier-invoices">فواتير الشراء</MudNavLink>
                    }
                    @if (HasPermission("frmInvoiceDeliveryStatus", "View") && IsVisible("متابعة التسليم","تسليم"))
                    {
                        <MudNavLink Href="/delivery-status">متابعة التسليم</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== المشتريات والمخزون ========== *@
            @if (HasAnyViewPermission("frm_StockLevels","frm_Bestsellingitems")
                && IsGroupVisible("المشتريات والمخزون","المشتريات","المخزون","رصيد المخزن","الاكثر مبيعا"))
            {
                <MudNavGroup Title="المشتريات والمخزون"
                             Icon="@Icons.Material.Rounded.Inventory"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_StockLevels", "View") && IsVisible("رصيد المخزن","مخزن","رصيد"))
                    {
                        <MudNavLink Href="/stock-levels">رصيد المخزن</MudNavLink>
                    }
                    @if (HasPermission("frm_Bestsellingitems", "View") && IsVisible("الاكثر مبيعا","مبيعات","الاكثر"))
                    {
                        <MudNavLink Href="/best-selling">الأكثر مبيعًا</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== المصروفات ========== *@
            @if (HasAnyViewPermission("frm_Expenses","frm_ExpensesList","frm_ExpensesGroup","frmExpenseTree")
                && IsGroupVisible("المصروفات","إضافة مصروف","مصروف جديد","كافة المصروفات","مجموعات المصروفات","شجرة حسابات"))
            {
                <MudNavGroup Title="المصروفات"
                             Icon="@Icons.Material.Rounded.MoneyOff"
                             Expanded="@_isSearching">
                    
                    @if (HasPermission("frm_ExpensesList", "View") && IsVisible("كافة المصروفات","المصروفات"))
                    {
                        <MudNavLink Href="/expenses"> المصروفات</MudNavLink>
                    }
                    @if (HasPermission("frm_ExpensesGroup", "View") && IsVisible("مجموعات المصروفات","مجموعات"))
                    {
                        <MudNavLink Href="/expense-groups">مجموعات المصروفات</MudNavLink>
                    }
                    @if (HasPermission("frmExpenseTree", "View") && IsVisible("شجرة حسابات","شجرة"))
                    {
                        <MudNavLink Href="/expense-tree">شجرة حسابات المصروفات</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== الخزينة ========== *@
            @if (HasAnyViewPermission("frm_CashBoxManual","frm_CashBoxTransaction","frm_TotalInOutNetCashBox","frm_CashFlowNew")
                && IsGroupVisible("الخزينة","سندات قبض","سندات صرف","سندات","حركات الخزينة","إجمالي المقبوضات","التدفقات النقدية","تدفقات"))
            {
                <MudNavGroup Title="الخزينة"
                             Icon="@Icons.Material.Rounded.AccountBalanceWallet"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_CashBoxManual", "View") && IsVisible("سندات قبض","سندات صرف","سندات"))
                    {
                        <MudNavLink Href="/cashbox/manual">سندات قبض وصرف</MudNavLink>
                    }
                    @if (HasPermission("frm_CashBoxTransaction", "View") && IsVisible("حركات الخزينة","حركات"))
                    {
                        <MudNavLink Href="/cashbox/transactions">حركات الخزينة</MudNavLink>
                    }
                    @if (HasPermission("frm_TotalInOutNetCashBox", "View") && IsVisible("إجمالي المقبوضات","المدفوعات","إجمالي"))
                    {
                        <MudNavLink Href="/cashbox/summary">إجمالي المقبوضات/المدفوعات</MudNavLink>
                    }
                    @if (HasPermission("frm_CashFlowNew", "View") && IsVisible("التدفقات النقدية","تدفقات"))
                    {
                        <MudNavLink Href="/cash-flow">قائمة التدفقات النقدية</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== الموظفين والرواتب ========== *@
            @if (HasAnyViewPermission("frm_Employees","frm_Employeeslist","frm_Payroll","frm_PayrollPayment","frmPayrollProcessor","frmPayrollReport","frm_EmpolyeeShifts","frm_AllShifts","frm_MySchedule","frm_ImportBiometric","frm_empAttendance","frmDailyExemptions","frm_MyPermissions")
                && IsGroupVisible("الموظفين والرواتب","الموظفين","الرواتب","إضافة موظف","كافة الموظفين","تسجيل راتب","راتب جماعي","شيفت","البصمة","استثناءات","إذن","حضور"))
            {
                <MudNavGroup Title="الموظفين والرواتب"
                             Icon="@Icons.Material.Rounded.People"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_Employees", "View") && IsVisible("إضافة موظف","موظف جديد","موظف"))
                    {
                        <MudNavLink Href="/employees/new">إضافة موظف</MudNavLink>
                    }
                    @if (HasPermission("frm_Employeeslist", "View") && IsVisible("كافة الموظفين","الموظفين"))
                    {
                        <MudNavLink Href="/employees">كافة الموظفين</MudNavLink>
                    }
                    @if (HasPermission("frm_Payroll", "View") && IsVisible("تسجيل راتب","راتب"))
                    {
                        <MudNavLink Href="/payroll/new">تسجيل راتب</MudNavLink>
                    }
                    @if (HasPermission("frm_PayrollPayment", "View") && IsVisible("مدفوعات الرواتب","رواتب"))
                    {
                        <MudNavLink Href="/payroll/payments">مدفوعات الرواتب</MudNavLink>
                    }
                    @if (HasPermission("frmPayrollProcessor", "View") && IsVisible("راتب جماعي","جماعي"))
                    {
                        <MudNavLink Href="/payroll/batch">راتب جماعي</MudNavLink>
                    }
                    @if (HasPermission("frmPayrollReport", "View") && IsVisible("الاستعلام عن الرواتب","استعلام"))
                    {
                        <MudNavLink Href="/payroll/report">الاستعلام عن الرواتب</MudNavLink>
                    }
                    @if (HasPermission("frm_EmpolyeeShifts", "View") && IsVisible("إضافة شيفت","شيفت"))
                    {
                        <MudNavLink Href="/shifts/new">إضافة شيفت</MudNavLink>
                    }
                    @if (HasPermission("frm_AllShifts", "View") && IsVisible("متابعة الشيفتات","شيفتات"))
                    {
                        <MudNavLink Href="/shifts">متابعة الشيفتات</MudNavLink>
                    }
                    @if (HasPermission("frm_MySchedule", "View") && IsVisible("شيفتاتي","جدولي"))
                    {
                        <MudNavLink Href="/my-schedule">شيفتاتي</MudNavLink>
                    }
                    @if (HasPermission("frm_ImportBiometric", "View") && IsVisible("البصمة","بصمة"))
                    {
                        <MudNavLink Href="/biometric">البصمة</MudNavLink>
                    }
                    @if (HasPermission("frm_empAttendance", "View") && IsVisible("بصمة الموظف","حضور","بصمة"))
                    {
                        <MudNavLink Href="/attendance">بصمة الموظف</MudNavLink>
                    }
                    @if (HasPermission("frmDailyExemptions", "View") && IsVisible("استثناءات"))
                    {
                        <MudNavLink Href="/exemptions">استثناءات</MudNavLink>
                    }
                    @if (HasPermission("frm_MyPermissions", "View") && IsVisible("طلب إذن","إذن"))
                    {
                        <MudNavLink Href="/my-permissions">طلب إذن</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== CRM ========== *@
            @if (HasAnyViewPermission("frmNewInteraction","frmDailyTasks","frmSalesPipeline","frmClientCard","frmNewQuotation","frmQuotationsList","frmInteractionsLog","frmCustomerProduct","frmManamgerSales","frmCustomerDocs","frm_Commissions")
                && IsGroupVisible("CRM","تواصل","مهام المتابعة","مراحل البيع","بطاقة العميل","عرض سعر","عروض الاسعار","سجل التواصلات","التعاقد","متابعة المدير","مستندات العميل","العمولات"))
            {
                <MudNavGroup Title="CRM"
                             Icon="@Icons.Material.Rounded.ContactPhone"
                             Expanded="@_isSearching">
                    @if (HasPermission("frmNewInteraction", "View") && IsVisible("تواصل جديد","تواصل"))
                    {
                        <MudNavLink Href="/crm/interactions/new">تواصل جديد</MudNavLink>
                    }
                    @if (HasPermission("frmDailyTasks", "View") && IsVisible("مهام المتابعة","مهام"))
                    {
                        <MudNavLink Href="/crm/tasks">مهام المتابعة</MudNavLink>
                    }
                    @if (HasPermission("frmSalesPipeline", "View") && IsVisible("مراحل البيع","pipeline"))
                    {
                        <MudNavLink Href="/crm/pipeline">مراحل البيع</MudNavLink>
                    }
                    @if (HasPermission("frmClientCard", "View") && IsVisible("بطاقة العميل","عميل"))
                    {
                        <MudNavLink Href="/crm/clients">بطاقة العميل</MudNavLink>
                    }
                    @if (HasPermission("frmNewQuotation", "View") && IsVisible("عرض سعر جديد","عرض سعر"))
                    {
                        <MudNavLink Href="/crm/quotations/new">عرض سعر جديد</MudNavLink>
                    }
                    @if (HasPermission("frmQuotationsList", "View") && IsVisible("عروض الاسعار","عروض"))
                    {
                        <MudNavLink Href="/crm/quotations">عروض الأسعار</MudNavLink>
                    }
                    @if (HasPermission("frmInteractionsLog", "View") && IsVisible("سجل التواصلات","تواصلات"))
                    {
                        <MudNavLink Href="/crm/interactions">سجل التواصلات</MudNavLink>
                    }
                    @if (HasPermission("frmCustomerProduct", "View") && IsVisible("التعاقد","عقد"))
                    {
                        <MudNavLink Href="/crm/contract">التعاقد</MudNavLink>
                    }
                    @if (HasPermission("frmManamgerSales", "View") && IsVisible("متابعة المدير","مدير"))
                    {
                        <MudNavLink Href="/crm/manager">متابعة المدير</MudNavLink>
                    }
                    @if (HasPermission("frmCustomerDocs", "View") && IsVisible("مستندات العميل","مستندات"))
                    {
                        <MudNavLink Href="/crm/documents">مستندات العميل</MudNavLink>
                    }
                    @if (HasPermission("frm_Commissions", "View") && IsVisible("العمولات","عمولة"))
                    {
                        <MudNavLink Href="/crm/commissions">العمولات</MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ========== إدارة النظام ========== *@
            @if (HasAnyViewPermission("frm_AllUsers","frm_AddUser","frm_AddPermission","frmManagePermissions","Frm_MainList_Edit","frm_NotificationsAll","frm_ChangePassword","frm_AuditViewer","frmContactSourses","frmSalesStages","frmInterestCategories","frmContactStatus","frmTaskTypes","frmLostReasons","frmAdCampain","frm_PricingMargins","frm_PriceRequests","frm_PriceHistory","frm_PricingHistory")
                && IsGroupVisible("إدارة النظام","المستخدمين","إضافة مستخدم","الصلاحيات","ربط الصلاحيات","قوائم الشاشة","الإشعارات","اشعارات","تغيير كلمة السر","كلمة المرور","متابعة النظام","مصادر العملاء","نسب الربح","طلبات تعديل الاسعار","تاريخ الاسعار"))
            {
                <MudNavGroup Title="إدارة النظام"
                             Icon="@Icons.Material.Rounded.Settings"
                             Expanded="@_isSearching">
                    @if (HasPermission("frm_AllUsers", "View") && IsVisible("المستخدمين","مستخدم"))
                    {
                        <MudNavLink Href="/admin/users">المستخدمين</MudNavLink>
                    }
                    @if (HasPermission("frm_AddUser", "View") && IsVisible("إضافة مستخدم","مستخدم جديد"))
                    {
                        <MudNavLink Href="/admin/users/new">إضافة مستخدم</MudNavLink>
                    }
                    @if (HasPermission("frm_AddPermission", "View") && IsVisible("الصلاحيات","صلاحية"))
                    {
                        <MudNavLink Href="/admin/permissions">الصلاحيات</MudNavLink>
                    }
                    @if (HasPermission("frmManagePermissions", "View") && IsVisible("ربط الصلاحيات"))
                    {
                        <MudNavLink Href="/admin/permissions/manage">ربط الصلاحيات</MudNavLink>
                    }
                    @if (HasPermission("Frm_MainList_Edit", "View") && IsVisible("قوائم الشاشة","قوائم"))
                    {
                        <MudNavLink Href="/admin/menu">قوائم الشاشة الرئيسية</MudNavLink>
                    }
                    @if (HasPermission("frm_NotificationsAll", "View") && IsVisible("الإشعارات","اشعارات"))
                    {
                        <MudNavLink Href="/notifications">الإشعارات</MudNavLink>
                    }
                    @if (HasPermission("frm_ChangePassword", "View") && IsVisible("تغيير كلمة السر","كلمة المرور"))
                    {
                        <MudNavLink Href="/change-password">تغيير كلمة السر</MudNavLink>
                    }
                    @if (HasPermission("frm_AuditViewer", "View") && IsVisible("متابعة النظام","audit"))
                    {
                        <MudNavLink Href="/admin/audit">متابعة النظام</MudNavLink>
                    }
                    @if (HasPermission("frmContactSourses", "View") && IsVisible("مصادر العملاء","مصادر"))
                    {
                        <MudNavLink Href="/admin/sources">مصادر العملاء</MudNavLink>
                    }
                    @if (HasPermission("frmSalesStages", "View") && IsVisible("مراحل البيع","مراحل"))
                    {
                        <MudNavLink Href="/admin/sales-stages">مراحل البيع</MudNavLink>
                    }
                    @if (HasPermission("frmInterestCategories", "View") && IsVisible("فئات الاهتمام","فئات"))
                    {
                        <MudNavLink Href="/admin/interests">فئات الاهتمام</MudNavLink>
                    }
                    @if (HasPermission("frmContactStatus", "View") && IsVisible("أنواع التواصل","تواصل"))
                    {
                        <MudNavLink Href="/admin/contact-types">أنواع التواصل</MudNavLink>
                    }
                    @if (HasPermission("frmTaskTypes", "View") && IsVisible("أنواع المهام","مهام"))
                    {
                        <MudNavLink Href="/admin/task-types">أنواع المهام</MudNavLink>
                    }
