    private async Task DownloadPdf()
    {
        try
        {
            await JS.InvokeVoidAsync("open", $"/api/quotations/{_form.QuotationId}/pdf", "_blank");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر فتح الـ PDF: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenWhatsApp()
{
    var normalizedPhone = PhoneNormalizer.ToWhatsAppFormat(_whatsappPhone, _whatsappCountryCode);
    
    if (string.IsNullOrEmpty(normalizedPhone))
    {
        Snackbar.Add("رقم الواتساب غير صحيح. مثال صحيح: 01001234567", Severity.Warning);
        return;
    }

    var encodedMsg = Uri.EscapeDataString(_whatsappMessage);
    var url = $"https://api.whatsapp.com/send?phone={normalizedPhone}&text={encodedMsg}";
    
    await JS.InvokeVoidAsync("open", url, "_blank");
    _showWhatsAppDialog = false;
}

