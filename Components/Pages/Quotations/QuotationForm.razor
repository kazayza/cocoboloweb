    private static Color GetStatusColor(string status)
    {
        return status switch
        {
            QuotationStatuses.Draft => Color.Default,
            QuotationStatuses.Sent => Color.Info,
            QuotationStatuses.Accepted => Color.Success,
            QuotationStatuses.Rejected => Color.Error,
            QuotationStatuses.Converted => Color.Success,
            QuotationStatuses.Expired => Color.Warning,
            _ => Color.Default
        };
    }

    private static string GetStatusText(string status)
    {
        return QuotationStatuses.All.TryGetValue(status, out var text) ? text : status;
    }

