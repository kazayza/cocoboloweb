@page "/quotations/new"
@page "/quotations/{Id:int}"
@page "/quotations/{Id:int}/edit"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Helpers

@inject IQuotationService QuotationService
@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

@if (_isLoading)
{
    <div class="loading-container">
        <div class="loading-card">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.h6" Class="mt-4" Style="color: var(--gold);">جاري تحميل البيانات...</MudText>
        </div>
    </div>
}
else
{
    var isOverdue = _form.ValidUntil.HasValue && _form.ValidUntil.Value.Date < DateTime.Today && !_form.IsConverted;
    var daysLeft = _form.DaysUntilExpiry;

    <div class="quotation-form-page" dir="rtl">

        <!-- ============= HEADER ============= -->
        <div class="form-header">
            <div class="header-top">
                <div class="header-left">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                   Color="Color.Inherit" OnClick="GoBack" />
                    <div>
                        <h1>
                            <MudIcon Icon="@Icons.Material.Filled.RequestQuote" />
                            @(IsEdit ? (_isReadOnly ? "عرض سعر" : "تعديل عرض السعر") : "عرض سعر جديد")
                        </h1>
                        <p>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_form.Status)">
                                @GetStatusText(_form.Status)
                            </MudChip>
                            @if (isOverdue)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error"
                                         Icon="@Icons.Material.Filled.Warning">منتهي الصلاحية</MudChip>
                            }
                            @if (!string.IsNullOrEmpty(_form.ReferenceNumber))
                            {
                                <span> • @_form.ReferenceNumber</span>
                            }
                            @if (!string.IsNullOrEmpty(_form.EmpName))
                            {
                                <span> • الموظف: @_form.EmpName</span>
                            }
                        </p>
                    </div>
                </div>
                <div class="header-right">
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="GoBack"
                               StartIcon="@Icons.Material.Filled.Close">إلغاء</MudButton>

                    @if (IsEdit)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="OpenPrintPage"
                                   StartIcon="@Icons.Material.Filled.Print">طباعة</MudButton>

                        @if (!_form.IsConverted)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       OnClick="OpenWhatsAppDialog"
                                       StartIcon="@Icons.Material.Filled.Send"
                                       Style="background: #25D366 !important;">
                                إرسال واتساب
                            </MudButton>
                        }

                        @if (_isReadOnly && _canEdit && !_form.IsConverted)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                       OnClick="@(() => _isReadOnly = false)"
                                       StartIcon="@Icons.Material.Filled.Edit">تعديل</MudButton>
                        }

                        @if (!_form.IsConverted && _canEdit)
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                                       OnClick="OpenChangeStatusDialog"
                                       StartIcon="@Icons.Material.Filled.Flag">تغيير الحالة</MudButton>
                        }

                        @if (!_form.IsConverted)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       OnClick="OpenConvertDialog"
                                       StartIcon="@Icons.Material.Filled.SwapHoriz">
                                تحويل لفاتورة
                            </MudButton>
                        }
                    }

                    @if (!_isReadOnly && !_form.IsConverted)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="SaveQuotation"
                                   Disabled="@_isSaving"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Class="save-btn">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                            }
                            حفظ
                        </MudButton>
                    }
                </div>
            </div>

            <!-- ⭐ Quick Summary -->
            @if (IsEdit)
            {
                <div class="header-summary">
                    <div class="summary-pill">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        <div>
                            <span>العميل</span>
                            <strong>@(_form.PartyName ?? "-")</strong>
                        </div>
                    </div>
                    <div class="summary-pill">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                        <div>
                            <span>التاريخ</span>
                            <strong>@_form.QuotationDate.ToString("yyyy/MM/dd")</strong>
                        </div>
                    </div>
                    <div class="summary-pill pill-total">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" />
                        <div>
                            <span>الإجمالي</span>
                            <strong>@FormatMoney(_form.GrandTotal) ج</strong>
                        </div>
                    </div>
                    <div class="summary-pill">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                        <div>
                            <span>الأصناف</span>
                            <strong>@_form.Items.Count</strong>
                        </div>
                    </div>
                    @if (_form.ValidUntil.HasValue)
                    {
                        <div class="summary-pill @(isOverdue ? "pill-overdue" : (daysLeft <= 7 ? "pill-warning" : ""))">
                            <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" />
                            <div>
                                <span>الصلاحية</span>
                                <strong>
                                    @_form.ValidUntil.Value.ToString("yyyy/MM/dd")
                                    @if (daysLeft.HasValue && daysLeft.Value >= 0 && !_form.IsConverted)
                                    {
                                        <span style="font-size:0.7rem; opacity:0.85;"> (@daysLeft يوم)</span>
                                    }
                                </strong>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ⭐ تنبيهات -->
        @if (_form.IsConverted)
        {
            <MudAlert Severity="Severity.Success" Class="mb-3" Icon="@Icons.Material.Filled.CheckCircle"
                      Variant="Variant.Filled" Dense="true">
                ✅ تم تحويل عرض السعر إلى الفاتورة
                <a href="/sales/invoices/@_form.InvoiceId" style="color: white; text-decoration: underline; font-weight: 800;">
                    @_form.InvoiceReference
                </a>
                ولا يمكن تعديله.
            </MudAlert>
        }

        @if (isOverdue && !_form.IsConverted)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-3" Icon="@Icons.Material.Filled.Warning"
                      Variant="Variant.Filled" Dense="true">
                ⚠️ عرض السعر منتهي الصلاحية منذ <strong>@(Math.Abs((DateTime.Today - _form.ValidUntil!.Value.Date).Days)) يوم</strong>
            </MudAlert>
        }
        else if (daysLeft.HasValue && daysLeft.Value <= 7 && daysLeft.Value >= 0 && !_form.IsConverted)
        {
            <MudAlert Severity="Severity.Info" Class="mb-3" Icon="@Icons.Material.Filled.AccessTime" Dense="true">
                ℹ️ عرض السعر ينتهي خلال <strong>@daysLeft يوم</strong>
            </MudAlert>
        }

        <div class="form-grid">
            <!-- ============= Main Column ============= -->
            <div class="main-col">

                <!-- بيانات عرض السعر -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Description" />
                        <h3>بيانات عرض السعر</h3>
                    </div>
                    <div class="grid-2">
                        <MudTextField Value="@_form.ReferenceNumber" Label="الرقم"
                                      Variant="Variant.Outlined" ReadOnly="true"
                                      HelperText="يتم توليده تلقائياً" />

                        <MudDatePicker Date="_form.QuotationDate"
                                       DateChanged="@(d => _form.QuotationDate = d ?? DateTime.Now)"
                                       Label="تاريخ العرض" Variant="Variant.Outlined"
                                       ReadOnly="@_isReadOnly" />

                        <MudDatePicker Date="_form.ValidUntil"
                                       DateChanged="@(d => _form.ValidUntil = d)"
                                       Label="ساري لحد تاريخ"
                                       Variant="Variant.Outlined"
                                       Clearable="true"
                                       ReadOnly="@_isReadOnly" />

                        <MudSelect T="int?" @bind-Value="_form.WarehouseId"
                                   Label="المخزن (اختياري)"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   Disabled="@_isReadOnly">
                            @foreach (var w in _warehouses)
                            {
                                <MudSelectItem T="int?" Value="@((int?)w.WarehouseId)">@w.WarehouseName</MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField Value="@(_form.EmpName ?? "غير محدد")"
                                      Label="الموظف" Variant="Variant.Outlined" ReadOnly="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person" />

                        <MudSelect T="string" Value="_form.PricingType"
                                   ValueChanged="@((string v) => OnPricingTypeChanged(v))"
                                   Label="نوع التسعير الافتراضي"
                                   Variant="Variant.Outlined"
                                   Disabled="@_isReadOnly">
                            @foreach (var tier in PricingTiers.All)
                            {
                                <MudSelectItem T="string" Value="@tier.Key">@tier.Value</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                </MudPaper>

                <!-- العميل -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                        <h3>العميل</h3>
                    </div>

                    <MudAutocomplete T="PartyLookupDto"
                                     Label="ابحث عن العميل بالاسم أو الهاتف *"
                                     Value="_selectedParty"
                                     ValueChanged="OnPartySelected"
                                     SearchFunc="SearchParties"
                                     ToStringFunc="@(p => p == null ? "" : p.PartyName)"
                                     Variant="Variant.Outlined"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="true"
                                     Disabled="@_isReadOnly"
                                     MinCharacters="1">
                        <ItemTemplate Context="party">
                            <div style="display:flex; flex-direction:column; gap:0.25rem;">
                                <strong>@party.PartyName</strong>
                                <span style="font-size:0.78rem; color:var(--mud-palette-text-secondary);">
                                    @if (!string.IsNullOrEmpty(party.Phone))
                                    {
                                        <span>📞 @party.Phone</span>
                                    }
                                    @if (!string.IsNullOrEmpty(party.City))
                                    {
                                        <span> • @party.City</span>
                                    }
                                </span>
                            </div>
                        </ItemTemplate>
                    </MudAutocomplete>

                    @if (_form.PartyId.HasValue && !string.IsNullOrEmpty(_form.PartyPhone))
                    {
                        <div class="party-phone-info mt-2">
                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                            <span>الهاتف: <strong>@_form.PartyPhone</strong></span>
                        </div>
                    }
                </MudPaper>

                <!-- ⭐ الأصناف (Cards زي الفواتير) -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                        <h3>الأصناف (@_form.Items.Count)</h3>
                    </div>

                    @if (!_isReadOnly && _form.PartyId.HasValue && !_availableProducts.Any())
                    {
                        <div class="empty-items">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" />
                            <p>لا توجد منتجات متاحة لهذا العميل</p>
                        </div>
                    }
                    else if (!_isReadOnly && !_form.PartyId.HasValue)
                    {
                        <div class="empty-items">
                            <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Size="Size.Large" />
                            <p>اختر العميل أولاً لعرض المنتجات المتاحة</p>
                        </div>
                    }

                    <!-- شبكة المنتجات المتاحة -->
                    @if (!_isReadOnly && _availableProducts.Any())
                    {
                        <div class="products-grid">
                            @foreach (var prod in _availableProducts)
                            {
                                var isAdded = _form.Items.Any(i => i.ProductId == prod.ProductId);
                                <div class="product-card @(isAdded ? "product-added" : "")">
                                    <div class="product-card-img">
                                        <img src="/api/product-images/@prod.ProductId"
                                             alt="@prod.ProductName"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                        <div class="img-placeholder-sm" style="display:none">📦</div>
                                    </div>
                                    <div class="product-card-info">
                                        <strong class="product-card-name">@prod.ProductName</strong>
                                        @if (!string.IsNullOrEmpty(prod.ProductDescription))
                                        {
                                            <span class="product-card-desc">@prod.ProductDescription</span>
                                        }

                                        @{
                                            var hasElite = (prod.SuggestedSalePriceElite ?? 0) > 0;
                                            var premiumPrice = prod.SuggestedSalePrice ?? 0;
                                            var elitePrice = prod.SuggestedSalePriceElite ?? premiumPrice;
                                            var addedPremium = _form.Items.Any(i => i.ProductId == prod.ProductId && i.PricingTier == PricingTiers.Premium);
                                            var addedElite = _form.Items.Any(i => i.ProductId == prod.ProductId && i.PricingTier == PricingTiers.Elite);
                                        }

                                        <div class="product-card-pricing-list">
                                            <!-- خط البريميم -->
                                            <div class="price-line price-premium">
                                                <span class="price-tag">
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Dense="true">Premium</MudChip>
                                                </span>
                                                <span class="price-value">@($"{premiumPrice:N2}") ج</span>
                                            </div>

                                            <!-- خط الإيليت (لو فيه) -->
                                            @if (hasElite)
                                            {
                                                <div class="price-line price-elite">
                                                    <span class="price-tag">
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Dense="true">Elite</MudChip>
                                                    </span>
                                                    <span class="price-value">@($"{elitePrice:N2}") ج</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="product-card-action">
                                        @if (!_isReadOnly)
                                        {
                                            <div class="tier-buttons-row">
                                                <!-- زرار Premium -->
                                                <MudButton Variant="@(addedPremium ? Variant.Outlined : Variant.Filled)"
                                                           Color="Color.Info"
                                                           Size="Size.Small"
                                                           StartIcon="@(addedPremium ? Icons.Material.Filled.Check : Icons.Material.Filled.Add)"
                                                           OnClick="@(() => AddProductWithTier(prod, PricingTiers.Premium))"
                                                           Disabled="@addedPremium"
                                                           Class="tier-btn">
                                                    @(addedPremium ? "مضاف" : "Premium")
                                                </MudButton>

                                                <!-- زرار Elite (لو متاح) -->
                                                @if (hasElite)
                                                {
                                                    <MudButton Variant="@(addedElite ? Variant.Outlined : Variant.Filled)"
                                                               Color="Color.Warning"
                                                               Size="Size.Small"
                                                               StartIcon="@(addedElite ? Icons.Material.Filled.Check : Icons.Material.Filled.Add)"
                                                               OnClick="@(() => AddProductWithTier(prod, PricingTiers.Elite))"
                                                               Disabled="@addedElite"
                                                               Class="tier-btn">
                                                        @(addedElite ? "مضاف" : "Elite")
                                                    </MudButton>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- جدول الأصناف المضافة -->
                    @if (_form.Items.Any())
                    {
                        <div class="items-table mt-4">
                            <div class="items-header">
                                <div class="col-img">صورة</div>
                                <div class="col-product">الصنف</div>
                                <div class="col-tier">الباقة</div>
                                <div class="col-qty">الكمية</div>
                                <div class="col-price">السعر</div>
                                <div class="col-total">الإجمالي</div>
                                <div class="col-action"></div>
                            </div>

                            @for (int i = 0; i < _form.Items.Count; i++)
                            {
                                var item = _form.Items[i];
                                var index = i;
                                <div class="item-row">
                                    <div class="col-img">
                                        <img src="/api/product-images/@item.ProductId"
                                             alt="@item.ProductName"
                                             class="item-thumb"
                                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                        <div class="item-thumb-placeholder" style="display:none">📦</div>
                                    </div>
                                    <div class="col-product">
                                        <strong>@item.ProductName</strong>
                                        @if (!string.IsNullOrEmpty(item.ProductDescription))
                                        {
                                            <div class="item-name-display">@item.ProductDescription</div>
                                        }
                                    </div>
                                    <div class="col-tier">
                                        <MudSelect T="string" Value="item.PricingTier"
                                                   ValueChanged="@((string v) => OnTierChanged(index, v))"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   Dense="true" Disabled="@_isReadOnly">
                                            @foreach (var tier in PricingTiers.All)
                                            {
                                                <MudSelectItem T="string" Value="@tier.Key">@tier.Value</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>
                                    <div class="col-qty">
                                        <MudNumericField Value="item.Quantity"
                                                         ValueChanged="@((decimal v) => { item.Quantity = v; RecalculateTotals(); })"
                                                         T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         Min="0.01m" Step="1m" Disabled="@_isReadOnly" />
                                    </div>
                                    <div class="col-price">
                                        <MudNumericField Value="item.UnitPrice"
                                                         ValueChanged="@((decimal v) => { item.UnitPrice = v; RecalculateTotals(); })"
                                                         T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         Min="0m" Disabled="@_isReadOnly" />
                                    </div>
                                    <div class="col-total"><strong>@FormatMoney(item.TotalAmount) ج</strong></div>
                                    <div class="col-action">
                                        @if (!_isReadOnly)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error" Size="Size.Small"
                                                           OnClick="@(() => RemoveItem(index))" />
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </MudPaper>

                <!-- ملاحظات -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Notes" />
                        <h3>الملاحظات والشروط</h3>
                    </div>
                    <MudTextField @bind-Value="_form.Notes"
                                  Placeholder="ملاحظات على عرض السعر..."
                                  Label="ملاحظات" Variant="Variant.Outlined" Lines="3"
                                  ReadOnly="@_isReadOnly" />
                </MudPaper>
            </div>

            <!-- ============= Sidebar ============= -->
            <div class="sidebar-col">
                <MudPaper Class="summary-card" Elevation="0">
                    <div class="summary-header">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                        <h3>الملخص المالي</h3>
                    </div>

                    <div class="summary-row">
                        <span>إجمالي الأصناف:</span>
                        <strong>@FormatMoney(_form.TotalAmount) ج</strong>
                    </div>

                    <!-- ✅ خصم مرن: نسبة أو قيمة -->
                    <div class="discount-section">
                        <div class="discount-label">
                            <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Size="Size.Small" />
                            <span>الخصم:</span>
                        </div>

                        <div class="discount-inputs">
                            <!-- خصم بالنسبة -->
                            <div class="discount-input-group">
                                <MudNumericField Value="_form.DiscountPercentage"
                                                 ValueChanged="@((decimal? v) => OnDiscountPercentageChanged(v))"
                                                 T="decimal?"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Min="0m" Max="100m" Step="1m"
                                                 Placeholder="0"
                                                 HideSpinButtons="false"
                                                 Disabled="@_isReadOnly"
                                                 Adornment="Adornment.End" AdornmentText="%"
                                                 Class="discount-field" />
                            </div>

                            <span class="discount-or">أو</span>

                            <!-- خصم بالقيمة -->
                            <div class="discount-input-group">
                                <MudNumericField Value="_form.DiscountAmount"
                                                 ValueChanged="@((decimal? v) => OnDiscountAmountChanged(v))"
                                                 T="decimal?"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Min="0m" Step="10m"
                                                 Placeholder="0"
                                                 HideSpinButtons="false"
                                                 Disabled="@_isReadOnly"
                                                 Adornment="Adornment.End" AdornmentText="ج"
                                                 Class="discount-field" />
                            </div>

                            @if ((_form.DiscountAmount ?? 0) > 0 || (_form.DiscountPercentage ?? 0) > 0)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="ClearDiscount"
                                               Disabled="@_isReadOnly"
                                               Title="إلغاء الخصم" />
                            }
                        </div>
                    </div>

                    @if ((_form.DiscountAmount ?? 0) > 0)
                    {
                        <div class="summary-row discount-row">
                            <span>إجمالي الخصم:</span>
                            <strong>
                                -@FormatMoney(_form.DiscountAmount ?? 0) ج
                                @if ((_form.DiscountPercentage ?? 0) > 0)
                                {
                                    <small style="opacity:0.7; margin-right:8px;">(@(_form.DiscountPercentage)%)</small>
                                }
                            </strong>
                        </div>
                    }

                    <div class="summary-divider"></div>

                    <div class="summary-row total-row">
                        <span>الإجمالي النهائي:</span>
                        <strong>@FormatMoney(_form.GrandTotal) ج</strong>
                    </div>

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3" Icon="@Icons.Material.Filled.Info">
                        <small>عرض السعر <strong>لا يؤثر على المخزون</strong>. يمكنك تحويله لفاتورة لاحقاً.</small>
                    </MudAlert>
                </MudPaper>
            </div>
        </div>
    </div>
}
<!-- ============= Convert to Invoice Dialog ============= -->
<MudDialog @bind-Visible="_showConvertDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Success" />
            <MudText Typo="Typo.h6">تحويل عرض السعر لفاتورة</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-3" Icon="@Icons.Material.Filled.Info">
            سيتم إنشاء <strong>فاتورة مبيعات</strong> + <strong>فاتورة مشتريات مرتبطة</strong> تلقائياً
        </MudAlert>

        <MudText Class="mb-3">
            <strong>العميل:</strong> @_form.PartyName <br />
            <strong>الإجمالي:</strong> <span style="color: var(--mud-palette-success); font-weight: 700;">@FormatMoney(_form.GrandTotal) ج</span>
        </MudText>

        <div class="quick-pay-row mb-3">
            <span style="font-size:0.85rem; font-weight:600;">دفعة فورية:</span>
            @foreach (var pct in SystemConstants.QuickPayPercentages)
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => _convertPaidAmount = Math.Round(_form.GrandTotal * pct / 100m, 2))">
                    @pct%
                </MudButton>
            }
            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success"
                       OnClick="@(() => _convertPaidAmount = _form.GrandTotal)">
                كامل
            </MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       OnClick="@(() => _convertPaidAmount = 0)">
                بدون
            </MudButton>
        </div>

        <MudNumericField @bind-Value="_convertPaidAmount" Label="المبلغ المدفوع"
                         Variant="Variant.Outlined" Min="0m" Max="@_form.GrandTotal" Class="mb-3" />

        @if (_convertPaidAmount > 0)
        {
            <MudSelect T="string" @bind-Value="_convertPaymentMethod"
                       Label="طريقة الدفع" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var pm in PaymentMethods.All)
                {
                    <MudSelectItem T="string" Value="@pm.Key">@pm.Value</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" @bind-Value="_convertCashBoxId"
                       Label="الخزينة" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var cb in _cashBoxes)
                {
                    <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
                }
            </MudSelect>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showConvertDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled"
                   OnClick="ExecuteConvert" Disabled="@_isConverting">
            @if (_isConverting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            تحويل
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- ============= WhatsApp Dialog ============= -->
<MudDialog @bind-Visible="_showWhatsAppDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Send" Style="color: #25D366;" />
            <MudText Typo="Typo.h6">إرسال عرض السعر عبر واتساب</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
            <strong>الخطوات:</strong><br />
            1. <strong>أولاً</strong>: اضغط "تحميل PDF" واحفظ الملف على جهازك<br />
            2. <strong>ثانياً</strong>: اضغط "فتح واتساب" - هيفتح المحادثة مع العميل<br />
            3. <strong>ثالثاً</strong>: ارفق الـ PDF في المحادثة وأرسله
        </MudAlert>

        <MudTextField @bind-Value="_whatsappPhone"
                      Label="رقم الواتساب (مع كود الدولة)"
                      Variant="Variant.Outlined"
                      Placeholder="201234567890"
                      HelperText="مثال: 201234567890 (بدون +)"
                      Class="mb-3" />

        <MudTextField @bind-Value="_whatsappMessage"
                      Label="نص الرسالة"
                      Variant="Variant.Outlined"
                      Lines="6"
                      Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showWhatsAppDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="DownloadPdf">
            تحميل PDF
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Send"
                   OnClick="OpenWhatsApp"
                   Style="background: #25D366 !important; color: white !important;">
            فتح واتساب
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- ============= Change Status Dialog ============= -->
<MudDialog @bind-Visible="_showStatusDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Flag" Color="Color.Primary" />
            <MudText Typo="Typo.h6">تغيير حالة عرض السعر</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-3">
            <strong>الحالة الحالية:</strong>
            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_form.Status)">
                @GetStatusText(_form.Status)
            </MudChip>
        </MudText>

        <MudSelect T="string" @bind-Value="_newStatus"
                   Label="الحالة الجديدة *"
                   Variant="Variant.Outlined">
            @foreach (var s in QuotationStatuses.All.Where(x => x.Key != QuotationStatuses.Converted))
            {
                <MudSelectItem T="string" Value="@s.Key">@s.Value</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showStatusDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="ExecuteChangeStatus" Disabled="@_isChangingStatus">
            @if (_isChangingStatus)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            تغيير
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    /* ============================================ */
    /*  PAGE LAYOUT                                  */
