    // ============================================================
    // Change Status
    // ============================================================
    private void OpenChangeStatusDialog()
    {
        if (_form.IsConverted)
        {
            Snackbar.Add("لا يمكن تغيير حالة عرض سعر تم تحويله لفاتورة.", Severity.Warning);
            return;
        }
        _newStatus = _form.Status;
        _showStatusDialog = true;
    }

    private async Task ExecuteChangeStatus()
    {
        if (_isChangingStatus) return;

        if (_newStatus == _form.Status)
        {
            _showStatusDialog = false;
            return;
        }

        _isChangingStatus = true;
        try
        {
            var (ok, msg) = await QuotationService.ChangeStatusAsync(
                _form.QuotationId, _newStatus, _currentUserName!);

            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

            if (ok)
            {
                _form.Status = _newStatus;
                _showStatusDialog = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر تغيير الحالة: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isChangingStatus = false;
        }
    }

    // ============================================================
    // Helpers
    // ============================================================
    private static Color GetStatusColor(string status)
    {
        return status switch
        {
            QuotationStatuses.Draft => Color.Default,
            QuotationStatuses.Sent => Color.Info,
            QuotationStatuses.Accepted => Color.Success,
            QuotationStatuses.Rejected => Color.Error,
            QuotationStatuses.Converted => Color.Success,
            QuotationStatuses.Expired => Color.Warning,
            _ => Color.Default
        };
    }

    private static string GetStatusText(string status)
    {
        return QuotationStatuses.All.TryGetValue(status, out var text) ? text : status;
    }

