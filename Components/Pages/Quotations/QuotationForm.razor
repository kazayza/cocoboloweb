    private async Task OnPartySelected(PartyLookupDto? party)
    {
        _selectedParty = party;
        _form.PartyId = party?.PartyId;
        _form.PartyName = party?.PartyName;
        _form.PartyPhone = party?.Phone;
        _form.Items.Clear();

        if (party != null)
        {
            await LoadProducts(party.PartyId);
        }
        else
        {
            _availableProducts = new();
        }

        RecalculateTotals();
    }

    private async Task LoadProducts(int partyId)
    {
