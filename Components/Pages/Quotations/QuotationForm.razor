    private async Task SaveQuotation()
    {
        if (_isSaving) return;

        if (_form.PartyId is null or 0)
        {
            Snackbar.Add("يرجى اختيار العميل", Severity.Warning);
            return;
        }
        if (!_form.Items.Any())
        {
            Snackbar.Add("يجب إضافة صنف واحد على الأقل", Severity.Warning);
            return;
        }
        if (_form.Items.Any(i => i.Quantity <= 0))
        {
            Snackbar.Add("يجب أن تكون الكمية أكبر من صفر لكل صنف", Severity.Warning);
            return;
        }
        if (_form.Items.Any(i => i.UnitPrice < 0))
        {
            Snackbar.Add("السعر لا يمكن أن يكون سالباً", Severity.Warning);
            return;
        }
        if (_form.ValidUntil.HasValue && _form.ValidUntil.Value.Date < _form.QuotationDate.Date)
        {
            Snackbar.Add("تاريخ انتهاء الصلاحية يجب أن يكون بعد تاريخ العرض", Severity.Warning);
            return;
        }

        RecalculateTotals();
        _isSaving = true;

        try
        {
            if (IsEdit)
            {
                var (ok, msg) = await QuotationService.UpdateQuotationAsync(_form, _currentUserName!);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok)
                {
                    // أعد القراءة عشان الـ IDs الجديدة بتاعة الـ Items
                    var refreshed = await QuotationService.GetQuotationForEditAsync(_form.QuotationId);
                    if (refreshed != null) _form = refreshed;
                }
            }
            else
            {
                var (ok, msg, id) = await QuotationService.CreateQuotationAsync(_form, _currentUserName!);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok && id.HasValue)
                    Navigation.NavigateTo($"/quotations/{id.Value}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر الحفظ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ============================================================
    // Convert to Invoice
    // ============================================================
    private void OpenConvertDialog()
    {
        if (_form.IsConverted)
        {
            Snackbar.Add("هذا العرض تم تحويله لفاتورة بالفعل.", Severity.Warning);
            return;
        }
        _convertPaidAmount = 0;
        _convertPaymentMethod = PaymentMethods.Cash;
        _convertCashBoxId = _cashBoxes.FirstOrDefault()?.CashBoxId;
        _showConvertDialog = true;
    }

    private async Task ExecuteConvert()
    {
        if (_isConverting) return;

        if (_convertPaidAmount > 0 && (_convertCashBoxId is null or 0))
        {
            Snackbar.Add("يرجى اختيار الخزينة", Severity.Warning);
            return;
        }
        if (_convertPaidAmount < 0)
        {
            Snackbar.Add("الدفعة لا يمكن أن تكون سالبة", Severity.Warning);
            return;
        }
        if (_convertPaidAmount > _form.GrandTotal)
        {
            Snackbar.Add("الدفعة أكبر من إجمالي العرض", Severity.Warning);
            return;
        }

        _isConverting = true;
        try
        {
            var (ok, msg, invId) = await QuotationService.ConvertToInvoiceAsync(
                _form.QuotationId, _convertPaidAmount,
                _convertCashBoxId, _convertPaymentMethod, _currentUserName!);

            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

            if (ok && invId.HasValue)
            {
                _showConvertDialog = false;
                Navigation.NavigateTo($"/sales/invoices/{invId.Value}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر التحويل: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isConverting = false;
        }
    }

