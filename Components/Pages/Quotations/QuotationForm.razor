<div class="discount-section">
    <div class="discount-header">
        <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Size="Size.Small" Style="color: var(--gold-dark);" />
        <span class="discount-title">الخصم</span>
        @if ((_form.DiscountAmount ?? 0) > 0 || (_form.DiscountPercentage ?? 0) > 0)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small" Color="Color.Error"
                           OnClick="ClearDiscount"
                           Disabled="@_isReadOnly"
                           Title="إلغاء الخصم"
                           Class="discount-clear-btn" />
        }
    </div>

    <div class="discount-tabs">
        <button type="button" 
                class="discount-tab @(_discountByPercentage ? "active" : "")"
                @onclick="@(() => _discountByPercentage = true)"
                disabled="@_isReadOnly">
            <MudIcon Icon="@Icons.Material.Filled.Percent" Size="Size.Small" />
            <span>بالنسبة</span>
        </button>
        <button type="button" 
                class="discount-tab @(!_discountByPercentage ? "active" : "")"
                @onclick="@(() => _discountByPercentage = false)"
                disabled="@_isReadOnly">
            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" />
            <span>بالقيمة</span>
        </button>
    </div>

    <div class="discount-input-wrapper">
    @if (_discountByPercentage)
    {
        <MudNumericField @key="@("pct-input")"
                         Value="@_form.DiscountPercentage"
                         ValueChanged="@((decimal? v) => OnDiscountPercentageChanged(v))"
                         T="decimal?"
                         Variant="Variant.Outlined"
                         Margin="Margin.Normal"
                         Min="0m" Max="100m" Step="1m"
                         Immediate="true"
                         Placeholder="0"
                         HideSpinButtons="false"
                         Disabled="@_isReadOnly"
                         Adornment="Adornment.End" AdornmentText="%"
                         Class="discount-big-field" />

        @if ((_form.DiscountAmount ?? 0) > 0)
        {
            <div class="discount-equivalent">
                = <strong>@FormatMoney(_form.DiscountAmount ?? 0) ج</strong>
            </div>
        }
    }
    else
    {
        <MudNumericField @key="@("amount-input")"
                         Value="@_form.DiscountAmount"
                         ValueChanged="@((decimal? v) => OnDiscountAmountChanged(v))"
                         T="decimal?"
                         Variant="Variant.Outlined"
                         Margin="Margin.Normal"
                         Min="0m" Step="50m"
                         Immediate="true"
                         Placeholder="0"
                         HideSpinButtons="false"
                         Disabled="@_isReadOnly"
                         Adornment="Adornment.End" AdornmentText="ج"
                         Class="discount-big-field" />

        @if ((_form.DiscountPercentage ?? 0) > 0)
        {
            <div class="discount-equivalent">
                = <strong>@_form.DiscountPercentage%</strong>
            </div>
        }
    }
</div>
</div>
                    

                    @if ((_form.DiscountAmount ?? 0) > 0)
                    {
                        <div class="summary-row discount-row">
                            <span>إجمالي الخصم:</span>
                            <strong>
                                -@FormatMoney(_form.DiscountAmount ?? 0) ج
                                @if ((_form.DiscountPercentage ?? 0) > 0)
                                {
                                    <small style="opacity:0.7; margin-right:8px;">(@(_form.DiscountPercentage)%)</small>
                                }
                            </strong>
                        </div>
                    }

                    <div class="summary-divider"></div>

                    <div class="summary-row total-row">
                        <span>الإجمالي النهائي:</span>
                        <strong>@FormatMoney(_form.GrandTotal) ج</strong>
                    </div>

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3" Icon="@Icons.Material.Filled.Info">
                        <small>عرض السعر <strong>لا يؤثر على المخزون</strong>. يمكنك تحويله لفاتورة لاحقاً.</small>
                    </MudAlert>
                </MudPaper>
            </div>
        </div>
    </div>
}
<!-- ============= Convert to Invoice Dialog ============= -->
<MudDialog @bind-Visible="_showConvertDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Success" />
            <MudText Typo="Typo.h6">تحويل عرض السعر لفاتورة</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-3" Icon="@Icons.Material.Filled.Info">
            سيتم إنشاء <strong>فاتورة مبيعات</strong> + <strong>فاتورة مشتريات مرتبطة</strong> تلقائياً
        </MudAlert>

        <MudText Class="mb-3">
            <strong>العميل:</strong> @_form.PartyName <br />
            <strong>الإجمالي:</strong> <span style="color: var(--mud-palette-success); font-weight: 700;">@FormatMoney(_form.GrandTotal) ج</span>
        </MudText>

        <div class="quick-pay-row mb-3">
            <span style="font-size:0.85rem; font-weight:600;">دفعة فورية:</span>
            @foreach (var pct in SystemConstants.QuickPayPercentages)
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => _convertPaidAmount = Math.Round(_form.GrandTotal * pct / 100m, 2))">
                    @pct%
                </MudButton>
            }
            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success"
                       OnClick="@(() => _convertPaidAmount = _form.GrandTotal)">
                كامل
            </MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       OnClick="@(() => _convertPaidAmount = 0)">
                بدون
            </MudButton>
        </div>

        <MudNumericField @bind-Value="_convertPaidAmount" Label="المبلغ المدفوع"
                         Variant="Variant.Outlined" Min="0m" Max="@_form.GrandTotal" Class="mb-3" />

        @if (_convertPaidAmount > 0)
        {
            <MudSelect T="string" @bind-Value="_convertPaymentMethod"
                       Label="طريقة الدفع" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var pm in PaymentMethods.All)
                {
                    <MudSelectItem T="string" Value="@pm.Key">@pm.Value</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" @bind-Value="_convertCashBoxId"
                       Label="الخزينة" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var cb in _cashBoxes)
                {
                    <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
                }
            </MudSelect>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showConvertDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled"
                   OnClick="ExecuteConvert" Disabled="@_isConverting">
            @if (_isConverting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            تحويل
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- ============= WhatsApp Dialog ============= -->
<!-- ============= WhatsApp Dialog (Improved) ============= -->
<MudDialog @bind-Visible="_showWhatsAppDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Share" Style="color: #25D366;" />
            <MudText Typo="Typo.h6">مشاركة عرض السعر عبر واتساب</MudText>
        </div>
    </TitleContent>
    <DialogContent>

        <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true" Icon="@Icons.Material.Filled.CheckCircle">
            <strong>الرسالة فيها رابط مباشر</strong> للعميل لعرض / تنزيل / طباعة العرض من المتصفح،
            بدون الحاجة لإرفاق ملفات يدوياً.
        </MudAlert>

        <!-- اختيار كود الدولة + الرقم -->
        <MudText Typo="Typo.body2" Class="mb-2" Style="font-weight:600;">رقم الواتساب:</MudText>
        <div class="d-flex gap-2 align-items-start mb-1">
            <MudSelect T="string" @bind-Value="_whatsappCountryCode"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="max-width:170px;" Dense="true">
                @foreach (var c in PhoneNormalizer.Countries)
                {
                    <MudSelectItem T="string" Value="@c.Value.DialCode">
                        @c.Value.DisplayName (+@c.Value.DialCode)
                    </MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_whatsappPhone"
                          Placeholder="01001234567"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Phone"
                          Style="flex:1;" />
        </div>

        @{
            var preview = GetPhonePreview();
        }
        @if (!string.IsNullOrEmpty(preview))
        {
            <MudText Typo="Typo.caption" Style="@(preview.StartsWith("✅") ? "color:green;" : "color:#d32f2f;")">
                @preview
            </MudText>
        }

        <!-- رابط المشاركة + زرار النسخ -->
        <MudText Typo="Typo.body2" Class="mt-3 mb-2" Style="font-weight:600;">رابط المشاركة:</MudText>
        <MudTextField @bind-Value="_shareLink" 
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      ReadOnly="true"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      OnAdornmentClick="CopyShareLink"
                      AdornmentAriaLabel="نسخ الرابط" />

        <!-- الرسالة (قابلة للتعديل) -->
        <MudTextField @bind-Value="_whatsappMessage"
                      Label="نص الرسالة"
                      Variant="Variant.Outlined"
                      Lines="7"
                      Class="mt-3" />

    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showWhatsAppDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>

        <MudButton Variant="Variant.Outlined" Color="Color.Info"
                   StartIcon="@Icons.Material.Filled.OpenInNew"
                   OnClick="PreviewShareLink">
            معاينة الرابط
        </MudButton>

        <MudButton Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Send"
                   OnClick="OpenWhatsApp"
                   Style="background: #25D366 !important; color: white !important;">
            إرسال واتساب
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- ============= Change Status Dialog ============= -->
<MudDialog @bind-Visible="_showStatusDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Flag" Color="Color.Primary" />
            <MudText Typo="Typo.h6">تغيير حالة عرض السعر</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-3">
            <strong>الحالة الحالية:</strong>
            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_form.Status)">
                @GetStatusText(_form.Status)
            </MudChip>
        </MudText>

        <MudSelect T="string" @bind-Value="_newStatus"
                   Label="الحالة الجديدة *"
                   Variant="Variant.Outlined">
            @foreach (var s in QuotationStatuses.All.Where(x => x.Key != QuotationStatuses.Converted))
            {
                <MudSelectItem T="string" Value="@s.Key">@s.Value</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showStatusDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="ExecuteChangeStatus" Disabled="@_isChangingStatus">
            @if (_isChangingStatus)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            تغيير
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    /* ============================================ */
    /*  PAGE LAYOUT                                  */
    /* ============================================ */
    .quotation-form-page {
        padding: 1rem;
        max-width: 1800px;
        margin: 0 auto;
        direction: rtl;
    }

    /* ============================================ */
    /*  HEADER                                       */
    /* ============================================ */
    .form-header {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        color: white;
    }

    .header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .header-left { display: flex; align-items: center; gap: 1rem; }
    .header-left h1 {
        margin: 0; font-size: 1.4rem; font-weight: 800;
        display: flex; align-items: center; gap: 0.5rem;
    }
    .header-left p { margin: 0; font-size: 0.85rem; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .header-right { display: flex; gap: 0.5rem; flex-wrap: wrap; }

    .save-btn {
        background: rgba(255,255,255,0.95) !important;
        color: var(--navy-dark) !important;
        font-weight: 700 !important;
    }

    /* Summary Pills */
    .header-summary {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(255,255,255,0.25);
    }

    .summary-pill {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(4px);
        padding: 0.5rem 0.85rem;
        border-radius: 10px;
        flex: 1;
        min-width: 140px;
    }
    .summary-pill span { font-size: 0.72rem; opacity: 0.85; display: block; }
    .summary-pill strong { font-size: 0.88rem; display: block; }

    .pill-total { background: rgba(255,255,255,0.25); }
    .pill-warning { background: rgba(245,158,11,0.3); }
    .pill-overdue {
        background: rgba(239,68,68,0.4);
        animation: pulse-bg 2s infinite;
    }

    @@keyframes pulse-bg {
        0%, 100% { background: rgba(239,68,68,0.3); }
        50% { background: rgba(239,68,68,0.5); }
    }

    /* ============================================ */
    /*  GRID LAYOUT                                  */
    /* ============================================ */
    .form-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(300px, 22vw, 360px);
    gap: 1rem;
    align-items: start;
}

.main-col,
.sidebar-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
}

.sidebar-col {
    align-self: start;
}

    /* ============================================ */
    /*  SECTIONS                                     */
    /* ============================================ */
    .form-section {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 14px;
        padding: 1.25rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .section-header h3 { margin: 0; font-size: 1.05rem; font-weight: 700; }

    .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }
    .quotation-meta-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.65rem;
    align-items: start;
}

.quotation-meta-grid .mud-input-control {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
}

@@media (max-width: 1300px) {
    .quotation-meta-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
}

@@media (max-width: 700px) {
    .quotation-meta-grid {
        grid-template-columns: 1fr;
    }
}

    /* ============================================ */
    /*  PARTY                                        */
    /* ============================================ */
    .party-phone-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 0.85rem;
        background: var(--gold-subtle);
        border-radius: 8px;
        font-size: 0.88rem;
    }

    /* ============================================ */
    /*  PRODUCTS GRID                                */
    /* ============================================ */
    .empty-items {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 2rem;
        color: var(--mud-palette-text-secondary);
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
