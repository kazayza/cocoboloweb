@page "/quotations/new"
@page "/quotations/{Id:int}"
@page "/quotations/{Id:int}/edit"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject IQuotationService QuotationService
@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

@if (_isLoading)
{
    <div class="loading-container">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </div>
}
else
{
    <div class="quotation-form-page" dir="rtl">

        <div class="form-header">
            <div class="header-left">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                               Color="Color.Inherit" OnClick="GoBack" Size="Size.Large" />
                <div>
                    <h1>
                        <MudIcon Icon="@Icons.Material.Filled.RequestQuote" />
                        @(IsEdit ? (_isReadOnly ? "عرض سعر" : "تعديل عرض السعر") : "عرض سعر جديد")
                    </h1>
                    <p>
                        @(_form.ReferenceNumber ?? "جديد")
                        @if (!string.IsNullOrEmpty(_form.InvoiceReference))
                        {
                            <span> • تحوّل إلى </span>
                            <a href="/sales/invoices/@_form.InvoiceId" style="color: white; text-decoration: underline;">
                                @_form.InvoiceReference
                            </a>
                        }
                    </p>
                </div>
            </div>
            <div class="header-right">
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="GoBack"
                           StartIcon="@Icons.Material.Filled.Close">
                    إلغاء
                </MudButton>

                @if (IsEdit && _form.InvoiceId == null)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Info"
                               OnClick="OpenPrintPage"
                               StartIcon="@Icons.Material.Filled.Print">
                        طباعة
                    </MudButton>

                    @if (_isReadOnly && _canEdit)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   OnClick="@(() => _isReadOnly = false)"
                                   StartIcon="@Icons.Material.Filled.Edit">
                            تعديل
                        </MudButton>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                               OnClick="OpenConvertDialog"
                               StartIcon="@Icons.Material.Filled.SwapHoriz">
                        تحويل لفاتورة
                    </MudButton>
                }

                @if (!_isReadOnly)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="SaveQuotation"
                               Disabled="@_isSaving"
                               StartIcon="@Icons.Material.Filled.Save"
                               Class="save-btn">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                        }
                        حفظ
                    </MudButton>
                }
            </div>
        </div>

        @if (_form.InvoiceId != null)
        {
            <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle" Class="mb-3">
                ✅ تم تحويل عرض السعر إلى الفاتورة <strong>@_form.InvoiceReference</strong> ولا يمكن تعديله.
            </MudAlert>
        }

        <div class="form-grid">
            <div class="main-col">

                <!-- بيانات عرض السعر -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Description" />
                        <h3>بيانات عرض السعر</h3>
                    </div>
                    <div class="grid-2">
                        <MudTextField Value="@_form.ReferenceNumber" Label="الرقم"
                                      Variant="Variant.Outlined" ReadOnly="true"
                                      HelperText="يتم توليده تلقائياً" />

                        <MudDatePicker Date="_form.QuotationDate"
                                       DateChanged="@(d => _form.QuotationDate = d ?? DateTime.Now)"
                                       Label="تاريخ العرض"
                                       Variant="Variant.Outlined"
                                       ReadOnly="@_isReadOnly" />

                        <MudDatePicker Date="_form.ValidUntil"
                                       DateChanged="@(d => _form.ValidUntil = d)"
                                       Label="ساري لحد تاريخ"
                                       Variant="Variant.Outlined"
                                       Clearable="true"
                                       ReadOnly="@_isReadOnly" />

                        <MudSelect T="int?" @bind-Value="_form.WarehouseId"
                                   Label="المخزن (اختياري)"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   Disabled="@_isReadOnly">
                            @foreach (var w in _warehouses)
                            {
                                <MudSelectItem T="int?" Value="@((int?)w.WarehouseId)">@w.WarehouseName</MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField Value="@(_form.EmpName ?? "غير محدد")"
                                      Label="الموظف"
                                      Variant="Variant.Outlined"
                                      ReadOnly="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person" />

                        <MudSelect T="string"
                                   Value="_form.PricingType"
                                   ValueChanged="@((string v) => OnPricingTypeChanged(v))"
                                   Label="نوع التسعير الافتراضي"
                                   Variant="Variant.Outlined"
                                   Disabled="@_isReadOnly">
                            @foreach (var tier in PricingTiers.All)
                            {
                                <MudSelectItem T="string" Value="@tier.Key">@tier.Value</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                </MudPaper>

                <!-- العميل -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                        <h3>العميل</h3>
                    </div>

                    <MudAutocomplete T="PartyLookupDto"
                                     Label="ابحث عن العميل *"
                                     Value="_selectedParty"
                                     ValueChanged="OnPartySelected"
                                     SearchFunc="SearchParties"
                                     ToStringFunc="@(p => p == null ? "" : p.PartyName)"
                                     Variant="Variant.Outlined"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="true"
                                     Disabled="@_isReadOnly"
                                     MinCharacters="1">
                        <ItemTemplate Context="party">
                            <div style="display:flex; flex-direction:column;">
                                <strong>@party.PartyName</strong>
                                <span style="font-size:0.78rem; color:var(--mud-palette-text-secondary);">
                                    @if (!string.IsNullOrEmpty(party.Phone))
                                    {
                                        <span>📞 @party.Phone</span>
                                    }
                                    @if (!string.IsNullOrEmpty(party.City))
                                    {
                                        <span> • @party.City</span>
                                    }
                                </span>
                            </div>
                        </ItemTemplate>
                    </MudAutocomplete>

                    @if (_partyProductsLoaded && _form.PartyId.HasValue && !_partyProducts.Any() && !_isReadOnly)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mt-3">
                            ⚠️ لا توجد منتجات مرتبطة بهذا العميل.
                        </MudAlert>
                    }
                </MudPaper>

                <!-- الأصناف -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header" style="justify-content: space-between;">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                            <h3>الأصناف (@_form.Items.Count)</h3>
                        </div>
                        @if (!_isReadOnly)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="AddItem"
                                       Size="Size.Small"
                                       Disabled="@(!_form.PartyId.HasValue || !_partyProducts.Any())">
                                إضافة صنف
                            </MudButton>
                        }
                    </div>

                    @if (!_form.PartyId.HasValue && !_isReadOnly)
                    {
                        <div class="empty-items">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                            <p>اختر العميل أولاً لعرض المنتجات الخاصة به</p>
                        </div>
                    }
                    else if (!_form.Items.Any())
                    {
                        <div class="empty-items">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" />
                            <p>لا توجد أصناف في عرض السعر</p>
                            @if (!_isReadOnly && _partyProducts.Any())
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                           OnClick="AddItem">
                                    أضف أول صنف
                                </MudButton>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="items-table">
                            <div class="items-header">
                                <div class="col-product">الصنف</div>
                                <div class="col-tier">الباقة</div>
                                <div class="col-qty">الكمية</div>
                                <div class="col-price">السعر</div>
                                <div class="col-total">الإجمالي</div>
                                <div class="col-action"></div>
                            </div>

                            @for (int i = 0; i < _form.Items.Count; i++)
                            {
                                var item = _form.Items[i];
                                var index = i;
                                <div class="item-row">
                                    <div class="col-product">
                                        <MudSelect T="int" Value="item.ProductId"
                                                   ValueChanged="@((int v) => OnProductChanged(index, v))"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   Dense="true" Disabled="@_isReadOnly">
                                            <MudSelectItem T="int" Value="0">-- اختر منتج --</MudSelectItem>
                                            @foreach (var prod in _partyProducts)
                                            {
                                                <MudSelectItem T="int" Value="@prod.ProductId">
                                                    @prod.ProductName
                                                </MudSelectItem>
                                            }
                                        </MudSelect>
                                        @if (!string.IsNullOrEmpty(item.ProductDescription))
                                        {
                                            <div class="item-desc">@item.ProductDescription</div>
                                        }
                                    </div>
                                    <div class="col-tier">
                                        <MudSelect T="string" Value="item.PricingTier"
                                                   ValueChanged="@((string v) => OnTierChanged(index, v))"
                                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                                   Dense="true" Disabled="@(_isReadOnly || item.ProductId == 0)">
                                            @foreach (var tier in PricingTiers.All)
                                            {
                                                <MudSelectItem T="string" Value="@tier.Key">@tier.Value</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>
                                    <div class="col-qty">
                                        <MudNumericField Value="item.Quantity"
                                                         ValueChanged="@((decimal v) => { item.Quantity = v; RecalculateTotals(); })"
                                                         T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         Min="0.01m" Step="1m" Disabled="@_isReadOnly" />
                                    </div>
                                    <div class="col-price">
                                        <MudNumericField Value="item.UnitPrice"
                                                         ValueChanged="@((decimal v) => { item.UnitPrice = v; RecalculateTotals(); })"
                                                         T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         Min="0m" Disabled="@_isReadOnly" />
                                    </div>
                                    <div class="col-total"><strong>@FormatMoney(item.TotalAmount) ج</strong></div>
                                    <div class="col-action">
                                        @if (!_isReadOnly)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error" Size="Size.Small"
                                                           OnClick="@(() => RemoveItem(index))" />
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </MudPaper>

                <!-- ملاحظات -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Notes" />
                        <h3>الملاحظات والشروط</h3>
                    </div>
                    <MudTextField @bind-Value="_form.Notes"
                                  Placeholder="ملاحظات على عرض السعر..."
                                  Label="ملاحظات"
                                  Variant="Variant.Outlined"
                                  Lines="3"
                                  ReadOnly="@_isReadOnly" />
                </MudPaper>
            </div>

            <!-- Sidebar -->
            <div class="sidebar-col">
                <MudPaper Class="summary-card" Elevation="0">
                    <h3>الملخص</h3>

                    <div class="summary-row">
                        <span>إجمالي الأصناف:</span>
                        <strong>@FormatMoney(_form.TotalAmount) ج</strong>
                    </div>

                    <div class="summary-row">
                        <span>خصم %:</span>
                        <MudNumericField Value="_form.DiscountPercentage"
                                         ValueChanged="@((decimal? v) => { _form.DiscountPercentage = v; RecalculateTotals(); })"
                                         T="decimal?"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Min="0m" Max="100m" Step="1m"
                                         Style="max-width:100px;"
                                         Disabled="@_isReadOnly" />
                    </div>

                    <div class="summary-row">
                        <span>قيمة الخصم:</span>
                        <strong style="color:var(--mud-palette-error);">
                            -@FormatMoney(_form.DiscountAmount ?? 0) ج
                        </strong>
                    </div>

                    <div class="summary-divider"></div>

                    <div class="summary-row total-row">
                        <span>الإجمالي النهائي:</span>
                        <strong>@FormatMoney(_form.GrandTotal) ج</strong>
                    </div>

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3" Icon="@Icons.Material.Filled.Info">
                        <small>
                            عرض السعر <strong>لا يؤثر على المخزون</strong>.
                            يمكنك تحويله لفاتورة لاحقاً.
                        </small>
                    </MudAlert>
                </MudPaper>
            </div>
        </div>
    </div>
}

<!-- Convert Dialog -->
<MudDialog @bind-Visible="_showConvertDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Success" Class="me-2" />
            تحويل عرض السعر لفاتورة
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-3">
            <strong>إجمالي:</strong> @FormatMoney(_form.GrandTotal) ج
        </MudAlert>

        <div class="quick-pay-row mb-3">
            <span style="font-size:0.85rem; font-weight:600;">دفعة فورية:</span>
            @foreach (var pct in SystemConstants.QuickPayPercentages)
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                           OnClick="@(() => _convertPaidAmount = Math.Round(_form.GrandTotal * pct / 100m, 2))">
                    @pct%
                </MudButton>
            }
            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success"
                       OnClick="@(() => _convertPaidAmount = _form.GrandTotal)">
                كامل
            </MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       OnClick="@(() => _convertPaidAmount = 0)">
                بدون
            </MudButton>
        </div>

        <MudNumericField @bind-Value="_convertPaidAmount" Label="المبلغ المدفوع"
                         Variant="Variant.Outlined" Min="0m" Max="@_form.GrandTotal" Class="mb-3" />

        @if (_convertPaidAmount > 0)
        {
            <MudSelect T="string" @bind-Value="_convertPaymentMethod"
                       Label="طريقة الدفع" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var pm in PaymentMethods.All)
                {
                    <MudSelectItem T="string" Value="@pm.Key">@pm.Value</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" @bind-Value="_convertCashBoxId"
                       Label="الخزينة" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var cb in _cashBoxes)
                {
                    <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
                }
            </MudSelect>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showConvertDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled"
                   OnClick="ExecuteConvert" Disabled="@_isConverting">
            @if (_isConverting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" /> }
            تحويل
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .quotation-form-page { padding: 1rem; max-width: 1800px; margin: 0 auto; direction: rtl; }

    .form-header {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        border-radius: 16px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem;
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 1rem; color: white;
    }
    .header-left { display: flex; align-items: center; gap: 1rem; }
    .header-left h1 {
        margin: 0; font-size: 1.5rem; font-weight: 800;
        display: flex; align-items: center; gap: 0.5rem;
    }
    .header-left p { margin: 0.25rem 0 0 0; font-size: 0.85rem; color: rgba(255,255,255,0.85); }
    .header-right { display: flex; gap: 0.5rem; flex-wrap: wrap; }

    .save-btn {
        background: rgba(255,255,255,0.95) !important;
        color: var(--navy-dark) !important;
        font-weight: 700 !important;
    }

    .form-grid { display: grid; grid-template-columns: 1fr 350px; gap: 1.5rem; }
    .main-col, .sidebar-col { display: flex; flex-direction: column; gap: 1rem; }

    .form-section {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 14px; padding: 1.25rem;
    }

    .section-header {
        display: flex; align-items: center; gap: 0.5rem;
        margin-bottom: 1rem; padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .section-header h3 { margin: 0; font-size: 1.05rem; font-weight: 700; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

    .empty-items {
        display: flex; flex-direction: column; align-items: center;
        gap: 1rem; padding: 2rem; color: var(--mud-palette-text-secondary);
    }

    .items-table { display: flex; flex-direction: column; gap: 0.5rem; }
    .items-header {
        display: grid;
        grid-template-columns: 2.5fr 1fr 0.8fr 1fr 1fr 50px;
        gap: 0.5rem; padding: 0.5rem;
        background: var(--mud-palette-background);
        border-radius: 8px; font-weight: 700; font-size: 0.85rem;
    }
    .item-row {
        display: grid;
        grid-template-columns: 2.5fr 1fr 0.8fr 1fr 1fr 50px;
        gap: 0.5rem; align-items: center;
    }
    .col-total { font-weight: 600; }
    .item-desc {
        font-size: 0.75rem; color: var(--mud-palette-text-secondary);
        margin-top: 0.25rem; padding-right: 0.5rem;
    }

    .summary-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 14px; padding: 1.25rem;
        position: sticky; top: 1rem;
    }
    .summary-card h3 {
        margin: 0 0 1rem 0; font-size: 1.1rem; font-weight: 800;
        padding-bottom: 0.5rem; border-bottom: 2px solid var(--gold);
    }
    .summary-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.4rem 0; font-size: 0.9rem;
    }
    .summary-divider { height: 1px; background: var(--mud-palette-divider); margin: 0.5rem 0; }
    .total-row {
        font-size: 1.05rem; background: var(--gold-subtle);
        padding: 0.6rem 0.75rem; border-radius: 8px;
    }

    .quick-pay-row {
        display: flex; gap: 0.25rem; align-items: center; flex-wrap: wrap;
        padding: 0.5rem; background: rgba(16,185,129,0.08); border-radius: 6px;
    }

    .loading-container { display:flex; align-items:center; justify-content:center; min-height: 60vh; }

    @@media (max-width: 1100px) { .form-grid { grid-template-columns: 1fr; } .summary-card { position: static; } }
    @@media (max-width: 700px) { .grid-2, .items-header, .item-row { grid-template-columns: 1fr; } }
</style>

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsEdit => Id.HasValue && Id.Value > 0;
    private bool _isReadOnly = false;

    private bool _isLoading = true;
    private bool _isSaving = false;

    private QuotationFormDto _form = new();
    private PartyLookupDto? _selectedParty;

    private List<Models.Warehouse> _warehouses = new();
    private List<Models.CashBox> _cashBoxes = new();
    private List<ProductLookupDto> _partyProducts = new();
    private bool _partyProductsLoaded = false;

    // Convert dialog
    private bool _showConvertDialog, _isConverting;
    private decimal _convertPaidAmount;
    private string _convertPaymentMethod = PaymentMethods.Cash;
    private int? _convertCashBoxId;

    private string? _currentUserName;
    private bool _canAdd, _canEdit;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canAdd = user.HasClaim("Permission", "frmQuotations:Add") || user.IsInRole("Admin");
            _canEdit = user.HasClaim("Permission", "frmQuotations:Edit") || user.IsInRole("Admin");

            _warehouses = await InvoiceService.GetWarehousesAsync();
            _cashBoxes = await InvoiceService.GetCashBoxesAsync();

            // Get employee
            var empId = await InvoiceService.GetEmployeeIdByUserNameAsync(_currentUserName);
            if (empId.HasValue)
            {
                _form.EmpId = empId.Value;
                _form.EmpName = await InvoiceService.GetEmployeeNameByIdAsync(empId.Value);
            }

            if (IsEdit)
            {
                var loaded = await QuotationService.GetQuotationForEditAsync(Id!.Value);
                if (loaded == null)
                {
                    Snackbar.Add("عرض السعر غير موجود", Severity.Error);
                    Navigation.NavigateTo("/quotations");
                    return;
                }
                _form = loaded;
                _isReadOnly = _form.InvoiceId != null; // ReadOnly لو متحول
                if (_form.PartyId.HasValue)
                {
                    _selectedParty = new PartyLookupDto
                    {
                        PartyId = _form.PartyId.Value,
                        PartyName = _form.PartyName ?? ""
                    };
                    _partyProducts = await InvoiceService.SearchProductsForPartyAsync(_form.PartyId.Value, null, 200);
                    _partyProductsLoaded = true;
                }
            }
            else
            {
                if (!_canAdd) { Navigation.NavigateTo("/quotations"); return; }
                if (_warehouses.Any()) _form.WarehouseId = _warehouses.First().WarehouseId;
                _form.ReferenceNumber = await QuotationService.GenerateNextQuotationNumberAsync();
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    // Party
    private async Task<IEnumerable<PartyLookupDto>> SearchParties(string value, CancellationToken token)
    {
        return await InvoiceService.SearchPartiesAsync(value);
    }

    private async Task OnPartySelected(PartyLookupDto? party)
    {
        _selectedParty = party;
        _form.PartyId = party?.PartyId;
        _form.PartyName = party?.PartyName;
        _form.Items.Clear();

        if (party != null)
        {
            _partyProducts = await InvoiceService.SearchProductsForPartyAsync(party.PartyId, null, 200);
            _partyProductsLoaded = true;
        }
        else
        {
            _partyProducts = new();
            _partyProductsLoaded = false;
        }
        RecalculateTotals();
    }

    // Tier
    private void OnPricingTypeChanged(string newType)
    {
        _form.PricingType = newType;
        // طبّق على كل الأصناف
        for (int i = 0; i < _form.Items.Count; i++)
        {
            _form.Items[i].PricingTier = newType;
            _form.Items[i].UnitPrice = GetSalePriceByTier(_form.Items[i], newType);
        }
        RecalculateTotals();
    }

    // Items
    private void AddItem()
    {
        _form.Items.Add(new QuotationItemDto
        {
            Quantity = 1,
            PricingTier = _form.PricingType
        });
        StateHasChanged();
    }

    private void OnProductChanged(int index, int productId)
    {
        if (index < 0 || index >= _form.Items.Count) return;
        var item = _form.Items[index];

        if (productId == 0)
        {
            item.ProductId = 0; item.ProductName = null;
            item.ProductDescription = null; item.UnitPrice = 0;
            RecalculateTotals();
            return;
        }

        var product = _partyProducts.FirstOrDefault(p => p.ProductId == productId);
        if (product != null)
        {
            item.ProductId = product.ProductId;
            item.ProductName = product.ProductName;
            item.ProductDescription = product.ProductDescription;
            item.ProductImagePath = product.ImagePath;
            item.SalePricePremium = product.SuggestedSalePrice;
            item.SalePriceElite = product.SuggestedSalePriceElite;
            item.UnitPrice = GetSalePriceByTier(item, item.PricingTier);
            if (item.Quantity == 0) item.Quantity = 1;
        }
        RecalculateTotals();
    }

    private void OnTierChanged(int index, string newTier)
    {
        if (index < 0 || index >= _form.Items.Count) return;
        var item = _form.Items[index];
        item.PricingTier = newTier;
        if (item.ProductId > 0) item.UnitPrice = GetSalePriceByTier(item, newTier);
        RecalculateTotals();
    }

    private decimal GetSalePriceByTier(QuotationItemDto item, string tier)
    {
        if (tier == PricingTiers.Elite)
            return item.SalePriceElite ?? item.SalePricePremium ?? 0;
        return item.SalePricePremium ?? 0;
    }

    private void RemoveItem(int index)
    {
        _form.Items.RemoveAt(index);
        RecalculateTotals();
    }

    private void RecalculateTotals()
    {
        _form.TotalAmount = Math.Round(_form.Items.Sum(i => i.TotalAmount), 2);

        if (_form.DiscountPercentage.HasValue && _form.DiscountPercentage.Value > 0)
            _form.DiscountAmount = Math.Round(_form.TotalAmount * (_form.DiscountPercentage.Value / 100m), 2);
        else
            _form.DiscountAmount = 0;

        _form.NetTotalAmount = _form.TotalAmount - (_form.DiscountAmount ?? 0);
        _form.GrandTotal = _form.NetTotalAmount ?? 0;

        StateHasChanged();
    }

    // Save
    private async Task SaveQuotation()
    {
        RecalculateTotals();
        _isSaving = true;
        try
        {
            if (IsEdit)
            {
                var (ok, msg) = await QuotationService.UpdateQuotationAsync(_form, _currentUserName!);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok) { _isReadOnly = true; }
            }
            else
            {
                var (ok, msg, id) = await QuotationService.CreateQuotationAsync(_form, _currentUserName!);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok && id.HasValue)
                {
                    Navigation.NavigateTo($"/quotations/{id.Value}");
                }
            }
        }
        finally { _isSaving = false; }
    }

    // Convert
    private void OpenConvertDialog()
    {
        _convertPaidAmount = 0;
        _convertCashBoxId = _cashBoxes.FirstOrDefault()?.CashBoxId;
        _showConvertDialog = true;
    }

    private async Task ExecuteConvert()
    {
        _isConverting = true;
        var (ok, msg, invId) = await QuotationService.ConvertToInvoiceAsync(
            _form.QuotationId, _convertPaidAmount,
            _convertCashBoxId, _convertPaymentMethod, _currentUserName!);
        _isConverting = false;
        _showConvertDialog = false;
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok && invId.HasValue)
        {
            Navigation.NavigateTo($"/sales/invoices/{invId.Value}");
        }
    }

    private void OpenPrintPage() => Navigation.NavigateTo($"/quotations/{Id}/print");
    private void GoBack() => Navigation.NavigateTo("/quotations");

    private string FormatMoney(decimal v) => $"{v:N2}";
}
