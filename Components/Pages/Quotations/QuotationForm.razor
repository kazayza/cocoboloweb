    var baseUrl = Navigation.BaseUri.TrimEnd('/');
    _shareLink = $"{baseUrl}/q/quotation/{_form.QuotationId}";

    // 3) ⭐ الرسالة فيها الرابط
    _whatsappMessage = $"السلام عليكم،\n\n" +
                       $"📋 عرض سعر رقم: {_form.ReferenceNumber}\n" +
                       $"📅 التاريخ: {_form.QuotationDate:yyyy/MM/dd}\n" +
                       $"💰 الإجمالي: {FormatMoney(_form.GrandTotal)} ج\n\n" +
                       $"👇 لعرض / تحميل / طباعة عرض السعر، اضغط الرابط:\n" +
                       $"{_shareLink}\n\n" +
