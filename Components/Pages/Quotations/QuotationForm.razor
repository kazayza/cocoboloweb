/// <summary>تحديث رد العميل (موافقة/رفض) - بواسطة الموظف</summary>
/// <summary>تحديث رد العميل (موافقة/رفض) - بواسطة الموظف</summary>
private async Task UpdateCustomerResponse(bool accepted)
{
    if (_isUpdatingResponse) return;

    var actionText = accepted ? "موافقة العميل" : "رفض العميل";
    
    // ✅ استخدام JS confirm (الأبسط والأضمن)
    var confirmed = await JS.InvokeAsync<bool>("confirm", 
        $"هل تريد تسجيل {actionText} على هذا العرض؟");

    if (!confirmed) return;

    _isUpdatingResponse = true;
    StateHasChanged();

    try
    {
        var newStatus = accepted 
            ? QuotationStatuses.Accepted 
            : QuotationStatuses.Rejected;

        var (ok, msg) = await QuotationService.ChangeStatusAsync(
            _form.QuotationId, newStatus, _currentUserName!);

        if (ok)
        {
            _form.Status = newStatus;
            var emoji = accepted ? "✅" : "❌";
            var text = accepted ? "موافقة العميل" : "رفض العميل";
            Snackbar.Add($"{emoji} تم تسجيل {text}", Severity.Success);
        }
        else
        {
            Snackbar.Add(msg, Severity.Error);
        }
    }
    catch (Exception ex)
    {
        Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
    }
    finally
    {
        _isUpdatingResponse = false;
        StateHasChanged();
    }
}

