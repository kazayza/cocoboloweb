   private async Task OpenWhatsApp()
{
    var normalizedPhone = PhoneNormalizer.ToWhatsAppFormat(
        _whatsappPhone, _whatsappCountryCode);

    if (string.IsNullOrEmpty(normalizedPhone) || 
        !PhoneNormalizer.IsValidWhatsAppNumber(normalizedPhone))
    {
        Snackbar.Add("رقم الواتساب غير صحيح. مثال: 01001234567", Severity.Warning);
        return;
    }

    try
    {
        // افتح واتساب
        var encodedMsg = Uri.EscapeDataString(_whatsappMessage);
        var url = $"https://api.whatsapp.com/send?phone={normalizedPhone}&text={encodedMsg}";
        await JS.InvokeVoidAsync("open", url, "_blank");
        _showWhatsAppDialog = false;

        // ⭐ Auto-update status to "Sent" لو لسه Draft
        if (_form.Status == QuotationStatuses.Draft)
        {
            var (ok, _) = await QuotationService.ChangeStatusAsync(
                _form.QuotationId, QuotationStatuses.Sent, _currentUserName!);
            if (ok)
            {
                _form.Status = QuotationStatuses.Sent;
                StateHasChanged();
                Snackbar.Add("✅ تم تحديث الحالة إلى: تم الإرسال", Severity.Success);
            }
        }

        Snackbar.Add($"تم فتح واتساب على: {PhoneNormalizer.FormatForDisplay(normalizedPhone)}",
                     Severity.Info);
    }
    catch (Exception ex)
    {
        Snackbar.Add($"تعذّر فتح واتساب: {ex.Message}", Severity.Error);
    }
}
/// <summary>يعرض رقم الواتساب بعد التطبيع</summary>
private string GetPhonePreview()
{
    if (string.IsNullOrWhiteSpace(_whatsappPhone)) return "";
    var normalized = PhoneNormalizer.ToWhatsAppFormat(_whatsappPhone, _whatsappCountryCode);
    if (normalized == null) return "❌ رقم غير صحيح";
    if (!PhoneNormalizer.IsValidWhatsAppNumber(normalized)) return "❌ رقم غير صحيح";
    return $"✅ سيتم الإرسال إلى: {PhoneNormalizer.FormatForDisplay(normalized)}";
}

