@code {
    [Parameter] public int? Id { get; set; }
    private bool IsEdit => Id.HasValue && Id.Value > 0;
    private bool _isReadOnly = false;

    private bool _isLoading = true;
    private bool _isSaving = false;

    private QuotationFormDto _form = new()
    {
        QuotationDate = DateTime.Today,
        ValidUntil = DateTime.Today.AddDays(15),
        Items = new List<QuotationItemDto>(),
        PricingType = PricingTiers.Premium
    };
    private PartyLookupDto? _selectedParty;

    private List<Models.Warehouse> _warehouses = new();
    private List<Models.CashBox> _cashBoxes = new();
    private List<ProductLookupDto> _availableProducts = new();

    // Convert dialog
    private bool _showConvertDialog, _isConverting;
    private decimal _convertPaidAmount;
    private string _convertPaymentMethod = PaymentMethods.Cash;
    private int? _convertCashBoxId;

    // WhatsApp dialog
    private bool _showWhatsAppDialog;
    private string _whatsappPhone = "";
    private string _whatsappMessage = "";
    private string _shareLink = "";
private string _whatsappCountryCode = "20";

    // Change status dialog
    private bool _showStatusDialog, _isChangingStatus;
    private string _newStatus = QuotationStatuses.Draft;

    private string? _currentUserName;
    private bool _canEdit;


    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;

            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canEdit = user.HasClaim("Permission", "frmQuotations:Edit") || user.IsInRole("Admin");

            _warehouses = await InvoiceService.GetWarehousesAsync() ?? new();
            _cashBoxes = await InvoiceService.GetCashBoxesAsync() ?? new();

            if (IsEdit)
            {
                var loaded = await QuotationService.GetQuotationForEditAsync(Id!.Value);
                if (loaded == null)
                {
                    Snackbar.Add("عرض السعر غير موجود", Severity.Error);
                    Navigation.NavigateTo("/quotations");
                    return;
                }

                _form = loaded;
                // ✅ الفورم تكون readonly لو محول لفاتورة أو اليوزر مش عنده Edit
                _isReadOnly = _form.IsConverted || !_canEdit;

                if (_form.PartyId.HasValue)
                {
                    _selectedParty = new PartyLookupDto
                    {
                        PartyId = _form.PartyId.Value,
                        PartyName = _form.PartyName ?? "",
                        Phone = _form.PartyPhone
                    };
                    await LoadProducts(_form.PartyId.Value);
                }
            }
            else
            {
                _isReadOnly = false;
                _form.ReferenceNumber = await QuotationService.GenerateNextQuotationNumberAsync();

                if (_warehouses.Any())
                    _form.WarehouseId = _warehouses.First().WarehouseId;

                var empId = await InvoiceService.GetEmployeeIdByUserNameAsync(_currentUserName!);
                if (empId.HasValue)
                {
                    _form.EmpId = empId.Value;
                    _form.EmpName = await InvoiceService.GetEmployeeNameByIdAsync(empId.Value);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ============================================================
    // Party
    // ============================================================
    private async Task<IEnumerable<PartyLookupDto>> SearchParties(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length < 1)
            return Enumerable.Empty<PartyLookupDto>();

        try
        {
            return await InvoiceService.SearchPartiesAsync(value);
        }
        catch
        {
            return Enumerable.Empty<PartyLookupDto>();
        }
    }

    private async Task OnPartySelected(PartyLookupDto? party)
    {
        _selectedParty = party;
        _form.PartyId = party?.PartyId;
        _form.PartyName = party?.PartyName;
        _form.PartyPhone = party?.Phone;
        _form.Items.Clear();

        if (party != null)
        {
            await LoadProducts(party.PartyId);
        }
        else
        {
            _availableProducts = new();
        }

        RecalculateTotals();
    }

    private async Task LoadProducts(int partyId)
    {
        try
        {
            _availableProducts = await InvoiceService.SearchProductsForPartyAsync(partyId, null, 200) ?? new();

            if (_availableProducts.Count == 0)
            {
                Snackbar.Add(
                    "لا توجد منتجات مرتبطة بهذا العميل. " +
                    "تحقّق من إضافة منتجات للعميل في شاشة المنتجات (حقل العميل في تعريف المنتج).",
                    Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _availableProducts = new();
            Snackbar.Add(
                $"تعذّر تحميل المنتجات: {ex.Message}",
                Severity.Error);
            Console.WriteLine($"[QuotationForm.LoadProducts] {ex}");
        }
    }

    // ============================================================
    // Pricing
    // ============================================================
    private void OnPricingTypeChanged(string newType)
    {
        _form.PricingType = newType;
        foreach (var item in _form.Items)
        {
            item.PricingTier = newType;
            if (item.ProductId > 0)
                item.UnitPrice = GetPriceByTier(item, newType);
        }
        RecalculateTotals();
    }

    private void OnTierChanged(int index, string newTier)
    {
        if (index < 0 || index >= _form.Items.Count) return;
        var item = _form.Items[index];
        item.PricingTier = newTier;
        if (item.ProductId > 0)
            item.UnitPrice = GetPriceByTier(item, newTier);
        RecalculateTotals();
    }

    private static decimal GetPriceByTier(QuotationItemDto item, string tier)
    {
        if (tier == PricingTiers.Elite)
            return item.SalePriceElite ?? item.SalePricePremium ?? 0;
        return item.SalePricePremium ?? 0;
    }

    // ============================================================
    // Products (Cards)
    // ============================================================
    private void AddProductToQuotation(ProductLookupDto product)
    {
        // الطريقة القديمة - استدعاء بالـ tier الافتراضي
        AddProductWithTier(product, _form.PricingType);
    }

    /// <summary>
    /// ✅ إضافة منتج بتسعير محدد (Premium أو Elite).
    /// لو المنتج مفيش له سعر Elite، بنرجّعه Premium تلقائيًا.
    /// لو المنتج مضاف بنفس الـ tier → نزوّد كميته بدل ما نمنع الإضافة.
    /// </summary>
    private void AddProductWithTier(ProductLookupDto product, string tier)
    {
        if (product is null) return;

        // لو الـ tier طلب Elite بس مفيش سعر → نزّله لـ Premium
        var hasEliteOrSamePrice = (product.SuggestedSalePriceElite ?? 0) > 0;
        if (tier == PricingTiers.Elite && !hasEliteOrSamePrice)
        {
            tier = PricingTiers.Premium;
            Snackbar.Add(
                $"المنتج '{product.ProductName}' ليس له سعر Elite، تمت الإضافة بسعر Premium.",
                Severity.Info);
        }

        // هل المنتج مضاف بنفس الـ tier؟
        var existing = _form.Items.FirstOrDefault(i =>
            i.ProductId == product.ProductId && i.PricingTier == tier);

        if (existing != null)
        {
            // زود الكمية بدل ما تمنع الإضافة
            existing.Quantity += 1;
            RecalculateTotals();
            Snackbar.Add($"تم زيادة الكمية للمنتج '{product.ProductName}' ({tier}).", Severity.Success);
            return;
        }

        var newItem = new QuotationItemDto
        {
            ProductId = product.ProductId,
            ProductName = product.ProductName,
            ProductDescription = product.ProductDescription,
            Quantity = 1,
            PricingTier = tier,
            SalePricePremium = product.SuggestedSalePrice,
            SalePriceElite = product.SuggestedSalePriceElite,
            PurchasePricePremium = product.PurchasePrice,
            PurchasePriceElite = product.PurchasePriceElite,
            Period = product.Period
        };

        newItem.UnitPrice = GetPriceByTier(newItem, tier);
        _form.Items.Add(newItem);
        RecalculateTotals();
    }

    private void RemoveItem(int index)
    {
        if (index < 0 || index >= _form.Items.Count) return;
        _form.Items.RemoveAt(index);
        RecalculateTotals();
    }

    // ============================================================
    // ✅ Calculations - بدون لمس الخصم (الخصم ليه handlers خاصة)
    // ============================================================
    private void RecalculateTotals()
    {
        _form.TotalAmount = Math.Round(_form.Items.Sum(i => i.TotalAmount), 2);

        // ✅ لو الإجمالي اتغير وكان فيه نسبة خصم → نعيد حساب القيمة بناءً على الإجمالي الجديد
        if (_form.DiscountPercentage.HasValue && _form.DiscountPercentage.Value > 0)
        {
            _form.DiscountAmount = Math.Round(
                _form.TotalAmount * (_form.DiscountPercentage.Value / 100m), 2);
        }
        // لو فيه قيمة بدون نسبة، نتأكد إنها مش أكبر من الإجمالي
        else if (_form.DiscountAmount.HasValue && _form.DiscountAmount.Value > 0)
        {
            if (_form.DiscountAmount.Value > _form.TotalAmount)
                _form.DiscountAmount = _form.TotalAmount;
        }
        else
        {
            _form.DiscountAmount = 0;
        }

        _form.NetTotalAmount = _form.TotalAmount - (_form.DiscountAmount ?? 0);
        _form.GrandTotal = _form.NetTotalAmount ?? 0;

        StateHasChanged();
    }

    // ============================================================
    // ✅ معالجات الخصم المرن
    // ============================================================
    /// <summary>المستخدم غيّر نسبة الخصم → احسب القيمة منها</summary>
    private void OnDiscountPercentageChanged(decimal? newPercentage)
    {
        _form.DiscountPercentage = newPercentage;

        if (newPercentage.HasValue && newPercentage.Value > 0)
        {
            // حدد القيمة بناءً على النسبة
            _form.DiscountAmount = Math.Round(
                _form.TotalAmount * (newPercentage.Value / 100m), 2);
        }
        else
        {
            // النسبة 0 → القيمة 0
            _form.DiscountAmount = 0;
        }

        UpdateGrandTotal();
    }

    /// <summary>المستخدم غيّر قيمة الخصم → احسب النسبة منها</summary>
    private void OnDiscountAmountChanged(decimal? newAmount)
    {
        _form.DiscountAmount = newAmount;

        if (newAmount.HasValue && newAmount.Value > 0)
        {
            // حد أقصى = الإجمالي
            if (newAmount.Value > _form.TotalAmount)
            {
                _form.DiscountAmount = _form.TotalAmount;
                newAmount = _form.TotalAmount;
            }

            // احسب النسبة المقابلة
            _form.DiscountPercentage = _form.TotalAmount > 0
                ? Math.Round((newAmount.Value / _form.TotalAmount) * 100, 2)
                : 0;
        }
        else
        {
            _form.DiscountPercentage = 0;
        }

        UpdateGrandTotal();
    }

    /// <summary>إلغاء الخصم تمامًا</summary>
    private void ClearDiscount()
    {
        _form.DiscountAmount = 0;
        _form.DiscountPercentage = 0;
        UpdateGrandTotal();
    }

    /// <summary>تحديث الإجمالي النهائي فقط (بدون لمس الخصم)</summary>
    private void UpdateGrandTotal()
    {
        _form.NetTotalAmount = _form.TotalAmount - (_form.DiscountAmount ?? 0);
        _form.GrandTotal = _form.NetTotalAmount ?? 0;
        StateHasChanged();
    }

    private string FormatMoney(decimal v) => $"{v:N2}";

    // ============================================================
    // Save
    // ============================================================
    private async Task SaveQuotation()
    {
        if (_isSaving) return;

        if (_form.PartyId is null or 0)
        {
            Snackbar.Add("يرجى اختيار العميل", Severity.Warning);
            return;
        }
        if (!_form.Items.Any())
        {
            Snackbar.Add("يجب إضافة صنف واحد على الأقل", Severity.Warning);
            return;
        }
        if (_form.Items.Any(i => i.Quantity <= 0))
        {
            Snackbar.Add("يجب أن تكون الكمية أكبر من صفر لكل صنف", Severity.Warning);
            return;
        }
        if (_form.Items.Any(i => i.UnitPrice < 0))
        {
            Snackbar.Add("السعر لا يمكن أن يكون سالباً", Severity.Warning);
            return;
        }
        if (_form.ValidUntil.HasValue && _form.ValidUntil.Value.Date < _form.QuotationDate.Date)
        {
            Snackbar.Add("تاريخ انتهاء الصلاحية يجب أن يكون بعد تاريخ العرض", Severity.Warning);
            return;
        }

        RecalculateTotals();
        _isSaving = true;

        try
        {
            if (IsEdit)
            {
                var (ok, msg) = await QuotationService.UpdateQuotationAsync(_form, _currentUserName!);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok)
                {
                    // أعد القراءة عشان الـ IDs الجديدة بتاعة الـ Items
                    var refreshed = await QuotationService.GetQuotationForEditAsync(_form.QuotationId);
                    if (refreshed != null) _form = refreshed;
                }
            }
            else
            {
                var (ok, msg, id) = await QuotationService.CreateQuotationAsync(_form, _currentUserName!);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok && id.HasValue)
                    Navigation.NavigateTo($"/quotations/{id.Value}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر الحفظ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ============================================================
    // Convert to Invoice
    // ============================================================
    private void OpenConvertDialog()
    {
        if (_form.IsConverted)
        {
            Snackbar.Add("هذا العرض تم تحويله لفاتورة بالفعل.", Severity.Warning);
            return;
        }
        _convertPaidAmount = 0;
        _convertPaymentMethod = PaymentMethods.Cash;
        _convertCashBoxId = _cashBoxes.FirstOrDefault()?.CashBoxId;
        _showConvertDialog = true;
    }

    private async Task ExecuteConvert()
    {
        if (_isConverting) return;

        if (_convertPaidAmount > 0 && (_convertCashBoxId is null or 0))
        {
            Snackbar.Add("يرجى اختيار الخزينة", Severity.Warning);
            return;
        }
        if (_convertPaidAmount < 0)
        {
            Snackbar.Add("الدفعة لا يمكن أن تكون سالبة", Severity.Warning);
            return;
        }
        if (_convertPaidAmount > _form.GrandTotal)
        {
            Snackbar.Add("الدفعة أكبر من إجمالي العرض", Severity.Warning);
            return;
        }

        _isConverting = true;
        try
        {
            var (ok, msg, invId) = await QuotationService.ConvertToInvoiceAsync(
                _form.QuotationId, _convertPaidAmount,
                _convertCashBoxId, _convertPaymentMethod, _currentUserName!);

            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

            if (ok && invId.HasValue)
            {
                _showConvertDialog = false;
                Navigation.NavigateTo($"/sales/invoices/{invId.Value}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر التحويل: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isConverting = false;
        }
    }

