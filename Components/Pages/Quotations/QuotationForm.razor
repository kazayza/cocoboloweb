                $"تعذّر تحميل المنتجات: {ex.Message}",
                Severity.Error);
            Console.WriteLine($"[QuotationForm.LoadProducts] {ex}");
        }
    }

    // ============================================================
    // Pricing
    // ============================================================
    private void OnPricingTypeChanged(string newType)
    {
        _form.PricingType = newType;
        foreach (var item in _form.Items)
        {
            item.PricingTier = newType;
            if (item.ProductId > 0)
                item.UnitPrice = GetPriceByTier(item, newType);
        }
        RecalculateTotals();
    }

    private void OnTierChanged(int index, string newTier)
    {
        if (index < 0 || index >= _form.Items.Count) return;
        var item = _form.Items[index];
        item.PricingTier = newTier;
        if (item.ProductId > 0)
            item.UnitPrice = GetPriceByTier(item, newTier);
        RecalculateTotals();
    }

    private static decimal GetPriceByTier(QuotationItemDto item, string tier)
    {
        if (tier == PricingTiers.Elite)
            return item.SalePriceElite ?? item.SalePricePremium ?? 0;
        return item.SalePricePremium ?? 0;
    }
    /// <summary>
/// سعر البيع الأساسي من جدول المنتجات حسب الباقة المختارة.
/// ممنوع سعر البيع في عرض السعر يقل عنه.
/// </summary>
private decimal GetBaseSalePrice(QuotationItemDto item)
{
    return GetPriceByTier(item, item.PricingTier);
}
/// <summary>مجموع الأسعار الأساسية لكل الأصناف — الحد الأدنى للإجمالي</summary>
private decimal GetBaseTotal()
{
    return Math.Round(_form.Items.Sum(i => i.Quantity * GetBaseSalePrice(i)), 2);
}

/// <summary>أقصى خصم مسموح به = الإجمالي - الحد الأدنى</summary>
private decimal GetMaxDiscount()
{
    if (_canOverrideBasePrice) return _form.TotalAmount;  // ← الأدمن مفيش حد
    return Math.Max(0, _form.TotalAmount - GetBaseTotal());
}
private static decimal RoundPriceToNearest100(decimal value)
{
    return Math.Round(value / 100m, 0, MidpointRounding.AwayFromZero) * 100m;
}

private static decimal RoundPriceUpTo100(decimal value)
{
    return Math.Ceiling(value / 100m) * 100m;
}

private decimal NormalizeSalePrice(QuotationItemDto item, decimal rawPrice)
{
    var basePrice = GetBaseSalePrice(item);
    var rounded = RoundPriceToNearest100(rawPrice);
    if (!_canOverrideBasePrice && rounded < basePrice)
        rounded = RoundPriceUpTo100(basePrice);
    return rounded;
}

/// <summary>
/// تكلفة الوحدة حسب الباقة المختارة.
/// Premium => PurchasePricePremium
/// Elite => PurchasePriceElite ولو مش موجودة يرجع Premium
/// </summary>
private decimal GetUnitCost(QuotationItemDto item)
{
    return item.PricingTier == PricingTiers.Elite
        ? (item.PurchasePriceElite ?? item.PurchasePricePremium ?? 0m)
        : (item.PurchasePricePremium ?? 0m);
}

/// <summary>
/// إجمالي تكلفة السطر = الكمية × تكلفة الوحدة.
/// </summary>
private decimal GetLineCost(QuotationItemDto item)
{
    return Math.Round(item.Quantity * GetUnitCost(item), 2);
}

/// <summary>
/// إجمالي تكلفة عرض السعر بالكامل.
/// </summary>
private decimal GetTotalCost()
{
    return Math.Round(_form.Items.Sum(GetLineCost), 2);
}

/// <summary>
/// الربح = إجمالي البيع بعد الخصم - إجمالي التكلفة.
/// </summary>
private decimal GetGrossProfit()
{
    return Math.Round(_form.GrandTotal - GetTotalCost(), 2);
}

/// <summary>
/// هامش الربح من البيع.
/// </summary>
//private decimal? GetProfitMarginPercentage()
//{
   // if (_form.GrandTotal <= 0) return null;

   // return Math.Round((GetGrossProfit() / _form.GrandTotal) * 100m, 2);
//}
private decimal? GetProfitMarginPercentage()
{
    var totalCost = GetTotalCost();

    if (totalCost <= 0) return null;

    return Math.Round((GetGrossProfit() / totalCost) * 100m, 2);
}
/// <summary>
/// عند تغيير سعر البيع يدويًا، يمنع أن يقل عن سعر البيع الأساسي من جدول المنتجات.
/// </summary>
private void OnUnitPriceChanged(QuotationItemDto item, decimal newPrice)
{
    var basePrice = GetBaseSalePrice(item);

    if (newPrice < basePrice)
    {
        item.UnitPrice = RoundPriceUpTo100(basePrice);

        Snackbar.Add(
            $"لا يمكن تقليل سعر البيع عن السعر الأساسي: {FormatMoney(basePrice)} ج",
            Severity.Warning);
    }
    else
    {
        item.UnitPrice = NormalizeSalePrice(item, newPrice);
    }

    RecalculateTotals();
}
/// <summary>
/// زيادة سعر منتج واحد بنسبة معينة على السعر الحالي داخل عرض السعر.
/// </summary>
private void IncreaseItemPrice(int index, decimal percentage)
{
    if (index < 0 || index >= _form.Items.Count) return;

    if (percentage <= 0)
    {
        Snackbar.Add("يرجى إدخال نسبة زيادة أكبر من صفر.", Severity.Warning);
        return;
    }

    var item = _form.Items[index];
    var basePrice = GetBaseSalePrice(item);

    // الزيادة تكون على السعر الحالي، ولو السعر الحالي أقل من الأساسي نبدأ من الأساسي
    var currentPrice = item.UnitPrice > 0 ? item.UnitPrice : basePrice;
    if (currentPrice < basePrice)
        currentPrice = basePrice;

    var newPrice = currentPrice + (currentPrice * percentage / 100m);

item.UnitPrice = NormalizeSalePrice(item, newPrice);

    RecalculateTotals();

    Snackbar.Add(
        $"تمت زيادة سعر '{item.ProductName}' بنسبة {percentage:N2}%",
        Severity.Success);
}
/// <summary>
/// زيادة أسعار كل المنتجات بنسبة معينة على الأسعار الحالية داخل عرض السعر.
/// </summary>
private void IncreaseAllPrices(decimal percentage)
{
    if (!_form.Items.Any())
    {
        Snackbar.Add("لا توجد منتجات في عرض السعر.", Severity.Warning);
        return;
    }

    if (percentage <= 0)
    {
        Snackbar.Add("يرجى إدخال نسبة زيادة أكبر من صفر.", Severity.Warning);
        return;
    }

    foreach (var item in _form.Items)
    {
        var basePrice = GetBaseSalePrice(item);

        var currentPrice = item.UnitPrice > 0 ? item.UnitPrice : basePrice;
        if (currentPrice < basePrice)
            currentPrice = basePrice;

        var newPrice = currentPrice + (currentPrice * percentage / 100m);

item.UnitPrice = NormalizeSalePrice(item, newPrice);
    }

    RecalculateTotals();

    Snackbar.Add(
        $"تمت زيادة أسعار كل المنتجات بنسبة {percentage:N2}%",
        Severity.Success);
}

