    .pagination-container { display: flex; justify-content: center; padding: 1rem 0; }
    .loading-container { display:flex; align-items:center; justify-content:center; min-height: 60vh; }
</style>

@code {
    private bool _isLoading = true;
    private QuotationFilterDto _filter = new();
    private PagedResult<QuotationListDto> _pagedResult = new();
    private QuotationStatsDto _stats = new();
    private DateTime? _dateFrom, _dateTo;

    private QuotationListDto? _selected;

    private bool _showConvertDialog, _isConverting;
    private bool _showDeleteDialog, _isDeleting;

    private decimal _convertPaidAmount = 0;
    private string _convertPaymentMethod = PaymentMethods.Cash;
    private int? _convertCashBoxId;
    private List<Models.CashBox> _cashBoxes = new();

    [Inject] private IInvoiceService InvoiceService { get; set; } = null!;

    private string? _currentUserName;
    private bool _canView, _canAdd, _canDelete;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserName = user.Identity?.Name ?? "System";

        _canView = user.HasClaim("Permission", "frmQuotationsList:View") || user.IsInRole("Admin");
        _canAdd = user.HasClaim("Permission", "frmQuotationsList:Add") || user.IsInRole("Admin");
        _canDelete = user.HasClaim("Permission", "frmQuotationsList:Delete") || user.IsInRole("Admin");

        if (!_canView) { Navigation.NavigateTo("/"); return; }

        try
        {
            _cashBoxes = await InvoiceService.GetCashBoxesAsync() ?? new();
            await LoadData();
            _stats = await QuotationService.GetStatsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadData()
    {
        try
        {
            _pagedResult = await QuotationService.GetQuotationsAsync(_filter);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر تحميل القائمة: {ex.Message}", Severity.Error);
            _pagedResult = new PagedResult<QuotationListDto>();
        }
    }

    private async Task RefreshStats()
    {
        try
        {
            _stats = await QuotationService.GetStatsAsync(_filter.DateFrom, _filter.DateTo);
        }
        catch { /* لا نوقف التطبيق لو الإحصائيات فشلت */ }
    }

    private async Task OnSearchChanged()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnFilterChanged()
    {
        _filter.PageNumber = 1;
        await LoadData();
        await RefreshStats();
    }

    private async Task OnDateFromChanged(DateTime? d)
    {
        _dateFrom = d;
        _filter.DateFrom = d;
        await OnFilterChanged();
    }

    private async Task OnDateToChanged(DateTime? d)
    {
        _dateTo = d;
        _filter.DateTo = d;
        await OnFilterChanged();
    }

    private async Task OnPageChanged(int p)
    {
        _filter.PageNumber = p;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _filter = new();
        _dateFrom = null;
        _dateTo = null;
        await LoadData();
        await RefreshStats();
    }

    private void GoToAdd() => Navigation.NavigateTo("/quotations/new");
    private void GoToView(int id) => Navigation.NavigateTo($"/quotations/{id}");

    // ============================================================
    // Convert
    // ============================================================
    private void OpenConvertDialog(QuotationListDto q)
    {
        if (q.InvoiceId != null)
        {
            Snackbar.Add("هذا العرض تم تحويله لفاتورة من قبل.", Severity.Warning);
            return;
        }
        _selected = q;
        _convertPaidAmount = 0;
        _convertPaymentMethod = PaymentMethods.Cash;
        _convertCashBoxId = _cashBoxes.FirstOrDefault()?.CashBoxId;
        _showConvertDialog = true;
    }

    private async Task ExecuteConvert()
    {
        if (_selected == null || _isConverting) return;

        // ✅ Validation قبل الإرسال
        if (_convertPaidAmount > 0 && (_convertCashBoxId is null or 0))
        {
            Snackbar.Add("يرجى اختيار الخزينة لتسجيل الدفعة.", Severity.Warning);
            return;
        }

        if (_convertPaidAmount < 0)
        {
            Snackbar.Add("الدفعة لا يمكن أن تكون سالبة.", Severity.Warning);
            return;
        }

        if (_convertPaidAmount > _selected.GrandTotal)
        {
            Snackbar.Add("الدفعة أكبر من إجمالي عرض السعر.", Severity.Warning);
            return;
        }

        _isConverting = true;
        try
        {
            var (ok, msg, invId) = await QuotationService.ConvertToInvoiceAsync(
                _selected.QuotationId, _convertPaidAmount,
                _convertCashBoxId, _convertPaymentMethod, _currentUserName!);

            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

            if (ok && invId.HasValue)
            {
                _showConvertDialog = false;
                await LoadData();
                await RefreshStats();
                Navigation.NavigateTo($"/sales/invoices/{invId.Value}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ غير متوقع: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isConverting = false;
        }
    }

    // ============================================================
    // Delete
    // ============================================================
    private void ConfirmDelete(QuotationListDto q)
    {
        if (q.InvoiceId != null)
        {
            Snackbar.Add("لا يمكن حذف عرض سعر تم تحويله لفاتورة.", Severity.Warning);
            return;
        }
        _selected = q;
        _showDeleteDialog = true;
    }
    [Inject] private IJSRuntime JS { get; set; } = null!;
[Inject] private IHttpClientFactory HttpFactory { get; set; } = null!;

private async Task ExportToExcel()
{
    try
    {
        Snackbar.Add("جاري تصدير الملف...", Severity.Info);

        var http = HttpFactory.CreateClient();
        http.BaseAddress = new Uri(Navigation.BaseUri);

        var response = await http.PostAsJsonAsync(
            "/api/quotations/export-excel", _filter);

        if (!response.IsSuccessStatusCode)
        {
            Snackbar.Add($"تعذّر التصدير. كود الخطأ: {response.StatusCode}", Severity.Error);
            return;
        }

        var bytes = await response.Content.ReadAsByteArrayAsync();
        var fileName = $"Quotations-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";

        await DownloadFile(fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            bytes);

        Snackbar.Add($"✅ تم تصدير {_pagedResult.TotalCount} عرض سعر بنجاح", Severity.Success);
    }
    catch (Exception ex)
    {
        Snackbar.Add($"خطأ في التصدير: {ex.Message}", Severity.Error);
    }
}

