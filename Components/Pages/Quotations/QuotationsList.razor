@page "/quotations"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components
@using System.Net.Http.Json

@inject IQuotationService QuotationService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider
@inject IQuotationExportService ExportService
@inject IEmployeeService EmployeeService

@if (_isLoading)
{
    <div class="loading-container">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </div>
}
else
{
    <div class="quotations-page" dir="rtl">

        <div class="page-header">
            <div class="header-content">
                <div class="header-info">
                    <h1>
                        <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Class="header-icon" />
                        عروض الأسعار
                    </h1>
                    <p>إدارة وتحويل عروض الأسعار لفواتير</p>
                </div>
                <div class="header-kpis">
    <div class="header-kpi-pill total-value-pill">
        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" />
        <span>القيمة الإجمالية</span>
        <strong>@FormatCompactMoney(_stats.TotalValue)</strong>
    </div>

    <div class="header-kpi-pill conversion-rate-pill">
        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
        <span>معدل التحويل</span>
        <strong>@_stats.ConversionRate%</strong>
    </div>
</div>
                <div class="header-actions">
    <div style="display:flex; gap:0.5rem;">
        <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.FileDownload"
                   OnClick="ExportToExcel"
                   Size="Size.Large">
            تصدير إكسيل
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                   OnClick="ExportToPdf"
                   Size="Size.Large">
            تصدير PDF
        </MudButton>
        @if (_canAdd)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="GoToAdd"
                       Size="Size.Large"
                       Class="add-btn">
                عرض سعر جديد
            </MudButton>
        }
    </div>
</div>
            </div>

            <!-- Stats -->
<div class="stats-row">

    <div class="@GetStatCardClass(QuickFilterAll)"
         @onclick="@(() => ApplyStatsQuickFilter(QuickFilterAll))">
        <div class="stat-icon total">
            <MudIcon Icon="@Icons.Material.Filled.Description" />
        </div>
        <div class="stat-info">
            <span class="stat-value">@_stats.TotalCount</span>
            <span class="stat-label">إجمالي العروض</span>
        </div>
    </div>

    <div class="@GetStatCardClass(QuickFilterAccepted)"
         @onclick="@(() => ApplyStatsQuickFilter(QuickFilterAccepted))">
        <div class="stat-icon accepted">
            <MudIcon Icon="@Icons.Material.Filled.ThumbUp" />
        </div>
        <div class="stat-info">
            <span class="stat-value">@_stats.AcceptedCount</span>
            <span class="stat-label">مقبول</span>
        </div>
    </div>

    <div class="@GetStatCardClass(QuickFilterRejected)"
         @onclick="@(() => ApplyStatsQuickFilter(QuickFilterRejected))">
        <div class="stat-icon rejected">
            <MudIcon Icon="@Icons.Material.Filled.ThumbDown" />
        </div>
        <div class="stat-info">
            <span class="stat-value">@_stats.RejectedCount</span>
            <span class="stat-label">مرفوض</span>
        </div>
    </div>

    <div class="@GetStatCardClass(QuickFilterConverted)"
         @onclick="@(() => ApplyStatsQuickFilter(QuickFilterConverted))">
        <div class="stat-icon converted">
            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" />
        </div>
        <div class="stat-info">
            <span class="stat-value">@_stats.ConvertedCount</span>
            <span class="stat-label">تحوّلت لفواتير</span>
        </div>
    </div>

    <div class="@GetStatCardClass(QuickFilterPending)"
         @onclick="@(() => ApplyStatsQuickFilter(QuickFilterPending))">
        <div class="stat-icon pending">
            <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" />
        </div>
        <div class="stat-info">
            <span class="stat-value">@_stats.PendingCount</span>
            <span class="stat-label">في الانتظار</span>
        </div>
    </div>

    <div class="@GetStatCardClass(QuickFilterExpired)"
         @onclick="@(() => ApplyStatsQuickFilter(QuickFilterExpired))">
        <div class="stat-icon expired">
            <MudIcon Icon="@Icons.Material.Filled.Schedule" />
        </div>
        <div class="stat-info">
            <span class="stat-value">@_stats.ExpiredCount</span>
            <span class="stat-label">منتهي</span>
        </div>
    </div>

  

</div>
        </div>

        <MudPaper Class="filters-container" Elevation="0">
            <div class="filters-row">
                <div class="search-field">
                    <MudTextField T="string"
                                  Value="_filter.SearchText"
                                  ValueChanged="@(async (string v) => { _filter.SearchText = v; await OnSearchChanged(); })"
                                  Placeholder="بحث باسم العميل أو الملاحظات..."
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true" DebounceInterval="400" Clearable="true" />
                </div>

                <MudDatePicker Date="_dateFrom" DateChanged="OnDateFromChanged"
                               Label="من تاريخ" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Class="filter-select" Clearable="true" />
                

                <MudDatePicker Date="_dateTo" DateChanged="OnDateToChanged"
                               Label="إلى تاريخ" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Class="filter-select" Clearable="true" />
                <MudSelect T="int?"
           Value="_filter.EmpId"
           ValueChanged="@(async (int? v) => { _filter.EmpId = v; await OnFilterChanged(); })"
           Label="الموظف"
           Variant="Variant.Outlined"
           Margin="Margin.Dense"
           Clearable="true"
           Class="filter-select">
    @foreach (var emp in _employees)
    {
        <MudSelectItem T="int?" Value="@((int?)emp.EmployeeId)">
            @emp.FullName
        </MudSelectItem>
    }
</MudSelect>
<MudSelect T="string"
           Value="_filter.Status"
           ValueChanged="@(async (string v) => { _filter.Status = v; _filter.IsConverted = null; _filter.IsExpired = null; await OnFilterChanged(); })"
           Label="حالة العرض"
           Variant="Variant.Outlined"
           Margin="Margin.Dense"
           Clearable="true"
           Class="filter-select">
    @foreach (var status in QuotationStatuses.All)
    {
        <MudSelectItem T="string" Value="@status.Key">
            @status.Value
        </MudSelectItem>
    }
</MudSelect>

                <MudSelect T="bool?"
                           Value="_filter.IsConverted"
                           ValueChanged="@(async (bool? v) => { _filter.IsConverted = v; _filter.Status = null; _filter.IsExpired = null; _filter.PendingOnly = null; await OnFilterChanged(); })"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Placeholder="حالة التحويل" Clearable="true" Class="filter-select">
                    <MudSelectItem T="bool?" Value="@((bool?)true)">تحوّلت لفاتورة</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">لم تتحول بعد</MudSelectItem>
                </MudSelect>

                <MudIconButton Icon="@Icons.Material.Filled.FilterAltOff"
                               Color="Color.Default" Variant="Variant.Outlined"
                               OnClick="ResetFilters" Title="إعادة تعيين" />
            </div>
        </MudPaper>

        <MudPaper Elevation="0" Class="table-container">
            <MudTable Items="@_pagedResult.Items" Hover="true" Striped="true"
                      OnRowClick="@((TableRowClickEventArgs<QuotationListDto> args) => GoToView(args.Item.QuotationId))"
                      Class="quotations-table">
                <HeaderContent>
    <MudTh>الرقم</MudTh>
    <MudTh>التاريخ</MudTh>
    <MudTh>العميل</MudTh>
    <MudTh>الموظف</MudTh>
    <MudTh>الباقة</MudTh>
    <MudTh>الإجمالي</MudTh>

    @if (_canViewCost)
    {
        <MudTh>التكلفة</MudTh>
        <MudTh>هامش الربح</MudTh>
    }

    <MudTh>أضيف بواسطة</MudTh>
    <MudTh>الأصناف</MudTh>
    <MudTh>الحالة</MudTh>
    <MudTh>الفاتورة</MudTh>
    <MudTh>إجراءات</MudTh>
</HeaderContent>
                <RowTemplate>
                    <MudTd><span class="quote-number">@context.ReferenceNumber</span></MudTd>

<MudTd>@context.QuotationDate.ToString("yyyy/MM/dd")</MudTd>

<MudTd>
    <strong>@(context.PartyName ?? "-")</strong>
    @if (!string.IsNullOrEmpty(context.PartyPhone))
    {
        <div style="font-size:0.78rem; color:var(--mud-palette-text-secondary);">
            @context.PartyPhone
        </div>
    }
</MudTd>

<MudTd>
    @(string.IsNullOrWhiteSpace(context.EmpName) ? "-" : context.EmpName)
</MudTd>

<MudTd>
    <MudChip T="string" Size="Size.Small"
             Color="@(context.PricingType == PricingTiers.Elite ? Color.Warning : Color.Info)">
        @PricingTiers.All.GetValueOrDefault(context.PricingType ?? "Premium", "بريميوم")
    </MudChip>
</MudTd>

<MudTd>
    <strong>@FormatMoney(context.GrandTotal)</strong>
</MudTd>

@if (_canViewCost)
{
    <MudTd>
        @if (context.TotalCost.HasValue)
        {
            <strong style="color:#b45309;">
                @FormatMoney(context.TotalCost.Value)
            </strong>
        }
        else
        {
            <span class="text-muted">-</span>
        }
    </MudTd>

    <MudTd>
        @if (context.ProfitMarginPercentage.HasValue)
        {
            var margin = context.ProfitMarginPercentage.Value;

            <MudChip T="string"
                     Size="Size.Small"
                     Color="@(margin >= 30 ? Color.Success : margin >= 15 ? Color.Warning : Color.Error)">
                @($"{margin:N2}%")
            </MudChip>
        }
        else
        {
            <span class="text-muted">-</span>
        }
    </MudTd>
}

<MudTd>
    @(string.IsNullOrWhiteSpace(context.CreatedBy) ? "-" : context.CreatedBy)
</MudTd>

<MudTd>@context.ItemsCount</MudTd>
                    <MudTd>
                        @if (context.InvoiceId != null)
{
    <MudChip T="string" Size="Size.Small" Color="Color.Success"
             Icon="@Icons.Material.Filled.CheckCircle">
        تحوّل لفاتورة
    </MudChip>
}
else if (context.IsExpired)
{
    <MudChip T="string" Size="Size.Small" Color="Color.Error"
             Icon="@Icons.Material.Filled.Schedule">
        منتهي
    </MudChip>
}
else
{
    @switch (context.Status)
    {
        case "Draft":
            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                     Icon="@Icons.Material.Filled.Edit">مسودة</MudChip>
            break;
        case "Sent":
            <MudChip T="string" Size="Size.Small" Color="Color.Info"
                     Icon="@Icons.Material.Filled.Send">تم الإرسال</MudChip>
            break;
        case "Accepted":
            <MudChip T="string" Size="Size.Small" Color="Color.Success"
                     Icon="@Icons.Material.Filled.ThumbUp">مقبول</MudChip>
            break;
        case "Rejected":
    <div style="display:inline-flex; align-items:center; gap:4px;">
        <MudChip T="string" Size="Size.Small" Color="Color.Error"
                 Icon="@Icons.Material.Filled.ThumbDown">مرفوض</MudChip>
        @if (!string.IsNullOrEmpty(context.RejectionReason))
        {
            <MudTooltip Text="@($"سبب الرفض: {context.RejectionReason}")">
                <MudIcon Icon="@Icons.Material.Filled.Info" 
                         Size="Size.Small" 
                         Color="Color.Error"
                         Style="cursor:help;" />
            </MudTooltip>
        }
    </div>
    break;
        default:
            <MudChip T="string" Size="Size.Small" Color="Color.Info">قيد المراجعة</MudChip>
            break;
    }
}
                    </MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.InvoiceReference))
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       OnClick="@(() => Navigation.NavigateTo($"/sales/invoices/{context.InvoiceId}"))">
                                @context.InvoiceReference
                            </MudButton>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </MudTd>
                    <MudTd>
                        <div class="table-actions" @onclick:stopPropagation="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Size="Size.Small" Color="Color.Info"
                                           OnClick="() => GoToView(context.QuotationId)"
                                           Title="عرض" />
                            <MudIconButton Icon="@Icons.Material.Filled.Print"
                                           Size="Size.Small" Color="Color.Default"
                                           OnClick="@(() => Navigation.NavigateTo($"/quotations/{context.QuotationId}/print"))"
Title="طباعة" />
                            @if (context.InvoiceId == null && _canAdd)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                               Size="Size.Small" Color="Color.Success"
                                               OnClick="() => OpenConvertDialog(context)"
                                               Title="تحويل لفاتورة" />
                            }
                            @if (context.InvoiceId == null && _canDelete)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="() => ConfirmDelete(context)"
                                               Title="حذف" />
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        @if (_pagedResult.TotalPages > 1)
        {
            <div class="pagination-container">
                <MudPagination Count="@_pagedResult.TotalPages"
                               Selected="@_filter.PageNumber"
                               SelectedChanged="OnPageChanged"
                               Color="Color.Primary"
                               ShowFirstButton="true" ShowLastButton="true" />
            </div>
        }
    </div>
}

<!-- Convert Dialog -->
<MudDialog @bind-Visible="_showConvertDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Success" />
            <MudText Typo="Typo.h6">تحويل عرض السعر إلى فاتورة</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-3">
            <strong>عرض السعر:</strong> @(_selected?.ReferenceNumber)<br />
            <strong>العميل:</strong> @(_selected?.PartyName)<br />
            <strong>الإجمالي:</strong> @FormatMoney(_selected?.GrandTotal ?? 0) ج
        </MudAlert>

        <MudText Typo="Typo.body2" Class="mb-2">
            هل تريد تسجيل دفعة فورية مع إنشاء الفاتورة؟
        </MudText>

        @if (_selected != null && _selected.GrandTotal > 0)
        {
            <div class="quick-pay-row mb-3">
                @foreach (var pct in SystemConstants.QuickPayPercentages)
                {
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                               OnClick="@(() => _convertPaidAmount = Math.Round(_selected.GrandTotal * pct / 100m, 2))">
                        @pct%
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success"
                           OnClick="@(() => _convertPaidAmount = _selected.GrandTotal)">
                    كامل
                </MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default"
                           OnClick="@(() => _convertPaidAmount = 0)">
                    بدون دفع
                </MudButton>
            </div>
        }

        <MudNumericField @bind-Value="_convertPaidAmount" Label="المبلغ المدفوع"
                         Variant="Variant.Outlined" Min="0m"
                         Max="@(_selected?.GrandTotal ?? 0)" Class="mb-3" />

        @if (_convertPaidAmount > 0)
        {
            <MudSelect T="string" @bind-Value="_convertPaymentMethod"
                       Label="طريقة الدفع" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var pm in PaymentMethods.All)
                {
                    <MudSelectItem T="string" Value="@pm.Key">@pm.Value</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" @bind-Value="_convertCashBoxId"
                       Label="الخزينة" Variant="Variant.Outlined" Class="mb-3">
                @foreach (var cb in _cashBoxes)
                {
                    <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
                }
            </MudSelect>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showConvertDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled"
                   OnClick="ExecuteConvert" Disabled="@_isConverting">
            @if (_isConverting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            تحويل لفاتورة
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Delete Dialog -->
<MudDialog @bind-Visible="_showDeleteDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">حذف عرض السعر</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>هل تريد حذف عرض السعر <strong>@(_selected?.ReferenceNumber)</strong>؟</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showDeleteDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled"
                   OnClick="ExecuteDelete" Disabled="@_isDeleting">
            حذف
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .quotations-page { padding: 1rem; max-width: 1800px; margin: 0 auto; direction: rtl; }

    .page-header {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        border-radius: 20px; padding: 2rem; margin-bottom: 1.5rem;
        box-shadow: 0 10px 40px var(--gold-border);
    }
    .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
}
.header-kpis {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    min-width: 320px;
    flex-wrap: wrap;
}

.header-kpi-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.35);
    color: #fff;
    border-radius: 999px;
    padding: 0.65rem 1.1rem;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.18), 0 8px 24px rgba(0,0,0,0.12);
    backdrop-filter: blur(6px);
    white-space: nowrap;
}

.header-kpi-pill span {
    font-size: 0.82rem;
    opacity: 0.9;
}

.header-kpi-pill strong {
    font-size: clamp(0.95rem, 1.2vw, 1.2rem);
    font-weight: 900;
    line-height: 1;
    direction: ltr;
}

.total-value-pill strong {
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
}
    .header-info h1 {
        color: white; font-size: 2rem; font-weight: 800; margin: 0;
        display: flex; align-items: center; gap: 0.75rem;
    }
    .header-icon { font-size: 2rem !important; }
    .header-info p { color: rgba(255,255,255,0.85); margin: 0.25rem 0 0 0; }

    .add-btn {
        background: rgba(255,255,255,0.95) !important;
        color: var(--navy-dark) !important;
        font-weight: 700 !important;
    }

    .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
    gap: 0.85rem;
}
    .stat-card {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 14px;
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.2s ease;
}

.stat-card:hover {
    transform: translateY(-3px);
    background: rgba(255,255,255,0.22);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
}

.stat-card.active {
    background: rgba(255,255,255,0.32);
    border: 2px solid rgba(255,255,255,0.95);
    box-shadow: 0 0 0 3px rgba(255,255,255,0.18);
}

.stat-card-info {
    cursor: default;
}

.stat-card-info:hover {
    transform: none;
}
    .stat-icon {
    width: 40px;
    height: 40px;
    min-width: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex: 0 0 40px;
}
    .stat-icon.total { background: rgba(255,255,255,0.2); }
.stat-icon.value { background: rgba(16,185,129,0.4); }
.stat-icon.converted { background: rgba(59,130,246,0.4); }
.stat-icon.pending { background: rgba(245,158,11,0.4); }
.stat-icon.rate { background: rgba(139,92,246,0.4); }
.stat-icon.accepted { background: rgba(34,197,94,0.45); }
.stat-icon.rejected { background: rgba(239,68,68,0.45); }
.stat-icon.expired { background: rgba(244,63,94,0.45); }
    .stat-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
}

.stat-value {
    font-size: clamp(1rem, 1.4vw, 1.35rem);
    font-weight: 800;
    color: white;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    direction: ltr;
    text-align: right;
}

.stat-label {
    font-size: 0.76rem;
    color: rgba(255,255,255,0.85);
    margin-top: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
    

    .filters-container {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px; padding: 1.25rem; margin-bottom: 1.5rem;
    }
    .filters-row { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
    .search-field { flex: 2; min-width: 250px; }
    .filter-select { flex: 1; min-width: 150px; }

    .table-container {
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px; overflow: hidden; margin-bottom: 1.5rem;
    }

    .quote-number {
