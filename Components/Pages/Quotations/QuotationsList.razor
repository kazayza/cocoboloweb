@code {
    private bool _isLoading = true;
    private const string QuickFilterAll = "all";
private const string QuickFilterConverted = "converted";
private const string QuickFilterPending = "pending";
private const string QuickFilterAccepted = "accepted";
private const string QuickFilterRejected = "rejected";
private const string QuickFilterExpired = "expired";
private const string QuickFilterCustom = "custom";

private string _activeQuickFilter = QuickFilterAll;

    [Parameter]
    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusQuery { get; set; }

    private QuotationFilterDto _filter = new();
    private PagedResult<QuotationListDto> _pagedResult = new();
    private QuotationStatsDto _stats = new();
    private DateTime? _dateFrom, _dateTo;
    private QuotationListDto? _selected;

    private bool _showConvertDialog, _isConverting;
    private bool _showDeleteDialog, _isDeleting;

    private decimal _convertPaidAmount = 0;
    private string _convertPaymentMethod = PaymentMethods.Cash;
    private int? _convertCashBoxId;
    private List<Models.CashBox> _cashBoxes = new();
    private List<EmployeeListDto> _employees = new();

    [Inject] private IInvoiceService InvoiceService { get; set; } = null!;

    private string? _currentUserName;
    private bool _canView, _canAdd, _canDelete, _canViewCost;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserName = user.Identity?.Name ?? "System";

        _canView = user.HasClaim("Permission", "frmQuotationsList:View") || user.IsInRole("Admin");
        _canAdd = user.HasClaim("Permission", "frmQuotationsList:Add") || user.IsInRole("Admin");
        _canDelete = user.HasClaim("Permission", "frmQuotationsList:Delete") || user.IsInRole("Admin");
        _canViewCost = user.IsInRole("Admin")
            || user.IsInRole("AccountManager");

        if (!_canView) { Navigation.NavigateTo("/"); return; }

        try
        {
            _cashBoxes = await InvoiceService.GetCashBoxesAsync() ?? new();
            _employees = await EmployeeService.SearchEmployeesAsync("", 200);
            ApplyQueryFilters();
            await LoadData();
            _stats = await QuotationService.GetStatsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
}

    private void ApplyQueryFilters()
    {
        if (string.IsNullOrWhiteSpace(StatusQuery))
            return;

        var requestedStatus = StatusQuery.Trim();
        var matchedStatus = QuotationStatuses.All.Keys
            .FirstOrDefault(s => string.Equals(s, requestedStatus, StringComparison.OrdinalIgnoreCase));

        if (string.IsNullOrWhiteSpace(matchedStatus))
            return;

        _filter.PageNumber = 1;
        _filter.Status = matchedStatus;
        _filter.IsConverted = null;
        _filter.IsExpired = null;
        _filter.PendingOnly = null;

        SyncActiveQuickFilter();
    }

    private string GetStatCardClass(string quickFilter)
    {
        return _activeQuickFilter == quickFilter
            ? "stat-card active"
            : "stat-card";
    }

private async Task ApplyStatsQuickFilter(string quickFilter)
{
    _activeQuickFilter = quickFilter;

    // نحافظ على البحث والتاريخ والموظف
    // ونلغي فقط فلاتر الحالة السريعة
    _filter.PageNumber = 1;
    _filter.Status = null;
    _filter.IsConverted = null;
    _filter.IsExpired = null;
    _filter.PendingOnly = null;

    switch (quickFilter)
    {
        case QuickFilterConverted:
            _filter.IsConverted = true;
            break;

        case QuickFilterPending:
            _filter.PendingOnly = true;
            break;

        case QuickFilterAccepted:
            _filter.Status = QuotationStatuses.Accepted;
            break;

        case QuickFilterRejected:
            _filter.Status = QuotationStatuses.Rejected;
            break;

        case QuickFilterExpired:
            _filter.IsExpired = true;
            break;

        case QuickFilterAll:
        default:
            break;
    }

    await LoadData();
}

    private async Task LoadData()
    {
        try
        {
            _pagedResult = await QuotationService.GetQuotationsAsync(_filter);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر تحميل القائمة: {ex.Message}", Severity.Error);
            _pagedResult = new PagedResult<QuotationListDto>();
        }
    }

    private async Task RefreshStats()
    {
        try
        {
            _stats = await QuotationService.GetStatsAsync(_filter.DateFrom, _filter.DateTo);
        }
        catch { /* لا نوقف التطبيق لو الإحصائيات فشلت */ }
    }

    private async Task OnSearchChanged()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnFilterChanged()
{
    _filter.PageNumber = 1;
    SyncActiveQuickFilter();
    await LoadData();
    await RefreshStats();
}
private void SyncActiveQuickFilter()
{
    if (_filter.PendingOnly == true)
    {
        _activeQuickFilter = QuickFilterPending;
    }
    else if (_filter.IsConverted == true || _filter.Status == QuotationStatuses.Converted)
    {
        _activeQuickFilter = QuickFilterConverted;
    }
    else if (_filter.IsExpired == true || _filter.Status == QuotationStatuses.Expired)
    {
        _activeQuickFilter = QuickFilterExpired;
    }
    else if (_filter.Status == QuotationStatuses.Accepted)
    {
        _activeQuickFilter = QuickFilterAccepted;
    }
    else if (_filter.Status == QuotationStatuses.Rejected)
    {
        _activeQuickFilter = QuickFilterRejected;
    }
    else if (string.IsNullOrWhiteSpace(_filter.Status)
             && _filter.IsConverted == null
             && _filter.IsExpired == null
             && _filter.PendingOnly != true)
    {
        _activeQuickFilter = QuickFilterAll;
    }
    else
    {
        _activeQuickFilter = QuickFilterCustom;
    }
}

    private async Task OnDateFromChanged(DateTime? d)
    {
        _dateFrom = d;
        _filter.DateFrom = d;
        await OnFilterChanged();
    }

    private async Task OnDateToChanged(DateTime? d)
    {
        _dateTo = d;
        _filter.DateTo = d;
        await OnFilterChanged();
    }

    private async Task OnPageChanged(int p)
    {
        _filter.PageNumber = p;
        await LoadData();
    }

    private async Task ResetFilters()
{
    _filter = new();
    _dateFrom = null;
    _dateTo = null;
    _activeQuickFilter = QuickFilterAll;

    await LoadData();
    await RefreshStats();
}

    private void GoToAdd() => Navigation.NavigateTo("/quotations/new");
    private void GoToView(int id) => Navigation.NavigateTo($"/quotations/{id}");

    // ============================================================
    // Convert
    // ============================================================
    private void OpenConvertDialog(QuotationListDto q)
    {
        if (q.InvoiceId != null)
        {
            Snackbar.Add("هذا العرض تم تحويله لفاتورة من قبل.", Severity.Warning);
            return;
        }
        _selected = q;
        _convertPaidAmount = 0;
        _convertPaymentMethod = PaymentMethods.Cash;
        _convertCashBoxId = _cashBoxes.FirstOrDefault()?.CashBoxId;
        _showConvertDialog = true;
    }

    private async Task ExecuteConvert()
    {
        if (_selected == null || _isConverting) return;

        // ✅ Validation قبل الإرسال
        if (_convertPaidAmount > 0 && (_convertCashBoxId is null or 0))
        {
            Snackbar.Add("يرجى اختيار الخزينة لتسجيل الدفعة.", Severity.Warning);
            return;
        }

        if (_convertPaidAmount < 0)
        {
            Snackbar.Add("الدفعة لا يمكن أن تكون سالبة.", Severity.Warning);
            return;
        }

        if (_convertPaidAmount > _selected.GrandTotal)
        {
            Snackbar.Add("الدفعة أكبر من إجمالي عرض السعر.", Severity.Warning);
            return;
        }

        _isConverting = true;
        try
        {
            var (ok, msg, invId) = await QuotationService.ConvertToInvoiceAsync(
                _selected.QuotationId, _convertPaidAmount,
                _convertCashBoxId, _convertPaymentMethod, _currentUserName!);

            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

            if (ok && invId.HasValue)
            {
                _showConvertDialog = false;
                await LoadData();
                await RefreshStats();
                Navigation.NavigateTo($"/sales/invoices/{invId.Value}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ غير متوقع: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isConverting = false;
        }
    }

    // ============================================================
    // Delete
    // ============================================================
    private void ConfirmDelete(QuotationListDto q)
    {
        if (q.InvoiceId != null)
        {
            Snackbar.Add("لا يمكن حذف عرض سعر تم تحويله لفاتورة.", Severity.Warning);
            return;
        }
        _selected = q;
        _showDeleteDialog = true;
    }
    [Inject] private IJSRuntime JS { get; set; } = null!;
[Inject] private IHttpClientFactory HttpFactory { get; set; } = null!;

private async Task ExportToExcel()
{
    try
    {
        Snackbar.Add("جاري تصدير الملف...", Severity.Info);

        var http = HttpFactory.CreateClient();
        http.BaseAddress = new Uri(Navigation.BaseUri);

        var response = await http.PostAsJsonAsync(
            "/api/quotations/export-excel", _filter);

        if (!response.IsSuccessStatusCode)
        {
            Snackbar.Add($"تعذّر التصدير. كود الخطأ: {response.StatusCode}", Severity.Error);
            return;
        }

        var bytes = await response.Content.ReadAsByteArrayAsync();
        var fileName = $"Quotations-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";

        await DownloadFile(fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            bytes);

        Snackbar.Add($"✅ تم تصدير {_pagedResult.TotalCount} عرض سعر بنجاح", Severity.Success);
    }
    catch (Exception ex)
    {
        Snackbar.Add($"خطأ في التصدير: {ex.Message}", Severity.Error);
    }
}

private async Task ExportToPdf()
{
    try
    {
        Snackbar.Add("جاري تصدير الملف...", Severity.Info);

        var http = HttpFactory.CreateClient();
        http.BaseAddress = new Uri(Navigation.BaseUri);

        var response = await http.PostAsJsonAsync(
            "/api/quotations/export-pdf", _filter);

        if (!response.IsSuccessStatusCode)
        {
            Snackbar.Add($"تعذّر التصدير. كود الخطأ: {response.StatusCode}", Severity.Error);
            return;
        }

        var bytes = await response.Content.ReadAsByteArrayAsync();
        var fileName = $"Quotations-{DateTime.Now:yyyyMMdd-HHmm}.pdf";

        await DownloadFile(fileName, "application/pdf", bytes);

        Snackbar.Add($"✅ تم تصدير {_pagedResult.TotalCount} عرض سعر بنجاح", Severity.Success);
    }
    catch (Exception ex)
    {
        Snackbar.Add($"خطأ في التصدير: {ex.Message}", Severity.Error);
    }
}

/// <summary>تنزيل ملف من الـ bytes عبر JS</summary>
private async Task DownloadFile(string fileName, string contentType, byte[] bytes)
{
    var base64 = Convert.ToBase64String(bytes);
    await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, contentType, base64);
}

    private async Task ExecuteDelete()
    {
        if (_selected == null || _isDeleting) return;

        _isDeleting = true;
        try
        {
            var (ok, msg) = await QuotationService.DeleteQuotationAsync(
                _selected.QuotationId, _currentUserName!);

            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

            if (ok)
            {
                _showDeleteDialog = false;
                await LoadData();
                await RefreshStats();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر الحذف: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private string FormatMoney(decimal v) => $"{v:N2} ج";
    private string FormatCompactMoney(decimal value)
{
    var abs = Math.Abs(value);

    if (abs >= 1_000_000_000)
        return $"{value / 1_000_000_000m:N2}B ج";

    if (abs >= 1_000_000)
        return $"{value / 1_000_000m:N2}M ج";

    if (abs >= 1_000)
        return $"{value / 1_000m:N0}K ج";

    return $"{value:N0} ج";
}
