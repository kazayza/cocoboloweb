/// <summary>تنزيل ملف من الـ bytes عبر JS</summary>
private async Task DownloadFile(string fileName, string contentType, byte[] bytes)
{
    var base64 = Convert.ToBase64String(bytes);
    await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, contentType, base64);
}

    private async Task ExecuteDelete()
    {
        if (_selected == null || _isDeleting) return;

        _isDeleting = true;
        try
        {
            var (ok, msg) = await QuotationService.DeleteQuotationAsync(
                _selected.QuotationId, _currentUserName!);

            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

            if (ok)
            {
                _showDeleteDialog = false;
                await LoadData();
                await RefreshStats();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذّر الحذف: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDeleting = false;
        }
    }

