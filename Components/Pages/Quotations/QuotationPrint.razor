@page "/quotations/{Id:int}/print"
@layout COCOBOLOERPNEW.Components.Layout.EmptyLayout

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject IQuotationService QuotationService
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (_isLoading)
{
    <div style="padding:3rem; text-align:center;">جاري التحميل...</div>
}
else if (_data == null)
{
    <div style="padding:2rem; text-align:center;"><h2>عرض السعر غير موجود</h2></div>
}
else
{
    var q = _data.Quotation;

    <div class="print-actions no-print">
        <button class="btn-action btn-print" @onclick="PrintNow">🖨️ طباعة</button>
        <button class="btn-action btn-back" @onclick="GoBack">← رجوع</button>
    </div>

    <div class="print-page" dir="rtl">

        <!-- Watermark -->
        <div class="watermark">QUOTATION</div>

        <!-- Header -->
        <div class="company-header">
            <div class="company-info">
                <h1>@(_data.CompanyName ?? "COCOBOLO")</h1>
                @if (!string.IsNullOrEmpty(_data.CompanyAddress))
                {
                    <div class="info-line">📍 @_data.CompanyAddress</div>
                }
                @if (!string.IsNullOrEmpty(_data.CompanyPhone))
                {
                    <div class="info-line">📞 @_data.CompanyPhone</div>
                }
                @if (!string.IsNullOrEmpty(_data.CompanyTaxNumber))
                {
                    <div class="info-line">رقم تسجيل ضريبي: @_data.CompanyTaxNumber</div>
                }
            </div>
            <div class="quote-title">
                <div class="title-label">عرض سعر</div>
                <div class="title-number">@q.ReferenceNumber</div>
                <div class="title-date">@q.QuotationDate.ToString("yyyy/MM/dd")</div>
                @if (q.ValidUntil.HasValue)
                {
                    <div class="valid-until">
                        ساري حتى @q.ValidUntil.Value.ToString("yyyy/MM/dd")
                    </div>
                }
            </div>
        </div>

        <!-- Customer & Quotation Info -->
        <div class="party-grid">
            <div class="party-box">
                <h3>السيد العميل / Mr. Client</h3>
                <div class="party-line"><strong>الاسم:</strong> @q.PartyName</div>
                @if (!string.IsNullOrEmpty(_data.CustomerPhone))
                {
                    <div class="party-line"><strong>الهاتف:</strong> @_data.CustomerPhone</div>
                }
                @if (!string.IsNullOrEmpty(_data.CustomerEmail))
                {
                    <div class="party-line"><strong>البريد:</strong> @_data.CustomerEmail</div>
                }
                @if (!string.IsNullOrEmpty(_data.CustomerAddress))
                {
                    <div class="party-line"><strong>العنوان:</strong> @_data.CustomerAddress</div>
                }
            </div>

            <div class="party-box">
                <h3>تفاصيل العرض</h3>
                <div class="party-line"><strong>الرقم:</strong> @q.ReferenceNumber</div>
                <div class="party-line"><strong>التاريخ:</strong> @q.QuotationDate.ToString("yyyy/MM/dd")</div>
                @if (q.ValidUntil.HasValue)
                {
                    <div class="party-line"><strong>الصلاحية:</strong> @q.ValidUntil.Value.ToString("yyyy/MM/dd")</div>
                }
                @if (!string.IsNullOrEmpty(q.EmpName))
                {
                    <div class="party-line"><strong>الموظف:</strong> @q.EmpName</div>
                }
                <div class="party-line">
                    <strong>الباقة:</strong>
                    <span class="tier-badge tier-@(q.PricingType.ToLower())">
                        @PricingTiers.All.GetValueOrDefault(q.PricingType, q.PricingType)
                    </span>
                </div>
            </div>
        </div>

        <!-- Greeting -->
        <div class="greeting">
            <p>تحية طيبة وبعد،</p>
            <p>يسعدنا أن نقدم لكم عرض السعر التالي بناءً على طلبكم:</p>
        </div>

        <!-- Items Table -->
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:50px;">#</th>
                    <th style="width:80px;">الصورة</th>
                    <th>الصنف / Item</th>
                    <th style="width:80px;">الباقة</th>
                    <th style="width:70px;">الكمية</th>
                    <th style="width:100px;">السعر</th>
                    <th style="width:120px;">الإجمالي</th>
                </tr>
            </thead>
            <tbody>
                @{ int rowNum = 1; }
                @foreach (var item in q.Items)
                {
                    <tr>
                        <td class="text-center">@(rowNum++)</td>
                        <td class="text-center">
    @if (item.ProductId > 0)
    {
        <img src="/api/product-images/@item.ProductId" 
             alt="@item.ProductName" 
             class="product-img"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
        <div class="img-placeholder" style="display:none">📦</div>
    }
    else
    {
        <div class="img-placeholder">📦</div>
    }
</td>
                        <td>
                            <strong>@item.ProductName</strong>
                            @if (!string.IsNullOrEmpty(item.ProductDescription))
                            {
                                <div class="item-desc">@item.ProductDescription</div>
                            }
                        </td>
                        <td class="text-center">
                            <span class="tier-badge tier-@(item.PricingTier.ToLower())">
                                @PricingTiers.All.GetValueOrDefault(item.PricingTier, item.PricingTier)
                            </span>
                        </td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@FormatMoney(item.UnitPrice)</td>
                        <td class="text-end"><strong>@FormatMoney(item.TotalAmount)</strong></td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Summary -->
        <div class="summary-section">
            <div class="summary-left">
                @if (!string.IsNullOrEmpty(q.Notes))
                {
                    <div class="notes-box">
                        <strong>ملاحظات:</strong>
                        <p>@q.Notes</p>
                    </div>
                }

                <div class="terms-box">
                    <h4>الشروط والأحكام</h4>
                    <ul>
                        <li>هذا العرض ساري لمدة @((q.ValidUntil.HasValue ? (q.ValidUntil.Value - q.QuotationDate).Days : 15)) يوم من تاريخ إصداره.</li>
                        <li>الأسعار شاملة جميع التكاليف ما لم يذكر خلاف ذلك.</li>
                        <li>التسليم خلال المدة المتفق عليها بعد التأكيد.</li>
                        <li>يستحق الدفع وفقاً للشروط المتفق عليها.</li>
                    </ul>
                </div>
            </div>
            <div class="summary-right">
                <table class="summary-table">
                    <tr>
                        <td>إجمالي الأصناف:</td>
                        <td>@FormatMoney(q.TotalAmount) ج</td>
                    </tr>
                    @if ((q.DiscountAmount ?? 0) > 0)
                    {
                        <tr>
                            <td>خصم (@(q.DiscountPercentage ?? 0)%):</td>
                            <td class="text-error">-@FormatMoney(q.DiscountAmount ?? 0) ج</td>
                        </tr>
                    }
                    <tr class="total-row">
                        <td><strong>الإجمالي النهائي:</strong></td>
                        <td><strong>@FormatMoney(q.GrandTotal) ج</strong></td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Closing -->
        <div class="closing">
            <p>نرجو منكم مراجعة العرض وفي حال موافقتكم يرجى إعادته موقعاً.</p>
            <p>وتفضلوا بقبول فائق الاحترام والتقدير.</p>
        </div>

        <!-- Signatures -->
        <div class="signatures">
            <div class="signature-box">
                <div class="signature-line"></div>
                <div class="signature-label">المفوّض بالعرض</div>
                <div class="signature-name">@(q.EmpName ?? "")</div>
            </div>
            <div class="signature-box">
                <div class="signature-line"></div>
                <div class="signature-label">موافقة العميل</div>
                <div class="signature-name">@q.PartyName</div>
            </div>
        </div>

        <div class="footer-note">
            تم إنشاء عرض السعر في @q.QuotationDate.ToString("yyyy/MM/dd HH:mm")
        </div>
    </div>
}

<style>
    body { background: white !important; margin: 0; padding: 0; }

    .print-actions {
        position: fixed; top: 1rem; left: 1rem;
        display: flex; gap: 0.5rem; z-index: 9999;
    }
    .btn-action {
        padding: 0.6rem 1.5rem; border-radius: 8px;
        border: none; cursor: pointer; font-weight: 700;
        font-size: 0.9rem; font-family: inherit;
    }
    .btn-print { background: #d4af37; color: white; }
    .btn-back { background: #e0e0e0; color: #333; }

    .print-page {
        max-width: 900px; margin: 1rem auto;
        padding: 2rem; background: white; color: #333;
        font-family: 'Tajawal', 'Segoe UI', Arial, sans-serif;
        font-size: 14px; line-height: 1.6;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        position: relative; overflow: hidden;
    }

    .watermark {
        position: absolute; top: 50%; right: 50%;
        transform: translate(50%, -50%) rotate(-45deg);
        font-size: 8rem; font-weight: 900;
        color: rgba(212, 175, 55, 0.05);
        pointer-events: none; z-index: 0; white-space: nowrap;
    }

    .company-header {
        display: flex; justify-content: space-between; align-items: flex-start;
        padding-bottom: 1.5rem; border-bottom: 3px solid #d4af37;
        margin-bottom: 1.5rem; position: relative; z-index: 1;
    }

    .company-info h1 { margin: 0; font-size: 1.8rem; color: #1a2842; font-weight: 800; }
    .info-line { font-size: 0.85rem; color: #555; margin-top: 0.25rem; }

    .quote-title { text-align: left; }
    .title-label { font-size: 1.4rem; font-weight: 800; color: #d4af37; }
    .title-number {
        font-size: 1.1rem; font-weight: 700; margin-top: 0.25rem;
        background: #faf6e8; padding: 0.3rem 0.75rem;
        border-radius: 6px; display: inline-block;
    }
    .title-date { font-size: 0.85rem; color: #666; margin-top: 0.25rem; }
    .valid-until {
        font-size: 0.78rem; color: #d97706; margin-top: 0.25rem;
        font-weight: 600;
    }

    .party-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 1rem; margin-bottom: 1.5rem;
        position: relative; z-index: 1;
    }
    .party-box {
        background: #faf6e8; border: 1px solid #d4af3744;
        border-radius: 8px; padding: 1rem;
    }
    .party-box h3 {
        margin: 0 0 0.5rem 0; font-size: 1rem; color: #1a2842;
        padding-bottom: 0.4rem; border-bottom: 1px solid #d4af3744;
    }
    .party-line { font-size: 0.85rem; margin: 0.25rem 0; }

    .greeting {
        background: #f9f9f9; padding: 1rem;
        border-radius: 6px; margin-bottom: 1rem;
        position: relative; z-index: 1;
    }
    .greeting p { margin: 0.25rem 0; }

    .items-table {
        width: 100%; border-collapse: collapse;
        margin-bottom: 1rem; font-size: 0.85rem;
        position: relative; z-index: 1;
    }
    .items-table th, .items-table td {
        border: 1px solid #ddd; padding: 0.5rem; text-align: right;
    }
    .items-table thead {
        background: linear-gradient(135deg, #1a2842, #2c3e5f);
        color: white;
    }
    .items-table thead th { font-weight: 700; }
    .items-table tbody tr:nth-child(even) { background: #fafafa; }

    .product-img {
        width: 60px; height: 60px; object-fit: cover;
        border-radius: 4px; border: 1px solid #ddd;
    }
    .img-placeholder {
        width: 60px; height: 60px; background: #f0f0f0;
        border-radius: 4px; display: flex; align-items: center;
        justify-content: center; font-size: 1.8rem; margin: 0 auto;
    }

    .item-desc { font-size: 0.75rem; color: #666; margin-top: 0.25rem; }

    .tier-badge {
        display: inline-block; padding: 0.2rem 0.5rem;
        border-radius: 4px; font-size: 0.7rem; font-weight: 700;
    }
    .tier-premium { background: #e3f2fd; color: #1565c0; }
    .tier-elite { background: #fff8e1; color: #f57f17; }

    .text-center { text-align: center; }
    .text-end { text-align: left; }
    .text-error { color: #d32f2f; }

    .summary-section {
        display: grid; grid-template-columns: 1.5fr 1fr;
        gap: 1.5rem; margin-top: 1rem;
        position: relative; z-index: 1;
    }

    .notes-box {
        background: #f9f9f9; border: 1px solid #ddd;
        border-radius: 6px; padding: 0.75rem;
        font-size: 0.85rem; margin-bottom: 0.75rem;
    }
    .notes-box p { margin: 0.25rem 0 0 0; }

    .terms-box {
        background: #fff8e1; border: 1px solid #f59e0b44;
        border-radius: 6px; padding: 0.75rem; font-size: 0.8rem;
    }
    .terms-box h4 {
        margin: 0 0 0.5rem 0; font-size: 0.9rem; color: #d97706;
    }
    .terms-box ul { margin: 0; padding-right: 1.2rem; }
    .terms-box li { margin: 0.2rem 0; }

    .summary-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
    .summary-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; }
    .summary-table td:last-child { text-align: left; font-weight: 600; }
    .summary-table .total-row td {
        background: #faf6e8; font-size: 1.1rem;
        border-top: 2px solid #d4af37; border-bottom: 2px solid #d4af37;
    }

    .closing {
        background: #f9f9f9; padding: 1rem; border-radius: 6px;
        margin-top: 1.5rem; font-size: 0.9rem;
        position: relative; z-index: 1;
    }
    .closing p { margin: 0.25rem 0; }

    .signatures {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 3rem; margin-top: 2rem; padding-top: 1.5rem;
        position: relative; z-index: 1;
    }
    .signature-box { text-align: center; }
    .signature-line { border-top: 1px solid #333; margin-bottom: 0.5rem; margin-top: 2.5rem; }
    .signature-label { font-weight: 700; font-size: 0.9rem; }
    .signature-name { font-size: 0.78rem; color: #666; margin-top: 0.25rem; }

    .footer-note {
        text-align: center; font-size: 0.75rem; color: #999;
        margin-top: 2rem; padding-top: 1rem;
        border-top: 1px dashed #ddd; position: relative; z-index: 1;
    }

    @@media print {
        body { background: white !important; margin: 0; }
        .no-print { display: none !important; }
        .print-page { box-shadow: none; margin: 0; padding: 0.5cm; max-width: 100%; }
        .product-img, .img-placeholder { width: 45px; height: 45px; }
        @@page { size: A4; margin: 1cm; }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private bool _isLoading = true;
    private QuotationPrintDto? _data;

    protected override async Task OnInitializedAsync()
    {
        _data = await QuotationService.GetQuotationForPrintAsync(Id);
        _isLoading = false;
    }

    private async Task PrintNow() => await JS.InvokeVoidAsync("window.print");
    private void GoBack() => Navigation.NavigateTo($"/quotations/{Id}");

    private string FormatMoney(decimal v) => $"{v:N2}";

    private string GetImageUrl(string? path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        if (path.StartsWith("http") || path.StartsWith("/")) return path;
        return "/" + path;
    }
}
