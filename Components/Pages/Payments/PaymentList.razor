</style>

@code {
    private bool _isLoading = true;
    private PaymentFilterDto _filter = new() { TransactionType = TransactionTypes.Sale };
    private PagedResult<PaymentListDto> _pagedResult = new();
    private PaymentStatsDto _stats = new();
    private DateTime? _dateFrom, _dateTo;
    private List<Models.CashBox> _cashBoxes = new();

    // Cancel dialog
    private bool _showCancelDialog, _isCancelling;
    private PaymentListDto? _selected;
    private string _cancelReason = "";

    // ⭐ Party Summary
    private PartyPaymentSummaryDto? _partySummary;

    private string? _currentUserName;
    private bool _canView, _canAdd, _canEdit, _canDelete;
    private bool _canViewPurchases;
    private bool _canSalePayment;
    private bool _canPurchasePayment;

    // ⭐ صلاحيات مركبة
    private bool CanAddPayment =>
        (_filter.TransactionType == TransactionTypes.Sale && _canSalePayment) ||
        (_filter.TransactionType == TransactionTypes.Purchase && _canPurchasePayment);

    private bool CanEditPayment(PaymentListDto p) =>
        _canEdit && (
        (p.TransactionType == TransactionTypes.Sale && _canSalePayment) ||
        (p.TransactionType == TransactionTypes.Purchase && _canPurchasePayment));

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserName = user.Identity?.Name ?? "System";

        _canView = user.HasClaim("Permission", "frm_Payments:View") || user.IsInRole("Admin");
        _canAdd = user.HasClaim("Permission", "frm_Payments:Add") || user.IsInRole("Admin");
        _canEdit = user.HasClaim("Permission", "frm_Payments:Edit") || user.IsInRole("Admin");
        _canDelete = user.HasClaim("Permission", "frm_Payments:Delete") || user.IsInRole("Admin");

        var isAdmin = user.IsInRole("Admin");
        var isAccountMgr = user.IsInRole("AccountManager");
        var isAccount = user.IsInRole("Account");
        var isSales = user.IsInRole("Sales");

        _canViewPurchases = isAdmin || isAccountMgr || isAccount;
        _canSalePayment = isAdmin || isAccountMgr || isAccount || isSales;
        _canPurchasePayment = isAdmin || isAccountMgr || isAccount;

        if (!_canView) { Navigation.NavigateTo("/"); return; }

        if (!_canViewPurchases && _filter.TransactionType == TransactionTypes.Purchase)
            _filter.TransactionType = TransactionTypes.Sale;

        _cashBoxes = await InvoiceService.GetCashBoxesAsync();
        await LoadAll();
        _isLoading = false;
    }

    private async Task LoadAll()
    {
        _pagedResult = await PaymentService.GetPaymentsAsync(_filter);
        _stats = await PaymentService.GetStatsAsync(_filter.TransactionType, _filter.DateFrom, _filter.DateTo);

        // ⭐ تحميل ملخص العميل لو بحث عن عميل واحد
        await TryLoadPartySummary();
    }

    private async Task SwitchType(string type)
    {
        _filter.TransactionType = type;
        _filter.PageNumber = 1;
        _partySummary = null;
        await LoadAll();
    }

    private async Task OnSearchChanged() { _filter.PageNumber = 1; await LoadAll(); }
    private async Task OnFilterChanged() { _filter.PageNumber = 1; await LoadAll(); }
    private async Task OnDateFromChanged(DateTime? d) { _dateFrom = d; _filter.DateFrom = d; await OnFilterChanged(); }
    private async Task OnDateToChanged(DateTime? d) { _dateTo = d; _filter.DateTo = d; await OnFilterChanged(); }
    private async Task OnPageChanged(int p) { _filter.PageNumber = p; await LoadAll(); }

    private async Task ResetFilters()
    {
        var type = _filter.TransactionType;
        _filter = new() { TransactionType = type };
        _dateFrom = null; _dateTo = null;
        _partySummary = null;
        await LoadAll();
    }

    private void GoToNew() => Navigation.NavigateTo($"/payments/new?type={_filter.TransactionType}");
    private void GoToReceipt(int id) => Navigation.NavigateTo($"/payments/{id}/receipt");
    private void GoToEdit(int id) => Navigation.NavigateTo($"/payments/new?edit={id}");

    // ⭐ تحميل ملخص العميل
    private async Task TryLoadPartySummary()
    {
        _partySummary = null;

        if (string.IsNullOrWhiteSpace(_filter.SearchText)) return;

        // نشوف هل النتائج كلها لعميل واحد
        var partyIds = _pagedResult.Items
            .Select(p => p.PartyId)
            .Distinct()
            .ToList();

        if (partyIds.Count == 1)
        {
            var partyId = partyIds.First();
            var firstItem = _pagedResult.Items.First(p => p.PartyId == partyId);

            // نجيب كل فواتير العميل
            var invoices = _pagedResult.Items
                .GroupBy(p => p.TransactionId)
                .Select(g => g.First())
                .Select(p => new PartyInvoiceSummary
                {
                    TransactionId = p.TransactionId,
                    ReferenceNumber = p.InvoiceReferenceNumber ?? $"#{p.TransactionId}",
                    GrandTotal = p.InvoiceGrandTotal,
                    PaidAmount = p.InvoicePaidAmount,
                    Remaining = p.InvoiceRemaining
                }).ToList();

            _partySummary = new PartyPaymentSummaryDto
            {
                PartyId = partyId,
                PartyName = firstItem.PartyName,
                Phone = firstItem.PartyPhone,
                InvoiceCount = invoices.Count,
                GrandTotal = invoices.Sum(i => i.GrandTotal),
                PaidAmount = invoices.Sum(i => i.PaidAmount),
                Remaining = invoices.Sum(i => i.Remaining),
                Invoices = invoices
            };
        }
    }

    private void ClearPartySummary()
    {
        _partySummary = null;
    }

    // Cancel
    private void ConfirmCancel(PaymentListDto p)
    {
        _selected = p;
        _cancelReason = "";
        _showCancelDialog = true;
    }

    private async Task ExecuteCancel()
    {
        if (_selected == null) return;
        if (string.IsNullOrWhiteSpace(_cancelReason))
        {
            Snackbar.Add("يرجى إدخال سبب الإلغاء", Severity.Warning);
            return;
        }

        _isCancelling = true;
        var (ok, msg) = await PaymentService.CancelPaymentAsync(
            _selected.PaymentId, _cancelReason, _currentUserName!);
        _isCancelling = false;
        _showCancelDialog = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadAll();
    }

    private string FormatMoney(decimal v) => $"{v:N2}";

    private Color GetPercentageColor(decimal pct) => pct switch
    {
        >= 70 => Color.Success,
        >= 20 => Color.Info,
        > 0 => Color.Warning,
        _ => Color.Default
    };

    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var words = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return words.Length >= 2
            ? $"{words[0][0]}{words[1][0]}"
            : name[0].ToString();
    }

    // ⭐ DTO للملخص
    private class PartyPaymentSummaryDto
    {
        public int PartyId { get; set; }
        public string PartyName { get; set; } = "";
        public string? Phone { get; set; }
        public int InvoiceCount { get; set; }
        public decimal GrandTotal { get; set; }
        public decimal PaidAmount { get; set; }
        public decimal Remaining { get; set; }
        public List<PartyInvoiceSummary> Invoices { get; set; } = new();
    }

    private class PartyInvoiceSummary
    {
        public int TransactionId { get; set; }
        public string ReferenceNumber { get; set; } = "";
        public decimal GrandTotal { get; set; }
        public decimal PaidAmount { get; set; }
        public decimal Remaining { get; set; }
    }
}