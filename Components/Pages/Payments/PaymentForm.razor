@page "/payments/new"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject IPaymentService PaymentService
@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

@if (_isLoading)
{
    <div class="loading-container">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </div>
}
else
{
    <div class="payment-form-page" dir="rtl">

        <!-- Header -->
        <div class="form-header">
            <div class="header-left">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                               Color="Color.Inherit" OnClick="GoBack" Size="Size.Large" />
                <div>
                    <h1>
                        <MudIcon Icon="@(_isEditMode
                            ? Icons.Material.Filled.Edit
                            : (_form.TransactionType == TransactionTypes.Sale
                                ? Icons.Material.Filled.AddCard
                                : Icons.Material.Filled.MoneyOff))" />
                        @(_isEditMode
                            ? $"تعديل الدفعة {_editReceiptNumber}"
                            : (_form.TransactionType == TransactionTypes.Sale
                                ? "تسجيل دفعة قبض جديدة"
                                : "تسجيل دفعة صرف جديدة"))
                    </h1>
                    <p>@(_isEditMode ? "تعديل بيانات الدفعة المحددة" : "اختر الفاتورة وأدخل بيانات الدفعة")</p>
                </div>
            </div>
            <div class="header-right">
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="GoBack"
                           StartIcon="@Icons.Material.Filled.Close">
                    إلغاء
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="SavePayment" Disabled="@(!CanSave || _isSaving)"
                           StartIcon="@Icons.Material.Filled.Save"
                           Class="save-btn">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    }
                    @(_isEditMode ? "حفظ التعديلات" : "حفظ الدفعة")
                </MudButton>
            </div>
        </div>

        <div class="form-grid">
            <!-- Main Column -->
            <div class="main-col">

                <!-- 1) Type Toggle (فقط في الإضافة) -->
                @if (!_isEditMode)
                {
                    <MudPaper Class="form-section" Elevation="0">
                        <div class="section-header">
                            <MudIcon Icon="@Icons.Material.Filled.Category" />
                            <h3>نوع الدفعة</h3>
                        </div>
                        <div class="type-toggle-form">
                            <button type="button"
                                    class="@(_form.TransactionType == TransactionTypes.Sale ? "active" : "")"
                                    @onclick="@(() => SwitchType(TransactionTypes.Sale))"
                                    disabled="@(!_canSalePayment)">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                                <div>
                                    <strong>سند قبض</strong>
                                    <span>دفعة من عميل (مبيعات)</span>
                                </div>
                            </button>
                            <button type="button"
                                    class="@(_form.TransactionType == TransactionTypes.Purchase ? "active" : "")"
                                    @onclick="@(() => SwitchType(TransactionTypes.Purchase))"
                                    disabled="@(!_canPurchasePayment)">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingDown" />
                                <div>
                                    <strong>سند صرف</strong>
                                    <span>دفعة لمورد (مشتريات)</span>
                                </div>
                            </button>
                        </div>
                    </MudPaper>
                }

                <!-- 2) اختيار الفاتورة (فقط في الإضافة) -->
                @if (!_isEditMode)
                {
                    <MudPaper Class="form-section" Elevation="0">
                        <div class="section-header">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" />
                            <h3>اختر الفاتورة</h3>
                        </div>

                        <MudAutocomplete T="InvoiceLookupDto"
                                         Label="ابحث برقم الفاتورة أو اسم العميل أو الهاتف *"
                                         Value="_selectedInvoice"
                                         ValueChanged="OnInvoiceSelected"
                                         SearchFunc="SearchInvoices"
                                         ToStringFunc="@(i => i == null ? "" : _form.TransactionType == TransactionTypes.Purchase && !string.IsNullOrEmpty(i.EmpName) ? $"{i.ReferenceNumber} - {i.PartyName} - {i.EmpName}" : $"{i.ReferenceNumber} - {i.PartyName}")"
                                         Variant="Variant.Outlined"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.Search"
                                         Clearable="true"
                                         ResetValueOnEmptyText="true"
                                         CoerceText="true"
                                         MinCharacters="1">
                            <ItemTemplate Context="inv">
                                <div style="display:flex; flex-direction:column; padding:0.25rem 0;">
                                    <div style="display:flex; justify-content:space-between; align-items:center;">
                                        <strong>@inv.ReferenceNumber</strong>
                                        <span style="color:var(--mud-palette-success); font-weight:700;">
                                            متبقي: @inv.Remaining.ToString("N2") ج
                                        </span>
                                    </div>
                                    <span style="font-size:0.85rem;">
    @inv.PartyName
    @if (_form.TransactionType == TransactionTypes.Purchase && !string.IsNullOrEmpty(inv.EmpName))
    {
        <span style="color:#3b82f6; font-weight:600;"> → @inv.EmpName</span>
    }
    @if (!string.IsNullOrEmpty(inv.PartyPhone))
    {
        <span> • 📞 @inv.PartyPhone</span>
    }
</span>
                                    <span style="font-size:0.78rem; color:var(--mud-palette-text-secondary);">
                                        إجمالي: @inv.GrandTotal.ToString("N2") ج |
                                        مدفوع: @inv.PaidAmount.ToString("N2") ج |
                                        @inv.TransactionDate.ToString("yyyy/MM/dd")
                                    </span>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </MudPaper>
                }

                <!-- 3) ⭐ تحليل النسب -->
                @if (_analysis != null)
                {
                    <MudPaper Class="form-section tiers-section" Elevation="0">
                        <div class="section-header">
                            <MudIcon Icon="@Icons.Material.Filled.PieChart" />
                            <h3>جدول الدفعات المرجعي (70% - 20% - 10%)</h3>
                        </div>

                        <div class="tiers-grid">
                            @foreach (var tier in _analysis.Tiers)
                            {
                                <div class="tier-card tier-@tier.Status.ToLower()">
                                    <div class="tier-header">
                                        <span class="tier-pct">@tier.Percentage%</span>
                                        @if (tier.Status == "Paid")
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                     Size="Size.Small" Style="color:#10b981;" />
                                        }
                                        else if (tier.Status == "Partial")
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.PieChartOutline"
                                                     Size="Size.Small" Style="color:#f59e0b;" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty"
                                                     Size="Size.Small" Style="color:#94a3b8;" />
                                        }
                                    </div>
                                    <div class="tier-name">@tier.TierName</div>
                                    <div class="tier-amount">@FormatMoney(tier.Amount) ج</div>
                                    <div class="tier-status-bar">
                                        <div class="tier-progress" style="width:@(tier.CompletionPercentage)%"></div>
                                    </div>
                                    <div class="tier-info">
                                        <small>
                                            مدفوع: @FormatMoney(tier.AmountPaid) ج
                                            @if (tier.Status != "Pending")
                                            {
                                                <span> (@tier.CompletionPercentage%)</span>
                                            }
                                        </small>
                                        @if (tier.AmountRemaining > 0)
                                        {
                                            <small class="text-warning">
                                                متبقي: @FormatMoney(tier.AmountRemaining) ج
                                            </small>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </MudPaper>
                }
                <!-- ⭐ سجل المدفوعات السابقة -->
<!-- ⭐ سجل المدفوعات السابقة -->
@if (_paymentHistory.Any())
{
    <MudPaper Class="form-section" Elevation="0">
        <div class="section-header">
            <MudIcon Icon="@Icons.Material.Filled.History" />
            <h3>سجل المدفوعات السابقة (@_paymentHistory.Count)</h3>
        </div>
        <div class="history-list">
            @foreach (var hist in _paymentHistory)
            {
                <div class="history-row">
                    <div class="history-main">
                        <span class="history-amount">@FormatMoney(hist.Amount) ج</span>
                        <span class="history-pct">(@hist.Percentage%)</span>
                        <span class="history-method">
                            @PaymentMethods.All.GetValueOrDefault(hist.PaymentMethod ?? "Cash", hist.PaymentMethod ?? "-")
                        </span>
                        @if (!string.IsNullOrEmpty(hist.CashBoxName))
                        {
                            <span class="history-cashbox">🏦 @hist.CashBoxName</span>
                        }
                    </div>
                    <div class="history-meta">
                        <span>@hist.PaymentDate.ToString("yyyy/MM/dd HH:mm")</span>
                        <span>بواسطة: @(hist.CreatedBy ?? "-")</span>
                    </div>
                </div>
            }
        </div>
    </MudPaper>
}

                <!-- 4) إدخال الدفعة -->
                @if (_selectedInvoice != null || _isEditMode)
                {
                    <MudPaper Class="form-section" Elevation="0">
                        <div class="section-header">
                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" />
                            <h3>تفاصيل الدفعة</h3>
                        </div>

                        <!-- Quick Pay Buttons -->
                        <div class="quick-buttons">
                            <span class="quick-label">دفع سريع:</span>
                            @foreach (var pct in SystemConstants.QuickPayPercentages)
                            {
                                <button type="button" class="quick-btn"
                                        @onclick="@(() => SetAmountByPercentage(pct))">
                                    @pct% (@FormatMoney(Math.Round(_form.InvoiceGrandTotal * pct / 100m, 2)) ج)
                                </button>
                            }
                            <button type="button" class="quick-btn quick-full"
                                    @onclick="@(() => _form.Amount = _form.InvoiceRemaining)">
                                💯 المتبقي كامل (@FormatMoney(_form.InvoiceRemaining) ج)
                            </button>
                        </div>
                        <!-- ⭐ تحذير دفعة مكررة -->
                        @if (_hasDuplicateWarning)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mt-2 mb-2">
                                @_duplicateWarningMsg
                            </MudAlert>
                        }
                        

                        <div class="grid-2 mt-3">
    <MudDatePicker Date="@_form.PaymentDate"
                   DateChanged="OnPaymentDateChanged"
                   Label="تاريخ الدفعة *"
                   Variant="Variant.Outlined"
                   Max="@DateTime.Now" />

    <MudTimePicker Time="@_form.PaymentDate.TimeOfDay"
                   TimeChanged="OnPaymentTimeChanged"
                   Label="وقت الدفعة"
                   Variant="Variant.Outlined" />
</div>
<div class="grid-2 mt-3">
    <MudNumericField @bind-Value="_form.Amount"
                                             @bind-Value:after="OnAmountChanged"
                                             Label="مبلغ الدفعة *"
                                             Variant="Variant.Outlined"
                                             Min="0.01m"
                                             Max="@_form.InvoiceRemaining"
                                             Step="100m"
                                             Class="amount-field" />

                            <MudSelect T="string" @bind-Value="_form.PaymentMethod"
                                       Label="طريقة الدفع *"
                                       Variant="Variant.Outlined">
                                @foreach (var pm in PaymentMethods.All)
                                {
                                    <MudSelectItem T="string" Value="@pm.Key">@pm.Value</MudSelectItem>
                                }
                            </MudSelect>

                            <MudSelect T="int?" @bind-Value="_form.CashBoxId"
                                       Label="الخزينة *"
                                       Variant="Variant.Outlined">
                                @foreach (var cb in _cashBoxes)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
                                }
                            </MudSelect>

                            <MudTextField @bind-Value="_form.Notes"
                                          Label="ملاحظات"
                                          Variant="Variant.Outlined" />
                        </div>

                        <!-- ⭐ تحليل المبلغ المُدخل -->
                        @if (_analysis?.CurrentPaymentAnalysis != null && _form.Amount > 0)
                        {
                            var ca = _analysis.CurrentPaymentAnalysis;
                            <div class="payment-analysis">
                                <div class="analysis-header">
                                    <MudIcon Icon="@Icons.Material.Filled.Analytics" />
                                    <strong>تحليل الدفعة:</strong>
                                </div>

                                <div class="analysis-pct">
                                    <span>المبلغ يساوي:</span>
                                    <strong class="big-pct">@ca.PercentageOfInvoice%</strong>
                                    <span>من إجمالي الفاتورة</span>
                                </div>

                                <div class="analysis-desc">@ca.Description</div>

                                @if (ca.Allocations.Any())
                                {
                                    <div class="allocations">
                                        <strong>توزيع الدفعة على الدفعات:</strong>
                                        @foreach (var alloc in ca.Allocations)
                                        {
                                            <div class="allocation-row">
                                                <span class="alloc-name">@alloc.TierName:</span>
                                                <span class="alloc-amount">@FormatMoney(alloc.AmountAllocated) ج</span>
                                                <span class="alloc-note">@alloc.Note</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </MudPaper>
                }
            </div>

            <!-- Sidebar -->
            <div class="sidebar-col">
                @if (_selectedInvoice != null || _isEditMode)
                {
                    <MudPaper Class="summary-card" Elevation="0">
                        <h3>@(_isEditMode ? "بيانات الدفعة" : "ملخص الفاتورة")</h3>
                        @if (_isEditMode && _form.LastModifiedAt.HasValue)
{
    <div class="last-modified-info">
        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
        <span>آخر تعديل: @_form.LastModifiedAt.Value.ToString("yyyy/MM/dd HH:mm") بواسطة @_form.LastModifiedBy</span>
    </div>
}
                         <!-- ⭐ رصيد العميل الإجمالي -->
    @if (_partyBalance != null)
    {
        <div class="party-balance">
            <div class="balance-title">رصيد العميل الإجمالي</div>
            <div class="balance-grid">
                <div class="balance-item">
                    <span class="balance-value">@_partyBalance.TotalInvoices</span>
                    <span class="balance-label">فاتورة</span>
                </div>
                <div class="balance-item">
                    <span class="balance-value">@FormatMoney(_partyBalance.GrandTotal)</span>
                    <span class="balance-label">الإجمالي</span>
                </div>
                <div class="balance-item">
                    <span class="balance-value paid-color">@FormatMoney(_partyBalance.PaidAmount)</span>
                    <span class="balance-label">المدفوع</span>
                </div>
                <div class="balance-item">
                    <span class="balance-value remain-color">@FormatMoney(_partyBalance.Remaining)</span>
                    <span class="balance-label">المتبقي</span>
                </div>
            </div>
            <div class="balance-statuses">
                @if (_partyBalance.PaidInvoices > 0)
                {
                    <span class="balance-badge badge-paid">✅ @_partyBalance.PaidInvoices مدفوعة</span>
                }
                @if (_partyBalance.PartialInvoices > 0)
                {
                    <span class="balance-badge badge-partial">⏳ @_partyBalance.PartialInvoices جزئية</span>
                }
                @if (_partyBalance.OpenInvoices > 0)
                {
                    <span class="balance-badge badge-open">📭 @_partyBalance.OpenInvoices مفتوحة</span>
                }
            </div>
        </div>
    }
                        <div class="summary-info">
                            <div class="info-item">
                                <span>الفاتورة:</span>
                                <strong>@_form.InvoiceReferenceNumber</strong>
                            </div>
                            <div class="info-item">
                                <span>العميل:</span>
                                <strong>@_form.PartyName</strong>
                            </div>
                            @if (!string.IsNullOrEmpty(_form.PartyPhone))
                            {
                                <div class="info-item">
                                    <span>الهاتف:</span>
                                    <strong>@_form.PartyPhone</strong>
                                </div>
                            }
                        </div>

                        <div class="summary-divider"></div>

                        <div class="summary-row">
                            <span>إجمالي الفاتورة:</span>
                            <strong>@FormatMoney(_form.InvoiceGrandTotal) ج</strong>
                        </div>
                        <div class="summary-row paid-row">
                            <span>المدفوع سابقاً:</span>
                            <strong>@FormatMoney(_form.InvoicePaidBefore) ج</strong>
                        </div>
                        <div class="summary-row remaining-row">
                            <span>المتبقي:</span>
                            <strong>@FormatMoney(_form.InvoiceRemaining) ج</strong>
                        </div>

                        @if (_form.Amount > 0)
                        {
                            var afterRemain = _form.InvoiceRemaining - _form.Amount;
                            var newPaidPct = _form.InvoiceGrandTotal == 0 ? 0
                                : Math.Round(((_form.InvoicePaidBefore + _form.Amount) / _form.InvoiceGrandTotal) * 100, 1);

                            <div class="summary-divider"></div>
                            <div class="summary-row new-payment-row">
                                <span>@(_isEditMode ? "المبلغ الجديد:" : "الدفعة الحالية:")</span>
                                <strong style="color: var(--gold);">+ @FormatMoney(_form.Amount) ج</strong>
                            </div>
                            <div class="summary-row final-row">
                                <span>المتبقي بعد الدفعة:</span>
                                <strong style="color: @(afterRemain == 0 ? "var(--mud-palette-success)" : "var(--mud-palette-error)");">
                                    @FormatMoney(afterRemain) ج
                                </strong>
                            </div>

                            <!-- Progress Bar -->
                            <div class="progress-section">
                                <div class="progress-label">
                                    <span>نسبة السداد بعد الدفعة:</span>
                                    <strong>@newPaidPct%</strong>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width:@(Math.Min(100, (double)newPaidPct))%"></div>
                                </div>
                            </div>
                        }

                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   FullWidth="true" Size="Size.Large"
                                   OnClick="SavePayment"
                                   Disabled="@(!CanSave || _isSaving)"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   Class="save-btn-full mt-3">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                            }
                            @(_isEditMode ? "حفظ التعديلات" : "حفظ الدفعة وفتح السند")
                        </MudButton>
                    </MudPaper>
                }
                else
                {
                    <MudPaper Class="summary-card placeholder-card" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Filled.ArrowBack"
                                 Size="Size.Large" Style="color:var(--mud-palette-divider);" />
                        <h3>اختر فاتورة أولاً</h3>
                        <p>ابحث عن الفاتورة من القسم الجانبي</p>
                    </MudPaper>
                }
            </div>
        </div>
    </div>
}
<!-- ⭐ Confirm Save Dialog -->
<MudDialog @bind-Visible="_showConfirmDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
            <MudText Typo="Typo.h6">@(_isEditMode ? "تأكيد تعديل الدفعة" : "تأكيد تسجيل الدفعة")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="confirm-details">
            <div class="confirm-row">
                <span>الفاتورة:</span>
                <strong>@_form.InvoiceReferenceNumber</strong>
            </div>
            <div class="confirm-row">
                <span>العميل:</span>
                <strong>@_form.PartyName</strong>
            </div>
            @if (!string.IsNullOrEmpty(_form.PartyPhone))
            {
                <div class="confirm-row">
                    <span>الهاتف:</span>
                    <strong>@_form.PartyPhone</strong>
                </div>
            }
            <div class="confirm-divider"></div>
            <div class="confirm-row">
                <span>المبلغ:</span>
                <strong style="color: var(--gold); font-size: 1.1rem;">@FormatMoney(_form.Amount) ج</strong>
            </div>
            <div class="confirm-row">
                <span>طريقة الدفع:</span>
                <strong>@PaymentMethods.All.GetValueOrDefault(_form.PaymentMethod, _form.PaymentMethod)</strong>
            </div>
            <div class="confirm-row">
                <span>الخزينة:</span>
                <strong>@(_cashBoxes.FirstOrDefault(c => c.CashBoxId == _form.CashBoxId)?.CashBoxName ?? "-")</strong>
            </div>
            <div class="confirm-row">
                <span>التاريخ:</span>
                <strong>@_form.PaymentDate.ToString("yyyy/MM/dd HH:mm")</strong>
            </div>
            <div class="confirm-divider"></div>
            <div class="confirm-row">
                <span>إجمالي الفاتورة:</span>
                <strong>@FormatMoney(_form.InvoiceGrandTotal) ج</strong>
            </div>
            <div class="confirm-row">
                <span>المدفوع سابقاً:</span>
                <strong class="paid-color">@FormatMoney(_form.InvoicePaidBefore) ج</strong>
            </div>
            <div class="confirm-row">
                <span>المتبقي بعد الدفعة:</span>
                <strong class="@((_form.InvoiceRemaining - _form.Amount) == 0 ? "paid-color" : "remain-color")">
                    @FormatMoney(_form.InvoiceRemaining - _form.Amount) ج
                </strong>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showConfirmDialog = false)" Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Close">
            إلغاء
        </MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled"
                   OnClick="ConfirmSave" Disabled="@_isSaving"
                   StartIcon="@Icons.Material.Filled.Check">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            @(_isEditMode ? "تأكيد التعديل" : "تأكيد الحفظ")
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .payment-form-page { padding: 1rem; max-width: 1800px; margin: 0 auto; direction: rtl; }

    .form-header {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        border-radius: 16px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem;
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 1rem; color: white;
    }
    .header-left { display: flex; align-items: center; gap: 1rem; }
    .header-left h1 {
        margin: 0; font-size: 1.5rem; font-weight: 800;
        display: flex; align-items: center; gap: 0.5rem;
    }
    .header-left p { margin: 0.25rem 0 0 0; font-size: 0.85rem; }
    .header-right { display: flex; gap: 0.5rem; flex-wrap: wrap; }

    .save-btn {
        background: rgba(255,255,255,0.95) !important;
        color: var(--navy-dark) !important;
        font-weight: 700 !important;
    }

    .form-grid { display: grid; grid-template-columns: 1fr 380px; gap: 1.5rem; }
    .main-col, .sidebar-col { display: flex; flex-direction: column; gap: 1rem; }

    .form-section {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 14px; padding: 1.25rem;
    }

    .section-header {
        display: flex; align-items: center; gap: 0.5rem;
