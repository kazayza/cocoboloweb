@code {
    [SupplyParameterFromQuery(Name = "type")]
    public string? PreType { get; set; }

    [SupplyParameterFromQuery(Name = "invoice")]
    public int? PreInvoiceId { get; set; }

    [SupplyParameterFromQuery(Name = "edit")]
    public int? EditPaymentId { get; set; }

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _isEditMode = false;
    private int? _editPaymentId;
    private string _editReceiptNumber = "";
    private List<PaymentHistoryDto> _paymentHistory = new();
    private PartyBalanceDto? _partyBalance;
    private bool _showConfirmDialog = false;
    private bool _hasDuplicateWarning = false;
    private string _duplicateWarningMsg = "";

    private PaymentFormDto _form = new();
    private InvoiceLookupDto? _selectedInvoice;
    private PaymentAnalysisDto? _analysis;

    private List<Models.CashBox> _cashBoxes = new();

    private string? _currentUserName;
    private bool _canAdd;
    private bool _canSalePayment;     // Admin + AccountManager + Account + Sales
    private bool _canPurchasePayment; // Admin + AccountManager + Account

    private bool CanSave => (_selectedInvoice != null || _isEditMode)
                            && _form.Amount > 0
                            && _form.Amount <= _form.InvoiceRemaining
                            && _form.CashBoxId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserName = user.Identity?.Name ?? "System";

        var isAdmin = user.IsInRole("Admin");
        var isAccountMgr = user.IsInRole("AccountManager");
        var isAccount = user.IsInRole("Account");
        var isSales = user.IsInRole("Sales");

        _canSalePayment = isAdmin || isAccountMgr || isAccount || isSales;
        _canPurchasePayment = isAdmin || isAccountMgr || isAccount;
        _canAdd = _canSalePayment || _canPurchasePayment;

        if (!_canAdd) { Navigation.NavigateTo("/payments"); return; }

        // Default type
        if (!string.IsNullOrEmpty(PreType))
            _form.TransactionType = PreType;

        _cashBoxes = await InvoiceService.GetCashBoxesAsync();
        if (_cashBoxes.Any())
            _form.CashBoxId = _cashBoxes.First().CashBoxId;

        // ⭐ وضع التعديل
        if (EditPaymentId.HasValue && EditPaymentId.Value > 0)
        {
            _editPaymentId = EditPaymentId.Value;
            _isEditMode = true;
            var editData = await PaymentService.GetPaymentForEditAsync(EditPaymentId.Value);
            if (editData != null)
            {
                _form = editData;
                _editReceiptNumber = PaymentService.GenerateReceiptNumber(
                    EditPaymentId.Value, _form.TransactionType, DateTime.Now);
                _selectedInvoice = new InvoiceLookupDto
{
    TransactionId = _form.TransactionId ?? 0,
    ReferenceNumber = _form.InvoiceReferenceNumber,
    PartyName = _form.PartyName ?? "",
    PartyPhone = _form.PartyPhone,
    GrandTotal = _form.InvoiceGrandTotal,
    PaidAmount = _form.InvoicePaidBefore
};
                await LoadAnalysis();
                _paymentHistory = await PaymentService.GetPaymentHistoryAsync(_form.TransactionId ?? 0);
                await LoadPartyBalance();
            }
            else
            {
                Snackbar.Add("الدفعة غير موجودة", Severity.Error);
                Navigation.NavigateTo("/payments");
                return;
            }
        }
        else
        {
            // لو جاي من فاتورة معينة
            if (PreInvoiceId.HasValue && PreInvoiceId.Value > 0)
            {
                var inv = await PaymentService.SearchInvoicesAsync(
                    _form.TransactionType, PreInvoiceId.Value.ToString(), false, 1);
                if (inv.Any())
                {
                    await OnInvoiceSelected(inv.First());
                }
            }
        }

        _isLoading = false;
    }
    private async Task LoadPartyBalance()
{
    if (_form.PartyId.HasValue)
    {
        _partyBalance = await PaymentService.GetPartyBalanceAsync(
            _form.PartyId.Value, _form.TransactionType);
    }
    else
    {
        _partyBalance = null;
    }
}

    private void CheckDuplicatePayment()
{
    _hasDuplicateWarning = false;
    _duplicateWarningMsg = "";

    if (_form.Amount <= 0 || !_form.TransactionId.HasValue) return;

    // نفس المبلغ + نفس الفاتورة + نفس اليوم
    var sameAmountHistory = _paymentHistory.Where(p =>
        p.Amount == _form.Amount &&
        p.PaymentDate.Date == _form.PaymentDate.Date).ToList();

    if (sameAmountHistory.Any())
    {
        _hasDuplicateWarning = true;
        var dup = sameAmountHistory.First();
        _duplicateWarningMsg = $"⚠️ تم تسجيل دفعة بنفس المبلغ ({FormatMoney(_form.Amount)} ج) على نفس الفاتورة بتاريخ {dup.PaymentDate:yyyy/MM/dd} بواسطة {dup.CreatedBy}";
    }
}

    private async Task SwitchType(string type)
    {
        // ⭐ منع التبديل لو مش مسموح
        if (type == TransactionTypes.Sale && !_canSalePayment) return;
        if (type == TransactionTypes.Purchase && !_canPurchasePayment) return;

        _form.TransactionType = type;
        _selectedInvoice = null;
        _analysis = null;
        _form.TransactionId = null;
        _form.InvoiceReferenceNumber = null;
        _form.PartyName = null;
        _form.PartyPhone = null;
        _form.InvoiceGrandTotal = 0;
        _form.InvoicePaidBefore = 0;
        _form.InvoiceRemaining = 0;
        _form.Amount = 0;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private async Task<IEnumerable<InvoiceLookupDto>> SearchInvoices(string value, CancellationToken token)
{
    var results = await PaymentService.SearchInvoicesAsync(_form.TransactionType, value, true);

    // ⭐ اختيار تلقائي لو نتيجة واحدة
    if (results.Count == 1 && _selectedInvoice == null)
    {
        await InvokeAsync(async () =>
        {
            await OnInvoiceSelected(results.First());
            StateHasChanged();
        });
    }

    return results;
}

    private async Task OnInvoiceSelected(InvoiceLookupDto? inv)
    {
        _selectedInvoice = inv;
        if (inv == null)
        {
            _analysis = null;
            _form.TransactionId = null;
            _form.Amount = 0;
            return;
        }

        _form.TransactionId = inv.TransactionId;
        _form.InvoiceReferenceNumber = inv.ReferenceNumber;
        _form.PartyId = inv.PartyId;
        _form.PartyName = inv.PartyName;
        _form.PartyPhone = inv.PartyPhone;
        _form.InvoiceGrandTotal = inv.GrandTotal;
        _form.InvoicePaidBefore = inv.PaidAmount;
        _form.InvoiceRemaining = inv.Remaining;
        _form.Amount = 0;

        await LoadAnalysis();
        _paymentHistory = await PaymentService.GetPaymentHistoryAsync(inv.TransactionId);
        await LoadPartyBalance();
    }

    private async Task LoadAnalysis()
    {
        if (!_form.TransactionId.HasValue) return;
        _analysis = await PaymentService.GetPaymentAnalysisAsync(
            _form.TransactionId.Value, _form.Amount > 0 ? _form.Amount : null);
    }

    private async Task OnAmountChanged()
    {
        CheckDuplicatePayment();
        await LoadAnalysis();
    }

    private void SetAmountByPercentage(int percentage)
    {
        var amount = Math.Round(_form.InvoiceGrandTotal * (percentage / 100m), 2);
        if (amount > _form.InvoiceRemaining) amount = _form.InvoiceRemaining;
        _form.Amount = amount;
        _ = LoadAnalysis();
    }

    private async Task SavePayment()
{
    if (!CanSave) return;
    _showConfirmDialog = true;
}

private async Task ConfirmSave()
{
    _showConfirmDialog = false;
    _isSaving = true;
    try
    {
        if (_isEditMode && _editPaymentId.HasValue)
        {
            var (ok, msg) = await PaymentService.UpdatePaymentAsync(
                _editPaymentId.Value, _form, _currentUserName!);
            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
            if (ok)
                Navigation.NavigateTo($"/payments/{_editPaymentId.Value}/receipt");
        }
        else
        {
            var (ok, msg, paymentId) = await PaymentService.CreatePaymentAsync(
                _form, _currentUserName!);
            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
            if (ok && paymentId.HasValue)
                Navigation.NavigateTo($"/payments/{paymentId.Value}/receipt");
        }
    }
    finally
    {
        _isSaving = false;
    }
}
    private void OnPaymentDateChanged(DateTime? d)
{
    if (d.HasValue)
    {
        var time = _form.PaymentDate.TimeOfDay;
        _form.PaymentDate = d.Value.Date + time;
    }
    CheckDuplicatePayment();
}

private void OnPaymentTimeChanged(TimeSpan? t)
{
    if (t.HasValue)
    {
        _form.PaymentDate = _form.PaymentDate.Date + t.Value;
    }
}
private async Task TryAutoSelectInvoice(string searchText)
{
    if (string.IsNullOrWhiteSpace(searchText)) return;

    var results = await PaymentService.SearchInvoicesAsync(
        _form.TransactionType, searchText, true, 2);

    // لو نتيجة واحدة بس → اخترها تلقائي
    if (results.Count == 1)
    {
        await OnInvoiceSelected(results.First());
    }
}

    private void GoBack() => Navigation.NavigateTo("/payments");

    private string FormatMoney(decimal v) => $"{v:N2}";
}