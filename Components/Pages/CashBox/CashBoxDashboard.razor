@code {
    private bool _isLoading = true;
    private bool _canManage = false;
    private CashBoxDashboardDto _dashboard = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frmCashBoxDashboard:View") || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }
        _canManage = user.HasClaim("Permission", "frmCashBoxManual:Add") || user.IsInRole("Admin");

        try { _dashboard = await CashBoxService.GetDashboardAsync(); }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _isLoading = false; }
    }

    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);
    private string FormatShort(decimal v) =>
        v >= 1000000 ? $"{(v / 1000000):F1}M" :
        v >= 1000 ? $"{(v / 1000):F0}K" :
        v.ToString("N0");

    private string GetRecvPct(bool isCredit)
    {
        var total = _dashboard.TotalCreditors + _dashboard.TotalDebtors;
        if (total == 0) return "0";
        var val = isCredit ? _dashboard.TotalCreditors : _dashboard.TotalDebtors;
        return ((double)val / (double)total * 100).ToString("F0");
    }
}
