@code {
    [SupplyParameterFromQuery(Name = "cashBoxId")]
    public int? PreCashBoxId { get; set; }

    private bool _isLoading = true;
    private bool _isTableLoading = false;
    private bool _filterExpanded = true;
    private string _searchDisplay = "";

    private CashBoxTransactionFilterDto _filter = new();
    private PagedResult<CashBoxTransactionDto> _pagedResult = new();
    private List<CashBoxListDto> _boxes = new();
    private DateTime? _dateFrom, _dateTo;
    private decimal _totalIn = 0, _totalOut = 0;

    private bool _canAdd = false;
    private System.Timers.Timer? _searchTimer;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frm_CashBoxTransaction:View") || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        _canAdd = user.HasClaim("Permission", "frm_CashBoxManual:Add") || user.IsInRole("Admin");
        _boxes = await CashBoxService.GetCashBoxesAsync();

        if (PreCashBoxId.HasValue)
            _filter.CashBoxId = PreCashBoxId;

        await LoadData();
        _isLoading = false;
    }

    private async Task LoadData()
    {
        _isTableLoading = true;
        StateHasChanged();
        _pagedResult = await CashBoxService.GetTransactionsAsync(_filter);
        _totalIn = _pagedResult.Items.Where(t => t.TransactionType == "قبض").Sum(t => t.Amount);
        _totalOut = _pagedResult.Items.Where(t => t.TransactionType == "صرف").Sum(t => t.Amount);
        _isTableLoading = false;
        StateHasChanged();
    }

    // Search with Arabic normalize + debounce
    private void OnSearchInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        _searchDisplay = value;
        _filter.SearchText = value.NormalizeArabic();

        _searchTimer?.Stop();
        _searchTimer?.Dispose();
        _searchTimer = new System.Timers.Timer(400);
        _searchTimer.Elapsed += async (_, _) =>
        {
            _searchTimer?.Stop();
            await InvokeAsync(async () => { _filter.PageNumber = 1; await LoadData(); StateHasChanged(); });
        };
        _searchTimer.AutoReset = false;
        _searchTimer.Start();
    }

    private async Task ClearSearch()
    {
        _searchDisplay = "";
        _filter.SearchText = "";
        _filter.PageNumber = 1;
        await LoadData();
    }

    private bool HasActiveFilters() =>
        !string.IsNullOrWhiteSpace(_searchDisplay) ||
        _filter.CashBoxId.HasValue ||
        !string.IsNullOrEmpty(_filter.TransactionType) ||
        !string.IsNullOrEmpty(_filter.ReferenceType) ||
        _dateFrom.HasValue || _dateTo.HasValue;

    private async Task OnFilterChange()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnPageChanged(int p)
    {
        _filter.PageNumber = p;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _searchDisplay = "";
        _filter = new();
        _dateFrom = null; _dateTo = null;
        if (PreCashBoxId.HasValue) _filter.CashBoxId = PreCashBoxId;
        await LoadData();
    }
    private bool _isExporting = false;

private async Task ExportToExcelAsync()
{
    _isExporting = true;
    StateHasChanged();

    try
    {
        // جلب كل البيانات بناءً على الفلتر الحالي (بدون حدود الصفحات)
        var exportFilter = new CashBoxTransactionFilterDto
        {
            CashBoxId = _filter.CashBoxId,
            TransactionType = _filter.TransactionType,
            ReferenceType = _filter.ReferenceType,
            DateFrom = _filter.DateFrom,
            DateTo = _filter.DateTo,
            SearchText = _filter.SearchText,
            PageNumber = 1,
            PageSize = int.MaxValue // كل السجلات
        };

        var result = await CashBoxService.GetTransactionsAsync(exportFilter);
        var data = result.Items;

        using var workbook = new XLWorkbook();
        var sheet = workbook.Worksheets.Add("حركات الخزينة");

        // تنسيق عام عربي
        sheet.RightToLeft = true;
        sheet.ColumnWidth = 18;

        // العناوين
        var headers = new[] { "التاريخ", "الوقت", "الخزينة", "النوع", "المصدر", "الجهة", "الحساب", "المبلغ", "الملاحظات", "المستخدم" };
        for (int i = 0; i < headers.Length; i++)
        {
            var cell = sheet.Cell(1, i + 1);
            cell.Value = headers[i];
            cell.Style.Font.Bold = true;
            cell.Style.Fill.BackgroundColor = XLColor.FromHtml("#D4A853");
            cell.Style.Font.FontColor = XLColor.White;
            cell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
        }

        // البيانات
        int row = 2;
        foreach (var t in data)
        {
            sheet.Cell(row, 1).Value = t.TransactionDate.ToString("yyyy/MM/dd");
            sheet.Cell(row, 2).Value = t.TransactionDate.ToString("HH:mm");
            sheet.Cell(row, 3).Value = t.CashBoxName;
            sheet.Cell(row, 4).Value = t.TransactionType;
            sheet.Cell(row, 5).Value = t.ReferenceTypeAr;
            sheet.Cell(row, 6).Value = t.PartyName ?? "";
            sheet.Cell(row, 7).Value = t.PersonalAccountName ?? "";
            sheet.Cell(row, 8).Value = t.Amount;
            sheet.Cell(row, 8).Style.NumberFormat.Format = "#,##0.00";
            sheet.Cell(row, 9).Value = t.Notes ?? "";
            sheet.Cell(row, 10).Value = t.CreatedBy ?? "";

            // تلوين الصفوف حسب النوع
            if (t.TransactionType == "صرف")
                sheet.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#FFF5F5");
            else
                sheet.Row(row).Style.Fill.BackgroundColor = XLColor.FromHtml("#F0FFF4");

            row++;
        }

        // تجميد الصف الأول
        sheet.SheetView.FreezeRows(1);

        // تحويل الملف إلى بايتات وتحميله
        using var stream = new MemoryStream();
        workbook.SaveAs(stream);
        stream.Seek(0, SeekOrigin.Begin);

        var bytes = stream.ToArray();
        var fileName = $"حركات_الخزينة_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

        await JS.InvokeVoidAsync("eval", $@"
    var a = document.createElement('a');
    a.download = '{fileName}';
    a.href = 'data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{Convert.ToBase64String(bytes)}';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
");
        Snackbar.Add("تم تصدير البيانات بنجاح", Severity.Success);
    }
    catch (Exception ex)
    {
        Snackbar.Add($"خطأ في التصدير: {ex.Message}", Severity.Error);
    }
    finally
    {
        _isExporting = false;
        StateHasChanged();
    }
}

    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);
}
