@page "/cashbox/manual"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject ICashBoxService CashBoxService
@inject IPersonalAccountService PersonalAccountService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ LOADING                                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-box">
            <div class="loading-logo" style="background:linear-gradient(135deg, @_currentOpColor, @(_currentOpColor)cc);">
                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Large" />
            </div>
            <h2>حركة خزينة يدوية</h2>
            <p>جاري تحميل البيانات...</p>
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="border-radius:10px;height:6px;" />
        </div>
    </div>
}
else
{
<div class="manual-page" dir="rtl">

    <!-- Background -->
    <div class="page-bg-deco">
        <div class="bg-orb bg-orb-1" style="background:radial-gradient(circle,@(_currentOpColor)12,transparent 70%);"></div>
        <div class="bg-orb bg-orb-2"></div>
    </div>

    <div class="top-accent" style="background:linear-gradient(90deg,@_currentOpColor,@(_currentOpColor)cc,@_currentOpColor);">
        <div class="accent-shimmer"></div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ HEADER                                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="manual-header">
        <div class="mh-bg">
            <div class="mh-gradient"></div>
            <div class="mh-orbs">
                <div class="mh-orb mh-o1"></div>
                <div class="mh-orb mh-o2"></div>
            </div>
            <div class="mh-grid"></div>
        </div>
        <div class="mh-content">
            <div class="mh-right">
                <button class="back-btn" @onclick="GoBack">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
                </button>
                <div class="mh-icon-wrap">
                    <div class="mh-icon-glow" style="background:@_currentOpColor;"></div>
                    <div class="mh-icon" style="border-color:@(_currentOpColor)40;">
                        <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Large" />
                    </div>
                </div>
                <div class="mh-text">
                    <h1>حركة خزينة يدوية</h1>
                    <p>
                        <span class="mh-op-name" style="background:@(_currentOpColor)20;color:@_currentOpColor;border:1px solid @(_currentOpColor)30;">
                            @ManualOperationTypes.All.GetValueOrDefault(_form.OperationType, "حركة")
                        </span>
                        <span class="mh-desc">@_currentOpDesc</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ FORM LAYOUT                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="form-layout">

        <!-- ─── Main Column ─── -->
        <div class="main-col">

            <!-- ═══ Operation Type ═══ -->
            <div class="form-panel">
                <div class="panel-hdr">
                    <div class="panel-title-group">
                        <div class="panel-icon" style="background:@(_currentOpColor)12;color:@_currentOpColor;">
                            <MudIcon Icon="@Icons.Material.Filled.Category" />
                        </div>
                        <div>
                            <h3>نوع العملية</h3>
                            <p>اختر نوع الحركة المالية</p>
                        </div>
                    </div>
                </div>

                <div class="ops-grid">
                    @foreach (var op in _operations)
                    {
                        var isSelected = _form.OperationType == op.Type;
                        <button type="button"
                                class="op-card @(isSelected ? "op-selected" : "")"
                                style="@(isSelected ? $"border-color:{op.Color};--op-color:{op.Color};" : $"--op-color:{op.Color};")"
                                @onclick="@(() => SelectOp(op.Type, op.Color, op.Icon, op.Description))">

                            @if (isSelected)
                            {
                                <div class="op-selected-glow" style="background:radial-gradient(circle,@(op.Color)15,transparent 60%);"></div>
                            }

                            <div class="op-icon-box" style="background:@(isSelected ? op.Color : $"{op.Color}18");color:@(isSelected ? "white" : op.Color);">
                                <MudIcon Icon="@GetOpIcon(op.Icon)" />
                            </div>
                            <div class="op-text">
                                <strong>@op.Title</strong>
                                <small>@op.SubTitle</small>
                            </div>

                            @if (isSelected)
                            {
                                <div class="op-check" style="background:@op.Color;">
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                </div>
                            }
                        </button>
                    }
                </div>
            </div>

            <!-- ═══ Details ═══ -->
            <div class="form-panel">
                <div class="panel-hdr">
                    <div class="panel-title-group">
                        <div class="panel-icon" style="background:rgba(59,130,246,0.1);color:#3b82f6;">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" />
                        </div>
                        <div>
                            <h3>تفاصيل العملية</h3>
                            <p>أدخل بيانات الحركة المالية</p>
                        </div>
                    </div>
                </div>

                <div class="form-fields">
                    <!-- Date & Amount -->
                    <div class="fields-row">
                        <div class="field-group">
                            <label class="field-label">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" />
                                التاريخ
                            </label>
                            <MudDatePicker Date="_form.TransactionDate"
                                           DateChanged="@(d => _form.TransactionDate = d ?? DateTime.Now)"
                                           Variant="Variant.Outlined" Class="premium-input"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />
                        </div>
                        <div class="field-group">
                            <label class="field-label">
                                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" />
                                المبلغ <span class="required">*</span>
                            </label>
                            <MudNumericField @bind-Value="_form.Amount"
                                             Variant="Variant.Outlined" Class="premium-input amount-input"
                                             Min="0.01m" Step="100m"
                                             Adornment="Adornment.End" AdornmentText="ج.م"
                                             Placeholder="0.00" />
                        </div>
                    </div>

                    <!-- CashBox -->
                    <div class="field-group">
                        <label class="field-label">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" />
                            @(_form.OperationType == ManualOperationTypes.Transfer ? "من خزينة" : "الخزينة") <span class="required">*</span>
                        </label>
                        <MudSelect T="int?" @bind-Value="_form.CashBoxId"
                                   Variant="Variant.Outlined" Class="premium-input"
                                   Placeholder="اختر الخزينة...">
                            @foreach (var box in _boxes.Where(b => b.IsActive))
                            {
                                <MudSelectItem T="int?" Value="@((int?)box.CashBoxId)">
                                    <div class="select-box-item">
                                        <span class="sbi-dot" style="background:@box.Color;"></span>
                                        <span>@box.CashBoxName</span>
                                        <span class="sbi-balance">(@box.CurrentBalance.ToString("N2") ج)</span>
                                    </div>
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                    <!-- To CashBox (Transfer) -->
                    @if (_form.OperationType == ManualOperationTypes.Transfer)
                    {
                        <div class="field-group transfer-field">
                            <div class="transfer-arrow">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" />
                            </div>
                            <label class="field-label">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" />
                                إلى خزينة <span class="required">*</span>
                            </label>
                            <MudSelect T="int?" @bind-Value="_form.ToCashBoxId"
                                       Variant="Variant.Outlined" Class="premium-input"
                                       Placeholder="اختر خزينة المقصد...">
                                @foreach (var box in _boxes.Where(b => b.IsActive && b.CashBoxId != _form.CashBoxId))
                                {
                                    <MudSelectItem T="int?" Value="@((int?)box.CashBoxId)">
                                        <div class="select-box-item">
                                            <span class="sbi-dot" style="background:@box.Color;"></span>
                                            <span>@box.CashBoxName</span>
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                    }

                    <!-- Personal Account (Loans) -->
                    @if (_form.OperationType == ManualOperationTypes.LoanIn ||
                         _form.OperationType == ManualOperationTypes.LoanRepayment)
                    {
                        <div class="field-group">
                            <label class="field-label">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                الحساب الشخصي <span class="required">*</span>
                            </label>
                            <MudSelect T="int?" @bind-Value="_form.PersonalAccountId"
                                       Variant="Variant.Outlined" Class="premium-input"
                                       Placeholder="اختر الحساب...">
                                @foreach (var acc in _accounts)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)acc.PersonalAccountId)">
                                        <div class="select-acc-item">
                                            <strong>@acc.AccountName</strong>
                                            <span class="sai-type">@acc.AccountTypeAr</span>
                                            @if (acc.CurrentBalance != 0)
                                            {
                                                <span class="sai-bal @(acc.CurrentBalance > 0 ? "sai-red" : "sai-green")">
                                                    @acc.CurrentBalance.ToString("N2") ج @acc.BalanceStatus
                                                </span>
                                            }
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                       OnClick="@(() => Navigation.NavigateTo("/cashbox/personal-accounts/new"))"
                                       Class="add-acc-link">
                                إضافة حساب شخصي جديد
                            </MudButton>
                        </div>
                    }

                    <!-- Recipient -->
                    @if (_form.OperationType == ManualOperationTypes.ManualReceipt ||
                         _form.OperationType == ManualOperationTypes.ManualPayment)
                    {
                        <div class="field-group">
                            <label class="field-label">
                                <MudIcon Icon="@Icons.Material.Filled.PersonOutline" Size="Size.Small" />
                                @(_form.OperationType == ManualOperationTypes.ManualReceipt ? "تم القبض من" : "تم الصرف إلى")
                            </label>
                            <MudTextField @bind-Value="_form.Recipient"
                                          Variant="Variant.Outlined" Class="premium-input"
                                          Placeholder="اسم الشخص أو الجهة..." />
                        </div>
                    }

                    <!-- Notes -->
                    <div class="field-group">
                        <label class="field-label">
                            <MudIcon Icon="@Icons.Material.Filled.StickyNote2" Size="Size.Small" />
                            ملاحظات
                        </label>
                        <MudTextField @bind-Value="_form.Notes"
                                      Variant="Variant.Outlined" Lines="3" Class="premium-input"
                                      Placeholder="أضف ملاحظات إضافية..." />
                    </div>
                </div>
            </div>

            <!-- ═══ Info Alert ═══ -->
            @if (_form.OperationType == ManualOperationTypes.Transfer)
            {
                <div class="info-alert info-blue">
                    <div class="alert-icon"><MudIcon Icon="@Icons.Material.Filled.Info" /></div>
                    <div class="alert-body">
                        <strong>التحويل بين الخزن</strong>
                        <p>سيتم إنشاء حركتين تلقائياً — صرف من المصدر + دخل للمستقبل</p>
                    </div>
                </div>
            }
            else if (_form.OperationType == ManualOperationTypes.LoanIn)
            {
                <div class="info-alert info-blue">
                    <div class="alert-icon"><MudIcon Icon="@Icons.Material.Filled.Info" /></div>
                    <div class="alert-body">
                        <strong>قرض دخل</strong>
                        <p>سيزيد رصيد الخزينة + يصبح الشخص دائناً (الشركة عليها له)</p>
                    </div>
                </div>
            }
            else if (_form.OperationType == ManualOperationTypes.LoanRepayment)
            {
                <div class="info-alert info-amber">
                    <div class="alert-icon"><MudIcon Icon="@Icons.Material.Filled.Warning" /></div>
                    <div class="alert-body">
                        <strong>تسديد قرض</strong>
                        <p>سينقص رصيد الخزينة + ينقص رصيد الدائن</p>
                    </div>
                </div>
            }
        </div>

        <!-- ─── Sidebar ─── -->
        <div class="side-col">
            <div class="summary-panel">
                <div class="sp-header">
                    <div class="sp-icon" style="background:@(_currentOpColor)12;color:@_currentOpColor;">
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" />
                    </div>
                    <h3>ملخص العملية</h3>
                </div>

                <!-- Operation Preview -->
                <div class="sp-preview" style="background:@(_currentOpColor)08;border-color:@(_currentOpColor)25;">
                    <div class="sp-prev-icon" style="background:@_currentOpColor;">
                        <MudIcon Icon="@GetOpIcon(_currentOpIcon)" Size="Size.Small" />
                    </div>
                    <div class="sp-prev-text">
                        <strong>@ManualOperationTypes.All.GetValueOrDefault(_form.OperationType, "حركة")</strong>
                        <small>@_currentOpDesc</small>
                    </div>
                </div>

                <!-- Summary Details -->
                <div class="sp-details">
                    <div class="sp-row">
                        <span class="sp-label">التاريخ</span>
                        <span class="sp-value">@_form.TransactionDate.ToString("yyyy/MM/dd")</span>
                    </div>

                    @{ var selectedBox = _boxes.FirstOrDefault(b => b.CashBoxId == _form.CashBoxId); }
                    @if (selectedBox != null)
                    {
                        <div class="sp-row">
                            <span class="sp-label">الخزينة</span>
                            <span class="sp-value" style="color:@selectedBox.Color;font-weight:700;">@selectedBox.CashBoxName</span>
                        </div>
                        <div class="sp-row">
                            <span class="sp-label">الرصيد الحالي</span>
                            <span class="sp-value sp-bold">@selectedBox.CurrentBalance.ToString("N2") ج.م</span>
                        </div>
                    }

                    @if (_form.OperationType == ManualOperationTypes.Transfer)
                    {
                        var toBox = _boxes.FirstOrDefault(b => b.CashBoxId == _form.ToCashBoxId);
                        if (toBox != null)
                        {
                            <div class="sp-row">
                                <span class="sp-label">إلى خزينة</span>
                                <span class="sp-value" style="color:@toBox.Color;font-weight:700;">@toBox.CashBoxName</span>
                            </div>
                        }
                    }

                    @if (_form.PersonalAccountId.HasValue)
                    {
                        var acc = _accounts.FirstOrDefault(a => a.PersonalAccountId == _form.PersonalAccountId);
                        if (acc != null)
                        {
                            <div class="sp-row">
                                <span class="sp-label">الحساب</span>
                                <span class="sp-value sp-bold">@acc.AccountName</span>
                            </div>
                        }
                    }

                    @if (!string.IsNullOrEmpty(_form.Recipient))
                    {
                        <div class="sp-row">
                            <span class="sp-label">المستلم</span>
                            <span class="sp-value">@_form.Recipient</span>
                        </div>
                    }
                </div>

                <!-- Amount Box -->
                <div class="sp-amount-box" style="background:@(_currentOpColor)08;border-color:@(_currentOpColor)30;">
                    <span class="sp-amount-label">المبلغ</span>
                    <span class="sp-amount-value" style="color:@_currentOpColor;">
                        @_form.Amount.ToString("N2")
                        <small>ج.م</small>
                    </span>
                </div>

                <!-- New Balance Preview -->
                @if (selectedBox != null && _form.Amount > 0)
                {
                    var newBalance = selectedBox.CurrentBalance;
                    if (_form.OperationType == ManualOperationTypes.ManualReceipt ||
                        _form.OperationType == ManualOperationTypes.LoanIn ||
                        _form.OperationType == ManualOperationTypes.OpeningBalance)
                        newBalance += _form.Amount;
                    else
                        newBalance -= _form.Amount;

                    var nbClass = newBalance < 0 ? "nb-negative" : "nb-positive";

                    <div class="sp-new-balance @nbClass">
                        <div class="sp-nb-header">
                            <MudIcon Icon="@(newBalance >= 0 ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)" Size="Size.Small" />
                            <span>الرصيد بعد العملية</span>
                        </div>
                        <span class="sp-nb-value">
                            @newBalance.ToString("N2") <small>ج.م</small>
                        </span>
                    </div>

                    @if (newBalance < 0 && (_form.OperationType == ManualOperationTypes.ManualPayment ||
                        _form.OperationType == ManualOperationTypes.LoanRepayment ||
                        _form.OperationType == ManualOperationTypes.Transfer))
                    {
                        <div class="sp-warning">
                            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" />
                            <span>الرصيد غير كافي!</span>
                        </div>
                    }
                }

                <!-- Actions -->
                <div class="sp-actions">
                    <button class="sp-btn sp-btn-cancel" @onclick="GoBack">
                        <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                        إلغاء
                    </button>
                    <button class="sp-btn sp-btn-save" disabled="@(_isSaving || !CanSave)"
                            style="background:@_currentOpColor;"
                            @onclick="Save">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Surface" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                        }
                        <span>تأكيد العملية</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>
}

<style>
    /* ══════════════════════════════════════════════════
       VARIABLES
       ══════════════════════════════════════════════════ */
    :root {
        --gold: #D4A853;
        --gold-dark: #B8912A;
        --gold-bg: #FEFBF3;
        --navy: #1B2A4A;
        --navy-dark: #0F1D36;
        --navy-light: #2D4A7A;
    }

    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(25px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-18px); } }
    @@keyframes pulseGlow { 0%, 100% { box-shadow: 0 0 0 0 rgba(212,168,83,0.4); } 50% { box-shadow: 0 0 25px 8px rgba(212,168,83,0.15); } }
    @@keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
    @@keyframes bounceSoft { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }

    /* ══════════════════════════════════════════════════
       LOADING
       ══════════════════════════════════════════════════ */
    .loading-screen {
        display: flex; align-items: center; justify-content: center; min-height: 70vh;
    }
    .loading-box { text-align: center; max-width: 300px; }
    .loading-logo {
        width: 76px; height: 76px; margin: 0 auto 1.25rem; border-radius: 20px;
        display: flex; align-items: center; justify-content: center; color: white;
        animation: bounceSoft 2s ease-in-out infinite;
    }
    .loading-box h2 { margin: 0 0 0.5rem; font-weight: 800; font-size: 1.3rem; }
    .loading-box p { color: var(--mud-palette-text-secondary); margin: 0 0 1.5rem; font-size: 0.88rem; }

    /* ══════════════════════════════════════════════════
       PAGE
       ══════════════════════════════════════════════════ */
    .manual-page {
        max-width: 1500px; margin: 0 auto; padding: 0 1.25rem 3rem; position: relative;
    }
    .page-bg-deco { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
    .bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); }
    .bg-orb-1 { width: 400px; height: 400px; top: -200px; right: -150px; animation: float 12s ease-in-out infinite; }
    .bg-orb-2 { width: 350px; height: 350px; bottom: -150px; left: -100px; background: radial-gradient(circle, rgba(59,130,246,0.06), transparent 70%); }
    .top-accent {
        height: 5px; position: relative; overflow: hidden; margin-bottom: 1.5rem;
        border-radius: 0 0 10px 10px; transition: background 0.4s ease;
    }
    .accent-shimmer {
        position: absolute; inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
        animation: shimmer 3s ease-in-out infinite;
    }

    /* ══════════════════════════════════════════════════
       HEADER
       ══════════════════════════════════════════════════ */
    .manual-header {
        position: relative; border-radius: 24px; overflow: hidden; margin-bottom: 1.5rem;
    }
    .mh-bg { position: absolute; inset: 0; }
    .mh-gradient {
        position: absolute; inset: 0;
        background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 50%, var(--navy-light) 100%);
    }
    .mh-orbs { position: absolute; inset: 0; overflow: hidden; }
    .mh-orb { position: absolute; border-radius: 50%; }
    .mh-o1 { width: 350px; height: 350px; top: -150px; right: -100px; background: radial-gradient(circle, rgba(212,168,83,0.25), transparent 60%); animation: float 8s ease-in-out infinite; }
    .mh-o2 { width: 200px; height: 200px; bottom: -80px; left: 20%; background: radial-gradient(circle, rgba(212,168,83,0.12), transparent 60%); }
    .mh-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 40px 40px; }
    .mh-content {
        position: relative; z-index: 2; padding: 1.75rem 2rem;
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    }
    .mh-right { display: flex; align-items: center; gap: 1rem; }
    .back-btn {
        width: 44px; height: 44px; border-radius: 12px;
        background: rgba(255,255,255,0.1); backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2); color: white;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all 0.3s; flex-shrink: 0;
    }
    .back-btn:hover { background: rgba(255,255,255,0.2); transform: translateX(4px); }
    .mh-icon-wrap { position: relative; }
    .mh-icon-glow {
        position: absolute; inset: -8px; border-radius: 18px;
        filter: blur(18px); opacity: 0.3; animation: pulseGlow 4s ease-in-out infinite;
    }
    .mh-icon {
        position: relative; width: 56px; height: 56px;
        background: rgba(255,255,255,0.08); backdrop-filter: blur(20px);
        border: 1px solid; border-radius: 16px;
        display: flex; align-items: center; justify-content: center; color: var(--gold);
    }
    .mh-text h1 { margin: 0; font-size: 1.6rem; font-weight: 900; color: white; }
    .mh-text p {
        margin: 0.5rem 0 0; display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    }
    .mh-op-name {
        display: inline-flex; padding: 0.3rem 0.7rem; border-radius: 8px;
        font-size: 0.78rem; font-weight: 700;
    }
    .mh-desc { font-size: 0.85rem; color: rgba(255,255,255,0.6); }

    /* ══════════════════════════════════════════════════
       FORM LAYOUT
       ══════════════════════════════════════════════════ */
    .form-layout {
        display: grid; grid-template-columns: 1fr 380px; gap: 1.5rem;
    }
    .main-col { display: flex; flex-direction: column; gap: 1.25rem; }

    /* ══════════════════════════════════════════════════
       PANELS
       ══════════════════════════════════════════════════ */
    .form-panel {
        background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider);
        border-radius: 20px; padding: 1.75rem;
    }
    .panel-hdr {
