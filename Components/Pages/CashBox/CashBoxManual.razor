    }
    .op-icon-box .mud-icon-root { font-size: 26px !important; }
    .op-text { flex: 1; min-width: 0; }
    .op-text strong { display: block; font-size: 0.95rem; color: var(--mud-palette-text-primary); }
    .op-text small { font-size: 0.75rem; color: var(--mud-palette-text-secondary); }
    .op-check {
        width: 24px; height: 24px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; color: white;
        flex-shrink: 0; animation: fadeInUp 0.3s ease-out;
    }
    .op-check .mud-icon-root { font-size: 14px !important; }

    /* ══════════════════════════════════════════════════
       FORM FIELDS
       ══════════════════════════════════════════════════ */
    .form-fields { display: flex; flex-direction: column; gap: 1.25rem; }
    .fields-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .field-group { display: flex; flex-direction: column; gap: 0.5rem; }
    .field-label {
        display: flex; align-items: center; gap: 0.4rem;
        font-size: 0.85rem; font-weight: 700; color: var(--mud-palette-text-secondary);
    }
    .field-label .mud-icon-root { font-size: 16px !important; color: var(--gold) !important; }
    .required { color: #ef4444; }
    ::deep .premium-input .mud-input-outlined-border { border-radius: 14px !important; }

    /* Transfer Arrow */
    .transfer-field { position: relative; padding-top: 1rem; }
    .transfer-arrow {
        position: absolute; top: -8px; right: 24px;
        width: 32px; height: 32px; border-radius: 50%;
        background: var(--mud-palette-surface); border: 2px solid var(--mud-palette-divider);
        display: flex; align-items: center; justify-content: center;
        color: #06b6d4; z-index: 2;
    }

    /* Select Items */
    .select-box-item { display: flex; align-items: center; gap: 0.5rem; }
    .sbi-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .sbi-balance { font-size: 0.78rem; color: var(--mud-palette-text-secondary); margin-right: auto; }
    .select-acc-item { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .sai-type { font-size: 0.72rem; color: var(--mud-palette-text-secondary); }
    .sai-bal { font-size: 0.75rem; font-weight: 600; margin-right: auto; }
    .sai-red { color: #ef4444; }
    .sai-green { color: #10b981; }
    .add-acc-link { align-self: flex-start; margin-top: 0.25rem; }

    /* ══════════════════════════════════════════════════
       INFO ALERTS
       ══════════════════════════════════════════════════ */
    .info-alert {
        display: flex; align-items: flex-start; gap: 0.875rem;
        padding: 1.25rem; border-radius: 16px; border: 1px solid;
    }
    .info-blue { background: rgba(59,130,246,0.06); border-color: rgba(59,130,246,0.15); color: #1d4ed8; }
    .info-amber { background: rgba(245,158,11,0.06); border-color: rgba(245,158,11,0.15); color: #b45309; }
    .alert-icon {
        width: 40px; height: 40px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .info-blue .alert-icon { background: rgba(59,130,246,0.12); }
    .info-amber .alert-icon { background: rgba(245,158,11,0.12); }
    .alert-body strong { display: block; font-size: 0.92rem; margin-bottom: 0.25rem; }
    .alert-body p { margin: 0; font-size: 0.82rem; opacity: 0.85; }

    /* ══════════════════════════════════════════════════
       SIDEBAR SUMMARY
       ══════════════════════════════════════════════════ */
    .side-col { position: relative; }
    .summary-panel {
        background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider);
        border-radius: 20px; padding: 1.75rem; position: sticky; top: 1rem;
    }
    .sp-header {
        display: flex; align-items: center; gap: 0.75rem;
        margin-bottom: 1.25rem; padding-bottom: 0.875rem;
        border-bottom: 2px solid var(--mud-palette-divider);
    }
    .sp-icon {
        width: 40px; height: 40px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .sp-header h3 { margin: 0; font-size: 1.05rem; font-weight: 700; color: var(--mud-palette-text-primary); }

    /* Preview */
    .sp-preview {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.875rem; border: 1px solid; border-radius: 14px;
        margin-bottom: 1.25rem; transition: all 0.3s;
    }
    .sp-prev-icon {
        width: 40px; height: 40px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0;
    }
    .sp-prev-text strong { display: block; font-size: 0.92rem; color: var(--mud-palette-text-primary); }
    .sp-prev-text small { font-size: 0.75rem; color: var(--mud-palette-text-secondary); }

    /* Details */
    .sp-details {
        display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem;
    }
    .sp-row {
        display: flex; justify-content: space-between; align-items: center;
        padding: 0.5rem 0; font-size: 0.88rem;
    }
    .sp-label { color: var(--mud-palette-text-secondary); font-weight: 500; }
    .sp-value { color: var(--mud-palette-text-primary); font-weight: 600; }
    .sp-bold { font-weight: 800; }

    /* Amount Box */
    .sp-amount-box {
        border: 2px dashed; border-radius: 14px; padding: 1.25rem;
        text-align: center; margin-bottom: 1rem; transition: border-style 0.3s;
    }
    .summary-panel:hover .sp-amount-box { border-style: solid; }
    .sp-amount-label {
        display: block; font-size: 0.82rem; font-weight: 600;
        color: var(--mud-palette-text-secondary); margin-bottom: 0.35rem;
    }
    .sp-amount-value {
        font-size: 2rem; font-weight: 900; line-height: 1;
    }
    .sp-amount-value small { font-size: 0.75rem; opacity: 0.6; margin-right: 0.2rem; }

    /* New Balance */
    .sp-new-balance {
        border: 1px solid; border-radius: 12px; padding: 1rem; text-align: center;
        margin-bottom: 0.75rem;
    }
    .sp-nb-header {
        display: flex; align-items: center; justify-content: center; gap: 0.35rem;
        font-size: 0.78rem; font-weight: 600; color: var(--mud-palette-text-secondary);
        margin-bottom: 0.35rem;
    }
    .sp-nb-value { font-size: 1.5rem; font-weight: 900; }
    .sp-nb-value small { font-size: 0.65rem; opacity: 0.6; }

    .nb-positive { background: rgba(16,185,129,0.08); border-color: rgba(16,185,129,0.2); }
    .nb-positive .sp-nb-header .mud-icon-root { color: #10b981 !important; }
    .nb-positive .sp-nb-value { color: #10b981; }

    .nb-negative { background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.2); }
    .nb-negative .sp-nb-header .mud-icon-root { color: #ef4444 !important; }
    .nb-negative .sp-nb-value { color: #ef4444; }

    /* Warning */
    .sp-warning {
        display: flex; align-items: center; justify-content: center; gap: 0.4rem;
        background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);
        color: #b91c1c; border-radius: 10px; padding: 0.6rem;
        font-size: 0.82rem; font-weight: 700; margin-bottom: 0.75rem;
    }
    .sp-warning .mud-icon-root { font-size: 16px !important; }

    /* Actions */
    .sp-actions {
        display: flex; gap: 0.75rem; padding-top: 1rem;
        border-top: 1px solid var(--mud-palette-divider);
    }
    .sp-btn {
        flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.4rem;
        padding: 0.875rem; border-radius: 14px; font-size: 0.92rem; font-weight: 700;
        cursor: pointer; transition: all 0.3s; font-family: inherit; border: none;
    }
    .sp-btn-cancel {
        background: var(--mud-palette-background); color: var(--mud-palette-text-secondary);
        border: 1px solid var(--mud-palette-divider);
    }
    .sp-btn-cancel:hover { background: var(--mud-palette-background-gray); }
    .sp-btn-save {
        color: white; box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }
    .sp-btn-save:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.2); }
    .sp-btn-save:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    /* ══════════════════════════════════════════════════
       RESPONSIVE
       ══════════════════════════════════════════════════ */
    @@media (max-width: 1100px) {
        .form-layout { grid-template-columns: 1fr; }
        .summary-panel { position: static; }
    }
    @@media (max-width: 768px) {
        .fields-row { grid-template-columns: 1fr; }
        .ops-grid { grid-template-columns: 1fr; }
        .mh-content { flex-direction: column; align-items: flex-start; }
    }
</style>

@code {
    private bool _isLoading = true;
    private bool _isSaving = false;

    private CashBoxManualFormDto _form = new()
    {
        OperationType = ManualOperationTypes.ManualReceipt,
        TransactionDate = DateTime.Now
    };

    private List<CashBoxListDto> _boxes = new();
    private List<PersonalAccountListDto> _accounts = new();

    private string _currentOpColor = "#22c55e";
    private string _currentOpIcon = "AddCard";
    private string _currentOpDesc = "تسجيل سند قبض يدوي";

    private record OpInfo(string Type, string Title, string SubTitle, string Description, string Icon, string Color);

    private List<OpInfo> _operations = new()
    {
        new(ManualOperationTypes.ManualReceipt, "سند قبض يدوي", "دخل غير مرتبط بفاتورة", "تسجيل سند قبض يدوي (دخل)", "AddCard", "#22c55e"),
        new(ManualOperationTypes.ManualPayment, "سند صرف يدوي", "صرف غير مرتبط بمصروف", "تسجيل سند صرف يدوي (خرج)", "RemoveCircle", "#dc2626"),
        new(ManualOperationTypes.LoanIn, "قرض دخل", "أخذ قرض من شخص", "تسجيل قرض دخل من شخص", "TrendingUp", "#3b82f6"),
        new(ManualOperationTypes.LoanRepayment, "تسديد قرض", "سداد لشخص", "تسجيل تسديد قرض لشخص", "TrendingDown", "#8b5cf6"),
        new(ManualOperationTypes.Transfer, "تحويل بين خزن", "نقل من خزينة لأخرى", "تحويل رصيد بين خزينتين", "SwapHoriz", "#06b6d4"),
        new(ManualOperationTypes.OpeningBalance, "رصيد افتتاحي", "إضافة رصيد بدء", "تسجيل رصيد افتتاحي إضافي", "Stars", "#6366f1")
    };

    private bool CanSave =>
        _form.Amount > 0 &&
        _form.CashBoxId.HasValue &&
        (_form.OperationType != ManualOperationTypes.Transfer || _form.ToCashBoxId.HasValue) &&
        ((_form.OperationType != ManualOperationTypes.LoanIn && _form.OperationType != ManualOperationTypes.LoanRepayment)
            || _form.PersonalAccountId.HasValue);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canAdd = user.HasClaim("Permission", "frmCashBoxManual:Add") || user.IsInRole("Admin");
        if (!canAdd) { Navigation.NavigateTo("/cashbox/dashboard"); return; }

        _boxes = await CashBoxService.GetCashBoxesAsync(activeOnly: true);
        _accounts = await PersonalAccountService.GetAccountsLookupAsync();

        var defaultBox = _boxes.FirstOrDefault(b => b.IsDefault) ?? _boxes.FirstOrDefault();
        if (defaultBox != null) _form.CashBoxId = defaultBox.CashBoxId;

        _isLoading = false;
    }

    private void SelectOp(string type, string color, string icon, string desc)
    {
        _form.OperationType = type;
        _currentOpColor = color;
        _currentOpIcon = icon;
        _currentOpDesc = desc;
        _form.ToCashBoxId = null;
        _form.PersonalAccountId = null;
        _form.Recipient = null;
    }

    private async Task Save()
    {
        if (!CanSave) return;
        _isSaving = true;

        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userName = auth.User.Identity?.Name ?? "System";

        var (ok, msg, _) = await CashBoxService.CreateManualOperationAsync(_form, userName);
        _isSaving = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) Navigation.NavigateTo("/cashbox/transactions");
    }

    private void GoBack() => Navigation.NavigateTo("/cashbox/dashboard");

    private string GetOpIcon(string iconName) => iconName switch
    {
        "AddCard" => Icons.Material.Filled.AddCard,
        "RemoveCircle" => Icons.Material.Filled.RemoveCircle,
        "TrendingUp" => Icons.Material.Filled.TrendingUp,
        "TrendingDown" => Icons.Material.Filled.TrendingDown,
        "SwapHoriz" => Icons.Material.Filled.SwapHoriz,
        "Stars" => Icons.Material.Filled.Stars,
        _ => Icons.Material.Filled.SwapHoriz
    };
}
