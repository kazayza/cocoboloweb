@code {
    private bool _isLoading = true;
    private List<CashBoxBalanceSummaryDto> _summary = new();
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private string _currentPeriod = "all";

    private Dictionary<string, string> _periods = new()
    {
        { "all", "كل الفترة" },
        { "today", "اليوم" },
        { "week", "أسبوع" },
        { "month", "شهر" },
        { "year", "سنة" }
    };

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frmCashBoxSummary:View") || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        await LoadData();
        _isLoading = false;
    }

    private async Task LoadData()
    {
        _summary = await CashBoxService.GetSummaryAsync(_dateFrom, _dateTo);
        StateHasChanged();
    }

    private async Task SetPeriod(string period)
    {
        _currentPeriod = period;
        var today = DateTime.Today;

        switch (period)
        {
            case "today": _dateFrom = today; _dateTo = today; break;
            case "week": _dateFrom = today.AddDays(-6); _dateTo = today; break;
            case "month": _dateFrom = new DateTime(today.Year, today.Month, 1); _dateTo = today; break;
            case "year": _dateFrom = new DateTime(today.Year, 1, 1); _dateTo = today; break;
            default: _dateFrom = null; _dateTo = null; break;
        }

        await LoadData();
    }

    private string GetPeriodText() => _currentPeriod switch
    {
        "today" => "اليوم",
        "week" => "آخر أسبوع",
        "month" => "هذا الشهر",
        "year" => "هذه السنة",
        "custom" => $"من {_dateFrom?.ToString("yyyy/MM/dd")} إلى {_dateTo?.ToString("yyyy/MM/dd")}",
        _ => "كل الفترة"
    };

    private async Task PrintReport() => await JS.InvokeVoidAsync("window.print");

    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);
}
