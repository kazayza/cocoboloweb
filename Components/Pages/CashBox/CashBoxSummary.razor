@page "/cashbox/summary"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject ICashBoxService CashBoxService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-box">
            <div class="loading-logo"><MudIcon Icon="@Icons.Material.Filled.Summarize" Size="Size.Large" /></div>
            <h2>ملخص الخزن</h2>
            <p>جاري تحميل التقرير...</p>
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="border-radius:10px;height:6px;" />
        </div>
    </div>
}
else
{
<div class="sum-page" dir="rtl">

    <div class="page-bg-deco"><div class="bg-orb bg-orb-1"></div><div class="bg-orb bg-orb-2"></div></div>
    <div class="top-accent"><div class="accent-shimmer"></div></div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ HEADER                                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="sum-header">
        <div class="sh-bg">
            <div class="sh-gradient"></div>
            <div class="sh-orbs"><div class="sh-orb sh-o1"></div><div class="sh-orb sh-o2"></div></div>
            <div class="sh-grid"></div>
        </div>
        <div class="sh-content">
            <div class="sh-top">
                <div class="sh-info">
                    <div class="sh-icon-wrap">
                        <div class="sh-icon-glow"></div>
                        <div class="sh-icon"><MudIcon Icon="@Icons.Material.Filled.Summarize" Size="Size.Large" /></div>
                        <div class="sh-badge"><MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" /></div>
                    </div>
                    <div class="sh-text">
                        <h1>ملخص الخزن</h1>
                        <p>
                            <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" Class="sh-sub-icon" />
                            تقرير شامل بأرصدة وحركات جميع الخزن
                        </p>
                    </div>
                </div>
                <div class="sh-actions">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Print"
                               OnClick="PrintReport" Class="sh-btn-ghost">طباعة التقرير</MudButton>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Dashboard"
                               OnClick="@(() => Navigation.NavigateTo("/cashbox/dashboard"))" Class="sh-btn-ghost">Dashboard</MudButton>
                </div>
            </div>

            <!-- Period Filter -->
            <div class="period-bar">
                <div class="period-label">
                    <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" />
                    <span>الفترة:</span>
                </div>
                <div class="period-buttons">
                    @foreach (var p in _periods)
                    {
                        <button class="period-btn @(_currentPeriod == p.Key ? "period-active" : "")"
                                @onclick="@(() => SetPeriod(p.Key))">
                            @p.Value
                        </button>
                    }
                </div>
                <div class="period-dates">
                    <MudDatePicker Date="_dateFrom"
                                   DateChanged="@(d => { _dateFrom = d; _currentPeriod = "custom"; _ = LoadData(); })"
                                   Label="من" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" Class="period-date-picker"
                                   Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />
                    <span class="period-arrow">←</span>
                    <MudDatePicker Date="_dateTo"
                                   DateChanged="@(d => { _dateTo = d; _currentPeriod = "custom"; _ = LoadData(); })"
                                   Label="إلى" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" Class="period-date-picker" />
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ TOTAL STATS                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="totals-row">
        <div class="total-card tc-opening">
            <div class="tc-glow"></div>
            <div class="tc-accent"></div>
            <div class="tc-inner">
                <div class="tc-icon-box"><MudIcon Icon="@Icons.Material.Filled.Stars" /></div>
                <div class="tc-data">
                    <span class="tc-label">الأرصدة الافتتاحية</span>
                    <div class="tc-val-row">
                        <span class="tc-value">@FormatMoney(_summary.Sum(s => s.OpeningBalance))</span>
                        <span class="tc-curr">ج.م</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="total-card tc-in">
            <div class="tc-glow"></div>
            <div class="tc-accent"></div>
            <div class="tc-inner">
                <div class="tc-icon-box"><MudIcon Icon="@Icons.Material.Filled.TrendingUp" /></div>
                <div class="tc-data">
                    <span class="tc-label">إجمالي الدخل</span>
                    <div class="tc-val-row">
                        <span class="tc-value">@FormatMoney(_summary.Sum(s => s.TotalIn))</span>
                        <span class="tc-curr">ج.م</span>
                    </div>
                    <span class="tc-sub">@_summary.Sum(s => s.InCount) حركة</span>
                </div>
            </div>
        </div>

        <div class="total-card tc-out">
            <div class="tc-glow"></div>
            <div class="tc-accent"></div>
            <div class="tc-inner">
                <div class="tc-icon-box"><MudIcon Icon="@Icons.Material.Filled.TrendingDown" /></div>
                <div class="tc-data">
                    <span class="tc-label">إجمالي الصرف</span>
                    <div class="tc-val-row">
                        <span class="tc-value">@FormatMoney(_summary.Sum(s => s.TotalOut))</span>
                        <span class="tc-curr">ج.م</span>
                    </div>
                    <span class="tc-sub">@_summary.Sum(s => s.OutCount) حركة</span>
                </div>
            </div>
        </div>

        <div class="total-card tc-balance">
            <div class="tc-glow"></div>
            <div class="tc-accent"></div>
            <div class="tc-inner">
                <div class="tc-icon-box"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
                <div class="tc-data">
                    <span class="tc-label">الرصيد الإجمالي</span>
                    <div class="tc-val-row">
                        <span class="tc-value">@FormatMoney(_summary.Sum(s => s.CurrentBalance))</span>
                        <span class="tc-curr">ج.م</span>
                    </div>
                    <span class="tc-sub">@_summary.Count خزينة</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ SUMMARY TABLE                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="table-panel">
        <div class="tp-header">
            <div class="tp-title-group">
                <div class="tp-icon"><MudIcon Icon="@Icons.Material.Filled.TableChart" /></div>
                <div>
                    <h3>تفصيل الخزن</h3>
                    <p>@_summary.Count خزينة — @GetPeriodText()</p>
                </div>
            </div>
        </div>

        <MudTable Items="@_summary" Hover="true" Striped="true" Class="premium-table">
            <HeaderContent>
                <MudTh>الخزينة</MudTh>
                <MudTh>النوع</MudTh>
                <MudTh>الافتتاحي</MudTh>
                <MudTh>الدخل</MudTh>
                <MudTh>الصرف</MudTh>
                <MudTh>الرصيد الحالي</MudTh>
                <MudTh>الحالة</MudTh>
            </HeaderContent>
            <RowTemplate>
                <!-- الخزينة -->
                <MudTd DataLabel="الخزينة">
                    <div class="td-cashbox">
                        <div class="td-cb-dot" style="background:@context.Color;"></div>
                        <strong class="td-cb-name">@context.CashBoxName</strong>
                    </div>
                </MudTd>

                <!-- النوع -->
                <MudTd DataLabel="النوع">
                    <span class="td-kind" style="background:@(context.Color)10;color:@context.Color;border:1px solid @(context.Color)25;">
                        @CashBoxKinds.All.GetValueOrDefault(context.CashBoxKind ?? "Other", "أخرى")
                    </span>
                </MudTd>

                <!-- الافتتاحي -->
                <MudTd DataLabel="الافتتاحي">
                    <span class="td-money">@FormatMoney(context.OpeningBalance)</span>
                </MudTd>

                <!-- الدخل -->
                <MudTd DataLabel="الدخل">
                    <div class="td-flow td-flow-in">
                        <strong>+@FormatMoney(context.TotalIn)</strong>
                        <small>@context.InCount حركة</small>
                    </div>
                </MudTd>

                <!-- الصرف -->
                <MudTd DataLabel="الصرف">
                    <div class="td-flow td-flow-out">
                        <strong>-@FormatMoney(context.TotalOut)</strong>
                        <small>@context.OutCount حركة</small>
                    </div>
                </MudTd>

                <!-- الرصيد -->
                <MudTd DataLabel="الرصيد">
                    <div class="td-balance">
                        <strong style="color:@context.Color;">@FormatMoney(context.CurrentBalance)</strong>
                        <small>ج.م</small>
                    </div>
                    @if (context.TotalIn + context.TotalOut > 0)
                    {
                        var inPct = (double)context.TotalIn / (double)(context.TotalIn + context.TotalOut) * 100;
                        <div class="td-bar">
                            <div class="td-bar-fill" style="width:@inPct.ToString("F0")%;background:@context.Color;"></div>
                        </div>
                    }
                </MudTd>

                <!-- الحالة -->
                <MudTd DataLabel="الحالة">
                    <span class="td-status @(context.IsActive ? "td-st-active" : "td-st-inactive")">
                        <span class="td-st-dot"></span>
                        @(context.IsActive ? "نشطة" : "معطّلة")
                    </span>
                </MudTd>
            </RowTemplate>
        </MudTable>

        @if (!_summary.Any())
        {
            <div class="empty-state">
                <div class="empty-icon-box"><MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" /></div>
                <h3>لا توجد بيانات</h3>
                <p>لم يتم العثور على خزن في هذه الفترة</p>
            </div>
        }

        <!-- Total Footer (inside a real table for alignment) -->
        @if (_summary.Any())
        {
            <div class="table-footer-wrap">
                <table class="tf-table">
                    <tr class="tf-row">
                        <!-- الخزينة -->
                        <td class="tf-cell tf-cell-name">
                            <strong>الإجمالي</strong>
                            <span class="tf-sub">@_summary.Count خزينة</span>
                        </td>
                        <!-- النوع -->
                        <td class="tf-cell">—</td>
                        <!-- الافتتاحي -->
                        <td class="tf-cell">
                            <strong>@FormatMoney(_summary.Sum(s => s.OpeningBalance))</strong>
                        </td>
                        <!-- الدخل -->
                        <td class="tf-cell tf-cell-in">
                            <strong>+@FormatMoney(_summary.Sum(s => s.TotalIn))</strong>
                            <span class="tf-sub">@_summary.Sum(s => s.InCount) حركة</span>
                        </td>
                        <!-- الصرف -->
                        <td class="tf-cell tf-cell-out">
                            <strong>-@FormatMoney(_summary.Sum(s => s.TotalOut))</strong>
                            <span class="tf-sub">@_summary.Sum(s => s.OutCount) حركة</span>
                        </td>
                        <!-- الرصيد -->
                        <td class="tf-cell tf-cell-balance">
                            <strong>@FormatMoney(_summary.Sum(s => s.CurrentBalance)) ج.م</strong>
                        </td>
                        <!-- الحالة -->
                        <td class="tf-cell">—</td>
                    </tr>
                </table>
            </div>
        }
    </div>

    <!-- Print Header (appears only when printing) -->
    <div class="print-header print-only">
        <div class="ph-top">
            <h1>COCOBOLO ERP</h1>
            <span class="ph-divider">|</span>
            <h2>ملخص الخزن</h2>
        </div>
        <div class="ph-meta">
            <span>الفترة: <strong>@GetPeriodText()</strong></span>
            <span>تاريخ الطباعة: <strong>@DateTime.Now.ToString("yyyy/MM/dd HH:mm")</strong></span>
            <span>عدد الخزن: <strong>@_summary.Count</strong></span>
        </div>
    </div>

    <!-- Footer -->
    <div class="dash-footer">
        <div class="footer-inner">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="footer-icon" />
            <span>COCOBOLO ERP — ملخص الخزن</span>
            <span class="footer-premium">Premium</span>
        </div>
    </div>

</div>
}

<style>
    :root { --gold:#D4A853; --gold-dark:#B8912A; --gold-bg:#FEFBF3; --navy:#1B2A4A; --navy-dark:#0F1D36; --navy-light:#2D4A7A; }
    @@keyframes fadeInUp { from{opacity:0;transform:translateY(25px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-18px)} }
    @@keyframes pulseGlow { 0%,100%{box-shadow:0 0 0 0 rgba(212,168,83,0.4)} 50%{box-shadow:0 0 25px 8px rgba(212,168,83,0.15)} }
    @@keyframes shimmer { 0%{transform:translateX(-100%)} 100%{transform:translateX(100%)} }
    @@keyframes bounceSoft { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-4px)} }

    .loading-screen{display:flex;align-items:center;justify-content:center;min-height:70vh}
    .loading-box{text-align:center;max-width:300px}
    .loading-logo{width:76px;height:76px;margin:0 auto 1.25rem;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:20px;display:flex;align-items:center;justify-content:center;color:white;animation:bounceSoft 2s ease-in-out infinite}
    .loading-box h2{margin:0 0 0.5rem;font-weight:800;font-size:1.3rem}
    .loading-box p{color:var(--mud-palette-text-secondary);margin:0 0 1.5rem;font-size:0.88rem}

    .sum-page{max-width:1800px;margin:0 auto;padding:0 1.25rem 2rem;position:relative}
    .page-bg-deco{position:fixed;inset:0;pointer-events:none;z-index:0}
    .bg-orb{position:absolute;border-radius:50%;filter:blur(80px)}
    .bg-orb-1{width:400px;height:400px;top:-200px;right:-150px;background:radial-gradient(circle,rgba(212,168,83,0.12),transparent 70%);animation:float 12s ease-in-out infinite}
    .bg-orb-2{width:350px;height:350px;bottom:-150px;left:-100px;background:radial-gradient(circle,rgba(59,130,246,0.06),transparent 70%)}
    .top-accent{height:5px;background:linear-gradient(90deg,var(--gold),var(--gold-dark),var(--gold));position:relative;overflow:hidden;margin-bottom:1.5rem;border-radius:0 0 10px 10px}
    .accent-shimmer{position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent);animation:shimmer 3s ease-in-out infinite}

    /* ═══════ HEADER ═══════ */
    .sum-header{position:relative;border-radius:24px;overflow:hidden;margin-bottom:1.5rem}
    .sh-bg{position:absolute;inset:0}
    .sh-gradient{position:absolute;inset:0;background:linear-gradient(135deg,var(--navy-dark),var(--navy),var(--navy-light))}
    .sh-orbs{position:absolute;inset:0;overflow:hidden}
    .sh-orb{position:absolute;border-radius:50%}
    .sh-o1{width:350px;height:350px;top:-150px;right:-100px;background:radial-gradient(circle,rgba(212,168,83,0.25),transparent 60%);animation:float 8s ease-in-out infinite}
    .sh-o2{width:200px;height:200px;bottom:-80px;left:20%;background:radial-gradient(circle,rgba(212,168,83,0.12),transparent 60%)}
    .sh-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:40px 40px}
    .sh-content{position:relative;z-index:2;padding:2rem 2.5rem}
    .sh-top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;margin-bottom:2rem}
    .sh-info{display:flex;align-items:center;gap:1.25rem}
    .sh-icon-wrap{position:relative}
    .sh-icon-glow{position:absolute;inset:-10px;background:var(--gold);border-radius:20px;filter:blur(20px);opacity:0.3;animation:pulseGlow 4s ease-in-out infinite}
    .sh-icon{position:relative;width:64px;height:64px;background:rgba(255,255,255,0.1);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.2);border-radius:20px;display:flex;align-items:center;justify-content:center;color:var(--gold)}
    .sh-icon::before{content:'';position:absolute;inset:0;border-radius:20px;background:linear-gradient(135deg,rgba(255,255,255,0.2),transparent 50%)}
    .sh-badge{position:absolute;top:-6px;right:-6px;width:24px;height:24px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;box-shadow:0 4px 12px rgba(212,168,83,0.5);animation:bounceSoft 2s ease-in-out infinite}
    .sh-badge .mud-icon-root{font-size:12px !important}
    .sh-text h1{margin:0;font-size:1.75rem;font-weight:900;color:white}
    .sh-text p{margin:0.5rem 0 0;font-size:0.9rem;color:rgba(255,255,255,0.6);display:flex;align-items:center;gap:0.4rem}
    .sh-sub-icon{color:#10b981 !important;font-size:16px !important}
    .sh-actions{display:flex;gap:0.75rem;flex-wrap:wrap}
    .sh-btn-ghost{background:rgba(255,255,255,0.08) !important;border-color:rgba(255,255,255,0.2) !important;color:white !important;font-weight:600 !important;border-radius:14px !important}

    /* Period filter */
    .period-bar{display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap}
    .period-label{display:flex;align-items:center;gap:0.35rem;color:rgba(255,255,255,0.7);font-weight:600;font-size:0.88rem}
    .period-label .mud-icon-root{font-size:16px !important}
    .period-buttons{display:flex;gap:0.4rem;flex-wrap:wrap}
    .period-btn{padding:0.5rem 1.1rem;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:10px;color:white;font-weight:600;cursor:pointer;font-family:inherit;font-size:0.82rem;transition:all 0.25s}
    .period-btn:hover{background:rgba(255,255,255,0.15);border-color:rgba(255,255,255,0.3)}
    .period-active{background:white !important;color:var(--navy-dark) !important;border-color:white !important;font-weight:700;box-shadow:0 4px 12px rgba(255,255,255,0.2)}
    .period-dates{display:flex;align-items:center;gap:0.5rem;margin-right:auto}
    .period-arrow{color:rgba(255,255,255,0.4);font-size:0.82rem}
    ::deep .period-date-picker{max-width:155px}
    ::deep .period-date-picker .mud-input-outlined-border{border-radius:10px !important}

    /* ═══════ TOTAL CARDS ═══════ */
    .totals-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;margin-bottom:1.5rem}
    .total-card{position:relative;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-divider);border-radius:20px;padding:1.5rem;overflow:hidden;transition:all 0.4s ease;cursor:default}
    .total-card:hover{transform:translateY(-6px);border-color:transparent}
    .tc-glow{position:absolute;inset:-50%;opacity:0;transition:opacity 0.5s;pointer-events:none}
    .total-card:hover .tc-glow{opacity:1}
    .tc-accent{position:absolute;top:0;left:0;right:0;height:4px;transform:scaleX(0.5);transform-origin:center;transition:transform 0.4s}
    .total-card:hover .tc-accent{transform:scaleX(1)}
    .tc-inner{position:relative;z-index:2;display:flex;align-items:center;gap:1rem}
    .tc-icon-box{width:56px;height:56px;border-radius:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform 0.3s}
    .total-card:hover .tc-icon-box{transform:scale(1.12) rotate(-5deg)}
    .tc-data{flex:1;min-width:0}
    .tc-label{font-size:0.85rem;font-weight:600;color:var(--mud-palette-text-secondary);display:block;margin-bottom:0.25rem}
    .tc-val-row{display:flex;align-items:baseline;gap:0.35rem}
    .tc-value{font-size:1.5rem;font-weight:900;line-height:1.2}
    .tc-curr{font-size:0.8rem;font-weight:600;opacity:0.6}
    .tc-sub{font-size:0.75rem;color:var(--mud-palette-text-secondary);margin-top:0.2rem;display:block}

    .tc-opening .tc-glow{background:radial-gradient(circle,rgba(99,102,241,0.2),transparent 60%)}
    .tc-opening .tc-accent{background:linear-gradient(90deg,#6366f1,#4f46e5)}
    .tc-opening .tc-icon-box{background:linear-gradient(135deg,rgba(99,102,241,0.15),rgba(99,102,241,0.05));color:#6366f1}
    .tc-opening .tc-value{color:#6366f1}
    .tc-opening:hover{box-shadow:0 20px 50px rgba(99,102,241,0.2)}

    .tc-in .tc-glow{background:radial-gradient(circle,rgba(16,185,129,0.2),transparent 60%)}
    .tc-in .tc-accent{background:linear-gradient(90deg,#10b981,#059669)}
    .tc-in .tc-icon-box{background:linear-gradient(135deg,rgba(16,185,129,0.15),rgba(16,185,129,0.05));color:#10b981}
    .tc-in .tc-value{color:#10b981}
    .tc-in:hover{box-shadow:0 20px 50px rgba(16,185,129,0.2)}

    .tc-out .tc-glow{background:radial-gradient(circle,rgba(239,68,68,0.2),transparent 60%)}
    .tc-out .tc-accent{background:linear-gradient(90deg,#ef4444,#dc2626)}
    .tc-out .tc-icon-box{background:linear-gradient(135deg,rgba(239,68,68,0.15),rgba(239,68,68,0.05));color:#ef4444}
    .tc-out .tc-value{color:#ef4444}
    .tc-out:hover{box-shadow:0 20px 50px rgba(239,68,68,0.2)}

    .tc-balance .tc-glow{background:radial-gradient(circle,rgba(212,168,83,0.2),transparent 60%)}
    .tc-balance .tc-accent{background:linear-gradient(90deg,var(--gold),var(--gold-dark))}
    .tc-balance .tc-icon-box{background:linear-gradient(135deg,rgba(212,168,83,0.15),rgba(212,168,83,0.05));color:var(--gold)}
    .tc-balance .tc-value{color:var(--gold)}
    .tc-balance:hover{box-shadow:0 20px 50px rgba(212,168,83,0.2)}

    /* ═══════ TABLE PANEL ═══════ */
