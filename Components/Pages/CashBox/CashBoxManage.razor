@code {
    private bool _isLoading = true;
    private bool _filterExpanded = true;
    private List<CashBoxListDto> _all = new();
    private List<CashBoxListDto> _filtered = new();

    private string _searchText = "";
    private string? _kindFilter;
    private bool? _activeFilter;

    // Delete
    private bool _showDeleteDialog = false;
    private bool _isDeleting = false;
    private CashBoxListDto? _selectedBox;

    private bool _canAdd, _canEdit, _canDelete;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frmCashBox:View") || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        _canAdd = user.HasClaim("Permission", "frmCashBox:Add") || user.IsInRole("Admin");
        _canEdit = user.HasClaim("Permission", "frmCashBox:Edit") || user.IsInRole("Admin");
        _canDelete = user.HasClaim("Permission", "frmCashBox:Delete") || user.IsInRole("Admin");

        await LoadData();
        _isLoading = false;
    }

    private async Task LoadData()
    {
        _all = await CashBoxService.GetCashBoxesAsync();
        ApplyFilter();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? "";
        ApplyFilter();
    }

    private void ClearSearch()
    {
        _searchText = "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        _filtered = _all.Where(b =>
            (string.IsNullOrEmpty(_searchText) || b.CashBoxName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_kindFilter) || b.CashBoxKind == _kindFilter) &&
            (!_activeFilter.HasValue || b.IsActive == _activeFilter.Value)
        ).ToList();
        StateHasChanged();
    }

    private bool HasActiveFilters() =>
        !string.IsNullOrWhiteSpace(_searchText) ||
        !string.IsNullOrEmpty(_kindFilter) ||
        _activeFilter.HasValue;

    private void ResetFilters()
    {
        _searchText = "";
        _kindFilter = null;
        _activeFilter = null;
        ApplyFilter();
    }

    private void ConfirmDelete(CashBoxListDto box)
    {
        _selectedBox = box;
        _showDeleteDialog = true;
    }

    private async Task ExecuteDelete()
    {
        if (_selectedBox == null) return;
        _isDeleting = true;

        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userName = auth.User.Identity?.Name ?? "System";

        var (ok, msg) = await CashBoxService.DeleteCashBoxAsync(_selectedBox.CashBoxId, userName);
        _isDeleting = false;
        _showDeleteDialog = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadData();
    }
}
