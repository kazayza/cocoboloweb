@page "/cashbox/manage"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject ICashBoxService CashBoxService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ LOADING                                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <p>جاري تحميل الخزن...</p>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else
{
    <div class="cb-page" dir="rtl">

        <div class="page-bg-decorations">
            <div class="bg-orb bg-orb-1"></div>
            <div class="bg-orb bg-orb-2"></div>
        </div>

        <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ HEADER                                                           -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="cb-header">
            <div class="header-bg">
                <div class="header-gradient"></div>
                <div class="header-orbs">
                    <div class="header-orb orb-1"></div>
                    <div class="header-orb orb-2"></div>
                </div>
                <div class="header-grid"></div>
            </div>

            <div class="header-content">
                <div class="header-top">
                    <div class="header-info">
                        <div class="header-icon-wrapper">
                            <div class="header-icon-glow"></div>
                            <div class="header-icon">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" />
                            </div>
                            <div class="header-icon-badge">
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                            </div>
                        </div>
                        <div class="header-text">
                            <div class="header-title-row">
                                <h1>إدارة الخزن</h1>
                                <span class="premium-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                                    Premium
                                </span>
                            </div>
                            <p>
                                <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" Class="subtitle-icon" />
                                أضف، عدّل، وأدر خزن الشركة
                            </p>
                        </div>
                    </div>
                    <div class="header-actions">
                        @if (_canAdd)
                        {
                            <MudButton Variant="Variant.Filled"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="@(() => Navigation.NavigateTo("/cashbox/new"))"
                                       Class="btn-add-new" Size="Size.Large">
                                <span class="btn-shine"></span>
                                خزينة جديدة
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Dashboard"
                                   OnClick="@(() => Navigation.NavigateTo("/cashbox/dashboard"))"
                                   Class="btn-secondary">
                            لوحة الخزينة
                        </MudButton>
                    </div>
                </div>

                <!-- Summary Stats -->
                <div class="summary-row">
                    <div class="summary-card">
                        <div class="summary-icon s-all"><MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" /></div>
                        <div><span class="s-val">@_all.Count</span><span class="s-lbl">خزينة</span></div>
                    </div>
                    <div class="summary-card">
                        <div class="summary-icon s-active"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" /></div>
                        <div><span class="s-val">@_all.Count(b => b.IsActive)</span><span class="s-lbl">نشطة</span></div>
                    </div>
                    <div class="summary-card">
                        <div class="summary-icon s-balance"><MudIcon Icon="@Icons.Material.Filled.MonetizationOn" Size="Size.Small" /></div>
                        <div><span class="s-val">@_all.Where(b => b.IsActive).Sum(b => b.CurrentBalance).ToString("N0")</span><span class="s-lbl">ج.م إجمالي</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ FILTER BAR                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="filter-container animate-card" style="--delay:0.2s">
            <div class="filter-header" @onclick="() => _filterExpanded = !_filterExpanded">
                <div class="filter-header-right">
                    <div class="filter-icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
                    </div>
                    <span class="filter-title">بحث وتصفية</span>
                    @if (HasActiveFilters())
                    {
                        <span class="filter-active-badge"><span class="badge-pulse"></span>فلتر نشط</span>
                    }
                </div>
                <div class="filter-header-left">
                    @if (HasActiveFilters())
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="ResetFilters" Class="btn-reset-filter">مسح الكل</MudButton>
                    }
                    <div class="filter-expand-icon @(_filterExpanded ? "expanded" : "")">
                        <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" />
                    </div>
                </div>
            </div>

            @if (_filterExpanded)
            {
                <div class="filter-content">
                    <div class="filter-grid">
                        <div class="search-box-wrapper">
                            <div class="search-icon"><MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" /></div>
                            <input type="text" value="@_searchText"
                                   @oninput="OnSearchInput"
                                   placeholder="بحث باسم الخزينة..."
                                   class="search-input" />
                            @if (!string.IsNullOrWhiteSpace(_searchText))
                            {
                                <button class="search-clear" @onclick="ClearSearch">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            }
                        </div>

                        <MudSelect T="string" @bind-Value="_kindFilter" @bind-Value:after="ApplyFilter"
                                   Label="النوع" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" AnchorOrigin="Origin.BottomCenter" Class="filter-select">
                            @foreach (var kind in CashBoxKinds.All)
                            {
                                <MudSelectItem T="string" Value="@kind.Key">@kind.Value</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="bool?" @bind-Value="_activeFilter" @bind-Value:after="ApplyFilter"
                                   Label="الحالة" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" AnchorOrigin="Origin.BottomCenter" Class="filter-select">
                            <MudSelectItem T="bool?" Value="@((bool?)true)">نشطة</MudSelectItem>
                            <MudSelectItem T="bool?" Value="@((bool?)false)">معطّلة</MudSelectItem>
                        </MudSelect>
                    </div>
                </div>
            }
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ BOXES GRID                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        @if (_filtered.Any())
        {
            <div class="boxes-grid">
                @foreach (var box in _filtered)
                {
                    <div class="box-card @(box.IsActive ? "" : "card-inactive") animate-card" style="--delay:0.3s">
                        <div class="card-glow" style="background:radial-gradient(circle,@(box.Color)15,transparent 60%);"></div>

                        <!-- Strip -->
                        <div class="card-strip" style="background:linear-gradient(135deg, @box.Color, @(box.Color)bb);"></div>

                        <!-- Badges -->
                        <div class="card-top-badges">
                            <span class="kind-badge" style="background:@(box.Color)12; color:@box.Color; border:1px solid @(box.Color)30;">
                                @box.KindAr
                            </span>
                            <div class="card-top-right">
                                @if (box.IsDefault)
                                {
                                    <span class="default-badge">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                                        افتراضية
                                    </span>
                                }
                                <span class="status-chip @(box.IsActive ? "chip-active" : "chip-inactive")">
                                    <span class="chip-dot"></span>
                                    @(box.IsActive ? "نشطة" : "معطّلة")
                                </span>
                            </div>
                        </div>

                        <!-- Body -->
                        <div class="card-body">
                            <!-- Name & Icon -->
                            <div class="card-name-section">
                                <div class="card-avatar" style="background:linear-gradient(135deg,@box.Color,@(box.Color)cc);">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                                </div>
                                <div class="card-name-block">
                                    <h3>@box.CashBoxName</h3>
                                    @if (!string.IsNullOrEmpty(box.Description))
                                    {
                                        <p class="card-desc">@box.Description</p>
                                    }
                                </div>
                            </div>

                            <!-- Balance -->
                            <div class="card-balance" style="--box-color:@box.Color;">
                                <div class="bal-header">
                                    <span class="bal-label">الرصيد الحالي</span>
                                    <span class="bal-currency">ج.م</span>
                                </div>
                                <div class="bal-amount" style="color:@box.Color;">
                                    @box.CurrentBalance.ToString("N2")
                                </div>
                                <!-- Balance bar -->
                                @if (box.TotalIn + box.TotalOut > 0)
                                {
                                    var inPct = (double)box.TotalIn / (double)(box.TotalIn + box.TotalOut) * 100;
                                    <div class="bal-bar-wrap">
                                        <div class="bal-bar-in" style="width:@inPct.ToString("F0")%;"></div>
                                    </div>
                                    <div class="bal-bar-legend">
                                        <span class="legend-in">● دخل</span>
                                        <span class="legend-out">● صرف</span>
                                    </div>
                                }
                            </div>

                            <!-- Stats Grid -->
                            <div class="card-stats">
                                <div class="cs-item">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" Class="cs-icon" />
                                    <div>
                                        <span class="cs-label">افتتاحي</span>
                                        <strong>@box.OpeningBalance.ToString("N2")</strong>
                                    </div>
                                </div>
                                <div class="cs-item cs-in">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />
                                    <div>
                                        <span class="cs-label">إيداع</span>
                                        <strong>@box.TotalIn.ToString("N2")</strong>
                                    </div>
                                </div>
                                <div class="cs-item cs-out">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" />
                                    <div>
                                        <span class="cs-label">سحب</span>
                                        <strong>@box.TotalOut.ToString("N2")</strong>
                                    </div>
                                </div>
                                <div class="cs-item">
                                    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" Class="cs-icon" />
                                    <div>
                                        <span class="cs-label">حركات</span>
                                        <strong>@box.TransactionsCount</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="card-actions">
                            <button class="card-action-btn act-view" @onclick="@(() => Navigation.NavigateTo($"/cashbox/transactions?cashBoxId={box.CashBoxId}"))">
                                <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                                <span>الحركات</span>
                            </button>
                            @if (_canEdit)
                            {
                                <button class="card-action-btn act-edit" @onclick="@(() => Navigation.NavigateTo($"/cashbox/{box.CashBoxId}/edit"))">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                    <span>تعديل</span>
                                </button>
                            }
                            @if (_canDelete && !box.IsDefault)
                            {
                                <button class="card-action-btn act-delete" @onclick="@(() => ConfirmDelete(box))">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-illustration">
                    <div class="empty-icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" />
                    </div>
                    <div class="empty-particles">
                        <span class="particle particle-1"></span>
                        <span class="particle particle-2"></span>
                    </div>
                </div>
                <h3>لا توجد خزن</h3>
                <p>ابدأ بإضافة خزينة جديدة لتتبع الحركات المالية</p>
                @if (_canAdd)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@(() => Navigation.NavigateTo("/cashbox/new"))"
                               Class="empty-btn">خزينة جديدة</MudButton>
                }
            </div>
        }

        <div class="page-footer">
            <div class="footer-content">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="footer-icon" />
                <span>COCOBOLO ERP — إدارة الخزن</span>
                <span class="footer-premium">Premium</span>
            </div>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DELETE DIALOG                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showDeleteDialog" Class="premium-dialog">
    <TitleContent>
        <div class="dialog-header dialog-header-danger">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box"><MudIcon Icon="@Icons.Material.Filled.DeleteForever" /></div>
                <span class="dialog-title">حذف الخزينة</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showDeleteDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body dialog-body-centered">
            <div class="delete-icon-box"><MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" /></div>
            <h3 class="delete-title">هل أنت متأكد؟</h3>
            <p class="delete-message">سيتم حذف الخزينة '<strong>@(_selectedBox?.CashBoxName ?? "")</strong>' نهائياً</p>
            <span class="delete-note"><MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />هذا الإجراء لا يمكن التراجع عنه</span>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions dialog-actions-centered">
            <MudButton OnClick="@(() => _showDeleteDialog = false)" Variant="Variant.Text" Class="btn-cancel">إلغاء</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ExecuteDelete" Disabled="@_isDeleting"
                       StartIcon="@Icons.Material.Filled.Delete" Class="btn-danger">
                @if (_isDeleting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" /> }
                نعم، احذف
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐⭐⭐ STYLES ⭐⭐⭐                                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════════════ -->
<style>
    :root { --gold:#D4A853; --gold-dark:#B8912A; --gold-bg:#FEFBF3; --navy:#1B2A4A; --navy-dark:#0F1D36; --navy-light:#2D4A7A; }
    @@keyframes fadeInUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
    @@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-15px)}}
    @@keyframes pulseGlow{0%,100%{box-shadow:0 0 0 0 rgba(212,168,83,0.4)}50%{box-shadow:0 0 25px 8px rgba(212,168,83,0.15)}}
    @@keyframes shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
    @@keyframes ping{75%,100%{transform:scale(2);opacity:0}}
    @@keyframes bounceSoft{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
    @@keyframes loadingDots{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}
    .animate-card{animation:fadeInUp 0.6s ease-out forwards;animation-delay:var(--delay,0s);opacity:0}

    .loading-screen{display:flex;align-items:center;justify-content:center;min-height:70vh}.loading-content{text-align:center}.loading-content p{color:var(--mud-palette-text-secondary);margin-top:1rem}.loading-dots{display:flex;justify-content:center;gap:0.5rem;margin-top:.75rem}.loading-dots span{width:10px;height:10px;background:var(--gold);border-radius:50%;animation:loadingDots 1.4s infinite both}.loading-dots span:nth-child(1){animation-delay:-.32s}.loading-dots span:nth-child(2){animation-delay:-.16s}

    .cb-page{position:relative;max-width:1800px;margin:0 auto;padding:0 1rem}
    .page-bg-decorations{position:fixed;inset:0;pointer-events:none;z-index:0}.bg-orb{position:absolute;border-radius:50%;filter:blur(80px)}.bg-orb-1{width:400px;height:400px;top:-200px;right:-150px;background:radial-gradient(circle,rgba(212,168,83,0.12),transparent 70%);animation:float 10s ease-in-out infinite}.bg-orb-2{width:350px;height:350px;bottom:-150px;left:-100px;background:radial-gradient(circle,rgba(59,130,246,0.06),transparent 70%)}
    .top-accent-bar{height:5px;background:linear-gradient(90deg,var(--gold),var(--gold-dark),var(--gold));position:relative;overflow:hidden;margin-bottom:1.5rem;border-radius:0 0 10px 10px}.accent-shimmer{position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent);animation:shimmer 3s ease-in-out infinite}

    /* HEADER */
    .cb-header{position:relative;border-radius:24px;overflow:hidden;margin-bottom:1.5rem}
    .header-bg{position:absolute;inset:0}.header-gradient{position:absolute;inset:0;background:linear-gradient(135deg,var(--navy-dark),var(--navy),var(--navy-light))}.header-orbs{position:absolute;inset:0;overflow:hidden}.header-orb{position:absolute;border-radius:50%}.header-orb.orb-1{width:350px;height:350px;top:-150px;right:-100px;background:radial-gradient(circle,rgba(212,168,83,0.25),transparent 60%);animation:float 8s ease-in-out infinite}.header-orb.orb-2{width:250px;height:250px;bottom:-100px;left:20%;background:radial-gradient(circle,rgba(212,168,83,0.15),transparent 60%)}.header-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:40px 40px}
    .header-content{position:relative;z-index:2;padding:2rem 2.5rem}.header-top{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;margin-bottom:1.75rem}
    .header-info{display:flex;align-items:center;gap:1.25rem}.header-icon-wrapper{position:relative}.header-icon-glow{position:absolute;inset:-10px;background:var(--gold);border-radius:20px;filter:blur(20px);opacity:0.3;animation:pulseGlow 4s ease-in-out infinite}.header-icon{position:relative;width:64px;height:64px;background:rgba(255,255,255,0.1);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,0.2);border-radius:20px;display:flex;align-items:center;justify-content:center;color:var(--gold)}.header-icon::before{content:'';position:absolute;inset:0;border-radius:20px;background:linear-gradient(135deg,rgba(255,255,255,0.2),transparent 50%)}.header-icon-badge{position:absolute;top:-6px;right:-6px;width:24px;height:24px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;box-shadow:0 4px 12px rgba(212,168,83,0.4);animation:bounceSoft 2s ease-in-out infinite}.header-icon-badge .mud-icon-root{font-size:12px !important}
    .header-text h1{margin:0;font-size:1.8rem;font-weight:900;color:white}.header-title-row{display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap}.premium-badge{display:inline-flex;align-items:center;gap:0.35rem;background:rgba(255,255,255,0.1);border:1px solid rgba(212,168,83,0.3);color:var(--gold);font-size:0.7rem;font-weight:700;padding:0.3rem 0.6rem;border-radius:20px}.premium-badge .mud-icon-root{font-size:10px !important}.header-text p{margin:0.5rem 0 0;font-size:0.9rem;color:rgba(255,255,255,0.6);display:flex;align-items:center;gap:0.5rem}.subtitle-icon{color:#10b981 !important;font-size:16px !important}
    .header-actions{display:flex;gap:0.75rem;flex-wrap:wrap}
    .btn-add-new{position:relative;overflow:hidden;background:linear-gradient(135deg,var(--gold),var(--gold-dark)) !important;color:white !important;font-weight:700 !important;padding:0.875rem 1.75rem !important;border-radius:16px !important;box-shadow:0 8px 25px rgba(212,168,83,0.35) !important;transition:all 0.4s cubic-bezier(0.175,0.885,0.32,1.275) !important}.btn-add-new:hover{transform:translateY(-3px) scale(1.02)}.btn-shine{position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.25),transparent);transition:left 0.6s}.btn-add-new:hover .btn-shine{left:100%}.btn-secondary{background:rgba(255,255,255,0.1) !important;border-color:rgba(255,255,255,0.3) !important;color:white !important;font-weight:600 !important;border-radius:14px !important}

    /* Summary */
    .summary-row{display:flex;gap:0.875rem;flex-wrap:wrap}
    .summary-card{display:flex;align-items:center;gap:0.6rem;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);border-radius:12px;padding:0.75rem 1.25rem;flex:1;min-width:160px;transition:all 0.3s}.summary-card:hover{background:rgba(255,255,255,0.12);transform:translateY(-2px)}
    .summary-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;color:white;flex-shrink:0}.s-all{background:rgba(212,168,83,0.25)}.s-active{background:rgba(16,185,129,0.25)}.s-balance{background:rgba(59,130,246,0.25)}
    .s-val{font-size:1.3rem;font-weight:900;color:#F1F5F9;display:block;line-height:1}.s-lbl{font-size:0.68rem;color:rgba(241,245,249,0.6);font-weight:600}

    /* FILTER */
    .filter-container{background:var(--mud-palette-surface);border:1px solid var(--mud-palette-divider);border-radius:20px;margin-bottom:1.25rem;overflow:hidden}
    .filter-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;cursor:pointer;transition:background 0.2s}.filter-header:hover{background:var(--mud-palette-background-gray)}
