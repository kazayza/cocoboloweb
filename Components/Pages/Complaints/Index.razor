@page "/complaints/list"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject IComplaintService ComplaintService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider
@inject ILogger<Index> Logger

@attribute [Authorize]
@implements IDisposable

<PageTitle>الشكاوى</PageTitle>

<!-- ═════════════════════════════════════════════════════════════════ -->
<!-- ⭐ LOADING STATE                                                    -->
<!-- ═════════════════════════════════════════════════════════════════ -->
@if (_isInitialLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="Color.Secondary" Size="Size.Large" Indeterminate="true" />
            </div>
            <MudText Typo="Typo.h6" Class="loading-text">جاري تحميل الشكاوى...</MudText>
            <div class="loading-dots">
                <span></span><span></span><span></span>
            </div>
        </div>
    </div>
}
else
{
<div dir="rtl" class="cmp-page">

    <!-- ═════════════════════════════════════════════════════════════ -->
    <!-- ⭐ BACKGROUND DECORATIONS                                      -->
    <!-- ═════════════════════════════════════════════════════════════ -->
    <div class="page-bg-decorations">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>

    <!-- ⭐ TOP ACCENT BAR -->
    <div class="top-accent-bar">
        <div class="accent-shimmer"></div>
    </div>

    <!-- ═════════════════════════════════════════════════════════════ -->
    <!-- ⭐ PREMIUM HEADER                                              -->
    <!-- ═════════════════════════════════════════════════════════════ -->
    <div class="cmp-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-orbs">
                <div class="header-orb orb-1"></div>
                <div class="header-orb orb-2"></div>
                <div class="header-orb orb-3"></div>
            </div>
            <div class="header-grid"></div>
        </div>

        <div class="header-content">
            <div class="header-top">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon">
                            <MudIcon Icon="@Icons.Material.Filled.SupportAgent" Size="Size.Large" />
                        </div>
                        <div class="header-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.Verified" />
                        </div>
                    </div>
                    <div class="header-text">
                        <div class="header-title-row">
                            <MudText Typo="Typo.h4" Class="header-title">نظام الشكاوى</MudText>
                            <div class="header-badge">
                                <span>@_totalCount شكوى</span>
                            </div>
                        </div>
                        <MudText Typo="Typo.body2" Class="header-subtitle">
                            متابعة وحل شكاوى العملاء باحترافية
                        </MudText>
                    </div>
                </div>

                <div class="header-actions">
                    @if (_canCreate)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Class="btn-add-premium"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="GoToNew">
                            شكوى جديدة
                        </MudButton>
                    }
                    @if (_canExport)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Class="btn-export-premium"
                                   StartIcon="@Icons.Material.Filled.FileDownload"
                                   OnClick="ExportAsync"
                                   Disabled="_isExporting">
                            @if (_isExporting)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                <span>جاري التصدير...</span>
                            }
                            else
                            {
                                <span>Excel</span>
                            }
                        </MudButton>
                    }
                </div>
            </div>

            <!-- ═══ STATS CARDS ═══ -->
            <div class="stats-grid">
                <div class="stat-card stat-total animate-card" style="--delay: 0.05s"
                     @onclick="@(() => SetStatusFilter(null))">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.ListAlt" />
                        </div>
                        <div class="stat-data">
                            <div class="stat-label">إجمالي الشكاوى</div>
                            <div class="stat-value">@_totalCount</div>
                        </div>
                    </div>
                </div>

                <div class="stat-card stat-new animate-card" style="--delay: 0.1s"
                     @onclick="@(() => SetStatusFilter(ComplaintStatus.New))">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.FiberNew" />
                        </div>
                        <div class="stat-data">
                            <div class="stat-label">جديدة</div>
                            <div class="stat-value">@_newCount</div>
                        </div>
                    </div>
                </div>

                <div class="stat-card stat-progress animate-card" style="--delay: 0.15s"
                     @onclick="@(() => SetStatusFilter(ComplaintStatus.InProgress))">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.HourglassTop" />
                        </div>
                        <div class="stat-data">
                            <div class="stat-label">قيد الحل</div>
                            <div class="stat-value">@_inProgressCount</div>
                        </div>
                    </div>
                </div>

                <div class="stat-card stat-resolved animate-card" style="--delay: 0.2s"
                     @onclick="@(() => SetStatusFilter(ComplaintStatus.Resolved))">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.TaskAlt" />
                        </div>
                        <div class="stat-data">
                            <div class="stat-label">تم الحل</div>
                            <div class="stat-value">@_resolvedCount</div>
                        </div>
                    </div>
                </div>

                <div class="stat-card stat-escalated animate-card" style="--delay: 0.25s"
                     @onclick="@(() => SetStatusFilter(ComplaintStatus.Escalated))">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.PriorityHigh" />
                        </div>
                        <div class="stat-data">
                            <div class="stat-label">مصعدة</div>
                            <div class="stat-value">@_escalatedCount</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═════════════════════════════════════════════════════════════ -->
    <!-- ⭐ FILTERS PANEL                                               -->
    <!-- ═════════════════════════════════════════════════════════════ -->
    <div class="filters-panel">
        <div class="filters-header">
            <div class="filters-title-box">
                <MudIcon Icon="@Icons.Material.Filled.FilterAlt" />
                <span>الفلاتر والبحث</span>
            </div>
            @if (HasActiveFilters)
            {
                <MudButton Variant="Variant.Text"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="ClearFilters">
                    مسح الفلاتر
                </MudButton>
            }
        </div>
        <div class="filters-content">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField T="string"
                                  @bind-Value="_filter.SearchText"
                                  @bind-Value:after="OnFilterChangedAsync"
                                  Placeholder="بحث برقم/موضوع/عميل/تليفون..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="400"
                                  Immediate="true"
                                  Clearable="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="byte?"
                               @bind-Value="_filter.Status"
                               @bind-Value:after="OnFilterChangedAsync"
                               Label="الحالة"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem T="byte?" Value="@((byte?)1)">جديدة</MudSelectItem>
                        <MudSelectItem T="byte?" Value="@((byte?)2)">قيد الحل</MudSelectItem>
                        <MudSelectItem T="byte?" Value="@((byte?)3)">انتظار العميل</MudSelectItem>
                        <MudSelectItem T="byte?" Value="@((byte?)4)">تم الحل</MudSelectItem>
                        <MudSelectItem T="byte?" Value="@((byte?)5)">مرفوضة</MudSelectItem>
                        <MudSelectItem T="byte?" Value="@((byte?)6)">مصعدة</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="byte?"
                               @bind-Value="_filter.Priority"
                               @bind-Value:after="OnFilterChangedAsync"
                               Label="الأولوية"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem T="byte?" Value="@((byte?)1)">عالية جداً 🔥</MudSelectItem>
                        <MudSelectItem T="byte?" Value="@((byte?)2)">عالية 🔴</MudSelectItem>
                        <MudSelectItem T="byte?" Value="@((byte?)3)">متوسطة 🟡</MudSelectItem>
                        <MudSelectItem T="byte?" Value="@((byte?)4)">منخفضة 🟢</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="int?"
                               @bind-Value="_filter.TypeId"
                               @bind-Value:after="OnFilterChangedAsync"
                               Label="النوع"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        @foreach (var t in _types)
                        {
                            <MudSelectItem T="int?" Value="@((int?)t.TypeId)">
                                @(t.TypeNameAr ?? t.TypeName)
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" md="1">
                    <MudDatePicker @bind-Date="_filter.DateFrom"
                                   @bind-Date:after="OnFilterChangedAsync"
                                   Label="من"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true" />
                </MudItem>
                <MudItem xs="6" md="1">
                    <MudDatePicker @bind-Date="_filter.DateTo"
                                   @bind-Date:after="OnFilterChangedAsync"
                                   Label="إلى"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true" />
                </MudItem>
                <MudItem xs="12" md="1">
                    <MudSwitch T="bool"
                               @bind-Value="_filter.OpenOnly"
                               @bind-Value:after="OnFilterChangedAsync"
                               Color="Color.Warning"
                               Label="المفتوحة فقط"
                               Class="mt-1" />
                </MudItem>
            </MudGrid>
        </div>
    </div>

    <!-- ═════════════════════════════════════════════════════════════ -->
    <!-- ⭐ DATA TABLE                                                  -->
    <!-- ═════════════════════════════════════════════════════════════ -->
    <div class="data-card">
        <MudTable Items="_items"
                  T="ComplaintListItemDto"
                  Hover="true"
                  Striped="true"
                  Loading="_isLoading"
                  LoadingProgressColor="Color.Secondary"
                  Dense="true"
                  Class="premium-table"
                  Breakpoint="Breakpoint.Sm"
                  Elevation="0">
            <NoRecordsContent>
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff"
                             Size="Size.Large"
                             Class="empty-icon" />
                    <MudText Typo="Typo.h6">لا توجد شكاوى مطابقة</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        جرّب تعديل الفلاتر أو ابدأ بإضافة شكوى جديدة
                    </MudText>
                </div>
            </NoRecordsContent>
            <HeaderContent>
                <MudTh>الرقم</MudTh>
                <MudTh>التاريخ</MudTh>
                <MudTh>العميل</MudTh>
                <MudTh>النوع</MudTh>
                <MudTh>الموضوع</MudTh>
                <MudTh>الأولوية</MudTh>
                <MudTh>الحالة</MudTh>
                <MudTh>المُسند</MudTh>
                <MudTh Style="text-align:center">أيام</MudTh>
                <MudTh Style="text-align:center">📎</MudTh>
                <MudTh Style="text-align:center">📋</MudTh>
                <MudTh Style="text-align:center">إجراءات</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="الرقم">
                    <span class="cell-id">#@context.ComplaintId</span>
                </MudTd>
                <MudTd DataLabel="التاريخ">
                    <span class="cell-date">@(context.ComplaintDate?.ToString("yyyy/MM/dd") ?? "—")</span>
                </MudTd>
                <MudTd DataLabel="العميل">
                    <div class="cell-client">
                        <strong>@context.ClientName</strong>
                        @if (!string.IsNullOrWhiteSpace(context.ClientPhone))
                        {
                            <small>@context.ClientPhone</small>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="النوع">@context.ComplaintType</MudTd>
                <MudTd DataLabel="الموضوع" Style="max-width:250px;">
                    <span class="cell-subject" title="@context.Subject">@context.Subject</span>
                </MudTd>
                <MudTd DataLabel="الأولوية">
                    <span class="@GetPriorityClass(context.Priority)">@context.PriorityName</span>
                </MudTd>
                <MudTd DataLabel="الحالة">
                    <span class="@GetStatusClass(context.Status)">@context.StatusName</span>
                </MudTd>
                <MudTd DataLabel="المُسند">@(context.EmployeeName ?? "—")</MudTd>
                <MudTd DataLabel="أيام" Style="text-align:center">
                    @if (context.DaysOpen.HasValue)
                    {
                        <span class="@GetDaysClass(context.DaysOpen.Value, context.Status)">
                            @context.DaysOpen
                        </span>
                    }
                </MudTd>
                <MudTd DataLabel="مرفقات" Style="text-align:center">
                    @if (context.AttachmentsCount > 0)
                    {
                        <span class="count-badge">@context.AttachmentsCount</span>
                    }
                    else { <span class="count-zero">0</span> }
                </MudTd>
                <MudTd DataLabel="متابعات" Style="text-align:center">
                    @if (context.FollowUpsCount > 0)
                    {
                        <span class="count-badge count-badge-blue">@context.FollowUpsCount</span>
                    }
                    else { <span class="count-zero">0</span> }
                </MudTd>
                <MudTd DataLabel="إجراءات" Style="text-align:center">
                    <div class="actions-cell">
                        <MudTooltip Text="عرض التفاصيل">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Size="Size.Small"
                                           Color="Color.Info"
                                           OnClick="@(() => GoToDetail(context.ComplaintId))" />
                        </MudTooltip>
                        @if (_canEdit && !ComplaintStatus.IsClosed(context.Status))
                        {
                            <MudTooltip Text="تعديل">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Color="Color.Warning"
                                               OnClick="@(() => GoToEdit(context.ComplaintId))" />
                            </MudTooltip>
                        }
                        @if (_canDelete)
                        {
                            <MudTooltip Text="حذف">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteAsync(context))" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="@(new int[] { 10, 25, 50, 100 })"
                               RowsPerPageString="عدد الصفوف"
                               InfoFormat="{first_item}-{last_item} من {all_items}" />
            </PagerContent>
        </MudTable>
    </div>

</div>
}

<style>
    /* ═════════════════ LOADING SCREEN ═════════════════ */
    .loading-screen {
        position: fixed; inset: 0;
        background: linear-gradient(135deg, #0f1a2e 0%, #1a2842 100%);
        display: flex; align-items: center; justify-content: center;
        z-index: 9999;
    }
    .loading-content { text-align: center; }
    .loading-spinner-box {
        background: rgba(212,175,55,0.1);
        padding: 24px; border-radius: 50%;
        border: 2px solid rgba(212,175,55,0.3);
        margin-bottom: 16px;
        display: inline-block;
    }
    .loading-text { color: #d4af37 !important; margin-bottom: 8px; }
    .loading-dots {
        display: inline-flex; gap: 6px; justify-content: center;
    }
    .loading-dots span {
        width: 8px; height: 8px; border-radius: 50%;
        background: #d4af37; animation: bounce 1.4s infinite ease-in-out both;
    }
    .loading-dots span:nth-child(2) { animation-delay: 0.16s; }
    .loading-dots span:nth-child(3) { animation-delay: 0.32s; }
    @@keyframes bounce {
        0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
        40% { transform: scale(1); opacity: 1; }
    }

    /* ═════════════════ PAGE ═════════════════ */
    .cmp-page {
        position: relative;
        min-height: 100vh;
        padding: 12px;
        background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
    }

    /* ═════════════════ BG DECORATIONS ═════════════════ */
    .page-bg-decorations {
        position: absolute; inset: 0;
        pointer-events: none; overflow: hidden;
    }
    .bg-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.25;
    }
    .bg-orb-1 {
        width: 300px; height: 300px;
        background: radial-gradient(circle, #d4af37, transparent);
        top: -100px; right: -50px;
    }
    .bg-orb-2 {
        width: 400px; height: 400px;
        background: radial-gradient(circle, #3b82f6, transparent);
        top: 30%; left: -100px;
    }
    .bg-orb-3 {
        width: 250px; height: 250px;
        background: radial-gradient(circle, #10b981, transparent);
        bottom: 10%; right: 20%;
    }

    /* ═════════════════ TOP ACCENT BAR ═════════════════ */
    .top-accent-bar {
        position: relative;
        height: 4px;
        background: linear-gradient(90deg, #d4af37, #e8c855, #d4af37);
        border-radius: 2px;
        margin-bottom: 12px;
        overflow: hidden;
    }
    .accent-shimmer {
        position: absolute; inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
        animation: shimmer 3s infinite;
    }
    @@keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    /* ═════════════════ HEADER ═════════════════ */
    .cmp-header {
        position: relative;
        background: linear-gradient(135deg, #1a2842 0%, #2c3e5f 100%);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .header-bg { position: absolute; inset: 0; overflow: hidden; }
    .header-gradient {
        position: absolute; inset: 0;
        background: linear-gradient(135deg, rgba(212,175,55,0.05) 0%, transparent 50%);
    }
    .header-orbs { position: absolute; inset: 0; }
    .header-orb {
        position: absolute; border-radius: 50%;
        filter: blur(40px); opacity: 0.4;
    }
    .header-orb.orb-1 { width: 200px; height: 200px; background: #d4af37; top: -50px; right: 10%; }
    .header-orb.orb-2 { width: 150px; height: 150px; background: #3b82f6; bottom: -30px; left: 20%; }
    .header-orb.orb-3 { width: 100px; height: 100px; background: #10b981; top: 40%; right: 40%; }
    .header-grid {
        position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 30px 30px;
    }
    .header-content { position: relative; padding: 20px; z-index: 1; }
    .header-top {
        display: flex; justify-content: space-between;
        align-items: center; gap: 16px;
        margin-bottom: 20px; flex-wrap: wrap;
    }
    .header-info { display: flex; gap: 16px; align-items: center; }
    .header-icon-wrapper {
        position: relative;
        width: 64px; height: 64px;
    }
    .header-icon-glow {
        position: absolute; inset: -4px;
        background: radial-gradient(circle, rgba(212,175,55,0.5), transparent);
        border-radius: 50%; filter: blur(10px);
        animation: pulse 2s infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 0.5; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.1); }
    }
    .header-icon {
        position: relative;
        width: 100%; height: 100%;
        background: linear-gradient(135deg, #d4af37, #b8941f);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: white;
        box-shadow: 0 8px 24px rgba(212,175,55,0.4);
    }
    .header-icon-badge {
        position: absolute; bottom: -2px; left: -2px;
        background: #10b981; border-radius: 50%;
        width: 24px; height: 24px;
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 14px;
        box-shadow: 0 2px 8px rgba(16,185,129,0.5);
    }
    .header-title { color: white !important; font-weight: 700; margin: 0; }
    .header-title-row {
        display: flex; align-items: center; gap: 12px;
    }
    .header-badge {
        background: rgba(212,175,55,0.2);
        color: #d4af37;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        border: 1px solid rgba(212,175,55,0.4);
        font-weight: 600;
    }
    .header-subtitle { color: rgba(255,255,255,0.7) !important; margin-top: 4px; }
    .header-actions { display: flex; gap: 8px; }

    .btn-add-premium {
        background: linear-gradient(135deg, #d4af37, #b8941f) !important;
        color: white !important;
        padding: 10px 20px !important;
        border-radius: 10px !important;
        font-weight: 600 !important;
        box-shadow: 0 4px 12px rgba(212,175,55,0.4);
        transition: all 0.3s;
    }
    .btn-add-premium:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(212,175,55,0.6);
    }
    .btn-export-premium {
        color: white !important;
