</style>

@code {
    // ───── State ─────
    private bool _isInitialLoading = true;
    private bool _isLoading       = false;
    private bool _isExporting     = false;

    private ComplaintFilterDto _filter = new() { PageSize = 25 };
    private List<ComplaintListItemDto> _items = new();
    private List<ComplaintTypeDto>     _types = new();

    private int _totalCount, _newCount, _inProgressCount, _resolvedCount, _escalatedCount;

    // ───── Permissions ─────
    private bool _canCreate, _canEdit, _canDelete, _canExport;
    private string _currentUserName = "system";

    private CancellationTokenSource? _cts;
    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_filter.SearchText)
        || _filter.Status.HasValue
        || _filter.Priority.HasValue
        || _filter.TypeId.HasValue
        || _filter.DateFrom.HasValue
        || _filter.DateTo.HasValue
        || _filter.OpenOnly;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();
        _types = await ComplaintService.GetTypesAsync();
        await LoadDataAsync();
        _isInitialLoading = false;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }

    private async Task LoadPermissionsAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserName = user.Identity?.Name ?? "system";
        _canCreate = ComplaintPermissions.CanCreate(user);
        _canEdit   = ComplaintPermissions.CanEdit(user);
        _canDelete = ComplaintPermissions.CanDelete(user);
        _canExport = ComplaintPermissions.CanExport(user);
    }

    // ───── Data Loading ─────
    private async Task LoadDataAsync()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        _isLoading = true;

        try
        {
            var result = await ComplaintService.GetComplaintsAsync(_filter, _currentUserName);
            _items = result.Items;
            _totalCount = result.TotalCount;

            // إحصائيات بسيطة من الصفحة الحالية (لاحقاً نضيف dashboard endpoint)
            var allItems = result.Items;
            _newCount        = allItems.Count(i => i.Status == ComplaintStatus.New);
            _inProgressCount = allItems.Count(i => i.Status == ComplaintStatus.InProgress);
            _resolvedCount   = allItems.Count(i => i.Status == ComplaintStatus.Resolved);
            _escalatedCount  = allItems.Count(i => i.Status == ComplaintStatus.Escalated);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load complaints failed");
            Snackbar.Add("تعذّر تحميل الشكاوى: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnFilterChangedAsync()
    {
        _filter.Page = 1;
        await LoadDataAsync();
    }

    private async Task ClearFilters()
    {
        _filter = new ComplaintFilterDto { PageSize = _filter.PageSize };
        await LoadDataAsync();
    }

    private async Task SetStatusFilter(byte? status)
    {
        _filter.Status = _filter.Status == status ? null : status;
        await OnFilterChangedAsync();
    }

    // ───── Navigation ─────
    private void GoToNew()       => Navigation.NavigateTo("/complaints/form");
    private void GoToEdit(int id) => Navigation.NavigateTo($"/complaints/form/{id}");
    private void GoToDetail(int id) => Navigation.NavigateTo($"/complaints/{id}");

    // ───── Delete ─────
    private async Task DeleteAsync(ComplaintListItemDto item)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Title,      "تأكيد الحذف" },
            { x => x.Message,    $"هل تريد حذف الشكوى رقم #{item.ComplaintId} للعميل {item.ClientName}؟" },
            { x => x.YesText,    "نعم، احذف" },
            { x => x.CancelText, "إلغاء" }
        };

        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأكيد الحذف", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var (ok, msg) = await ComplaintService.DeleteAsync(item.ComplaintId);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadDataAsync();
    }

    // ───── Export ─────
    private async Task ExportAsync()
    {
        _isExporting = true;
        try
        {
            var bytes = await ComplaintService.ExportToExcelAsync(_filter);
            var fileName = $"complaints_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await JS.InvokeVoidAsync("downloadFile", fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
            Snackbar.Add("تم تصدير الملف بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Export failed");
            Snackbar.Add("فشل التصدير: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isExporting = false;
        }
    }

    // ───── UI Helpers ─────
    private string GetPriorityClass(byte? p) =>
        $"badge-priority priority-{p ?? 0}";

    private string GetStatusClass(byte? s) =>
        $"badge-status status-{s ?? 0}";

    private string GetDaysClass(int days, byte? status)
    {
        if (ComplaintStatus.IsClosed(status)) return "days-normal";
        return days switch
        {
            <= 1  => "days-normal",
            <= 3  => "days-warning",
            _     => "days-critical"
        };
    }
}
