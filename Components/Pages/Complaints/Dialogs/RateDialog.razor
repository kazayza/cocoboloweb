@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject IComplaintService ComplaintService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.StarRate" Color="Color.Warning" />
            <MudText Typo="Typo.h6">تقييم العميل</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-3 text-center">كم تقيّم خدمتنا في حل الشكوى؟</MudText>
        <div style="text-align:center; padding: 16px 0;">
            <MudRating @bind-SelectedValue="_rating"
                       MaxValue="5"
                       Size="Size.Large"
                       Color="Color.Warning" />
            <MudText Typo="Typo.caption" Class="mt-2 d-block">
                @(_rating > 0 ? $"{_rating} من 5" : "اختر التقييم")
            </MudText>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                   OnClick="Save" Disabled="_saving || _rating == 0">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" /> }
            else { <span>حفظ التقييم</span> }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter, EditorRequired] public int ComplaintId { get; set; }

    private int _rating = 0;
    private bool _saving;

    private async Task Save()
    {
        if (_rating is < 1 or > 5)
        {
            Snackbar.Add("اختر التقييم من 1 إلى 5", Severity.Warning);
            return;
        }
        _saving = true;
        var (ok, msg) = await ComplaintService.RateAsync(new RateComplaintDto
        {
            ComplaintId       = ComplaintId,
            SatisfactionLevel = (byte)_rating
        });
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        _saving = false;
        if (ok) MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
