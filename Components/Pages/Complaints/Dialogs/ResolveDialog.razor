@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject IComplaintService ComplaintService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.TaskAlt" Color="Color.Success" />
            <MudText Typo="Typo.h6">حل الشكوى</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
            اكتب الحل المُقدّم للعميل. ده هيتسجل كحل نهائي.
        </MudAlert>
        <MudTextField T="string"
                      @bind-Value="_solution"
                      Label="الحل النهائي"
                      Variant="Variant.Outlined"
                      Lines="5"
                      Required="true"
                      RequiredError="الحل مطلوب"
                      Counter="2000"
                      MaxLength="2000" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   OnClick="Save" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" /> }
            else { <span>حفظ الحل</span> }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter, EditorRequired] public int ComplaintId { get; set; }

    private string _solution = "";
    private bool _saving;

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_solution))
        {
            Snackbar.Add("الحل مطلوب", Severity.Warning);
            return;
        }

        _saving = true;
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User.Identity?.Name ?? "system";

        var (ok, msg) = await ComplaintService.ChangeStatusAsync(new ChangeStatusDto
        {
            ComplaintId = ComplaintId,
            NewStatus   = ComplaintStatus.Resolved,
            Solution    = _solution
        }, user);

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        _saving = false;
        if (ok) MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
