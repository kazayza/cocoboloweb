@page "/complaints/{Id:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using COCOBOLOERPNEW.Components.Pages.Complaints.Dialogs

@inject IComplaintService ComplaintService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider
@inject IDbContextFactory<COCOBOLOERPNEW.Models.db24804Context> DbFactory
@inject ILogger<Detail> Logger

@using Microsoft.EntityFrameworkCore

@attribute [Authorize]

<PageTitle>شكوى #@Id</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="Color.Secondary" Size="Size.Large" Indeterminate="true" />
            </div>
            <MudText Typo="Typo.h6" Class="loading-text">جاري تحميل التفاصيل...</MudText>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else if (_detail is null)
{
    <div class="error-state">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" />
        <MudText Typo="Typo.h5">الشكوى غير موجودة</MudText>
        <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("/complaints/list"))">
            رجوع للقائمة
        </MudButton>
    </div>
}
else
{
<div dir="rtl" class="cmp-detail-page">

    <!-- BG -->
    <div class="page-bg-decorations">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
    </div>

    <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

    <!-- ═══ HEADER ═══ -->
    <div class="detail-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-orbs">
                <div class="header-orb orb-1"></div>
                <div class="header-orb orb-2"></div>
            </div>
            <div class="header-grid"></div>
        </div>

        <div class="header-content">
            <div class="header-top">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon">
                            <MudIcon Icon="@Icons.Material.Filled.SupportAgent" Size="Size.Large" />
                        </div>
                    </div>
                    <div class="header-text">
                        <div class="header-title-row">
                            <MudText Typo="Typo.h5" Class="header-title">شكوى #@_detail.ComplaintId</MudText>
                            <span class="@GetStatusClass(_detail.Status)">@_detail.StatusName</span>
                            <span class="@GetPriorityClass(_detail.Priority)">@_detail.PriorityName</span>
                            @if (_detail.Escalated == true)
                            {
                                <span class="badge-escalated">⚠️ مصعدة</span>
                            }
                        </div>
                        <MudText Typo="Typo.body2" Class="header-subtitle">
                            @_detail.Subject
                        </MudText>
                        <div class="header-meta">
                            <span><MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" /> @(_detail.ComplaintDate?.ToString("yyyy/MM/dd HH:mm") ?? "—")</span>
                            <span><MudIcon Icon="@Icons.Material.Filled.Timelapse" Size="Size.Small" /> @_detail.DaysOpen يوم</span>
                            @if (!string.IsNullOrWhiteSpace(_detail.CreatedBy))
                            {
                                <span><MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" /> @_detail.CreatedBy</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="header-actions">
                    <MudButton Variant="Variant.Outlined" Class="btn-back"
                               StartIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="@(() => Navigation.NavigateTo("/complaints/list"))">
                        رجوع
                    </MudButton>
                    @if (_canEdit && !_detail.IsClosed)
                    {
                        <MudButton Variant="Variant.Filled" Class="btn-edit"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="@(() => Navigation.NavigateTo($"/complaints/form/{_detail.ComplaintId}"))">
                            تعديل
                        </MudButton>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ ACTION BAR ═══ -->
    @if (HasAnyAction)
    {
        <div class="action-bar">
            <div class="action-bar-title">
                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" />
                <span>الإجراءات السريعة</span>
            </div>
            <div class="action-bar-buttons">
                @if (_canChangeStatus && !_detail.IsClosed)
                {
                    <MudButton Variant="Variant.Filled" Class="btn-action btn-action-success"
                               StartIcon="@Icons.Material.Filled.TaskAlt"
                               OnClick="OpenResolveDialog">
                        تم الحل
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Class="btn-action btn-action-info"
                               StartIcon="@Icons.Material.Filled.HourglassTop"
                               OnClick="@(() => ChangeStatusAsync(ComplaintStatus.InProgress))">
                        قيد الحل
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Class="btn-action btn-action-purple"
                               StartIcon="@Icons.Material.Filled.HourglassEmpty"
                               OnClick="@(() => ChangeStatusAsync(ComplaintStatus.AwaitingClient))">
                        انتظار العميل
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Class="btn-action btn-action-danger"
                               StartIcon="@Icons.Material.Filled.Cancel"
                               OnClick="@(() => ChangeStatusAsync(ComplaintStatus.Rejected))">
                        رفض
                    </MudButton>
                }
                @if (_canAssign && !_detail.IsClosed)
                {
                    <MudButton Variant="Variant.Outlined" Class="btn-action-outlined"
                               StartIcon="@Icons.Material.Filled.PersonPin"
                               OnClick="OpenAssignDialog">
                        إسناد/تغيير المسؤول
                    </MudButton>
                }
                @if (_canEscalate && !_detail.IsClosed && _detail.Escalated != true)
                {
                    <MudButton Variant="Variant.Outlined" Class="btn-action-outlined btn-escalate"
                               StartIcon="@Icons.Material.Filled.PriorityHigh"
                               OnClick="OpenEscalateDialog">
                        تصعيد
                    </MudButton>
                }
                @if (_detail.IsClosed && _detail.SatisfactionLevel is null)
                {
                    <MudButton Variant="Variant.Outlined" Class="btn-action-outlined"
                               StartIcon="@Icons.Material.Filled.StarRate"
                               OnClick="OpenRateDialog">
                        إضافة تقييم العميل
                    </MudButton>
                }
            </div>
        </div>
    }

    <MudGrid Spacing="2">
        <!-- ═══ COLUMN: التفاصيل ═══ -->
        <MudItem xs="12" lg="8">

            <!-- 📋 Details Card -->
            <div class="info-card animate-card" style="--delay: 0.05s">
                <div class="info-card-header">
                    <div class="card-icon card-icon-gold">
                        <MudIcon Icon="@Icons.Material.Filled.Description" />
                    </div>
                    <span>تفاصيل الشكوى</span>
                </div>
                <div class="info-card-body">
                    <div class="detail-row">
                        <span class="detail-label">النوع:</span>
                        <span class="detail-value">@(_detail.TypeName ?? "—")</span>
                    </div>
                    <div class="detail-block">
                        <div class="detail-label">الموضوع:</div>
                        <div class="detail-value-block">@_detail.Subject</div>
                    </div>
                    <div class="detail-block">
                        <div class="detail-label">التفاصيل:</div>
                        <div class="detail-value-block details-text">@_detail.Details</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_detail.Solution))
                    {
                        <div class="detail-block solution-block">
                            <div class="detail-label">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                الحل النهائي:
                            </div>
                            <div class="detail-value-block">@_detail.Solution</div>
                            @if (_detail.SolvedDate.HasValue)
                            {
                                <div class="solution-meta">
                                    تم الحل: @_detail.SolvedDate.Value.ToString("yyyy/MM/dd HH:mm")
                                </div>
                            }
                        </div>
                    }
                    @if (_detail.Escalated == true && !string.IsNullOrWhiteSpace(_detail.EscalationReason))
                    {
                        <div class="detail-block escalation-block">
                            <div class="detail-label">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                                سبب التصعيد:
                            </div>
                            <div class="detail-value-block">@_detail.EscalationReason</div>
                            <div class="solution-meta">
                                مُصعدة إلى: <strong>@_detail.EscalatedTo</strong>
                                @if (_detail.EscalatedDate.HasValue)
                                {
                                    <span> — @_detail.EscalatedDate.Value.ToString("yyyy/MM/dd HH:mm")</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- 📎 Attachments -->
            <div class="info-card animate-card" style="--delay: 0.1s">
                <div class="info-card-header">
                    <div class="card-icon card-icon-blue">
                        <MudIcon Icon="@Icons.Material.Filled.AttachFile" />
                    </div>
                    <span>المرفقات (@_detail.Attachments.Count)</span>
                    <div class="header-spacer"></div>
                    <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.xlsx,.xls"
                                   FilesChanged="OnFileUploadedAsync"
                                   Disabled="_isUploading">
                        <ActivatorContent>
                            <MudButton HtmlTag="label"
                                       Variant="Variant.Filled"
                                       Size="Size.Small"
                                       Class="btn-upload"
                                       StartIcon="@Icons.Material.Filled.Upload"
                                       Disabled="_isUploading">
                                @if (_isUploading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                                    <span>رفع...</span>
                                }
                                else { <span>رفع ملف</span> }
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </div>
                <div class="info-card-body">
                    @if (_detail.Attachments.Count == 0)
                    {
                        <div class="empty-mini">
                            <MudIcon Icon="@Icons.Material.Filled.NoteAdd" Size="Size.Large" />
                            <span>لا توجد مرفقات</span>
                        </div>
                    }
                    else
                    {
                        <div class="attachments-grid">
                            @foreach (var att in _detail.Attachments)
                            {
                                <div class="attachment-card">
                                    @if (att.IsImage)
                                    {
                                        <a href="@att.FilePath" target="_blank" class="att-image-link">
                                            <img src="@att.FilePath" alt="@att.OriginalFileName" />
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="att-icon-box">
                                            <MudIcon Icon="@GetFileIcon(att.MimeType)" Size="Size.Large" />
                                        </div>
                                    }
                                    <div class="att-info">
                                        <div class="att-name" title="@att.OriginalFileName">@att.OriginalFileName</div>
                                        <div class="att-meta">@att.FileSizeFormatted</div>
                                        <div class="att-actions">
                                            <a href="@att.FilePath" target="_blank" class="att-btn att-btn-view">
                                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                                            </a>
                                            @if (_canEdit)
                                            {
                                                <button class="att-btn att-btn-delete"
                                                        @onclick="() => DeleteAttachmentAsync(att.AttachmentId)">
                                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- 📋 FollowUps -->
            <div class="info-card animate-card" style="--delay: 0.15s">
                <div class="info-card-header">
                    <div class="card-icon card-icon-purple">
                        <MudIcon Icon="@Icons.Material.Filled.History" />
                    </div>
                    <span>المتابعات (@_detail.FollowUps.Count)</span>
                </div>
                <div class="info-card-body">

                    @if (_canAddFollowUp && !_detail.IsClosed)
                    {
                        <!-- Add FollowUp Form -->
                        <div class="followup-form">
                            <MudGrid Spacing="2">
                                <MudItem xs="12">
                                    <MudTextField T="string"
                                                  @bind-Value="_newFollowUp.Notes"
                                                  Placeholder="اكتب ملاحظة المتابعة..."
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Lines="2" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField T="string"
                                                  @bind-Value="_newFollowUp.ActionTaken"
                                                  Placeholder="الإجراء المتخذ (اختياري)"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.PlayArrow" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudDatePicker @bind-Date="_newFollowUp.NextFollowUpDate"
                                                   Label="موعد المتابعة القادم"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Clearable="true" />
                                </MudItem>
                                <MudItem xs="12" md="2">
                                    <MudButton Variant="Variant.Filled"
                                               Class="btn-add-followup"
                                               StartIcon="@Icons.Material.Filled.Send"
                                               OnClick="AddFollowUpAsync"
                                               Disabled="_isAddingFollowUp"
                                               FullWidth="true">
                                        @if (_isAddingFollowUp)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                        }
                                        else { <span>إضافة</span> }
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                        </div>
                    }

                    @if (_detail.FollowUps.Count == 0)
                    {
                        <div class="empty-mini">
                            <MudIcon Icon="@Icons.Material.Filled.Forum" Size="Size.Large" />
                            <span>لا توجد متابعات بعد</span>
                        </div>
                    }
                    else
                    {
                        <div class="followups-timeline">
                            @foreach (var f in _detail.FollowUps)
                            {
                                <div class="followup-item">
                                    <div class="followup-dot"></div>
                                    <div class="followup-body">
                                        <div class="followup-header">
                                            <span class="followup-author">
                                                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" />
                                                @(f.FollowUpByName ?? $"موظف #{f.FollowUpBy}")
                                            </span>
                                            <span class="followup-date">@(f.FollowUpDate?.ToString("yyyy/MM/dd HH:mm") ?? "—")</span>
                                        </div>
                                        <div class="followup-notes">@f.Notes</div>
                                        @if (!string.IsNullOrWhiteSpace(f.ActionTaken))
                                        {
                                            <div class="followup-action">
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                                <span><strong>الإجراء:</strong> @f.ActionTaken</span>
                                            </div>
                                        }
                                        @if (f.NextFollowUpDate.HasValue)
                                        {
                                            <div class="followup-next">
                                                <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Color="Color.Warning" />
                                                <span><strong>متابعة قادمة:</strong> @f.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </MudItem>

        <!-- ═══ COLUMN: الجانب الأيمن ═══ -->
        <MudItem xs="12" lg="4">

            <!-- 👤 Client -->
            <div class="info-card animate-card" style="--delay: 0.08s">
                <div class="info-card-header">
                    <div class="card-icon card-icon-blue">
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                    </div>
                    <span>العميل</span>
                </div>
                <div class="info-card-body">
                    <div class="client-name">@_detail.ClientName</div>
                    @if (!string.IsNullOrWhiteSpace(_detail.ClientPhone))
                    {
                        <div class="client-row">
                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                            <a href="tel:@_detail.ClientPhone">@_detail.ClientPhone</a>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_detail.ClientEmail))
                    {
                        <div class="client-row">
                            <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" />
                            <a href="mailto:@_detail.ClientEmail">@_detail.ClientEmail</a>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_detail.ClientAddress))
                    {
                        <div class="client-row">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                            <span>@_detail.ClientAddress</span>
                        </div>
                    }
                </div>
            </div>

            <!-- 👨‍💼 Assigned -->
            <div class="info-card animate-card" style="--delay: 0.12s">
                <div class="info-card-header">
                    <div class="card-icon card-icon-purple">
                        <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" />
                    </div>
                    <span>المسؤول</span>
                </div>
                <div class="info-card-body">
                    @if (!string.IsNullOrWhiteSpace(_detail.AssignedToName))
                    {
                        <div class="assigned-box">
                            <div class="assigned-avatar">
                                @_detail.AssignedToName.Substring(0, 1)
                            </div>
                            <div class="assigned-info">
                                <div class="assigned-name">@_detail.AssignedToName</div>
                                <div class="assigned-label">المُسند إليه</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-mini">
                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Large" />
                            <span>لم يتم الإسناد</span>
                        </div>
                    }
                </div>
            </div>

            <!-- 🔗 Related -->
            @if (_detail.TransactionId.HasValue || _detail.ProductId.HasValue)
            {
                <div class="info-card animate-card" style="--delay: 0.16s">
                    <div class="info-card-header">
                        <div class="card-icon card-icon-gold">
                            <MudIcon Icon="@Icons.Material.Filled.Link" />
                        </div>
                        <span>الربط</span>
                    </div>
                    <div class="info-card-body">
                        @if (_detail.TransactionId.HasValue)
                        {
                            <div class="link-item">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" />
                                <div>
                                    <div class="link-label">الفاتورة المرتبطة</div>
                                    <a href="/sales/invoices/@_detail.TransactionId" class="link-value">
                                        @(_detail.TransactionRef ?? $"#{_detail.TransactionId}")
                                    </a>
                                    @if (_detail.TransactionDate.HasValue)
                                    {
                                        <small> — @_detail.TransactionDate.Value.ToString("yyyy/MM/dd")</small>
                                    }
                                </div>
                            </div>
                        }
                        @if (_detail.ProductId.HasValue)
                        {
                            <div class="link-item">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                                <div>
                                    <div class="link-label">المنتج</div>
                                    <div class="link-value">@(_detail.ProductName ?? $"#{_detail.ProductId}")</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- ⭐ Rating -->
            @if (_detail.SatisfactionLevel.HasValue)
            {
                <div class="info-card animate-card" style="--delay: 0.2s">
                    <div class="info-card-header">
                        <div class="card-icon card-icon-gold">
                            <MudIcon Icon="@Icons.Material.Filled.Star" />
                        </div>
                        <span>تقييم العميل</span>
                    </div>
                    <div class="info-card-body" style="text-align:center;">
                        <div class="rating-stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <MudIcon Icon="@(i <= _detail.SatisfactionLevel.Value ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)"
                                         Color="@(i <= _detail.SatisfactionLevel.Value ? Color.Warning : Color.Default)" />
                            }
                        </div>
                        <div class="rating-number">@_detail.SatisfactionLevel / 5</div>
                    </div>
                </div>
            }
        </MudItem>
    </MudGrid>
</div>
}

<style>
    /* Common styles (Loading + Header) — مشتركة من الشاشات السابقة */
    .loading-screen { position: fixed; inset: 0; background: linear-gradient(135deg, #0f1a2e 0%, #1a2842 100%); display: flex; align-items: center; justify-content: center; z-index: 9999; }
    .loading-content { text-align: center; }
    .loading-spinner-box { background: rgba(212,175,55,0.1); padding: 24px; border-radius: 50%; border: 2px solid rgba(212,175,55,0.3); margin-bottom: 16px; display: inline-block; }
    .loading-text { color: #d4af37 !important; margin-bottom: 8px; }
    .loading-dots { display: inline-flex; gap: 6px; justify-content: center; }
    .loading-dots span { width: 8px; height: 8px; border-radius: 50%; background: #d4af37; animation: bounce 1.4s infinite ease-in-out both; }
    .loading-dots span:nth-child(2) { animation-delay: 0.16s; }
    .loading-dots span:nth-child(3) { animation-delay: 0.32s; }
    @@keyframes bounce { 0%,80%,100% { transform: scale(0); opacity: 0.5; } 40% { transform: scale(1); opacity: 1; } }

    .error-state {
        min-height: 60vh;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 12px; color: #ef4444;
    }

    .cmp-detail-page { position: relative; min-height: 100vh; padding: 12px; background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%); }
    .page-bg-decorations { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
    .bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.2; }
    .bg-orb-1 { width: 300px; height: 300px; background: radial-gradient(circle, #d4af37, transparent); top: -100px; right: -50px; }
    .bg-orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, #3b82f6, transparent); bottom: 10%; left: -100px; }
    .top-accent-bar { position: relative; height: 4px; background: linear-gradient(90deg, #d4af37, #e8c855, #d4af37); border-radius: 2px; margin-bottom: 12px; overflow: hidden; }
    .accent-shimmer { position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent); animation: shimmer 3s infinite; }
    @@keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

    /* ═════════════════ HEADER ═════════════════ */
    .detail-header { position: relative; background: linear-gradient(135deg, #1a2842 0%, #2c3e5f 100%); border-radius: 16px; overflow: hidden; margin-bottom: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
    .header-bg { position: absolute; inset: 0; overflow: hidden; }
    .header-gradient { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(212,175,55,0.05) 0%, transparent 50%); }
    .header-orbs { position: absolute; inset: 0; }
    .header-orb { position: absolute; border-radius: 50%; filter: blur(40px); opacity: 0.4; }
