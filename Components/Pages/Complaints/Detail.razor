@code {
    [Parameter] public int Id { get; set; }

    private bool _isLoading = true;
    private bool _isUploading = false;
    private bool _isAddingFollowUp = false;

    private ComplaintDetailDto? _detail;

    private FollowUpFormDto _newFollowUp = new();

    private bool _canEdit, _canChangeStatus, _canAssign, _canEscalate, _canAddFollowUp;
    private string _currentUserName = "system";
    private int    _currentUserId   = 0;
    private int    _currentEmployeeId = 0;

    private bool HasAnyAction =>
        (_canChangeStatus && !_detail!.IsClosed)
        || (_canAssign && !_detail!.IsClosed)
        || (_canEscalate && !_detail!.IsClosed && _detail.Escalated != true)
        || (_detail!.IsClosed && _detail.SatisfactionLevel is null);

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();
        await LoadDetailAsync();
        _isLoading = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        // إعادة تحميل عند تغيير الـ Id من نفس الصفحة
        if (!_isLoading && _detail != null && _detail.ComplaintId != Id)
        {
            _isLoading = true;
            await LoadDetailAsync();
            _isLoading = false;
        }
    }

    private async Task LoadPermissionsAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserName  = user.Identity?.Name ?? "system";
        _canEdit          = ComplaintPermissions.CanEdit(user);
        _canChangeStatus  = ComplaintPermissions.CanChangeStatus(user);
        _canAssign        = ComplaintPermissions.CanAssign(user);
        _canEscalate      = ComplaintPermissions.CanEscalate(user);
        _canAddFollowUp   = ComplaintPermissions.CanAddFollowUp(user);

        // تحديد UserId + EmployeeId من Claims
        var uidClaim = user.FindFirst("UserId")?.Value;
        if (int.TryParse(uidClaim, out var uid)) _currentUserId = uid;

        // جلب EmployeeId المرتبط بالـ User (لو موجود)
        if (_currentUserId > 0)
        {
            try
            {
                using var db = await DbFactory.CreateDbContextAsync();
                var u = await db.Users.AsNoTracking()
                    .Where(x => x.UserId == _currentUserId)
                    .Select(x => new { x.UserId, x.FullName })
                    .FirstOrDefaultAsync();

                // محاولة ربط الـ User بالـ Employee بالاسم
                if (u != null)
                {
                    var emp = await db.Employees.AsNoTracking()
                        .Where(e => e.FullName == u.FullName)
                        .Select(e => new { e.EmployeeId })
                        .FirstOrDefaultAsync();
                    if (emp != null) _currentEmployeeId = emp.EmployeeId;
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to map user to employee");
            }
        }
    }

    private async Task LoadDetailAsync()
    {
        try
        {
            _detail = await ComplaintService.GetByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load complaint {Id} failed", Id);
            Snackbar.Add("تعذّر تحميل التفاصيل: " + ex.Message, Severity.Error);
        }
    }

    // ═══════════════ STATUS CHANGE ═══════════════

    private async Task ChangeStatusAsync(byte newStatus)
    {
        if (_detail is null) return;

        var dto = new ChangeStatusDto
        {
            ComplaintId = _detail.ComplaintId,
            NewStatus   = newStatus
        };

        var (ok, msg) = await ComplaintService.ChangeStatusAsync(dto, _currentUserName);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadDetailAsync();
    }

    private async Task OpenResolveDialog()
    {
        if (_detail is null) return;

        var parameters = new DialogParameters<ResolveDialog>
        {
            { x => x.ComplaintId, _detail.ComplaintId }
        };
        var dialog = await DialogService.ShowAsync<ResolveDialog>("حل الشكوى",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is true)
            await LoadDetailAsync();
    }

    // ═══════════════ ASSIGN ═══════════════

    private async Task OpenAssignDialog()
    {
        if (_detail is null) return;

        var parameters = new DialogParameters<AssignDialog>
        {
            { x => x.ComplaintId,       _detail.ComplaintId },
            { x => x.CurrentAssignedTo, _detail.AssignedTo }
        };
        var dialog = await DialogService.ShowAsync<AssignDialog>("إسناد الشكوى",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is true)
            await LoadDetailAsync();
    }

    // ═══════════════ ESCALATE ═══════════════

    private async Task OpenEscalateDialog()
    {
        if (_detail is null) return;

        var parameters = new DialogParameters<EscalateDialog>
        {
            { x => x.ComplaintId, _detail.ComplaintId }
        };
        var dialog = await DialogService.ShowAsync<EscalateDialog>("تصعيد الشكوى",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is true)
            await LoadDetailAsync();
    }

    // ═══════════════ RATE ═══════════════

    private async Task OpenRateDialog()
    {
        if (_detail is null) return;

        var parameters = new DialogParameters<RateDialog>
        {
            { x => x.ComplaintId, _detail.ComplaintId }
        };
        var dialog = await DialogService.ShowAsync<RateDialog>("تقييم العميل",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is true)
            await LoadDetailAsync();
    }

    // ═══════════════ FOLLOW-UPS ═══════════════

    private async Task AddFollowUpAsync()
    {
        if (_detail is null) return;
        if (string.IsNullOrWhiteSpace(_newFollowUp.Notes))
        {
            Snackbar.Add("الملاحظات مطلوبة", Severity.Warning);
            return;
        }
        if (_currentEmployeeId <= 0)
        {
            Snackbar.Add("لا يوجد سجل موظف مرتبط بحسابك", Severity.Warning);
            return;
        }

        _isAddingFollowUp = true;
        try
        {
            _newFollowUp.ComplaintId = _detail.ComplaintId;
            var (ok, msg, _) = await ComplaintService.AddFollowUpAsync(_newFollowUp, _currentEmployeeId);
            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
            if (ok)
            {
                _newFollowUp = new FollowUpFormDto();
                await LoadDetailAsync();
            }
        }
        finally
        {
            _isAddingFollowUp = false;
        }
    }

    // ═══════════════ ATTACHMENTS ═══════════════

    private async Task OnFileUploadedAsync(IBrowserFile? file)
    {
        if (file is null || _detail is null) return;
        if (file.Size > 10 * 1024 * 1024)
        {
            Snackbar.Add("حجم الملف يتجاوز 10 ميجا", Severity.Warning);
            return;
        }

        _isUploading = true;
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(11 * 1024 * 1024).CopyToAsync(ms);
            var bytes = ms.ToArray();

            var (ok, msg, _) = await ComplaintService.UploadAttachmentAsync(
                _detail.ComplaintId, file.Name, bytes, file.ContentType, _currentUserId);

            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
            if (ok) await LoadDetailAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Upload failed");
            Snackbar.Add("فشل الرفع: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task DeleteAttachmentAsync(int attachmentId)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Title,      "تأكيد الحذف" },
            { x => x.Message,    "هل تريد حذف هذا المرفق؟" },
            { x => x.YesText,    "حذف" },
            { x => x.CancelText, "إلغاء" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("حذف", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var (ok, msg) = await ComplaintService.DeleteAttachmentAsync(attachmentId);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadDetailAsync();
    }

    // ═══════════════ HELPERS ═══════════════

    private string GetStatusClass(byte? s) => $"badge-status status-{s ?? 0}";
    private string GetPriorityClass(byte? p) => $"badge-priority priority-{p ?? 0}";

    private static string GetFileIcon(string mime) => mime.ToLowerInvariant() switch
    {
        var m when m.Contains("pdf") => Icons.Material.Filled.PictureAsPdf,
        var m when m.Contains("word") || m.Contains("doc") => Icons.Material.Filled.Description,
        var m when m.Contains("sheet") || m.Contains("excel") => Icons.Material.Filled.TableChart,
        var m when m.Contains("image") => Icons.Material.Filled.Image,
        _ => Icons.Material.Filled.InsertDriveFile
    };
}
