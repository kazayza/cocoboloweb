@page "/complaints/form"
@page "/complaints/form/{Id:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject IComplaintService ComplaintService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider
@inject ILogger<Form> Logger

@attribute [Authorize]

<PageTitle>@(IsEdit ? "تعديل شكوى" : "شكوى جديدة")</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="Color.Secondary" Size="Size.Large" Indeterminate="true" />
            </div>
            <MudText Typo="Typo.h6" Class="loading-text">جاري التحميل...</MudText>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else
{
<div dir="rtl" class="cmp-form-page">

    <!-- BG -->
    <div class="page-bg-decorations">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>

    <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

    <!-- ═══ HERO HEADER ═══ -->
    <div class="form-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-orbs">
                <div class="header-orb orb-1"></div>
                <div class="header-orb orb-2"></div>
                <div class="header-orb orb-3"></div>
            </div>
            <div class="header-grid"></div>
        </div>

        <div class="header-content">
            <div class="header-top">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon">
                            <MudIcon Icon="@(IsEdit ? Icons.Material.Filled.EditNote : Icons.Material.Filled.AddTask)" Size="Size.Large" />
                        </div>
                        <div class="header-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.SupportAgent" />
                        </div>
                    </div>
                    <div class="header-text">
                        <div class="header-title-row">
                            <MudText Typo="Typo.h4" Class="header-title">
                                @(IsEdit ? $"تعديل الشكوى #{Id}" : "تسجيل شكوى جديدة")
                            </MudText>
                            @if (!IsEdit)
                            {
                                <div class="header-badge">جديد</div>
                            }
                        </div>
                        <MudText Typo="Typo.body2" Class="header-subtitle">
                            @(IsEdit ? "تعديل بيانات الشكوى المسجلة" : "املأ البيانات الأساسية لتسجيل شكوى جديدة")
                        </MudText>
                        <!-- Breadcrumb -->
                        <div class="breadcrumb">
                            <MudLink Href="/" Class="bc-link">الرئيسية</MudLink>
                            <span>›</span>
                            <MudLink Href="/complaints/list" Class="bc-link">الشكاوى</MudLink>
                            <span>›</span>
                            <span class="bc-current">@(IsEdit ? "تعديل" : "شكوى جديدة")</span>
                        </div>
                    </div>
                </div>

                <div class="header-actions">
                    <MudButton Variant="Variant.Outlined"
                               Class="btn-back"
                               StartIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="@(() => Navigation.NavigateTo("/complaints/list"))">
                        رجوع للقائمة
                    </MudButton>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ MAIN LAYOUT (2 columns على الشاشات الكبيرة) ═══ -->
    <MudForm @ref="_form" Model="@_model" ValidationDelay="0">

        <MudGrid Spacing="2">
            <!-- ═══════ العمود الرئيسي (الفورم) ═══════ -->
            <MudItem xs="12" lg="8">

                <!-- ⭐ Section 1: العميل -->
                <div class="form-section animate-section" style="--delay: 0.05s">
                    <div class="section-header">
                        <div class="section-icon section-icon-blue">
                            <MudIcon Icon="@Icons.Material.Filled.Person" />
                        </div>
                        <div class="section-titles">
                            <div class="section-title">معلومات العميل</div>
                            <div class="section-subtitle">اختر العميل المرتبط بالشكوى</div>
                        </div>
                        <div class="section-status @(_selectedParty != null ? "status-done" : "status-pending")">
                            @(_selectedParty != null ? "✓" : "1")
                        </div>
                    </div>
                    <div class="section-body">
                        <MudAutocomplete T="PartyLookupItemDto"
                                         @bind-Value="_selectedParty"
                                         @bind-Value:after="OnPartyChangedAsync"
                                         SearchFunc="SearchPartiesAsync"
                                         ToStringFunc="@(p => p?.PartyName ?? "")"
                                         Label="ابحث عن العميل بالاسم أو رقم الهاتف..."
                                         Required="true"
                                         RequiredError="العميل مطلوب"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Normal"
                                         Clearable="true"
                                         CoerceText="true"
                                         ResetValueOnEmptyText="false"
                                         AdornmentIcon="@Icons.Material.Filled.Search"
                                         Adornment="Adornment.Start">
                            <ItemTemplate Context="p">
                                <div class="party-item">
                                    <div class="party-avatar">
                                        @(p.PartyName?.Substring(0, 1) ?? "؟")
                                    </div>
                                    <div class="party-info">
                                        <strong>@p.PartyName</strong>
                                        @if (!string.IsNullOrWhiteSpace(p.Phone))
                                        {
                                            <small>📞 @p.Phone</small>
                                        }
                                    </div>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </div>
                </div>

                <!-- ⭐ Section 2: تفاصيل الشكوى -->
                <div class="form-section animate-section" style="--delay: 0.1s">
                    <div class="section-header">
                        <div class="section-icon section-icon-gold">
                            <MudIcon Icon="@Icons.Material.Filled.Description" />
                        </div>
                        <div class="section-titles">
                            <div class="section-title">تفاصيل الشكوى</div>
                            <div class="section-subtitle">الموضوع والنوع والشرح الكامل</div>
                        </div>
                        <div class="section-status @(IsDetailsDone ? "status-done" : "status-pending")">
                            @(IsDetailsDone ? "✓" : "2")
                        </div>
                    </div>
                    <div class="section-body">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="8">
                                <MudTextField T="string"
                                              @bind-Value="_model.Subject"
                                              Label="موضوع الشكوى"
                                              Required="true"
                                              RequiredError="الموضوع مطلوب"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Normal"
                                              MaxLength="255"
                                              Counter="255"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Title" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="int"
                                           @bind-Value="_model.TypeId"
                                           Label="نوع الشكوى"
                                           Required="true"
                                           RequiredError="النوع مطلوب"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Normal"
                                           AdornmentIcon="@Icons.Material.Filled.Category"
                                           Adornment="Adornment.Start">
                                    @foreach (var t in _types)
                                    {
                                        <MudSelectItem T="int" Value="@t.TypeId">
                                            @(t.TypeNameAr ?? t.TypeName)
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField T="string"
                                              @bind-Value="_model.Details"
                                              Label="تفاصيل الشكوى"
                                              Required="true"
                                              RequiredError="التفاصيل مطلوبة"
                                              Variant="Variant.Outlined"
                                              Lines="6"
                                              Margin="Margin.Normal"
                                              Counter="2000"
                                              MaxLength="2000"
                                              HelperText="اكتب وصف تفصيلي للشكوى" />
                            </MudItem>
                        </MudGrid>
                    </div>
                </div>

                <!-- ⭐ Section 3: الأولوية والإسناد -->
                <div class="form-section animate-section" style="--delay: 0.15s">
                    <div class="section-header">
                        <div class="section-icon section-icon-red">
                            <MudIcon Icon="@Icons.Material.Filled.PriorityHigh" />
                        </div>
                        <div class="section-titles">
                            <div class="section-title">الأولوية والمسؤول</div>
                            <div class="section-subtitle">حدد أهمية الشكوى وأسندها لموظف</div>
                        </div>
                        <div class="section-status status-done">3</div>
                    </div>
                    <div class="section-body">
                        <label class="field-label">الأولوية</label>
                        <div class="priority-grid">
                            @foreach (var (val, txt, icon, cls) in PriorityOptions)
                            {
                                <div class="priority-option @cls @(_model.Priority == val ? "selected" : "")"
                                     @onclick="@(() => _model.Priority = val)">
                                    <div class="priority-icon">@icon</div>
                                    <div class="priority-text">@txt</div>
                                </div>
                            }
                        </div>

                        <MudGrid Spacing="2" Class="mt-3">
                            <MudItem xs="12" md="12">
                                <MudSelect T="int?"
                                           @bind-Value="_model.AssignedTo"
                                           Label="المُسند إليه (اختياري — سيتم تحويل الحالة لـ 'قيد الحل' تلقائياً)"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Normal"
                                           Clearable="true"
                                           AdornmentIcon="@Icons.Material.Filled.PersonPin"
                                           Adornment="Adornment.Start">
                                    @foreach (var e in _employees)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)e.EmployeeId)">
                                            @e.FullName
                                            @if (!string.IsNullOrWhiteSpace(e.JobTitle))
                                            {
                                                <span style="color:#94a3b8;font-size:11px;"> — @e.JobTitle</span>
                                            }
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                    </div>
                </div>

                <!-- ⭐ Section 4: ربط متقدم (Collapsible) -->
                <div class="form-section animate-section" style="--delay: 0.2s">
                    <div class="section-header section-header-collapsible"
                         @onclick="@(() => _advancedOpen = !_advancedOpen)">
                        <div class="section-icon section-icon-purple">
                            <MudIcon Icon="@Icons.Material.Filled.Link" />
                        </div>
                        <div class="section-titles">
                            <div class="section-title">ربط بفاتورة / منتج (اختياري)</div>
                            <div class="section-subtitle">اضغط للتوسعة</div>
                        </div>
                        <MudIcon Icon="@(_advancedOpen ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" />
                    </div>
                    <MudCollapse Expanded="_advancedOpen">
                        <div class="section-body">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="8">
                                    <MudSelect T="int?"
                                               @bind-Value="_model.TransactionId"
                                               @bind-Value:after="OnTransactionChangedAsync"
                                               Label="الفاتورة المرتبطة"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Normal"
                                               Clearable="true"
                                               Disabled="@(_selectedParty is null)"
                                               AdornmentIcon="@Icons.Material.Filled.Receipt"
                                               Adornment="Adornment.Start">
                                        @foreach (var t in _transactions)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)t.TransactionId)">
                                                @(t.ReferenceNumber ?? $"فاتورة #{t.TransactionId}")
                                                — @t.TransactionDate.ToString("yyyy/MM/dd")
                                                — @t.GrandTotal.ToString("N2") ج
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (_selectedParty is null)
                                    {
                                        <MudText Typo="Typo.caption" Class="hint-text">اختر العميل أولاً</MudText>
                                    }
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudAutocomplete T="ProductLookupItemDto"
                                                     @bind-Value="_selectedProduct"
                                                     @bind-Value:after="OnProductChanged"
                                                     SearchFunc="SearchProductsAsync"
                                                     ToStringFunc="@(p => p?.ProductName ?? "")"
                                                     Label="@(_model.TransactionId.HasValue ? "منتج من الفاتورة" : "منتج اشتراه العميل")"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Normal"
                                                     Clearable="true"
                                                     CoerceText="true"
                                                     Disabled="@(_selectedParty is null || _availableProducts.Count == 0)"
                                                     AdornmentIcon="@Icons.Material.Filled.Inventory2"
                                                     Adornment="Adornment.Start">
                                        <ItemTemplate Context="p">
                                            <div class="product-item">
                                                <div class="product-thumb">
                                                    <img src="/api/product-images/@p.ProductId"
                                                         alt="@p.ProductName"
                                                         onerror="this.onerror=null;this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 40 40%22><rect fill=%22%23e2e8f0%22 width=%2240%22 height=%2240%22 rx=%224%22/><text x=%2220%22 y=%2226%22 text-anchor=%22middle%22 font-size=%2218%22>📦</text></svg>';" />
                                                </div>
                                                <div class="product-info">
                                                    <strong>@p.ProductName</strong>
                                                    @if (p.Price.HasValue)
                                                    {
                                                        <small>@p.Price.Value.ToString("N2") ج</small>
                                                    }
                                                </div>
                                            </div>
                                        </ItemTemplate>
                                    </MudAutocomplete>
                                    @if (_selectedParty is null)
                                    {
                                        <MudText Typo="Typo.caption" Class="hint-text">اختر العميل أولاً</MudText>
                                    }
                                    else if (_availableProducts.Count == 0)
                                    {
                                        <MudText Typo="Typo.caption" Class="hint-text">العميل ليس لديه مشتريات سابقة</MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Class="hint-text">
                                            @(_model.TransactionId.HasValue ? "منتجات الفاتورة المختارة" : $"كل منتجات العميل ({_availableProducts.Count})")
                                        </MudText>
                                    }
                                </MudItem>
                            </MudGrid>
                        </div>
                    </MudCollapse>
                </div>

            </MudItem>

            <!-- ═══════ العمود الجانبي (Sidebar) ═══════ -->
            <MudItem xs="12" lg="4">

                <!-- 📊 Form Progress -->
                <div class="sidebar-card animate-section" style="--delay: 0.05s">
                    <div class="sidebar-header sidebar-header-gold">
                        <MudIcon Icon="@Icons.Material.Filled.Checklist" />
                        <span>تقدم النموذج</span>
                    </div>
                    <div class="sidebar-body">
                        <div class="progress-item @(_selectedParty != null ? "done" : "")">
                            <div class="progress-check">
                                @if (_selectedParty != null)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.RadioButtonUnchecked" />
                                }
                            </div>
                            <span>اختيار العميل</span>
                        </div>
                        <div class="progress-item @(IsDetailsDone ? "done" : "")">
                            <div class="progress-check">
                                @if (IsDetailsDone)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.RadioButtonUnchecked" />
                                }
                            </div>
                            <span>تفاصيل الشكوى</span>
                        </div>
                        <div class="progress-item done">
                            <div class="progress-check">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                            </div>
                            <span>الأولوية (@PriorityOptions.First(p => p.val == _model.Priority).txt)</span>
                        </div>
                        @if (_model.AssignedTo.HasValue)
                        {
                            <div class="progress-item done">
                                <div class="progress-check">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                                </div>
                                <span>تم الإسناد</span>
                            </div>
                        }
                        @if (_model.TransactionId.HasValue)
                        {
                            <div class="progress-item done">
                                <div class="progress-check">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                                </div>
                                <span>مرتبط بفاتورة</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- 👤 Customer Preview -->
                @if (_selectedParty != null)
                {
                    <div class="sidebar-card animate-section" style="--delay: 0.1s">
                        <div class="sidebar-header sidebar-header-blue">
                            <MudIcon Icon="@Icons.Material.Filled.PersonPin" />
                            <span>بطاقة العميل</span>
                        </div>
                        <div class="sidebar-body">
                            <div class="customer-card">
                                <div class="customer-avatar-big">
                                    @(_selectedParty.PartyName?.Substring(0, 1) ?? "؟")
                                </div>
                                <div class="customer-name">@_selectedParty.PartyName</div>
                                @if (!string.IsNullOrWhiteSpace(_selectedParty.Phone))
                                {
                                    <a href="tel:@_selectedParty.Phone" class="customer-phone">
                                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                                        @_selectedParty.Phone
                                    </a>
                                }
                            </div>

                            @if (_customerStats != null)
                            {
                                <div class="customer-stats">
                                    <div class="customer-stat">
                                        <div class="cs-value">@_customerStats.TotalComplaints</div>
                                        <div class="cs-label">شكاوى سابقة</div>
                                    </div>
                                    <div class="customer-stat">
                                        <div class="cs-value">@_customerStats.OpenComplaints</div>
                                        <div class="cs-label">مفتوحة</div>
                                    </div>
                                    <div class="customer-stat">
                                        <div class="cs-value">@_transactions.Count</div>
                                        <div class="cs-label">فواتير</div>
                                    </div>
                                </div>

                                @if (_customerStats.RecentComplaints.Any())
                                {
                                    <div class="recent-complaints">
                                        <div class="rc-title">آخر شكاوى للعميل:</div>
                                        @foreach (var c in _customerStats.RecentComplaints)
                                        {
                                            <a href="/complaints/@c.ComplaintId" target="_blank" class="rc-item">
                                                <span class="rc-id">#@c.ComplaintId</span>
                                                <span class="rc-subject">@c.Subject</span>
                                                <span class="@GetStatusClass(c.Status)">@c.StatusName</span>
                                            </a>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="sidebar-card empty-sidebar animate-section" style="--delay: 0.1s">
                        <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Size="Size.Large" />
                        <MudText Typo="Typo.body2">اختر عميل من اليمين لعرض بطاقته وآخر شكاويه</MudText>
                    </div>
                }

                <!-- 💡 Tips -->
                <div class="sidebar-card animate-section" style="--delay: 0.15s">
                    <div class="sidebar-header sidebar-header-purple">
                        <MudIcon Icon="@Icons.Material.Filled.TipsAndUpdates" />
                        <span>نصائح سريعة</span>
                    </div>
                    <div class="sidebar-body">
                        <ul class="tips-list">
                            <li>اكتب التفاصيل بشكل واضح ومحدد</li>
                            <li>اربط الشكوى بفاتورة إن أمكن</li>
                            <li>تحديد الأولوية يساعد في الترتيب</li>
                            <li>الإسناد المباشر يسرّع المعالجة</li>
                            <li>بعد الحفظ، تقدر ترفع صور ومرفقات</li>
                        </ul>
                    </div>
                </div>

            </MudItem>
        </MudGrid>
    </MudForm>

    <!-- ═══ STICKY BOTTOM BAR ═══ -->
    <div class="sticky-actions">
        <div class="sticky-actions-inner">
            <div class="sticky-info">
                @if (_selectedParty != null)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                    <span>جاهز للحفظ</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Default" />
                    <span>اختر العميل أولاً</span>
                }
            </div>
            <div class="sticky-buttons">
                <MudButton Variant="Variant.Text"
                           Size="Size.Large"
                           OnClick="Cancel"
                           Disabled="_isSaving">
                    إلغاء
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Size="Size.Large"
                           Class="btn-save"
                           StartIcon="@(_isSaving ? null : Icons.Material.Filled.Save)"
                           OnClick="SaveAsync"
                           Disabled="_isSaving">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                        <span>جاري الحفظ...</span>
                    }
                    else
                    {
                        <span>@(IsEdit ? "تحديث الشكوى" : "حفظ وإكمال")</span>
                    }
                </MudButton>
            </div>
        </div>
    </div>

</div>
}

<style>
    /* ═════════════ LOADING ═════════════ */
    .loading-screen { position: fixed; inset: 0; background: linear-gradient(135deg, #0f1a2e 0%, #1a2842 100%); display: flex; align-items: center; justify-content: center; z-index: 9999; }
    .loading-content { text-align: center; }
    .loading-spinner-box { background: rgba(212,175,55,0.1); padding: 24px; border-radius: 50%; border: 2px solid rgba(212,175,55,0.3); margin-bottom: 16px; display: inline-block; }
    .loading-text { color: #d4af37 !important; margin-bottom: 8px; }
    .loading-dots { display: inline-flex; gap: 6px; justify-content: center; }
    .loading-dots span { width: 8px; height: 8px; border-radius: 50%; background: #d4af37; animation: bounce 1.4s infinite ease-in-out both; }
    .loading-dots span:nth-child(2) { animation-delay: 0.16s; }
    .loading-dots span:nth-child(3) { animation-delay: 0.32s; }
    @@keyframes bounce { 0%,80%,100% { transform: scale(0); opacity: 0.5; } 40% { transform: scale(1); opacity: 1; } }

    /* ═════════════ PAGE ═════════════ */
    .cmp-form-page {
        position: relative;
        min-height: 100vh;
        padding: 12px 12px 100px 12px;
        background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
    }
    .page-bg-decorations { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
    .bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.2; }
    .bg-orb-1 { width: 300px; height: 300px; background: radial-gradient(circle, #d4af37, transparent); top: -100px; right: -50px; }
    .bg-orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, #3b82f6, transparent); top: 30%; left: -100px; }
