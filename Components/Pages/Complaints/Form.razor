@code {
    [Parameter] public int? Id { get; set; }

    private bool IsEdit => Id.HasValue && Id.Value > 0;

    private MudForm? _form;
    private bool _isLoading = true;
    private bool _isSaving  = false;
    private bool _advancedOpen = false;

    private ComplaintFormDto _model = new() { Priority = 2 };

    private PartyLookupItemDto? _selectedParty;
    private List<ComplaintTypeDto>         _types        = new();
    private List<EmployeeLookupItemDto>    _employees    = new();
    private List<TransactionLookupItemDto> _transactions = new();
    private List<ProductLookupItemDto> _availableProducts = new();
    private ProductLookupItemDto? _selectedProduct;

    private CustomerSnapshot? _customerStats;

    private string _currentUserName = "system";

    // Priority options with icons
    private (byte val, string txt, string icon, string cls)[] PriorityOptions => new[]
    {
        ((byte)1, "عالية جداً", "🔥", "priority-1-style"),
        ((byte)2, "عالية",     "🔴", "priority-2-style"),
        ((byte)3, "متوسطة",    "🟡", "priority-3-style"),
        ((byte)4, "منخفضة",    "🟢", "priority-4-style"),
    };

    private bool IsDetailsDone =>
        !string.IsNullOrWhiteSpace(_model.Subject)
        && !string.IsNullOrWhiteSpace(_model.Details)
        && _model.TypeId > 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();

        var typesTask     = ComplaintService.GetTypesAsync();
        var employeesTask = ComplaintService.GetEmployeesAsync();
        await Task.WhenAll(typesTask, employeesTask);
        _types     = await typesTask;
        _employees = await employeesTask;

        if (IsEdit) await LoadComplaintAsync();

        _isLoading = false;
    }

    private async Task LoadPermissionsAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserName = user.Identity?.Name ?? "system";

        var allowed = IsEdit
            ? ComplaintPermissions.CanEdit(user)
            : ComplaintPermissions.CanCreate(user);

        if (!allowed)
        {
            Snackbar.Add("ليس لديك صلاحية", Severity.Error);
            Navigation.NavigateTo("/complaints/list");
        }
    }

    private async Task LoadComplaintAsync()
    {
        try
        {
            var c = await ComplaintService.GetByIdAsync(Id!.Value);
            if (c is null)
            {
                Snackbar.Add("الشكوى غير موجودة", Severity.Error);
                Navigation.NavigateTo("/complaints/list");
                return;
            }
            if (c.IsClosed)
            {
                Snackbar.Add("لا يمكن تعديل شكوى مغلقة", Severity.Warning);
                Navigation.NavigateTo($"/complaints/{Id.Value}");
                return;
            }

            _model = new ComplaintFormDto
            {
                ComplaintId   = c.ComplaintId,
                PartyId       = c.PartyId,
                TypeId        = c.TypeId,
                TransactionId = c.TransactionId,
                ProductId     = c.ProductId,
                Subject       = c.Subject,
                Details       = c.Details,
                Priority      = c.Priority ?? 2,
                AssignedTo    = c.AssignedTo
            };

            _selectedParty = new PartyLookupItemDto
            {
                PartyId   = c.PartyId,
                PartyName = c.ClientName ?? "",
                Phone     = c.ClientPhone
            };

            await LoadCustomerDataAsync(c.PartyId);
            await LoadProductsAsync();

            // إعداد المنتج المختار لو موجود
            if (c.ProductId.HasValue)
            {
                _selectedProduct = _availableProducts.FirstOrDefault(p => p.ProductId == c.ProductId.Value)
                                ?? new ProductLookupItemDto
                                {
                                    ProductId   = c.ProductId.Value,
                                    ProductName = c.ProductName ?? $"منتج #{c.ProductId.Value}"
                                };
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load complaint {Id} failed", Id);
            Snackbar.Add("تعذّر تحميل الشكوى: " + ex.Message, Severity.Error);
        }
    }

    // ─── Product lookup ──────────────────────────
    private async Task<IEnumerable<ProductLookupItemDto>> SearchProductsAsync(string? value, CancellationToken ct)
    {
        if (_availableProducts.Count == 0) return Enumerable.Empty<ProductLookupItemDto>();

        if (string.IsNullOrWhiteSpace(value))
            return _availableProducts;

        var s = value.Trim();
        return _availableProducts.Where(p =>
            p.ProductName.Contains(s, StringComparison.OrdinalIgnoreCase)
            || (p.Description?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private void OnProductChanged()
    {
        _model.ProductId = _selectedProduct?.ProductId;
    }

    private async Task LoadProductsAsync()
    {
        if (_selectedParty is null)
        {
            _availableProducts = new();
            return;
        }

        try
        {
            // لو في فاتورة → منتجاتها فقط
            // لو مفيش → كل منتجات العميل
            if (_model.TransactionId.HasValue)
            {
                _availableProducts = await ComplaintService.GetTransactionProductsAsync(_model.TransactionId.Value);
            }
            else
            {
                _availableProducts = await ComplaintService.GetCustomerProductsAsync(_selectedParty.PartyId);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load products");
            _availableProducts = new();
        }
    }

        private async Task OnTransactionChangedAsync()
    {
        // كل ما تتغير الفاتورة → نعمل reload للمنتجات
        _model.ProductId = null;
        _selectedProduct = null;
        await LoadProductsAsync();
    }

        private async Task<IEnumerable<PartyLookupItemDto>> SearchPartiesAsync(string? value, CancellationToken ct)
    {
        try { return await ComplaintService.SearchPartiesAsync(value, 20); }
        catch { return Enumerable.Empty<PartyLookupItemDto>(); }
    }

    private async Task OnPartyChangedAsync()
    {
        if (_selectedParty is null)
        {
            _model.PartyId = 0;
            _model.TransactionId = null;
            _model.ProductId = null;
            _selectedProduct = null;
            _transactions = new();
            _availableProducts = new();
            _customerStats = null;
            return;
        }

        _model.PartyId = _selectedParty.PartyId;
        _model.TransactionId = null;
        _model.ProductId = null;
        _selectedProduct = null;
        await LoadCustomerDataAsync(_selectedParty.PartyId);
        await LoadProductsAsync();  // تحميل كل منتجات العميل افتراضياً
    }

    private async Task LoadCustomerDataAsync(int partyId)
    {
        try
        {
            _transactions = await ComplaintService.GetCustomerTransactionsAsync(partyId);

            // جلب آخر شكاوى العميل + الإحصائيات
            var filter = new ComplaintFilterDto
            {
                PartyId = partyId,
                Page = 1,
                PageSize = 5
            };
            var recent = await ComplaintService.GetComplaintsAsync(filter);
            _customerStats = new CustomerSnapshot
            {
                TotalComplaints  = recent.TotalCount,
                OpenComplaints   = recent.Items.Count(i => !ComplaintStatus.IsClosed(i.Status)),
                RecentComplaints = recent.Items.Take(3).ToList()
            };
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load customer data");
            _transactions = new();
            _customerStats = null;
        }
    }

    private async Task SaveAsync()
    {
        if (_form is null) return;
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            Snackbar.Add("الرجاء تصحيح الأخطاء قبل الحفظ", Severity.Warning);
            return;
        }

        if (_selectedParty is null || _model.PartyId <= 0)
        {
            Snackbar.Add("الرجاء اختيار العميل", Severity.Warning);
            return;
        }

        _isSaving = true;
        try
        {
            if (IsEdit)
            {
                var (ok, msg) = await ComplaintService.UpdateAsync(_model, _currentUserName);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok) Navigation.NavigateTo($"/complaints/{Id!.Value}");
            }
            else
            {
                var (ok, msg, newId) = await ComplaintService.CreateAsync(_model, _currentUserName);
                Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
                if (ok && newId.HasValue) Navigation.NavigateTo($"/complaints/{newId.Value}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Save failed");
            Snackbar.Add("حدث خطأ: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel()
    {
        if (IsEdit) Navigation.NavigateTo($"/complaints/{Id!.Value}");
        else        Navigation.NavigateTo("/complaints/list");
    }

    private string GetStatusClass(byte? s) => $"badge-status status-{s ?? 0}";

    // ─── Helper class ───
    private class CustomerSnapshot
    {
        public int TotalComplaints { get; set; }
        public int OpenComplaints  { get; set; }
        public List<ComplaintListItemDto> RecentComplaints { get; set; } = new();
    }
