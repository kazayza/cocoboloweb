@page "/notifications"

@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>الإشعارات — COCOBOLO ERP</PageTitle>

<div class="notif-page" dir="rtl">

    <div class="page-header">
        <div class="ph-left">
            <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="page-icon" />
            <div>
                <h1>الإشعارات</h1>
                <p>@_notifications.Count إشعار - @_notifications.Count(n => !n.IsRead) جديد</p>
            </div>
        </div>
        @if (_notifications.Any(n => !n.IsRead))
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.DoneAll"
                       OnClick="MarkAllAsRead">تعليم الكل كمقروء</MudButton>
        }
    </div>

    <div class="filter-tabs">
        <button class="tab @(_filter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>
            الكل (@_notifications.Count)
        </button>
        <button class="tab @(_filter == "unread" ? "active" : "")" @onclick='() => SetFilter("unread")'>
            غير مقروء (@_notifications.Count(n => !n.IsRead))
        </button>
        <button class="tab @(_filter == "read" ? "active" : "")" @onclick='() => SetFilter("read")'>
            مقروء (@_notifications.Count(n => n.IsRead))
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="loading-state">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <p>جاري التحميل...</p>
        </div>
    }
    else if (FilteredNotifications.Any())
    {
        <div class="notif-list">
            @foreach (var notif in FilteredNotifications)
            {
                <div class="notif-card @(!notif.IsRead ? "unread" : "")" @onclick="() => HandleClick(notif)">
                    <div class="nc-icon @(!notif.IsRead ? "active" : "")">
                        <MudIcon Icon="@(notif.IsRead ? Icons.Material.Filled.NotificationsNone : Icons.Material.Filled.NotificationsActive)" />
                    </div>
                    <div class="nc-content">
                        <div class="nc-header">
                            <strong>@notif.Title</strong>
                            <small>@GetTimeAgo(notif.CreatedAt)</small>
                        </div>
                        <p>@notif.Message</p>
                        @if (!string.IsNullOrEmpty(notif.CreatedBy))
                        {
                            <small class="nc-from">من: @notif.CreatedBy</small>
                        }
                    </div>
                    @if (!notif.IsRead)
                    {
                        <div class="nc-dot"></div>
                    }
                </div>
            }
        </div>

        @if (_notifications.Count >= _limit)
        {
            <div style="text-align: center; margin: 2rem 0 1rem;">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ExpandMore"
                           OnClick="LoadMoreAsync" Disabled="@_isLoadingMore">
                    @if (_isLoadingMore)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    }
                    عرض المزيد من الإشعارات السابقة
                </MudButton>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Filled.NotificationsOff" Size="Size.Large" />
            <h3>لا توجد إشعارات</h3>
            <p>سيتم عرض الإشعارات هنا عند وصولها</p>
        </div>
    }
</div>

<style>
    .notif-page {
        padding: 1.5rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .ph-left { display: flex; align-items: center; gap: 1rem; }
    .page-icon {
        font-size: 2.5rem !important;
        color: #d4af37;
    }
    .page-header h1 { margin: 0; font-size: 1.75rem; color: #1e293b; }
    .page-header p { margin: 0; color: #64748b; font-size: .9rem; }

    .filter-tabs {
        display: flex;
        gap: 0;
        background: white;
        border-radius: 12px;
        padding: 4px;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .tab {
        flex: 1;
        padding: .85rem;
        background: transparent;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: .9rem;
        font-weight: 600;
        color: #64748b;
        transition: all .2s;
        font-family: inherit;
    }
    .tab:hover { background: #f8fafc; }
    .tab.active {
        background: #d4af37;
        color: white;
        box-shadow: 0 2px 6px rgba(212,175,55,0.3);
    }

    .loading-state, .empty-state {
        text-align: center;
        padding: 4rem 1rem;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .empty-state ::deep .mud-icon-root {
        font-size: 4rem !important;
        opacity: 0.3;
    }
    .empty-state h3 { color: #475569; margin: 1rem 0 .5rem; }
    .empty-state p { color: #94a3b8; }

    .notif-list { display: flex; flex-direction: column; gap: .75rem; }

    .notif-card {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        background: white;
        padding: 1.25rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        cursor: pointer;
        transition: all .2s ease;
        position: relative;
    }
    .notif-card:hover {
        transform: translateX(-4px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    }
    .notif-card.unread {
        background: linear-gradient(135deg, rgba(212,175,55,0.05) 0%, white 100%);
        border-right: 4px solid #d4af37;
    }
    .nc-icon {
        width: 48px; height: 48px;
        background: #f1f5f9;
        color: #94a3b8;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .nc-icon.active {
        background: rgba(212,175,55,0.15);
        color: #d4af37;
    }
    .nc-content { flex: 1; }
    .nc-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: .5rem;
        margin-bottom: .35rem;
    }
    .nc-header strong { color: #1e293b; font-size: 1rem; }
    .nc-header small { color: #94a3b8; font-size: .75rem; white-space: nowrap; }
    .nc-content p { margin: 0; color: #475569; font-size: .9rem; line-height: 1.5; white-space: pre-wrap; }
    .nc-from { color: #94a3b8; font-size: .75rem; margin-top: .35rem; display: block; }
    .nc-dot {
        position: absolute;
        top: 1rem; left: 1rem;
        width: 10px; height: 10px;
        background: #ef4444;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }
    @@keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.3); opacity: 0.7; }
    }

    @@media (max-width: 768px) {
        .notif-page { padding: 1rem; }
        .page-header h1 { font-size: 1.3rem; }
    }
</style>

@code {
    private List<Notification> _notifications = new();
    private bool _isLoading = true;
    private bool _isLoadingMore = false;
    private int _limit = 350;
    private string _filter = "all";
    private string? _currentUserName;
    private string? _currentUserRole;
    private List<string> _userRoles = new();

    private IEnumerable<Notification> FilteredNotifications => _filter switch
    {
        "unread" => _notifications.Where(n => !n.IsRead),
        "read" => _notifications.Where(n => n.IsRead),
        _ => _notifications
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            _currentUserName = auth.User.Identity?.Name;
            _userRoles = auth.User.Claims
                .Where(c => c.Type == ClaimTypes.Role || c.Type == "role" || c.Type.EndsWith("/role"))
                .Select(c => c.Value)
                .Distinct()
                .ToList();
            _currentUserRole = _userRoles.FirstOrDefault();

            await Load();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task Load()
    {
        _notifications = await NotificationService.GetLatestAsync(
            _currentUserName ?? "", _userRoles, _limit);
    }

    private async Task LoadMoreAsync()
    {
        _isLoadingMore = true;
        _limit += 300;
        await Load();
        _isLoadingMore = false;
    }

    private void SetFilter(string f) => _filter = f;

    private async Task HandleClick(Notification notif)
    {
        if (!notif.IsRead)
        {
            await NotificationService.MarkAsReadAsync(notif.NotificationId);
            notif.IsRead = true;
        }

        var url = GetNotificationUrl(notif);
        if (!string.IsNullOrWhiteSpace(url))
        {
            Navigation.NavigateTo(url);
        }
    }

    private async Task MarkAllAsRead()
    {
        await NotificationService.MarkAllAsReadForUserAsync(_currentUserName ?? "", _userRoles);
        foreach (var n in _notifications)
        {
            n.IsRead = true;
        }
        Snackbar.Add("تم تعليم جميع الإشعارات كمقروءة", Severity.Success);
    }
    private static string? GetNotificationUrl(Notification notif)
{
    if (string.Equals(notif.RelatedTable, "LeadsCRM", StringComparison.OrdinalIgnoreCase))
    {
        if (string.Equals(notif.FormName, "crm/leads/my", StringComparison.OrdinalIgnoreCase))
            return "/crm/leads/my";

        return "/crm/leads";
    }

    if (string.Equals(notif.RelatedTable, "PayrollRuns", StringComparison.OrdinalIgnoreCase) && notif.RelatedId.HasValue)
        return $"/hr/payroll/run/{notif.RelatedId.Value}";

    if (string.Equals(notif.RelatedTable, "Payroll", StringComparison.OrdinalIgnoreCase))
    {
        if (string.Equals(notif.FormName, "frm_PayrollPayment", StringComparison.OrdinalIgnoreCase))
            return "/hr/payroll/bonuses";

        if (string.Equals(notif.FormName, "frm_Payroll", StringComparison.OrdinalIgnoreCase))
            return "/hr/payroll";
    }

    if (string.IsNullOrWhiteSpace(notif.FormName))
        return null;

    var form = notif.FormName.Trim().TrimStart('/');

    if (notif.RelatedId.HasValue)
        return $"/{form}/{notif.RelatedId.Value}";

    return $"/{form}";
}

    private string GetTimeAgo(DateTime dateTime)
    {
        var diff = DateTime.Now - dateTime;
        if (diff.TotalMinutes < 1) return "الآن";
        if (diff.TotalMinutes < 60) return $"منذ {(int)diff.TotalMinutes} دقيقة";
        if (diff.TotalHours < 24) return $"منذ {(int)diff.TotalHours} ساعة";
        if (diff.TotalDays < 7) return $"منذ {(int)diff.TotalDays} يوم";
        return dateTime.ToString("dd/MM/yyyy");
    }
}
