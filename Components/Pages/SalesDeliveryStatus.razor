@page "/sales-delivery-status"
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@inject ISalesDeliveryStatusService DeliveryService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>متابعة تسليمات المبيعات</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @* ═══════════════════════════════════════════════════ *@
    @*  العنوان                                           *@
    @* ═══════════════════════════════════════════════════ *@
    <MudText Typo="Typo.h5" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Class="me-2" />
        متابعة تسليمات المبيعات
    </MudText>

    @* ═══════════════════════════════════════════════════ *@
    @*  كروت الإحصائيات                                   *@
    @* ═══════════════════════════════════════════════════ *@
    <MudGrid Class="mb-4">

        @* إجمالي الفواتير *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt"
                             Color="Color.Primary" Size="Size.Large" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            إجمالي الفواتير
                        </MudText>
                        <MudText Typo="Typo.h5" Color="Color.Primary">
                            @_summary.TotalCount
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        @* جارى التسليم *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.HourglassBottom"
                             Color="Color.Warning" Size="Size.Large" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            جارى التسليم
                        </MudText>
                        <MudText Typo="Typo.h5" Color="Color.Warning">
                            @_summary.PendingCount
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        @* متأخر *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Warning"
                             Color="Color.Error" Size="Size.Large" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            متأخر
                        </MudText>
                        <MudText Typo="Typo.h5" Color="Color.Error">
                            @_summary.OverdueCount
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        @* المتبقى *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet"
                             Color="Color.Info" Size="Size.Large" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            المتبقى
                        </MudText>
                        <MudText Typo="Typo.h5" Color="Color.Info">
                            @_summary.TotalRemaining.ToString("N2")
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

    </MudGrid>

    @* ═══════════════════════════════════════════════════ *@
    @*  الفلاتر                                           *@
    @* ═══════════════════════════════════════════════════ *@
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudGrid>

            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="من تاريخ"
                               @bind-Date="_dateFrom"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               DateFormat="yyyy/MM/dd"
                               Clearable="true" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="إلى تاريخ"
                               @bind-Date="_dateTo"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               DateFormat="yyyy/MM/dd"
                               Clearable="true" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="_partyName"
                              Label="اسم العميل"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect @bind-Value="_deliveryStatus"
                           Label="حالة التسليم"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true">
                    <MudSelectItem Value="@((string?)null)">الكل</MudSelectItem>
                    <MudSelectItem Value="@("جارى")">جارى</MudSelectItem>
                    <MudSelectItem Value="@("متأخر")">متأخر</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" Class="d-flex gap-2">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           OnClick="SearchAsync">
                    بحث
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.RestartAlt"
                           OnClick="ResetFiltersAsync">
                    إعادة تعيين
                </MudButton>
            </MudItem>

        </MudGrid>
    </MudPaper>

    @* ═══════════════════════════════════════════════════ *@
    @*  الجدول                                            *@
    @* ═══════════════════════════════════════════════════ *@
    <MudTable Items="@_data"
              Dense="true"
              Hover="true"
              Striped="true"
              Bordered="true"
              Loading="@_loading"
              LoadingProgressColor="Color.Primary"
              RowsPerPage="15"
              Elevation="2">

        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<VwSalesDeliveryStatus, object>(x => x.TransactionId)">رقم العملية</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<VwSalesDeliveryStatus, object>(x => x.TransactionDate)">التاريخ</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<VwSalesDeliveryStatus, object>(x => x.PartyName)">العميل</MudTableSortLabel></MudTh>
            <MudTh>الموظف</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<VwSalesDeliveryStatus, object>(x => x.DueDate ?? DateTime.MaxValue)">تاريخ الاستحقاق</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<VwSalesDeliveryStatus, object>(x => x.DaysRemaining ?? 0)">الأيام المتبقية</MudTableSortLabel></MudTh>
            <MudTh>الإجمالى</MudTh>
            <MudTh>المدفوع</MudTh>
            <MudTh>المتبقى</MudTh>
            <MudTh>الحالة</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="رقم العملية">@context.TransactionId</MudTd>
            <MudTd DataLabel="التاريخ">@context.TransactionDate.ToString("yyyy/MM/dd")</MudTd>
            <MudTd DataLabel="العميل">@context.PartyName</MudTd>
            <MudTd DataLabel="الموظف">@context.EmployeeName</MudTd>
            <MudTd DataLabel="تاريخ الاستحقاق">
                @(context.DueDate?.ToString("yyyy/MM/dd") ?? "—")
            </MudTd>
            <MudTd DataLabel="الأيام المتبقية">
                @if (context.DaysRemaining.HasValue)
                {
                    var days = context.DaysRemaining.Value;
                    var color = days < 0 ? Color.Error : days == 0 ? Color.Warning : Color.Success;
                    <MudChip T="string" Color="@color" Size="Size.Small">
                        @days يوم
                    </MudChip>
                }
                else
                {
                    <MudText>—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="الإجمالى">@context.GrandTotal.ToString("N2")</MudTd>
            <MudTd DataLabel="المدفوع">@context.PaidAmount.ToString("N2")</MudTd>
            <MudTd DataLabel="المتبقى">
                @((context.GrandTotal - context.PaidAmount).ToString("N2"))
            </MudTd>
            <MudTd DataLabel="الحالة">
                @if (context.DeliveryStatus == "متأخر")
                {
                    <MudChip T="string" Color="Color.Error"
                             Size="Size.Small"
                             Icon="@Icons.Material.Filled.Warning">
                        متأخر
                    </MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Warning"
                             Size="Size.Small"
                             Icon="@Icons.Material.Filled.HourglassBottom">
                        جارى
                    </MudChip>
                }
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="pa-4">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="me-2" />
                لا توجد بيانات
            </MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 15, 25, 50, 100 }"
                           RowsPerPageString="عدد الصفوف:"
                           InfoFormat="{first_item}-{last_item} من {all_items}" />
        </PagerContent>

    </MudTable>

</MudContainer>

@code {
    // ─── الحالة ────────────────────────────────────
    private List<VwSalesDeliveryStatus> _data = new();
    private DeliveryStatusSummary _summary = new();
    private bool _loading = true;

    // ─── الفلاتر ───────────────────────────────────
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private string? _partyName;
    private string? _deliveryStatus;

    // ─── التحميل الأولى ────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    // ─── تحميل البيانات ────────────────────────────
    private async Task LoadDataAsync()
    {
        _loading = true;

        try
        {
            var dataTask = DeliveryService.GetFilteredAsync(
                _dateFrom, _dateTo, _partyName, _deliveryStatus);

            var summaryTask = DeliveryService.GetSummaryAsync(
                _dateFrom, _dateTo, _partyName, _deliveryStatus);

            await Task.WhenAll(dataTask, summaryTask);

            _data = dataTask.Result;
            _summary = summaryTask.Result;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SalesDeliveryStatus] Error: {ex.Message}");
            _data = new();
            _summary = new();
        }
        finally
        {
            _loading = false;
        }
    }

    // ─── بحث ────────────────────────────────────────
    private async Task SearchAsync()
    {
        await LoadDataAsync();
    }

    // ─── إعادة تعيين ───────────────────────────────
    private async Task ResetFiltersAsync()
    {
        _dateFrom = null;
        _dateTo = null;
        _partyName = null;
        _deliveryStatus = null;

        await LoadDataAsync();
    }
}