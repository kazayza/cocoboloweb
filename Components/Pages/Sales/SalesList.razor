@page "/sales"
@page "/sales/invoices"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Security.Claims

@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider
@inject IAuditService AuditService
@inject NotificationService NotifyService

@if (_isLoading)
{
    <div class="loading-container">
        <div class="loading-spinner">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
        <MudText Typo="Typo.h6" Class="mt-4" Style="color: var(--gold);">جاري تحميل الفواتير...</MudText>
    </div>
}
else
{
    <div class="invoices-page" dir="rtl">

        <!-- Header -->
        <div class="page-header">
            <div class="header-overlay"></div>
            <div class="header-content">
                <div class="header-info">
                    <div class="header-badge">
                        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                    </div>
                    <div>
                        <h1>إدارة الفواتير</h1>
                        <p>متابعة وتحصيل فواتير المبيعات والمشتريات</p>
                    </div>
                </div>
                <div class="header-actions">
                    @if (_canAdd)
                    {
                        <MudButton Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.AddShoppingCart"
                                   OnClick="GoToAdd"
                                   Size="Size.Large"
                                   Class="add-btn">
                            فاتورة جديدة
                        </MudButton>
                    }
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-icon-wrap stat-total">
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" />
                    </div>
                    <div class="stat-body">
                        <span class="stat-value">@_stats.TotalCount</span>
                        <span class="stat-label">إجمالي الفواتير</span>
                    </div>
                </div>
                @if (_canSeeAmounts)
                {
                    <div class="stat-card">
                        <div class="stat-icon-wrap stat-sales">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                        </div>
                        <div class="stat-body">
                            <span class="stat-value">@FormatMoney(_stats.TotalSales)</span>
                            <span class="stat-label">إجمالي المبيعات</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon-wrap stat-paid">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                        </div>
                        <div class="stat-body">
                            <span class="stat-value">@FormatMoney(_stats.TotalPaid)</span>
                            <span class="stat-label">المحصّل</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon-wrap stat-remaining">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" />
                        </div>
                        <div class="stat-body">
                            <span class="stat-value">@FormatMoney(_stats.TotalRemaining)</span>
                            <span class="stat-label">المتبقي</span>
                        </div>
                    </div>
                }
                <div class="stat-card">
                    <div class="stat-icon-wrap stat-today">
                        <MudIcon Icon="@Icons.Material.Filled.Today" />
                    </div>
                    <div class="stat-body">
                        <span class="stat-value">@_stats.TodayCount</span>
                        <span class="stat-label">فواتير اليوم</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap stat-overdue">
                        <MudIcon Icon="@Icons.Material.Filled.WarningAmber" />
                    </div>
                    <div class="stat-body">
                        <span class="stat-value">@_stats.OverdueCount</span>
                        <span class="stat-label">متأخرة</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <div class="tabs-container">
            <div class="tabs-group">
                <button class="tab-btn @(_activeTab == "Sale" ? "tab-active" : "")"
                        @onclick="@(() => SwitchTab("Sale"))">
                    <MudIcon Icon="@Icons.Material.Filled.Sell" Size="Size.Small" />
                    <span>المبيعات</span>
                </button>
                @if (_canViewPurchases)
                {
                    <button class="tab-btn @(_activeTab == "Purchase" ? "tab-active" : "")"
                            @onclick="@(() => SwitchTab("Purchase"))">
                        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" />
                        <span>المشتريات</span>
                    </button>
                }
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-card">
            <div class="filters-row">
                <div class="search-field">
                    <MudTextField T="string"
                                  Value="_filter.SearchText"
                                  ValueChanged="@(async (string v) => { _filter.SearchText = v; await OnSearchChanged(); })"
                                  Placeholder="بحث برقم الفاتورة أو اسم العميل..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  DebounceInterval="400"
                                  Clearable="true" />
                </div>

                <MudDatePicker Date="_dateFrom"
                               DateChanged="OnDateFromChanged"
                               Label="من تاريخ"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="filter-select"
                               Clearable="true" />

                <MudDatePicker Date="_dateTo"
                               DateChanged="OnDateToChanged"
                               Label="إلى تاريخ"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Class="filter-select"
                               Clearable="true" />

                <MudSelect T="string"
                           Value="_filter.InvoiceStatus"
                           ValueChanged="@(async (string v) => { _filter.InvoiceStatus = v; await OnFilterChanged(); })"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Placeholder="الحالة"
                           Clearable="true"
                           Class="filter-select">
                    @foreach (var status in InvoiceStatuses.All)
                    {
                        <MudSelectItem T="string" Value="@status.Key">@status.Value</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="bool?"
                           Value="_filter.HasRemaining"
                           ValueChanged="@(async (bool? v) => { _filter.HasRemaining = v; await OnFilterChanged(); })"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Placeholder="السداد"
                           Clearable="true"
                           Class="filter-select">
                    <MudSelectItem T="bool?" Value="@((bool?)true)">فيها متبقي</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">مسددة بالكامل</MudSelectItem>
                </MudSelect>

                <button class="reset-btn" @onclick="ResetFilters" title="إعادة تعيين">
                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                </button>
            </div>

            <div class="results-bar">
                <div class="results-count">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                    <span>عرض @_pagedResult.Items.Count من @_pagedResult.TotalCount فاتورة</span>
                </div>
            </div>
        </div>

        @if (_isTableLoading)
        {
            <div class="table-loading">
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            </div>
        }

        <!-- Table -->
        <div class="table-card">
            <MudTable Items="@_pagedResult.Items"
                      Hover="true"
                      Striped="true"
                      Dense="false"
                      FixedHeader="true"
                      Height="600px"
                      OnRowClick="@((TableRowClickEventArgs<InvoiceListDto> args) => GoToDetails(args.Item.TransactionId))"
                      RowClass="table-row"
                      Class="invoices-table">
                <HeaderContent>
                    <MudTh>رقم الفاتورة</MudTh>
                    <MudTh>التاريخ</MudTh>
                    <MudTh>@(_activeTab == "Purchase" ? "العميل (من فاتورة البيع)" : "العميل")</MudTh>
                    <MudTh>الإجمالي</MudTh>
                    <MudTh>المدفوع</MudTh>
                    <MudTh>المتبقي</MudTh>
                    <MudTh>الحالة</MudTh>
                    <MudTh>التسليم</MudTh>
                    <MudTh>إجراءات</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <span class="invoice-number">@(context.ReferenceNumber ?? $"#{context.TransactionId}")</span>
                    </MudTd>
                    <MudTd>
                        <div class="date-cell">
                            <span class="date-main">@context.TransactionDate.ToString("yyyy/MM/dd")</span>
                            @if (context.DueDate.HasValue)
                            {
                                <span class="date-due @(IsOverdue(context) ? "overdue" : "")">
                                    <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" />
                                    @context.DueDate.Value.ToString("yyyy/MM/dd")
                                </span>
                            }
                        </div>
                    </MudTd>
                    <MudTd>
                        <div class="customer-cell">
                            @if (_activeTab == "Purchase")
                            {
                                <span class="customer-name">@(context.EmpName ?? "-")</span>
                            }
                            else
                            {
                                <span class="customer-name">@context.PartyName</span>
                                @if (!string.IsNullOrEmpty(context.PartyPhone))
                                {
                                    <span class="customer-phone">
                                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                                        @context.PartyPhone
                                    </span>
                                }
                            }
                        </div>
                    </MudTd>
                    <MudTd><strong class="amount-total">@FormatMoney(context.GrandTotal)</strong></MudTd>
                    <MudTd><span class="amount-paid">@FormatMoney(context.PaidAmount)</span></MudTd>
                    <MudTd>
                        <span class="@(context.Remaining > 0 ? "amount-remaining" : "amount-zero")">
                            @FormatMoney(context.Remaining)
                        </span>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@GetStatusColor(context.InvoiceStatus)">
                            @GetStatusText(context.InvoiceStatus)
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        @if (context.IsDelivered == true)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                     Icon="@Icons.Material.Filled.LocalShipping">
                                تم
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                قيد التسليم
                            </MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        <div class="table-actions" @onclick:stopPropagation="true">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Size="Size.Small" Color="Color.Info"
                                           OnClick="() => GoToDetails(context.TransactionId)"
                                           Title="عرض" />
                            @if (_canEdit && context.InvoiceStatus != InvoiceStatuses.Cancelled)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Payment"
                                               Size="Size.Small" Color="Color.Success"
                                               OnClick="() => OpenAddPaymentDialog(context)"
                                               Title="إضافة دفعة"
                                               Disabled="@(context.Remaining <= 0)" />
                            }
                            @if (context.InvoiceStatus != InvoiceStatuses.Cancelled)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.EditNote"
                                               Size="Size.Small" Color="Color.Warning"
                                               OnClick="() => OpenEditRequestDialog(context)"
                                               Title="طلب تعديل" />
                            }
                            @if (_canDelete && context.InvoiceStatus != InvoiceStatuses.Cancelled)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="() => ConfirmCancel(context)"
                                               Title="إلغاء الفاتورة" />
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>

        <!-- Pagination -->
        @if (_pagedResult.TotalPages > 1)
        {
            <div class="pagination-container">
                <MudPagination Count="@_pagedResult.TotalPages"
                               Selected="@_filter.PageNumber"
                               SelectedChanged="OnPageChanged"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               ShowFirstButton="true"
                               ShowLastButton="true" />
            </div>
        }
    </div>
}

<!-- Cancel Dialog -->
<MudDialog @bind-Visible="_showCancelDialog">
    <TitleContent>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6">إلغاء الفاتورة</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText>
            هل تريد إلغاء الفاتورة <strong>@(_selectedInvoice?.ReferenceNumber ?? "")</strong>؟
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
            سيتم إعادة الكميات إلى المخزون وإلغاء الفاتورة المرآة (شراء) وأي دفعات مقدمة مرتبطة.
        </MudText>
        <MudTextField @bind-Value="_cancelReason"
                      Label="سبب الإلغاء"
                      Variant="Variant.Outlined"
                      Class="mt-3"
                      Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCancelDialog = false)" Variant="Variant.Outlined">
            تراجع
        </MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ExecuteCancel"
                   Disabled="@_isCancelling">
            @if (_isCancelling)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            تأكيد الإلغاء
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Add Payment Dialog -->
<MudDialog @bind-Visible="_showPaymentDialog">
    <TitleContent>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Payment" Color="Color.Success" />
            <MudText Typo="Typo.h6">إضافة دفعة</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-3">
            الفاتورة: <strong>@(_selectedInvoice?.ReferenceNumber ?? "")</strong>
        </MudText>
        <MudText Typo="Typo.body2" Class="mb-3">
            المتبقي: <strong style="color: var(--mud-palette-error);">
                @FormatMoney(_selectedInvoice?.Remaining ?? 0)
            </strong>
        </MudText>

        <MudNumericField @bind-Value="_paymentAmount"
                         Label="المبلغ"
                         Variant="Variant.Outlined"
                         Min="0.01m"
                         Max="@(_selectedInvoice?.Remaining ?? 0)"
                         Class="mb-3" />

        <MudSelect T="string" @bind-Value="_paymentMethod"
                   Label="طريقة الدفع"
                   Variant="Variant.Outlined"
                   Class="mb-3">
            @foreach (var pm in PaymentMethods.All)
            {
                <MudSelectItem T="string" Value="@pm.Key">@pm.Value</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="int?" @bind-Value="_paymentCashBoxId"
                   Label="الخزينة"
                   Variant="Variant.Outlined"
                   Class="mb-3">
            @foreach (var cb in _cashBoxes)
            {
                <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
            }
        </MudSelect>

        <MudTextField @bind-Value="_paymentNotes"
                      Label="ملاحظات"
                      Variant="Variant.Outlined"
                      Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showPaymentDialog = false)" Variant="Variant.Outlined">
            إلغاء
        </MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled"
                   OnClick="ExecuteAddPayment" Disabled="@_isSavingPayment">
            @if (_isSavingPayment)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            تسجيل الدفعة
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Edit Request Dialog -->
<MudDialog @bind-Visible="_showEditRequestDialog">
    <TitleContent>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Warning" />
            <MudText Typo="Typo.h6">طلب تعديل فاتورة</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText>
            فاتورة: <strong>@(_selectedInvoice?.ReferenceNumber ?? "")</strong>
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-2 mb-3" Style="color: var(--mud-palette-text-secondary);">
            سيتم إرسال طلب التعديل لمدير الحسابات والإدارة
        </MudText>
        <MudTextField @bind-Value="_editRequestReason"
                      Label="سبب التعديل *"
                      Variant="Variant.Outlined"
                      Lines="3"
                      Placeholder="اكتب سبب طلب التعديل..." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showEditRequestDialog = false)" Variant="Variant.Outlined">
            إلغاء
        </MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled"
                   OnClick="ExecuteEditRequest" Disabled="@_isSendingEditRequest">
            @if (_isSendingEditRequest)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            إرسال الطلب
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    /* ===== Page ===== */
    .invoices-page {
        padding: 1.5rem;
        max-width: 1600px;
        margin: 0 auto;
        direction: rtl;
    }

    /* ===== Header ===== */
    .page-header {
        position: relative;
        background: linear-gradient(135deg, #1a2842 0%, #2a3f6a 50%, #1a2842 100%);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .header-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d4af37' fill-opacity='0.06'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }

    .header-content {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.75rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-badge {
        width: 52px;
        height: 52px;
        background: linear-gradient(135deg, #d4af37, #f0d060);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a2842;
        font-size: 1.5rem;
        box-shadow: 0 4px 15px rgba(212,175,55,0.4);
    }

    .header-info h1 {
        color: white;
        font-size: 1.75rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .header-info p {
        color: rgba(255,255,255,0.7);
        margin: 0.25rem 0 0 0;
        font-size: 0.9rem;
    }

    .add-btn {
        background: linear-gradient(135deg, #d4af37, #f0d060) !important;
        color: #1a2842 !important;
        font-weight: 700 !important;
        border-radius: 12px !important;
        box-shadow: 0 4px 20px rgba(212,175,55,0.4) !important;
        transition: all 0.3s ease !important;
    }
    .add-btn:hover {
        transform: translateY(-2px) !important;
        box-shadow: 0 8px 25px rgba(212,175,55,0.5) !important;
    }

    /* ===== Stats ===== */
    .stats-row {
        position: relative;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(155px, 1fr));
        gap: 0.75rem;
    }

    .stat-card {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 14px;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }
    .stat-card:hover {
        background: rgba(255,255,255,0.15);
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    }

    .stat-icon-wrap {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .stat-total     { background: rgba(255,255,255,0.15); color: white; }
    .stat-sales     { background: rgba(16,185,129,0.25); color: #6ee7b7; }
    .stat-paid      { background: rgba(59,130,246,0.25); color: #93c5fd; }
    .stat-remaining { background: rgba(239,68,68,0.25); color: #fca5a5; }
    .stat-today     { background: rgba(245,158,11,0.25); color: #fcd34d; }
    .stat-overdue   { background: rgba(220,38,38,0.3); color: #fca5a5; }

    .stat-body { display: flex; flex-direction: column; min-width: 0; }
    .stat-value {
        font-size: 1.1rem;
        font-weight: 800;
        color: white;
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .stat-label {
        font-size: 0.72rem;
        color: rgba(255,255,255,0.6);
        margin-top: 0.15rem;
        white-space: nowrap;
    }

    /* ===== Tabs ===== */
    .tabs-container {
        margin-bottom: 1rem;
    }

    .tabs-group {
        display: inline-flex;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        padding: 4px;
        gap: 4px;
    }

    .tab-btn {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.55rem 1.25rem;
        border: none;
        border-radius: 10px;
        background: transparent;
        color: var(--mud-palette-text-secondary);
        font-family: inherit;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.25s ease;
    }
    .tab-btn:hover {
        background: var(--mud-palette-hover);
        color: var(--mud-palette-text-primary);
    }
    .tab-btn.tab-active {
        background: linear-gradient(135deg, #d4af37, #f0d060);
        color: #1a2842;
        box-shadow: 0 2px 10px rgba(212,175,55,0.3);
