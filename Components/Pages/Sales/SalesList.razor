@code {
    private bool _isLoading = true;
    private bool _isTableLoading = false;
    private bool _showCancelDialog = false;
    private bool _isCancelling = false;
    private bool _showPaymentDialog = false;
    private bool _isSavingPayment = false;
    private bool _showEditRequestDialog;
    private bool _isSendingEditRequest;
    private string? _editRequestReason;

    private InvoiceFilterDto _filter = new() { TransactionType = TransactionTypes.Sale };
    private PagedResult<InvoiceListDto> _pagedResult = new();
    private InvoiceStatsDto _stats = new();
    private InvoiceListDto? _selectedInvoice;
    private string? _cancelReason;

    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private decimal _paymentAmount;
    private string _paymentMethod = PaymentMethods.Cash;
    private int? _paymentCashBoxId;
    private string? _paymentNotes;
    private List<Models.CashBox> _cashBoxes = new();

    private string? _currentUserName;
    private bool _canView, _canAdd, _canEdit, _canDelete;
    private bool _canViewPurchases;
    private bool _canSeeAmounts;
    private string _activeTab = "Sale";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canView = user.HasClaim("Permission", "frm_PartiesInvoices:View") || user.IsInRole("Admin");
            _canAdd = user.HasClaim("Permission", "frm_PartiesInvoices:Add") || user.IsInRole("Admin");
            _canEdit = user.HasClaim("Permission", "frm_PartiesInvoices:Edit") || user.IsInRole("Admin");
            _canDelete = user.HasClaim("Permission", "frm_PartiesInvoices:Delete") || user.IsInRole("Admin");

            _canViewPurchases = user.IsInRole("Admin") || user.IsInRole("AccountManager") || user.IsInRole("Account");
            _canSeeAmounts = user.IsInRole("Admin") || user.IsInRole("AccountManager") || user.IsInRole("Account");

            if (!_canView)
            {
                Navigation.NavigateTo("/");
                return;
            }

            _cashBoxes = await InvoiceService.GetCashBoxesAsync();
            await LoadData();
            await LoadStats();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadData()
    {
        _isTableLoading = true;
        _pagedResult = await InvoiceService.GetInvoicesAsync(_filter);
        _isTableLoading = false;
    }

    private async Task LoadStats()
    {
        _stats = await InvoiceService.GetStatsAsync(_filter.DateFrom, _filter.DateTo, _activeTab);
    }

    private async Task OnSearchChanged()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnFilterChanged()
    {
        _filter.PageNumber = 1;
        await LoadData();
        await LoadStats();
    }

    private async Task OnDateFromChanged(DateTime? d)
    {
        _dateFrom = d;
        _filter.DateFrom = d;
        await OnFilterChanged();
    }

    private async Task OnDateToChanged(DateTime? d)
    {
        _dateTo = d;
        _filter.DateTo = d;
        await OnFilterChanged();
    }

    private async Task OnPageChanged(int page)
    {
        _filter.PageNumber = page;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _filter = new() { TransactionType = _activeTab };
        _dateFrom = null;
        _dateTo = null;
        await LoadData();
        await LoadStats();
    }

    private async Task SwitchTab(string tab)
    {
        _activeTab = tab;
        _filter.TransactionType = tab;
        _filter.PageNumber = 1;
        await LoadData();
        await LoadStats();
    }

    private void GoToAdd() => Navigation.NavigateTo("/sales/invoices/new");
    private void GoToDetails(int id) => Navigation.NavigateTo($"/sales/invoices/{id}");

    private void ConfirmCancel(InvoiceListDto invoice)
    {
        _selectedInvoice = invoice;
        _cancelReason = "";
        _showCancelDialog = true;
    }

    private async Task ExecuteCancel()
    {
        if (_selectedInvoice == null) return;
        if (string.IsNullOrWhiteSpace(_cancelReason))
        {
            Snackbar.Add("يرجى إدخال سبب الإلغاء", Severity.Warning);
            return;
        }

        _isCancelling = true;
        var (ok, msg) = await InvoiceService.CancelInvoiceAsync(
            _selectedInvoice.TransactionId, _cancelReason!, _currentUserName!);
        _isCancelling = false;
        _showCancelDialog = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) { await LoadData(); await LoadStats(); }
    }

    private void OpenAddPaymentDialog(InvoiceListDto invoice)
    {
        _selectedInvoice = invoice;
        _paymentAmount = invoice.Remaining;
        _paymentMethod = PaymentMethods.Cash;
        _paymentCashBoxId = _cashBoxes.FirstOrDefault()?.CashBoxId;
        _paymentNotes = null;
        _showPaymentDialog = true;
    }

    private async Task ExecuteAddPayment()
    {
        if (_selectedInvoice == null) return;
        if (_paymentAmount <= 0) { Snackbar.Add("أدخل مبلغاً صحيحاً", Severity.Warning); return; }

        _isSavingPayment = true;
        var (ok, msg) = await InvoiceService.AddPaymentAsync(
            _selectedInvoice.TransactionId, _paymentAmount, _paymentMethod,
            _paymentCashBoxId, _paymentNotes, _currentUserName!);
        _isSavingPayment = false;
        _showPaymentDialog = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) { await LoadData(); await LoadStats(); }
    }

    private void OpenEditRequestDialog(InvoiceListDto invoice)
    {
        _selectedInvoice = invoice;
        _editRequestReason = "";
        _showEditRequestDialog = true;
    }

    private async Task ExecuteEditRequest()
    {
        if (_selectedInvoice == null) return;
        if (string.IsNullOrWhiteSpace(_editRequestReason))
        {
            Snackbar.Add("يرجى إدخال سبب التعديل", Severity.Warning);
            return;
        }

        _isSendingEditRequest = true;

        try
        {
            await AuditService.LogAsync("Transactions", "EditRequest",
                _selectedInvoice.TransactionId.ToString(),
                (string?)null,
                (string?)$"فاتورة: {_selectedInvoice.ReferenceNumber} - السبب: {_editRequestReason} - بواسطة: {_currentUserName}",
                _currentUserName!);

            var title = "📝 طلب تعديل فاتورة";
            var message = $"طلب تعديل الفاتورة {_selectedInvoice.ReferenceNumber} " +
                          $"بواسطة {_currentUserName} - السبب: {_editRequestReason}";

            await NotifyService.NotifyRoleAsync(title, message, SystemRoles.AccountManager,
                _currentUserName!, "sales/invoices", "Transactions",
                _selectedInvoice.TransactionId);
            await NotifyService.NotifyRoleAsync(title, message, SystemRoles.Admin,
                _currentUserName!, "sales/invoices", "Transactions",
                _selectedInvoice.TransactionId);

            _showEditRequestDialog = false;
            Snackbar.Add("تم إرسال طلب التعديل بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSendingEditRequest = false;
        }
    }

    private string FormatMoney(decimal value) => $"{value:N2} ج";

    private string GetStatusText(string? status) => status switch
    {
        InvoiceStatuses.Open => "مفتوحة",
        InvoiceStatuses.PartiallyPaid => "مدفوعة جزئياً",
        InvoiceStatuses.Paid => "مدفوعة",
        InvoiceStatuses.Cancelled => "ملغية",
        _ => status ?? "-"
    };

    private Color GetStatusColor(string? status) => status switch
    {
        InvoiceStatuses.Paid => Color.Success,
        InvoiceStatuses.PartiallyPaid => Color.Warning,
        InvoiceStatuses.Cancelled => Color.Error,
        _ => Color.Info
    };

    private bool IsOverdue(InvoiceListDto inv) =>
        inv.DueDate.HasValue && inv.DueDate.Value < DateTime.Today && inv.Remaining > 0;
}