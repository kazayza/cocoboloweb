@page "/sales/invoices/{Id:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS
@inject IAuditService AuditService
@inject NotificationService NotifyService

@if (_isLoading)
{
    <div class="loading-container">
        <div class="loading-card">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.h6" Class="mt-4" Style="color: var(--gold);">جاري تحميل الفاتورة...</MudText>
        </div>
    </div>
}
else if (_details == null)
{
    <MudAlert Severity="Severity.Error" Class="ma-4">الفاتورة غير موجودة</MudAlert>
}
else
{
    var inv = _details.Invoice;
    var remaining = inv.GrandTotal - inv.PaidAmount;
    var paidPct = inv.GrandTotal == 0 ? 0 : Math.Round((inv.PaidAmount / inv.GrandTotal) * 100, 1);
    var isOverdue = inv.DueDate.HasValue && inv.DueDate.Value.Date < DateTime.Today && remaining > 0;

    <div class="invoice-details-page" dir="rtl">

        <!-- ================ HEADER ================ -->
        <div class="form-header">
            <div class="header-top">
                <div class="header-left">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                   Color="Color.Inherit" OnClick="GoBack" />
                    <div>
                        <h1>
                            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                            فاتورة @inv.ReferenceNumber
                        </h1>
                        <p>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(inv.InvoiceStatus)">
                                @GetStatusText(inv.InvoiceStatus)
                            </MudChip>
                            @if (isOverdue)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error"
                                         Icon="@Icons.Material.Filled.Warning">
                                    متأخرة
                                </MudChip>
                            }
                            @if (!string.IsNullOrEmpty(inv.EmpName))
                            {
                                <span> • الموظف: @inv.EmpName</span>
                            }
                        </p>
                    </div>
                </div>
                <div class="header-right">
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit" OnClick="GoBack"
                               StartIcon="@Icons.Material.Filled.ArrowBack">رجوع</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="OpenPrintPage"
                               StartIcon="@Icons.Material.Filled.Print" Class="print-btn">طباعة</MudButton>
                    @if (inv.InvoiceStatus != InvoiceStatuses.Cancelled)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.EditNote"
                                   OnClick="OpenEditRequestDialog">طلب تعديل</MudButton>
                    }
                    @if (_canEdit && inv.InvoiceStatus != InvoiceStatuses.Cancelled && remaining > 0)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Payment"
                                   OnClick="OpenAddPaymentDialog">إضافة دفعة</MudButton>
                    }
                </div>
            </div>

            <!-- ⭐ Quick Summary Cards -->
            <div class="header-summary">
                <div class="summary-pill">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    <div>
                        <span>العميل</span>
                        <strong>@inv.PartyName</strong>
                    </div>
                </div>
                <div class="summary-pill">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                    <div>
                        <span>التاريخ</span>
                        <strong>@inv.TransactionDate.ToString("yyyy/MM/dd")</strong>
                    </div>
                </div>
                <div class="summary-pill pill-total">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" />
                    <div>
                        <span>الإجمالي</span>
                        <strong>@FormatMoney(inv.GrandTotal) ج</strong>
                    </div>
                </div>
                <div class="summary-pill pill-paid">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                    <div>
                        <span>المدفوع (@paidPct%)</span>
                        <strong>@FormatMoney(inv.PaidAmount) ج</strong>
                    </div>
                </div>
                <div class="summary-pill @(remaining > 0 ? "pill-remaining" : "pill-done")">
                    <MudIcon Icon="@(remaining > 0 ? Icons.Material.Filled.Schedule : Icons.Material.Filled.Verified)"
                             Size="Size.Small" />
                    <div>
                        <span>المتبقي</span>
                        <strong>@FormatMoney(remaining) ج</strong>
                    </div>
                </div>
                @if (inv.DueDate.HasValue)
                {
                    <div class="summary-pill @(isOverdue ? "pill-overdue" : "")">
                        <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" />
                        <div>
                            <span>الاستحقاق</span>
                            <strong>@inv.DueDate.Value.ToString("yyyy/MM/dd")</strong>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ⭐ تنبيه التأخير -->
        @if (isOverdue)
        {
            var overdueDays = (DateTime.Today - inv.DueDate!.Value.Date).Days;
            <MudAlert Severity="Severity.Error" Class="mb-3" Icon="@Icons.Material.Filled.Warning"
                      Variant="Variant.Filled" Dense="true">
                ⚠️ هذه الفاتورة متأخرة عن الاستحقاق بـ <strong>@overdueDays يوم</strong>
                — المتبقي: <strong>@FormatMoney(remaining) ج</strong>
            </MudAlert>
        }

        <div class="details-grid">
            <div class="main-col">

                <!-- ================ بيانات الفاتورة ================ -->
                <MudPaper Class="info-section" Elevation="0">
                    <div class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                        <h3>بيانات الفاتورة</h3>
                    </div>
                    <div class="info-grid">
                        <div class="info-card">
                            <div class="info-card-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" />
                            </div>
                            <div>
                                <span>رقم الفاتورة</span>
                                <strong>@inv.ReferenceNumber</strong>
                            </div>
                        </div>
                        <div class="info-card">
                            <div class="info-card-icon">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" />
                            </div>
                            <div>
                                <span>التاريخ</span>
                                <strong>@inv.TransactionDate.ToString("yyyy/MM/dd")</strong>
                            </div>
                        </div>
                        <div class="info-card">
                            <div class="info-card-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            </div>
                            <div>
                                <span>العميل</span>
                                <strong>@inv.PartyName</strong>
                            </div>
                        </div>
                        <div class="info-card">
                            <div class="info-card-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" />
                            </div>
                            <div>
                                <span>الموظف</span>
                                <strong>@(inv.EmpName ?? "-")</strong>
                            </div>
                        </div>
                        <div class="info-card">
                            <div class="info-card-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" />
                            </div>
                            <div>
                                <span>تاريخ الاستحقاق</span>
                                <strong>
                                    @(inv.DueDate?.ToString("yyyy/MM/dd") ?? "-")
                                    @if (inv.DueDate.HasValue && inv.Items.Any(i => i.Period.HasValue && i.Period > 0))
                                    {
                                        var maxPeriod = inv.Items.Where(i => i.Period.HasValue).Max(i => i.Period.Value);
                                        <span class="period-hint">(أكبر فترة: @maxPeriod يوم)</span>
                                    }
                                </strong>
                            </div>
                        </div>
                        <div class="info-card">
                            <div class="info-card-icon">
                                <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" />
                            </div>
                            <div>
                                <span>طريقة الدفع</span>
                                <strong>@(GetPaymentMethodText(inv.PaymentMethod))</strong>
                            </div>
                        </div>
                        <div class="info-card">
                            <div class="info-card-icon">
                                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Size="Size.Small" />
                            </div>
                            <div>
                                <span>حالة التسليم</span>
                                <strong>
                                    @if (inv.IsDelivered == true)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">تم التسليم</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">قيد التسليم</MudChip>
                                    }
                                </strong>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(inv.MirrorPurchaseReferenceNumber))
                        {
                            <div class="info-card">
                                <div class="info-card-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" />
                                </div>
                                <div>
                                    <span>فاتورة الشراء المرتبطة</span>
                                    <strong>@inv.MirrorPurchaseReferenceNumber</strong>
                                </div>
                            </div>
                        }
                    </div>
                </MudPaper>

                <!-- ================ الأصناف ================ -->
                <MudPaper Class="info-section" Elevation="0">
                    <div class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                        <h3>الأصناف (@inv.Items.Count)</h3>
                    </div>
                    <MudTable Items="inv.Items" Dense="true" Hover="true" Striped="true"
                              Class="items-table" Elevation="0">
                        <HeaderContent>
                            <MudTh Style="width:80px;">الصورة</MudTh>
                            <MudTh>الصنف</MudTh>
                            <MudTh Style="width:100px;">الباقة</MudTh>
                            <MudTh Style="width:80px;">الكمية</MudTh>
                            <MudTh Style="width:100px;">السعر</MudTh>
                            <MudTh Style="width:110px;">الإجمالي</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <div class="item-img-wrapper" @onclick="@(() => OpenImagePreview(context.ProductId, context.ProductName))">
                                    <img src="/api/product-images/@context.ProductId"
                                         alt="@context.ProductName"
                                         class="item-thumb"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                    <div class="item-thumb-placeholder" style="display:none">📦</div>
                                    <div class="img-zoom-icon">
                                        <MudIcon Icon="@Icons.Material.Filled.ZoomIn" Size="Size.Small" />
                                    </div>
                                </div>
                            </MudTd>
                            <MudTd>
                                <div class="item-name">@context.ProductName</div>
                                @if (!string.IsNullOrEmpty(context.ProductDescription))
                                {
                                    <div class="item-desc">@context.ProductDescription</div>
                                }
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(context.PricingTier == PricingTiers.Elite ? Color.Warning : Color.Info)"
                                         Variant="Variant.Filled">
                                    @PricingTiers.All.GetValueOrDefault(context.PricingTier, context.PricingTier)
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <span class="qty-value">@context.Quantity</span>
                                @if (context.Period.HasValue && context.Period > 0)
                                {
                                    <div class="period-hint">@context.Period يوم</div>
                                }
                            </MudTd>
                            <MudTd>@FormatMoney(context.UnitPrice) ج</MudTd>
                            <MudTd>
                                <strong class="item-total">@FormatMoney(context.TotalAmount) ج</strong>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>

                <!-- ================ الرسوم الإضافية ================ -->
                @if (inv.Charges.Any())
                {
                    <MudPaper Class="info-section" Elevation="0">
                        <div class="section-title">
                            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Small" />
                            <h3>الرسوم الإضافية</h3>
                        </div>
                        <MudTable Items="inv.Charges" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>الوصف</MudTh>
                                <MudTh Style="width:130px;">المبلغ</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.ChargeDescription</MudTd>
                                <MudTd><strong>@FormatMoney(context.ChargeAmount) ج</strong></MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                }

                <!-- ================ سجل المدفوعات ================ -->
                <MudPaper Class="info-section" Elevation="0">
                    <div class="section-title">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Small" />
                        <h3>سجل المدفوعات (@_details.Payments.Count)</h3>
                    </div>
                    @if (!_details.Payments.Any())
                    {
                        <div class="empty-state">
                            <MudIcon Icon="@Icons.Material.Filled.MoneyOff" Size="Size.Large"
                                     Style="color:var(--mud-palette-text-secondary);" />
                            <MudText Typo="Typo.body2" Class="text-muted mt-2">لا توجد مدفوعات بعد</MudText>
                        </div>
                    }
                    else
                    {
                        <MudTable Items="_details.Payments" Dense="true" Hover="true"
                                  Striped="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>التاريخ</MudTh>
                                <MudTh>المبلغ</MudTh>
                                <MudTh>النسبة</MudTh>
                                <MudTh>الطريقة</MudTh>
                                <MudTh>الخزينة</MudTh>
                                <MudTh>ملاحظات</MudTh>
                                <MudTh>المستخدم</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <div class="payment-date">
                                        <MudIcon Icon="@Icons.Material.Filled.AccessTime"
                                                 Size="Size.Small" Class="me-1" />
                                        @context.PaymentDate.ToString("yyyy/MM/dd HH:mm")
                                    </div>
                                </MudTd>
                                <MudTd>
                                    <strong class="payment-amount">@FormatMoney(context.Amount) ج</strong>
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                             Variant="Variant.Filled">@context.Percentage%</MudChip>
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                             Variant="Variant.Outlined">
                                        @GetPaymentMethodText(context.PaymentMethod)
                                    </MudChip>
                                </MudTd>
                                <MudTd>@(context.CashBoxName ?? "-")</MudTd>
                                <MudTd>
                                    <span class="payment-notes">@(context.Notes ?? "-")</span>
                                </MudTd>
                                <MudTd>
                                    <span class="payment-user">@(context.CreatedBy ?? "-")</span>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>

                <!-- ================ ملاحظات ================ -->
                @if (!string.IsNullOrEmpty(inv.Notes))
                {
                    <MudPaper Class="info-section" Elevation="0">
                        <div class="section-title">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" />
                            <h3>ملاحظات</h3>
                        </div>
                        <div class="notes-content">
                            <MudText>@inv.Notes</MudText>
                        </div>
                    </MudPaper>
                }
            </div>

            <!-- ================ SIDEBAR ================ -->
            <div class="sidebar-col">
                <MudPaper Class="summary-card" Elevation="0">
                    <div class="summary-header">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                        <h3>الملخص المالي</h3>
                    </div>

                    <div class="summary-row">
                        <span>إجمالي الأصناف:</span>
                        <strong>@FormatMoney(inv.TotalAmount) ج</strong>
                    </div>

                    @if ((inv.DiscountAmount ?? 0) > 0)
                    {
                        <div class="summary-row discount-row">
                            <span>الخصم:</span>
                            <strong>-@FormatMoney(inv.DiscountAmount ?? 0) ج</strong>
                        </div>
                    }

                    <div class="summary-row">
                        <span>الصافي:</span>
                        <strong>@FormatMoney(inv.NetTotalAmount ?? 0) ج</strong>
                    </div>

                    @if (inv.TotalChargesAmount > 0)
                    {
                        <div class="summary-row">
                            <span>رسوم إضافية:</span>
                            <strong>+@FormatMoney(inv.TotalChargesAmount) ج</strong>
                        </div>
                    }

                    <div class="summary-divider"></div>

                    <div class="summary-row total-row">
                        <span>الإجمالي:</span>
                        <strong>@FormatMoney(inv.GrandTotal) ج</strong>
                    </div>

                    <div class="summary-row paid-row">
                        <span>المدفوع:</span>
                        <strong>@FormatMoney(inv.PaidAmount) ج</strong>
                    </div>

                    <div class="summary-row">
                        <span>نسبة السداد:</span>
                        <strong>@paidPct%</strong>
                    </div>

                    <div class="progress-bar">
                        <div class="progress-fill @(isOverdue ? "progress-overdue" : "")"
                             style="width: @Math.Min(100, (double)paidPct).ToString("F0")%;"></div>
                    </div>

                    <div class="summary-divider"></div>

                    <div class="summary-row remaining-row">
                        <span>المتبقي:</span>
                        <strong class="@(remaining > 0 ? "remaining-danger" : "remaining-success")">
                            @FormatMoney(remaining) ج
                        </strong>
                    </div>

                    @if (isOverdue)
                    {
                        <div class="overdue-alert">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                            <span>متأخرة عن الاستحقاق بـ @((DateTime.Today - inv.DueDate!.Value.Date).Days) يوم</span>
                        </div>
                    }
                </MudPaper>
            </div>
        </div>
    </div>
}

<!-- ================ Image Preview Dialog ================ -->
<MudDialog @bind-Visible="_showImagePreview">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@_previewProductName</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="image-preview-container">
            <img src="/api/product-images/@_previewProductId"
                 alt="@_previewProductName"
                 class="image-preview-full" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showImagePreview = false)" Variant="Variant.Outlined">إغلاق</MudButton>
    </DialogActions>
</MudDialog>

<!-- ================ Payment Dialog ================ -->
<MudDialog @bind-Visible="_showPaymentDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.Payment" Color="Color.Success" />
            <MudText Typo="Typo.h6">إضافة دفعة</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @{
            var payRemaining = (_details?.Invoice.GrandTotal ?? 0) - (_details?.Invoice.PaidAmount ?? 0);
            var grand = _details?.Invoice.GrandTotal ?? 0;
        }
        <MudText Class="mb-2">
            المتبقي:
            <strong style="color:var(--mud-palette-error);">@FormatMoney(payRemaining) ج</strong>
        </MudText>

        @if (grand > 0)
        {
            <div class="quick-pay-row mb-3">
                <span style="font-size:0.85rem; font-weight:600;">دفع سريع:</span>
                @foreach (var pct in SystemConstants.QuickPayPercentages)
                {
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                               OnClick="@(() => SetPaymentByPct(pct))">@pct%</MudButton>
                }
                <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success"
                           OnClick="@(() => _paymentAmount = payRemaining)">كامل</MudButton>
            </div>
        }

        <MudNumericField @bind-Value="_paymentAmount" Label="المبلغ"
                         Variant="Variant.Outlined" Min="0.01m" Max="@payRemaining" Class="mb-2" />

        @if (grand > 0 && _paymentAmount > 0)
        {
            var payPct = Math.Round((_paymentAmount / grand) * 100, 1);
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                هذه الدفعة تساوي <strong>@payPct%</strong> من إجمالي الفاتورة
            </MudAlert>
        }

        <MudSelect T="string" @bind-Value="_paymentMethod" Label="طريقة الدفع"
                   Variant="Variant.Outlined" Class="mb-3">
            @foreach (var pm in PaymentMethods.All)
            {
                <MudSelectItem T="string" Value="@pm.Key">@pm.Value</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="int?" @bind-Value="_paymentCashBoxId" Label="الخزينة"
                   Variant="Variant.Outlined" Class="mb-3">
            @foreach (var cb in _cashBoxes)
            {
                <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="_paymentNotes" Label="ملاحظات"
                      Variant="Variant.Outlined" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showPaymentDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled"
                   OnClick="ExecuteAddPayment" Disabled="@_isSavingPayment">
            @if (_isSavingPayment)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            تسجيل
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- ================ Edit Request Dialog ================ -->
<MudDialog @bind-Visible="_showEditRequestDialog">
    <TitleContent>
        <div style="display:flex; align-items:center; gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Warning" />
            <MudText Typo="Typo.h6">طلب تعديل فاتورة</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText>فاتورة: <strong>@(_details?.Invoice?.ReferenceNumber)</strong></MudText>
        <MudText Typo="Typo.body2" Class="mt-2 mb-3" Style="color:var(--mud-palette-text-secondary);">
            سيتم إرسال طلب التعديل لمدير الحسابات والإدارة
        </MudText>
        <MudTextField @bind-Value="_editRequestReason" Label="سبب التعديل *"
                      Variant="Variant.Outlined" Lines="3"
                      Placeholder="اكتب سبب طلب التعديل..." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showEditRequestDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled"
                   OnClick="ExecuteEditRequest" Disabled="@_isSendingEditRequest">
            @if (_isSendingEditRequest)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            إرسال الطلب
        </MudButton>
    </DialogActions>
</MudDialog>

