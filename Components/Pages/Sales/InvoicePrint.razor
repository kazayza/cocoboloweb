@page "/sales/invoices/{Id:int}/print"
@layout COCOBOLOERPNEW.Components.Layout.EmptyLayout

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (_isLoading)
{
    <div class="loading-container">
        <MudProgressCircular Color="Color.Primary"
                             Size="Size.Large"
                             Indeterminate="true" />
    </div>
}
else if (_data == null)
{
    <div class="not-found">
        <h2>الفاتورة غير موجودة</h2>
    </div>
}
else
{
    var inv = _data.Invoice;

    <div class="print-actions no-print">
        <button class="btn-action btn-print" @onclick="PrintNow">
            🖨️ طباعة
        </button>
        @*<button class="btn-action btn-pdf" @onclick="ExportPdf">
            📄 تصدير PDF
        </button>*@
        <button class="btn-action btn-back" @onclick="GoBack">
            ← رجوع
        </button>
    </div>

    @* ============================================ *@
    @* صفحات المنتجات                                *@
    @* ============================================ *@
    @foreach (var page in PagedItems.Select((items, index) => new { items, index }))
    {
        bool isFirstPage = page.index == 0;

        <div class="print-page">
            <div class="content" dir="rtl">

                @if (isFirstPage)
                {
                    <div class="invoice-top-meta">
                        <div class="meta-type">
                            @(inv.TransactionType == TransactionTypes.Purchase
                                ? "فاتورة مشتريات"
                                : "فاتورة مبيعات")
                        </div>
                        <div class="meta-number">
                            @inv.ReferenceNumber
                        </div>
                        <div class="meta-date">
                            @inv.TransactionDate.ToString("yyyy/MM/dd")
                        </div>
                    </div>

                    <!-- بيانات العميل والفاتورة -->
                    <div class="party-grid">
                        <div class="party-box">
                            @if (inv.TransactionType == TransactionTypes.Purchase)
                            {
                                <h3>المورد / العميل</h3>
                                <div class="party-line">
                                    <strong>المورد:</strong> المصنع
                                </div>
                                <div class="party-line separator-top">
                                    <strong>العميل:</strong> @(inv.EmpName ?? "-")
                                </div>
                            }
                            else
                            {
                                <h3>العميل</h3>
                                <div class="party-line">
                                    <strong>الاسم:</strong> @inv.PartyName
                                </div>
                                @if (!string.IsNullOrWhiteSpace(_data.CustomerPhone))
                                {
                                    <div class="party-line">
                                        <strong>الهاتف:</strong> @_data.CustomerPhone
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_data.CustomerEmail))
                                {
                                    <div class="party-line">
                                        <strong>البريد:</strong> @_data.CustomerEmail
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_data.CustomerAddress))
                                {
                                    <div class="party-line">
                                        <strong>العنوان:</strong> @_data.CustomerAddress
                                    </div>
                                }
                            }
                        </div>

                        <div class="party-box">
                            <h3>تفاصيل الفاتورة</h3>
                            <div class="party-line">
                                <strong>
                                    @(inv.TransactionType == TransactionTypes.Purchase
                                        ? "فاتورة مشتريات"
                                        : "فاتورة مبيعات")
                                </strong>
                                -
                                <span style="color:#b8860b;font-weight:700;">
                                    @inv.ReferenceNumber
                                </span>
                            </div>
                            <div class="party-line">
                                <strong>تاريخ التعاقد:</strong>
                                @inv.TransactionDate.ToString("yyyy/MM/dd")
                            </div>
                            @if (inv.DueDate.HasValue)
                            {
                                <div class="party-line">
                                    <strong>تاريخ الاستلام:</strong>
                                    @inv.DueDate.Value.ToString("yyyy/MM/dd")
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(inv.EmpName))
                            {
                                <div class="party-line">
                                    <strong>المهندس المسئول:</strong> @inv.EmpName
                                </div>
                            }
                            <div class="party-line">
                                <strong>الحالة:</strong>
                                <span class="status-badge status-@(inv.InvoiceStatus?.ToLower())">
                                    @GetStatusText(inv.InvoiceStatus)
                                </span>
                            </div>
                        </div>
                    </div>
                }

                <!-- جدول المنتجات -->
                <table class="items-table">
                    <thead>
                        <tr>
                            <th style="width:40px;">#</th>
                            <th style="width:115px;">صورة القطعة</th>
                            <th>الوصف</th>
                            <th style="width:70px;">الكمية</th>
                            <th style="width:90px;">السعر</th>
                            <th style="width:100px;">الإجمالي</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = 0;
                            for (int p = 0; p < page.index; p++)
                            {
                                rowIndex += PagedItems[p].Count;
                            }
                        }

                        @foreach (var item in page.items)
                        {
                            rowIndex++;
                            <tr>
                                <td class="text-center">@rowIndex</td>
                                <td class="text-center">
                                    <img src="/api/product-images/@item.ProductId"
                                         alt="@item.ProductName"
                                         class="product-img"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                    <div class="img-placeholder" style="display:none">📦</div>
                                </td>
                                <td>
                                    <strong>@item.ProductName</strong>
                                    @if (!string.IsNullOrWhiteSpace(item.ProductDescription))
                                    {
                                        <div class="item-desc">@item.ProductDescription</div>
                                    }
                                </td>
                                <td class="text-center">@FormatMoney(item.Quantity, 0)</td>
                                <td class="text-end">@FormatMoney(item.UnitPrice)</td>
                                <td class="text-end">
                                    <strong>@FormatMoney(item.TotalAmount)</strong>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    }

    @* ============================================ *@
    @* صفحة الإجماليات والتوقيعات (منفصلة دائماً)      *@
    @* ============================================ *@
    <div class="print-page">
        <div class="content summary-page-content" dir="rtl">

            <div class="summary-page-header">
                <h2>الملخص المالي</h2>
                <p>@inv.ReferenceNumber</p>
            </div>

            @if (inv.Charges.Any())
            {
                <table class="charges-table">
                    <thead>
                        <tr>
                            <th colspan="2" class="charges-title">رسوم إضافية</th>
                        </tr>
                        <tr>
                            <th>الوصف</th>
                            <th style="width:130px;">المبلغ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ch in inv.Charges)
                        {
                            <tr>
                                <td>@ch.ChargeDescription</td>
                                <td class="text-end">@FormatMoney(ch.ChargeAmount)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <table class="summary-table summary-large">
                <tr>
                    <td>إجمالي الأصناف:</td>
                    <td>@FormatMoney(inv.TotalAmount) ج</td>
                </tr>
                @if ((inv.DiscountAmount ?? 0) > 0)
                {
                    <tr>
                        <td>الخصم:</td>
                        <td class="text-error">-@FormatMoney(inv.DiscountAmount ?? 0) ج</td>
                    </tr>
                }
                <tr>
                    <td>الصافي:</td>
                    <td>@FormatMoney(inv.NetTotalAmount ?? 0) ج</td>
                </tr>
                @if (inv.TotalChargesAmount > 0)
                {
                    <tr>
                        <td>رسوم إضافية:</td>
                        <td>+@FormatMoney(inv.TotalChargesAmount) ج</td>
                    </tr>
                }
                <tr class="total-row">
                    <td><strong>الإجمالي النهائي:</strong></td>
                    <td><strong>@FormatMoney(inv.GrandTotal) ج</strong></td>
                </tr>
                <tr class="paid-row">
                    <td>المدفوع:</td>
                    <td>@FormatMoney(inv.PaidAmount) ج</td>
                </tr>
                <tr class="remaining-row">
                    <td><strong>المتبقي:</strong></td>
                    <td><strong>@FormatMoney(inv.GrandTotal - inv.PaidAmount) ج</strong></td>
                </tr>
            </table>

            @if (!string.IsNullOrWhiteSpace(inv.Notes))
            {
                <div class="notes-box notes-large">
                    <strong>ملاحظات:</strong>
                    <p>@inv.Notes</p>
                </div>
            }

            <div class="signatures signatures-large">
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-label">توقيع الموظف</div>
                    <div class="signature-name">@(inv.EmpName ?? "")</div>
                </div>
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-label">توقيع العميل</div>
                    <div class="signature-name">@inv.PartyName</div>
                </div>
            </div>

        </div>
    </div>

    @* ============================================ *@
    @* صفحة الشروط والأحكام                           *@
    @* ============================================ *@
    <div class="print-page">
        <div class="content terms-content" dir="rtl">

            <div class="invoice-top-meta">
                <div class="meta-type" style="color:#c62828;">شروط وأحكام</div>
                <div class="meta-number">@inv.ReferenceNumber</div>
                <div class="meta-date">@inv.TransactionDate.ToString("yyyy/MM/dd")</div>
            </div>

            <div class="terms-header">شروط وأحكام التعاقد</div>

            <ul class="terms-list">
                <li>
                    فترة الضمان تصل إلى
                    <span class="highlight">5 سنوات</span>
                    من تاريخ الاستلام ضد عيوب الصناعة و صيانة مدى الحياة.
                </li>
                <li>
                    الأسعار غير شاملة تكاليف أي معدات و أدوات مناولة خاصة مثل
                    ( أوناش أو كلارك أو هاند ليفت ...الخ ).
                </li>
                <li>
                    يسقط الضمان بمجرد نقل المنتج من مكان إلى آخر أو إعادة الفك أو التركيب بمعرفة العميل.
                </li>
                <li>
                    يحق للعميل إلغاء أو تعديل التعاقد فقط في خلال
                    <span class="highlight">يومان</span>
                    من تاريخ التعاقد بدون أي خصومات.
                </li>
                <li>
                    في حالة رغبة العميل في إلغاء التعاقد و ذلك بعد مرور
                    <span class="highlight">3 أيام</span>
                    يتم خصم
                    <span class="highlight">50%</span>
                    من قيمة البند أو إضافتها في حال التعديل.
                </li>
                <li>
                    في حالة رغبة العميل في إلغاء التعاقد أو التعديل في بند محدد و ذلك بعد مرور
                    <span class="highlight">4 أيام</span>
                    أو أكثر يتم خصم كامل قيمة البند أو إضافته في حال التعديل.
                </li>
                <li>
                    في حالة وجود عيب صناعة بالمنتج تقوم الشركة بإصلاح أو استبدال الجزء محل العيب فقط وليس كامل المنتج.
                </li>
                <li>
                    يوقع العميل أو من ينوب عنه إذن استلام للمنتج بمجرد استلامه ومعاينته المعاينة التامة.
                </li>
                <li>
                    لا يتم الاستلام إلا بعد سداد كامل القيمة و في حالة تأخير العميل في الاستلام يجب سداد المبلغ كاملا بمجرد الانتهاء من التشطيب.
                </li>
                <li>
                    يتم احتساب مدة التعاقد من وقت سداد
                    <span class="highlight">70%</span>
                    من إجمالى قيمة التعاقد ولا يحق للعميل فسخ التعاقد واسترداد الدفعة المقدمة بعد البدء فى التنفيذ.
                </li>
                <li>
                    تحديد موعد استلام أو خدمات ما بعد البيع يتم الاتصال على
                    <span class="highlight">(01090707897)</span>
                    وذلك قبل
                    <span class="highlight">15 يوما</span>
                    على الأقل.
                </li>
                <li>
                    يجوز للعميل تغيير موعد الاستلام المتفق عليه مسبقا وذلك قبل تاريخ الاستلام بـ
                    <span class="highlight">7 أيام</span>
                    على الأقل.
                </li>
                <li>
                    تخلى الشركة مسئوليتها عن خدمة النقل والتركيب عند تغيير العميل لموعد الاستلام أكثر من
                    <span class="highlight">مرتين</span>
                    أو قبل الاستلام بأقل من
                    <span class="highlight">48 ساعة</span>.
                </li>
                <li>
                    ملاءمة المنتج لموقع العميل من حيث المقاسات والذوق العام هو مسئولية العميل وحده فقط دون غيره حيث أن المنتجات تم تصنيعها خصيصا بناء على طلبه وبالمواصفات المحددة من قبله.
                </li>
                <li>
                    بمجرد استلام العميل للمنتج لا يجوز استبدالها أو استرجاعها وإنما يسرى عليها شروط وأحكام الضمان وخدمة ما بعد البيع.
                </li>
            </ul>

            <div class="payment-terms-block">
                <div class="payment-title">شروط الدفعات</div>
                <ul class="terms-list">
                    <li><span class="highlight">70%</span> مقدم تعاقد</li>
                    <li><span class="highlight">20%</span> بعد صورة النجار</li>
                    <li><span class="highlight">10%</span> قبل التسليم</li>
                </ul>
            </div>

            <div class="signatures">
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-label">توقيع العميل</div>
                </div>
                <div class="signature-box">
                    <div class="signature-line"></div>
                    <div class="signature-label">توقيع الشركة</div>
                </div>
            </div>

        </div>
    </div>
}

<style>
    body {
        margin: 0;
        padding: 0;
        background: #f2f2f2;
        font-family: 'Segoe UI', 'Tajawal', sans-serif;
    }

    .loading-container,
    .not-found {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
    }

    /* ======================================== */
    /* ACTIONS                                  */
    /* ======================================== */
    .print-actions {
        position: fixed;
        top: 1rem;
        left: 1rem;
        display: flex;
        gap: .5rem;
        z-index: 9999;
    }

    .btn-action {
        border: none;
        border-radius: 8px;
        padding: .7rem 1.4rem;
        cursor: pointer;
        font-weight: 700;
    }

    .btn-print {
        background: #d4af37;
        color: white;
    }

    .btn-pdf {
        background: #c62828;
        color: white;
    }

    .btn-back {
        background: #ddd;
    }

    /* ======================================== */
    /* PAGE                                     */
    /* ======================================== */
    .print-page {
        width: 210mm;
        height: 297mm;
        margin: 1rem auto;
        position: relative;
        background-image: url('/images/design-background.png');
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
        overflow: hidden;
        box-shadow: 0 0 10px rgba(0,0,0,.15);
        page-break-after: always;
        box-sizing: border-box;
    }

    .content {
        position: relative;
        height: 100%;
        padding-top: 42mm;
        padding-bottom: 38mm;
        padding-left: 12mm;
        padding-right: 12mm;
        box-sizing: border-box;
    }

    .invoice-top-meta {
        position: absolute;
        top: 14mm;
        left: 14mm;
        width: 52mm;
        text-align: center;
        z-index: 5;
    }

    .meta-type {
        font-size: .95rem;
        font-weight: 700;
        color: #1a2842;
        margin-bottom: .3rem;
    }

    .meta-number {
        font-size: .88rem;
        font-weight: 600;
        color: #444;
        margin-bottom: .2rem;
        letter-spacing: .5px;
    }

    .meta-date {
        font-size: .8rem;
        color: #666;
    }

    /* ======================================== */
    /* PARTY GRID                               */
    /* ======================================== */
    .party-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .party-box {
        background: #faf6e8;
        border: 1px solid #d4af3744;
        border-radius: 10px;
        padding: 1rem;
    }

    .party-box h3 {
        margin: 0 0 .45rem 0;
        font-size: .88rem;
        color: #1a2842;
        padding-bottom: .35rem;
        border-bottom: 1px solid #d4af3744;
    }

    .party-line {
        font-size: .76rem;
        margin: .18rem 0;
        line-height: 1.45;
    }

    .separator-top {
        margin-top: .5rem;
        padding-top: .5rem;
        border-top: 1px dashed #ccc;
    }

    /* ======================================== */
    /* STATUS                                   */
    /* ======================================== */
    .status-badge {
        display: inline-block;
        padding: .2rem .6rem;
        border-radius: 5px;
        font-size: .75rem;
        font-weight: 700;
    }

    .status-paid {
        background: #d4edda;
        color: #155724;
    }

    .status-partiallypaid {
        background: #fff3cd;
        color: #856404;
    }

    .status-open {
        background: #d1ecf1;
        color: #0c5460;
    }

    .status-cancelled {
        background: #f8d7da;
        color: #721c24;
    }

    /* ======================================== */
    /* TABLES                                   */
    /* ======================================== */
    .items-table,
    .charges-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1rem;
        font-size: .82rem;
        background: white;
    }

    .items-table th,
    .items-table td,
    .charges-table th,
    .charges-table td {
        border: 1px solid #ddd;
        padding: .5rem;
        vertical-align: middle;
    }

    .items-table thead th,
    .charges-table thead th {
        background: #1a2842;
        color: white;
        font-weight: 700;
    }

    .charges-title {
        background: #d4af37 !important;
        text-align: center;
    }

    .items-table tr {
        break-inside: avoid;
        page-break-inside: avoid;
    }

    .items-table tbody tr:nth-child(even) td {
        background: #fafafa;
    }

    /* ======================================== */
    /* IMAGES                                   */
    /* ======================================== */
    .product-img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #ddd;
    }

    .img-placeholder {
        width: 100px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f5f5;
        border-radius: 6px;
        border: 1px dashed #ccc;
        margin: auto;
    }

    .item-desc {
        font-size: .72rem;
        color: #777;
        margin-top: .2rem;
    }

    /* ======================================== */
    /* SUMMARY PAGE                             */
    /* ======================================== */
    .summary-page-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .summary-page-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 3px double #d4af37;
    }

    .summary-page-header h2 {
        font-size: 1.8rem;
        color: #1a2842;
        margin: 0 0 .5rem 0;
    }

    .summary-page-header p {
        font-size: 1.1rem;
        color: #b8860b;
        font-weight: 700;
        margin: 0;
    }

    .summary-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
    }

    .summary-table td {
        border-bottom: 1px solid #eee;
        padding: .5rem;
    }

    .summary-table td:last-child {
        text-align: left;
        font-weight: 700;
    }

    .summary-large {
        font-size: .95rem !important;
        width: 80%;
        margin: 0 auto;
    }

    .summary-large td {
        padding: .8rem .5rem !important;
    }

    .summary-large .total-row td {
        font-size: 1.1rem !important;
    }

    .total-row td {
        background: #faf6e8;
        border-top: 2px solid #d4af37;
        border-bottom: 2px solid #d4af37;
        font-size: 1rem;
    }

    .paid-row td {
        color: #2e7d32;
    }

    .remaining-row td {
        background: #fff5f5;
        color: #c62828;
    }

    .notes-box {
        background: #fafafa;
        border-right: 3px solid #d4af37;
        padding: .8rem;
        border-radius: 8px;
    }

    .notes-large {
        margin-top: 1.5rem;
        font-size: .9rem;
    }

    /* ======================================== */
    /* SIGNATURES                               */
    /* ======================================== */
    .signatures {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        margin-top: 2rem;
    }

    .signatures-large {
        width: 80%;
        margin: 2rem auto 0 auto;
    }

    .signature-box {
        text-align: center;
    }

    .signature-line {
        border-top: 1px solid #333;
        margin-top: 2.5rem;
        margin-bottom: .5rem;
    }

    .signature-label {
        font-weight: 700;
    }

    .signature-name {
        margin-top: .3rem;
        color: #666;
        font-size: .8rem;
    }

    /* ======================================== */
    /* TERMS                                    */
    /* ======================================== */
    .terms-header {
        text-align: center;
        font-size: 1.35rem;
        font-weight: 800;
        color: #1a2842;
        margin-bottom: 1rem;
        padding-bottom: .5rem;
        border-bottom: 2px solid #d4af37;
        letter-spacing: .5px;
        font-family: Arial, sans-serif;
    }

    .terms-list {
        padding: 0;
        margin: 0;
        margin-bottom: .5rem;
