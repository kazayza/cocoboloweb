@code {
    [Parameter]
    public int Id { get; set; }

    private bool _isLoading = true;
    private InvoicePrintDto? _data;

    private const int FirstPageItems = 5;
    private const int MiddlePageItems = 7;

    private List<List<InvoiceItemDto>> PagedItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await InvoiceService.GetInvoiceForPrintAsync(Id);

            if (_data != null)
            {
                PagedItems = new();
                var items = _data.Invoice.Items.ToList();

                if (items.Any())
                {
                    // أول صفحة: 6 منتجات
                    PagedItems.Add(items.Take(FirstPageItems).ToList());

                    // باقي الصفحات: 7 منتجات لكل صفحة
                    var remaining = items.Skip(FirstPageItems).ToList();

                    while (remaining.Any())
                    {
                        PagedItems.Add(remaining.Take(MiddlePageItems).ToList());
                        remaining = remaining.Skip(MiddlePageItems).ToList();
                    }
                }
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PrintNow()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task ExportPdf()
    {
        await JS.InvokeVoidAsync("open", $"/api/invoices/{Id}/pdf", "_blank");
    }

    private void GoBack()
    {
        Navigation.NavigateTo($"/sales/invoices/{Id}");
    }

    private string FormatMoney(decimal value, int decimals = 2)
{
    return value.ToString($"N{decimals}");
}

    private string GetStatusText(string? status)
    {
        return status switch
        {
            InvoiceStatuses.Open => "مفتوحة",
            InvoiceStatuses.PartiallyPaid => "مدفوعة جزئياً",
            InvoiceStatuses.Paid => "مدفوعة",
            InvoiceStatuses.Cancelled => "ملغية",
            _ => status ?? "-"
        };
    }
}