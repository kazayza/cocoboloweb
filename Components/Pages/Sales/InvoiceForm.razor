@page "/sales/invoices/new"
@page "/sales/invoices/{Id:int}/edit"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services

@inject IInvoiceService InvoiceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider

@if (_isLoading)
{
    <div class="loading-container">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Class="mt-4" Style="color: var(--gold);">جاري التحميل...</MudText>
    </div>
}
else
{
    <div class="invoice-form-page" dir="rtl">

        <!-- Header -->
        <div class="form-header">
            <div class="header-left">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                               Color="Color.Inherit"
                               OnClick="GoBack"
                               Size="Size.Large" />
                <div>
                                        <h1>
                        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                        @if (IsEdit && _form.TransactionType == TransactionTypes.Purchase)
                        {
                            <span>فاتورة مشتريات</span>
                        }
                        else if (IsEdit)
                        {
                            <span>فاتورة مبيعات</span>
                        }
                        else
                        {
                            <span>فاتورة مبيعات جديدة</span>
                        }
                    </h1>
                    <p>
                        @if (IsEdit && _form.TransactionType == TransactionTypes.Purchase)
                        {
                            <span>@_form.ReferenceNumber</span>
                        }
                        else if (IsEdit)
                        {
                            <span>@_form.ReferenceNumber</span>
                        }
                        else
                        {
                            <span>إنشاء فاتورة جديدة وفاتورة شراء مرتبطة تلقائياً</span>
                        }
                    </p>
                </div>
            </div>
            <div class="header-right">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Inherit"
                           OnClick="GoBack"
                           StartIcon="@Icons.Material.Filled.Close">
                    إلغاء
                </MudButton>
                @if (!IsEdit)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveInvoice"
                               Disabled="@_isSaving"
                               Class="save-btn">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                        }
                        حفظ الفاتورة
                    </MudButton>
                }
            </div>
        </div>

        <div class="form-grid">
            <!-- Main Column -->
            <div class="main-col">

                <!-- 1) Invoice Info -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Description" />
                        <h3>بيانات الفاتورة</h3>
                    </div>
                    @if (IsEdit && _form.TransactionType == TransactionTypes.Purchase)
                    {
                        <MudAlert Severity="Severity.Info" Class="mb-3" Icon="@Icons.Material.Filled.Link">
                            <strong>المورد:</strong> المصنع
                            <span style="margin: 0 0.5rem;">|</span>
                            <strong>العميل (من فاتورة البيع):</strong> @(_form.EmpName ?? "-")
                        </MudAlert>
                    }
                    <div class="grid-2">
                        <MudTextField @bind-Value="_form.ReferenceNumber"
                                      Label="رقم الفاتورة"
                                      Variant="Variant.Outlined"
                                      ReadOnly="@IsEdit"
                                      HelperText="اتركه فاضي للتوليد التلقائي" />

                        <MudDatePicker Date="_form.TransactionDate"
                                       DateChanged="@(d => _form.TransactionDate = d ?? DateTime.Now)"
                                       Label="تاريخ الفاتورة"
                                       Variant="Variant.Outlined"
                                       ReadOnly="@IsEdit" />

                        <MudSelect T="int?" @bind-Value="_form.WarehouseId"
                                   Label="المخزن *"
                                   Variant="Variant.Outlined"
                                   Disabled="@IsEdit">
                            @foreach (var w in _warehouses)
                            {
                                <MudSelectItem T="int?" Value="@((int?)w.WarehouseId)">@w.WarehouseName</MudSelectItem>
                            }
                        </MudSelect>

                        <MudDatePicker Date="_form.DueDate"
                                       DateChanged="@(d => _form.DueDate = d)"
                                       Label="تاريخ التسليم"
                                       Variant="Variant.Outlined"
                                       Clearable="true" />
                    </div>
                </MudPaper>

                <!-- 2) Customer Selection -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                        <h3>العميل</h3>
                    </div>

                    <MudAutocomplete T="PartyLookupDto"
                                     Label="ابحث عن العميل بالاسم أو الهاتف *"
                                     Value="_selectedParty"
                                     ValueChanged="OnPartySelected"
                                     SearchFunc="SearchParties"
                                     ToStringFunc="@(p => p == null ? "" : p.PartyName)"
                                     Variant="Variant.Outlined"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="true"
                                     Disabled="@IsEdit"
                                     MinCharacters="1">
                        <ItemTemplate Context="party">
                            <div style="display:flex; flex-direction:column; gap:0.25rem;">
                                <strong>@party.PartyName</strong>
                                <span style="font-size:0.78rem; color:var(--mud-palette-text-secondary);">
                                    @if (!string.IsNullOrEmpty(party.Phone))
                                    {
                                        <span>📞 @party.Phone</span>
                                    }
                                    @if (!string.IsNullOrEmpty(party.City))
                                    {
                                        <span> • @party.City</span>
                                    }
                                    @if (party.AdvanceBalance > 0)
                                    {
                                        <span style="color:var(--mud-palette-success); font-weight:700;">
                                            • 💰 رصيد دفعات مقدمة: @($"{party.AdvanceBalance:N2}") ج
                                        </span>
                                    }
                                </span>
                            </div>
                        </ItemTemplate>
                    </MudAutocomplete>

                    @if (_advances.Any() && !IsEdit)
                    {
                        <MudAlert Severity="Severity.Info"
                                  Class="mt-3"
                                  Icon="@Icons.Material.Filled.Savings">
                            <MudText Typo="Typo.body2">
                                <strong>هذا العميل لديه دفعات مقدمة سابقة بإجمالي
                                    @FormatMoney(_advances.Sum(a => a.ChargeAmount)) ج</strong>
                                — اختر التي تود خصمها من هذه الفاتورة:
                            </MudText>

                            <div class="advances-list mt-2">
                                @foreach (var adv in _advances)
                                {
                                    <div class="advance-row">
                                        <MudCheckBox T="bool"
                                                     Value="@_form.SelectedAdvanceChargeIds.Contains(adv.ChargeId)"
                                                     ValueChanged="@(v => ToggleAdvance(adv.ChargeId, v))"
                                                     Color="Color.Success"
                                                     Dense="true">
                                            <strong>@FormatMoney(adv.ChargeAmount) ج</strong>
                                            — @adv.ChargeDescription
                                            <span class="advance-date">
                                                (@adv.CreatedAt?.ToString("yyyy/MM/dd"))
                                            </span>
                                        </MudCheckBox>
                                    </div>
                                }
                            </div>
                        </MudAlert>
                    }
                </MudPaper>

                <!-- 3) Items -->
                                <!-- 3) Items -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                            <h3>الأصناف (@_form.Items.Count)</h3>
                        </div>
                    </div>

                    @if (!IsEdit && _form.PartyId.HasValue && !_availableProducts.Any())
                    {
                        <div class="empty-items">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" />
                            <p>لا توجد منتجات متاحة لهذا العميل</p>
                        </div>
                    }
                    else if (!IsEdit && !_form.PartyId.HasValue)
                    {
                        <div class="empty-items">
                            <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Size="Size.Large" />
                            <p>اختر العميل أولاً لعرض المنتجات المتاحة</p>
                        </div>
                    }

                    <!-- شبكة المنتجات المتاحة -->
                    @if (!IsEdit && _availableProducts.Any())
                    {
                        <div class="products-grid">
                            @foreach (var prod in _availableProducts)
                            {
                                var isAdded = _form.Items.Any(i => i.ProductId == prod.ProductId);
                                <div class="product-card @(isAdded ? "product-added" : "")">
                                    <div class="product-card-img">
    <img src="/api/product-images/@prod.ProductId"
         alt="@prod.ProductName"
         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
    <div class="img-placeholder-sm" style="display:none">📦</div>
</div>
                                    <div class="product-card-info">
                                        <strong class="product-card-name">@prod.ProductName</strong>
                                        @if (!string.IsNullOrEmpty(prod.ProductDescription))
                                        {
                                            <span class="product-card-desc">@prod.ProductDescription</span>
                                        }
                                                                                <div class="product-card-pricing">
                                            @if (prod.PricingType == PricingTiers.CClass)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Dense="true">C Class</MudChip>
                                                <span class="product-card-price">@($"{(prod.SuggestedSalePriceCClass ?? 0):N2}") ج</span>
                                            }
                                            else if (prod.PricingType == PricingTiers.Elite)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Dense="true">Elite</MudChip>
                                                <span class="product-card-price">@($"{(prod.SuggestedSalePriceElite ?? prod.SuggestedSalePrice ?? 0):N2}") ج</span>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Dense="true">Premium</MudChip>
                                                <span class="product-card-price">@($"{(prod.SuggestedSalePrice ?? 0):N2}") ج</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="product-card-action">
                                        @if (isAdded)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                                     Icon="@Icons.Material.Filled.Check">تمت الإضافة</MudChip>
                                        }
                                        else
                                        {
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                                       Size="Size.Small" FullWidth="true"
                                                       StartIcon="@Icons.Material.Filled.Add"
                                                       OnClick="@(() => AddProductToInvoice(prod))">
                                                إضافة
                                            </MudButton>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- جدول الأصناف المضافة -->
                    @if (_form.Items.Any())
                    {
                        <div class="items-table mt-4">
                            <div class="items-header">
                                <div class="col-product">الصنف</div>
                                <div class="col-tier">الباقة</div>
                                <div class="col-qty">الكمية</div>
                                <div class="col-price">السعر</div>
                                <div class="col-total">الإجمالي</div>
                                <div class="col-action"></div>
                            </div>

                            @for (int i = 0; i < _form.Items.Count; i++)
                            {
                                var item = _form.Items[i];
                                var index = i;
                                <div class="item-row">
                                    <div class="col-product">
                                        <strong>@item.ProductName</strong>
                                        @if (!string.IsNullOrEmpty(item.ProductDescription))
                                        {
                                            <div class="item-name-display">@item.ProductDescription</div>
                                        }
                                    </div>
                                    <div class="col-tier">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(item.PricingTier == PricingTiers.CClass ? Color.Secondary : item.PricingTier == PricingTiers.Elite ? Color.Warning : Color.Info)">
                                            @PricingTiers.All.GetValueOrDefault(item.PricingTier, item.PricingTier)
                                        </MudChip>
                                    </div>
                                    <div class="col-qty">
                                        <MudNumericField Value="item.Quantity"
                                                         ValueChanged="@((decimal v) => { item.Quantity = v; RecalculateTotals(); })"
                                                         T="decimal"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="0.01m"
                                                         Step="1m"
                                                         Disabled="@IsEdit" />
                                    </div>
                                    <div class="col-price">
                                        <MudNumericField Value="item.UnitPrice"
                                                         ValueChanged="@((decimal v) => { item.UnitPrice = v; RecalculateTotals(); })"
                                                         T="decimal"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="0m"
                                                         Step="1m"
                                                         Disabled="@IsEdit" />
                                    </div>
                                    <div class="col-total"><strong>@FormatMoney(item.TotalAmount) ج</strong></div>
                                    <div class="col-action">
                                        @if (!IsEdit)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => RemoveItem(index))" />
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </MudPaper>

                <!-- 4) Charges -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header" style="justify-content: space-between;">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" />
                            <h3>رسوم إضافية (@_form.Charges.Count)</h3>
                        </div>
                        @if (!IsEdit)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="AddCharge"
                                       Size="Size.Small">
                                إضافة رسم
                            </MudButton>
                        }
                    </div>

                    @if (_form.Charges.Any())
                    {
                        @for (int i = 0; i < _form.Charges.Count; i++)
                        {
                            var ch = _form.Charges[i];
                            var index = i;
                            <div class="charge-row">
                                <MudTextField @bind-Value="ch.ChargeDescription"
                                              Placeholder="مثل: شحن، تركيب..."
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Disabled="@IsEdit" />
                                <MudNumericField Value="ch.ChargeAmount"
                                                 ValueChanged="@((decimal v) => { ch.ChargeAmount = v; RecalculateTotals(); })"
                                                 T="decimal"
                                                 Label="المبلغ"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense"
                                                 Min="0m"
                                                 Disabled="@IsEdit" />
                                @if (!IsEdit)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="@(() => RemoveCharge(index))" />
                                }
                            </div>
                        }
                    }
                </MudPaper>

                <!-- 5) Notes -->
                <MudPaper Class="form-section" Elevation="0">
                    <div class="section-header">
                        <MudIcon Icon="@Icons.Material.Filled.Notes" />
                        <h3>ملاحظات</h3>
                    </div>
                    <MudTextField @bind-Value="_form.Notes"
                                  Placeholder="ملاحظات على الفاتورة..."
                                  Variant="Variant.Outlined"
                                  Lines="3" />
                </MudPaper>
            </div>

            <!-- Sidebar -->
            <div class="sidebar-col">
                <MudPaper Class="summary-card" Elevation="0">
                    <h3>ملخص الفاتورة</h3>

                    <div class="summary-row">
                        <span>إجمالي الأصناف:</span>
                        <strong>@FormatMoney(_form.TotalAmount) ج</strong>
                    </div>

                    <div class="summary-row">
                        <span>خصم %:</span>
                        <MudNumericField Value="_form.DiscountPercentage"
                                         ValueChanged="@((decimal? v) => { _form.DiscountPercentage = v; RecalculateTotals(); })"
                                         T="decimal?"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0m" Max="100m" Step="1m"
                                         Style="max-width:100px;"
                                         Disabled="@IsEdit" />
                    </div>

                    <div class="summary-row">
                        <span>قيمة الخصم:</span>
                        <strong style="color:var(--mud-palette-error);">
                            -@FormatMoney(_form.DiscountAmount ?? 0) ج
                        </strong>
                    </div>

                    <div class="summary-row">
                        <span>الصافي:</span>
                        <strong>@FormatMoney(_form.NetTotalAmount ?? 0) ج</strong>
                    </div>

                    <div class="summary-row">
                        <span>رسوم إضافية:</span>
                        <strong>+@FormatMoney(_form.TotalChargesAmount) ج</strong>
                    </div>

                    <div class="summary-divider"></div>

                    <div class="summary-row total-row">
                        <span>الإجمالي النهائي:</span>
                        <strong>@FormatMoney(_form.GrandTotal) ج</strong>
                    </div>

                    <div class="summary-divider"></div>

                    @{
                        var advanceTotal = _advances
                            .Where(a => _form.SelectedAdvanceChargeIds.Contains(a.ChargeId))
                            .Sum(a => a.ChargeAmount);
                    }

                    @if (advanceTotal > 0)
                    {
                        <div class="summary-row paid-row">
                            <span>دفعات مقدمة مطبقة:</span>
                            <strong style="color:var(--mud-palette-success);">
                                @FormatMoney(advanceTotal) ج
                            </strong>
                        </div>
                    }

                    @if (!IsEdit)
                    {
                        <div class="payment-section">
                            <h4>دفعة فورية</h4>
                            <MudNumericField @bind-Value="_form.PaidAmount"
                                             Label="المبلغ المدفوع"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Min="0m"
                                             Max="@(_form.GrandTotal - advanceTotal)"
                                             Class="mb-2" />

                            @if (_form.PaidAmount > 0)
                            {
                                <MudSelect T="string" @bind-Value="_form.PaymentMethod"
                                           Label="طريقة الدفع"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Class="mb-2">
                                    @foreach (var pm in PaymentMethods.All)
                                    {
                                        <MudSelectItem T="string" Value="@pm.Key">@pm.Value</MudSelectItem>
                                    }
                                </MudSelect>

                                <MudSelect T="int?" @bind-Value="_form.CashBoxId"
                                           Label="الخزينة"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense">
                                    @foreach (var cb in _cashBoxes)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="summary-row paid-row">
                            <span>المدفوع:</span>
                            <strong style="color:var(--mud-palette-success);">
                                @FormatMoney(_form.PaidAmount) ج
                            </strong>
                        </div>
                    }

                    <div class="summary-divider"></div>
                    @{
                        var totalPaid = advanceTotal + (IsEdit ? 0 : _form.PaidAmount);
                        var remaining = _form.GrandTotal - totalPaid;
                        if (IsEdit) remaining = _form.GrandTotal - _form.PaidAmount;
                    }
                    <div class="summary-row remaining-row">
                        <span>المتبقي:</span>
                        <strong style="color: @(remaining > 0 ? "var(--mud-palette-error)" : "var(--mud-palette-success)");">
                            @FormatMoney(remaining) ج
                        </strong>
                    </div>

                    @if (!IsEdit)
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="SaveInvoice"
                                   Disabled="@_isSaving"
                                   Class="save-btn-full mt-3">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                            }
                            حفظ الفاتورة
                        </MudButton>

                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2" Icon="@Icons.Material.Filled.Info">
                            <small>سيتم إنشاء فاتورة شراء مرتبطة تلقائياً</small>
                        </MudAlert>
                    }
                </MudPaper>
            </div>
        </div>
    </div>
}

<style>
    .invoice-form-page {
        padding: 1rem;
        max-width: 1800px;
        margin: 0 auto;
        direction: rtl;
    }

    .form-header {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        color: white;
    }

    .header-left { display: flex; align-items: center; gap: 1rem; }
    .header-left h1 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .header-left p {
        margin: 0.25rem 0 0 0;
        font-size: 0.85rem;
        color: rgba(255,255,255,0.85);
    }
    .header-right { display: flex; gap: 0.5rem; }

    .save-btn {
        background: rgba(255,255,255,0.95) !important;
        color: var(--navy-dark) !important;
        font-weight: 700 !important;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 1.5rem;
    }

    .main-col, .sidebar-col {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-section {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 14px;
        padding: 1.25rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .section-header h3 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 700;
    }

    .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    .advances-list { display: flex; flex-direction: column; gap: 0.25rem; }
    .advance-row {
        background: rgba(16,185,129,0.08);
        border-radius: 8px;
        padding: 0.25rem 0.5rem;
    }
    .advance-date { font-size: 0.78rem; color: var(--mud-palette-text-secondary); }

    .empty-items {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 2rem;
        color: var(--mud-palette-text-secondary);
    }

    .items-table { display: flex; flex-direction: column; gap: 0.5rem; }
    .items-header {
        display: grid;
        grid-template-columns: 2.5fr 1fr 0.8fr 1fr 1fr 50px;
        gap: 0.5rem;
        padding: 0.5rem;
        background: var(--mud-palette-background);
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.85rem;
    }
    .item-row {
        display: grid;
