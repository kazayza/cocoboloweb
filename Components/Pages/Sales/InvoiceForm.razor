@code {
    [Parameter] public int? Id { get; set; }
    private bool IsEdit => Id.HasValue && Id.Value > 0;

    private bool _isLoading = true;
    private bool _isSaving = false;

    private InvoiceFormDto _form = new();
    private PartyLookupDto? _selectedParty;
    private List<CustomerAdvanceDto> _advances = new();

    private List<Models.Warehouse> _warehouses = new();
    private List<Models.CashBox> _cashBoxes = new();

    // تم الاستغناء عنه - المنتجات بتتضاف من الشبكة مباشرة
    private List<ProductLookupDto> _availableProducts = new();

    private string? _currentUserName;
    private bool _canAdd, _canEdit;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canAdd = user.HasClaim("Permission", "frm_SalesInvoiveNew:Add") || user.IsInRole("Admin");
            _canEdit = user.HasClaim("Permission", "frm_SalesInvoiveNew:Edit") || user.IsInRole("Admin");

            if (!IsEdit && !_canAdd) { Navigation.NavigateTo("/sales"); return; }

            _warehouses = await InvoiceService.GetWarehousesAsync();
            _cashBoxes = await InvoiceService.GetCashBoxesAsync();

            if (IsEdit)
            {
                var loaded = await InvoiceService.GetInvoiceForEditAsync(Id!.Value);
                if (loaded == null)
                {
                    Snackbar.Add("الفاتورة غير موجودة", Severity.Error);
                    Navigation.NavigateTo("/sales");
                    return;
                }
                _form = loaded;
                if (_form.PartyId.HasValue)
                {
                    _selectedParty = new PartyLookupDto
                    {
                        PartyId = _form.PartyId.Value,
                        PartyName = _form.PartyName ?? ""
                    };
                }
            }
            else
            {
                if (_warehouses.Any())
                    _form.WarehouseId = _warehouses.First().WarehouseId;
                _form.ReferenceNumber = await InvoiceService.GenerateNextInvoiceNumberAsync(TransactionTypes.Sale);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ============================
    // Party
    // ============================
    private async Task<IEnumerable<PartyLookupDto>> SearchParties(string value, CancellationToken token)
    {
        return await InvoiceService.SearchPartiesAsync(value);
    }

           private async Task OnPartySelected(PartyLookupDto? party)
    {
        _selectedParty = party;
        _form.PartyId = party?.PartyId;
        _form.PartyName = party?.PartyName;
        _form.SelectedAdvanceChargeIds.Clear();
        _form.Items.Clear();
        _availableProducts.Clear();

        if (party != null)
        {
            _advances = await InvoiceService.GetCustomerAdvancesAsync(party.PartyId, unappliedOnly: true);
            _availableProducts = await InvoiceService.SearchProductsForPartyAsync(party.PartyId, null);
        }
        else
        {
            _advances = new();
            _availableProducts = new();
        }
        StateHasChanged();
    }
            private void AddProductToInvoice(ProductLookupDto prod)
    {
        if (_form.Items.Any(i => i.ProductId == prod.ProductId)) return;

        string tier;
        decimal price;

        if (prod.PricingType == PricingTiers.CClass)
        {
            tier = PricingTiers.CClass;
            price = prod.SuggestedSalePriceCClass ?? 0;
        }
        else if (prod.PricingType == PricingTiers.Elite)
        {
            tier = PricingTiers.Elite;
            price = prod.SuggestedSalePriceElite ?? prod.SuggestedSalePrice ?? 0;
        }
        else
        {
            tier = PricingTiers.Premium;
            price = prod.SuggestedSalePrice ?? 0;
        }

        var item = new InvoiceItemDto
        {
            ProductId = prod.ProductId,
            ProductName = prod.ProductName,
            ProductDescription = prod.ProductDescription,
            ProductImagePath = prod.ImagePath,
            Quantity = 1,
            UnitPrice = price,
            PricingTier = tier,
            AvailableStock = prod.AvailableStock,
            SalePriceCClass = prod.SuggestedSalePriceCClass,
            SalePricePremium = prod.SuggestedSalePrice,
            SalePriceElite = prod.SuggestedSalePriceElite,
            PurchasePriceCClass = prod.PurchasePriceCClass,
            PurchasePricePremium = prod.PurchasePrice,
            PurchasePriceElite = prod.PurchasePriceElite,
            Period = prod.Period
        };

        _form.Items.Add(item);
        RecalculateTotals();
        CalculateDueDate();
    }

    

    private void ToggleAdvance(int chargeId, bool selected)
    {
        if (selected)
        {
            if (!_form.SelectedAdvanceChargeIds.Contains(chargeId))
                _form.SelectedAdvanceChargeIds.Add(chargeId);
        }
        else
        {
            _form.SelectedAdvanceChargeIds.Remove(chargeId);
        }
        StateHasChanged();
    }

    // ============================
    // Items
    // ============================
    

    

        
        private void CalculateDueDate()
    {
        var maxPeriod = _form.Items
            .Where(i => i.ProductId > 0 && i.Period.HasValue)
            .Select(i => i.Period.Value)
            .DefaultIfEmpty(0)
            .Max();

        if (maxPeriod > 0)
        {
            _form.DueDate = _form.TransactionDate.AddDays(maxPeriod);
        }
        StateHasChanged();
    }

    

   

        private void RemoveItem(int index)
    {
        _form.Items.RemoveAt(index);
        RecalculateTotals();
        CalculateDueDate();
    }

    // ============================
    // Charges
    // ============================
    private void AddCharge()
    {
        _form.Charges.Add(new InvoiceChargeDto());
        StateHasChanged();
    }

    private void RemoveCharge(int index)
    {
        _form.Charges.RemoveAt(index);
        RecalculateTotals();
    }

    // ============================
    // Calculations
    // ============================
    private void RecalculateTotals()
    {
        _form.TotalAmount = Math.Round(_form.Items.Sum(i => i.TotalAmount), 2);

        if (_form.DiscountPercentage.HasValue && _form.DiscountPercentage.Value > 0)
            _form.DiscountAmount = Math.Round(_form.TotalAmount * (_form.DiscountPercentage.Value / 100m), 2);
        else
            _form.DiscountAmount = 0;

        _form.NetTotalAmount = _form.TotalAmount - (_form.DiscountAmount ?? 0);
        _form.TotalChargesAmount = Math.Round(_form.Charges.Sum(c => c.ChargeAmount), 2);
        _form.GrandTotal = (_form.NetTotalAmount ?? 0) + _form.TotalChargesAmount;

        StateHasChanged();
    }

    // ============================
    // Save
    // ============================
    private async Task SaveInvoice()
    {
        if (IsEdit) return;

        RecalculateTotals();

        var advanceTotal = _advances
            .Where(a => _form.SelectedAdvanceChargeIds.Contains(a.ChargeId))
            .Sum(a => a.ChargeAmount);

        if (_form.PaidAmount + advanceTotal > _form.GrandTotal)
        {
            Snackbar.Add("إجمالي المدفوع أكبر من إجمالي الفاتورة", Severity.Warning);
            return;
        }

        _isSaving = true;
        try
        {
            var (ok, msg, id, _) = await InvoiceService.CreateInvoiceAsync(_form, _currentUserName!);
            if (ok)
            {
                Snackbar.Add(msg, Severity.Success);
                Navigation.NavigateTo($"/sales/invoices/{id}");
            }
            else
            {
                Snackbar.Add(msg, Severity.Error);
            }
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/sales");

    private string FormatMoney(decimal value) => $"{value:N2}";
}
