@code {
    private bool _isLoading = true;
    private string _currentUserName = "User";
    private string _currentUserRole = "";
    private string _greetingIcon = "👋";
    private string _greetingMessage = "أهلاً بك";
    private string _greetingSubtext = "";

    // Permissions
    private bool _canViewSales = false;
    private bool _canViewQuotes = false;
    private bool _canViewCustomers = true;
    private bool _canViewCashBox = false;
    private bool _canAddCustomer = false;
    private bool _canAddProduct = false;
    private bool _canAddQuote = false;
    private bool _canAddInvoice = false;
    private bool _canAddCashBox = false;
    private bool _canAddInspection = false;
    private bool _canAddComplaint = false;

    private bool _fabOpen = false;

    // Data
    private HomeStats _stats = new();
    private QuotationStatsDto _quoteStats = new();
    private List<RecentInvoice> _recentInvoices = new();
    private List<RecentQuote> _recentQuotes = new();
    private List<AttentionItem> _attentionItems = new();
    private List<DailySales> _chartData = new();
    private int _unreadNotifications = 0;
    private List<Notification> _notifications = new();
    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _currentUserName = user.Identity?.Name ?? "User";
            _currentUserRole = user.FindFirst(ClaimTypes.Role)?.Value ?? "User";

            UpdateGreeting();
            SetPermissions();

            await LoadStats();
            if (_canViewSales) await LoadRecentInvoices();
            if (_canViewQuotes) await LoadRecentQuotes();
            await LoadNotifications();
            await LoadAttentionItems();
            if (_canViewSales) await LoadChartData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في التحميل: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                try
                {
                    await InvokeAsync(async () =>
                    {
                        await LoadNotifications();
                        StateHasChanged();
                    });
                }
                catch { }
            }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
    }

    public void Dispose() => _refreshTimer?.Dispose();

    private void UpdateGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 12) { _greetingIcon = "🌅"; _greetingMessage = $"صباح الخير، {_currentUserName}"; _greetingSubtext = "ابدأ يومك بإنجاز جديد وحقق أهدافك"; }
        else if (hour < 18) { _greetingIcon = "☀️"; _greetingMessage = $"مساء النور، {_currentUserName}"; _greetingSubtext = "تابع إنجازاتك واستثمر وقتك بفعالية"; }
        else { _greetingIcon = "🌙"; _greetingMessage = $"مساء الخير، {_currentUserName}"; _greetingSubtext = "ختام يوم مثمر بإذن الله"; }
    }

    private void SetPermissions()
    {
        var role = _currentUserRole?.Trim().ToLower() ?? "";

        bool isAdmin = role == "admin";
        bool isAccountant = role == "accountant" || role == "محاسب";
        bool isAccMgr = role == "accountingmanager" || role == "مدير الحسابات";
        bool isSales = role == "sales" || role == "مبيعات";
        bool isFactory = role == "factory" || role == "مصنع" || role == "إنتاج";
        bool isSalesManager =role == "salesmanager" || role == "مدير المبيعات";

        _canViewSales = isAdmin || isAccountant || isAccMgr || isSales;
        _canViewQuotes = isAdmin || isAccountant || isAccMgr || isSales;
        _canViewCustomers = true;
        _canViewCashBox = isAdmin || isAccountant || isAccMgr;

        _canAddCustomer = isAdmin || isAccountant || isAccMgr || isSales;
        _canAddProduct = isAdmin || isAccountant || isAccMgr || isFactory;
        _canAddQuote = isAdmin || isAccountant || isAccMgr || isSales;
        _canAddInvoice = isAdmin || isAccountant || isAccMgr || isSales;
        _canAddCashBox = isAdmin || isAccountant || isAccMgr;
        _canAddInspection = isAdmin || isAccountant || isAccMgr || isSales;
        _canAddComplaint= isAdmin || isAccMgr || isSalesManager || isSales;
    }

    private void ToggleFab() => _fabOpen = !_fabOpen;
    private void NavTo(string url) { _fabOpen = false; Navigation.NavigateTo(url); }

    // ════════════ DATA LOADING (same as previous version) ════════════
    private async Task LoadStats()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var today = DateTime.Today;
            var thisMonthStart = new DateTime(today.Year, today.Month, 1);
            var lastMonthStart = thisMonthStart.AddMonths(-1);

            _stats.CustomersCount = await db.Parties.AsNoTracking().CountAsync();
            _stats.ActiveCustomers = await db.Parties.AsNoTracking().CountAsync(p => p.IsActive == true);

            if (_canViewSales)
            {
                var salesQuery = db.Transactions.AsNoTracking()
                    .Where(t => t.TransactionType == "Sale" && t.TransactionDate >= thisMonthStart);
                _stats.InvoicesCount = await salesQuery.CountAsync();
                _stats.InvoicesTotal = await salesQuery.SumAsync(t => (decimal?)t.GrandTotal) ?? 0;

                var lastMonthSales = await db.Transactions.AsNoTracking()
                    .Where(t => t.TransactionType == "Sale"
                             && t.TransactionDate >= lastMonthStart
                             && t.TransactionDate < thisMonthStart)
                    .SumAsync(t => (decimal?)t.GrandTotal) ?? 0;

                if (lastMonthSales > 0)
                {
                    _stats.SalesGrowth = Math.Round(
                        ((_stats.InvoicesTotal - lastMonthSales) / lastMonthSales) * 100, 1);
                }
            }

            if (_canViewCashBox)
            {
                var cashBoxes = await CashBoxService.GetCashBoxesAsync(true);
                _stats.CashBoxBalance = cashBoxes.Sum(c => c.CurrentBalance);
            }
        }
        catch (Exception ex) { Console.WriteLine($"[LoadStats] {ex.Message}"); }
    }

    private async Task LoadRecentInvoices()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var transactions = await db.Transactions.AsNoTracking()
                .Where(t => t.TransactionType == "Sale")
                .OrderByDescending(t => t.TransactionDate)
                .Take(5)
                .Select(t => new
                {
                    t.TransactionId, t.PartyId, t.GrandTotal,
                    t.InvoiceStatus, t.TransactionDate
                })
                .ToListAsync();

            if (!transactions.Any()) { _recentInvoices = new(); return; }

            var partyIds = transactions.Select(t => t.PartyId).Distinct().ToList();
            var parties = await db.Parties.AsNoTracking()
                .Where(p => partyIds.Contains(p.PartyId))
                .Select(p => new { p.PartyId, p.PartyName })
                .ToListAsync();
            var partyDict = parties.ToDictionary(p => p.PartyId, p => p.PartyName ?? "غير محدد");

            _recentInvoices = transactions.Select(t => new RecentInvoice
            {
                TransactionId = t.TransactionId,
                PartyName = partyDict.TryGetValue(t.PartyId, out var pn) ? pn : "غير محدد",
                GrandTotal = t.GrandTotal,
                InvoiceStatus = t.InvoiceStatus ?? "Open",
                Date = t.TransactionDate
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadRecentInvoices] {ex.Message}");
            _recentInvoices = new();
        }
    }

    private async Task LoadRecentQuotes()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var quotes = await db.Quotations.AsNoTracking()
                .OrderByDescending(q => q.QuotationDate)
                .Take(5)
                .Select(q => new
                {
                    q.QuotationId, q.ReferenceNumber, q.QuotationDate,
                    q.PartyId, q.GrandTotal, q.TotalAmount, q.Status
                })
                .ToListAsync();

            if (quotes.Any())
            {
                var partyIds = quotes.Select(q => q.PartyId).Distinct().ToList();
                var parties = await db.Parties.AsNoTracking()
                    .Where(p => partyIds.Contains(p.PartyId))
                    .Select(p => new { p.PartyId, p.PartyName })
                    .ToListAsync();
                var partyDict = parties.ToDictionary(p => p.PartyId, p => p.PartyName ?? "غير محدد");

                _recentQuotes = quotes.Select(q => new RecentQuote
                {
                    QuotationId = q.QuotationId,
                    ReferenceNumber = q.ReferenceNumber ?? $"QT-{q.QuotationDate.Year}-{q.QuotationId:D5}",
                    PartyName = partyDict.TryGetValue(q.PartyId, out var pn) ? pn : "غير محدد",
                    GrandTotal = q.GrandTotal ?? q.TotalAmount,
                    Status = string.IsNullOrEmpty(q.Status) ? "Draft" : q.Status,
                    QuotationDate = q.QuotationDate
                }).ToList();
            }

            var totalQuotes = await db.Quotations.AsNoTracking().CountAsync();
            var convertedQuotes = await db.Quotations.AsNoTracking().CountAsync(q => q.InvoiceId != null);
            var pendingQuotes = await db.Quotations.AsNoTracking()
                .CountAsync(q => (q.Status == "Draft" || q.Status == "Sent") && q.InvoiceId == null);

            _quoteStats = new QuotationStatsDto
            {
                TotalCount = totalQuotes,
                ConvertedCount = convertedQuotes,
                DraftCount = pendingQuotes,
                ConversionRate = totalQuotes > 0
                    ? Math.Round(((decimal)convertedQuotes / totalQuotes) * 100, 1)
                    : 0
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadRecentQuotes] {ex.Message}");
            _recentQuotes = new();
        }
    }

    private async Task LoadChartData()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var startDate = DateTime.Today.AddDays(-6);
            var transactions = await db.Transactions.AsNoTracking()
                .Where(t => t.TransactionType == "Sale" && t.TransactionDate >= startDate)
                .Select(t => new { Date = t.TransactionDate.Date, Amount = t.GrandTotal })
                .ToListAsync();

            _chartData = new();
            for (int i = 0; i < 7; i++)
            {
                var date = startDate.AddDays(i);
                var amount = transactions.Where(t => t.Date == date).Sum(t => t.Amount);
                _chartData.Add(new DailySales { Date = date, Amount = amount });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadChartData] {ex.Message}");
            _chartData = new();
        }
    }

    private async Task LoadNotifications()
    {
        try
        {
            _unreadNotifications = await NotificationService.GetUnreadCountAsync(_currentUserName, _currentUserRole);
            _notifications = await NotificationService.GetLatestAsync(_currentUserName, _currentUserRole, 8);
        }
        catch { _notifications = new(); }
    }

    private async Task LoadAttentionItems()
    {
        if (!_canViewQuotes) { _attentionItems = new(); return; }

        var items = new List<AttentionItem>();
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();

            var pendingQuotes = await db.Quotations.AsNoTracking()
                .CountAsync(q => (q.Status == "Sent" || q.Status == "Draft") && q.InvoiceId == null);
            if (pendingQuotes > 0)
                items.Add(new AttentionItem { Emoji = "⏳", Title = $"{pendingQuotes} عرض سعر في انتظار رد", Description = "تابع مع العملاء", Link = "/quotations?status=Sent", Severity = "medium" });

            var threeDaysLater = DateTime.Today.AddDays(3);
            var expiringQuotes = await db.Quotations.AsNoTracking()
                .CountAsync(q => q.ValidUntil.HasValue && q.ValidUntil.Value.Date >= DateTime.Today && q.ValidUntil.Value.Date <= threeDaysLater && q.InvoiceId == null && q.Status != "Rejected" && q.Status != "Expired");
            if (expiringQuotes > 0)
                items.Add(new AttentionItem { Emoji = "⚠️", Title = $"{expiringQuotes} عرض ينتهي خلال 3 أيام", Description = "تواصل مع العملاء قبل الانتهاء", Link = "/quotations", Severity = "high" });

            var expiredCount = await db.Quotations.AsNoTracking()
                .CountAsync(q => q.ValidUntil.HasValue && q.ValidUntil.Value.Date < DateTime.Today && q.InvoiceId == null && q.Status != "Rejected" && q.Status != "Expired");
            if (expiredCount > 0)
                items.Add(new AttentionItem { Emoji = "⏰", Title = $"{expiredCount} عرض منتهي الصلاحية", Description = "يحتاج مراجعة", Link = "/quotations", Severity = "low" });

            var acceptedNotConverted = await db.Quotations.AsNoTracking()
                .CountAsync(q => q.Status == "Accepted" && q.InvoiceId == null);
            if (acceptedNotConverted > 0)
                items.Add(new AttentionItem { Emoji = "✅", Title = $"{acceptedNotConverted} عرض مقبول جاهز للتحويل", Description = "حوّلها لفواتير", Link = "/quotations?status=Accepted", Severity = "high" });
        }
        catch (Exception ex) { Console.WriteLine($"[LoadAttentionItems] {ex.Message}"); }

        _attentionItems = items;
    }

    // ════════════ HELPERS ════════════
    private string FormatMoney(decimal value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000:N1}M";
        if (value >= 1_000) return $"{value / 1_000:N1}K";
        return $"{value:N0}";
    }

    private string FormatChartValue(decimal value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000:N1}M";
        if (value >= 1_000) return $"{value / 1_000:N1}K";
        return $"{value:N0}";
    }

    private string GetStatusClass(string status)
    {
        var s = (status ?? "").ToLower();
        if (s.Contains("paid") && !s.Contains("partial")) return "status-paid";
        if (s.Contains("partial")) return "status-partiallypaid";
        if (s.Contains("cancel")) return "status-cancelled";
        return "status-open";
    }

    private string GetInvoiceStatusText(string? status) => (status ?? "").Trim().ToLower() switch
    {
        "paid" => "مدفوعة",
        "partiallypaid" => "مدفوعة جزئياً",
        "open" => "مفتوحة",
        "cancelled" => "ملغية",
        _ => status ?? "مفتوحة"
    };

    private string GetQuoteStatusText(string status) => status switch
    {
        "Draft" => "مسودة", "Sent" => "تم الإرسال", "Accepted" => "مقبول",
        "Rejected" => "مرفوض", "Converted" => "تحوّل لفاتورة", "Expired" => "منتهي",
        _ => status
    };

    private string TimeAgo(DateTime dateTime)
    {
        var span = DateTime.Now - dateTime;
        if (span.TotalSeconds < 60) return "الآن";
        if (span.TotalMinutes < 60) return $"منذ {(int)span.TotalMinutes} دقيقة";
        if (span.TotalHours < 24) return $"منذ {(int)span.TotalHours} ساعة";
        if (span.TotalDays < 7) return $"منذ {(int)span.TotalDays} يوم";
        return dateTime.ToString("dd/MM/yyyy");
    }

    public class HomeStats
    {
        public int CustomersCount { get; set; }
        public int ActiveCustomers { get; set; }
        public int InvoicesCount { get; set; }
        public decimal InvoicesTotal { get; set; }
        public decimal CashBoxBalance { get; set; }
        public decimal SalesGrowth { get; set; }
    }

    public class RecentInvoice
    {
        public int TransactionId { get; set; }
        public string PartyName { get; set; } = "";
        public decimal GrandTotal { get; set; }
        public string InvoiceStatus { get; set; } = "";
        public DateTime Date { get; set; }
    }

    public class RecentQuote
    {
        public int QuotationId { get; set; }
        public string ReferenceNumber { get; set; } = "";
        public string PartyName { get; set; } = "";
        public decimal GrandTotal { get; set; }
        public string Status { get; set; } = "";
        public DateTime QuotationDate { get; set; }
    }

    public class AttentionItem
    {
        public string Emoji { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Link { get; set; } = "";
        public string Severity { get; set; } = "medium";
    }

    public class DailySales
    {
        public DateTime Date { get; set; }
        public decimal Amount { get; set; }
    }
}
