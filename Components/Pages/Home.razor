@page "/"
@implements IDisposable

@using ApexCharts
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor

@inject NotificationService      NotificationService
@inject AuthenticationStateProvider AuthProvider
@inject IDbContextFactory<db24804Context> DbFactory
@inject ICashBoxService          CashBoxService
@inject NavigationManager        Navigation
@inject ISnackbar                Snackbar

<PageTitle>الرئيسية — COCOBOLO ERP</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="MudBlazor.Color.Secondary" Size="MudBlazor.Size.Large" Indeterminate="true" />
            </div>
            <MudText Typo="Typo.h6" Class="loading-text">جاري تحميل لوحة التحكم...</MudText>
            <div class="loading-dots">
                <span></span><span></span><span></span>
            </div>
        </div>
    </div>
}
else
{
<div dir="rtl" class="home-page">

    <!-- ⭐ BACKGROUND DECORATIONS -->
    <div class="page-bg-decorations">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>

    <!-- ⭐ TOP ACCENT BAR -->
    <div class="top-accent-bar">
        <div class="accent-shimmer"></div>
    </div>

    <!-- ⭐ PREMIUM HEADER -->
    <div class="home-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-orbs">
                <div class="header-orb orb-1"></div>
                <div class="header-orb orb-2"></div>
                <div class="header-orb orb-3"></div>
            </div>
            <div class="header-grid"></div>
        </div>

        <div class="header-content">
            <div class="header-top">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon">
                            <span class="greet-emoji">@_greetingIcon</span>
                        </div>
                        <div class="header-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="MudBlazor.Size.Small" />
                        </div>
                        <div class="header-icon-badge-secondary">
                            <MudIcon Icon="@Icons.Material.Filled.Verified" Size="MudBlazor.Size.Small" />
                        </div>
                    </div>
                    <div class="header-text">
                        <div class="header-title-row">
                            <h1>@_greetingMessage</h1>
                            <span class="premium-badge">
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="MudBlazor.Size.Small" />
                                @_currentUserRole
                            </span>
                        </div>
                        <p>
                            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="MudBlazor.Size.Small" Class="subtitle-icon" />
                            @_greetingSubtext
                        </p>
                    </div>
                </div>
            </div>

            <!-- Stats Grid (inside header) -->
            <div class="stats-grid">
                @if (_p.ViewSales)
                {
                    <div class="stat-card stat-sales animate-card" style="--delay: 0.05s"
                         @onclick='() => Navigation.NavigateTo("/sales/invoices")'>
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class='stat-value @GetStatClass(FormatMoney(_kpi.SalesThisMonth))'>@FormatMoney(_kpi.SalesThisMonth)</span>
                                    @if (_kpi.SalesGrowth != 0)
                                    {
                                        <span class='stat-trend @(_kpi.SalesGrowth >= 0 ? "trend-up" : "trend-down")'>
                                            <MudIcon Icon="@(_kpi.SalesGrowth >= 0 ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)" Size="MudBlazor.Size.Small" />
                                            @Math.Abs(_kpi.SalesGrowth)%
                                        </span>
                                    }
                                </div>
                                <div class="stat-label">مبيعات الشهر</div>
                            </div>
                        </div>
                    </div>
                }

                @if (_p.ViewQuotes)
                {
                    <div class="stat-card stat-quotes animate-card" style="--delay: 0.1s"
                         @onclick='() => Navigation.NavigateTo("/quotations")'>
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Rounded.RequestQuote" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class='stat-value @GetStatClass(_kpi.QuotesTotal.ToString())'>@_kpi.QuotesTotal</span>
                                    @if (_kpi.QuotesPending > 0)
                                    {
                                        <span class="stat-percent">@_kpi.QuotesPending معلق</span>
                                    }
                                </div>
                                <div class="stat-label">عروض الأسعار</div>
                            </div>
                        </div>
                    </div>
                }

                @if (_p.ViewCustomers)
                {
                    <div class="stat-card stat-customers animate-card" style="--delay: 0.15s"
                         @onclick='() => Navigation.NavigateTo("/customers")'>
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Rounded.Groups" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class='stat-value @GetStatClass(_kpi.CustomersTotal.ToString())'>@_kpi.CustomersTotal</span>
                                    <span class="stat-percent">@_kpi.CustomersActive نشط</span>
                                </div>
                                <div class="stat-label">العملاء</div>
                            </div>
                        </div>
                    </div>
                }

                @if (_p.ViewCashBox)
                {
                    <div class="stat-card stat-cash animate-card" style="--delay: 0.2s"
                         @onclick='() => Navigation.NavigateTo("/cashbox/dashboard")'>
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Rounded.AccountBalance" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class='stat-value @GetStatClass(FormatMoney(_kpi.CashBalance))'>@FormatMoney(_kpi.CashBalance)</span>
                                </div>
                                <div class="stat-label">رصيد الخزنة</div>
                            </div>
                        </div>
                    </div>
                }

                @if (_p.ViewProducts)
                {
                    <div class="stat-card stat-products animate-card" style="--delay: 0.25s"
                         @onclick='() => Navigation.NavigateTo("/products")'>
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Rounded.Inventory2" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class='stat-value @GetStatClass(_kpi.ProductsTotal.ToString())'>@_kpi.ProductsTotal</span>
                                    @if (_kpi.ProductsPendingPrice > 0)
                                    {
                                        <span class="stat-percent warn">@_kpi.ProductsPendingPrice تسعير</span>
                                    }
                                </div>
                                <div class="stat-label">المنتجات</div>
                            </div>
                        </div>
                    </div>
                }

                @if (_p.ViewEmployees)
                {
                    <div class="stat-card stat-hr animate-card" style="--delay: 0.3s"
                         @onclick='() => Navigation.NavigateTo("/employees")'>
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Rounded.Badge" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class='stat-value @GetStatClass(_kpi.EmployeesTotal.ToString())'>@_kpi.EmployeesTotal</span>
                                </div>
                                <div class="stat-label">الموظفين</div>
                            </div>
                        </div>
                    </div>
                }

                @if (_p.ViewExpenses)
                {
                    <div class="stat-card stat-expenses animate-card" style="--delay: 0.35s"
                         @onclick='() => Navigation.NavigateTo("/expenses")'>
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Rounded.AccountBalanceWallet" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class='stat-value @GetStatClass(FormatMoney(_kpi.ExpensesThisMonth))'>@FormatMoney(_kpi.ExpensesThisMonth)</span>
                                </div>
                                <div class="stat-label">مصروفات الشهر</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ⭐ QUICK ACCESS -->
    @{ var quickLinks = BuildQuickLinks(); }
    @if (quickLinks.Any())
    {
        <div class="pro-card animate-card" style="--delay: 0.2s">
            <div class="card-hdr">
                <div class="hdr-left">
                    <div class="hdr-icon" style="background: linear-gradient(135deg,#667eea,#764ba2)">
                        <MudIcon Icon="@Icons.Material.Rounded.Apps" />
                    </div>
                    <div>
                        <h3>وصول سريع</h3>
                        <p>انتقل مباشرة لأي قسم</p>
                    </div>
                </div>
            </div>
            <div class="quick-grid">
                @foreach (var link in quickLinks)
                {
                    <button class="quick-btn" @onclick="() => Navigation.NavigateTo(link.Url)"
                            style="--qc: @link.Color">
                        <div class="quick-btn-icon">
                            <MudIcon Icon="@link.Icon" />
                        </div>
                        <span>@link.Label</span>
                    </button>
                }
            </div>
        </div>
    }

    <!-- ⭐ ATTENTION + CHART -->
    <div class="content-row animate-card" style="--delay: 0.3s">
        @if (_attentionItems.Any())
        {
            <div class="pro-card">
                <div class="card-hdr">
                    <div class="hdr-left">
                        <div class="hdr-icon attention-icon">
                            <MudIcon Icon="@Icons.Material.Filled.NotificationImportant" />
                        </div>
                        <div>
                            <h3>تحتاج اهتمامك</h3>
                            <p>@_attentionItems.Count تنبيه نشط</p>
                        </div>
                    </div>
                </div>
                <div class="att-list">
                    @foreach (var item in _attentionItems)
                    {
                        <div class='att-row @item.Severity' @onclick='() => Navigation.NavigateTo(item.Link)'>
                            <div class="att-emoji">@item.Emoji</div>
                            <div class="att-text">
                                <strong>@item.Title</strong>
                                <small>@item.Description</small>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="MudBlazor.Size.Small" Class="att-arrow" />
                        </div>
                    }
                </div>
            </div>
        }

        @if (_p.ViewSales && _salesChart.Any())
        {
                <div class='pro-card @(_attentionItems.Any() ? "" : "full-width")'>
                <div class="card-hdr">
                    <div class="hdr-left">
                        <div class="hdr-icon chart-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Analytics" />
                        </div>
                        <div>
                            <h3>تحليل المبيعات</h3>
                            <p>مبيعات + مصروفات</p>
                        </div>
                    </div>
                    <div class="chart-controls">
                        <div class="chart-total">
                            <small>الإجمالي</small>
                            <strong>@FormatMoney(_salesChart.Sum(d => d.Amount))</strong>
                        </div>
                        <div class="period-toggle">
                            <button class='period-btn @(_chartPeriod == 7   ? "active" : "")' @onclick='() => SetChartPeriod(7)'>أسبوع</button>
                            <button class='period-btn @(_chartPeriod == 30  ? "active" : "")' @onclick='() => SetChartPeriod(30)'>شهر</button>
                            <button class='period-btn @(_chartPeriod == 90  ? "active" : "")' @onclick='() => SetChartPeriod(90)'>3 شهور</button>
                            <button class='period-btn @(_chartPeriod == 365 ? "active" : "")' @onclick='() => SetChartPeriod(365)'>سنة</button>
                        </div>
                    </div>
                </div>
                <ApexChart TItem="DayData" Options="_salesChartOptions" Height="240">
                    <ApexPointSeries TItem="DayData"
                                     Items="_salesChart"
                                     Name="المبيعات"
                                     SeriesType="SeriesType.Area"
                                     XValue="@(d => d.Label)"
                                     YValue="@(d => (decimal?)d.Amount)" />
                    <ApexPointSeries TItem="DayData"
                                     Items="_expensesChart"
                                     Name="المصروفات"
                                     SeriesType="SeriesType.Line"
                                     XValue="@(d => d.Label)"
                                     YValue="@(d => (decimal?)d.Amount)" />
                </ApexChart>
            </div>
        }
    </div>

    <!-- ⭐ QUOTES DONUT + RECENT QUOTES -->
    @if (_p.ViewQuotes && _kpi.QuotesTotal > 0)
    {
        <div class="content-row animate-card" style="--delay: 0.35s">
            <div class="pro-card">
                <div class="card-hdr">
                    <div class="hdr-left">
                        <div class="hdr-icon" style="background: linear-gradient(135deg,#06b6d4,#0891b2)">
                            <MudIcon Icon="@Icons.Material.Filled.DonutLarge" />
                        </div>
                        <div>
                            <h3>توزيع عروض الأسعار</h3>
                            <p>حالة العروض الحالية</p>
                        </div>
                    </div>
                </div>
                <ApexChart TItem="SliceData" Options="_donutOptions" Height="220">
                    <ApexPointSeries TItem="SliceData"
                                     Items="_quotesDonut"
                                     Name="العروض"
                                     SeriesType="SeriesType.Donut"
                                     XValue="@(d => d.Label)"
                                     YValue="@(d => (decimal?)d.Value)" />
                </ApexChart>
            </div>

            <div class="pro-card">
                <div class="card-hdr">
                    <div class="hdr-left">
                        <div class="hdr-icon quote-icon">
                            <MudIcon Icon="@Icons.Material.Filled.RequestQuote" />
                        </div>
                        <div>
                            <h3>آخر عروض الأسعار</h3>
                            <p>أحدث 5 عروض</p>
                        </div>
                    </div>
                    <button class="view-all" @onclick='() => Navigation.NavigateTo("/quotations")'>
                        عرض الكل
                        <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="MudBlazor.Size.Small" />
                    </button>
                </div>
                @if (_recentQuotes.Any())
                {
                    <div class="activity-list">
                        @foreach (var q in _recentQuotes)
                        {
                            <div class="activity-item" @onclick='() => Navigation.NavigateTo("/quotations/" + q.QuotationId)'>
                                <div class="ai-id">@q.ReferenceNumber</div>
                                <div class="ai-info">
                                    <strong>@q.PartyName</strong>
                                    <small>
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="MudBlazor.Size.Small" />
                                        @q.QuotationDate.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                                <div class="ai-amount">@q.GrandTotal.ToString("N0") <span class="cur">ج.م</span></div>
                                <span class='ai-status quote-@(q.Status.ToLower())'>@GetQuoteStatusText(q.Status)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <MudIcon Icon="@Icons.Material.Filled.RequestQuote" />
                        <p>لا توجد عروض حديثة</p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ⭐ RECENT INVOICES -->
    @if (_p.ViewSales)
    {
        <div class="content-row animate-card" style="--delay: 0.4s">
            <div class="pro-card full-width">
                <div class="card-hdr">
                    <div class="hdr-left">
                        <div class="hdr-icon invoice-icon">
                            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                        </div>
                        <div>
                            <h3>آخر فواتير المبيعات</h3>
                            <p>أحدث 5 فواتير</p>
                        </div>
                    </div>
                    <button class="view-all" @onclick='() => Navigation.NavigateTo("/sales/invoices")'>
                        عرض الكل
                        <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="MudBlazor.Size.Small" />
                    </button>
                </div>
                @if (_recentInvoices.Any())
                {
                    <div class="activity-list">
                        @foreach (var inv in _recentInvoices)
                        {
                            <div class="activity-item" @onclick='() => Navigation.NavigateTo("/sales/invoices/" + inv.TransactionId)'>
                                <div class="ai-id">#@inv.TransactionId</div>
                                <div class="ai-info">
                                    <strong>@inv.PartyName</strong>
                                    <small>
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="MudBlazor.Size.Small" />
                                        @inv.Date.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                                <div class="ai-amount">@inv.GrandTotal.ToString("N0") <span class="cur">ج.م</span></div>
                                <span class='ai-status @GetStatusClass(inv.InvoiceStatus)'>@GetInvoiceStatusText(inv.InvoiceStatus)</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                        <p>لا توجد فواتير حديثة</p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ⭐ NOTIFICATIONS -->
    <div class="pro-card notif-card animate-card" style="--delay: 0.45s">
        <div class="card-hdr">
            <div class="hdr-left">
                <div class="hdr-icon notif-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" />
                </div>
                <div>
                    <h3>الإشعارات الأخيرة</h3>
                    <p>@_unreadNotifications إشعار غير مقروء</p>
                </div>
            </div>
            <button class="view-all" @onclick='() => Navigation.NavigateTo("/notifications")'>
                عرض الكل
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="MudBlazor.Size.Small" />
            </button>
        </div>
        @if (_notifications.Any())
        {
            <div class="notif-list">
                @foreach (var n in _notifications.Take(5))
                {
                    <div class='notif-item @(n.IsRead ? "" : "unread")'>
                        <div class="ni-icon">
                            <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Size="MudBlazor.Size.Small" />
                        </div>
                        <div class="ni-content">
                            <div class="ni-header">
                                <strong>@n.Title</strong>
                                <small>@TimeAgo(n.CreatedAt)</small>
                            </div>
                            <p>@n.Message</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsOff" />
                <p>لا توجد إشعارات</p>
            </div>
        }
    </div>

</div>

<!-- ⭐ FAB -->
<div class='fab-wrap @(_fabOpen ? "open" : "")'>
    @if (_fabOpen)
    {
        <div class="fab-overlay" @onclick="ToggleFab"></div>
    }
    <div class="fab-menu">
        @if (_p.AddCustomer)
        {
            <button class="fab-item" @onclick='() => NavTo("/customers/form")'>
                <span class="fab-tip">إضافة عميل</span>
                <div class="fab-icon"><MudIcon Icon="@Icons.Material.Filled.PersonAdd" /></div>
            </button>
        }
        @if (_p.AddProduct)
        {
            <button class="fab-item" @onclick='() => NavTo("/products/form")'>
                <span class="fab-tip">إضافة منتج</span>
                <div class="fab-icon"><MudIcon Icon="@Icons.Material.Filled.Inventory2" /></div>
            </button>
        }
        @if (_p.AddQuote)
        {
            <button class="fab-item" @onclick='() => NavTo("/quotations/new")'>
                <span class="fab-tip">عرض سعر جديد</span>
                <div class="fab-icon"><MudIcon Icon="@Icons.Material.Filled.RequestQuote" /></div>
            </button>
        }
        @if (_p.AddInvoice)
        {
            <button class="fab-item" @onclick='() => NavTo("/sales/invoices/new")'>
                <span class="fab-tip">فاتورة جديدة</span>
                <div class="fab-icon"><MudIcon Icon="@Icons.Material.Filled.ReceiptLong" /></div>
            </button>
        }
        @if (_p.AddCashBox)
        {
            <button class="fab-item" @onclick='() => NavTo("/cashbox/manual")'>
                <span class="fab-tip">سند خزنة</span>
                <div class="fab-icon"><MudIcon Icon="@Icons.Material.Filled.Payments" /></div>
            </button>
        }
        @if (_p.AddComplaint)
        {
            <button class="fab-item" @onclick='() => NavTo("/complaints/form")'>
                <span class="fab-tip">شكوى جديدة</span>
                <div class="fab-icon"><MudIcon Icon="@Icons.Material.Filled.SupportAgent" /></div>
            </button>
        }
        @if (_p.AddInspection)
        {
            <button class="fab-item" @onclick='() => NavTo("/additional-charges")'>
                <span class="fab-tip">رسم معاينة</span>
                <div class="fab-icon"><MudIcon Icon="@Icons.Material.Filled.Search" /></div>
            </button>
        }
    </div>
    <button class="fab-main" @onclick="ToggleFab" title='@(_fabOpen ? "إغلاق" : "إضافة سريعة")'>
        <MudIcon Icon="@(_fabOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)" />
    </button>
</div>
}

<style>
    /* ══════════════════════════════════════════════════════════════
       CSS VARIABLES
    ══════════════════════════════════════════════════════════════ */
    :root {
        --gold:       #D4A853;
        --gold-dark:  #B8912A;
        --gold-light: #F0DBA8;
        --gold-bg:    #FEFBF3;
        --navy:       #1B2A4A;
        --navy-dark:  #0F1D36;
        --navy-light: #2D4A7A;
    }

    /* ══════════════════════════════════════════════════════════════
       ANIMATIONS
    ══════════════════════════════════════════════════════════════ */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50%      { transform: translateY(-15px); }
    }
    @@keyframes floatDelayed {
        0%, 100% { transform: translateY(0) translateX(0); }
        50%      { transform: translateY(-20px) translateX(10px); }
    }
    @@keyframes pulseSlow {
        0%, 100% { opacity: 0.5; transform: scale(1); }
        50%      { opacity: 0.8; transform: scale(1.1); }
    }
    @@keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 0 0 rgba(212,168,83,0.4); }
        50%      { box-shadow: 0 0 25px 8px rgba(212,168,83,0.15); }
    }
    @@keyframes shimmer {
        0%   { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
    @@keyframes bounceSoft {
        0%, 100% { transform: translateY(0); }
        50%      { transform: translateY(-3px); }
    }
    @@keyframes loadingDots {
        0%, 80%, 100% { transform: scale(0); opacity: 0; }
        40%           { transform: scale(1); opacity: 1; }
    }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .animate-card {
        animation: fadeInUp 0.5s ease-out backwards;
        animation-delay: var(--delay, 0s);
    }

    /* ══════════════════════════════════════════════════════════════
       LOADING
    ══════════════════════════════════════════════════════════════ */
    .loading-screen {
        display: flex; align-items: center;
        justify-content: center; min-height: 70vh;
    }
    .loading-content { text-align: center; }
    .loading-spinner-box {
        width: 80px; height: 80px;
        margin: 0 auto 1rem;
        display: flex; align-items: center; justify-content: center;
    }
    .loading-text { color: var(--mud-palette-text-secondary); }
    .loading-dots {
        display: flex; justify-content: center;
        gap: .5rem; margin-top: 1rem;
    }
    .loading-dots span {
        width: 10px; height: 10px;
        background: var(--gold); border-radius: 50%;
        animation: loadingDots 1.4s infinite ease-in-out both;
    }
    .loading-dots span:nth-child(1) { animation-delay: -.32s; }
    .loading-dots span:nth-child(2) { animation-delay: -.16s; }

    /* ══════════════════════════════════════════════════════════════
       PAGE
    ══════════════════════════════════════════════════════════════ */
    .home-page {
        position: relative;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1.5rem 120px;
    }

    /* ══════════════════════════════════════════════════════════════
       BACKGROUND ORBS
    ══════════════════════════════════════════════════════════════ */
    .page-bg-decorations {
        position: fixed; inset: 0;
        pointer-events: none; overflow: hidden; z-index: 0;
    }
    .bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); }
    .bg-orb-1 {
        width: 400px; height: 400px; top: -150px; right: -150px;
        background: radial-gradient(circle, rgba(212,168,83,.12), transparent 70%);
    }
    .bg-orb-2 {
        width: 350px; height: 350px; bottom: -100px; left: -100px;
        background: radial-gradient(circle, rgba(59,130,246,.08), transparent 70%);
    }
    .bg-orb-3 {
        width: 250px; height: 250px; top: 30%; right: 40%;
        background: radial-gradient(circle, rgba(139,92,246,.05), transparent 70%);
    }

    /* ══════════════════════════════════════════════════════════════
       TOP ACCENT BAR
    ══════════════════════════════════════════════════════════════ */
    .top-accent-bar {
        height: 5px;
        background: linear-gradient(90deg, var(--gold), var(--gold-dark), var(--gold));
        position: relative; overflow: hidden;
        margin-bottom: 1.5rem;
        border-radius: 0 0 10px 10px;
    }
    .accent-shimmer {
        position: absolute; inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.4), transparent);
        animation: shimmer 3s ease-in-out infinite;
    }

    /* ══════════════════════════════════════════════════════════════
       PREMIUM HEADER
    ══════════════════════════════════════════════════════════════ */
    .home-header {
        position: relative; border-radius: 24px;
        overflow: hidden; margin-bottom: 1.5rem;
        animation: fadeInUp .5s ease-out;
    }
    .header-bg { position: absolute; inset: 0; }
    .header-gradient {
        position: absolute; inset: 0;
        background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 40%, var(--navy-light) 100%);
    }
    .header-orbs { position: absolute; inset: 0; overflow: hidden; }
    .header-orb { position: absolute; border-radius: 50%; }
    .header-orb.orb-1 {
        width: 400px; height: 400px; top: -180px; right: -120px;
        background: radial-gradient(circle, rgba(212,168,83,.25), transparent 60%);
        animation: float 8s ease-in-out infinite;
    }
    .header-orb.orb-2 {
        width: 300px; height: 300px; bottom: -120px; left: 15%;
        background: radial-gradient(circle, rgba(212,168,83,.15), transparent 60%);
        animation: floatDelayed 10s ease-in-out infinite;
    }
    .header-orb.orb-3 {
        width: 180px; height: 180px; top: 25%; left: 8%;
        background: radial-gradient(circle, rgba(255,255,255,.05), transparent 60%);
        animation: pulseSlow 6s ease-in-out infinite;
    }
    .header-grid {
        position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.02) 1px, transparent 1px);
        background-size: 40px 40px;
    }
    .header-content {
        position: relative; z-index: 2;
        padding: 2rem 2.5rem;
    }
    .header-top {
        display: flex; align-items: center;
        justify-content: space-between;
        flex-wrap: wrap; gap: 1.5rem;
        margin-bottom: 2rem;
    }
    .header-info { display: flex; align-items: center; gap: 1.25rem; }
    .header-icon-wrapper { position: relative; }
    .header-icon-glow {
        position: absolute; inset: -10px;
        background: var(--gold); border-radius: 20px;
        filter: blur(20px); opacity: .3;
        animation: pulseGlow 4s ease-in-out infinite;
    }
    .header-icon {
        position: relative; width: 64px; height: 64px;
        background: rgba(255,255,255,.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,.2);
        border-radius: 20px;
        display: flex; align-items: center; justify-content: center;
        color: var(--gold); box-shadow: 0 8px 32px rgba(0,0,0,.2);
    }
    .header-icon::before {
        content: ''; position: absolute; inset: 0;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(255,255,255,.2), transparent 50%);
        pointer-events: none;
    }
    .greet-emoji { font-size: 2rem; line-height: 1; }
    .header-icon-badge {
        position: absolute; top: -6px; right: -6px;
        width: 24px; height: 24px;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: white; box-shadow: 0 4px 12px rgba(212,168,83,.4);
        animation: bounceSoft 2s ease-in-out infinite;
    }
    .header-icon-badge ::deep .mud-icon-root { font-size: 12px !important; }
    .header-icon-badge-secondary {
        position: absolute; bottom: -4px; left: -4px;
        width: 20px; height: 20px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: white; box-shadow: 0 4px 12px rgba(16,185,129,.4);
        opacity: 0; transform: scale(.8);
        transition: all .3s ease;
    }
    .header-icon-wrapper:hover .header-icon-badge-secondary {
        opacity: 1; transform: scale(1);
    }
    .header-icon-badge-secondary ::deep .mud-icon-root { font-size: 10px !important; }
    .header-text h1 {
        margin: 0; font-size: 1.8rem; font-weight: 900;
        color: white; letter-spacing: -.5px;
    }
    .header-title-row {
        display: flex; align-items: center;
        gap: .75rem; flex-wrap: wrap;
    }
    .premium-badge {
        display: inline-flex; align-items: center; gap: .35rem;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(212,168,83,.3);
        color: var(--gold);
        font-size: .7rem; font-weight: 700;
        padding: .3rem .6rem; border-radius: 20px;
    }
    .premium-badge ::deep .mud-icon-root { font-size: 10px !important; }
    .header-text p {
        margin: .5rem 0 0; font-size: .9rem;
        color: rgba(255,255,255,.6);
        display: flex; align-items: center; gap: .5rem;
    }
    .subtitle-icon { color: #10b981 !important; font-size: 16px !important; }

    /* ══════════════════════════════════════════════════════════════
       STATS GRID (inside header)
    ══════════════════════════════════════════════════════════════ */
    .stats-grid { display: flex; gap: 1rem; flex-wrap: wrap; }
    .stat-card {
        position: relative;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 16px; padding: 1rem 1.25rem;
        display: flex; align-items: center; gap: .875rem;
        flex: 1; min-width: 150px; overflow: hidden;
        transition: all .4s ease; cursor: pointer;
    }
    .stat-card:hover {
        background: rgba(255,255,255,.1);
        transform: translateY(-3px);
        border-color: rgba(212,168,83,.3);
    }
    .stat-glow {
        position: absolute; inset: -50%;
        opacity: 0; transition: opacity .5s ease;
        pointer-events: none;
    }
    .stat-card:hover .stat-glow { opacity: 1; }
    .stat-accent {
        position: absolute; top: 0; left: 0; right: 0; height: 3px;
        transform: scaleX(0); transform-origin: right;
        transition: transform .4s ease;
    }
    .stat-card:hover .stat-accent { transform: scaleX(1); }
    .stat-content {
        position: relative; z-index: 2;
        display: flex; align-items: center; gap: .75rem;
    }
    .stat-icon-box {
        width: 46px; height: 46px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; transition: transform .3s ease;
    }
    .stat-card:hover .stat-icon-box { transform: scale(1.1); }
    .stat-data { min-width: 0; }
    .stat-value-row { display: flex; align-items: center; gap: .5rem; }
    .stat-value {
        font-size: 1.5rem; font-weight: 900;
        color: #ffffff; line-height: 1;
        font-variant-numeric: tabular-nums;
        text-shadow: 0 1px 3px rgba(0,0,0,.25);
    }
    /* حجم ديناميكي حسب طول الرقم */
    .stat-value.val-sm  { font-size: 1.15rem; }
    .stat-value.val-md  { font-size: 1.3rem; }
    .stat-value.val-num { font-size: 1.5rem; }
    .stat-percent {
        font-size: .65rem; font-weight: 700;
        background: rgba(16,185,129,.2); color: #10b981;
        padding: .15rem .4rem; border-radius: 6px;
    }
    .stat-percent.warn { background: rgba(245,158,11,.2); color: #f59e0b; }
    .stat-trend {
        display: inline-flex; align-items: center; gap: .15rem;
        font-size: .6rem; font-weight: 700;
        padding: .15rem .4rem; border-radius: 6px;
    }
    .stat-trend ::deep .mud-icon-root { font-size: 10px !important; }
    .stat-trend.trend-up   { background: rgba(16,185,129,.2); color: #10b981; }
    .stat-trend.trend-down { background: rgba(239,68,68,.2);  color: #ef4444; }
    .stat-label {
        font-size: .72rem; font-weight: 600;
        color: rgba(241,245,249,.6); margin-top: .15rem;
    }

    /* Stat color themes */
    .stat-sales     .stat-glow    { background: radial-gradient(circle, rgba(16,185,129,.2), transparent 70%); }
    .stat-sales     .stat-accent  { background: linear-gradient(90deg, #10b981, #059669); }
    .stat-sales     .stat-icon-box { background: rgba(16,185,129,.15); color: #10b981; }
    .stat-quotes    .stat-glow    { background: radial-gradient(circle, rgba(139,92,246,.2), transparent 70%); }
    .stat-quotes    .stat-accent  { background: linear-gradient(90deg, #8b5cf6, #7c3aed); }
    .stat-quotes    .stat-icon-box { background: rgba(139,92,246,.15); color: #8b5cf6; }
    .stat-customers .stat-glow    { background: radial-gradient(circle, rgba(59,130,246,.2), transparent 70%); }
    .stat-customers .stat-accent  { background: linear-gradient(90deg, #3b82f6, #2563eb); }
    .stat-customers .stat-icon-box { background: rgba(59,130,246,.15); color: #3b82f6; }
    .stat-cash      .stat-glow    { background: radial-gradient(circle, rgba(212,168,83,.2), transparent 70%); }
    .stat-cash      .stat-accent  { background: linear-gradient(90deg, var(--gold), var(--gold-dark)); }
    .stat-cash      .stat-icon-box { background: rgba(212,168,83,.15); color: var(--gold); }
    .stat-products  .stat-glow    { background: radial-gradient(circle, rgba(139,92,246,.2), transparent 70%); }
    .stat-products  .stat-accent  { background: linear-gradient(90deg, #8b5cf6, #6d28d9); }
    .stat-products  .stat-icon-box { background: rgba(139,92,246,.15); color: #8b5cf6; }
    .stat-hr        .stat-glow    { background: radial-gradient(circle, rgba(236,72,153,.2), transparent 70%); }
    .stat-hr        .stat-accent  { background: linear-gradient(90deg, #ec4899, #db2777); }
    .stat-hr        .stat-icon-box { background: rgba(236,72,153,.15); color: #ec4899; }
    .stat-expenses  .stat-glow    { background: radial-gradient(circle, rgba(249,115,22,.2), transparent 70%); }
    .stat-expenses  .stat-accent  { background: linear-gradient(90deg, #f97316, #ea580c); }
    .stat-expenses  .stat-icon-box { background: rgba(249,115,22,.15); color: #f97316; }

    /* ── Chart Period Toggle ── */
    .chart-controls { display: flex; align-items: center; gap: .5rem; }
    .period-toggle {
        display: flex; background: rgba(0,0,0,.06);
        border-radius: 8px; padding: 2px; gap: 2px;
    }
    .period-btn {
        padding: .25rem .6rem; border: none; border-radius: 6px;
        font-size: .72rem; font-weight: 700; cursor: pointer;
        background: transparent; color: #64748b;
        transition: all .2s ease; font-family: inherit;
    }
    .period-btn.active {
        background: white; color: #1e293b;
        box-shadow: 0 1px 4px rgba(0,0,0,.12);
    }

    /* ══════════════════════════════════════════════════════════════
       QUICK ACCESS
    ══════════════════════════════════════════════════════════════ */
    .quick-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: .75rem;
    }
    .quick-btn {
        display: flex; flex-direction: column; align-items: center;
        gap: .5rem; padding: 1rem .5rem;
        border: 1.5px solid var(--mud-palette-divider);
        border-radius: 12px;
        background: var(--mud-palette-background);
        cursor: pointer; transition: all .2s ease;
        font-size: .8rem; font-weight: 700;
        color: var(--mud-palette-text-primary);
        font-family: inherit;
    }
    .quick-btn:hover {
        border-color: var(--qc);
        color: var(--qc);
        transform: translateY(-3px);
        box-shadow: 0 6px 16px color-mix(in srgb, var(--qc) 20%, transparent);
    }
    .quick-btn-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        background: color-mix(in srgb, var(--qc) 12%, transparent);
        color: var(--qc); transition: transform .2s;
    }
    .quick-btn:hover .quick-btn-icon { transform: scale(1.1); }
    .quick-btn-icon .mud-icon-root { font-size: 1.3rem !important; }

    /* ══════════════════════════════════════════════════════════════
       CONTENT CARDS
    ══════════════════════════════════════════════════════════════ */
    .content-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem; margin-bottom: 1.5rem;
        position: relative; z-index: 1;
    }
    .pro-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px; padding: 1.25rem;
        margin-bottom: 1.5rem;
        position: relative; z-index: 1;
    }
    .content-row .pro-card { margin-bottom: 0; }
    .pro-card.full-width { grid-column: span 2; }
    .notif-card { margin-bottom: 0; }

    .card-hdr {
        display: flex; justify-content: space-between;
        align-items: center; margin-bottom: 1rem;
        padding-bottom: .85rem;
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .hdr-left { display: flex; align-items: center; gap: .85rem; }
    .hdr-icon {
        width: 40px; height: 40px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        color: white;
    }
    .hdr-icon ::deep .mud-icon-root { font-size: 1.3rem; }
    .attention-icon { background: linear-gradient(135deg, #f59e0b, #d97706); }
    .chart-icon     { background: linear-gradient(135deg, #10b981, #059669); }
    .invoice-icon   { background: linear-gradient(135deg, #3b82f6, #2563eb); }
    .quote-icon     { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
    .notif-icon     { background: linear-gradient(135deg, #ef4444, #dc2626); }

    .card-hdr h3 {
        margin: 0; font-size: 1rem; font-weight: 700;
        color: var(--mud-palette-text-primary);
    }
    .card-hdr p {
        margin: .15rem 0 0; font-size: .75rem;
        color: var(--mud-palette-text-secondary);
    }
    .chart-total { text-align: left; }
    .chart-total small {
        display: block; font-size: .7rem;
        color: var(--mud-palette-text-secondary);
    }
    .chart-total strong {
        font-size: 1.1rem; font-weight: 800; color: #10b981;
        font-variant-numeric: tabular-nums;
    }
    .view-all {
        display: inline-flex; align-items: center; gap: .35rem;
        background: transparent;
        border: 1px solid var(--mud-palette-divider);
        color: var(--mud-palette-text-secondary);
        font-size: .8rem; font-weight: 600;
        padding: .45rem .85rem; border-radius: 8px;
        cursor: pointer; transition: all .2s; font-family: inherit;
    }
    .view-all:hover {
        background: var(--gold-bg);
        color: var(--gold-dark); border-color: var(--gold);
    }
    .view-all ::deep .mud-icon-root { font-size: .9rem !important; }

    /* ══════════════════════════════════════════════════════════════
       ATTENTION
    ══════════════════════════════════════════════════════════════ */
    .att-list { display: flex; flex-direction: column; gap: .5rem; }
    .att-row {
        display: flex; align-items: center; gap: .85rem;
        padding: .85rem 1rem;
        background: var(--mud-palette-background);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px; cursor: pointer;
        transition: transform .2s, box-shadow .2s;
        border-right: 4px solid transparent;
    }
    .att-row:hover { transform: translateX(-3px); box-shadow: 0 4px 12px rgba(0,0,0,.06); }
    .att-row.high   { border-right-color: #ef4444; }
    .att-row.medium { border-right-color: #f59e0b; }
    .att-row.low    { border-right-color: #3b82f6; }
    .att-emoji { font-size: 1.5rem; flex-shrink: 0; }
    .att-text { flex: 1; }
    .att-text strong { display: block; color: var(--mud-palette-text-primary); font-size: .9rem; }
    .att-text small  { color: var(--mud-palette-text-secondary); font-size: .78rem; }
    .att-arrow { color: var(--mud-palette-text-disabled); }

    /* ══════════════════════════════════════════════════════════════
       ACTIVITY LIST
    ══════════════════════════════════════════════════════════════ */
    .activity-list { display: flex; flex-direction: column; gap: .5rem; }
    .activity-item {
        display: grid;
        grid-template-columns: auto 1fr auto auto;
        gap: .85rem; align-items: center;
        padding: .75rem .95rem;
        background: var(--mud-palette-background);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px; cursor: pointer;
        transition: transform .2s, box-shadow .2s;
    }
    .activity-item:hover { transform: translateX(-3px); box-shadow: 0 4px 12px rgba(0,0,0,.06); }
    .ai-id {
        font-weight: 700; color: var(--mud-palette-text-secondary);
        font-size: .75rem;
        background: var(--mud-palette-surface);
        padding: .25rem .55rem; border-radius: 6px;
        border: 1px solid var(--mud-palette-divider);
        font-variant-numeric: tabular-nums;
    }
    .ai-info strong {
        display: block; color: var(--mud-palette-text-primary);
        font-size: .88rem; margin-bottom: .1rem;
    }
    .ai-info small {
        color: var(--mud-palette-text-secondary); font-size: .72rem;
        display: inline-flex; align-items: center; gap: .2rem;
    }
    .ai-info small ::deep .mud-icon-root { font-size: .85rem !important; }
    .ai-amount {
        font-weight: 800; color: var(--mud-palette-text-primary);
        font-size: .9rem; text-align: left;
        font-variant-numeric: tabular-nums;
    }
    .ai-amount .cur {
        font-weight: 500; color: var(--mud-palette-text-secondary);
        font-size: .7rem; margin-right: .15rem;
    }
    .ai-status {
        padding: .2rem .55rem; border-radius: 100px;
        font-size: .68rem; font-weight: 700; white-space: nowrap;
    }
    .ai-status.status-paid, .ai-status.quote-converted { background: #d1fae5; color: #065f46; }
    .ai-status.status-partiallypaid { background: #fef3c7; color: #92400e; }
    .ai-status.status-open          { background: #dbeafe; color: #1e40af; }
    .ai-status.status-cancelled     { background: #fee2e2; color: #991b1b; }
    .ai-status.quote-draft    { background: #e2e8f0; color: #475569; }
    .ai-status.quote-sent     { background: #dbeafe; color: #1e40af; }
    .ai-status.quote-accepted { background: #d1fae5; color: #065f46; }
    .ai-status.quote-rejected { background: #fee2e2; color: #991b1b; }
    .ai-status.quote-expired  { background: #fef3c7; color: #92400e; }

    /* ══════════════════════════════════════════════════════════════
       NOTIFICATIONS
    ══════════════════════════════════════════════════════════════ */
    .notif-list { display: flex; flex-direction: column; gap: .5rem; }
    .notif-item {
        display: flex; gap: .75rem; padding: .85rem 1rem;
        background: var(--mud-palette-background);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px; transition: box-shadow .2s;
    }
    .notif-item.unread {
        background: var(--gold-bg);
