        padding: .25rem .5rem;
        border-radius: 6px;
    }
    .inv-info strong { display: block; color: #1e293b; font-size: .9rem; }
    .inv-info small { color: #64748b; font-size: .75rem; }
    .inv-amount { font-weight: 700; color: #1e293b; text-align: left; }
    .inv-amount small { color: #64748b; font-weight: 500; font-size: .7rem; margin-right: .15rem; }
    .inv-status {
        padding: .2rem .6rem;
        border-radius: 100px;
        font-size: .7rem; font-weight: 700;
    }
    .inv-status.status-paid, .inv-status.quote-converted { background: #d1fae5; color: #065f46; }
    .inv-status.status-partiallypaid { background: #fef3c7; color: #92400e; }
    .inv-status.status-open { background: #dbeafe; color: #1e40af; }
    .inv-status.status-cancelled { background: #fee2e2; color: #991b1b; }
    .inv-status.quote-draft { background: #e2e8f0; color: #475569; }
    .inv-status.quote-sent { background: #dbeafe; color: #1e40af; }
    .inv-status.quote-accepted { background: #d1fae5; color: #065f46; }
    .inv-status.quote-rejected { background: #fee2e2; color: #991b1b; }
    .inv-status.quote-expired { background: #fef3c7; color: #92400e; }

    /* Notifications */
    .notif-panel { margin-bottom: 1.5rem; }
    .notif-count {
        background: #ef4444; color: white;
        padding: .2rem .6rem;
        border-radius: 100px;
        font-size: .75rem; font-weight: 700;
    }
    .notif-item {
        display: flex; gap: .75rem;
        padding: .85rem; border-radius: 10px;
        background: #f8fafc; transition: all .2s;
    }
    .notif-item.unread {
        background: rgba(212,175,55,0.08);
        border-right: 3px solid #d4af37;
    }
    .ni-icon {
        width: 36px; height: 36px;
        background: rgba(239,68,68,0.1); color: #ef4444;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .ni-content { flex: 1; }
    .ni-content strong { display: block; color: #1e293b; margin-bottom: .15rem; }
    .ni-content p { margin: 0 0 .25rem 0; color: #475569; font-size: .85rem; }
    .ni-content small { color: #94a3b8; font-size: .75rem; }

    /* Empty State */
    .empty-mini {
        text-align: center;
        padding: 2rem 1rem;
        color: #94a3b8;
    }
    .empty-mini ::deep .mud-icon-root { font-size: 3rem !important; opacity: 0.4; }
    .empty-mini p { margin: .5rem 0 0; }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .home { padding: 1rem; }
        .hero-content { padding: 1.25rem; }
        .hero-text h1 { font-size: 1.5rem; }
        .hero-actions { width: 100%; }
        .hero-actions .ha-btn-primary,
        .hero-actions .ha-btn-quote,
        .hero-actions .ha-btn-outline { flex: 1; min-width: 0; }
        .kpis-grid { grid-template-columns: 1fr 1fr; gap: .75rem; }
        .kpi { padding: 1rem; }
        .kpi-value { font-size: 1.2rem; }
        .duo-grid { grid-template-columns: 1fr; }
        .inv-row { grid-template-columns: 1fr auto; gap: .5rem; }
        .inv-id, .inv-status { grid-column: 1 / -1; }
        .chart-bars { height: 180px; gap: 4px; }
        .chart-bar-value { font-size: .6rem; }
    }
    @@media (max-width: 480px) {
        .kpis-grid { grid-template-columns: 1fr; }
    }
</style>

@code {
    private bool _isLoading = true;
    private string _currentUserName = "User";
    private string _currentUserRole = "";
    private string _avatarLetter = "U";
    private string _greetingIcon = "👋";
    private string _greetingMessage = "أهلاً بك";

    private HomeStats _stats = new();
    private QuotationStatsDto _quoteStats = new();

    private List<RecentInvoice> _recentInvoices = new();
    private List<RecentQuote> _recentQuotes = new();
    private List<AttentionItem> _attentionItems = new();
    private List<DailySales> _chartData = new();

    private int _unreadNotifications = 0;
    private List<Notification> _notifications = new();

    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            _currentUserName = authState.User.Identity?.Name ?? "User";
            _currentUserRole = authState.User.FindFirst(ClaimTypes.Role)?.Value ?? "";
            _avatarLetter = string.IsNullOrEmpty(_currentUserName) ? "U" : _currentUserName[0].ToString().ToUpper();

            var hour = DateTime.Now.Hour;
            if (hour < 12) { _greetingIcon = "🌅"; _greetingMessage = "صباح الخير"; }
            else if (hour < 18) { _greetingIcon = "☀️"; _greetingMessage = "مساء النور"; }
            else { _greetingIcon = "🌙"; _greetingMessage = "مساء الخير"; }

            await Task.WhenAll(
                LoadStats(),
                LoadRecentInvoices(),
                LoadRecentQuotes(),
                LoadNotifications(),
                LoadAttentionItems(),
                LoadChartData()
            );
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في التحميل: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                try
                {
                    await InvokeAsync(async () =>
                    {
                        await LoadNotifications();
                        await LoadAttentionItems();
                        StateHasChanged();
                    });
                }
                catch { }
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    public void Dispose() => _refreshTimer?.Dispose();

    private async Task LoadStats()
    {
        try
        {
            var today = DateTime.Today;
            var thisMonthStart = new DateTime(today.Year, today.Month, 1);
            var lastMonthStart = thisMonthStart.AddMonths(-1);

            _stats.CustomersCount = await Db.Parties.AsNoTracking().CountAsync();
            _stats.ActiveCustomers = await Db.Parties.AsNoTracking().CountAsync(p => p.IsActive == true);

            // ⭐ All transactions in current month
            var salesQuery = Db.Transactions.AsNoTracking()
                .Where(t => t.TransactionDate >= thisMonthStart);
            _stats.InvoicesCount = await salesQuery.CountAsync();
            _stats.InvoicesTotal = await salesQuery.SumAsync(t => (decimal?)t.GrandTotal) ?? 0;

            var lastMonthSales = await Db.Transactions.AsNoTracking()
                .Where(t => t.TransactionDate >= lastMonthStart && t.TransactionDate < thisMonthStart)
                .SumAsync(t => (decimal?)t.GrandTotal) ?? 0;

            if (lastMonthSales > 0)
            {
                _stats.SalesGrowth = Math.Round(
                    ((_stats.InvoicesTotal - lastMonthSales) / lastMonthSales) * 100, 1);
            }

            var cashBoxes = await CashBoxService.GetCashBoxesAsync(true);
            _stats.CashBoxBalance = cashBoxes.Sum(c => c.CurrentBalance);
        }
        catch { }
    }

    // ⭐ All transactions - no filter on type
    private async Task LoadRecentInvoices()
    {
        try
        {
            _recentInvoices = await Db.Transactions.AsNoTracking()
                .OrderByDescending(t => t.TransactionDate)
                .Take(5)
                .Join(Db.Parties.AsNoTracking(),
                    t => t.PartyId, p => p.PartyId,
                    (t, p) => new RecentInvoice
                    {
                        TransactionId = t.TransactionId,
                        PartyName = p.PartyName ?? "غير محدد",
                        GrandTotal = t.GrandTotal,
                        InvoiceStatus = t.InvoiceStatus ?? "مفتوحة",
                        Date = t.TransactionDate
                    })
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadRecentInvoices] {ex.Message}");
            _recentInvoices = new();
        }
    }

    // ⭐ Direct DB query - avoids permission check
    private async Task LoadRecentQuotes()
    {
        try
        {
            var quotes = await Db.Quotations.AsNoTracking()
                .OrderByDescending(q => q.QuotationDate)
                .Take(5)
                .ToListAsync();

            _recentQuotes = new();
            foreach (var q in quotes)
            {
                var partyName = await Db.Parties.AsNoTracking()
                    .Where(p => p.PartyId == q.PartyId)
                    .Select(p => p.PartyName)
                    .FirstOrDefaultAsync();

                _recentQuotes.Add(new RecentQuote
                {
                    QuotationId = q.QuotationId,
                    ReferenceNumber = q.ReferenceNumber ?? $"QT-{q.QuotationDate.Year}-{q.QuotationId:D5}",
                    PartyName = partyName ?? "غير محدد",
                    GrandTotal = q.GrandTotal ?? q.TotalAmount,
                    Status = string.IsNullOrEmpty(q.Status) ? "Draft" : q.Status,
                    QuotationDate = q.QuotationDate
                });
            }

            // Stats
            var totalQuotes = await Db.Quotations.AsNoTracking().CountAsync();
            var convertedQuotes = await Db.Quotations.AsNoTracking().CountAsync(q => q.InvoiceId != null);
            var pendingQuotes = await Db.Quotations.AsNoTracking()
                .CountAsync(q => (q.Status == "Draft" || q.Status == "Sent") && q.InvoiceId == null);

            _quoteStats = new QuotationStatsDto
            {
                TotalCount = totalQuotes,
                ConvertedCount = convertedQuotes,
                DraftCount = pendingQuotes,
                ConversionRate = totalQuotes > 0
                    ? Math.Round(((decimal)convertedQuotes / totalQuotes) * 100, 1)
                    : 0
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadRecentQuotes] {ex.Message}");
            _recentQuotes = new();
        }
    }

    // ⭐ Chart - 7 days
    private async Task LoadChartData()
    {
        try
        {
            var startDate = DateTime.Today.AddDays(-6);
            var transactions = await Db.Transactions.AsNoTracking()
                .Where(t => t.TransactionDate >= startDate)
                .Select(t => new { Date = t.TransactionDate.Date, Amount = t.GrandTotal })
                .ToListAsync();

            _chartData = new();
            for (int i = 0; i < 7; i++)
            {
                var date = startDate.AddDays(i);
                var amount = transactions.Where(t => t.Date == date).Sum(t => t.Amount);
                _chartData.Add(new DailySales { Date = date, Amount = amount });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LoadChartData] {ex.Message}");
            _chartData = new();
        }
    }

    private async Task LoadNotifications()
    {
        try
        {
            _unreadNotifications = await NotificationService.GetUnreadCountAsync(_currentUserName, _currentUserRole);
            _notifications = await NotificationService.GetLatestAsync(_currentUserName, _currentUserRole, 8);
        }
        catch { _notifications = new(); }
    }

    private async Task LoadAttentionItems()
    {
        var items = new List<AttentionItem>();

        try
        {
            var pendingQuotes = await Db.Quotations.AsNoTracking()
                .CountAsync(q => (q.Status == "Sent" || q.Status == "Draft") && q.InvoiceId == null);
            if (pendingQuotes > 0)
            {
                items.Add(new AttentionItem
                {
                    Emoji = "⏳",
                    Title = $"{pendingQuotes} عرض سعر في انتظار رد",
                    Description = "اضغط للمتابعة مع العملاء",
                    Link = "/quotations?status=Sent",
                    Severity = "medium"
                });
            }

            var threeDaysLater = DateTime.Today.AddDays(3);
            var expiringQuotes = await Db.Quotations.AsNoTracking()
                .CountAsync(q => q.ValidUntil.HasValue
                              && q.ValidUntil.Value.Date >= DateTime.Today
                              && q.ValidUntil.Value.Date <= threeDaysLater
                              && q.InvoiceId == null
                              && q.Status != "Rejected"
                              && q.Status != "Expired");
            if (expiringQuotes > 0)
            {
                items.Add(new AttentionItem
                {
                    Emoji = "⚠️",
                    Title = $"{expiringQuotes} عرض ينتهي خلال 3 أيام",
                    Description = "تواصل مع العملاء قبل انتهاء العرض",
                    Link = "/quotations",
                    Severity = "high"
                });
            }

            var expiredCount = await Db.Quotations.AsNoTracking()
                .CountAsync(q => q.ValidUntil.HasValue
                              && q.ValidUntil.Value.Date < DateTime.Today
                              && q.InvoiceId == null
                              && q.Status != "Rejected"
                              && q.Status != "Expired");
            if (expiredCount > 0)
            {
                items.Add(new AttentionItem
                {
                    Emoji = "⏰",
                    Title = $"{expiredCount} عرض منتهي الصلاحية",
                    Description = "يحتاج مراجعة وتحديث الحالة",
                    Link = "/quotations",
                    Severity = "low"
                });
            }

            var acceptedNotConverted = await Db.Quotations.AsNoTracking()
                .CountAsync(q => q.Status == "Accepted" && q.InvoiceId == null);
            if (acceptedNotConverted > 0)
            {
                items.Add(new AttentionItem
                {
                    Emoji = "✅",
                    Title = $"{acceptedNotConverted} عرض مقبول جاهز للتحويل لفاتورة",
                    Description = "اضغط لتحويل العروض المقبولة",
                    Link = "/quotations?status=Accepted",
                    Severity = "high"
                });
            }
        }
        catch { }

        _attentionItems = items;
    }

    private string FormatMoney(decimal value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000:N1}M ج";
        if (value >= 1_000) return $"{value / 1_000:N1}K ج";
        return $"{value:N0} ج";
    }

    private string FormatChartValue(decimal value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000:N1}M";
        if (value >= 1_000) return $"{value / 1_000:N1}K";
        return $"{value:N0}";
    }

    private string GetStatusClass(string status)
    {
        var s = (status ?? "").ToLower();
        if (s.Contains("paid") && !s.Contains("partial")) return "status-paid";
        if (s.Contains("partial")) return "status-partiallypaid";
        if (s.Contains("cancel")) return "status-cancelled";
        return "status-open";
    }

    private string GetQuoteStatusText(string status) => status switch
    {
        "Draft" => "مسودة",
        "Sent" => "تم الإرسال",
        "Accepted" => "مقبول",
        "Rejected" => "مرفوض",
        "Converted" => "تحوّل لفاتورة",
        "Expired" => "منتهي",
        _ => status
    };

    private string TimeAgo(DateTime dateTime)
    {
        var span = DateTime.Now - dateTime;
        if (span.TotalSeconds < 60) return "الآن";
        if (span.TotalMinutes < 60) return $"منذ {(int)span.TotalMinutes} دقيقة";
        if (span.TotalHours < 24) return $"منذ {(int)span.TotalHours} ساعة";
        if (span.TotalDays < 7) return $"منذ {(int)span.TotalDays} يوم";
        return dateTime.ToString("dd/MM/yyyy");
    }

    public class HomeStats
    {
        public int CustomersCount { get; set; }
        public int ActiveCustomers { get; set; }
        public int InvoicesCount { get; set; }
        public decimal InvoicesTotal { get; set; }
        public decimal CashBoxBalance { get; set; }
        public decimal SalesGrowth { get; set; }
    }

    public class RecentInvoice
    {
        public int TransactionId { get; set; }
        public string PartyName { get; set; } = "";
        public decimal GrandTotal { get; set; }
        public string InvoiceStatus { get; set; } = "";
        public DateTime Date { get; set; }
    }

    public class RecentQuote
    {
        public int QuotationId { get; set; }
        public string ReferenceNumber { get; set; } = "";
        public string PartyName { get; set; } = "";
        public decimal GrandTotal { get; set; }
        public string Status { get; set; } = "";
        public DateTime QuotationDate { get; set; }
    }

    public class AttentionItem
    {
        public string Emoji { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Link { get; set; } = "";
        public string Severity { get; set; } = "medium";
    }

    public class DailySales
    {
        public DateTime Date { get; set; }
        public decimal Amount { get; set; }
    }
}
