@page "/"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

@inject IProductService ProductService
@inject ICashBoxService CashBoxService
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthProvider
@inject db24804Context Db
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>لوحة التحكم — COCOBOLO ERP</PageTitle>

@if (_isLoading)
{
    <div class="home-loading">
        <div class="hl-box">
            <div class="hl-logo"><span>C</span></div>
            <h2>COCOBOLO ERP</h2>
            <p>جاري تحميل لوحة التحكم...</p>
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="border-radius:10px;height:6px;max-width:280px;margin:0 auto;" />
        </div>
    </div>
}
else
{
<div class="home" dir="rtl">

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ HERO SECTION                                                       -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <div class="hero">
        <div class="hero-bg">
            <div class="hero-grad"></div>
            <div class="hero-orbs">
                <div class="ho ho1"></div>
                <div class="ho ho2"></div>
                <div class="ho ho3"></div>
            </div>
            <div class="hero-grid"></div>
        </div>

        <div class="hero-content">
            <div class="hero-main">
                <div class="hero-avatar">
                    <span>@_avatarLetter</span>
                    <div class="ha-ring"></div>
                </div>
                <div class="hero-text">
                    <div class="hero-greeting">
                        <span class="hg-icon">@_greetingIcon</span>
                        <span class="hg-text">@_greetingMessage</span>
                    </div>
                    <h1>@_currentUserName</h1>
                    <div class="hero-meta">
                        <span class="hm-role">
                            <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" />
                            @_currentUserRole
                        </span>
                        <span class="hm-date">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                            @DateTime.Now.ToString("dddd، dd MMMM yyyy", new CultureInfo("ar-EG"))
                        </span>
                        @if (_unreadNotifications > 0)
                        {
                            <span class="hm-notif">
                                <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Small" />
                                @_unreadNotifications إشعار جديد
                            </span>
                        }
                    </div>
                </div>
            </div>

            <div class="hero-actions">
                @if (HasPermission("frm_PartiesInvoices", "Add"))
                {
                    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Receipt"
                               OnClick="@(() => Navigation.NavigateTo("/sales/invoices/new"))" Class="ha-btn-primary">
                        <span class="btn-shine"></span>فاتورة جديدة
                    </MudButton>
                }
                @if (HasPermission("frm_ProductList", "Add"))
                {
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.AddBox"
                               OnClick="@(() => Navigation.NavigateTo("/products/form"))" Class="ha-btn-ghost">
                        إضافة منتج
                    </MudButton>
                }
                @if (HasPermission("frmCashBoxManual", "Add"))
                {
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.SwapHoriz"
                               OnClick="@(() => Navigation.NavigateTo("/cashbox/manual"))" Class="ha-btn-ghost">
                        حركة خزينة
                    </MudButton>
                }
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ KPI CARDS                                                          -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <div class="kpi-row">
        <div class="kpi kpi-products" @onclick="@(() => Navigation.NavigateTo("/products"))">
            <div class="kpi-accent"></div>
            <div class="kpi-body">
                <div class="kpi-icon"><MudIcon Icon="@Icons.Material.Filled.Inventory2" /></div>
                <div class="kpi-data">
                    <span class="kpi-val">@_stats.ProductsCount.ToString("N0")</span>
                    <span class="kpi-lbl">إجمالي المنتجات</span>
                </div>
                <div class="kpi-extra">
                    <span class="kpi-badge">@_stats.PricedCount تسعير</span>
                </div>
            </div>
        </div>

        <div class="kpi kpi-customers" @onclick="@(() => Navigation.NavigateTo("/customers"))">
            <div class="kpi-accent"></div>
            <div class="kpi-body">
                <div class="kpi-icon"><MudIcon Icon="@Icons.Material.Filled.Groups" /></div>
                <div class="kpi-data">
                    <span class="kpi-val">@_stats.CustomersCount.ToString("N0")</span>
                    <span class="kpi-lbl">العملاء</span>
                </div>
                <div class="kpi-extra">
                    <span class="kpi-badge">@_stats.ActiveCustomers نشط</span>
                </div>
            </div>
        </div>

        <div class="kpi kpi-invoices" @onclick="@(() => Navigation.NavigateTo("/sales/invoices"))">
            <div class="kpi-accent"></div>
            <div class="kpi-body">
                <div class="kpi-icon"><MudIcon Icon="@Icons.Material.Filled.Receipt" /></div>
                <div class="kpi-data">
                    <span class="kpi-val">@_stats.InvoicesCount.ToString("N0")</span>
                    <span class="kpi-lbl">فواتير هذا الشهر</span>
                </div>
                <div class="kpi-extra">
                    <span class="kpi-badge">@_stats.InvoicesTotal.ToString("N0") ج.م</span>
                </div>
            </div>
        </div>

        <div class="kpi kpi-cashbox" @onclick="@(() => Navigation.NavigateTo("/cashbox/dashboard"))">
            <div class="kpi-accent"></div>
            <div class="kpi-body">
                <div class="kpi-icon"><MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" /></div>
                <div class="kpi-data">
                    <span class="kpi-val">@_stats.CashBoxBalance.ToString("N0")</span>
                    <span class="kpi-lbl">رصيد الخزينة</span>
                </div>
                <div class="kpi-extra">
                    <span class="kpi-badge @(_stats.CashBoxBalance >= 0 ? "badge-green" : "badge-red")">
                        @(_stats.CashBoxBalance >= 0 ? "✅ موجب" : "⚠️ سالب")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ INVOICES + NOTIFICATIONS                                           -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <div class="duo-grid">
        <!-- Recent Invoices -->
        <div class="panel">
            <div class="panel-hdr">
                <div class="ph-title">
                    <div class="ph-icon ph-icon-amber"><MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" /></div>
                    <h3>آخر الفواتير</h3>
                </div>
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => Navigation.NavigateTo("/sales/invoices"))">عرض الكل</MudButton>
            </div>

            @if (_recentInvoices.Any())
            {
                <div class="inv-list">
                    @foreach (var inv in _recentInvoices)
                    {
                        <div class="inv-row" @onclick="@(() => Navigation.NavigateTo($"/sales/invoices/{inv.TransactionId}"))">
                            <div class="inv-id">#@inv.TransactionId</div>
                            <div class="inv-info">
                                <strong>@inv.PartyName</strong>
                                <small>@inv.Date.ToString("dd/MM/yyyy")</small>
                            </div>
                            <div class="inv-amount">@inv.GrandTotal.ToString("N2") <small>ج.م</small></div>
                            <span class="inv-status @GetStatusClass(inv.InvoiceStatus)">@inv.InvoiceStatus</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-mini"><MudIcon Icon="@Icons.Material.Filled.ReceiptLong" /><p>لا توجد فواتير حديثة</p></div>
            }
        </div>

        <!-- Notifications -->
        <div class="panel">
            <div class="panel-hdr">
                <div class="ph-title">
                    <div class="ph-icon ph-icon-red"><MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Small" /></div>
                    <h3>الإشعارات</h3>
                </div>
                @if (_unreadNotifications > 0)
                {
                    <span class="notif-count">@_unreadNotifications جديد</span>
                }
            </div>

            @if (_notifications.Any())
            {
                <div class="notif-list">
                    @foreach (var n in _notifications)
                    {
                        <div class="notif-item @(n.IsRead == false ? "ni-unread" : "")">
                            <div class="ni-icon"><MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Size="Size.Small" /></div>
                            <div class="ni-body">
                                <strong>@n.Title</strong>
                                <p>@n.Message</p>
                                <small>@n.CreatedAt.ToString("dd/MM HH:mm")</small>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-mini"><MudIcon Icon="@Icons.Material.Filled.NotificationsNone" /><p>لا توجد إشعارات</p></div>
            }
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ QUICK ACTIONS                                                      -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <div class="panel">
        <div class="panel-hdr">
            <div class="ph-title">
                <div class="ph-icon ph-icon-gold"><MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" /></div>
                <h3>اختصارات سريعة</h3>
            </div>
        </div>
        <div class="qa-grid">
            @foreach (var qa in _quickActions.Where(q => HasPermission(q.Permission, q.Action)))
            {
                <div class="qa-card" @onclick="@(() => Navigation.NavigateTo(qa.Url))">
                    <div class="qa-icon" style="background:@(qa.Color)12;color:@qa.Color;">
                        <MudIcon Icon="@qa.Icon" />
                    </div>
                    <span class="qa-label">@qa.Label</span>
                </div>
            }
        </div>
    </div>

    <!-- Footer -->
    <div class="home-footer">
        <MudIcon Icon="@Icons.Material.Filled.Diamond" Size="Size.Small" Class="hf-icon" />
        <span>COCOBOLO ERP — لوحة التحكم</span>
        <span class="hf-prem"></span>
    </div>

</div>
}

<style>
    .home { max-width:1600px; margin:0 auto; padding:1.25rem; }

    /* Loading */
    .home-loading { display:flex; align-items:center; justify-content:center; min-height:80vh; }
    .hl-box { text-align:center; }
    .hl-logo {
        width:80px; height:80px; margin:0 auto 1.25rem;
        background:linear-gradient(135deg,#D4AF37,#a67c00);
        border-radius:22px; display:flex; align-items:center; justify-content:center;
        font-size:2.5rem; font-weight:900; color:white;
        box-shadow:0 8px 30px rgba(212,175,55,0.35);
    }
    .hl-box h2 { margin:0 0 0.5rem; font-size:1.4rem; font-weight:800; color:var(--mud-palette-text-primary); }
    .hl-box p { color:var(--mud-palette-text-secondary); margin:0 0 1.5rem; }

    /* ═══════ HERO ═══════ */
    .hero { position:relative; border-radius:24px; overflow:hidden; margin-bottom:1.5rem; }
    .hero-bg { position:absolute; inset:0; }
    .hero-grad { position:absolute; inset:0; background:linear-gradient(135deg,#070D1A 0%,#0F1D36 30%,#1B2A4A 60%,#2D4A7A 100%); }
    .hero-orbs { position:absolute; inset:0; overflow:hidden; }
    .ho { position:absolute; border-radius:50%; }
    .ho1 { width:400px; height:400px; top:-180px; right:-120px; background:radial-gradient(circle,rgba(212,175,55,0.3),transparent 60%); animation:float 8s ease-in-out infinite; }
    .ho2 { width:300px; height:300px; bottom:-120px; left:10%; background:radial-gradient(circle,rgba(212,175,55,0.15),transparent 60%); animation:floatR 10s ease-in-out infinite; }
    .ho3 { width:200px; height:200px; top:20%; left:5%; background:radial-gradient(circle,rgba(255,255,255,0.04),transparent 60%); }
    .hero-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px); background-size:40px 40px; }

    .hero-content { position:relative; z-index:2; padding:2.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1.5rem; }
    .hero-main { display:flex; align-items:center; gap:1.5rem; }
    .hero-avatar {
        position:relative; width:72px; height:72px; border-radius:20px;
        background:linear-gradient(135deg,#D4AF37,#a67c00);
        display:flex; align-items:center; justify-content:center;
        font-size:2rem; font-weight:900; color:white;
        box-shadow:0 8px 30px rgba(212,175,55,0.4);
        flex-shrink:0;
    }
    .ha-ring {
        position:absolute; inset:-4px; border-radius:24px;
        border:2px solid rgba(212,175,55,0.4);
        animation:pulseGlow 3s ease-in-out infinite;
    }
    .hero-greeting { display:flex; align-items:center; gap:0.5rem; margin-bottom:0.35rem; }
    .hg-icon { font-size:1.5rem; }
    .hg-text { font-size:1rem; font-weight:600; color:rgba(255,255,255,0.7); }
    .hero-text h1 { margin:0; font-size:1.75rem; font-weight:900; color:white; }
    .hero-meta { display:flex; gap:1rem; margin-top:0.6rem; flex-wrap:wrap; }
    .hm-role, .hm-date, .hm-notif {
        display:inline-flex; align-items:center; gap:0.3rem;
        font-size:0.78rem; font-weight:600; padding:0.3rem 0.7rem;
        border-radius:8px; background:rgba(255,255,255,0.08);
        color:rgba(255,255,255,0.7);
    }
    .hm-role .mud-icon-root, .hm-date .mud-icon-root, .hm-notif .mud-icon-root { font-size:14px !important; }
    .hm-notif { background:rgba(239,68,68,0.2); color:#fca5a5; }

    .hero-actions { display:flex; gap:0.75rem; flex-wrap:wrap; }
    .ha-btn-primary {
        position:relative; overflow:hidden;
        background:linear-gradient(135deg,#D4AF37,#a67c00) !important;
        color:white !important; font-weight:700 !important;
        padding:0.875rem 1.75rem !important; border-radius:14px !important;
        box-shadow:0 6px 20px rgba(212,175,55,0.35) !important;
    }
    .ha-btn-primary:hover { transform:translateY(-2px); }
    .btn-shine { position:absolute; top:0; left:-100%; width:100%; height:100%; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.25),transparent); transition:left 0.6s; }
    .ha-btn-primary:hover .btn-shine { left:100%; }
    .ha-btn-ghost { background:rgba(255,255,255,0.06) !important; border-color:rgba(255,255,255,0.2) !important; color:white !important; font-weight:600 !important; border-radius:14px !important; }

    /* ═══════ KPI ═══════ */
    .kpi-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1.25rem; margin-bottom:1.5rem; }
    .kpi {
        background:var(--mud-palette-surface); border:1px solid var(--mud-palette-divider);
        border-radius:18px; overflow:hidden; cursor:pointer; transition:all 0.35s;
    }
    .kpi:hover { transform:translateY(-5px); box-shadow:0 10px 30px rgba(0,0,0,0.07); }
    .kpi-accent { height:4px; }
    .kpi-body { padding:1.5rem; display:flex; align-items:center; gap:1rem; }
    .kpi-icon {
        width:54px; height:54px; border-radius:16px;
        display:flex; align-items:center; justify-content:center;
        flex-shrink:0; transition:transform 0.3s;
    }
    .kpi:hover .kpi-icon { transform:scale(1.1) rotate(-5deg); }
    .kpi-data { flex:1; min-width:0; }
    .kpi-val { display:block; font-size:1.6rem; font-weight:900; line-height:1.2; color:var(--mud-palette-text-primary); }
    .kpi-lbl { display:block; font-size:0.82rem; color:var(--mud-palette-text-secondary); font-weight:600; margin-top:0.2rem; }
    .kpi-extra { flex-shrink:0; }
    .kpi-badge { font-size:0.72rem; font-weight:700; padding:0.3rem 0.6rem; border-radius:8px; }
    .badge-green { background:rgba(16,185,129,0.1); color:#10b981; }
    .badge-red { background:rgba(239,68,68,0.1); color:#ef4444; }

    /* KPI Colors */
    .kpi-products .kpi-accent { background:linear-gradient(90deg,#6366f1,#4f46e5); }
    .kpi-products .kpi-icon { background:rgba(99,102,241,0.1); color:#6366f1; }
    .kpi-products .kpi-badge { background:rgba(99,102,241,0.1); color:#6366f1; }

    .kpi-customers .kpi-accent { background:linear-gradient(90deg,#10b981,#059669); }
    .kpi-customers .kpi-icon { background:rgba(16,185,129,0.1); color:#10b981; }
    .kpi-customers .kpi-badge { background:rgba(16,185,129,0.1); color:#10b981; }

    .kpi-invoices .kpi-accent { background:linear-gradient(90deg,#f59e0b,#d97706); }
    .kpi-invoices .kpi-icon { background:rgba(245,158,11,0.1); color:#f59e0b; }
    .kpi-invoices .kpi-badge { background:rgba(245,158,11,0.1); color:#f59e0b; }

    .kpi-cashbox .kpi-accent { background:linear-gradient(90deg,#D4AF37,#a67c00); }
    .kpi-cashbox .kpi-icon { background:rgba(212,175,55,0.1); color:#D4AF37; }

    /* ═══════ PANELS ═══════ */
    .duo-grid { display:grid; grid-template-columns:1.3fr 0.7fr; gap:1.25rem; margin-bottom:1.5rem; }
    .panel { background:var(--mud-palette-surface); border:1px solid var(--mud-palette-divider); border-radius:18px; padding:1.5rem; }
    .panel-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem; padding-bottom:0.875rem; border-bottom:2px solid var(--mud-palette-divider); }
    .ph-title { display:flex; align-items:center; gap:0.6rem; }
    .ph-title h3 { margin:0; font-size:1.05rem; font-weight:700; color:var(--mud-palette-text-primary); }
    .ph-icon { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .ph-icon-amber { background:rgba(245,158,11,0.1); color:#f59e0b; }
    .ph-icon-red { background:rgba(239,68,68,0.1); color:#ef4444; }
    .ph-icon-gold { background:rgba(212,175,55,0.1); color:#D4AF37; }

    /* Invoices */
    .inv-list { display:flex; flex-direction:column; gap:0.5rem; }
    .inv-row {
        display:flex; align-items:center; gap:0.875rem; padding:0.875rem 1rem;
        background:var(--mud-palette-background); border:1px solid var(--mud-palette-divider);
        border-radius:12px; cursor:pointer; transition:all 0.25s;
    }
    .inv-row:hover { border-color:rgba(212,175,55,0.3); transform:translateX(-3px); }
    .inv-id { font-size:0.82rem; font-weight:800; color:var(--mud-palette-text-secondary); background:var(--mud-palette-background-gray); padding:0.25rem 0.5rem; border-radius:6px; }
    .inv-info { flex:1; min-width:0; }
    .inv-info strong { display:block; font-size:0.9rem; color:var(--mud-palette-text-primary); }
    .inv-info small { font-size:0.72rem; color:var(--mud-palette-text-secondary); }
    .inv-amount { font-size:1rem; font-weight:900; color:var(--mud-palette-text-primary); }
    .inv-amount small { font-size:0.65rem; opacity:0.6; }
    .inv-status { font-size:0.72rem; font-weight:700; padding:0.25rem 0.6rem; border-radius:20px; }
    .inv-st-paid { background:rgba(16,185,129,0.1); color:#10b981; }
    .inv-st-open { background:rgba(245,158,11,0.1); color:#f59e0b; }
    .inv-st-cancelled { background:rgba(239,68,68,0.1); color:#ef4444; }
    .inv-st-default { background:rgba(59,130,246,0.1); color:#3b82f6; }

    /* Notifications */
    .notif-count { background:#ef4444; color:white; font-size:0.72rem; font-weight:700; padding:0.25rem 0.6rem; border-radius:20px; }
    .notif-list { display:flex; flex-direction:column; gap:0.5rem; max-height:350px; overflow-y:auto; }
    .notif-item {
        display:flex; gap:0.75rem; padding:0.875rem; border-radius:12px;
        background:var(--mud-palette-background); border:1px solid transparent;
        transition:all 0.2s;
    }
    .ni-unread { border-right:3px solid #D4AF37; background:rgba(212,175,55,0.04); }
    .ni-icon { width:36px; height:36px; border-radius:10px; background:rgba(99,102,241,0.1); color:#6366f1; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .ni-body { flex:1; }
    .ni-body strong { font-size:0.88rem; display:block; color:var(--mud-palette-text-primary); }
    .ni-body p { font-size:0.8rem; color:var(--mud-palette-text-secondary); margin:0.2rem 0; line-height:1.5; }
    .ni-body small { font-size:0.72rem; color:var(--mud-palette-text-disabled); }

    /* Quick Actions */
    .qa-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:0.875rem; }
    .qa-card {
        display:flex; flex-direction:column; align-items:center; gap:0.75rem;
        padding:1.5rem 1rem; border-radius:16px; cursor:pointer;
        background:var(--mud-palette-background); border:1px solid var(--mud-palette-divider);
        transition:all 0.3s;
    }
    .qa-card:hover { transform:translateY(-3px); box-shadow:0 8px 25px rgba(0,0,0,0.06); border-color:rgba(212,175,55,0.3); }
    .qa-icon { width:52px; height:52px; border-radius:16px; display:flex; align-items:center; justify-content:center; transition:transform 0.3s; }
    .qa-card:hover .qa-icon { transform:scale(1.1); }
    .qa-icon .mud-icon-root { font-size:26px !important; }
    .qa-label { font-size:0.88rem; font-weight:700; color:var(--mud-palette-text-primary); text-align:center; }

    /* Empty & Footer */
    .empty-mini { text-align:center; padding:2.5rem; color:var(--mud-palette-text-disabled); }
    .empty-mini .mud-icon-root { font-size:40px !important; opacity:0.3; }
    .empty-mini p { margin:0.5rem 0 0; font-size:0.88rem; }
    .home-footer { display:flex; align-items:center; justify-content:center; gap:0.5rem; padding:1.5rem; font-size:0.75rem; color:var(--mud-palette-text-secondary); }
    .hf-icon { color:#D4AF37 !important; }
    .hf-prem { color:#D4AF37; font-weight:700; }

    /* Animations */
    @@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-18px)} }
    @@keyframes floatR { 0%,100%{transform:translateY(0) rotate(0)} 50%{transform:translateY(-12px) rotate(3deg)} }
    @@keyframes pulseGlow { 0%,100%{box-shadow:0 0 0 0 rgba(212,175,55,0.3)} 50%{box-shadow:0 0 20px 5px rgba(212,175,55,0.1)} }

    /* Responsive */
    @@media(max-width:1200px) { .kpi-row{grid-template-columns:repeat(2,1fr);} }
    @@media(max-width:900px) { .duo-grid{grid-template-columns:1fr;} .hero-content{flex-direction:column;align-items:stretch;} .hero-actions{justify-content:center;} }
    @@media(max-width:600px) { .kpi-row{grid-template-columns:1fr;} .qa-grid{grid-template-columns:repeat(3,1fr);} .hero-main{flex-direction:column;text-align:center;} }
</style>

@code {
    private bool _isLoading = true;
    private string _currentUserName = "";
    private string _currentUserRole = "";
    private string _avatarLetter = "U";
    private ClaimsPrincipal? _user;
    private int _unreadNotifications = 0;
    private readonly DashboardStats _stats = new();
    private List<RecentInvoice> _recentInvoices = new();
    private List<Notification> _notifications = new();

    private string _greetingMessage => DateTime.Now.Hour switch
    {
        >= 5 and < 12 => "صباح الخير",
        >= 12 and < 17 => "مساء النور",
        >= 17 and < 21 => "مساء الخير",
        _ => "أهلاً بك"
    };

    private string _greetingIcon => DateTime.Now.Hour switch
    {
        >= 5 and < 12 => "☀️",
        >= 12 and < 17 => "🌤️",
        >= 17 and < 21 => "🌅",
        _ => "🌙"
    };

    private record QuickAction(string Label, string Icon, string Url, string Color, string Permission, string Action);

    private List<QuickAction> _quickActions = new()
    {
        new("العملاء", Icons.Material.Filled.Groups, "/customers", "#10b981", "frm_PartiesList", "View"),
        new("المدفوعات", Icons.Material.Filled.Payments, "/payments", "#f59e0b", "frm_Payments", "View"),
        new("الخزينة", Icons.Material.Filled.AccountBalance, "/cashbox/dashboard", "#D4AF37", "frmCashBox", "View"),
        new("المصروفات", Icons.Material.Filled.ReceiptLong, "/expenses", "#ef4444", "frmExpenses", "View"),
        new("قائمة الدخل", Icons.Material.Filled.Timeline, "/reports/income-statement", "#6366f1", "frmIncomeStatement", "View"),
        new("التدفقات النقدية", Icons.Material.Filled.WaterfallChart, "/reports/cash-flow", "#0ea5e9", "frm_CashFlowNew", "View"),
        new("المنتجات", Icons.Material.Filled.Inventory2, "/products", "#8b5cf6", "frm_ProductList", "View"),
        new("الرسوم الإضافية", Icons.Material.Filled.MonetizationOn, "/additional-charges", "#D4AF37", "frmAdditionalCharges", "View"),
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            _user = auth.User;
            if (_user.Identity?.IsAuthenticated == true)
            {
                _currentUserName = _user.Identity.Name ?? "";
                _currentUserRole = _user.FindFirst(ClaimTypes.Role)?.Value ?? "User";
                _avatarLetter = string.IsNullOrEmpty(_currentUserName) ? "U" : _currentUserName[..1].ToUpper();
            }
            await Task.WhenAll(LoadStats(), LoadRecentInvoices(), LoadNotifications());
        }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _isLoading = false; }
    }

    private async Task LoadStats()
    {
        try
        {
            var products = await ProductService.GetProductsAsync(null);
            _stats.ProductsCount = products.Count;
            _stats.PricedCount = products.Count(p => p.PricingStatusId == 3);
            var today = DateTime.Today;
            var monthStart = new DateTime(today.Year, today.Month, 1);
            _stats.CustomersCount = await Db.Parties.AsNoTracking().CountAsync();
            _stats.ActiveCustomers = await Db.Parties.AsNoTracking().CountAsync(p => p.IsActive == true);
            _stats.InvoicesCount = await Db.Transactions.AsNoTracking().CountAsync(t => t.TransactionDate >= monthStart && t.TransactionType == "Sale");
            _stats.InvoicesTotal = await Db.Transactions.AsNoTracking().Where(t => t.TransactionDate >= monthStart && t.TransactionType == "Sale").SumAsync(t => t.GrandTotal);
            var cashBoxes = await CashBoxService.GetCashBoxesAsync(true);
            _stats.CashBoxBalance = cashBoxes.Sum(c => c.CurrentBalance);
        }
        catch { }
    }

    private async Task LoadRecentInvoices()
    {
        try
        {
            _recentInvoices = await Db.Transactions.AsNoTracking()
                .Where(t => t.TransactionType == "Sale")
                .OrderByDescending(t => t.TransactionDate).Take(5)
                .Join(Db.Parties.AsNoTracking(), t => t.PartyId, p => p.PartyId,
                    (t, p) => new RecentInvoice
                    {
                        TransactionId = t.TransactionId, PartyName = p.PartyName,
                        GrandTotal = t.GrandTotal, InvoiceStatus = t.InvoiceStatus ?? "مفتوحة",
                        Date = t.TransactionDate
                    }).ToListAsync();
        }
        catch { _recentInvoices = new(); }
    }

    private async Task LoadNotifications()
    {
        try
        {
            _unreadNotifications = await NotificationService.GetUnreadCountAsync(_currentUserName, _currentUserRole);
            _notifications = await NotificationService.GetLatestAsync(_currentUserName, _currentUserRole, 8);
        }
        catch { _notifications = new(); }
    }

    private bool HasPermission(string formName, string action)
    {
        if (_user?.Identity?.IsAuthenticated != true) return false;
        return _user.HasClaim("Permission", $"{formName}:{action}");
    }

    private string GetStatusClass(string? status) => status switch
    {
        "مدفوعة" or "Paid" => "inv-st-paid",
        "ملغاة" or "Cancelled" => "inv-st-cancelled",
        "مفتوحة" or "Open" => "inv-st-open",
        _ => "inv-st-default"
    };

    private class DashboardStats
    {
        public int ProductsCount { get; set; }
        public int PricedCount { get; set; }
        public int CustomersCount { get; set; }
        public int ActiveCustomers { get; set; }
        public int InvoicesCount { get; set; }
        public decimal InvoicesTotal { get; set; }
        public decimal CashBoxBalance { get; set; }
    }

    private class RecentInvoice
    {
        public int TransactionId { get; set; }
        public string PartyName { get; set; } = "";
        public decimal GrandTotal { get; set; }
        public string InvoiceStatus { get; set; } = "";
        public DateTime Date { get; set; }
    }
}
