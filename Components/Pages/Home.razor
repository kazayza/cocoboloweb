    // ── Data Loaders ───────────────────────────────────────────────
    private async Task LoadKpi()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var today          = DateTime.Today;
            var thisMonthStart = new DateTime(today.Year, today.Month, 1);
            var lastMonthStart = thisMonthStart.AddMonths(-1);

            _kpi.CustomersTotal  = await db.Parties.AsNoTracking().CountAsync();
            _kpi.CustomersActive = await db.Parties.AsNoTracking().CountAsync(p => p.IsActive == true);

            if (_p.ViewSales)
            {
                _kpi.SalesThisMonth = await db.Transactions.AsNoTracking()
                    .Where(t => t.TransactionType == "Sale" && t.TransactionDate >= thisMonthStart)
                    .SumAsync(t => (decimal?)t.GrandTotal) ?? 0;

                var lastMonth = await db.Transactions.AsNoTracking()
                    .Where(t => t.TransactionType == "Sale"
                             && t.TransactionDate >= lastMonthStart
                             && t.TransactionDate < thisMonthStart)
                    .SumAsync(t => (decimal?)t.GrandTotal) ?? 0;

                _kpi.SalesGrowth = lastMonth > 0
                    ? Math.Round((_kpi.SalesThisMonth - lastMonth) / lastMonth * 100, 1)
                    : 0;
            }

            if (_p.ViewQuotes)
            {
                _kpi.QuotesTotal   = await db.Quotations.AsNoTracking().CountAsync();
                _kpi.QuotesPending = await db.Quotations.AsNoTracking()
                    .CountAsync(q => (q.Status == "Draft" || q.Status == "Sent") && q.InvoiceId == null);
            }

            if (_p.ViewCashBox)
            {
                var boxes = await CashBoxService.GetCashBoxesAsync(true);
                _kpi.CashBalance = boxes.Sum(b => b.CurrentBalance);
            }

            if (_p.ViewProducts)
            {
                _kpi.ProductsTotal        = await db.Products.AsNoTracking().CountAsync();
                _kpi.ProductsPendingPrice = await db.Products.AsNoTracking()
                    .CountAsync(p => p.PricingStatusId == 2);
            }

            if (_p.ViewEmployees)
            {
                _kpi.EmployeesTotal = await db.Employees.AsNoTracking()
                    .CountAsync(e => e.Status == "نشط");
            }

            if (_p.ViewExpenses)
            {
                _kpi.ExpensesThisMonth = await db.Expenses.AsNoTracking()
                    .Where(e => e.ExpenseDate >= thisMonthStart)
                    .SumAsync(e => (decimal?)e.Amount) ?? 0;
            }
        }
        catch (Exception ex) { Console.WriteLine($"[LoadKpi] {ex.Message}"); }
    }

    private async Task LoadRecentInvoices()
    {
        if (!_p.ViewSales) return;
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var txns = await db.Transactions.AsNoTracking()
                .Where(t => t.TransactionType == "Sale")
                .OrderByDescending(t => t.TransactionDate)
                .Take(5)
                .Select(t => new { t.TransactionId, t.PartyId, t.GrandTotal, t.InvoiceStatus, t.TransactionDate })
                .ToListAsync();

            if (!txns.Any()) { _recentInvoices = new(); return; }

            var partyIds  = txns.Select(t => t.PartyId).Distinct().ToList();
            var partyDict = await db.Parties.AsNoTracking()
                .Where(p => partyIds.Contains(p.PartyId))
                .Select(p => new { p.PartyId, p.PartyName })
                .ToDictionaryAsync(p => p.PartyId, p => p.PartyName ?? "غير محدد");

            _recentInvoices = txns.Select(t => new RecentInvoice
            {
                TransactionId = t.TransactionId,
                PartyName     = partyDict.TryGetValue(t.PartyId, out var pn) ? pn : "غير محدد",
                GrandTotal    = t.GrandTotal,
                InvoiceStatus = t.InvoiceStatus ?? "Open",
                Date          = t.TransactionDate
            }).ToList();
        }
        catch (Exception ex) { Console.WriteLine($"[LoadRecentInvoices] {ex.Message}"); _recentInvoices = new(); }
    }

    private async Task LoadRecentQuotes()
    {
        if (!_p.ViewQuotes) return;
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var quotes = await db.Quotations.AsNoTracking()
                .OrderByDescending(q => q.QuotationDate).Take(5)
                .Select(q => new { q.QuotationId, q.ReferenceNumber, q.QuotationDate, q.PartyId, q.GrandTotal, q.TotalAmount, q.Status })
                .ToListAsync();

            if (quotes.Any())
            {
                var partyIds  = quotes.Select(q => q.PartyId).Distinct().ToList();
                var partyDict = await db.Parties.AsNoTracking()
                    .Where(p => partyIds.Contains(p.PartyId))
                    .Select(p => new { p.PartyId, p.PartyName })
                    .ToDictionaryAsync(p => p.PartyId, p => p.PartyName ?? "غير محدد");

                _recentQuotes = quotes.Select(q => new RecentQuote
                {
                    QuotationId     = q.QuotationId,
                    ReferenceNumber = q.ReferenceNumber ?? $"QT-{q.QuotationDate.Year}-{q.QuotationId:D5}",
                    PartyName       = partyDict.TryGetValue(q.PartyId, out var pn) ? pn : "غير محدد",
                    GrandTotal      = q.GrandTotal ?? q.TotalAmount,
                    Status          = string.IsNullOrEmpty(q.Status) ? "Draft" : q.Status,
                    QuotationDate   = q.QuotationDate
                }).ToList();
            }

            _quotesDonut = new List<SliceData>
            {
                new("مسودة",         await db.Quotations.AsNoTracking().CountAsync(q => q.Status == "Draft")),
                new("تم الإرسال",    await db.Quotations.AsNoTracking().CountAsync(q => q.Status == "Sent")),
                new("مقبول",         await db.Quotations.AsNoTracking().CountAsync(q => q.Status == "Accepted")),
                new("مرفوض",         await db.Quotations.AsNoTracking().CountAsync(q => q.Status == "Rejected")),
                new("محوّل لفاتورة", await db.Quotations.AsNoTracking().CountAsync(q => q.Status == "Converted")),
                new("منتهي",         await db.Quotations.AsNoTracking().CountAsync(q => q.Status == "Expired")),
            }.Where(s => s.Value > 0).ToList();
        }
        catch (Exception ex) { Console.WriteLine($"[LoadRecentQuotes] {ex.Message}"); _recentQuotes = new(); }
    }

    private async Task LoadChartData()
    {
        if (!_p.ViewSales) return;
        try
        {
            using var db  = await DbFactory.CreateDbContextAsync();
            var days      = _chartPeriod;
            var start     = DateTime.Today.AddDays(-(days - 1));

            // تحديد التجميع: يومي للأسبوع والشهر، أسبوعي لـ 3 شهور، شهري للسنة
            bool groupByMonth = days >= 365;
            bool groupByWeek  = days >= 90 && !groupByMonth;

            var sales = await db.Transactions.AsNoTracking()
                .Where(t => t.TransactionType == "Sale" && t.TransactionDate >= start)
                .Select(t => new { Date = t.TransactionDate.Date, t.GrandTotal })
                .ToListAsync();

            var expenses = _p.ViewExpenses
                ? await db.Expenses.AsNoTracking()
                    .Where(e => e.ExpenseDate >= start)
                    .Select(e => new { Date = e.ExpenseDate.Date, e.Amount })
                    .ToListAsync()
                : new();

            if (groupByMonth)
            {
                // تجميع شهري
                _salesChart = Enumerable.Range(0, 12).Select(i =>
                {
                    var d   = start.AddMonths(i);
                    if (d > DateTime.Today) return null;
                    var amt = sales.Where(t => t.Date.Year == d.Year && t.Date.Month == d.Month).Sum(t => t.GrandTotal);
                    return new DayData(d.ToString("MM/yy"), amt);
                }).Where(x => x != null).Select(x => x!).ToList();

                _expensesChart = Enumerable.Range(0, 12).Select(i =>
                {
                    var d   = start.AddMonths(i);
                    if (d > DateTime.Today) return null;
                    var amt = expenses.Where(e => e.Date.Year == d.Year && e.Date.Month == d.Month).Sum(e => e.Amount);
                    return new DayData(d.ToString("MM/yy"), amt);
                }).Where(x => x != null).Select(x => x!).ToList();
            }
            else if (groupByWeek)
            {
                // تجميع أسبوعي
                int weeks = days / 7;
                _salesChart = Enumerable.Range(0, weeks).Select(i =>
                {
                    var wStart = start.AddDays(i * 7);
                    var wEnd   = wStart.AddDays(6);
                    var amt    = sales.Where(t => t.Date >= wStart && t.Date <= wEnd).Sum(t => t.GrandTotal);
                    return new DayData(wStart.ToString("dd/MM"), amt);
                }).ToList();

                _expensesChart = Enumerable.Range(0, weeks).Select(i =>
                {
                    var wStart = start.AddDays(i * 7);
                    var wEnd   = wStart.AddDays(6);
                    var amt    = expenses.Where(e => e.Date >= wStart && e.Date <= wEnd).Sum(e => e.Amount);
                    return new DayData(wStart.ToString("dd/MM"), amt);
                }).ToList();
            }
            else
            {
                // تجميع يومي
                _salesChart = Enumerable.Range(0, days).Select(i =>
                {
                    var d   = start.AddDays(i);
                    var amt = sales.Where(t => t.Date == d).Sum(t => t.GrandTotal);
                    return new DayData(d.ToString("dd/MM"), amt);
                }).ToList();

                _expensesChart = Enumerable.Range(0, days).Select(i =>
                {
                    var d   = start.AddDays(i);
                    var amt = expenses.Where(e => e.Date == d).Sum(e => e.Amount);
                    return new DayData(d.ToString("dd/MM"), amt);
                }).ToList();
            }
        }
        catch (Exception ex) { Console.WriteLine($"[LoadChartData] {ex.Message}"); }
    }

    private async Task LoadAttentionItems()
    {
        var items = new List<AttentionItem>();
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();

            if (_p.ViewQuotes)
            {
                var pending = await db.Quotations.AsNoTracking()
                    .CountAsync(q => (q.Status == "Draft" || q.Status == "Sent") && q.InvoiceId == null);
                if (pending > 0)
                    items.Add(new() { Emoji = "⏳", Title = $"{pending} عرض سعر في انتظار رد", Description = "تابع مع العملاء", Link = "/quotations", Severity = "medium" });

                var soon = DateTime.Today.AddDays(3);
                var exp  = await db.Quotations.AsNoTracking()
                    .CountAsync(q => q.ValidUntil.HasValue && q.ValidUntil.Value.Date >= DateTime.Today
                                  && q.ValidUntil.Value.Date <= soon
                                  && q.InvoiceId == null && q.Status != "Rejected" && q.Status != "Expired");
                if (exp > 0)
                    items.Add(new() { Emoji = "⚠️", Title = $"{exp} عرض ينتهي خلال 3 أيام", Description = "تواصل مع العملاء قبل الانتهاء", Link = "/quotations", Severity = "high" });

                var accepted = await db.Quotations.AsNoTracking()
                    .CountAsync(q => q.Status == "Accepted" && q.InvoiceId == null);
                if (accepted > 0)
                    items.Add(new() { Emoji = "✅", Title = $"{accepted} عرض مقبول جاهز للتحويل", Description = "حوّلها لفواتير الآن", Link = "/quotations", Severity = "high" });

                var expired = await db.Quotations.AsNoTracking()
                    .CountAsync(q => q.ValidUntil.HasValue && q.ValidUntil.Value.Date < DateTime.Today
                                  && q.InvoiceId == null && q.Status != "Rejected" && q.Status != "Expired");
                if (expired > 0)
                    items.Add(new() { Emoji = "⏰", Title = $"{expired} عرض منتهي الصلاحية", Description = "يحتاج مراجعة", Link = "/quotations", Severity = "low" });
            }

            if (_p.ViewSales)
            {
                var overdue = DateTime.Today.AddDays(-30);
                var oldInv  = await db.Transactions.AsNoTracking()
                    .CountAsync(t => t.TransactionType == "Sale"
                                  && t.InvoiceStatus == "Open"
                                  && t.TransactionDate <= overdue);
                if (oldInv > 0)
                    items.Add(new() { Emoji = "💰", Title = $"{oldInv} فاتورة متأخرة السداد (+30 يوم)", Description = "راجع المتأخرات", Link = "/sales/invoices", Severity = "high" });

                var oldComp = await db.Complaints.AsNoTracking()
                    .CountAsync(c => (c.Status == 1 || c.Status == 2)
                                  && c.CreatedAt.HasValue
                                  && c.CreatedAt.Value <= DateTime.Today.AddDays(-7));
                if (oldComp > 0)
                    items.Add(new() { Emoji = "🔴", Title = $"{oldComp} شكوى مفتوحة أكثر من 7 أيام", Description = "تابع الشكاوى القديمة", Link = "/complaints/list", Severity = "high" });
            }

            if (_p.ViewProducts)
            {
                var needPrice = await db.Products.AsNoTracking()
                    .CountAsync(p => p.PricingStatusId == 2);
                if (needPrice > 0)
                    items.Add(new() { Emoji = "🏷️", Title = $"{needPrice} منتج في انتظار التسعير", Description = "ادخل التكلفة لتحديد السعر", Link = "/products", Severity = "medium" });
            }
        }
        catch (Exception ex) { Console.WriteLine($"[LoadAttentionItems] {ex.Message}"); }

        _attentionItems = items;
    }

