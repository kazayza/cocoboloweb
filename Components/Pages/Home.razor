    // ── Init ───────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            // 🛡️ إذا لم يكن مسجلاً دخوله، نقوم بتحويله فوراً لصفحة الـ login
            if (user.Identity?.IsAuthenticated != true)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            _currentUserName = user.Identity?.Name ?? "User";
            _currentUserRole = user.FindFirst(ClaimTypes.Role)?.Value ?? "";

            // Greeting
            var h = DateTime.Now.Hour;
            if (h < 12) {
                _greetingIcon = "🌅"; _greetingMessage = $"صباح الخير، {_currentUserName}"; _greetingSubtext = "ابدأ يومك بإنجاز جديد وحقق أهدافك";
            } else if (h < 18) {
                _greetingIcon = "☀️"; _greetingMessage = $"مساء النور، {_currentUserName}"; _greetingSubtext = "تابع إنجازاتك واستثمر وقتك بفعالية";
            } else {
                _greetingIcon = "🌙"; _greetingMessage = $"مساء الخير، {_currentUserName}"; _greetingSubtext = "ختام يوم مثمر بإذن الله";
            }

            // Permissions from Claims
            _p = new Perms
            {
                ViewSales      = user.HasClaim("Permission", "frm_PartiesInvoices:View") || user.IsInRole("Admin"),
                ViewQuotes     = user.HasClaim("Permission", "frmQuotationsList:View")   || user.IsInRole("Admin"),
                ViewCustomers  = user.HasClaim("Permission", "frm_PartiesList:View")     || user.IsInRole("Admin"),
                ViewCashBox    = user.HasClaim("Permission", "frmCashBoxDashboard:View") || user.IsInRole("Admin"),
                ViewProducts   = user.HasClaim("Permission", "frm_ProductList:View")     || user.IsInRole("Admin"),
                ViewEmployees  = user.HasClaim("Permission", "frm_Employeeslist:View")   || user.IsInRole("Admin"),
                ViewExpenses   = user.HasClaim("Permission", "frm_ExpensesList:View")    || user.IsInRole("Admin"),
                ViewAttendance = user.HasClaim("Permission", "frm_empAttendance:View")   || user.IsInRole("Admin"),
                AddCustomer    = user.HasClaim("Permission", "frm_Parties:Add")          || user.IsInRole("Admin"),
                AddProduct     = user.HasClaim("Permission", "frm_ProductList:Add")      || user.IsInRole("Admin"),
                AddQuote       = user.HasClaim("Permission", "frmQuotationsList:Add")    || user.IsInRole("Admin"),
                AddInvoice     = user.HasClaim("Permission", "frm_SalesInvoiveNew:Add")  || user.IsInRole("Admin"),
                AddCashBox     = user.HasClaim("Permission", "frm_CashBoxManual:Add")    || user.IsInRole("Admin"),
                AddComplaint   = user.HasClaim("Permission", "frm_Complaints_Main:Add")  || user.IsInRole("Admin"),
                AddInspection  = user.HasClaim("Permission", "frmInspectionCharge:Add")  || user.IsInRole("Admin"),
            };

            // Load everything in parallel
            await Task.WhenAll(
                LoadKpi(),
                LoadRecentInvoices(),
                LoadRecentQuotes(),
                LoadAttentionItems(),
                LoadChartData(),
                LoadNotifications()
            );
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في التحميل: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    await LoadNotifications();
                    StateHasChanged();
                });
            }
            catch { }
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    public void Dispose() => _refreshTimer?.Dispose();

    // ── Quick Links ────────────────────────────────────────────────
