    // ── Helpers ────────────────────────────────────────────────────
    private static string FormatMoney(decimal v)
    {
        if (v >= 1_000_000) return $"{v/1_000_000:N1}M";
        if (v >= 1_000)     return $"{v/1_000:N1}K";
        return $"{v:N0}";
    }

    private static string GetStatusClass(string? s) => (s ?? "").ToLower() switch
    {
        var x when x.Contains("paid") && !x.Contains("partial") => "status-paid",
        var x when x.Contains("partial")                         => "status-partiallypaid",
        var x when x.Contains("cancel")                         => "status-cancelled",
        _                                                        => "status-open"
    };

    private static string GetInvoiceStatusText(string? s) => (s ?? "").ToLower() switch
    {
        "paid"          => "مدفوعة",
        "partiallypaid" => "جزئي",
        "open"          => "مفتوحة",
        "cancelled"     => "ملغية",
        _               => "مفتوحة"
    };

    private static string GetQuoteStatusText(string s) => s switch
    {
        "Draft"     => "مسودة",
        "Sent"      => "تم الإرسال",
        "Accepted"  => "مقبول",
        "Rejected"  => "مرفوض",
        "Converted" => "محوّل",
        "Expired"   => "منتهي",
        _           => s
    };

    private static string TimeAgo(DateTime dt)
    {
        var span = DateTime.Now - dt;
        if (span.TotalSeconds < 60) return "الآن";
        if (span.TotalMinutes < 60) return $"منذ {(int)span.TotalMinutes} دقيقة";
        if (span.TotalHours   < 24) return $"منذ {(int)span.TotalHours} ساعة";
        if (span.TotalDays    < 7)  return $"منذ {(int)span.TotalDays} يوم";
        return dt.ToString("dd/MM/yyyy");
    }

