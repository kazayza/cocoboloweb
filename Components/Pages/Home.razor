    .inv-list, .notif-list { display: flex; flex-direction: column; gap: .5rem; }
    .inv-row {
        display: grid;
        grid-template-columns: auto 1fr auto auto;
        gap: .75rem; align-items: center;
        padding: .75rem .85rem;
        border-radius: 10px;
        cursor: pointer; background: #f8fafc;
        transition: all .2s;
    }
    .inv-row:hover { background: #f1f5f9; transform: translateX(-4px); }
    .inv-id {
        font-weight: 700; color: #64748b;
