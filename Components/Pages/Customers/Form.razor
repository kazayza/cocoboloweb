@page "/customers/form"
@page "/customers/form/{Id:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims

@inject PartyService PartyService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

@if (_isLoading)
{
    <div class="loading-container">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Class="mt-4" Style="color: var(--gold);">جاري تحميل البيانات...</MudText>
    </div>
}
else
{
    <div class="customer-form-page" dir="rtl">

        <!-- Header -->
        <div class="page-header">
            <div class="header-content">
                <button class="back-btn" @onclick="GoBack">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" />
                </button>
                <div class="header-info">
                    <h1>@(IsNew ? "إضافة عميل جديد" : _model.PartyName)</h1>
                    <div class="header-meta">
                        @if (!IsNew)
                        {
                            <div class="meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" />
                                <span>كود: @_model.PartyId</span>
                            </div>
                        }
                        <div class="meta-item">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                            <span>@(IsNew ? "جديد" : _originalCreatedAt?.ToString("yyyy/MM/dd") ?? "جديد")</span>
                        </div>
                    </div>
                </div>
                @if (!IsNew && _model.StageId.HasValue)
{
    var currentStage = _salesStages.FirstOrDefault(s => s.StageId == _model.StageId);
    if (currentStage != null)
    {
        <span class="stage-badge"
              style="background: @(currentStage.StageColor)33; color: white; border: 1px solid @(currentStage.StageColor)88;">
            @(currentStage.StageNameAr ?? currentStage.StageName)
        </span>
    }
}
            </div>
        </div>

        <!-- Error -->
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled"
                      ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null"
                      Class="mb-4" Style="border-radius: 12px;">
                @_errorMessage
            </MudAlert>
        }

        <!-- Tabs -->
        <MudPaper Class="tabs-container" Elevation="0">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
                     PanelClass="tab-panel" Class="custom-tabs">

                <!-- Tab 1: البيانات الأساسية -->
                <MudTabPanel Text="البيانات الأساسية" Icon="@Icons.Material.Filled.Person">
                    <div class="tab-content">
                        <div class="tab-header">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Class="tab-icon" />
                            <div class="tab-header-text">
                                <h2>البيانات الأساسية</h2>
                                <p>معلومات العميل الأساسية</p>
                            </div>
                        </div>

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>اسم العميل <span class="required">*</span></label>
                                    <MudTextField @bind-Value="_model.PartyName"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="أدخل اسم العميل"
                                                  Required="true"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Person" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>نوع الطرف <span class="required">*</span></label>
                                    <MudSelect T="int" @bind-Value="_model.PartyType"
                                               Variant="Variant.Outlined"
                                               Placeholder="اختر النوع"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.Category">
                                        @foreach (var type in _partyTypes)
                                        {
                                            <MudSelectItem Value="@type.PartyTypeId">@type.PartyTypeName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>الوظيفة</label>
                                    <MudTextField @bind-Value="_model.JobTitle"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="مثال: مهندس، مقاول، صاحب شركة"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Work" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
    <div class="form-field">
        <label>مرحلة العميل</label>
        <MudSelect T="int?" @bind-Value="_model.StageId"
                   Variant="Variant.Outlined"
                   Placeholder="اختر المرحلة"
                   Adornment="Adornment.Start"
                   AdornmentIcon="@Icons.Material.Filled.TrendingUp">
            @foreach (var stage in _salesStages)
            {
                <MudSelectItem T="int?" Value="@((int?)stage.StageId)">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <span style="width: 12px; height: 12px; border-radius: 50%; background: @stage.StageColor; display: inline-block;"></span>
                        @(stage.StageNameAr ?? stage.StageName)
                    </div>
                </MudSelectItem>
            }
        </MudSelect>
    </div>
</MudItem>

                            <MudItem xs="12" md="6">
    <div class="form-field">
        <label>التقييم</label>
        <div class="rating-container">
            <div class="rating-stars">
                @for (int i = 1; i <= 5; i++)
                {
                    var starValue = i;
                    <MudIconButton Icon="@(starValue <= _ratingValue
                                          ? Icons.Material.Filled.Star
                                          : Icons.Material.Outlined.StarBorder)"
                                   Size="Size.Large"
                                   OnClick="@(() => SetRating(starValue))"
                                   Class="@(starValue <= _ratingValue ? "star-filled" : "star-empty")" />
                }
            </div>
            <div class="rating-info">
                @if (_ratingValue > 0)
                {
                    <span class="rating-text">@GetRatingText(_ratingValue)</span>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="@(() => SetRating(0))"
                                   Title="إزالة التقييم"
                                   Class="rating-clear" />
                }
                else
                {
                    <span class="rating-text empty">اضغط على نجمة للتقييم</span>
                }
            </div>
        </div>
    </div>
</MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>الرقم القومي</label>
                                    <MudTextField @bind-Value="_model.NationalId"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="14 رقم"
                                                  MaxLength="14"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Badge" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>تابع لـ (مكتب / وسيط)</label>
                                    <MudAutocomplete T="PartyListDto"
                                                     @bind-Value="_selectedParent"
                                                     Variant="Variant.Outlined"
                                                     Placeholder="اختر المكتب أو الوسيط..."
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Filled.AccountTree"
                                                     SearchFunc="@SearchParents"
                                                     ToStringFunc="@(p => p?.PartyName ?? "")"
                                                     Clearable="true"
                                                     MaxItems="30" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>مصدر التواصل</label>
                                    <MudSelect T="int?" @bind-Value="_model.ContactSourceId"
                                               Variant="Variant.Outlined"
                                               Placeholder="كيف عرف عنك؟"
                                               Clearable="true"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.Source">
                                        @foreach (var source in _contactSources)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)source.SourceId)">
                                                @(source.SourceNameAr ?? source.SourceName)
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>مصدر الإحالة</label>
                                    <MudSelect T="int?" @bind-Value="_model.ReferralSourceId"
                                               Variant="Variant.Outlined"
                                               Placeholder="من أحال العميل؟"
                                               Clearable="true"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.Share">
                                        @foreach (var source in _referralSources)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)source.ReferralSourceId)">
                                                @source.SourceName
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>الحالة</label>
                                    <MudSwitch @bind-Value="_isActive"
                                               Color="Color.Success"
                                               Label="@(_isActive ? "نشط" : "غير نشط")" />
                                </div>
                            </MudItem>

                            <MudItem xs="12">
                                <div class="form-field">
                                    <label>ملاحظات</label>
                                    <MudTextField @bind-Value="_model.Notes"
                                                  Variant="Variant.Outlined"
                                                  Lines="3"
                                                  Placeholder="أي ملاحظات إضافية..."
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Notes" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudTabPanel>

                <!-- Tab 2: التواصل والعنوان -->
                <MudTabPanel Text="التواصل والعنوان" Icon="@Icons.Material.Filled.ContactPhone">
                    <div class="tab-content">
                        <div class="tab-header">
                            <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Class="tab-icon" />
                            <div class="tab-header-text">
                                <h2>بيانات التواصل والعنوان</h2>
                                <p>أرقام الهاتف والبريد والعنوان</p>
                            </div>
                        </div>

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>الهاتف الأساسي</label>
                                    <MudTextField @bind-Value="_model.Phone"
              Variant="Variant.Outlined"
              Placeholder="01xxxxxxxxx"
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Phone"
              MaxLength="15"
              HelperText="مثال: 01012345678"
              Validation="@(new Func<string, string>(ValidatePhoneField))" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>هاتف إضافي</label>
                                    <MudTextField @bind-Value="_model.Phone2"
              Variant="Variant.Outlined"
              Placeholder="01xxxxxxxxx"
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.PhoneAndroid"
              MaxLength="15"
              Validation="@(new Func<string, string>(ValidatePhoneField))" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>البريد الإلكتروني</label>
                                    <MudTextField @bind-Value="_model.Email"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="example@email.com"
                                                  InputType="InputType.Email"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Email" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>شخص التواصل</label>
                                    <MudTextField @bind-Value="_model.ContactPerson"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="اسم الشخص المسؤول"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.PersonPin" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>المدينة</label>
                                    <MudTextField @bind-Value="_model.City"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="مثال: القاهرة"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.LocationCity" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>المنطقة</label>
                                    <MudTextField @bind-Value="_model.Area"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="مثال: مدينة نصر"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Map" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>الدور</label>
                                    <MudTextField @bind-Value="_model.FloorNumber"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="رقم الدور"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Apartment" />
                                </div>
                            </MudItem>

                            <MudItem xs="12">
                                <div class="form-field">
                                    <label>العنوان التفصيلي</label>
                                    <MudTextField @bind-Value="_model.Address"
                                                  Variant="Variant.Outlined"
                                                  Lines="2"
                                                  Placeholder="العنوان بالكامل..."
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.LocationOn" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudTabPanel>

                <!-- Tab 3: البيانات المالية -->
                <MudTabPanel Text="البيانات المالية" Icon="@Icons.Material.Filled.AccountBalance">
                    <div class="tab-content">
                        <div class="tab-header">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="tab-icon" />
                            <div class="tab-header-text">
                                <h2>البيانات المالية</h2>
                                <p>الرصيد الافتتاحي والبيانات الضريبية</p>
                            </div>
                        </div>

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>الرصيد الافتتاحي</label>
                                    <MudNumericField T="decimal?" @bind-Value="_model.OpeningBalance"
                                                     Variant="Variant.Outlined"
                                                     Placeholder="0.00"
                                                     Format="N2"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Filled.Money" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>نوع الرصيد</label>
                                    <MudSelect T="string" @bind-Value="_model.BalanceType"
                                               Variant="Variant.Outlined"
                                               Placeholder="اختر النوع"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.SwapHoriz">
                                        <MudSelectItem T="string" Value="@("D")">مدين (له)</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("C")">دائن (عليه)</MudSelectItem>
                                    </MudSelect>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>الرقم الضريبي</label>
                                    <MudTextField @bind-Value="_model.TaxNumber"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="الرقم الضريبي"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Receipt" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudTabPanel>

                <!-- Tab 4: جهات الاتصال -->
                <MudTabPanel Text="جهات الاتصال" Icon="@Icons.Material.Filled.Contacts">
                    <div class="tab-content">
                        <div class="tab-header">
                            <MudIcon Icon="@Icons.Material.Filled.Contacts" Class="tab-icon" />
                            <div class="tab-header-text">
                                <h2>جهات الاتصال</h2>
                                <p>إضافة وإدارة جهات اتصال العميل</p>
                            </div>
                            <MudButton Variant="Variant.Filled" Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                       OnClick="AddContact" Size="Size.Medium">
                                إضافة جهة اتصال
                            </MudButton>
                        </div>

                        @if (_model.Contacts.Any())
                        {
                            <div class="contacts-list">
                                @foreach (var (contact, index) in _model.Contacts.Select((c, i) => (c, i)))
                                {
                                    <div class="contact-card">
                                        <div class="contact-number">@(index + 1)</div>
                                        <div class="contact-fields">
                                            <MudGrid>
                                                <MudItem xs="12" md="3">
                                                    <MudTextField @bind-Value="contact.ContactName"
                                                                  Variant="Variant.Outlined"
                                                                  Placeholder="الاسم"
                                                                  Margin="Margin.Dense"
                                                                  Adornment="Adornment.Start"
                                                                  AdornmentIcon="@Icons.Material.Filled.Person" />
                                                </MudItem>
                                                <MudItem xs="12" md="2">
                                                    <MudTextField @bind-Value="contact.JobTitle"
                                                                  Variant="Variant.Outlined"
                                                                  Placeholder="الوظيفة"
                                                                  Margin="Margin.Dense"
                                                                  Adornment="Adornment.Start"
                                                                  AdornmentIcon="@Icons.Material.Filled.Work" />
                                                </MudItem>
                                                <MudItem xs="12" md="2">
                                                    <MudTextField @bind-Value="contact.Phone"
                                                                  Variant="Variant.Outlined"
                                                                  Placeholder="الهاتف"
                                                                  Margin="Margin.Dense"
                                                                  Adornment="Adornment.Start"
                                                                  AdornmentIcon="@Icons.Material.Filled.Phone" />
                                                </MudItem>
                                                <MudItem xs="12" md="3">
                                                    <MudTextField @bind-Value="contact.Email"
                                                                  Variant="Variant.Outlined"
                                                                  Placeholder="البريد"
                                                                  Margin="Margin.Dense"
                                                                  Adornment="Adornment.Start"
                                                                  AdornmentIcon="@Icons.Material.Filled.Email" />
                                                </MudItem>
                                                <MudItem xs="12" md="2" Class="d-flex align-center gap-2">
                                                    <MudCheckBox @bind-Value="contact.IsPrimary"
                                                                 Label="أساسي"
                                                                 Color="Color.Primary"
                                                                 Dense="true" />
                                                </MudItem>
                                            </MudGrid>
                                        </div>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error" Size="Size.Medium"
                                                       OnClick="@(() => RemoveContact(contact))" />
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">
                                <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Size="Size.Large" />
                                <h3>لا توجد جهات اتصال</h3>
                                <p>أضف جهات اتصال للعميل مثل المهندس المسؤول أو المحاسب</p>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.PersonAdd"
                                           OnClick="AddContact" Size="Size.Large">
                                    إضافة أول جهة اتصال
                                </MudButton>
                            </div>
                        }
                    </div>
                </MudTabPanel>

            </MudTabs>
        </MudPaper>

        <!-- Sticky Actions -->
        <div class="form-actions-sticky">
            <div class="form-actions">
                <MudButton Variant="Variant.Outlined" OnClick="GoBack"
                           Size="Size.Large" StartIcon="@Icons.Material.Filled.Close"
                           Class="cancel-btn">
                    إلغاء
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Check"
                           OnClick="SaveParty" Size="Size.Large"
                           Disabled="@_isSaving" Class="save-btn">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Surface"
                                             Indeterminate="true" Class="me-2" />
                    }
                    @(IsNew ? "إضافة العميل" : "حفظ التعديلات")
                </MudButton>
            </div>
        </div>

    </div>
}

<style>
    /* ============================
       Page Layout
       ============================ */
    .customer-form-page {
        padding: 2rem;
        max-width: 1600px;
        margin: 0 auto;
        padding-bottom: 120px;
    }

    .loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
    }

    /* ============================
       Header
       ============================ */
    .page-header {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px var(--gold-border);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .back-btn {
        width: 48px;
        height: 48px;
        background: rgba(255,255,255,0.2);
        border: none;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        background: rgba(255,255,255,0.3);
        transform: translateX(5px);
    }

    .header-info { flex: 1; }

    .header-info h1 {
        color: white;
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
    }

    .header-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255,255,255,0.9);
        font-size: 0.9rem;
    }
    /* ============================
   Rating
   ============================ */
.rating-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.rating-stars {
    display: flex;
    gap: 0.15rem;
    align-items: center;
}

.star-filled {
    color: var(--gold) !important;
    transform: scale(1.1);
    transition: all 0.2s ease;
}

.star-empty {
    color: var(--mud-palette-divider) !important;
    transition: all 0.2s ease;
}

.star-empty:hover {
    color: var(--gold) !important;
    transform: scale(1.15);
}

.rating-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.rating-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gold);
    padding: 0.25rem 0.75rem;
    background: var(--gold-subtle);
    border-radius: 8px;
}

.rating-text.empty {
    color: var(--mud-palette-text-secondary);
    background: none;
    font-weight: 400;
}

.rating-clear {
