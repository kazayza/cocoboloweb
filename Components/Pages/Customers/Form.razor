@page "/customers/form"
@page "/customers/form/{Id:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims

@inject PartyService PartyService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ LOADING STATE                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            </div>
            <MudText Typo="Typo.h6" Class="loading-text">جاري تحميل البيانات...</MudText>
            <div class="loading-dots">
                <span></span><span></span><span></span>
            </div>
        </div>
    </div>
}
else
{
    <div class="customer-form-page" dir="rtl">

        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ BACKGROUND DECORATIONS                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <div class="page-bg-decorations">
            <div class="bg-orb bg-orb-1"></div>
            <div class="bg-orb bg-orb-2"></div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ TOP ACCENT BAR                                                           -->
        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <div class="top-accent-bar">
            <div class="accent-shimmer"></div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ PREMIUM HEADER                                                           -->
        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <div class="form-header">
            <div class="header-bg">
                <div class="header-gradient"></div>
                <div class="header-orbs">
                    <div class="header-orb orb-1"></div>
                    <div class="header-orb orb-2"></div>
                </div>
                <div class="header-grid"></div>
            </div>

            <div class="header-content">
                <button class="back-btn" @onclick="GoBack">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
                </button>

                <div class="header-icon-wrapper">
                    <div class="header-icon-glow"></div>
                    <div class="header-icon">
                        <MudIcon Icon="@(IsNew ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" Size="Size.Large" />
                    </div>
                    @if (!IsNew)
                    {
                        <div class="header-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                        </div>
                    }
                </div>

                <div class="header-info">
                    <div class="header-title-row">
                        <h1>@(IsNew ? "إضافة عميل جديد" : _model.PartyName)</h1>
                        @if (!IsNew)
                        {
                            <span class="customer-id-badge">#@_model.PartyId</span>
                        }
                    </div>
                    <div class="header-meta">
                        @if (!IsNew)
                        {
                            <div class="meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                                <span>@(_originalCreatedAt?.ToString("yyyy/MM/dd  HH:mm") ?? "—")</span>
                            </div>
                            <div class="meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.PersonOutline" Size="Size.Small" />
                                <span>بواسطة: @(_model.CreatedBy ?? _currentUserName ?? "—")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(_model.LastUpdatedBy))
                            {
                                <div class="meta-item meta-updated">
                                    <MudIcon Icon="@Icons.Material.Filled.EditNote" Size="Size.Small" />
                                    <span>آخر تعديل: @_model.LastUpdatedBy — @(_model.LastUpdatedAt?.ToString("MM/dd HH:mm") ?? "")</span>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="meta-item meta-new">
                                <MudIcon Icon="@Icons.Material.Filled.PersonOutline" Size="Size.Small" />
                                <span>الإضافة بواسطة: @_currentUserName</span>
                            </div>
                        }
                        <div class="meta-item">
                            <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                            <span>@(_partyTypes.FirstOrDefault(t => t.PartyTypeId == _model.PartyType)?.PartyTypeName ?? "عميل")</span>
                        </div>
                    </div>
                </div>

                @if (!IsNew && _model.StageId.HasValue)
                {
                    var currentStage = _salesStages.FirstOrDefault(s => s.StageId == _model.StageId);
                    if (currentStage != null)
                    {
                        <div class="stage-badge-wrapper">
                            <span class="stage-badge" style="--stage-color: @currentStage.StageColor;">
                                <span class="stage-dot"></span>
                                @(currentStage.StageNameAr ?? currentStage.StageName)
                            </span>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ ERROR ALERT                                                              -->
        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="error-alert">
                <div class="error-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Error" />
                </div>
                <span class="error-text">@_errorMessage</span>
                <button class="error-close" @onclick="() => _errorMessage = null">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                </button>
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ TABS                                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <div class="tabs-wrapper">
            <div class="custom-tab-nav">
                <button type="button" class="custom-tab-btn @(_activeTab == 0 ? "active" : "")" @onclick="() => SetActiveTab(0)">
                    <span class="tab-num">1</span>
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    <span class="tab-text">البيانات الأساسية</span>
                </button>
                <button type="button" class="custom-tab-btn @(_activeTab == 1 ? "active" : "")" @onclick="() => SetActiveTab(1)">
                    <span class="tab-num">2</span>
                    <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Size="Size.Small" />
                    <span class="tab-text">التواصل والعنوان</span>
                </button>
                <button type="button" class="custom-tab-btn @(_activeTab == 2 ? "active" : "")" @onclick="() => SetActiveTab(2)">
                    <span class="tab-num">3</span>
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" />
                    <span class="tab-text">البيانات المالية</span>
                </button>
                <button type="button" class="custom-tab-btn @(_activeTab == 3 ? "active" : "")" @onclick="() => SetActiveTab(3)">
                    <span class="tab-num">4</span>
                    <MudIcon Icon="@Icons.Material.Filled.Contacts" Size="Size.Small" />
                    <span class="tab-text">جهات الاتصال</span>
                        @if (_model.Contacts.Any())
                        {
                            <span class="tab-count">@_model.Contacts.Count</span>
                        }
                </button>
            </div>

            <div class="custom-tab-panels">
                @if (_activeTab == 0)
                {

                        <div class="tab-content">
                            <div class="section-header">
                                <div class="section-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" />
                                </div>
                                <div class="section-info">
                                    <h2>البيانات الأساسية</h2>
                                    <p>معلومات العميل الأساسية والتصنيف</p>
                                </div>
                            </div>

                            <div class="form-grid">
                                <!-- اسم العميل -->
                                <div class="form-field span-2">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                        اسم العميل <span class="required">*</span>
                                    </label>
                                    <MudTextField @bind-Value="_model.PartyName"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="أدخل اسم العميل الكامل"
                                                  Required="true"
                                                  Class="premium-input" />
                                </div>

                                <!-- نوع الطرف -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                                        نوع الطرف <span class="required">*</span>
                                    </label>
                                    <MudSelect T="int" @bind-Value="_model.PartyType"
                                               Variant="Variant.Outlined"
                                               Placeholder="اختر النوع"
                                               Class="premium-input">
                                        @foreach (var type in _partyTypes)
                                        {
                                            <MudSelectItem Value="@type.PartyTypeId">@type.PartyTypeName</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                <!-- الوظيفة -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Work" Size="Size.Small" />
                                        الوظيفة
                                    </label>
                                    <MudTextField @bind-Value="_model.JobTitle"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="مثال: مهندس، مقاول"
                                                  Class="premium-input" />
                                </div>

                                <!-- مرحلة العميل -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                                        مرحلة العميل
                                    </label>
                                    <MudSelect T="int?" @bind-Value="_model.StageId"
                                               Variant="Variant.Outlined"
                                               Placeholder="اختر المرحلة"
                                               Class="premium-input">
                                        @foreach (var stage in _salesStages)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)stage.StageId)">
                                                <div class="stage-option">
                                                    <span class="stage-color-dot" style="background: @stage.StageColor;"></span>
                                                    @(stage.StageNameAr ?? stage.StageName)
                                                </div>
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                <!-- التقييم -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                                        التقييم
                                    </label>
                                    <div class="rating-box">
                                        <div class="rating-stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                var starValue = i;
                                                <button class="star-btn @(starValue <= _ratingValue ? "filled" : "")"
                                                        @onclick="@(() => SetRating(starValue))">
                                                    <MudIcon Icon="@(starValue <= _ratingValue ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)" />
                                                </button>
                                            }
                                        </div>
                                        @if (_ratingValue > 0)
                                        {
                                            <span class="rating-label">@GetRatingText(_ratingValue)</span>
                                            <button class="rating-clear" @onclick="@(() => SetRating(0))">
                                                <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                            </button>
                                        }
                                    </div>
                                </div>

                                <!-- الرقم القومي -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" />
                                        الرقم القومي
                                    </label>
                                    <MudTextField @bind-Value="_model.NationalId"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="14 رقم"
                                                  MaxLength="14"
                                                  Class="premium-input" />
                                </div>

                                <!-- تابع لـ -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" />
                                        تابع لـ (مكتب / وسيط)
                                    </label>
                                    <MudAutocomplete T="PartyListDto"
                                                     @bind-Value="_selectedParent"
                                                     Variant="Variant.Outlined"
                                                     Placeholder="اختر المكتب أو الوسيط..."
                                                     SearchFunc="@SearchParents"
                                                     ToStringFunc="@(p => p?.PartyName ?? "")"
                                                     Clearable="true"
                                                     MaxItems="30"
                                                     Class="premium-input" />
                                </div>

                                <!-- مصدر التواصل -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Source" Size="Size.Small" />
                                        مصدر التواصل
                                    </label>
                                    <MudSelect T="int?" @bind-Value="_model.ContactSourceId"
                                               Variant="Variant.Outlined"
                                               Placeholder="كيف عرف عنك؟"
                                               Clearable="true"
                                               Class="premium-input">
                                        @foreach (var source in _contactSources)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)source.SourceId)">
                                                @(source.SourceNameAr ?? source.SourceName)
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                <!-- مصدر الإحالة -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Share" Size="Size.Small" />
                                        مصدر الإحالة
                                    </label>
                                    <MudSelect T="int?" @bind-Value="_model.ReferralSourceId"
                                               Variant="Variant.Outlined"
                                               Placeholder="من أحال العميل؟"
                                               Clearable="true"
                                               Class="premium-input">
                                        @foreach (var source in _referralSources)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)source.ReferralSourceId)">
                                                @source.SourceName
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                <!-- الحالة -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.ToggleOn" Size="Size.Small" />
                                        الحالة
                                    </label>
                                    <div class="status-toggle">
                                        <button class="status-btn @(_isActive ? "active" : "")"
                                                @onclick="() => _isActive = true">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                            نشط
                                        </button>
                                        <button class="status-btn @(!_isActive ? "inactive" : "")"
                                                @onclick="() => _isActive = false">
                                            <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" />
                                            غير نشط
                                        </button>
                                    </div>
                                </div>

                                <!-- ملاحظات -->
                                <div class="form-field span-2">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" />
                                        ملاحظات
                                    </label>
                                    <MudTextField @bind-Value="_model.Notes"
                                                  Variant="Variant.Outlined"
                                                  Lines="3"
                                                  Placeholder="أي ملاحظات إضافية..."
                                                  Class="premium-input" />
                                </div>
                            </div>
                        </div>
                    
                }

                @if (_activeTab == 1)
                {

                        <div class="tab-content">
                            <div class="section-header">
                                <div class="section-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.ContactPhone" />
                                </div>
                                <div class="section-info">
                                    <h2>بيانات التواصل والعنوان</h2>
                                    <p>أرقام الهاتف والبريد والموقع</p>
                                </div>
                            </div>

                            <div class="form-grid">
                                <!-- الهاتف الأساسي -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                                        الهاتف الأساسي
                                    </label>
                                    <MudTextField @bind-Value="_model.Phone"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="01xxxxxxxxx"
                                                  MaxLength="15"
                                                  Validation="@(new Func<string, string>(ValidatePhoneField))"
                                                  Class="premium-input" />
                                </div>

                                <!-- هاتف إضافي -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Size="Size.Small" />
                                        هاتف إضافي
                                    </label>
                                    <MudTextField @bind-Value="_model.Phone2"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="01xxxxxxxxx"
                                                  MaxLength="15"
                                                  Validation="@(new Func<string, string>(ValidatePhoneField))"
                                                  Class="premium-input" />
                                </div>

                                <!-- البريد الإلكتروني -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" />
                                        البريد الإلكتروني
                                    </label>
                                    <MudTextField @bind-Value="_model.Email"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="example@email.com"
                                                  InputType="InputType.Email"
                                                  Class="premium-input" />
                                </div>

                                <!-- شخص التواصل -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.PersonPin" Size="Size.Small" />
                                        شخص التواصل
                                    </label>
                                    <MudTextField @bind-Value="_model.ContactPerson"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="اسم الشخص المسؤول"
                                                  Class="premium-input" />
                                </div>

                                <!-- المدينة -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationCity" Size="Size.Small" />
                                        المدينة
                                    </label>
                                    <MudTextField @bind-Value="_model.City"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="مثال: القاهرة"
                                                  Class="premium-input" />
                                </div>

                                <!-- المنطقة -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" />
                                        المنطقة
                                    </label>
                                    <MudTextField @bind-Value="_model.Area"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="مثال: مدينة نصر"
                                                  Class="premium-input" />
                                </div>

                                <!-- الدور -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Apartment" Size="Size.Small" />
                                        الدور
                                    </label>
                                    <MudTextField @bind-Value="_model.FloorNumber"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="رقم الدور"
                                                  Class="premium-input" />
                                </div>

                                <!-- فارغ للمحاذاة -->
                                <div class="form-field"></div>

                                <!-- العنوان التفصيلي -->
                                <div class="form-field span-2">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                                        العنوان التفصيلي
                                    </label>
                                    <MudTextField @bind-Value="_model.Address"
                                                  Variant="Variant.Outlined"
                                                  Lines="2"
                                                  Placeholder="العنوان بالكامل..."
                                                  Class="premium-input" />
                                </div>
                            </div>
                        </div>
                    
                }

                @if (_activeTab == 2)
                {

                        <div class="tab-content">
                            <div class="section-header">
                                <div class="section-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" />
                                </div>
                                <div class="section-info">
                                    <h2>البيانات المالية</h2>
                                    <p>الرصيد الافتتاحي والبيانات الضريبية</p>
                                </div>
                            </div>

                            <div class="form-grid">
                                <!-- الرصيد الافتتاحي -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Money" Size="Size.Small" />
                                        الرصيد الافتتاحي
                                    </label>
                                    <MudNumericField T="decimal?" @bind-Value="_model.OpeningBalance"
                                                     Variant="Variant.Outlined"
                                                     Placeholder="0.00"
                                                     Format="N2"
                                                     Adornment="Adornment.End"
                                                     AdornmentText="ج.م"
                                                     Class="premium-input" />
                                </div>

                                <!-- نوع الرصيد -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" />
                                        نوع الرصيد
                                    </label>
                                    <div class="balance-type-toggle">
                                        <button class="balance-btn @(_model.BalanceType == "D" ? "debit" : "")"
                                                @onclick="SetBalanceDebit">
                                            <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />
                                            مدين (له)
                                        </button>
                                        <button class="balance-btn @(_model.BalanceType == "C" ? "credit" : "")"
                                                @onclick="SetBalanceCredit">
                                            <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" />
                                            دائن (عليه)
                                        </button>
                                    </div>
                                </div>

                                <!-- الرقم الضريبي -->
                                <div class="form-field">
                                    <label class="field-label">
                                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" />
                                        الرقم الضريبي
                                    </label>
                                    <MudTextField @bind-Value="_model.TaxNumber"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="الرقم الضريبي"
                                                  Class="premium-input" />
                                </div>
                            </div>
                        </div>
                    
                }

                @if (_activeTab == 3)
                {

                        <div class="tab-content">
                            <div class="section-header">
                                <div class="section-icon">
                                    <MudIcon Icon="@Icons.Material.Filled.Contacts" />
                                </div>
                                <div class="section-info">
                                    <h2>جهات الاتصال</h2>
                                    <p>إضافة وإدارة جهات اتصال العميل</p>
                                </div>
                                <MudButton Variant="Variant.Filled"
                                           StartIcon="@Icons.Material.Filled.PersonAdd"
                                           OnClick="AddContact"
                                           Class="add-contact-btn">
                                    إضافة جهة اتصال
                                </MudButton>
                            </div>

                            @if (_model.Contacts.Any())
                            {
                                <div class="contacts-list">
                                    @foreach (var (contact, index) in _model.Contacts.Select((c, i) => (c, i)))
                                    {
                                        <div class="contact-card">
                                            <div class="contact-header">
                                                <div class="contact-number">@(index + 1)</div>
                                                <span class="contact-title">جهة اتصال @(index + 1)</span>
                                                @if (contact.IsPrimary)
                                                {
                                                    <span class="primary-badge">أساسي</span>
                                                }
                                                <button class="contact-delete" @onclick="@(() => RemoveContact(contact))">
                                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                                </button>
                                            </div>
                                            <div class="contact-body">
                                                <div class="contact-grid">
                                                    <MudTextField @bind-Value="contact.ContactName"
                                                                  Variant="Variant.Outlined"
                                                                  Label="الاسم"
                                                                  Margin="Margin.Dense"
                                                                  Class="premium-input" />
                                                    <MudTextField @bind-Value="contact.JobTitle"
                                                                  Variant="Variant.Outlined"
                                                                  Label="الوظيفة"
                                                                  Margin="Margin.Dense"
                                                                  Class="premium-input" />
                                                    <MudTextField @bind-Value="contact.Phone"
                                                                  Variant="Variant.Outlined"
                                                                  Label="الهاتف"
                                                                  Margin="Margin.Dense"
                                                                  Class="premium-input" />
                                                    <MudTextField @bind-Value="contact.Email"
                                                                  Variant="Variant.Outlined"
                                                                  Label="البريد"
                                                                  Margin="Margin.Dense"
                                                                  Class="premium-input" />
                                                </div>
                                                <div class="contact-footer">
                                                    <MudCheckBox @bind-Value="contact.IsPrimary"
                                                                 Label="جهة اتصال أساسية"
                                                                 Color="Color.Primary"
                                                                 Dense="true" />
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-contacts">
                                    <div class="empty-icon">
                                        <MudIcon Icon="@Icons.Material.Filled.ContactPhone" />
                                    </div>
                                    <h3>لا توجد جهات اتصال</h3>
                                    <p>أضف جهات اتصال للعميل مثل المهندس المسؤول أو المحاسب</p>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.PersonAdd"
                                               OnClick="AddContact">
                                        إضافة أول جهة اتصال
                                    </MudButton>
                                </div>
                            }
                        </div>
                    
                }

            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ STICKY ACTIONS                                                           -->
        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <div class="actions-bar">
            <div class="actions-content">
                <div class="actions-info">
                    @if (!IsNew)
                    {
                        <span class="last-update">
                            <MudIcon Icon="@Icons.Material.Filled.Update" Size="Size.Small" />
                            آخر تحديث: @(_model.LastUpdatedAt?.ToString("yyyy/MM/dd HH:mm") ?? _originalCreatedAt?.ToString("yyyy/MM/dd HH:mm") ?? "—")
                        </span>
                        <span class="last-update">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            @(_model.LastUpdatedBy ?? _model.CreatedBy ?? "—")
                        </span>
                    }
                    else
                    {
                        <span class="last-update">
                            <MudIcon Icon="@Icons.Material.Filled.FiberNew" Size="Size.Small" />
                            إضافة جديدة بواسطة: @_currentUserName
                        </span>
                    }
                </div>
                <div class="actions-buttons">
                    <MudButton Variant="Variant.Outlined"
                               OnClick="GoBack"
                               StartIcon="@Icons.Material.Filled.Close"
                               Class="btn-cancel">
                        إلغاء
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="SaveParty"
                               Disabled="@_isSaving"
                               Class="btn-save">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                        }
                        @(IsNew ? "إضافة العميل" : "حفظ التعديلات")
                    </MudButton>
                </div>
            </div>
        </div>

    </div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐⭐⭐ PREMIUM STYLES ⭐⭐⭐                                                                              -->
<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════════ -->
<style>
    /* ═══════════════════════════════════════════════════════════════════════════
       CSS VARIABLES
       ═══════════════════════════════════════════════════════════════════════════ */
    :root {
        --gold: #D4A853;
        --gold-dark: #B8912A;
        --gold-light: #F0DBA8;
        --gold-bg: #FEFBF3;
        --navy: #1B2A4A;
        --navy-dark: #0F1D36;
        --navy-light: #2D4A7A;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       ANIMATIONS
       ═══════════════════════════════════════════════════════════════════════════ */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }
    @@keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 0 0 rgba(212, 168, 83, 0.4); }
        50% { box-shadow: 0 0 25px 8px rgba(212, 168, 83, 0.15); }
    }
    @@keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
    @@keyframes loadingDots {
        0%, 80%, 100% { transform: scale(0); opacity: 0; }
        40% { transform: scale(1); opacity: 1; }
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       LOADING SCREEN
       ═══════════════════════════════════════════════════════════════════════════ */
    .loading-screen {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 70vh;
    }
    .loading-content { text-align: center; }
    .loading-spinner-box {
        width: 80px; height: 80px;
        margin: 0 auto 1rem auto;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .loading-text { color: var(--mud-palette-text-secondary); }
    .loading-dots {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 1rem;
    }
    .loading-dots span {
        width: 10px; height: 10px;
        background: var(--gold);
        border-radius: 50%;
        animation: loadingDots 1.4s infinite ease-in-out both;
    }
    .loading-dots span:nth-child(1) { animation-delay: -0.32s; }
    .loading-dots span:nth-child(2) { animation-delay: -0.16s; }

    /* ═══════════════════════════════════════════════════════════════════════════
       PAGE LAYOUT
       ═══════════════════════════════════════════════════════════════════════════ */
    .customer-form-page {
        position: relative;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1.5rem;
        padding-bottom: 120px;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       BACKGROUND DECORATIONS
       ═══════════════════════════════════════════════════════════════════════════ */
    .page-bg-decorations {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 0;
    }
    .bg-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
    }
    .bg-orb-1 {
        width: 400px; height: 400px;
        top: -150px; right: -150px;
        background: radial-gradient(circle, rgba(212,168,83,0.12), transparent 70%);
        animation: float 10s ease-in-out infinite;
    }
    .bg-orb-2 {
        width: 350px; height: 350px;
        bottom: -100px; left: -100px;
        background: radial-gradient(circle, rgba(59,130,246,0.08), transparent 70%);
        animation: float 12s ease-in-out infinite reverse;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       TOP ACCENT BAR
       ═══════════════════════════════════════════════════════════════════════════ */
    .top-accent-bar {
        height: 5px;
        background: linear-gradient(90deg, var(--gold), var(--gold-dark), var(--gold));
        position: relative;
        overflow: hidden;
        margin-bottom: 1.5rem;
        border-radius: 0 0 10px 10px;
    }
    .accent-shimmer {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
        animation: shimmer 3s ease-in-out infinite;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       FORM HEADER
       ═══════════════════════════════════════════════════════════════════════════ */
    .form-header {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .header-bg {
        position: absolute;
        inset: 0;
    }
    .header-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 50%, var(--navy-light) 100%);
    }
    .header-orbs {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }
    .header-orb {
        position: absolute;
        border-radius: 50%;
    }
    .header-orb.orb-1 {
        width: 300px; height: 300px;
        top: -120px; right: -80px;
        background: radial-gradient(circle, rgba(212,168,83,0.25), transparent 60%);
        animation: float 8s ease-in-out infinite;
    }
    .header-orb.orb-2 {
        width: 200px; height: 200px;
        bottom: -80px; left: 20%;
        background: radial-gradient(circle, rgba(212,168,83,0.15), transparent 60%);
    }
    .header-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 40px 40px;
    }
    .header-content {
        position: relative;
        z-index: 2;
        padding: 2rem;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
    }
    .back-btn {
        width: 48px; height: 48px;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }
    .back-btn:hover {
        background: rgba(255,255,255,0.2);
        transform: translateX(5px);
    }
    .header-icon-wrapper {
        position: relative;
        flex-shrink: 0;
    }
    .header-icon-glow {
        position: absolute;
        inset: -8px;
        background: var(--gold);
        border-radius: 18px;
        filter: blur(15px);
        opacity: 0.3;
        animation: pulseGlow 4s ease-in-out infinite;
    }
    .header-icon {
        position: relative;
        width: 56px; height: 56px;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
    }
    .header-icon-badge {
        position: absolute;
        top: -4px; right: -4px;
        width: 20px; height: 20px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }
    .header-icon-badge .mud-icon-root { font-size: 12px !important; }
    .header-info { flex: 1; min-width: 200px; }
    .header-title-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .header-title-row h1 {
        margin: 0;
        font-size: 1.6rem;
        font-weight: 800;
        color: white;
    }
    .customer-id-badge {
        background: rgba(255,255,255,0.15);
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.25rem 0.6rem;
        border-radius: 8px;
    }
    .header-meta {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
        flex-wrap: wrap;
    }
    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        color: rgba(255,255,255,0.7);
        font-size: 0.85rem;
    }
    .meta-item .mud-icon-root { font-size: 14px !important; }
    .stage-badge-wrapper { flex-shrink: 0; }
    .stage-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 700;
        background: color-mix(in srgb, var(--stage-color) 20%, transparent);
        color: white;
        border: 1px solid color-mix(in srgb, var(--stage-color) 50%, transparent);
    }
    .stage-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: var(--stage-color);
    }
    /* Meta items extras */
    .meta-updated {
        background: rgba(245,158,11,0.15);
        padding: 0.2rem 0.6rem;
        border-radius: 8px;
        border: 1px solid rgba(245,158,11,0.3);
    }
    .meta-new {
        background: rgba(16,185,129,0.15);
        padding: 0.2rem 0.6rem;
        border-radius: 8px;
        border: 1px solid rgba(16,185,129,0.3);
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       ERROR ALERT
       ═══════════════════════════════════════════════════════════════════════════ */
    .error-alert {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 14px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.3s ease-out;
    }
    .error-icon {
        width: 36px; height: 36px;
        background: #fee2e2;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ef4444;
        flex-shrink: 0;
    }
    .error-text {
        flex: 1;
        color: #b91c1c;
        font-weight: 600;
    }
    .error-close {
        width: 28px; height: 28px;
        background: transparent;
        border: none;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ef4444;
        cursor: pointer;
        transition: background 0.2s ease;
    }
    .error-close:hover { background: #fee2e2; }

    /* ═══════════════════════════════════════════════════════════════════════════
       TABS
       ═══════════════════════════════════════════════════════════════════════════ */
    .tabs-wrapper {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .custom-tab-nav {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.85rem 1rem;
        background: var(--mud-palette-background-gray);
        border-bottom: 2px solid var(--mud-palette-divider);
        overflow-x: auto;
        flex-wrap: nowrap;
        -webkit-overflow-scrolling: touch;
    }
    .custom-tab-nav::-webkit-scrollbar {
        height: 4px;
    }
    .custom-tab-nav::-webkit-scrollbar-thumb {
        background: rgba(212,168,83,0.35);
        border-radius: 999px;
    }
    .custom-tab-btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.85rem 1rem;
        border: 2px solid transparent;
        border-radius: 14px;
        background: transparent;
        color: var(--mud-palette-text-secondary);
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.28s ease;
        outline: none;
        min-height: 56px;
    }
    .custom-tab-btn:hover {
        background: var(--gold-bg);
        border-color: rgba(212,168,83,0.2);
        color: var(--gold-dark);
        transform: translateY(-1px);
    }
    .custom-tab-btn.active {
        background: linear-gradient(135deg, var(--gold-bg) 0%, white 100%);
        color: var(--gold-dark);
        border-color: var(--gold);
        box-shadow: 0 4px 15px rgba(212,168,83,0.18), 0 2px 6px rgba(0,0,0,0.05);
    }
    .custom-tab-btn.active::after {
        content: '';
        position: absolute;
        bottom: -0.85rem;
        left: 12%;
        right: 12%;
        height: 3px;
        background: linear-gradient(90deg, var(--gold), var(--gold-dark));
        border-radius: 3px 3px 0 0;
    }
    .custom-tab-btn .mud-icon-root {
        font-size: 1.05rem !important;
        color: inherit;
        transition: color 0.25s ease;
    }
    .tab-text {
        line-height: 1.2;
    }
    .tab-num {
        width: 24px;
        height: 24px;
        background: var(--mud-palette-text-disabled);
        color: white;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 800;
        transition: all 0.25s ease;
        flex-shrink: 0;
    }
    .custom-tab-btn.active .tab-num {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        box-shadow: 0 2px 8px rgba(212,168,83,0.35);
        transform: scale(1.08);
    }
    .tab-count {
        background: var(--mud-palette-primary);
        color: white;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.15rem 0.4rem;
        border-radius: 10px;
        margin-inline-start: auto;
    }
    .custom-tab-panels {
        position: relative;
    }
    .tab-content {
        padding: 2rem;
        animation: fadeInUp 0.35s ease-out;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       SECTION HEADER
       ═══════════════════════════════════════════════════════════════════════════ */
    .section-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid var(--mud-palette-divider);
        flex-wrap: wrap;
    }
    .section-icon {
        width: 52px; height: 52px;
        background: linear-gradient(135deg, var(--gold-bg), white);
        border: 1px solid rgba(212,168,83,0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        flex-shrink: 0;
    }
    .section-info { flex: 1; min-width: 200px; }
    .section-info h2 {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
    }
    .section-info p {
        margin: 0.25rem 0 0 0;
        color: var(--mud-palette-text-secondary);
        font-size: 0.9rem;
    }
    .add-contact-btn {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark)) !important;
        color: white !important;
        font-weight: 700 !important;
        border-radius: 12px !important;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       FORM GRID & FIELDS
       ═══════════════════════════════════════════════════════════════════════════ */
    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }
    .form-field.span-2 { grid-column: span 2; }
    .field-label {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 0.5rem;
    }
    .field-label .mud-icon-root {
        font-size: 16px !important;
        color: var(--gold) !important;
    }
    .required { color: #ef4444; }
    ::deep .premium-input .mud-input-outlined-border {
        border-radius: 12px !important;
    }
    ::deep .premium-input.mud-input-outlined:hover .mud-input-outlined-border {
        border-color: var(--gold) !important;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       RATING
       ═══════════════════════════════════════════════════════════════════════════ */
    .rating-box {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .rating-stars {
        display: flex;
        gap: 0.15rem;
    }
    .star-btn {
        width: 36px; height: 36px;
        background: var(--mud-palette-background-gray);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--mud-palette-text-disabled);
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .star-btn:hover {
        border-color: var(--gold);
        color: var(--gold);
        transform: scale(1.1);
    }
    .star-btn.filled {
        background: var(--gold-bg);
        border-color: var(--gold);
        color: var(--gold);
    }
    .rating-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--gold);
        background: var(--gold-bg);
        padding: 0.35rem 0.75rem;
        border-radius: 8px;
    }
    .rating-clear {
        width: 24px; height: 24px;
        background: transparent;
        border: none;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--mud-palette-text-secondary);
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .rating-clear:hover {
        background: #fef2f2;
        color: #ef4444;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       STATUS TOGGLE
       ═══════════════════════════════════════════════════════════════════════════ */
    .status-toggle, .balance-type-toggle {
        display: flex;
        gap: 0.5rem;
    }
    .status-btn, .balance-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        padding: 0.75rem;
        border: 2px solid var(--mud-palette-divider);
        border-radius: 12px;
        background: var(--mud-palette-surface);
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--mud-palette-text-secondary);
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .status-btn:hover, .balance-btn:hover {
        border-color: var(--mud-palette-text-disabled);
    }
    .status-btn.active {
        border-color: #10b981;
        background: #ecfdf5;
