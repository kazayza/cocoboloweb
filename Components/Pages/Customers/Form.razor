    // UI Helpers
    // ============================
    private string GetStageText(string? stage) => stage switch
    {
        CustomerStages.Lead      => "عميل محتمل",
        CustomerStages.Prospect  => "تم التواصل",
        CustomerStages.Qualified => "مؤهل للشراء",
        CustomerStages.Client    => "عميل فعلي",
        CustomerStages.Lost      => "خسرناه",
        _ => "غير محدد"
    };

    private string GetStageIcon(string? stage) => stage switch
    {
        CustomerStages.Lead      => "🔵",
        CustomerStages.Prospect  => "🟡",
        CustomerStages.Qualified => "🟣",
        CustomerStages.Client    => "🟢",
        CustomerStages.Lost      => "🔴",
        _ => "⚪"
    };

    private string GetStageCssClass(string? stage) => stage switch
    {
        CustomerStages.Lead      => "stage-lead",
        CustomerStages.Prospect  => "stage-prospect",
        CustomerStages.Qualified => "stage-qualified",
        CustomerStages.Client    => "stage-client",
        CustomerStages.Lost      => "stage-lost",
        _ => "stage-default"
    };
