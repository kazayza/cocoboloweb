@code {
    // ════════════════════════════════════════════════════════════════════════════
    // PARAMETERS
    // ════════════════════════════════════════════════════════════════════════════
    [Parameter] public int? Id { get; set; }

    // ════════════════════════════════════════════════════════════════════════════
    // STATE
    // ════════════════════════════════════════════════════════════════════════════
    private PartyFormDto _model = new();
    private List<PartyType> _partyTypes = new();
    private List<ReferralSource> _referralSources = new();
    private List<ContactSource> _contactSources = new();
    private List<SalesStage> _salesStages = new();
    private List<PartyListDto> _parentParties = new();
    private PartyListDto? _selectedParent;

    private string? _currentUserName;
    private string? _errorMessage;
    private DateTime? _originalCreatedAt;

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _canAdd = false;
    private bool _canEdit = false;
    private bool _isActive = true;
    private int _ratingValue = 0;
    private int _activeTab = 0;

    private bool IsNew => !Id.HasValue || Id.Value == 0;

    private void SetActiveTab(int index)
    {
        _activeTab = index;
    }

    // ════════════════════════════════════════════════════════════════════════════
    // LIFECYCLE
    // ════════════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canAdd = user.HasClaim("Permission", "frm_Parties:Add");
            _canEdit = user.HasClaim("Permission", "frm_Parties:Edit");

            if (IsNew && !_canAdd)
            {
                Navigation.NavigateTo("/customers");
                return;
            }

            if (!IsNew && !_canEdit)
            {
                Navigation.NavigateTo("/customers");
                return;
            }

            await LoadLookups();

            if (!IsNew)
                await LoadParty(Id!.Value);
            else
            {
                _model.PartyType = _partyTypes.FirstOrDefault()?.PartyTypeId ?? 1;
                _model.CustomerStage = CustomerStages.Lead;
                _model.BalanceType = "D";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "خطأ في تحميل البيانات";
            Console.WriteLine($"[CustomerForm] Init Error: {ex}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ════════════════════════════════════════════════════════════════════════════
    // DATA LOADING
    // ════════════════════════════════════════════════════════════════════════════
    private async Task LoadLookups()
    {
        _partyTypes = await PartyService.GetPartyTypesAsync();
        _referralSources = await PartyService.GetReferralSourcesAsync();
        _contactSources = await PartyService.GetContactSourcesAsync();
        _parentParties = await PartyService.GetParentPartiesAsync();
        _salesStages = await PartyService.GetSalesStagesAsync();
    }

    private async Task LoadParty(int partyId)
    {
        var dto = await PartyService.GetPartyForEditAsync(partyId);
        if (dto == null)
        {
            _errorMessage = "العميل غير موجود";
            return;
        }

        _model = dto;
        _isActive = dto.IsActive ?? true;
        _ratingValue = dto.Rating ?? 0;
        _originalCreatedAt = dto.CreatedAt ?? DateTime.Now;

        if (dto.ParentPartyId.HasValue)
        {
            _selectedParent = _parentParties
                .FirstOrDefault(p => p.PartyId == dto.ParentPartyId.Value);
        }
    }

    // ════════════════════════════════════════════════════════════════════════════
    // SEARCH
    // ════════════════════════════════════════════════════════════════════════════
    private Task<IEnumerable<PartyListDto>> SearchParents(string value, CancellationToken ct)
    {
        var result = string.IsNullOrWhiteSpace(value)
            ? _parentParties.Where(p => p.PartyId != _model.PartyId)
            : _parentParties.Where(p =>
                p.PartyId != _model.PartyId &&
                p.PartyName.ContainsArabic(value));

        return Task.FromResult(result);
    }

    // ════════════════════════════════════════════════════════════════════════════
    // RATING
    // ════════════════════════════════════════════════════════════════════════════
    private void SetRating(int value)
    {
        _ratingValue = _ratingValue == value ? 0 : value;
    }

    private string GetRatingText(int rating) => rating switch
    {
        1 => "ضعيف",
        2 => "مقبول",
        3 => "جيد",
        4 => "ممتاز",
        5 => "استثنائي",
        _ => ""
    };

    // ════════════════════════════════════════════════════════════════════════════
    // CONTACTS
    // ════════════════════════════════════════════════════════════════════════════
    private void AddContact()
    {
        _model.Contacts.Add(new PartyContactDto
        {
            ContactName = "",
            IsActive = true
        });
    }

    private void RemoveContact(PartyContactDto contact)
    {
        _model.Contacts.Remove(contact);
    }

    // ════════════════════════════════════════════════════════════════════════════
    // SAVE
    // ════════════════════════════════════════════════════════════════════════════
    private async Task SaveParty()
    {
        _errorMessage = null;
        _isSaving = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_model.PartyName))
            {
                _errorMessage = "اسم العميل مطلوب!";
                _isSaving = false;
                return;
            }

            _model.IsActive = _isActive;
            _model.Rating = _ratingValue > 0 ? _ratingValue : null;
            _model.ParentPartyId = _selectedParent?.PartyId;

            var (success, message, partyId) = await PartyService.SavePartyAsync(
                _model, _currentUserName!);

            if (success)
            {
                Snackbar.Add(message, Severity.Success);
                GoBack();
            }
            else
            {
                _errorMessage = message;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "خطأ أثناء الحفظ";
            Console.WriteLine($"[CustomerForm] Save Error: {ex}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ════════════════════════════════════════════════════════════════════════════
    // PHONE VALIDATION
    // ════════════════════════════════════════════════════════════════════════════
    private string ValidatePhoneField(string phone)
    {
        if (string.IsNullOrWhiteSpace(phone))
            return null;

        var cleaned = phone.Trim().Replace(" ", "").Replace("-", "");

        if (cleaned.Length < 10)
            return "الرقم قصير جداً";

        if (cleaned.Length > 15)
            return "الرقم طويل جداً";

        var toCheck = cleaned.StartsWith("+") ? cleaned.Substring(1) : cleaned;
        if (!toCheck.All(char.IsDigit))
            return "الرقم يحتوي على حروف غير صالحة";

        if (cleaned.StartsWith("01") && cleaned.Length != 11)
            return "رقم الهاتف المصري لازم 11 رقم";

        return null;
    }

    // ════════════════════════════════════════════════════════════════════════════
    // BALANCE TYPE
    // ════════════════════════════════════════════════════════════════════════════
    private void SetBalanceDebit() => _model.BalanceType = "D";
    private void SetBalanceCredit() => _model.BalanceType = "C";

    // ════════════════════════════════════════════════════════════════════════════
    // NAVIGATION
    // ════════════════════════════════════════════════════════════════════════════
    private void GoBack() => Navigation.NavigateTo("/customers");
}
