@page "/customers"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims

@inject PartyService PartyService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider

@if (_isLoading)
{
    <div class="loading-container">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Class="mt-4" Style="color: var(--gold);">جاري تحميل البيانات...</MudText>
    </div>
}
else
{
    <div class="customers-page" dir="rtl">

        <!-- Header -->
        <div class="page-header">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="4" Class="header-content" Wrap="Wrap.Wrap">
                <div class="header-info">
                    <h1>
                        <MudIcon Icon="@Icons.Material.Filled.People" Class="header-icon" />
                        إدارة العملاء
                    </h1>
                    <p>إدارة بيانات العملاء والموردين</p>
                </div>
                <MudStack Row="true" Spacing="3">
                    @if (_canAdd)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="GoToAdd" Size="Size.Large" Class="add-btn">
                            إضافة عميل جديد
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FileDownload" OnClick="ExportToExcel" Size="Size.Large" Disabled="@_isExporting" Class="export-btn">
                        @if (_isExporting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                        }
                        تصدير Excel
                    </MudButton>
                </MudStack>
            </MudStack>

            <!-- Stats Cards -->
            <div class="stats-row">
                <div class="stat-card">
                    <div class="stat-icon total">
                        <MudIcon Icon="@Icons.Material.Filled.People" />
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@_stats.TotalCount</span>
                        <span class="stat-label">إجمالي</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon active">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@_stats.ActiveCount</span>
                        <span class="stat-label">نشط</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon leads">
                        <MudIcon Icon="@Icons.Material.Filled.PersonSearch" />
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@_stats.LeadsCount</span>
                        <span class="stat-label">عملاء محتملون</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon clients">
                        <MudIcon Icon="@Icons.Material.Filled.Verified" />
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@_stats.ClientsCount</span>
                        <span class="stat-label">عملاء فعليون</span>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon month">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
                    </div>
                    <div class="stat-info">
                        <span class="stat-value">@_stats.ThisMonthCount</span>
                        <span class="stat-label">هذا الشهر</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <MudPaper Class="filters-container" Elevation="0">
            <MudGrid Spacing="3" Class="mb-4">
                <MudItem xs="12" md="4">
                    <MudTextField T="string"
                                  Value="_filter.SearchText"
                                  ValueChanged="@(async (string v) => { _filter.SearchText = v; await OnSearchChanged(v); })"
                                  Placeholder="بحث بالاسم أو الهاتف أو البريد..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  DebounceInterval="400"
                                  Clearable="true" />
                </MudItem>

                <MudItem xs="6" md="2">
                    <MudSelect T="int?"
                               Value="_filter.PartyType"
                               ValueChanged="@(async (int? v) => { _filter.PartyType = v; await OnFilterChanged(); })"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Placeholder="النوع"
                               Clearable="true">
                        @foreach (var type in _partyTypes)
                        {
                            <MudSelectItem T="int?" Value="@((int?)type.PartyTypeId)">@type.PartyTypeName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6" md="2">
                    <MudSelect T="int?"
                               Value="_filter.StageId"
                               ValueChanged="@(async (int? v) => { _filter.StageId = v; await OnFilterChanged(); })"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Placeholder="المرحلة"
                               Clearable="true">
                        @foreach (var stage in _salesStages)
                        {
                            <MudSelectItem T="int?" Value="@((int?)stage.StageId)">
                                @(stage.StageNameAr ?? stage.StageName)
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6" md="2">
                    <MudSelect T="bool?"
                               Value="_filter.IsActive"
                               ValueChanged="@(async (bool? v) => { _filter.IsActive = v; await OnFilterChanged(); })"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Placeholder="الحالة"
                               Clearable="true">
                        <MudSelectItem T="bool?" Value="@((bool?)true)">نشط</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)false)">غير نشط</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="6" md="1">
                    <MudSelect T="bool?"
                               Value="_filter.HasInvoices"
                               ValueChanged="@(async (bool? v) => { _filter.HasInvoices = v; await OnFilterChanged(); })"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Placeholder="الفواتير"
                               Clearable="true">
                        <MudSelectItem T="bool?" Value="@((bool?)true)">مرتبط بفواتير</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)false)">بدون فواتير</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="1">
                    <MudIconButton Icon="@Icons.Material.Filled.FilterAltOff"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   OnClick="ResetFilters"
                                   Title="إعادة تعيين الفلاتر"
                                   Size="Size.Medium" />
                </MudItem>
            </MudGrid>

            <!-- Results Count -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="results-info">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    عرض @_pagedResult.Items.Count من @_pagedResult.TotalCount نتيجة
                </MudText>
                <MudStack Row="true" Spacing="1">
                    <MudIconButton Icon="@Icons.Material.Filled.GridView"
                                   Color="@(_viewMode == ViewMode.Grid ? Color.Primary : Color.Default)"
                                   OnClick="@(() => _viewMode = ViewMode.Grid)"
                                   Size="Size.Small" />
                    <MudIconButton Icon="@Icons.Material.Filled.TableRows"
                                   Color="@(_viewMode == ViewMode.Table ? Color.Primary : Color.Default)"
                                   OnClick="@(() => _viewMode = ViewMode.Table)"
                                   Size="Size.Small" />
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- Content -->
        @if (_isTableLoading)
        {
            <div class="table-loading">
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            </div>
        }

        @if (_viewMode == ViewMode.Grid)
        {
            <!-- Grid View -->
            @if (_pagedResult.Items.Any())
            {
                <div class="customers-grid">
                    @foreach (var customer in _pagedResult.Items)
                    {
                        <div class="customer-card @(!customer.IsActive == true ? "inactive-card" : "")"
                             @onclick="() => { if (_canEdit) GoToEdit(customer.PartyId); }">

                            <!-- Card Header -->
                            <div class="customer-card-header">
                                <div class="customer-avatar">
                                    @GetInitials(customer.PartyName)
                                </div>
                                <div class="customer-header-info">
                                    <h3>@customer.PartyName</h3>
                                    @if (!string.IsNullOrEmpty(customer.JobTitle))
                                    {
                                        <span class="job-title">@customer.JobTitle</span>
                                    }
                                </div>
                                <div class="card-badges">
                                    <span class="stage-badge" style="background: @(customer.StageColor ?? "#94a3b8")22; color: @(customer.StageColor ?? "#94a3b8"); border: 1px solid @(customer.StageColor ?? "#94a3b8")44;">
                                        @(customer.StageNameAr ?? customer.StageName ?? GetStageText(customer.CustomerStage))
                                    </span>
                                </div>
                            </div>

                            <!-- Card Body -->
                            <div class="customer-card-body">
                                @if (!string.IsNullOrEmpty(customer.Phone))
                                {
                                    <div class="info-row">
                                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                                        <span>@customer.Phone</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(customer.Email))
                                {
                                    <div class="info-row">
                                        <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" />
                                        <span>@customer.Email</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(customer.City))
                                {
                                    <div class="info-row">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                                        <span>@customer.City</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(customer.ParentPartyName))
                                {
                                    <div class="info-row">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" />
                                        <span>@customer.ParentPartyName</span>
                                    </div>
                                }
                            </div>

                            <!-- Card Footer -->
                            <div class="customer-card-footer">
                                <div class="footer-badges">
                                    @if (customer.HasInvoices)
                                    {
                                        <span class="badge badge-invoice">
                                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" />
                                            عنده فواتير
                                        </span>
                                    }
                                    @if (customer.ContactsCount > 0)
                                    {
                                        <span class="badge badge-contacts">
                                            <MudIcon Icon="@Icons.Material.Filled.Contacts" Size="Size.Small" />
                                            @customer.ContactsCount جهة اتصال
                                        </span>
                                    }
                                    @if (customer.Rating.HasValue)
                                    {
                                        <span class="badge badge-rating">
                                            @for (int i = 1; i <= customer.Rating.Value; i++)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color: var(--gold);" />
                                            }
                                        </span>
                                    }
                                </div>
                                <div class="card-actions" @onclick:stopPropagation="true">
                                    @if (_canEdit)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => GoToEdit(customer.PartyId)" Title="تعديل" />
                                    }
                                    @if (_canDelete)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => ConfirmDelete(customer)" Title="حذف" />
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Large" />
                    <h3>لا توجد نتائج</h3>
                    <p>جرب تغيير معايير البحث أو الفلترة</p>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ResetFilters">إعادة تعيين الفلاتر</MudButton>
                </div>
            }
        }
        else
        {
            <!-- Table View -->
            <MudPaper Elevation="0" Class="table-container">
                <MudTable Items="@_pagedResult.Items" Hover="true" Striped="true" Dense="false" FixedHeader="true" Height="600px"
                          OnRowClick="@((TableRowClickEventArgs<PartyListDto> args) => { if (_canEdit) GoToEdit(args.Item.PartyId); })"
                          RowClass="table-row" Class="customers-table">
                    <HeaderContent>
                        <MudTh Style="width: 70px;">
                            <MudTableSortLabel SortBy="new Func<PartyListDto, object>(x => x.PartyId)">الكود</MudTableSortLabel>
                        </MudTh>
                        <MudTh>
                            <MudTableSortLabel SortBy="new Func<PartyListDto, object>(x => x.PartyName)" InitialDirection="SortDirection.Ascending">العميل</MudTableSortLabel>
                        </MudTh>
                        <MudTh>النوع</MudTh>
                        <MudTh>التواصل</MudTh>
                        <MudTh>المدينة</MudTh>
                        <MudTh>المرحلة</MudTh>
                        <MudTh>التقييم</MudTh>
                        <MudTh>الفواتير</MudTh>
                        <MudTh>الحالة</MudTh>
                        <MudTh>إجراءات</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <span class="party-code">@context.PartyId</span>
                        </MudTd>
                        <MudTd>
                            <div class="table-customer-info">
                                <div class="table-avatar">
                                    @GetInitials(context.PartyName)
                                </div>
                                <div>
                                    <div class="customer-name">@context.PartyName</div>
                                    @if (!string.IsNullOrEmpty(context.JobTitle))
                                    {
                                        <div class="customer-subtitle">@context.JobTitle</div>
                                    }
                                    @if (!string.IsNullOrEmpty(context.ParentPartyName))
                                    {
                                        <div class="customer-subtitle">
                                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" />
                                            @context.ParentPartyName
                                        </div>
                                    }
                                </div>
                            </div>
                        </MudTd>
                        <MudTd><span class="type-badge">@context.PartyTypeName</span></MudTd>
                        <MudTd>
                            <div class="contact-info">
                                @if (!string.IsNullOrEmpty(context.Phone))
                                {
                                    <div><MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" /> @context.Phone</div>
                                }
                                @if (!string.IsNullOrEmpty(context.Email))
                                {
                                    <div><MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" /> @context.Email</div>
                                }
                            </div>
                        </MudTd>
                        <MudTd>@(context.City ?? "-")</MudTd>
                        <MudTd>
                            @{
                                var stageColor = context.StageColor ?? "#94a3b8";
                                var stageText = context.StageNameAr ?? context.StageName ?? GetStageText(context.CustomerStage);
                            }
                            <span class="stage-badge" style="background: @(stageColor)22; color: @stageColor; border: 1px solid @(stageColor)44;">
                                @stageText
                            </span>
                        </MudTd>
                        <MudTd>
                            @if (context.Rating.HasValue)
                            {
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var starIndex = i;
                                    <MudIcon Icon="@(starIndex <= context.Rating.Value ? Icons.Material.Filled.Star : Icons.Material.Outlined.Star)"
                                             Size="Size.Small"
                                             Style="@(starIndex <= context.Rating.Value ? "color: var(--gold);" : "color: var(--mud-palette-divider);")" />
                                }
                            }
                            else
                            {
                                <MudText Style="color: var(--mud-palette-text-secondary);">-</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            @if (context.HasInvoices)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Receipt">نعم</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">لا</MudChip>
                            }
                        </MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive == true ? Color.Success : Color.Error)">
                                @(context.IsActive == true ? "نشط" : "غير نشط")
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            <div class="table-actions" @onclick:stopPropagation="true">
                                @if (_canEdit)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => GoToEdit(context.PartyId)" Title="تعديل" />
                                }
                                @if (_canDelete)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => ConfirmDelete(context)" Title="حذف" />
                                }
                            </div>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        <!-- Pagination -->
        @if (_pagedResult.TotalPages > 1)
        {
            <div class="pagination-container">
                <MudPagination Count="@_pagedResult.TotalPages"
                               Selected="@_filter.PageNumber"
                               SelectedChanged="OnPageChanged"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               ShowFirstButton="true"
                               ShowLastButton="true" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    صفحة @_filter.PageNumber من @_pagedResult.TotalPages
                </MudText>
            </div>
        }

    </div>
}

<!-- Delete Dialog -->
<MudDialog @bind-Visible="_showDeleteDialog">
    <TitleContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6">تأكيد الحذف</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText>
            هل تريد حذف العميل <strong>@_selectedParty?.PartyName</strong>؟
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            سيتم إلغاء تفعيله فقط ولن يتم الحذف النهائي.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showDeleteDialog = false)" Variant="Variant.Outlined">إلغاء</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ExecuteDelete" Disabled="@_isDeleting">
            @if (_isDeleting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            حذف
        </MudButton>
    </DialogActions>
</MudDialog>


<style>
    /* ============================ Page Layout ============================ */
    .customers-page {
        padding: 1rem;
        max-width: 1800px;
        margin: 0 auto;
        direction: rtl;
    }

    /* ============================ Header ============================ */
    .page-header {
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
    }

    /* -- Light Mode Header -- */
    .mud-light-mode .page-header {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        box-shadow: 0 10px 40px rgba(212, 175, 55, 0.25);
    }

    /* -- Dark Mode Header (Navy + Gold Border instead of bright gold) -- */
    .mud-dark-mode .page-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        border-bottom: 3px solid var(--gold);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
    }

    .header-info h1 {
        color: white;
        font-size: 2rem;
        font-weight: 800;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .header-icon { font-size: 2rem !important; }

    .header-info p {
        color: rgba(255,255,255,0.85);
        margin: 0.25rem 0 0 0;
        font-size: 0.95rem;
    }

    .add-btn {
        background: rgba(255,255,255,0.95) !important;
        color: var(--navy-dark) !important;
        font-weight: 700 !important;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15) !important;
        transition: all 0.3s ease;
    }
    .add-btn:hover {
        background: white !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
    }

    .mud-dark-mode .add-btn {
        background: var(--gold) !important;
        color: #000 !important;
    }

    .export-btn {
        background: rgba(255,255,255,0.15) !important;
        color: white !important;
        border-color: rgba(255,255,255,0.4) !important;
        font-weight: 600 !important;
    }
    .export-btn:hover { background: rgba(255,255,255,0.25) !important; }

    .mud-dark-mode .export-btn {
        border-color: var(--gold) !important;
        color: var(--gold) !important;
        background: rgba(212, 175, 55, 0.1) !important;
    }

    /* ============================ Stats ============================ */
    .stats-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .stat-card {
        border-radius: 14px;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
        min-width: 140px;
        transition: all 0.3s ease;
    }

    /* -- Light Mode Stats (Glassy on Gold) -- */
    .mud-light-mode .stat-card {
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
    }
    .mud-light-mode .stat-card:hover {
        background: rgba(255,255,255,0.3);
        transform: translateY(-2px);
    }

    /* -- Dark Mode Stats (Subtle Surface Cards) -- */
    .mud-dark-mode .stat-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
    }
    .mud-dark-mode .stat-card:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-2px);
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .mud-light-mode .stat-icon.total { background: rgba(255,255,255,0.25); }
    .mud-light-mode .stat-icon.active { background: rgba(16,185,129,0.5); }
    .mud-light-mode .stat-icon.leads { background: rgba(59,130,246,0.5); }
    .mud-light-mode .stat-icon.clients { background: rgba(139,92,246,0.5); }
    .mud-light-mode .stat-icon.month { background: rgba(245,158,11,0.5); }

    .mud-dark-mode .stat-icon.total { background: rgba(255,255,255,0.1); color: var(--mud-palette-text-primary); }
    .mud-dark-mode .stat-icon.active { background: rgba(16,185,129,0.2); color: #10b981; }
    .mud-dark-mode .stat-icon.leads { background: rgba(59,130,246,0.2); color: #3b82f6; }
    .mud-dark-mode .stat-icon.clients { background: rgba(139,92,246,0.2); color: #8b5cf6; }
