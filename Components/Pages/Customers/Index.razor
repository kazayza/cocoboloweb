@page "/customers"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims

@inject PartyService PartyService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider

@if (_isLoading)
{
    <div style="display:flex;flex-direction:column;align-items:center;
                justify-content:center;min-height:60vh;gap:1rem;">
        <MudProgressCircular Color="Color.Secondary" Size="Size.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Color="Color.Secondary">جاري تحميل البيانات...</MudText>
    </div>
}
else
{
<div dir="rtl" class="cust-page">

    <!-- ╔══════════════════════════════════════╗
         ║           HEADER                     ║
         ╚══════════════════════════════════════╝ -->
    <div class="cust-header">
  <div class="cust-header-top">
    <div class="cust-title-group">
      <div class="cust-title-icon">
        <MudIcon Icon="@Icons.Material.Rounded.People" />
      </div>
      <div>
        <div class="cust-title">إدارة العملاء</div>
        <div class="cust-subtitle">إدارة بيانات العملاء والموردين</div>
      </div>
    </div>
    <div class="cust-header-actions">
      <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Rounded.PersonAdd" OnClick="GoToAdd">
        إضافة عميل
      </MudButton>
      <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.FileDownload" OnClick="ExportToExcel">
        تصدير
      </MudButton>
    </div>
  </div>

  <div class="cust-stats">
    <div class="cust-stat">
      <div class="cust-stat-icon is-primary">
        <MudIcon Icon="@Icons.Material.Rounded.People" />
      </div>
      <div class="cust-stat-data">
        <span class="cust-stat-num">@_stats.TotalCount</span>
        <span class="cust-stat-lbl">إجمالي</span>
      </div>
    </div>
    <div class="cust-stat">
      <div class="cust-stat-icon is-success">
        <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" />
      </div>
      <div class="cust-stat-data">
        <span class="cust-stat-num">@_stats.ActiveCount</span>
        <span class="cust-stat-lbl">نشط</span>
      </div>
    </div>
    <div class="cust-stat">
      <div class="cust-stat-icon is-info">
        <MudIcon Icon="@Icons.Material.Rounded.PersonSearch" />
      </div>
      <div class="cust-stat-data">
        <span class="cust-stat-num">@_stats.LeadsCount</span>
        <span class="cust-stat-lbl">محتملون</span>
      </div>
    </div>
    <div class="cust-stat">
      <div class="cust-stat-icon is-violet">
        <MudIcon Icon="@Icons.Material.Rounded.Verified" />
      </div>
      <div class="cust-stat-data">
        <span class="cust-stat-num">@_stats.ClientsCount</span>
        <span class="cust-stat-lbl">فعليون</span>
      </div>
    </div>
    <div class="cust-stat">
      <div class="cust-stat-icon is-warning">
        <MudIcon Icon="@Icons.Material.Rounded.CalendarMonth" />
      </div>
      <div class="cust-stat-data">
        <span class="cust-stat-num">@_stats.ThisMonthCount</span>
        <span class="cust-stat-lbl">هذا الشهر</span>
      </div>
    </div>
  </div>
</div>

    <!-- ╔══════════════════════════════════════╗
         ║           FILTER BAR                 ║
         ╚══════════════════════════════════════╝ -->
    <MudPaper Elevation="0" Class="cust-filter-bar">

        <div class="cust-filter-row">

            <!-- Search -->
            <div class="cust-search-box">
                <MudIcon Icon="@Icons.Material.Rounded.Search"
                         Class="cust-search-icon" />
                <input type="text"
       value="@_searchDisplayText"
       @oninput="OnSearchInput"
       placeholder="بحث بالاسم أو الهاتف أو البريد..."
       class="cust-search-input" />
                @if (!string.IsNullOrWhiteSpace(_searchDisplayText))
{
    <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
             OnClose="ClearSearch" Variant="Variant.Filled">
        بحث: @_searchDisplayText
    </MudChip>
}
            </div>

            <!-- Filters -->
            <MudSelect T="int?" Value="_filter.PartyType"
                       ValueChanged="@(async (int? v) => { _filter.PartyType = v; await OnFilterChanged(); })"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Placeholder="النوع" Clearable="true"
                       Color="Color.Secondary" Class="cust-filter-select">
                @foreach (var t in _partyTypes)
                {
                    <MudSelectItem T="int?" Value="@((int?)t.PartyTypeId)">
                        @t.PartyTypeName
                    </MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" Value="_filter.StageId"
                       ValueChanged="@(async (int? v) => { _filter.StageId = v; await OnFilterChanged(); })"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Placeholder="المرحلة" Clearable="true"
                       Color="Color.Secondary" Class="cust-filter-select">
                @foreach (var s in _salesStages)
                {
                    <MudSelectItem T="int?" Value="@((int?)s.StageId)">
                        @(s.StageNameAr ?? s.StageName)
                    </MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="bool?" Value="_filter.IsActive"
                       ValueChanged="@(async (bool? v) => { _filter.IsActive = v; await OnFilterChanged(); })"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Placeholder="الحالة" Clearable="true"
                       Color="Color.Secondary" Class="cust-filter-select">
                <MudSelectItem T="bool?" Value="@((bool?)true)">نشط</MudSelectItem>
                <MudSelectItem T="bool?" Value="@((bool?)false)">غير نشط</MudSelectItem>
            </MudSelect>

            <MudSelect T="bool?" Value="_filter.HasInvoices"
                       ValueChanged="@(async (bool? v) => { _filter.HasInvoices = v; await OnFilterChanged(); })"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Placeholder="الفواتير" Clearable="true"
                       Color="Color.Secondary" Class="cust-filter-select">
                <MudSelectItem T="bool?" Value="@((bool?)true)">بفواتير</MudSelectItem>
                <MudSelectItem T="bool?" Value="@((bool?)false)">بدون فواتير</MudSelectItem>
            </MudSelect>

            <!-- Reset (يظهر لو فيه فلتر مختار) -->
            @if (_hasActiveFilters)
            {
                <MudTooltip Text="إعادة تعيين الفلاتر">
                    <MudIconButton Icon="@Icons.Material.Rounded.FilterAltOff"
                                   Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   OnClick="ResetFilters"
                                   Size="Size.Medium" />
                </MudTooltip>
            }
        </div>

        <!-- Active Filters Chips -->
        @if (_hasActiveFilters)
        {
            <div class="cust-active-filters">
                @if (!string.IsNullOrWhiteSpace(_filter.SearchText))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                             OnClose="ClearSearch" Variant="Variant.Filled">
                        بحث: @_filter.SearchText
                    </MudChip>
                }
                @if (_filter.PartyType.HasValue)
                {
                    var typeName = _partyTypes.FirstOrDefault(x => x.PartyTypeId == _filter.PartyType)?.PartyTypeName;
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                             OnClose="@(async () => { _filter.PartyType = null; await OnFilterChanged(); })"
                             Variant="Variant.Filled">
                        النوع: @typeName
                    </MudChip>
                }
                @if (_filter.StageId.HasValue)
                {
                    var stageName = _salesStages.FirstOrDefault(x => x.StageId == _filter.StageId);
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                             OnClose="@(async () => { _filter.StageId = null; await OnFilterChanged(); })"
                             Variant="Variant.Filled">
                        المرحلة: @(stageName?.StageNameAr ?? stageName?.StageName)
                    </MudChip>
                }
                @if (_filter.IsActive.HasValue)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                             OnClose="@(async () => { _filter.IsActive = null; await OnFilterChanged(); })"
                             Variant="Variant.Filled">
                        الحالة: @(_filter.IsActive == true ? "نشط" : "غير نشط")
                    </MudChip>
                }
                @if (_filter.HasInvoices.HasValue)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                             OnClose="@(async () => { _filter.HasInvoices = null; await OnFilterChanged(); })"
                             Variant="Variant.Filled">
                        الفواتير: @(_filter.HasInvoices == true ? "بفواتير" : "بدون")
                    </MudChip>
                }
            </div>
        }

        <MudDivider Class="my-2" />

        <!-- Results + View Toggle -->
        <div class="cust-results-bar">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                عرض <b style="color:var(--mud-palette-text-primary);">
                    @_pagedResult.Items.Count
                </b>
                من
                <b style="color:var(--mud-palette-text-primary);">
                    @_pagedResult.TotalCount
                </b>
                نتيجة
            </MudText>
            <div class="cust-view-toggle">
                <MudTooltip Text="عرض شبكي">
                    <MudIconButton Icon="@Icons.Material.Rounded.GridView"
                                   Color="@(_viewMode == ViewMode.Grid
                                            ? Color.Secondary : Color.Default)"
                                   OnClick="@(() => _viewMode = ViewMode.Grid)"
                                   Size="Size.Small" />
                </MudTooltip>
                <MudTooltip Text="عرض جدول">
                    <MudIconButton Icon="@Icons.Material.Rounded.TableRows"
                                   Color="@(_viewMode == ViewMode.Table
                                            ? Color.Secondary : Color.Default)"
                                   OnClick="@(() => _viewMode = ViewMode.Table)"
                                   Size="Size.Small" />
                </MudTooltip>
            </div>
        </div>
    </MudPaper>

    <!-- Loading -->
    @if (_isTableLoading)
    {
        <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Class="mb-3" />
    }

    <!-- ╔══════════════════════════════════════╗
         ║           GRID VIEW                  ║
         ╚══════════════════════════════════════╝ -->
    @if (_viewMode == ViewMode.Grid)
    {
        @if (_pagedResult.Items.Any())
        {
            <div class="cust-grid">
                @foreach (var c in _pagedResult.Items)
                {
                    <div class="cust-card @(c.IsActive != true ? "cust-card-inactive" : "")"
                         @onclick="() => { if (_canEdit) GoToEdit(c.PartyId); }">

                        <!-- Card Head -->
                        <div class="cust-card-head">
                            <div class="cust-card-avatar">
                                @GetInitials(c.PartyName)
                                @if (c.IsActive == true)
                                {
                                    <div class="cust-status-dot cust-status-active"></div>
                                }
                                else
                                {
                                    <div class="cust-status-dot cust-status-inactive"></div>
                                }
                            </div>
                            <div class="cust-card-info">
                                <div class="cust-card-name">@c.PartyName</div>
                                @if (!string.IsNullOrEmpty(c.JobTitle))
                                {
                                    <div class="cust-card-job">@c.JobTitle</div>
                                }
                                @if (!string.IsNullOrEmpty(c.PartyTypeName))
                                {
                                    <div class="cust-card-type">@c.PartyTypeName</div>
                                }
                            </div>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Style="@GetStageBadgeStyle(c.StageColor)">
                                @(c.StageNameAr ?? c.StageName ?? GetStageText(c.CustomerStage))
                            </MudChip>
                        </div>

                        <!-- Card Body -->
                        <div class="cust-card-body">
                            @if (!string.IsNullOrEmpty(c.Phone))
                            {
                                <div class="cust-info-row">
                                    <MudIcon Icon="@Icons.Material.Rounded.Phone"
                                             Style="color:var(--gold);font-size:1rem;flex-shrink:0;" />
                                    <span>@c.Phone</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(c.Email))
                            {
                                <div class="cust-info-row">
                                    <MudIcon Icon="@Icons.Material.Rounded.Email"
                                             Style="color:var(--gold);font-size:1rem;flex-shrink:0;" />
                                    <span class="cust-info-ellipsis">@c.Email</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(c.City))
                            {
                                <div class="cust-info-row">
                                    <MudIcon Icon="@Icons.Material.Rounded.LocationOn"
                                             Style="color:var(--gold);font-size:1rem;flex-shrink:0;" />
                                    <span>@c.City</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(c.ParentPartyName))
                            {
                                <div class="cust-info-row">
                                    <MudIcon Icon="@Icons.Material.Rounded.AccountTree"
                                             Style="color:var(--gold);font-size:1rem;flex-shrink:0;" />
                                    <span>@c.ParentPartyName</span>
                                </div>
                            }
                        </div>

                        <!-- Card Footer -->
                        <div class="cust-card-foot">
                            <!-- Badges -->
                            <div class="cust-foot-badges">
                                @if (c.HasInvoices)
                                {
                                    <MudChip T="string" Size="Size.Small"
                                             Color="Color.Success" Variant="Variant.Text"
                                             Icon="@Icons.Material.Rounded.Receipt">
                                        فواتير
                                    </MudChip>
                                }
                                @if (c.ContactsCount > 0)
                                {
                                    <MudChip T="string" Size="Size.Small"
                                             Color="Color.Info" Variant="Variant.Text"
                                             Icon="@Icons.Material.Rounded.Contacts">
                                        @c.ContactsCount
                                    </MudChip>
                                }
                                @if (c.Rating.HasValue)
                                {
                                    <MudRating SelectedValue="@c.Rating.Value"
                                               MaxValue="5" ReadOnly="true"
                                               Size="Size.Small"
                                               FullIcon="@Icons.Material.Rounded.Star"
                                               EmptyIcon="@Icons.Material.Rounded.StarBorder"
                                               Color="Color.Secondary" />
                                }
                            </div>

                            <!-- Quick Actions -->
                            <div class="cust-foot-actions" @onclick:stopPropagation="true">
                                @if (!string.IsNullOrEmpty(c.Phone))
                                {
                                    <MudTooltip Text="اتصال">
                                        <MudIconButton Icon="@Icons.Material.Rounded.Call"
                                                       Size="Size.Small"
                                                       Color="Color.Success"
                                                       Href="@($"tel:{c.Phone}")" />
                                    </MudTooltip>
                                    <MudTooltip Text="واتساب">
                                        <MudIconButton Icon="@Icons.Material.Rounded.Chat"
                                                       Size="Size.Small"
                                                       Color="Color.Success"
                                                       OnClick="@(() => OpenWhatsApp(c.Phone))" />
                                    </MudTooltip>
                                }
                                @if (_canEdit)
                                {
                                    <MudTooltip Text="تعديل">
                                        <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                                       Size="Size.Small" Color="Color.Primary"
                                                       OnClick="() => GoToEdit(c.PartyId)" />
                                    </MudTooltip>
                                }
                                @if (_canDelete)
                                {
                                    <MudTooltip Text="حذف">
                                        <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                                       Size="Size.Small" Color="Color.Error"
                                                       OnClick="() => ConfirmDelete(c)" />
                                    </MudTooltip>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <MudPaper Elevation="0" Class="cust-empty">
                <MudIcon Icon="@Icons.Material.Rounded.PeopleAlt"
                         Style="font-size:5rem;color:var(--mud-palette-divider);" />
                <MudText Typo="Typo.h6" Class="mt-4 mb-2">لا توجد نتائج</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    جرب تغيير معايير البحث أو الفلترة
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Rounded.Refresh"
                           OnClick="ResetFilters"
                           Style="text-transform:none;border-radius:12px;">
                    إعادة تعيين الفلاتر
                </MudButton>
            </MudPaper>
        }
    }
    else
    {
        <!-- ╔══════════════════════════════════════╗
             ║           TABLE VIEW                 ║
             ╚══════════════════════════════════════╝ -->
        <MudPaper Elevation="0" Class="cust-table-wrap">
            <MudTable Items="@_pagedResult.Items"
                      Hover="true" Striped="true" Dense="false"
                      FixedHeader="true" Height="600px"
                      OnRowClick="@((TableRowClickEventArgs<PartyListDto> a)
                                    => { if (_canEdit) GoToEdit(a.Item.PartyId); })"
                      RowStyle="cursor:pointer;"
                      Class="cust-table">
                <HeaderContent>
                    <MudTh Style="width:70px;">
                        <MudTableSortLabel SortBy="new Func<PartyListDto,object>(x=>x.PartyId)">
                            #
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<PartyListDto,object>(x=>x.PartyName)"
                                           InitialDirection="SortDirection.Ascending">
                            العميل
                        </MudTableSortLabel>
                    </MudTh>
                    <MudTh>التواصل</MudTh>
                    <MudTh>المدينة</MudTh>
                    <MudTh>المرحلة</MudTh>
                    <MudTh>التقييم</MudTh>
                    <MudTh>الفواتير</MudTh>
                    <MudTh>الحالة</MudTh>
                    <MudTh Style="width:120px;">إجراءات</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small"
                                 Color="Color.Secondary" Variant="Variant.Text"
                                 Style="font-weight:700;">
                            @context.PartyId
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <div style="display:flex;align-items:center;gap:0.75rem;">
                            <div class="cust-tbl-avatar">
                                @GetInitials(context.PartyName)
                                <div class="cust-status-dot @(context.IsActive==true
                                    ? "cust-status-active" : "cust-status-inactive")
                                    cust-status-tbl"></div>
                            </div>
                            <div>
                                <div style="font-weight:700;font-size:0.9rem;
                                            color:var(--mud-palette-text-primary);">
                                    @context.PartyName
                                </div>
                                @if (!string.IsNullOrEmpty(context.JobTitle))
                                {
                                    <div style="font-size:0.76rem;
                                                color:var(--mud-palette-text-secondary);">
                                        @context.JobTitle
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(context.ParentPartyName))
                                {
                                    <div style="font-size:0.76rem;
                                                color:var(--mud-palette-text-secondary);
                                                display:flex;align-items:center;gap:0.2rem;">
                                        <MudIcon Icon="@Icons.Material.Rounded.AccountTree"
                                                 Style="font-size:0.8rem;" />
                                        @context.ParentPartyName
                                    </div>
                                }
                            </div>
                        </div>
                    </MudTd>
                    <MudTd>
                        <div style="display:flex;flex-direction:column;gap:0.2rem;
                                    font-size:0.82rem;
                                    color:var(--mud-palette-text-secondary);">
                            @if (!string.IsNullOrEmpty(context.Phone))
                            {
                                <div style="display:flex;align-items:center;gap:0.35rem;">
                                    <MudIcon Icon="@Icons.Material.Rounded.Phone"
                                             Style="font-size:0.9rem;color:var(--gold);" />
                                    @context.Phone
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(context.Email))
                            {
                                <div style="display:flex;align-items:center;gap:0.35rem;">
                                    <MudIcon Icon="@Icons.Material.Rounded.Email"
                                             Style="font-size:0.9rem;color:var(--gold);" />
                                    @context.Email
                                </div>
                            }
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@(context.City ?? "-")</MudText>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Style="@GetStageBadgeStyle(context.StageColor)">
                            @(context.StageNameAr ?? context.StageName
                              ?? GetStageText(context.CustomerStage))
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        @if (context.Rating.HasValue)
                        {
                            <MudRating SelectedValue="@context.Rating.Value"
                                       MaxValue="5" ReadOnly="true" Size="Size.Small"
                                       FullIcon="@Icons.Material.Rounded.Star"
                                       EmptyIcon="@Icons.Material.Rounded.StarBorder"
                                       Color="Color.Secondary" />
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Color="@(context.HasInvoices ? Color.Success : Color.Default)"
                                 Icon="@(context.HasInvoices
                                         ? Icons.Material.Rounded.CheckCircle
                                         : Icons.Material.Rounded.RadioButtonUnchecked)">
                            @(context.HasInvoices ? "نعم" : "لا")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                 Color="@(context.IsActive == true
                                          ? Color.Success : Color.Error)">
                            @(context.IsActive == true ? "نشط" : "غير نشط")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <div style="display:flex;gap:0.1rem;"
                             @onclick:stopPropagation="true">
                            @if (!string.IsNullOrEmpty(context.Phone))
                            {
                                <MudTooltip Text="واتساب">
                                    <MudIconButton Icon="@Icons.Material.Rounded.Chat"
                                                   Size="Size.Small" Color="Color.Success"
                                                   OnClick="@(() => OpenWhatsApp(context.Phone))" />
                                </MudTooltip>
                            }
                            @if (_canEdit)
                            {
                                <MudTooltip Text="تعديل">
                                    <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                                   Size="Size.Small" Color="Color.Primary"
                                                   OnClick="() => GoToEdit(context.PartyId)" />
                                </MudTooltip>
                            }
                            @if (_canDelete)
                            {
                                <MudTooltip Text="حذف">
                                    <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                                   Size="Size.Small" Color="Color.Error"
                                                   OnClick="() => ConfirmDelete(context)" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <!-- ╔══════════════════════════════════════╗
         ║           PAGINATION                 ║
         ╚══════════════════════════════════════╝ -->
    @if (_pagedResult.TotalPages > 1)
    {
        <div class="cust-paging">
            <MudPagination Count="@_pagedResult.TotalPages"
                           Selected="@_filter.PageNumber"
                           SelectedChanged="OnPageChanged"
                           Color="Color.Secondary"
                           Variant="Variant.Filled"
                           ShowFirstButton="true"
                           ShowLastButton="true"
                           BoundaryCount="1"
                           MiddleCount="3" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                صفحة <b>@_filter.PageNumber</b> من <b>@_pagedResult.TotalPages</b>
            </MudText>
        </div>
    }

</div>
}

<!-- ═══════ Delete Dialog ═══════ -->
<MudDialog @bind-Visible="_showDeleteDialog">
    <TitleContent>
        <div style="display:flex;align-items:center;gap:0.5rem;">
            <MudIcon Icon="@Icons.Material.Rounded.Warning" Color="Color.Error" />
            <MudText Typo="Typo.h6">تأكيد الحذف</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText>
            هل تريد حذف العميل
            <strong>@_selectedParty?.PartyName</strong>؟
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            سيتم إلغاء تفعيله فقط ولن يتم الحذف النهائي.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showDeleteDialog = false)"
                   Variant="Variant.Outlined"
                   Style="text-transform:none;border-radius:10px;">
            إلغاء
        </MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled"
                   OnClick="ExecuteDelete" Disabled="@_isDeleting"
                   Style="text-transform:none;border-radius:10px;">
            @if (_isDeleting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            حذف
        </MudButton>
    </DialogActions>
</MudDialog>

