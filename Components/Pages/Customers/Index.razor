@page "/customers"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims

@inject PartyService PartyService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ LOADING STATE                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="Color.Secondary" Size="Size.Large" Indeterminate="true" />
            </div>
            <MudText Typo="Typo.h6" Class="loading-text">جاري تحميل البيانات...</MudText>
            <div class="loading-dots">
                <span></span><span></span><span></span>
            </div>
        </div>
    </div>
}
else
{
<div dir="rtl" class="cust-page">

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ BACKGROUND DECORATIONS                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <div class="page-bg-decorations">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ TOP ACCENT BAR                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <div class="top-accent-bar">
        <div class="accent-shimmer"></div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ PREMIUM HEADER                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <div class="cust-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-orbs">
                <div class="header-orb orb-1"></div>
                <div class="header-orb orb-2"></div>
                <div class="header-orb orb-3"></div>
            </div>
            <div class="header-grid"></div>
        </div>

        <div class="header-content">
            <div class="header-top">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon">
                            <MudIcon Icon="@Icons.Material.Rounded.People" Size="Size.Large" />
                        </div>
                        <div class="header-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                        </div>
                        <div class="header-icon-badge-secondary">
                            <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" />
                        </div>
                    </div>
                    <div class="header-text">
                        <div class="header-title-row">
                            <h1>إدارة العملاء</h1>
                            <span class="premium-badge">
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                                Premium
                            </span>
                        </div>
                        <p>
                            <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" Class="subtitle-icon" />
                            إدارة بيانات العملاء والموردين وتتبع المراحل
                        </p>
                    </div>
                </div>

                <div class="header-actions">
                    @if (_canAdd)
                    {
                        <MudButton Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Rounded.PersonAdd"
                                   OnClick="GoToAdd"
                                   Class="btn-add-new">
                            <span class="btn-shine"></span>
                            إضافة عميل جديد
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Rounded.FileDownload"
                               OnClick="ExportToExcel"
                               Disabled="@_isExporting"
                               Class="btn-export">
                        @if (_isExporting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                        }
                        تصدير Excel
                    </MudButton>
                </div>
            </div>

            <!-- Premium Stats -->
            <div class="stats-grid">
                <div class="stat-card stat-total animate-card" style="--delay: 0.05s">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Rounded.People" />
                        </div>
                        <div class="stat-data">
                            <div class="stat-value-row">
                                <span class="stat-value">@_stats.TotalCount</span>
                            </div>
                            <div class="stat-label">إجمالي العملاء</div>
                        </div>
                    </div>
                </div>

                <div class="stat-card stat-active animate-card" style="--delay: 0.1s">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" />
                        </div>
                        <div class="stat-data">
                            <div class="stat-value-row">
                                <span class="stat-value">@_stats.ActiveCount</span>
                                @if (_stats.TotalCount > 0)
                                {
                                    <span class="stat-percent">@(Math.Round((decimal)_stats.ActiveCount / _stats.TotalCount * 100))%</span>
                                }
                            </div>
                            <div class="stat-label">نشط</div>
                        </div>
                    </div>
                </div>

                <div class="stat-card stat-leads animate-card" style="--delay: 0.15s">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Rounded.PersonSearch" />
                        </div>
                        <div class="stat-data">
                            <span class="stat-value">@_stats.LeadsCount</span>
                            <div class="stat-label">محتملون</div>
                        </div>
                    </div>
                </div>

                <div class="stat-card stat-clients animate-card" style="--delay: 0.2s">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Rounded.Verified" />
                        </div>
                        <div class="stat-data">
                            <span class="stat-value">@_stats.ClientsCount</span>
                            <div class="stat-label">فعليون</div>
                        </div>
                    </div>
                </div>

                <div class="stat-card stat-month animate-card" style="--delay: 0.25s">
                    <div class="stat-glow"></div>
                    <div class="stat-accent"></div>
                    <div class="stat-content">
                        <div class="stat-icon-box">
                            <MudIcon Icon="@Icons.Material.Rounded.CalendarMonth" />
                        </div>
                        <div class="stat-data">
                            <div class="stat-value-row">
                                <span class="stat-value">@_stats.ThisMonthCount</span>
                                <span class="stat-trend trend-up">
                                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                                    جديد
                                </span>
                            </div>
                            <div class="stat-label">هذا الشهر</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ PREMIUM FILTER BAR                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <div class="filter-container animate-card" style="--delay: 0.3s">
        <div class="filter-header" @onclick="() => _filterExpanded = !_filterExpanded">
            <div class="filter-header-right">
                <div class="filter-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
                </div>
                <span class="filter-title">بحث وتصفية</span>
                @if (_hasActiveFilters)
                {
                    <span class="filter-active-badge">
                        <span class="badge-pulse"></span>
                        @GetActiveFiltersCount() فلاتر
                    </span>
                }
            </div>
            <div class="filter-header-left">
                @if (_hasActiveFilters)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="ResetFilters" Class="btn-reset-filter">
                        مسح الكل
                    </MudButton>
                }
                <div class="filter-expand-icon @(_filterExpanded ? "expanded" : "")">
                    <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" />
                </div>
            </div>
        </div>

        @if (_filterExpanded)
        {
            <div class="filter-content">
                <div class="filter-grid">
                    <!-- Search Box -->
                    <div class="search-box-wrapper">
                        <div class="search-icon">
                            <MudIcon Icon="@Icons.Material.Rounded.Search" />
                        </div>
                        <input type="text"
                               value="@_searchDisplayText"
                               @oninput="OnSearchInput"
                               placeholder="بحث بالاسم أو الهاتف أو البريد..."
                               class="search-input" />
                        @if (!string.IsNullOrWhiteSpace(_searchDisplayText))
                        {
                            <button class="search-clear" @onclick="ClearSearch">
                                <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                            </button>
                        }
                    </div>

                    <!-- Filters -->
                    <MudSelect T="int?" Value="_filter.PartyType"
                               ValueChanged="@(async (int? v) => { _filter.PartyType = v; await OnFilterChanged(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Label="النوع" Clearable="true"
                               AnchorOrigin="Origin.BottomCenter"
                               Class="filter-select">
                        @foreach (var t in _partyTypes)
                        {
                            <MudSelectItem T="int?" Value="@((int?)t.PartyTypeId)">
                                @t.PartyTypeName
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" Value="_filter.StageId"
                               ValueChanged="@(async (int? v) => { _filter.StageId = v; await OnFilterChanged(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Label="المرحلة" Clearable="true"
                               AnchorOrigin="Origin.BottomCenter"
                               Class="filter-select">
                        @foreach (var s in _salesStages)
                        {
                            <MudSelectItem T="int?" Value="@((int?)s.StageId)">
                                @(s.StageNameAr ?? s.StageName)
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="bool?" Value="_filter.IsActive"
                               ValueChanged="@(async (bool? v) => { _filter.IsActive = v; await OnFilterChanged(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Label="الحالة" Clearable="true"
                               AnchorOrigin="Origin.BottomCenter"
                               Class="filter-select">
                        <MudSelectItem T="bool?" Value="@((bool?)true)">نشط</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)false)">غير نشط</MudSelectItem>
                    </MudSelect>

                    <MudSelect T="bool?" Value="_filter.HasInvoices"
                               ValueChanged="@(async (bool? v) => { _filter.HasInvoices = v; await OnFilterChanged(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Label="الفواتير" Clearable="true"
                               AnchorOrigin="Origin.BottomCenter"
                               Class="filter-select">
                        <MudSelectItem T="bool?" Value="@((bool?)true)">لديه فواتير</MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)false)">بدون فواتير</MudSelectItem>
                    </MudSelect>
                </div>

                <!-- Active Filters Chips -->
                @if (_hasActiveFilters)
                {
                    <div class="active-filters-chips">
                        @if (!string.IsNullOrWhiteSpace(_filter.SearchText))
                        {
                            <div class="filter-chip">
                                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                                <span>بحث: @_searchDisplayText</span>
                                <button @onclick="ClearSearch">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            </div>
                        }
                        @if (_filter.PartyType.HasValue)
                        {
                            var typeName = _partyTypes.FirstOrDefault(x => x.PartyTypeId == _filter.PartyType)?.PartyTypeName;
                            <div class="filter-chip">
                                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                                <span>النوع: @typeName</span>
                                <button @onclick="@(async () => { _filter.PartyType = null; await OnFilterChanged(); })">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            </div>
                        }
                        @if (_filter.StageId.HasValue)
                        {
                            var stage = _salesStages.FirstOrDefault(x => x.StageId == _filter.StageId);
                            <div class="filter-chip">
                                <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" />
                                <span>المرحلة: @(stage?.StageNameAr ?? stage?.StageName)</span>
                                <button @onclick="@(async () => { _filter.StageId = null; await OnFilterChanged(); })">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            </div>
                        }
                        @if (_filter.IsActive.HasValue)
                        {
                            <div class="filter-chip">
                                <MudIcon Icon="@(_filter.IsActive == true ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Size="Size.Small" />
                                <span>@(_filter.IsActive == true ? "نشط" : "غير نشط")</span>
                                <button @onclick="@(async () => { _filter.IsActive = null; await OnFilterChanged(); })">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            </div>
                        }
                        @if (_filter.HasInvoices.HasValue)
                        {
                            <div class="filter-chip">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" />
                                <span>@(_filter.HasInvoices == true ? "لديه فواتير" : "بدون فواتير")</span>
                                <button @onclick="@(async () => { _filter.HasInvoices = null; await OnFilterChanged(); })">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- Results Bar -->
        <div class="results-bar">
            <div class="results-info">
                <span class="results-text">
                    عرض <strong>@_pagedResult.Items.Count</strong> من <strong>@_pagedResult.TotalCount</strong> نتيجة
                </span>
            </div>
            <div class="view-toggle">
                <button class="view-btn @(_viewMode == ViewMode.Grid ? "active" : "")"
                        @onclick="@(() => _viewMode = ViewMode.Grid)">
                    <MudIcon Icon="@Icons.Material.Rounded.GridView" Size="Size.Small" />
                </button>
                <button class="view-btn @(_viewMode == ViewMode.Table ? "active" : "")"
                        @onclick="@(() => _viewMode = ViewMode.Table)">
                    <MudIcon Icon="@Icons.Material.Rounded.TableRows" Size="Size.Small" />
                </button>
            </div>
        </div>
    </div>

    <!-- Loading Bar -->
    @if (_isTableLoading)
    {
        <div class="loading-bar">
            <MudProgressLinear Color="Color.Secondary" Indeterminate="true" />
        </div>
    }

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ GRID VIEW                                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    @if (_viewMode == ViewMode.Grid)
    {
        @if (_pagedResult.Items.Any())
        {
            <div class="customers-grid">
                @foreach (var c in _pagedResult.Items)
                {
                    <div class="customer-card @(c.IsActive != true ? "card-inactive" : "")"
                         @onclick="() => { if (_canEdit) GoToEdit(c.PartyId); }">

                        <!-- Card Glow -->
                        <div class="card-glow"></div>

                        <!-- Card Header -->
                        <div class="card-header">
                            <div class="card-avatar-wrapper">
                                <div class="card-avatar">
                                    @GetInitials(c.PartyName)
                                </div>
                                <span class="status-indicator @(c.IsActive == true ? "status-active" : "status-inactive")"></span>
                            </div>
                            <div class="card-info">
                                <div class="card-name">@c.PartyName</div>
                                @if (!string.IsNullOrEmpty(c.JobTitle))
                                {
                                    <div class="card-job">@c.JobTitle</div>
                                }
                                @if (!string.IsNullOrEmpty(c.PartyTypeName))
                                {
                                    <div class="card-type-badge">@c.PartyTypeName</div>
                                }
                            </div>
                            <div class="card-stage" style="@GetStageBadgeStyle(c.StageColor)">
                                @(c.StageNameAr ?? c.StageName ?? GetStageText(c.CustomerStage))
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(c.Phone))
                            {
                                <div class="info-row">
                                    <div class="info-icon">
                                        <MudIcon Icon="@Icons.Material.Rounded.Phone" Size="Size.Small" />
                                    </div>
                                    <span dir="ltr">@c.Phone</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(c.Email))
                            {
                                <div class="info-row">
                                    <div class="info-icon">
                                        <MudIcon Icon="@Icons.Material.Rounded.Email" Size="Size.Small" />
                                    </div>
                                    <span class="info-ellipsis">@c.Email</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(c.City))
                            {
                                <div class="info-row">
                                    <div class="info-icon">
                                        <MudIcon Icon="@Icons.Material.Rounded.LocationOn" Size="Size.Small" />
                                    </div>
                                    <span>@c.City</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(c.ParentPartyName))
                            {
                                <div class="info-row">
                                    <div class="info-icon">
                                        <MudIcon Icon="@Icons.Material.Rounded.AccountTree" Size="Size.Small" />
                                    </div>
                                    <span>@c.ParentPartyName</span>
                                </div>
                            }
                        </div>

                        <!-- Card Footer -->
                        <div class="card-footer">
                            <div class="card-badges">
                                @if (c.HasInvoices)
                                {
                                    <span class="badge badge-success">
                                        <MudIcon Icon="@Icons.Material.Rounded.Receipt" Size="Size.Small" />
                                        فواتير
                                    </span>
                                }
                                @if (c.ContactsCount > 0)
                                {
                                    <span class="badge badge-info">
                                        <MudIcon Icon="@Icons.Material.Rounded.Contacts" Size="Size.Small" />
                                        @c.ContactsCount
                                    </span>
                                }
                                @if (c.Rating.HasValue)
                                {
                                    <div class="card-rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <MudIcon Icon="@(i <= c.Rating.Value ? Icons.Material.Rounded.Star : Icons.Material.Rounded.StarBorder)"
                                                     Size="Size.Small"
                                                     Class="@(i <= c.Rating.Value ? "star-filled" : "star-empty")" />
                                        }
                                    </div>
                                }
                            </div>

                            <div class="card-actions" @onclick:stopPropagation="true">
                                @if (!string.IsNullOrEmpty(c.Phone))
                                {
                                    <MudTooltip Text="اتصال" Placement="Placement.Top">
                                        <a href="tel:@c.Phone" class="action-btn action-call">
                                            <MudIcon Icon="@Icons.Material.Rounded.Call" Size="Size.Small" />
                                        </a>
                                    </MudTooltip>
                                    <MudTooltip Text="واتساب" Placement="Placement.Top">
                                        <button class="action-btn action-whatsapp" @onclick="@(() => OpenWhatsApp(c.Phone))">
                                            <MudIcon Icon="@Icons.Material.Rounded.Chat" Size="Size.Small" />
                                        </button>
                                    </MudTooltip>
                                }
                                @if (_canEdit)
                                {
                                    <MudTooltip Text="تعديل" Placement="Placement.Top">
                                        <button class="action-btn action-edit" @onclick="() => GoToEdit(c.PartyId)">
                                            <MudIcon Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" />
                                        </button>
                                    </MudTooltip>
                                }
                                @if (_canDelete)
                                {
                                    <MudTooltip Text="حذف" Placement="Placement.Top">
                                        <button class="action-btn action-delete" @onclick="() => ConfirmDelete(c)">
                                            <MudIcon Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" />
                                        </button>
                                    </MudTooltip>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-illustration">
                    <div class="empty-icon-box">
                        <MudIcon Icon="@Icons.Material.Rounded.PeopleAlt" Size="Size.Large" />
                    </div>
                    <div class="empty-particles">
                        <span class="particle particle-1"></span>
                        <span class="particle particle-2"></span>
                        <span class="particle particle-3"></span>
                    </div>
                </div>
                <h3>لا توجد نتائج</h3>
                <p>جرب تغيير معايير البحث أو الفلترة للعثور على العملاء</p>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Rounded.Refresh"
                           OnClick="ResetFilters" Class="empty-btn">
                    إعادة تعيين الفلاتر
                </MudButton>
            </div>
        }
    }
    else
    {
        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ TABLE VIEW                                                               -->
        <!-- ═══════════════════════════════════════════════════════════════════════════ -->
        <div class="table-container">
            <div class="table-header-bar">
                <div class="table-header-right">
                    <div class="table-dot-wrapper">
                        <span class="table-dot"></span>
                        <span class="table-dot-ping"></span>
                    </div>
                    <span class="table-title">قائمة العملاء</span>
                    <span class="table-count">@_pagedResult.TotalCount عميل</span>
                </div>
            </div>

            <MudTable Items="@_pagedResult.Items"
                      Hover="true" Striped="true" Dense="false"
                      FixedHeader="true" Height="600px"
                      OnRowClick="@((TableRowClickEventArgs<PartyListDto> a) => { if (_canEdit) GoToEdit(a.Item.PartyId); })"
                      RowStyle="cursor:pointer;"
                      Class="customers-table">
                <HeaderContent>
                    <MudTh Style="width:70px;">#</MudTh>
                    <MudTh>العميل</MudTh>
                    <MudTh>التواصل</MudTh>
                    <MudTh>المدينة</MudTh>
                    <MudTh>المرحلة</MudTh>
                    <MudTh>التقييم</MudTh>
                    <MudTh>الفواتير</MudTh>
                    <MudTh>الحالة</MudTh>
                    <MudTh Style="width:130px;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <span class="table-id">@context.PartyId</span>
                    </MudTd>
                    <MudTd>
                        <div class="table-customer-cell">
                            <div class="table-avatar-wrapper">
                                <div class="table-avatar">
                                    @GetInitials(context.PartyName)
                                </div>
                                <span class="status-indicator status-small @(context.IsActive == true ? "status-active" : "status-inactive")"></span>
                            </div>
                            <div class="table-customer-info">
                                <div class="table-customer-name">@context.PartyName</div>
                                @if (!string.IsNullOrEmpty(context.JobTitle))
                                {
                                    <div class="table-customer-job">@context.JobTitle</div>
                                }
                                @if (!string.IsNullOrEmpty(context.ParentPartyName))
                                {
                                    <div class="table-customer-parent">
                                        <MudIcon Icon="@Icons.Material.Rounded.AccountTree" Size="Size.Small" />
                                        @context.ParentPartyName
                                    </div>
                                }
                            </div>
                        </div>
                    </MudTd>
                    <MudTd>
                        <div class="table-contact-cell">
                            @if (!string.IsNullOrEmpty(context.Phone))
                            {
                                <div class="contact-row">
                                    <MudIcon Icon="@Icons.Material.Rounded.Phone" Size="Size.Small" />
                                    <span dir="ltr">@context.Phone</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(context.Email))
                            {
                                <div class="contact-row">
                                    <MudIcon Icon="@Icons.Material.Rounded.Email" Size="Size.Small" />
                                    <span>@context.Email</span>
                                </div>
                            }
                        </div>
                    </MudTd>
                    <MudTd>
                        <span class="table-city">@(context.City ?? "—")</span>
                    </MudTd>
                    <MudTd>
                        <span class="table-stage" style="@GetStageBadgeStyle(context.StageColor)">
                            @(context.StageNameAr ?? context.StageName ?? GetStageText(context.CustomerStage))
                        </span>
                    </MudTd>
                    <MudTd>
                        @if (context.Rating.HasValue)
                        {
                            <div class="table-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var idx = i;
                                    <MudIcon Icon="@(idx <= context.Rating.Value ? Icons.Material.Rounded.Star : Icons.Material.Rounded.StarBorder)"
                                             Size="Size.Small"
                                             Class="@(idx <= context.Rating.Value ? "star-filled" : "star-empty")" />
                                }
                            </div>
                        }
                        else
                        {
                            <span class="table-empty">—</span>
                        }
                    </MudTd>
                    <MudTd>
                        <span class="table-invoice @(context.HasInvoices ? "has-invoices" : "")">
                            <MudIcon Icon="@(context.HasInvoices ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)" Size="Size.Small" />
                            @(context.HasInvoices ? "نعم" : "لا")
                        </span>
                    </MudTd>
                    <MudTd>
                        <span class="table-status @(context.IsActive == true ? "is-active" : "is-inactive")">
                            @(context.IsActive == true ? "نشط" : "غير نشط")
                        </span>
                    </MudTd>
                    <MudTd>
                        <div class="table-actions" @onclick:stopPropagation="true">
                            @if (!string.IsNullOrEmpty(context.Phone))
                            {
                                <MudTooltip Text="واتساب" Placement="Placement.Top">
                                    <button class="action-btn action-whatsapp" @onclick="@(() => OpenWhatsApp(context.Phone))">
                                        <MudIcon Icon="@Icons.Material.Rounded.Chat" Size="Size.Small" />
                                    </button>
                                </MudTooltip>
                            }
                            @if (_canEdit)
                            {
                                <MudTooltip Text="تعديل" Placement="Placement.Top">
                                    <button class="action-btn action-edit" @onclick="() => GoToEdit(context.PartyId)">
                                        <MudIcon Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" />
                                    </button>
                                </MudTooltip>
                            }
                            @if (_canDelete)
                            {
                                <MudTooltip Text="حذف" Placement="Placement.Top">
                                    <button class="action-btn action-delete" @onclick="() => ConfirmDelete(context)">
                                        <MudIcon Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" />
                                    </button>
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    }

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ PAGINATION                                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    @if (_pagedResult.TotalPages > 1)
    {
        <div class="pagination-bar">
            <span class="pagination-info">
                صفحة <strong>@_filter.PageNumber</strong> من <strong>@_pagedResult.TotalPages</strong>
            </span>
            <div class="pagination-controls">
                <MudIconButton Icon="@Icons.Material.Filled.FirstPage" Size="Size.Small"
                               Disabled="@(_filter.PageNumber == 1)"
                               OnClick="@(() => OnPageChanged(1))"
                               Class="pagination-btn" />
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                               Disabled="@(_filter.PageNumber == 1)"
                               OnClick="@(() => OnPageChanged(_filter.PageNumber - 1))"
                               Class="pagination-btn" />
                @{
                    var startPage = Math.Max(1, _filter.PageNumber - 2);
                    var endPage = Math.Min(_pagedResult.TotalPages, startPage + 4);
                    startPage = Math.Max(1, endPage - 4);
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    var page = i;
                    <button class="pagination-num @(page == _filter.PageNumber ? "active" : "")"
                            @onclick="@(() => OnPageChanged(page))">
                        @(page)
                    </button>
                }
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                               Disabled="@(_filter.PageNumber == _pagedResult.TotalPages)"
                               OnClick="@(() => OnPageChanged(_filter.PageNumber + 1))"
                               Class="pagination-btn" />
                <MudIconButton Icon="@Icons.Material.Filled.LastPage" Size="Size.Small"
                               Disabled="@(_filter.PageNumber == _pagedResult.TotalPages)"
                               OnClick="@(() => OnPageChanged(_pagedResult.TotalPages))"
                               Class="pagination-btn" />
            </div>
        </div>
    }

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ FLOATING ACTION BUTTON                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    @if (_canAdd)
    {
        <div class="fab-container">
            <div class="fab-main" @onclick="GoToAdd">
                <div class="fab-pulse"></div>
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Medium" />
            </div>
        </div>
    }

    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <!-- ⭐ FOOTER                                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════════════ -->
    <div class="page-footer">
        <div class="footer-content">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="footer-icon" />
            <span>COCOBOLO ERP — نظام إدارة العملاء</span>
            <span class="footer-premium">Premium Edition</span>
        </div>
    </div>

</div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DELETE DIALOG                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showDeleteDialog" Class="premium-dialog dialog-danger">
    <TitleContent>
        <div class="dialog-header dialog-header-danger">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" />
                </div>
                <span class="dialog-title">تأكيد الحذف</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showDeleteDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body dialog-body-centered">
            <div class="delete-illustration">
                <div class="delete-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Large" />
                </div>
            </div>
            <h3 class="delete-title">هل تريد حذف هذا العميل؟</h3>
            <p class="delete-message">
                سيتم إلغاء تفعيل العميل <strong>@_selectedParty?.PartyName</strong>
            </p>
            <span class="delete-note">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                لن يتم الحذف النهائي، فقط إلغاء التفعيل
            </span>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions dialog-actions-centered">
            <MudButton OnClick="@(() => _showDeleteDialog = false)" Variant="Variant.Text" Class="btn-cancel">
                إلغاء
            </MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       OnClick="ExecuteDelete" Disabled="@_isDeleting"
                       StartIcon="@Icons.Material.Filled.Delete" Class="btn-danger">
                @if (_isDeleting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                }
                حذف
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>


<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐⭐⭐ PREMIUM STYLES ⭐⭐⭐                                                                              -->
<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════════ -->
<style>
    /* ═══════════════════════════════════════════════════════════════════════════
       CSS VARIABLES
       ═══════════════════════════════════════════════════════════════════════════ */
    :root {
        --gold: #D4A853;
        --gold-dark: #B8912A;
        --gold-light: #F0DBA8;
        --gold-bg: #FEFBF3;
        --navy: #1B2A4A;
        --navy-dark: #0F1D36;
        --navy-light: #2D4A7A;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       ANIMATIONS
       ═══════════════════════════════════════════════════════════════════════════ */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(5deg); }
    }
    @@keyframes floatDelayed {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-15px) rotate(-3deg); }
    }
    @@keyframes pulseSlow {
        0%, 100% { opacity: 0.5; transform: scale(1); }
        50% { opacity: 0.3; transform: scale(1.1); }
    }
    @@keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 0 0 rgba(212, 168, 83, 0.4); }
        50% { box-shadow: 0 0 30px 10px rgba(212, 168, 83, 0.15); }
    }
    @@keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
    @@keyframes bounceSoft {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }
    @@keyframes ping {
        75%, 100% { transform: scale(2); opacity: 0; }
    }
    @@keyframes loadingDots {
        0%, 80%, 100% { transform: scale(0); opacity: 0; }
        40% { transform: scale(1); opacity: 1; }
    }
    .animate-card {
        animation: fadeInUp 0.6s ease-out forwards;
        animation-delay: var(--delay, 0s);
        opacity: 0;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       LOADING SCREEN
       ═══════════════════════════════════════════════════════════════════════════ */
    .loading-screen {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 70vh;
        gap: 1.5rem;
    }
    .loading-content {
        text-align: center;
    }
    .loading-spinner-box {
        width: 80px; height: 80px;
        margin: 0 auto 1rem auto;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .loading-text {
        color: var(--mud-palette-text-secondary);
    }
    .loading-dots {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 1rem;
    }
    .loading-dots span {
        width: 10px; height: 10px;
        background: var(--gold);
        border-radius: 50%;
        animation: loadingDots 1.4s infinite ease-in-out both;
    }
    .loading-dots span:nth-child(1) { animation-delay: -0.32s; }
    .loading-dots span:nth-child(2) { animation-delay: -0.16s; }

    /* ═══════════════════════════════════════════════════════════════════════════
       PAGE LAYOUT
       ═══════════════════════════════════════════════════════════════════════════ */
    .cust-page {
        position: relative;
        max-width: 1800px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       BACKGROUND DECORATIONS
       ═══════════════════════════════════════════════════════════════════════════ */
    .page-bg-decorations {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 0;
    }
    .bg-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
    }
    .bg-orb-1 {
        width: 400px; height: 400px;
        top: -200px; right: -200px;
        background: radial-gradient(circle, rgba(212,168,83,0.12), transparent 70%);
        animation: float 10s ease-in-out infinite;
    }
    .bg-orb-2 {
        width: 500px; height: 500px;
        bottom: -250px; left: -250px;
        background: radial-gradient(circle, rgba(59,130,246,0.06), transparent 70%);
        animation: floatDelayed 12s ease-in-out infinite;
    }
    .bg-orb-3 {
        width: 600px; height: 600px;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        background: radial-gradient(circle, rgba(139,92,246,0.04), transparent 60%);
        animation: pulseSlow 8s ease-in-out infinite;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       TOP ACCENT BAR
       ═══════════════════════════════════════════════════════════════════════════ */
    .top-accent-bar {
        height: 5px;
        background: linear-gradient(90deg, var(--gold), var(--gold-dark), var(--gold));
        position: relative;
        overflow: hidden;
        margin-bottom: 1.5rem;
        border-radius: 0 0 10px 10px;
    }
    .accent-shimmer {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
        animation: shimmer 3s ease-in-out infinite;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       PREMIUM HEADER
       ═══════════════════════════════════════════════════════════════════════════ */
    .cust-header {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .header-bg {
        position: absolute;
        inset: 0;
    }
    .header-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 40%, var(--navy-light) 100%);
    }
    .header-orbs {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }
    .header-orb {
        position: absolute;
        border-radius: 50%;
    }
    .header-orb.orb-1 {
        width: 400px; height: 400px;
        top: -180px; right: -120px;
        background: radial-gradient(circle, rgba(212,168,83,0.25), transparent 60%);
        animation: float 8s ease-in-out infinite;
    }
    .header-orb.orb-2 {
        width: 300px; height: 300px;
        bottom: -120px; left: 15%;
        background: radial-gradient(circle, rgba(212,168,83,0.15), transparent 60%);
        animation: floatDelayed 10s ease-in-out infinite;
    }
    .header-orb.orb-3 {
        width: 180px; height: 180px;
        top: 25%; left: 8%;
        background: radial-gradient(circle, rgba(255,255,255,0.05), transparent 60%);
        animation: pulseSlow 6s ease-in-out infinite;
    }
    .header-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 40px 40px;
    }
    .header-content {
        position: relative;
        z-index: 2;
        padding: 2rem 2.5rem;
    }
    .header-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    .header-info {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }
    .header-icon-wrapper {
        position: relative;
    }
    .header-icon-glow {
        position: absolute;
        inset: -10px;
        background: var(--gold);
        border-radius: 20px;
        filter: blur(20px);
        opacity: 0.3;
        animation: pulseGlow 4s ease-in-out infinite;
    }
    .header-icon {
        position: relative;
        width: 64px; height: 64px;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }
    .header-icon::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent 50%);
        pointer-events: none;
    }
    .header-icon-badge {
        position: absolute;
        top: -6px; right: -6px;
        width: 24px; height: 24px;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 4px 12px rgba(212,168,83,0.4);
        animation: bounceSoft 2s ease-in-out infinite;
    }
    .header-icon-badge .mud-icon-root { font-size: 12px !important; }
    .header-icon-badge-secondary {
        position: absolute;
        bottom: -4px; left: -4px;
        width: 20px; height: 20px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 4px 12px rgba(16,185,129,0.4);
        opacity: 0;
        transform: scale(0.8);
        transition: all 0.3s ease;
    }
    .header-icon-wrapper:hover .header-icon-badge-secondary {
        opacity: 1;
        transform: scale(1);
    }
    .header-icon-badge-secondary .mud-icon-root { font-size: 10px !important; }
    .header-text h1 {
        margin: 0;
        font-size: 1.8rem;
        font-weight: 900;
        color: white;
        letter-spacing: -0.5px;
    }
    .header-title-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .premium-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(212,168,83,0.3);
        color: var(--gold);
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.3rem 0.6rem;
        border-radius: 20px;
    }
    .premium-badge .mud-icon-root { font-size: 10px !important; }
    .header-text p {
        margin: 0.5rem 0 0 0;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.6);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .subtitle-icon { color: #10b981 !important; font-size: 16px !important; }
    .header-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .btn-add-new {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%) !important;
        color: white !important;
        font-weight: 700 !important;
        padding: 0.875rem 1.75rem !important;
        border-radius: 16px !important;
        box-shadow: 0 8px 25px rgba(212, 168, 83, 0.35) !important;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
    }
    .btn-add-new:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 12px 35px rgba(212, 168, 83, 0.45) !important;
    }
    .btn-shine {
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
        transition: left 0.6s ease;
    }
    .btn-add-new:hover .btn-shine { left: 100%; }
    .btn-export {
        background: rgba(255,255,255,0.1) !important;
        border-color: rgba(255,255,255,0.3) !important;
        color: white !important;
        font-weight: 600 !important;
        padding: 0.75rem 1.25rem !important;
        border-radius: 14px !important;
        transition: all 0.3s ease !important;
    }
    .btn-export:hover {
        background: rgba(255,255,255,0.15) !important;
        border-color: rgba(255,255,255,0.5) !important;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       STATS GRID (inside header)
       ═══════════════════════════════════════════════════════════════════════════ */
    .stats-grid {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .stat-card {
        position: relative;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.875rem;
        flex: 1;
        min-width: 150px;
        overflow: hidden;
        transition: all 0.4s ease;
        cursor: default;
    }
    .stat-card:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-3px);
        border-color: rgba(212,168,83,0.3);
    }
    .stat-glow {
        position: absolute;
        inset: -50%;
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
    }
    .stat-card:hover .stat-glow { opacity: 1; }
    .stat-accent {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.4s ease;
    }
    .stat-card:hover .stat-accent { transform: scaleX(1); }
    .stat-content {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .stat-icon-box {
        width: 46px; height: 46px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: transform 0.3s ease;
    }
    .stat-card:hover .stat-icon-box { transform: scale(1.1); }
    .stat-data { min-width: 0; }
    .stat-value-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .stat-value {
        font-size: 1.5rem;
        font-weight: 900;
        color: #F1F5F9;
        line-height: 1;
    }
    .stat-percent {
        font-size: 0.65rem;
        font-weight: 700;
        background: rgba(16,185,129,0.2);
        color: #10b981;
        padding: 0.15rem 0.4rem;
        border-radius: 6px;
    }
    .stat-trend {
        display: inline-flex;
        align-items: center;
        gap: 0.15rem;
        font-size: 0.6rem;
        font-weight: 700;
        padding: 0.15rem 0.4rem;
        border-radius: 6px;
    }
    .stat-trend .mud-icon-root { font-size: 10px !important; }
    .stat-trend.trend-up { background: rgba(16,185,129,0.2); color: #10b981; }
    .stat-label {
        font-size: 0.72rem;
        font-weight: 600;
        color: rgba(241,245,249,0.6);
        margin-top: 0.15rem;
    }
    /* Stat Colors */
    .stat-total .stat-glow { background: radial-gradient(circle, rgba(212,168,83,0.2), transparent 70%); }
    .stat-total .stat-accent { background: linear-gradient(90deg, var(--gold), var(--gold-dark)); }
    .stat-total .stat-icon-box { background: rgba(212,168,83,0.15); color: var(--gold); }

    .stat-active .stat-glow { background: radial-gradient(circle, rgba(16,185,129,0.2), transparent 70%); }
    .stat-active .stat-accent { background: linear-gradient(90deg, #10b981, #059669); }
    .stat-active .stat-icon-box { background: rgba(16,185,129,0.15); color: #10b981; }

    .stat-leads .stat-glow { background: radial-gradient(circle, rgba(59,130,246,0.2), transparent 70%); }
    .stat-leads .stat-accent { background: linear-gradient(90deg, #3b82f6, #2563eb); }
    .stat-leads .stat-icon-box { background: rgba(59,130,246,0.15); color: #3b82f6; }

    .stat-clients .stat-glow { background: radial-gradient(circle, rgba(139,92,246,0.2), transparent 70%); }
    .stat-clients .stat-accent { background: linear-gradient(90deg, #8b5cf6, #7c3aed); }
    .stat-clients .stat-icon-box { background: rgba(139,92,246,0.15); color: #8b5cf6; }

    .stat-month .stat-glow { background: radial-gradient(circle, rgba(245,158,11,0.2), transparent 70%); }
    .stat-month .stat-accent { background: linear-gradient(90deg, #f59e0b, #d97706); }
    .stat-month .stat-icon-box { background: rgba(245,158,11,0.15); color: #f59e0b; }

    /* ═══════════════════════════════════════════════════════════════════════════
       FILTER BAR
       ═══════════════════════════════════════════════════════════════════════════ */
    .filter-container {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        margin-bottom: 1.25rem;
        overflow: hidden;
        transition: box-shadow 0.3s ease;
    }
    .filter-container:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }
    .filter-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        cursor: pointer;
        transition: background 0.2s ease;
    }
    .filter-header:hover { background: var(--mud-palette-background-gray); }
    .filter-header-right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .filter-icon-box {
        width: 36px; height: 36px;
        background: var(--mud-palette-background-gray);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--mud-palette-text-secondary);
        transition: all 0.3s ease;
    }
    .filter-header:hover .filter-icon-box {
        background: var(--gold);
        color: white;
    }
    .filter-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
    }
    .filter-active-badge {
        position: relative;
        background: var(--gold);
        color: white;
        font-size: 0.68rem;
        font-weight: 700;
        padding: 0.25rem 0.6rem;
        border-radius: 12px;
        overflow: hidden;
    }
    .badge-pulse {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 100%; height: 100%;
        background: white;
        border-radius: 12px;
        opacity: 0;
        animation: ping 1.5s ease-in-out infinite;
    }
    .filter-header-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-reset-filter {
        font-size: 0.75rem !important;
        border-radius: 8px !important;
    }
    .filter-expand-icon {
        width: 28px; height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--mud-palette-text-secondary);
        transition: transform 0.3s ease;
    }
    .filter-expand-icon.expanded { transform: rotate(180deg); }
    .filter-content {
        padding: 0 1.5rem 1.25rem 1.5rem;
        border-top: 1px solid var(--mud-palette-divider);
        animation: fadeInUp 0.3s ease-out;
    }
    .filter-grid {
        display: grid;
        grid-template-columns: 2fr repeat(4, 1fr);
        gap: 0.875rem;
        padding-top: 1rem;
    }
    /* Search Box */
    .search-box-wrapper {
        display: flex;
        align-items: center;
        background: var(--mud-palette-background);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        padding: 0 0.75rem;
        height: 42px;
        transition: all 0.3s ease;
    }
    .search-box-wrapper:focus-within {
        border-color: var(--gold);
        box-shadow: 0 0 0 3px rgba(212,168,83,0.1);
    }
    .search-icon {
        color: var(--mud-palette-text-secondary);
        margin-left: 0.5rem;
    }
    .search-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--mud-palette-text-primary);
        font-size: 0.875rem;
        padding: 0 0.5rem;
        font-family: inherit;
    }
    .search-input::placeholder { color: var(--mud-palette-text-secondary); }
    .search-clear {
        width: 24px; height: 24px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--mud-palette-background-gray);
        border: none;
        cursor: pointer;
        color: var(--mud-palette-text-secondary);
        transition: all 0.2s ease;
    }
    .search-clear:hover {
        background: var(--mud-palette-error);
        color: white;
    }
    ::deep .filter-select .mud-input-outlined-border {
        border-radius: 12px !important;
    }
    /* Active Filters Chips */
    .active-filters-chips {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px dashed var(--mud-palette-divider);
    }
    .filter-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--gold-bg);
        border: 1px solid rgba(212,168,83,0.3);
        color: var(--gold-dark);
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.5rem 0.35rem 0.75rem;
        border-radius: 20px;
    }
    .filter-chip .mud-icon-root { font-size: 14px !important; }
    .filter-chip button {
        width: 18px; height: 18px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(212,168,83,0.2);
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .filter-chip button .mud-icon-root { font-size: 12px !important; }
    .filter-chip button:hover {
        background: var(--mud-palette-error);
        color: white;
    }
    /* Results Bar */
    .results-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.875rem 1.5rem;
        border-top: 1px solid var(--mud-palette-divider);
        background: var(--mud-palette-background-gray);
    }
    .results-text {
        font-size: 0.82rem;
        color: var(--mud-palette-text-secondary);
    }
    .results-text strong { color: var(--mud-palette-text-primary); }
    .view-toggle {
        display: flex;
        gap: 0.25rem;
        background: var(--mud-palette-surface);
        padding: 0.25rem;
        border-radius: 10px;
        border: 1px solid var(--mud-palette-divider);
    }
    .view-btn {
        width: 34px; height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--mud-palette-text-secondary);
        transition: all 0.2s ease;
    }
    .view-btn:hover { background: var(--mud-palette-background-gray); }
    .view-btn.active {
        background: var(--gold);
        color: white;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       LOADING BAR
       ═══════════════════════════════════════════════════════════════════════════ */
    .loading-bar {
        margin-bottom: 1rem;
        border-radius: 10px;
        overflow: hidden;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       CUSTOMERS GRID
       ═══════════════════════════════════════════════════════════════════════════ */
    .customers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }
    .customer-card {
        position: relative;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .customer-card:hover {
        border-color: var(--gold);
        transform: translateY(-6px);
    }
    .customer-card:hover .card-glow { opacity: 1; }
    .card-inactive { opacity: 0.55; }
    .card-glow {
        position: absolute;
        inset: -50%;
        background: radial-gradient(circle at center, rgba(212,168,83,0.08), transparent 60%);
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
    }
    /* Card Header */
    .card-header {
        padding: 1.25rem;
        display: flex;
        align-items: flex-start;
        gap: 0.875rem;
        border-bottom: 1px solid var(--mud-palette-divider);
        background: linear-gradient(135deg, var(--mud-palette-surface) 0%, var(--mud-palette-background-gray) 100%);
    }
    .card-avatar-wrapper {
        position: relative;
        flex-shrink: 0;
    }
    .card-avatar {
        width: 54px; height: 54px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        color: white;
        font-weight: 800;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 0 3px var(--mud-palette-surface),
                    0 0 0 5px var(--gold),
                    0 8px 20px rgba(212,168,83,0.3);
        transition: transform 0.3s ease;
    }
    .customer-card:hover .card-avatar {
        transform: scale(1.08) rotate(3deg);
    }
    .status-indicator {
        position: absolute;
        bottom: -3px; left: -3px;
        width: 14px; height: 14px;
        border-radius: 50%;
        border: 3px solid var(--mud-palette-surface);
    }
    .status-indicator.status-small {
        width: 12px; height: 12px;
        border-width: 2px;
    }
    .status-active { background: #10b981; }
    .status-inactive { background: #ef4444; }
    .card-info {
        flex: 1;
        min-width: 0;
    }
    .card-name {
        font-size: 1rem;
        font-weight: 800;
        color: var(--mud-palette-text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 0.2rem;
        transition: color 0.3s ease;
    }
    .customer-card:hover .card-name { color: var(--gold-dark); }
    .card-job {
        font-size: 0.78rem;
        color: var(--mud-palette-text-secondary);
    }
    .card-type-badge {
        display: inline-block;
        margin-top: 0.35rem;
        font-size: 0.68rem;
        font-weight: 700;
        background: var(--gold-bg);
        color: var(--gold-dark);
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        border: 1px solid rgba(212,168,83,0.2);
    }
    .card-stage {
        display: inline-flex;
        padding: 0.3rem 0.6rem;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 700;
        border: 1px solid;
        flex-shrink: 0;
    }
    /* Card Body */
    .card-body {
        padding: 1rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        min-height: 100px;
    }
    .info-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
        color: var(--mud-palette-text-secondary);
    }
    .info-icon {
        width: 24px; height: 24px;
        border-radius: 6px;
        background: var(--gold-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        flex-shrink: 0;
    }
    .info-icon .mud-icon-root { font-size: 14px !important; }
    .info-ellipsis {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    /* Card Footer */
    .card-footer {
        padding: 0.75rem 1.25rem;
        background: var(--mud-palette-background-gray);
        border-top: 1px solid var(--mud-palette-divider);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }
    .card-badges {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-wrap: wrap;
        flex: 1;
    }
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.68rem;
        font-weight: 600;
        padding: 0.25rem 0.5rem;
        border-radius: 6px;
    }
    .badge .mud-icon-root { font-size: 12px !important; }
    .badge-success { background: #ecfdf5; color: #047857; }
    .badge-info { background: #eff6ff; color: #1d4ed8; }
    .card-rating {
        display: flex;
        gap: 0.1rem;
    }
    .star-filled { color: var(--gold) !important; font-size: 14px !important; }
    .star-empty { color: var(--mud-palette-divider) !important; font-size: 14px !important; }
    .card-actions {
        display: flex;
        gap: 0.25rem;
        flex-shrink: 0;
    }
    .action-btn {
        width: 32px; height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
    }
    .action-btn:hover { transform: scale(1.1); }
    .action-btn:active { transform: scale(0.95); }
    .action-call { color: #10b981; }
    .action-call:hover { background: #ecfdf5; border-color: #10b981; }
    .action-whatsapp { color: #25d366; }
    .action-whatsapp:hover { background: #dcfce7; border-color: #25d366; }
    .action-edit { color: #3b82f6; }
    .action-edit:hover { background: #eff6ff; border-color: #3b82f6; }
    .action-delete { color: #ef4444; }
    .action-delete:hover { background: #fef2f2; border-color: #ef4444; }

    /* ═══════════════════════════════════════════════════════════════════════════
       TABLE VIEW
       ═══════════════════════════════════════════════════════════════════════════ */
    .table-container {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .table-header-bar {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--mud-palette-divider);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(90deg, var(--mud-palette-background-gray), var(--mud-palette-surface));
    }
    .table-header-right {
        display: flex;
        align-items: center;
        gap: 0.625rem;
    }
    .table-dot-wrapper {
        position: relative;
        width: 12px; height: 12px;
    }
    .table-dot {
        position: absolute;
        inset: 2px;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        border-radius: 50%;
    }
    .table-dot-ping {
        position: absolute;
        inset: 0;
        background: var(--gold);
        border-radius: 50%;
        animation: ping 2s ease-in-out infinite;
    }
    .table-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
    }
    .table-count {
        font-size: 0.72rem;
        color: var(--mud-palette-text-secondary);
        background: var(--mud-palette-background-gray);
        padding: 0.25rem 0.6rem;
        border-radius: 12px;
        font-weight: 600;
    }
    ::deep .customers-table .mud-table-head th {
        background: var(--mud-palette-background-gray) !important;
        font-size: 0.8rem !important;
        font-weight: 700 !important;
        color: var(--mud-palette-text-secondary) !important;
        padding: 0.875rem 1rem !important;
        border-bottom: 2px solid var(--mud-palette-divider) !important;
    }
    ::deep .customers-table .mud-table-body tr {
        transition: all 0.3s ease;
    }
    ::deep .customers-table .mud-table-body tr:hover {
        background: var(--gold-bg) !important;
    }
    ::deep .customers-table .mud-table-body td {
        padding: 1rem !important;
        vertical-align: middle !important;
        border-bottom: 1px solid var(--mud-palette-divider) !important;
    }
    .table-id {
        display: inline-block;
        background: var(--mud-palette-background-gray);
        color: var(--mud-palette-text-secondary);
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.25rem 0.5rem;
        border-radius: 6px;
    }
    .table-customer-cell {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .table-avatar-wrapper {
        position: relative;
        flex-shrink: 0;
    }
    .table-avatar {
        width: 42px; height: 42px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        color: white;
        font-weight: 800;
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 0 2px var(--mud-palette-surface),
                    0 0 0 4px var(--gold);
        transition: transform 0.3s ease;
    }
    tr:hover .table-avatar { transform: scale(1.08); }
    .table-customer-info { min-width: 0; }
    .table-customer-name {
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
        transition: color 0.3s ease;
    }
    tr:hover .table-customer-name { color: var(--gold-dark); }
    .table-customer-job {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
    }
    .table-customer-parent {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.72rem;
        color: var(--mud-palette-text-secondary);
    }
    .table-customer-parent .mud-icon-root { font-size: 12px !important; }
    .table-contact-cell {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }
    .contact-row {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        color: var(--mud-palette-text-secondary);
    }
    .contact-row .mud-icon-root {
        font-size: 14px !important;
        color: var(--gold) !important;
    }
    .table-city {
        font-size: 0.85rem;
        color: var(--mud-palette-text-secondary);
    }
    .table-stage {
        display: inline-flex;
        padding: 0.3rem 0.6rem;
        border-radius: 8px;
        font-size: 0.72rem;
        font-weight: 700;
        border: 1px solid;
    }
    .table-rating {
        display: flex;
        gap: 0.1rem;
    }
    .table-empty {
        color: var(--mud-palette-text-disabled);
    }
    .table-invoice {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
    }
    .table-invoice .mud-icon-root { font-size: 16px !important; }
    .table-invoice.has-invoices { color: #10b981; }
    .table-status {
        display: inline-block;
        padding: 0.3rem 0.7rem;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
    }
    .table-status.is-active { background: #ecfdf5; color: #047857; }
    .table-status.is-inactive { background: #fef2f2; color: #b91c1c; }
    .table-actions {
        display: flex;
        gap: 0.25rem;
        justify-content: center;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       EMPTY STATE
       ═══════════════════════════════════════════════════════════════════════════ */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 24px;
        margin-bottom: 1.5rem;
    }
    .empty-illustration {
        position: relative;
        width: 120px; height: 120px;
        margin: 0 auto 1.5rem auto;
    }
    .empty-icon-box {
        position: absolute;
        inset: 10px;
        background: linear-gradient(135deg, var(--mud-palette-background-gray), var(--mud-palette-surface));
        border-radius: 24px;
        display: flex;
        align-items: center;
