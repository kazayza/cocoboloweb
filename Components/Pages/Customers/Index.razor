@code {
    // ============================
    // State
    // ============================
    private bool _isLoading = true;
    private bool _isTableLoading = false;
    private bool _showDeleteDialog = false;
    private bool _isDeleting = false;

    private PartyListDto? _selectedParty;
    private PartyFilterDto _filter = new() { IsActive = true };
    private PagedResult<PartyListDto> _pagedResult = new();
    private PartyStatsDto _stats = new();
    private List<PartyType> _partyTypes = new();
    private List<SalesStage> _salesStages = new();
    private ViewMode _viewMode = ViewMode.Grid;
    private bool _isExporting = false;

    private string? _currentUserName;
    private bool _canView = false;
    private bool _canAdd = false;
    private bool _canEdit = false;
    private bool _canDelete = false;

    private enum ViewMode { Grid, Table }

    // ============================
    // Lifecycle
    // ============================
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canView = user.HasClaim("Permission", "frm_PartiesList:View");
            _canAdd = user.HasClaim("Permission", "frm_Parties:Add");
            _canEdit = user.HasClaim("Permission", "frm_Parties:Edit");
            _canDelete = user.HasClaim("Permission", "frm_PartiesList:Delete");

            if (!_canView)
            {
                Navigation.NavigateTo("/");
                return;
            }

            await LoadLookups();
            await LoadData();
            await LoadStats();
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ============================
    // Data Loading
    // ============================
    private async Task LoadData()
    {
        _isTableLoading = true;
        _pagedResult = await PartyService.GetPartiesAsync(_filter);
        _isTableLoading = false;
    }

    private async Task LoadStats()
    {
        _stats = await PartyService.GetStatsAsync(_filter.PartyType);
    }

    private async Task LoadLookups()
    {
        _partyTypes = await PartyService.GetPartyTypesAsync();
        _salesStages = await PartyService.GetSalesStagesAsync();
    }

    // ============================
    // Filter Events
    // ============================
    private async Task OnSearchChanged(string value)
    {
        _filter.SearchText = value;
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnFilterChanged()
    {
        _filter.PageNumber = 1;
        await LoadData();
        await LoadStats();
    }

    private async Task OnPageChanged(int page)
    {
        _filter.PageNumber = page;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _filter = new() { IsActive = true };
        await LoadData();
        await LoadStats();
    }

    // ============================
    // Navigation
    // ============================
    private void GoToAdd() => Navigation.NavigateTo("/customers/form");
    private void GoToEdit(int partyId) => Navigation.NavigateTo($"/customers/form/{partyId}");

    // ============================
    // Delete
    // ============================
    private void ConfirmDelete(PartyListDto party)
    {
        _selectedParty = party;
        _showDeleteDialog = true;
    }

    private async Task ExecuteDelete()
    {
        if (_selectedParty == null) return;

        _isDeleting = true;
        var (success, message) = await PartyService.DeletePartyAsync(_selectedParty.PartyId, _currentUserName!);
        _isDeleting = false;
        _showDeleteDialog = false;

        if (success)
        {
            Snackbar.Add(message, Severity.Success);
            await LoadData();
            await LoadStats();
        }
        else
        {
            Snackbar.Add(message, Severity.Error);
        }
    }

    // ============================
    // Export
    // ============================
    private async Task ExportToExcel()
    {
        try
        {
            _isExporting = true;
            StateHasChanged();

            var data = await PartyService.GetAllForExportAsync(_filter);

            var sb = new System.Text.StringBuilder();
            sb.AppendLine("الاسم,النوع,الهاتف,البريد,المدينة,المرحلة,التقييم,الحالة,تاريخ الإنشاء");

            foreach (var item in data)
            {
                sb.AppendLine($"\"{item.PartyName}\",\"{item.PartyTypeName}\",\"{item.Phone}\",\"{item.Email}\",\"{item.City}\",\"{GetStageText(item.CustomerStage)}\",\"{item.Rating}\",\"{(item.IsActive == true ? "نشط" : "غير نشط")}\",\"{item.CreatedAt:yyyy/MM/dd}\"");
            }

            var bytes = System.Text.Encoding.UTF8.GetPreamble()
                .Concat(System.Text.Encoding.UTF8.GetBytes(sb.ToString()))
                .ToArray();

            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"Customers_{DateTime.Now:yyyyMMdd_HHmmss}.csv";

            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='{fileName}';a.click();");

            Snackbar.Add($"تم تصدير {data.Count} سجل", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("خطأ في التصدير", Severity.Error);
            Console.WriteLine($"Export Error: {ex}");
        }
        finally
        {
            _isExporting = false;
        }
    }

    // ============================
    // UI Helpers
    // ============================
    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var words = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return words.Length >= 2 ? $"{words[0][0]}{words[1][0]}" : name[0].ToString();
    }

    private string GetStageText(string? stage) => stage switch
    {
        CustomerStages.Lead => "عميل محتمل",
        CustomerStages.Prospect => "تم التواصل",
        CustomerStages.Qualified => "مؤهل للشراء",
        CustomerStages.Client => "عميل فعلي",
        CustomerStages.Lost => "خسرناه",
        _ => "غير محدد"
    };

    private string GetStageIcon(string? stage) => stage switch
    {
        CustomerStages.Lead => "🔵",
        CustomerStages.Prospect => "🟡",
        CustomerStages.Qualified => "🟣",
        CustomerStages.Client => "🟢",
        CustomerStages.Lost => "🔴",
        _ => "⚪"
    };

    private string GetStageCssClass(string? stage) => stage switch
    {
        CustomerStages.Lead => "stage-lead",
        CustomerStages.Prospect => "stage-prospect",
        CustomerStages.Qualified => "stage-qualified",
        CustomerStages.Client => "stage-client",
        CustomerStages.Lost => "stage-lost",
        _ => "stage-default"
    };
}