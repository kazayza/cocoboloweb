@code {
    /* ═══════════════════════════════════════════════════════════════════════════
       STATE VARIABLES
       ═══════════════════════════════════════════════════════════════════════════ */
    private bool _isLoading = true;
    private bool _isTableLoading = false;
    private bool _showDeleteDialog = false;
    private bool _isDeleting = false;
    private bool _isExporting = false;
    private bool _filterExpanded = true;
    private string _searchDisplayText = "";

    private PartyListDto? _selectedParty;
    private PartyFilterDto _filter = new() { IsActive = true };
    private PagedResult<PartyListDto> _pagedResult = new();
    private PartyStatsDto _stats = new();
    private List<PartyType> _partyTypes = new();
    private List<SalesStage> _salesStages = new();
    private ViewMode _viewMode = ViewMode.Grid;

    private string? _currentUserName;
    private bool _canView, _canAdd, _canEdit, _canDelete;

    private System.Timers.Timer? _searchTimer;

    private bool _hasActiveFilters =>
        !string.IsNullOrWhiteSpace(_searchDisplayText) ||
        _filter.PartyType.HasValue ||
        _filter.StageId.HasValue ||
        _filter.IsActive.HasValue ||
        _filter.HasInvoices.HasValue;

    private enum ViewMode { Grid, Table }

    /* ═══════════════════════════════════════════════════════════════════════════
       LIFECYCLE
       ═══════════════════════════════════════════════════════════════════════════ */
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canView = user.HasClaim("Permission", "frm_PartiesList:View");
            _canAdd = user.HasClaim("Permission", "frm_Parties:Add");
            _canEdit = user.HasClaim("Permission", "frm_Parties:Edit");
            _canDelete = user.HasClaim("Permission", "frm_PartiesList:Delete");

            if (!_canView) { Navigation.NavigateTo("/"); return; }

            await LoadLookups();
            await LoadData();
            await LoadStats();
        }
        finally { _isLoading = false; }
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       DATA LOADING
       ═══════════════════════════════════════════════════════════════════════════ */
    private async Task LoadData()
    {
        _isTableLoading = true;
        StateHasChanged();
        _pagedResult = await PartyService.GetPartiesAsync(_filter);
        _isTableLoading = false;
        StateHasChanged();
    }

    private async Task LoadStats() =>
        _stats = await PartyService.GetStatsAsync(_filter.PartyType);

    private async Task LoadLookups()
    {
        _partyTypes = await PartyService.GetPartyTypesAsync();
        _salesStages = await PartyService.GetSalesStagesAsync();
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       SEARCH WITH DEBOUNCE
       ═══════════════════════════════════════════════════════════════════════════ */
    private void OnSearchInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        _searchDisplayText = value;
        _filter.SearchText = value.NormalizeArabic();

        _searchTimer?.Stop();
        _searchTimer?.Dispose();
        _searchTimer = new System.Timers.Timer(400);
        _searchTimer.Elapsed += async (_, _) =>
        {
            _searchTimer?.Stop();
            await InvokeAsync(async () =>
            {
                _filter.PageNumber = 1;
                await LoadData();
                StateHasChanged();
            });
        };
        _searchTimer.AutoReset = false;
        _searchTimer.Start();
    }

    private async Task ClearSearch()
    {
        _searchDisplayText = "";
        _filter.SearchText = "";
        _filter.PageNumber = 1;
        await LoadData();
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       FILTER HANDLERS
       ═══════════════════════════════════════════════════════════════════════════ */
    private int GetActiveFiltersCount()
    {
        int count = 0;
        if (!string.IsNullOrWhiteSpace(_filter.SearchText)) count++;
        if (_filter.PartyType.HasValue) count++;
        if (_filter.StageId.HasValue) count++;
        if (_filter.IsActive.HasValue) count++;
        if (_filter.HasInvoices.HasValue) count++;
        return count;
    }

    private async Task OnFilterChanged()
    {
        _filter.PageNumber = 1;
        await LoadData();
        await LoadStats();
    }

    private async Task OnPageChanged(int page)
    {
        _filter.PageNumber = page;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _searchDisplayText = "";
        _filter = new() { IsActive = true };
        await LoadData();
        await LoadStats();
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       NAVIGATION
       ═══════════════════════════════════════════════════════════════════════════ */
    private void GoToAdd() => Navigation.NavigateTo("/customers/form");
    private void GoToEdit(int id) => Navigation.NavigateTo($"/customers/form/{id}");

    private async Task OpenWhatsApp(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return;
        var clean = new string(phone.Where(char.IsDigit).ToArray());
        if (!clean.StartsWith("2")) clean = "2" + clean;
        await JS.InvokeVoidAsync("open", $"https://wa.me/{clean}", "_blank");
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       DELETE
       ═══════════════════════════════════════════════════════════════════════════ */
    private void ConfirmDelete(PartyListDto p)
    {
        _selectedParty = p;
        _showDeleteDialog = true;
    }

    private async Task ExecuteDelete()
    {
        if (_selectedParty == null) return;
        _isDeleting = true;
        var (ok, msg) = await PartyService.DeletePartyAsync(_selectedParty.PartyId, _currentUserName!);
        _isDeleting = false;
        _showDeleteDialog = false;
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) { await LoadData(); await LoadStats(); }
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       EXPORT
       ═══════════════════════════════════════════════════════════════════════════ */
    private async Task ExportToExcel()
    {
        try
        {
            _isExporting = true;
            StateHasChanged();

            var data = await PartyService.GetAllForExportAsync(_filter);
            var sb = new System.Text.StringBuilder();
            sb.AppendLine("الاسم,النوع,الهاتف,البريد,المدينة,المرحلة,التقييم,الحالة,تاريخ الإنشاء");

            foreach (var item in data)
                sb.AppendLine(
                    $"\"{item.PartyName}\",\"{item.PartyTypeName}\"," +
                    $"\"{item.Phone}\",\"{item.Email}\",\"{item.City}\"," +
                    $"\"{GetStageText(item.CustomerStage)}\",\"{item.Rating}\"," +
                    $"\"{(item.IsActive == true ? "نشط" : "غير نشط")}\"," +
                    $"\"{item.CreatedAt:yyyy/MM/dd}\"");

            var bytes = System.Text.Encoding.UTF8.GetPreamble()
                            .Concat(System.Text.Encoding.UTF8.GetBytes(sb.ToString()))
                            .ToArray();
            var b64 = Convert.ToBase64String(bytes);
            var fname = $"Customers_{DateTime.Now:yyyyMMdd_HHmmss}.csv";

            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');" +
                $"a.href='data:text/csv;base64,{b64}';" +
                $"a.download='{fname}';a.click();");

            Snackbar.Add($"تم تصدير {data.Count} سجل بنجاح ✅", Severity.Success);
        }
        catch { Snackbar.Add("حدث خطأ في التصدير", Severity.Error); }
        finally { _isExporting = false; StateHasChanged(); }
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       HELPERS
       ═══════════════════════════════════════════════════════════════════════════ */
    private string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var w = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return w.Length >= 2 ? $"{w[0][0]}{w[1][0]}" : name[0].ToString();
    }

    private string GetStageBadgeStyle(string? color)
    {
        var c = color ?? "#94a3b8";
        return $"color:{c};border-color:{c};background:linear-gradient(135deg,{c}10,{c}05);";
    }

    private string GetStageText(string? stage) => stage switch
    {
        CustomerStages.Lead => "عميل محتمل",
        CustomerStages.Prospect => "تم التواصل",
        CustomerStages.Qualified => "مؤهل للشراء",
        CustomerStages.Client => "عميل فعلي",
        CustomerStages.Lost => "خسرناه",
        _ => "غير محدد"
    };
}
