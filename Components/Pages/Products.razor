@page "/products"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject IProductService ProductService
@inject IAuditService AuditService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject db24804Context Db
@inject IJSRuntime JS
@inject IServiceScopeFactory ScopeFactory

<div class="products-page">

    <!-- Header Section -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-left">
                <div class="page-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                </div>
                <div class="header-text">
                    <h1>إدارة المنتجات</h1>
                    <p class="subtitle">عرض وإدارة كافة المنتجات المسجلة في النظام</p>
                </div>
            </div>
            <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                @if (_canExport)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               Class="add-btn"
                               Style="background: rgba(255,255,255,0.15); color: white; border-color: rgba(255,255,255,0.4);"
                               OnClick="ExportToExcel">
                        تصدير Excel
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Class="add-btn"
                           OnClick="AddProduct">
                    إضافة منتج جديد
                </MudButton>
            </div>
        </div>
    </div>

    <!-- Controls Bar -->
    <div class="controls-bar">
        <div class="search-section">
            <MudTextField @bind-Value="SearchText"
                          Immediate="true"
                          Placeholder="ابحث عن منتج بالكود أو الاسم أو العميل..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Class="search-field" />
        </div>

        <!-- ✅ Filter بالحالة -->
        <div class="filter-section">
            <MudSelect T="int?" 
           Value="@_statusFilter"
           ValueChanged="OnStatusFilterChanged"
           Placeholder="كل الحالات"
           Variant="Variant.Outlined"
           Margin="Margin.Dense"
           Clearable="true"
           Class="status-filter"
           AdornmentIcon="@Icons.Material.Filled.FilterAlt"
           Adornment="Adornment.Start">
                <MudSelectItem T="int?" Value="@((int?)null)">كل الحالات</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)1)">مسودة</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)2)">بانتظار التسعير</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)3)">تم التسعير</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)4)">طلب تعديل سعر</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)5)">تمت الموافقة</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)6)">مرفوض</MudSelectItem>
            </MudSelect>
        </div>
        <!-- ⭐ View Mode Toggle -->
<div class="view-toggle">
    <button type="button" class="toggle-btn @(_viewMode == "table" ? "active" : "")"
            @onclick='() => SetViewMode("table")'>
        <MudIcon Icon="@Icons.Material.Filled.TableRows" Size="Size.Small" />
        <span>جدول</span>
    </button>
    <button type="button" class="toggle-btn @(_viewMode == "grid" ? "active" : "")"
            @onclick='() => SetViewMode("grid")'>
        <MudIcon Icon="@Icons.Material.Filled.GridView" Size="Size.Small" />
        <span>كروت</span>
    </button>
</div>

        <!-- ✅ Stats كفلتر -->
        <div class="stats-chips">
            <button type="button" class="stat-chip @(_activeStatFilter == "all" ? "active" : "")"
                    @onclick='() => FilterByStat("all")'>
                <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" />
                <span class="stat-label">الإجمالي</span>
                <span class="stat-value">@_totalCount</span>
            </button>
            <button type="button" class="stat-chip success @(_activeStatFilter == "priced" ? "active-filter" : "")"
                    @onclick='() => FilterByStat("priced")'>
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                <span class="stat-label">مسعّرة</span>
                <span class="stat-value">@_pricedCount</span>
            </button>
            <button type="button" class="stat-chip warning @(_activeStatFilter == "unpriced" ? "active-filter" : "")"
                    @onclick='() => FilterByStat("unpriced")'>
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                <span class="stat-label">بدون سعر</span>
                <span class="stat-value">@_noPriceCount</span>
            </button>
            @if (!string.IsNullOrWhiteSpace(_searchText) || _statusFilter.HasValue || _activeStatFilter != "all")
            {
                <button type="button" class="stat-chip clear-filter" @onclick="ClearAllFilters">
                    <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" />
                    <span class="stat-label">مسح الفلتر</span>
                </button>
            }
        </div>
    </div>

    <!-- Products Table -->
    <div class="table-container">
        @if (_isLoading)
        {
            <div class="loading-state">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <p>جاري تحميل البيانات...</p>
            </div>
        }
        else if (!_filteredProducts.Any())
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" />
                <h3>لا توجد منتجات</h3>
                <p>@(string.IsNullOrWhiteSpace(_searchText) && !_statusFilter.HasValue && _activeStatFilter == "all"
                    ? "لم يتم إضافة أي منتجات بعد"
                    : "لم يتم العثور على نتائج مطابقة")</p>
                @if (string.IsNullOrWhiteSpace(_searchText) && !_statusFilter.HasValue && _activeStatFilter == "all")
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddProduct"
                               Class="mt-3">
                        إضافة أول منتج
                    </MudButton>
                }
            </div>
        }
        else
{
    @if (_viewMode == "table")
    {
        <!-- ============ Table View ============ -->
        <MudTable Items="@_pagedProducts"
                  Hover="true"
                  Breakpoint="Breakpoint.Sm"
                  Elevation="0"
                  Class="products-table">

            <HeaderContent>
                <MudTh Class="table-header" Style="width: 70px;">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" />
                        <span>الصورة</span>
                    </div>
                </MudTh>
                <MudTh Class="table-header">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" />
                        <span>الكود</span>
                    </div>
                </MudTh>
                <MudTh Class="table-header">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" />
                        <span>المنتج</span>
                    </div>
                </MudTh>
                <MudTh Class="table-header">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                        <span>باقه التسعير</span>
                    </div>
                </MudTh>
                <MudTh Class="table-header">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                        <span>الحالة</span>
                    </div>
                </MudTh>
                @if (_showSalePrice)
                {
                    <MudTh Class="table-header">
                        <div class="header-cell">
                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" />
                            <span>سعر البيع Premium</span>
                        </div>
                    </MudTh>
                    <MudTh Class="table-header">
                        <div class="header-cell">
                            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Size="Size.Small" Style="color:#ec4899" />
                            <span style="color:#ec4899">سعر البيع Elite</span>
                        </div>
                    </MudTh>
                }
                <MudTh Class="table-header">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        <span>العميل</span>
                    </div>
                </MudTh>
                <MudTh Class="table-header">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" />
                        <span>تاريخ التسجيل</span>
                    </div>
                </MudTh>
                <MudTh Class="table-header">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.Factory" Size="Size.Small" />
                        <span>وقت تسعير المصنع</span>
                    </div>
                </MudTh>
                <MudTh Class="table-header">
                    <div class="header-cell">
                        <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" />
                        <span>استجابة التسعير</span>
                    </div>
                </MudTh>
                <MudTh Class="table-header actions-header">
                    <span>الإجراءات</span>
                </MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="الصورة">
                    <div class="product-thumb-wrapper" @onclick="@(() => OpenViewDialog(context))">
                        <img src="/api/product-images/@context.ProductId"
                             alt="@context.ProductName"
                             class="product-thumb"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                        <div class="product-thumb-placeholder" style="display:none">
                            <MudIcon Icon="@Icons.Material.Filled.Image" />
                        </div>
                    </div>
                </MudTd>

                <MudTd DataLabel="الكود">
                    <span class="code-badge">#@context.ProductId</span>
                </MudTd>

                <MudTd DataLabel="المنتج">
                    <div class="product-info">
                        <strong>@context.ProductName</strong>
                        @if (!string.IsNullOrWhiteSpace(context.ProductDescription))
                        {
                            <span class="product-desc">
                                @(context.ProductDescription.Length > 40
                                    ? context.ProductDescription.Substring(0, 40) + "..."
                                    : context.ProductDescription)
                            </span>
                        }
                    </div>
                </MudTd>

                <MudTd DataLabel="النوع">
                    <span class="pricing-type-badge @(context.PricingType == "Elite" ? "elite" : "premium")">
                        @context.PricingType
                    </span>
                </MudTd>

                <MudTd DataLabel="الحالة">
                    <MudChip T="string"
                             Color="@GetStatusColor(context.PricingStatusId)"
                             Size="Size.Small"
                             Variant="Variant.Outlined">
                        @GetStatusText(context.PricingStatusId)
                    </MudChip>
                </MudTd>

                @if (_showSalePrice)
                {
                    <!-- عمود سعر البيع Premium -->
                    <MudTd DataLabel="سعر البيع Premium">
                        @if (context.SuggestedSalePrice.HasValue && context.SuggestedSalePrice.Value > 0)
                        {
                            <span class="sale-price">
                                @context.SuggestedSalePrice.Value.ToString("N0") ج.م
                            </span>
                        }
                        else
                        {
                            <span class="no-price">-</span>
                        }
                    </MudTd>

                    <!-- عمود سعر البيع Elite -->
                    <MudTd DataLabel="سعر البيع Elite">
                        @if (context.SuggestedSalePriceElite.HasValue && context.SuggestedSalePriceElite.Value > 0)
                        {
                            <span class="sale-price elite-price">
                                @context.SuggestedSalePriceElite.Value.ToString("N0") ج.م
                            </span>
                        }
                        else
                        {
                            <span class="no-price">-</span>
                        }
                    </MudTd>
                }

                <MudTd DataLabel="العميل">
                    @if (!string.IsNullOrWhiteSpace(context.CustomerName))
                    {
                        <span class="customer-badge">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            @context.CustomerName
                        </span>
                    }
                    else
                    {
                        <span class="no-data">-</span>
                    }
                </MudTd>

                <MudTd DataLabel="تاريخ التسجيل">
                    @if (context.CreatedAt.HasValue)
                    {
                        <div class="time-cell">
                            <div class="time-date">@context.CreatedAt.Value.ToString("yyyy/MM/dd")</div>
                            <div class="time-clock">@context.CreatedAt.Value.ToString("hh:mm tt")</div>
                        </div>
                    }
                    else
                    {
                        <span class="no-data">—</span>
                    }
                </MudTd>

                <MudTd DataLabel="وقت تسعير المصنع">
                    @if (context.FactoryPricedAt.HasValue)
                    {
                        <div class="time-cell priced">
                            <div class="time-date">@context.FactoryPricedAt.Value.ToString("yyyy/MM/dd")</div>
                            <div class="time-clock">@context.FactoryPricedAt.Value.ToString("hh:mm tt")</div>
                        </div>
                    }
                    else
                    {
                        <div class="unpriced-badge">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                            <span>لم يُسعّر بعد</span>
                        </div>
                    }
                </MudTd>

                <MudTd DataLabel="استجابة التسعير">
                    @if (!string.IsNullOrEmpty(context.ResponseTimeText))
                    {
                        <div class="response-badge @(context.ResponseTimeClass ?? "")">
                            @context.ResponseTimeText
                        </div>
                    }
                    else
                    {
                        <span class="no-data">—</span>
                    }
                </MudTd>

                <MudTd DataLabel="الإجراءات">
                    <div class="action-buttons">
                        <MudTooltip Text="عرض سريع">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Color="Color.Info"
                                           Size="Size.Small"
                                           OnClick="() => OpenViewDialog(context)" />
                        </MudTooltip>

                        <MudTooltip Text="تعديل">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Warning"
                                           Size="Size.Small"
                                           OnClick="() => Edit(context.ProductId)" />
                        </MudTooltip>

                        @if (!string.IsNullOrWhiteSpace(context.PdfPath) || context.HasOldPdf)
                        {
                            <MudTooltip Text="عرض PDF">
                                <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="() => OpenPdf(context)" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudTooltip Text="لا يوجد ملف PDF">
                                <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf"
                                               Color="Color.Default"
                                               Size="Size.Small"
                                               Disabled="true" />
                            </MudTooltip>
                        }
                        <!-- ⭐ زر سجل التسعير -->
@if (_canViewPricingHistory)
{
    <MudTooltip Text="سجل التسعير">
        <MudIconButton Icon="@Icons.Material.Filled.History"
                       Color="Color.Info"
                       Size="Size.Small"
                       OnClick="() => OpenPricingHistory(context)" />
    </MudTooltip>
}

                        @if (_canDelete)
                        {
                            <MudTooltip Text="حذف">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="() => AskDelete(context)" />
                            </MudTooltip>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
    else
    {
        <!-- ============ ⭐ Grid View ============ -->
        <div class="products-grid">
            @foreach (var product in _pagedProducts)
            {
                <div class="product-card">
                    <div class="product-card-image" @onclick="@(() => OpenViewDialog(product))">
                        <img src="/api/product-images/@product.ProductId"
                             alt="@product.ProductName"
                             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                        <div class="product-card-placeholder" style="display:none">
                            <MudIcon Icon="@Icons.Material.Filled.Image" />
                            <span>لا توجد صورة</span>
                        </div>

                        <!-- Status Badge -->
                        <div class="card-status-badge status-@(product.PricingStatusId)">
                            @GetStatusText(product.PricingStatusId)
                        </div>

                        <!-- Pricing Type Badge -->
                        <div class="card-pricing-badge @(product.PricingType == "Elite" ? "elite" : "premium")">
                            @product.PricingType
                        </div>

                        <!-- Quick View Overlay -->
                        <div class="card-overlay">
                            <MudIcon Icon="@Icons.Material.Filled.ZoomIn" />
                            <span>عرض سريع</span>
                        </div>
                    </div>

                    <div class="product-card-body">
    <!-- ⭐ الكود + الاسم في سطر واحد -->
    <div class="card-title-row">
        <span class="card-code-inline">#@product.ProductId</span>
        <h3 class="card-title">@product.ProductName</h3>
    </div>

    @if (!string.IsNullOrWhiteSpace(product.CustomerName))
    {
        <div class="card-customer">
            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
            <span>@product.CustomerName</span>
        </div>
    }

    @if (_showSalePrice)
    {
        <div class="card-prices-row">
            <!-- Premium -->
            <div class="card-price-item">
                <span class="card-price-label">Premium</span>
                @if (product.SuggestedSalePrice.HasValue && product.SuggestedSalePrice.Value > 0)
                {
                    <span class="card-price-value premium-val">@product.SuggestedSalePrice.Value.ToString("N0") <small>ج.م</small></span>
                }
                else
                {
                    <span class="card-price-empty">-</span>
                }
            </div>
            <!-- Elite -->
            <div class="card-price-item">
                <span class="card-price-label elite-label">Elite ✦</span>
                @if (product.SuggestedSalePriceElite.HasValue && product.SuggestedSalePriceElite.Value > 0)
                {
                    <span class="card-price-value elite-val">@product.SuggestedSalePriceElite.Value.ToString("N0") <small>ج.م</small></span>
                }
                else
                {
                    <span class="card-price-empty">-</span>
                }
            </div>
        </div>
    }
</div>

                    <div class="product-card-actions">
    <MudTooltip Text="تعديل">
        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                       Color="Color.Warning"
                       Size="Size.Small"
                       OnClick="() => Edit(product.ProductId)" />
    </MudTooltip>

    @if (!string.IsNullOrWhiteSpace(product.PdfPath) || product.HasOldPdf)
    {
        <MudTooltip Text="عرض PDF">
            <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf"
                           Color="Color.Error"
                           Size="Size.Small"
                           OnClick="() => OpenPdf(product)" />
        </MudTooltip>
    }

    <!-- ⭐ زر سجل التسعير -->
    @if (_canViewPricingHistory)
    {
        <MudTooltip Text="سجل التسعير">
            <MudIconButton Icon="@Icons.Material.Filled.History"
                           Color="Color.Info"
                           Size="Size.Small"
                           OnClick="() => OpenPricingHistory(product)" />
        </MudTooltip>
    }

    @if (_canDelete)
    {
        <MudTooltip Text="حذف">
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           Size="Size.Small"
                           OnClick="() => AskDelete(product)" />
        </MudTooltip>
    }
</div>
                </div>
            }
        </div>
    }

    <!-- ✅ Pagination -->
    <div class="pagination-bar">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            عرض @(_pageStart) - @(_pageEnd) من @(_filteredProducts.Count) منتج
        </MudText>
        <MudPagination T="int"
                       Count="@_totalPages"
                       Selected="@_currentPage"
                       SelectedChanged="OnPageChanged"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       ShowFirstButton="true"
                       ShowLastButton="true" />
    </div>
}
    </div>
</div>

<!-- VIEW DIALOG -->
@if (_viewDialogOpen && _selectedProduct != null)
{
    <MudOverlay ZIndex="1000" OnClick="@(() => _viewDialogOpen = false)" />
    <div class="custom-dialog">
        <MudPaper class="vd-paper" Elevation="24">

            <!-- Header متدرج مع الباقة -->
            <div class="vd-header @(_selectedProduct.PricingType == "Elite" ? "vd-header-elite" : "vd-header-premium")">
                <div class="vd-header-left">
                    <span class="vd-badge">@_selectedProduct.PricingType</span>
                    <span class="vd-code">#@_selectedProduct.ProductId</span>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               OnClick="@(() => _viewDialogOpen = false)"
                               Color="Color.Inherit" Size="Size.Small" />
            </div>

            <!-- صورة المنتج -->
            <div class="vd-image-wrap">
                <img src="/api/product-images/@_selectedProduct.ProductId"
                     alt="@_selectedProduct.ProductName"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="vd-img-placeholder" style="display:none">
                    <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Style="font-size:3rem;opacity:.3" />
                    <span>لا توجد صورة</span>
                </div>
            </div>

            <!-- اسم المنتج والحالة -->
            <div class="vd-title-row">
                <div>
                    <h2 class="vd-product-name">@_selectedProduct.ProductName</h2>
                    @if (!string.IsNullOrWhiteSpace(_selectedProduct.CustomerName))
                    {
                        <div class="vd-customer">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                            <span>@_selectedProduct.CustomerName</span>
                        </div>
                    }
                </div>
                <MudChip T="string"
                         Color="@GetStatusColor(_selectedProduct.PricingStatusId)"
                         Size="Size.Small" Variant="Variant.Filled">
                    @GetStatusText(_selectedProduct.PricingStatusId)
                </MudChip>
            </div>

            <!-- الأسعار -->
            @if (_showSalePrice)
            {
                <div class="vd-prices">
                    <div class="vd-price-card vd-price-premium">
                        <span class="vd-price-label">سعر البيع Premium</span>
                        <span class="vd-price-value premium-val">
                            @if (_selectedProduct.SuggestedSalePrice.HasValue && _selectedProduct.SuggestedSalePrice.Value > 0)
                            {
                                @_selectedProduct.SuggestedSalePrice.Value.ToString("N0")
                                <small>ج.م</small>
                            }
                            else
                            {
                                <span style="font-size:1rem;font-weight:500;color:#94a3b8">غير محدد</span>
                            }
                        </span>
                    </div>
                    <div class="vd-price-card vd-price-elite">
                        <span class="vd-price-label">✦ سعر البيع Elite</span>
                        <span class="vd-price-value elite-val">
                            @if (_selectedProduct.SuggestedSalePriceElite.HasValue && _selectedProduct.SuggestedSalePriceElite.Value > 0)
                            {
                                @_selectedProduct.SuggestedSalePriceElite.Value.ToString("N0")
                                <small>ج.م</small>
                            }
                            else
                            {
                                <span style="font-size:1rem;font-weight:500;color:#94a3b8">غير محدد</span>
                            }
                        </span>
                    </div>
                </div>
            }

            <!-- الوصف -->
            @if (!string.IsNullOrWhiteSpace(_selectedProduct.ProductDescription))
            {
                <div class="vd-desc">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                    <p>@_selectedProduct.ProductDescription</p>
                </div>
            }

            <!-- أزرار الإجراءات -->
            <div class="vd-actions">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Edit"
                           FullWidth="true"
                           OnClick="() => { Edit(_selectedProduct.ProductId); _viewDialogOpen = false; }">
                    تعديل المنتج
                </MudButton>
                @if (!string.IsNullOrWhiteSpace(_selectedProduct.PdfPath) || _selectedProduct.HasOldPdf)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.PictureAsPdf"
                               FullWidth="true"
                               OnClick="() => OpenPdf(_selectedProduct)">
                        فتح PDF
                    </MudButton>
                }
            </div>

        </MudPaper>
    </div>
}

<!-- DELETE DIALOG -->
@if (_deleteDialogOpen && _productToDelete != null)
{
    <MudOverlay ZIndex="1000" OnClick="@(() => _deleteDialogOpen = false)" />
    <div class="custom-dialog">
        <MudPaper Style="border-radius: 20px; overflow: hidden; width: 450px; max-width: 95vw;" Elevation="24">
            <div style="background: #ef4444; padding: 1.25rem; color: white; display: flex; justify-content: space-between; align-items: center;">
                <MudText Typo="Typo.h6" Style="color: white; margin:0;">تأكيد الحذف</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               OnClick="@(() => _deleteDialogOpen = false)"
                               Color="Color.Inherit" />
            </div>
            <div style="padding: 1.5rem; text-align: center;">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Style="font-size: 3rem; color: #ef4444;" />
                <p style="margin: 1rem 0; font-size: 1.1rem;">
                    هل أنت متأكد من حذف المنتج:<br />
                    <strong>@_productToDelete.ProductName</strong>؟
                </p>
                <p style="color: #718096; font-size: 0.9rem;">هذا الإجراء لا يمكن التراجع عنه.</p>

                @if (!string.IsNullOrEmpty(_deleteError))
                {
                    <MudAlert Color="Color.Error" Class="mt-3">@_deleteError</MudAlert>
                }

                <div style="display: flex; gap: 1rem; margin-top: 1.5rem; justify-content: center;">
                    <MudButton Variant="Variant.Outlined"
                               OnClick="@(() => _deleteDialogOpen = false)">
                        إلغاء
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="ConfirmDelete"
                               Disabled="_isDeleting">
                        @if (_isDeleting)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-2" />
                            <span>جاري الحذف...</span>
                        }
                        else
                        {
                            <span>حذف نهائي</span>
                        }
                    </MudButton>
                </div>
            </div>
        </MudPaper>
    </div>
}
<!-- ⭐ PRICING HISTORY DIALOG -->
@if (_pricingHistoryDialogOpen && _selectedProduct != null)
{
    <MudOverlay ZIndex="1000" OnClick="@(() => _pricingHistoryDialogOpen = false)" />
    <div class="custom-dialog">
        <MudPaper Style="border-radius: 20px; overflow: hidden; width: 700px; max-width: 95vw; max-height: 85vh; display: flex; flex-direction: column;" Elevation="24">
            <!-- Header -->
            <div class="dialog-gradient-header">
                <div>
                    <MudText Typo="Typo.h6" Style="color: white; margin:0;">
                        <MudIcon Icon="@Icons.Material.Filled.History" Class="me-2" />
                        سجل التسعير
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.9); margin:0;">
                        @_selectedProduct.ProductName | كود: #@_selectedProduct.ProductId
                    </MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               OnClick="@(() => _pricingHistoryDialogOpen = false)"
                               Color="Color.Inherit" />
            </div>

            <!-- Body -->
            <div style="padding: 1.5rem; overflow-y: auto; flex: 1;">
                @if (_isLoadingHistory)
                {
                    <div style="text-align: center; padding: 2rem;">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                        <p style="margin-top: 1rem; color: #718096;">جاري تحميل السجل...</p>
                    </div>
                }
                else if (!_pricingHistories.Any())
                {
                    <div style="text-align: center; padding: 3rem;">
                        <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Style="font-size: 4rem; opacity: 0.2;" />
                        <h3 style="margin: 1rem 0; color: #4a5568;">لا يوجد سجل تسعير</h3>
                        <p style="color: #718096;">لم يتم تسجيل أي تغييرات في الأسعار لهذا المنتج بعد</p>
                    </div>
                }
                else
                {
                    <div class="pricing-history-timeline">
                        @foreach (var history in _pricingHistories)
                        {
                            <div class="history-item">
                                <div class="history-dot"></div>
                                <div class="history-content">
                                    <div class="history-row">
                                        <span class="history-type-badge">@FormatPriceType(history.PriceType)</span>
                                        <div class="history-user">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                            <span>@history.ChangedBy</span>
                                        </div>
                                    </div>
                                    <div class="history-prices">
                                        <span class="old-price-val">@FormatPrice(history.OldPrice)</span>
<MudIcon Icon="@Icons.Material.Filled.ArrowLeft" Size="Size.Small" />
<span class="new-price-val">@FormatPrice(history.NewPrice)</span>
                                        <span class="price-currency-small">ج.م</span>
                                    </div>
                                    <div class="history-date">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                                        <span>@history.ChangedAt.ToString("yyyy/MM/dd HH:mm")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Footer -->
            <div style="padding: 1rem 1.5rem; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    إجمالي السجلات: <strong>@_pricingHistories.Count</strong>
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="@(() => _pricingHistoryDialogOpen = false)">
                    إغلاق
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

