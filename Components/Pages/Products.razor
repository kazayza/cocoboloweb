    // ==================== DIALOGS ====================
    private void OpenViewDialog(ProductListDto product)
    {
        _selectedProduct = product;
        _viewDialogOpen = true;
    }

    // ==================== PDF ====================
            private async Task OpenPdf(ProductListDto product)
    {
        // 1. لو فيه مسار جديد (string)
        if (!string.IsNullOrWhiteSpace(product.PdfPath))
        {
            var path = product.PdfPath.Replace("\\", "/");
            if (!path.StartsWith("http") && !path.StartsWith("/"))
                path = "/" + path;

            var fullUrl = Navigation.ToAbsoluteUri(path).ToString();
            await JS.InvokeVoidAsync("open", fullUrl, "_blank");
            return;
        }

        // 2. لو فيه ملف قديم (byte[])
        if (product.HasOldPdf)
        {
            try
            {
                // حل مشكلة الـ Threading
                using var scope = ScopeFactory.CreateScope();
                var db = scope.ServiceProvider.GetRequiredService<db24804Context>();

                var fileBytes = await db.Products
                    .Where(p => p.ProductId == product.ProductId)
                    .Select(p => p.Pdffile)
                    .FirstOrDefaultAsync();

                if (fileBytes?.Length > 0)
                {
                    var base64 = Convert.ToBase64String(fileBytes);
                    // استدعاء الدالة اللي عملناها في الـ JS
                    await JS.InvokeVoidAsync("openPdfBase64", base64);
                }
            }
            catch (Exception)
            {
                // لو حصل خطأ
            }
        }
    }

    // ==================== EXPORT ====================
    private async Task ExportToExcel()
    {
        var html = new System.Text.StringBuilder();
        html.Append("<meta charset='utf-8'>");
        html.Append("<table border='1' style='direction:rtl; font-family:Tahoma; border-collapse:collapse;'>");
        html.Append("<tr style='background:#667eea; color:white; font-weight:bold;'>");
        html.Append("<th style='padding:8px;'>كود المنتج</th>");
        html.Append("<th style='padding:8px;'>اسم المنتج</th>");
        html.Append("<th style='padding:8px;'>نوع التسعير</th>");
        html.Append("<th style='padding:8px;'>الحالة</th>");
        if (_showSalePrice) html.Append("<th style='padding:8px;'>سعر البيع</th>");
        html.Append("<th style='padding:8px;'>العميل</th>");
        html.Append("</tr>");

        foreach (var p in _filteredProducts)
        {
            html.Append("<tr>");
            html.Append($"<td style='padding:6px; text-align:center;'>{p.ProductId}</td>");
            html.Append($"<td style='padding:6px;'>{p.ProductName}</td>");
            html.Append($"<td style='padding:6px; text-align:center;'>{p.PricingType}</td>");
            html.Append($"<td style='padding:6px; text-align:center;'>{GetStatusText(p.PricingStatusId)}</td>");
            if (_showSalePrice)
                html.Append($"<td style='padding:6px; text-align:center;'>{(p.SuggestedSalePrice?.ToString("N0") ?? "0")} ج.م</td>");
            html.Append($"<td style='padding:6px;'>{p.CustomerName ?? "-"}</td>");
            html.Append("</tr>");
        }

        html.Append("</table>");

        var bytes = System.Text.Encoding.UTF8.GetBytes(html.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval",
            $"var a=document.createElement('a'); a.href='data:application/vnd.ms-excel;base64,{base64}'; a.download='المنتجات.xls'; a.click();");
    }

    // ==================== DELETE ====================
    private void AskDelete(ProductListDto product)
    {
        _deleteError = null;
        _productToDelete = product;
        _deleteDialogOpen = true;
    }

    private async Task ConfirmDelete()
    {
        if (_productToDelete == null) return;

        _isDeleting = true;
        _deleteError = null;
        StateHasChanged();

        try
        {
            var product = await Db.Products
                .Include(p => p.ProductComponents)
                .Include(p => p.ProductImages)
                .FirstOrDefaultAsync(p => p.ProductId == _productToDelete.ProductId);

            if (product == null)
            {
                _deleteError = "المنتج غير موجود!";
                return;
            }

            // حذف المكونات والصور وسجل التسعير
            if (product.ProductComponents.Any())
                Db.ProductComponents.RemoveRange(product.ProductComponents);

            if (product.ProductImages.Any())
                Db.ProductImages.RemoveRange(product.ProductImages);

            var priceHistories = await Db.PriceHistories
                .Where(ph => ph.ProductId == product.ProductId)
                .ToListAsync();

            if (priceHistories.Any())
                Db.PriceHistories.RemoveRange(priceHistories);

            Db.Products.Remove(product);
            await Db.SaveChangesAsync();

            _deleteDialogOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            _deleteError = $"خطأ أثناء الحذف: {ex.InnerException?.Message ?? ex.Message}";
        }
        finally
        {
            _isDeleting = false;
            StateHasChanged();
        }
    }
}