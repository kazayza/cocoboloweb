@code {
    // ==================== STATE ====================
    private List<ProductListDto> _allProducts = new();
    private string _viewMode = "table"; // ⭐ "table" or "grid"
    private List<ProductListDto> _filteredProducts = new();
    private List<ProductListDto> _pagedProducts = new();

    private string? _searchText;
    private int? _statusFilter = null;
    private string _activeStatFilter = "all"; // ✅ "all", "priced", "unpriced"
    private int _totalCount;
    private int _pricedCount;
    private int _noPriceCount;
    private bool _isLoading = true;
    private bool _isDeleting = false;

    // ==================== PAGINATION ====================
    private int _currentPage = 1;
    private int _pageSize = 20;
    private int _totalPages => (int)Math.Ceiling(_filteredProducts.Count / (double)_pageSize);
    private int _pageStart => _filteredProducts.Count == 0 ? 0 : ((_currentPage - 1) * _pageSize) + 1;
    private int _pageEnd => Math.Min(_currentPage * _pageSize, _filteredProducts.Count);

    // ==================== PERMISSIONS ====================
    private string? _currentRole;
    private bool _showSalePrice = true;
    private bool _canDelete = false;
    private bool _canExport = false;
    private bool _canViewPricingHistory = false;

    // ==================== DIALOGS ====================
    private bool _viewDialogOpen = false;
    private ProductListDto? _selectedProduct = null;
    private bool _deleteDialogOpen = false;
    private ProductListDto? _productToDelete = null;
    private string? _deleteError = null;
    // ⭐ Pricing History Dialog
private bool _pricingHistoryDialogOpen = false;
private List<PriceHistory> _pricingHistories = new();
private bool _isLoadingHistory = false;

    // ==================== SEARCH PROPERTY ====================
    private string? SearchText
    {
        get => _searchText;
        set
        {
            _searchText = value;
            _currentPage = 1;
            ApplyFilter();
        }
    }

    // ==================== LIFECYCLE ====================
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _currentRole = auth.User.FindFirst(ClaimTypes.Role)?.Value;

        _showSalePrice = _currentRole != "factory";
        _canDelete = _currentRole is "Admin" or "AccountManager";
        _canExport = _currentRole is "Admin" or "AccountManager";
        _canViewPricingHistory = _currentRole is "Admin" or "AccountManager";

        // ✅ تحميل الفلتر المحفوظ من sessionStorage
        await RestoreFilterState();

        await LoadData();
    }

    // ==================== DATA ====================
    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _allProducts = await ProductService.GetProductsAsync(null);
            _totalCount = _allProducts.Count;

            // ✅ إحصائيات — مسعّر = عنده Premium أو Elite
            _pricedCount = _allProducts.Count(p =>
                (p.SuggestedSalePrice.HasValue && p.SuggestedSalePrice.Value > 0) ||
                (p.SuggestedSalePriceElite.HasValue && p.SuggestedSalePriceElite.Value > 0));
            _noPriceCount = _allProducts.Count(p =>
                (!p.SuggestedSalePrice.HasValue || p.SuggestedSalePrice.Value == 0) &&
                (!p.SuggestedSalePriceElite.HasValue || p.SuggestedSalePriceElite.Value == 0));

            ApplyFilter();
        }
        catch
        {
            _allProducts = new();
            _filteredProducts = new();
            _pagedProducts = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // ==================== FILTER & PAGINATION ====================
    private void ApplyFilter()
    {
        var query = _allProducts.AsEnumerable();

        // Search filter
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            query = query.Where(p =>
                (p.ProductName != null && p.ProductName.ContainsArabic(_searchText)) ||
                (p.CustomerName != null && p.CustomerName.ContainsArabic(_searchText)) ||
                p.ProductId.ToString().Contains(_searchText));
        }

        // Status filter
        if (_statusFilter.HasValue)
        {
            query = query.Where(p => p.PricingStatusId == _statusFilter.Value);
        }

        // ✅ Stat filter (مسعّرة = Premium أو Elite / بدون سعر = مفيش الاتنين)
        if (_activeStatFilter == "priced")
        {
            query = query.Where(p =>
                (p.SuggestedSalePrice.HasValue && p.SuggestedSalePrice.Value > 0) ||
                (p.SuggestedSalePriceElite.HasValue && p.SuggestedSalePriceElite.Value > 0));
        }
        else if (_activeStatFilter == "unpriced")
        {
            query = query.Where(p =>
                (!p.SuggestedSalePrice.HasValue || p.SuggestedSalePrice.Value == 0) &&
                (!p.SuggestedSalePriceElite.HasValue || p.SuggestedSalePriceElite.Value == 0));
        }

        _filteredProducts = query.ToList();
        UpdatePage();
        StateHasChanged();

        // ✅ حفظ حالة الفلتر
        _ = SaveFilterState();
    }

    private void UpdatePage()
    {
        _pagedProducts = _filteredProducts
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
    }
    // ⭐ Pricing History
private async Task OpenPricingHistory(ProductListDto product)
{
    _selectedProduct = product;
    _pricingHistoryDialogOpen = true;
    _isLoadingHistory = true;
    _pricingHistories = new();
    StateHasChanged();

    try
    {
        _pricingHistories = await Db.PriceHistories
            .Where(ph => ph.ProductId == product.ProductId)
            .OrderByDescending(ph => ph.ChangedAt)
            .ToListAsync();
    }
    catch
    {
        _pricingHistories = new();
    }
    finally
    {
        _isLoadingHistory = false;
        StateHasChanged();
    }
}

private string FormatPriceType(string? type) => type switch
{
    "Premium_Cost" => "تكلفة Premium",
    "Premium_Sale" => "بيع Premium",
    "Elite_Cost" => "تكلفة Elite",
    "Elite_Sale" => "بيع Elite",
    "RequestChange" => "طلب تعديل",
    _ => type ?? "غير محدد"
};
private string FormatPrice(object? price)
{
    if (price == null) return "0";
    
    if (decimal.TryParse(price.ToString(), out var value))
        return value.ToString("N0");
    
    return price.ToString() ?? "0";
}

    private void OnPageChanged(int page)
    {
        _currentPage = page;
        UpdatePage();
        _ = SaveFilterState();
        StateHasChanged();
    }

    private void OnStatusFilterChanged(int? value)
    {
        _statusFilter = value;
        _currentPage = 1;
        ApplyFilter();
    }

    // ==================== HELPERS ====================
    private string GetStatusText(int? statusId) => statusId switch
    {
        1 => "مسودة",
        2 => "بانتظار التسعير",
        3 => "تم التسعير",
        4 => "طلب تعديل سعر",
        5 => "تمت الموافقة",
        6 => "مرفوض",
        7 => "طلب تعديل سعر بيع",
        8 => "طلب تعديل تكلفة",
        _ => "غير محدد"
    };

    private Color GetStatusColor(int? statusId) => statusId switch
    {
        1 => Color.Default,
        2 => Color.Warning,
        3 => Color.Success,
        4 => Color.Info,
        5 => Color.Success,
        6 => Color.Error,
        7 => Color.Info,
        8 => Color.Info,
        _ => Color.Default
    };
    // ==================== VIEW MODE ====================
private void SetViewMode(string mode)
{
    _viewMode = mode;
    _ = SaveFilterState();
    StateHasChanged();
}

    // ==================== STAT FILTER ====================
    private void FilterByStat(string filter)
    {
        // ✅ لو ضغط نفس الفلتر تاني → شيله
        if (_activeStatFilter == filter && filter != "all")
        {
            _activeStatFilter = "all";
        }
        else
        {
            _activeStatFilter = filter;
        }
        _currentPage = 1;
        ApplyFilter();
    }

    private void ClearAllFilters()
    {
        _searchText = null;
        _statusFilter = null;
        _activeStatFilter = "all";
        _currentPage = 1;
        ApplyFilter();
    }

    // ==================== PERSIST FILTER STATE ====================
    private async Task SaveFilterState()
    {
        try
        {
            var state = System.Text.Json.JsonSerializer.Serialize(new
            {
                SearchText = _searchText,
                StatusFilter = _statusFilter,
                ActiveStatFilter = _activeStatFilter,
                ViewMode = _viewMode,
                CurrentPage = _currentPage
            });
            await JS.InvokeVoidAsync("eval",
                $"sessionStorage.setItem('productsFilter', '{state.Replace("'", "\\'")}')");
        }
        catch { }
    }

    private async Task RestoreFilterState()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("eval",
                "sessionStorage.getItem('productsFilter') || ''");

            if (!string.IsNullOrWhiteSpace(json))
            {
                var doc = System.Text.Json.JsonDocument.Parse(json);
                var root = doc.RootElement;

                if (root.TryGetProperty("SearchText", out var search))
                    _searchText = search.GetString();

                if (root.TryGetProperty("StatusFilter", out var status) && status.ValueKind != System.Text.Json.JsonValueKind.Null)
                    _statusFilter = status.GetInt32();

                if (root.TryGetProperty("ActiveStatFilter", out var statFilter))
                    _activeStatFilter = statFilter.GetString() ?? "all";

                if (root.TryGetProperty("ViewMode", out var view))
                    _viewMode = view.GetString() ?? "table";

                if (root.TryGetProperty("CurrentPage", out var page))
                    _currentPage = page.GetInt32();
            }
        }
        catch { }
    }

    // ==================== NAVIGATION ====================
    
    private void AddProduct() => Navigation.NavigateTo("/products/form");
    private void Edit(int id) => Navigation.NavigateTo($"/products/form/{id}");

    // ==================== DIALOGS ====================
    private void OpenViewDialog(ProductListDto product)
    {
        _selectedProduct = product;
        _viewDialogOpen = true;
    }

    // ==================== PDF ====================
            private async Task OpenPdf(ProductListDto product)
    {
        // 1. لو فيه مسار جديد (string)
        if (!string.IsNullOrWhiteSpace(product.PdfPath))
        {
            var path = product.PdfPath.Replace("\\", "/");
            if (!path.StartsWith("http") && !path.StartsWith("/"))
                path = "/" + path;

            var fullUrl = Navigation.ToAbsoluteUri(path).ToString();
            await JS.InvokeVoidAsync("open", fullUrl, "_blank");
            return;
        }

        // 2. لو فيه ملف قديم (byte[])
        if (product.HasOldPdf)
        {
            try
            {
                // حل مشكلة الـ Threading
                using var scope = ScopeFactory.CreateScope();
                var db = scope.ServiceProvider.GetRequiredService<db24804Context>();

                var fileBytes = await db.Products
                    .Where(p => p.ProductId == product.ProductId)
                    .Select(p => p.Pdffile)
                    .FirstOrDefaultAsync();

                if (fileBytes?.Length > 0)
                {
                    var base64 = Convert.ToBase64String(fileBytes);
                    // استدعاء الدالة اللي عملناها في الـ JS
                    await JS.InvokeVoidAsync("openPdfBase64", base64);
                }
            }
            catch (Exception)
            {
                // لو حصل خطأ
            }
        }
    }

    // ==================== EXPORT ====================
    private async Task ExportToExcel()
    {
        var html = new System.Text.StringBuilder();
        html.Append("<meta charset='utf-8'>");
        html.Append("<table border='1' style='direction:rtl; font-family:Tahoma; border-collapse:collapse;'>");
        html.Append("<tr style='background:#667eea; color:white; font-weight:bold;'>");
        html.Append("<th style='padding:8px;'>كود المنتج</th>");
        html.Append("<th style='padding:8px;'>اسم المنتج</th>");
        html.Append("<th style='padding:8px;'>نوع التسعير</th>");
        html.Append("<th style='padding:8px;'>الحالة</th>");
        if (_showSalePrice)
        {
            html.Append("<th style='padding:8px;'>سعر البيع Premium</th>");
            html.Append("<th style='padding:8px;'>سعر البيع Elite</th>");
        }
        html.Append("<th style='padding:8px;'>العميل</th>");
        html.Append("</tr>");

        foreach (var p in _filteredProducts)
        {
            html.Append("<tr>");
            html.Append($"<td style='padding:6px; text-align:center;'>{p.ProductId}</td>");
            html.Append($"<td style='padding:6px;'>{p.ProductName}</td>");
            html.Append($"<td style='padding:6px; text-align:center;'>{p.PricingType}</td>");
            html.Append($"<td style='padding:6px; text-align:center;'>{GetStatusText(p.PricingStatusId)}</td>");
            if (_showSalePrice)
            {
                html.Append($"<td style='padding:6px; text-align:center;'>{(p.SuggestedSalePrice?.ToString("N0") ?? "-")} ج.م</td>");
                html.Append($"<td style='padding:6px; text-align:center;'>{(p.SuggestedSalePriceElite?.ToString("N0") ?? "-")} ج.م</td>");
            }
            html.Append($"<td style='padding:6px;'>{p.CustomerName ?? "-"}</td>");
            html.Append("</tr>");
        }

        html.Append("</table>");

        var bytes = System.Text.Encoding.UTF8.GetBytes(html.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval",
            $"var a=document.createElement('a'); a.href='data:application/vnd.ms-excel;base64,{base64}'; a.download='المنتجات.xls'; a.click();");
    }

    // ==================== DELETE ====================
    private void AskDelete(ProductListDto product)
    {
        _deleteError = null;
        _productToDelete = product;
        _deleteDialogOpen = true;
