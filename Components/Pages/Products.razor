    private async Task ConfirmDelete()
    {
        if (_productToDelete == null) return;

        _isDeleting = true;
        _deleteError = null;
        StateHasChanged();

        try
        {
            var product = await Db.Products
                .Include(p => p.ProductComponents)
                .Include(p => p.ProductImages)
                .FirstOrDefaultAsync(p => p.ProductId == _productToDelete.ProductId);

            if (product == null)
            {
                _deleteError = "المنتج غير موجود!";
                return;
            }

            // حذف المكونات والصور وسجل التسعير
            if (product.ProductComponents.Any())
                Db.ProductComponents.RemoveRange(product.ProductComponents);

            if (product.ProductImages.Any())
                Db.ProductImages.RemoveRange(product.ProductImages);

            var priceHistories = await Db.PriceHistories
                .Where(ph => ph.ProductId == product.ProductId)
                .ToListAsync();

            if (priceHistories.Any())
                Db.PriceHistories.RemoveRange(priceHistories);

            Db.Products.Remove(product);
            await Db.SaveChangesAsync();

            _deleteDialogOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            _deleteError = $"خطأ أثناء الحذف: {ex.InnerException?.Message ?? ex.Message}";
        }
        finally
        {
            _isDeleting = false;
            StateHasChanged();
        }
    }
}