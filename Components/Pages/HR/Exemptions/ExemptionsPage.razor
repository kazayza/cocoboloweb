@page "/hr/exemptions"
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.DTOs
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@attribute [Authorize]

@inject IAttendanceService AttendanceService
@inject IEmployeeService EmployeeService
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar

<PageTitle>الاستثناءات</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (!_hasViewPermission)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
                <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius:20px;">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large"
                             Style="font-size:64px; color:#EF5350;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Color="Color.Error" Class="mb-2">غير مصرح</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">
                        ليس لديك صلاحية الوصول إلى شاشة الاستثناءات
                    </MudText>
                </MudPaper>
            </MudContainer>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 hr-page-shell">
                <MudText Typo="Typo.h4" Style="font-weight:700; color:#1E293B;">الاستثناءات</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    إذن • مأمورية • مهمة رسمية • انصراف مبكر
                </MudText>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
                }

                @* ═══ KPI Cards ═══ *@
                <MudGrid Class="mb-4">
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3" Style='@GetStatusBorderStyle(null, "#3B82F6")' @onclick="() => FilterByStatus(null)">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">الإجمالي</MudText>
                            <MudText Typo="Typo.h5" Style="font-weight:700; color:#3B82F6;">@_stats.TotalCount</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3" Style='@GetStatusBorderStyle(ExemptionStatus.Pending, "#F59E0B")' @onclick='() => FilterByStatus(ExemptionStatus.Pending)'>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">قيد الاعتماد</MudText>
                            <MudText Typo="Typo.h5" Style="font-weight:700; color:#F59E0B;">@_stats.PendingCount</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3" Style='@GetStatusBorderStyle(ExemptionStatus.Approved, "#10B981")' @onclick='() => FilterByStatus(ExemptionStatus.Approved)'>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">معتمد</MudText>
                            <MudText Typo="Typo.h5" Style="font-weight:700; color:#10B981;">@_stats.ApprovedCount</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudPaper Class="pa-3" Style='@GetStatusBorderStyle(ExemptionStatus.Rejected, "#EF4444")' @onclick='() => FilterByStatus(ExemptionStatus.Rejected)'>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">مرفوض</MudText>
                            <MudText Typo="Typo.h5" Style="font-weight:700; color:#EF4444;">@_stats.RejectedCount</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @* ═══ Filter Bar ═══ *@
                <div class="sticky-filter-shell">
                <MudPaper Class="pa-3 mb-4">
                    <MudGrid>
                        <MudItem xs="12" sm="3">
                            <MudTextField T="string"
                                          Label="بحث بالاسم / القسم"
                                          @bind-Value="_filter.SearchText"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          OnKeyUp="OnSearchKey"
                                          Clearable="true" />
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudDatePicker Label="من تاريخ" @bind-Value="_filter.DateFrom" Editable="false" Clearable="true" />
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudDatePicker Label="إلى تاريخ" @bind-Value="_filter.DateTo" Editable="false" Clearable="true" />
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudSelect T="string" Label="السبب" @bind-Value="_filter.ReasonCode" Clearable="true">
                                @foreach (var rc in ExemptionReasonCodes.Suggestions)
                                {
                                    <MudSelectItem T="string" Value="@rc">@rc</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudSelect T="string" Label="القسم" @bind-Value="_filter.Department" Clearable="true">
                                @foreach (var d in _departments)
                                {
                                    <MudSelectItem T="string" Value="@d">@d</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6" sm="1">
                            <MudSelect T="bool?" Label="الخصم" @bind-Value="_filter.IsDeducted" Clearable="true">
                                <MudSelectItem T="bool?" Value="@((bool?)true)">يُخصم</MudSelectItem>
                                <MudSelectItem T="bool?" Value="@((bool?)false)">لا يُخصم</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudSelect T="string" Label="الحالة" @bind-Value="_filter.Status" Clearable="true">
                                <MudSelectItem T="string" Value="@ExemptionStatus.Pending">قيد الاعتماد</MudSelectItem>
                                <MudSelectItem T="string" Value="@ExemptionStatus.Approved">معتمد</MudSelectItem>
                                <MudSelectItem T="string" Value="@ExemptionStatus.Rejected">مرفوض</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="6" sm="2" Class="d-flex align-center">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilters" FullWidth="true" type="button">
                                <MudIcon Icon="@Icons.Material.Filled.FilterList" Class="ml-2" />
                                فلتر
                            </MudButton>
                        </MudItem>
                        <MudItem xs="6" sm="2" Class="d-flex align-center">
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearFilters" FullWidth="true" type="button">
                                <MudIcon Icon="@Icons.Material.Filled.ClearAll" Class="ml-2" />
                                مسح الفلاتر
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
                </div>

                <div class="d-flex justify-end mb-3" style="gap:8px;">
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadData" type="button">
                        تحديث
                    </MudButton>

                    @if (_hasAddPermission)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog" type="button">
                            إضافة استثناء
                        </MudButton>
                    }
                </div>

                @if (_loading && _items.Count == 0)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
                }

                @* ═══ Table ═══ *@
                <MudTable Items="@_items" Hover="true" Elevation="2" Class="mt-2" Dense="true">
                    <ToolBarContent>
                        <div class="d-flex align-center justify-space-between w-100 flex-wrap" style="gap:8px;">
                            <MudText Typo="Typo.h6" Style="font-weight:600;">قائمة الاستثناءات</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                عرض @_fromRecord - @_toRecord من @_totalCount
                            </MudText>
                        </div>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>الموظف</MudTh>
                        <MudTh>القسم</MudTh>
                        <MudTh>التاريخ</MudTh>
                        <MudTh>السبب</MudTh>
                        <MudTh>المدة</MudTh>
                        <MudTh>الخصم</MudTh>
                        <MudTh>الحالة</MudTh>
                        <MudTh>الوصف / الملاحظات</MudTh>
                        <MudTh>أنشأه</MudTh>
                        <MudTh>اعتمده</MudTh>
                        <MudTh>إجراءات</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="item">
                        <MudTd DataLabel="الموظف">
                            <MudText Typo="Typo.body2" Style="font-weight:600;">@item.EmployeeName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">كود البصمة: @item.BioEmployeeId</MudText>
                        </MudTd>
                        <MudTd DataLabel="القسم">@item.Department</MudTd>
                        <MudTd DataLabel="التاريخ">
                            <div>@item.DateDisplay</div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@item.DayName</MudText>
                        </MudTd>
                        <MudTd DataLabel="السبب">
                            <MudChip T="string" Color="@GetReasonColor(item.ReasonCode)" Size="Size.Small" Variant="Variant.Outlined">
                                @item.ReasonCode
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="المدة">
                            <MudText Typo="Typo.body2" Style="font-weight:500;">@item.DurationDisplay</MudText>
                        </MudTd>
                        <MudTd DataLabel="الخصم">
                            <MudText Typo="Typo.body2" Style="@($"color:{item.DeductionColor}; font-weight:600;")">@item.DeductionDisplay</MudText>
                        </MudTd>
                        <MudTd DataLabel="الحالة">
                            <MudChip T="string" Color="@GetMudColorForStatus(item.Status)" Size="Size.Small">
                                @item.StatusAr
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="الوصف / الملاحظات">
                            <div style="max-width:220px;">
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <MudText Typo="Typo.caption">@item.Description</MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.Notes))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Notes</MudText>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="أنشأه">
                            <MudText Typo="Typo.caption">@item.CreatedBy</MudText>
                        </MudTd>
                        <MudTd DataLabel="اعتمده">
                            <MudText Typo="Typo.caption">@(string.IsNullOrWhiteSpace(item.ApprovedBy) ? "—" : item.ApprovedBy)</MudText>
                        </MudTd>
                        <MudTd DataLabel="إجراءات">
                            <div class="d-flex" style="gap:4px;">
                                @if (item.IsPendingStatus && _canApproveReject)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success"
                                                   Size="Size.Small" @onclick='() => ApproveExemption(item.ExemptionId)'
                                                   type="button" Title="اعتماد" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error"
                                                   Size="Size.Small" @onclick='() => OpenRejectDialog(item.ExemptionId)'
                                                   type="button" Title="رفض" />
                                }

                                @if (_hasDeletePermission)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                   Size="Size.Small" @onclick='() => DeleteExemption(item.ExemptionId)'
                                                   type="button" Title="حذف" />
                                }
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4">
                            @if (_loading)
                            {
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                            }
                            else if (!string.IsNullOrWhiteSpace(_errorMessage))
                            {
                                <span style="color:#EF4444;">⚠️ @_errorMessage</span>
                            }
                            else
                            {
                                <span>لا توجد استثناءات مطابقة للفلاتر الحالية</span>
                            }
                        </MudText>
                    </NoRecordsContent>
                </MudTable>

                @if (_totalCount > 0)
                {
                    <MudPaper Class="pa-3 mt-3 d-flex align-center justify-space-between flex-wrap" Elevation="1" Style="gap:12px;">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            الصفحة @_filter.PageNumber من @_totalPages — عرض @_fromRecord إلى @_toRecord من @_totalCount
                        </MudText>

                        <div class="d-flex align-center" style="gap:8px;">
                            <MudSelect T="int" Value="@_filter.PageSize" ValueChanged="OnPageSizeChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:110px;">
                                <MudSelectItem T="int" Value="25">25</MudSelectItem>
                                <MudSelectItem T="int" Value="50">50</MudSelectItem>
                                <MudSelectItem T="int" Value="100">100</MudSelectItem>
                            </MudSelect>

                            <MudButton Variant="Variant.Outlined" Disabled="@(!_hasPreviousPage)" OnClick="PreviousPage" type="button">
                                السابق
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Disabled="@(!_hasNextPage)" OnClick="NextPage" type="button">
                                التالي
                            </MudButton>
                        </div>
                    </MudPaper>
                }
            </MudContainer>
        }
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
            <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius:20px;">
                <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Large"
                         Style="font-size:64px; color:#FF9800;" Class="mb-4" />
                <MudText Typo="Typo.h5" Color="Color.Warning" Class="mb-2">تسجيل الدخول مطلوب</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    يرجى تسجيل الدخول للوصول إلى شاشة الاستثناءات
                </MudText>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@* ═══ Create Dialog ═══ *@
<MudDialog @bind-Visible="_createDialogOpen">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">إضافة استثناء جديد</MudText>
        <MudForm @ref="_createForm">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudAutocomplete T="EmployeeSimple"
                                     Label="الموظف"
                                     @bind-Value="_newExemption.Employee"
                                     SearchFunc="@SearchEmployees"
                                     ToStringFunc="@(e => e?.Name ?? "")"
                                     Required="true"
                                     RequiredError="اختر الموظف"
                                     Clearable="true">
                        <ItemTemplate Context="emp">
                            <div style="padding:8px 12px;">
                                <strong>@emp.Name</strong>
                                <br />
                                <small style="color:#757575;">@(string.IsNullOrWhiteSpace(emp.Department) ? "بدون قسم" : emp.Department)</small>
                            </div>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="التاريخ" @bind-Value="_newExemption.Date" Editable="false" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudAutocomplete T="string"
                                     Label="السبب"
                                     Value="@_newExemption.ReasonCode"
                                     ValueChanged="OnReasonChanged"
                                     SearchFunc="@SearchReasons"
                                     Required="true"
                                     RequiredError="اكتب السبب"
                                     Clearable="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="وصف تفصيلي (اختياري)" @bind-Value="_newExemption.Description" Lines="2" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSwitch T="bool" Label="يوم كامل" @bind-Checked="_newExemption.IsFullDay" Color="Color.Primary" />
                </MudItem>
                @if (!_newExemption.IsFullDay)
                {
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="decimal?" Label="عدد الساعات" @bind-Value="_newExemption.Hours"
                                         Min="0.5m" Max="12m" Step="0.5m" Required="true" RequiredError="حدد الساعات" />
                    </MudItem>
                }
                <MudItem xs="12" sm="4">
                    <MudSelect T="bool" Label="الخصم من الراتب" @bind-Value="_newExemption.IsDeductedExplicit">
                        <MudSelectItem T="bool" Value="@true">يُخصم</MudSelectItem>
                        <MudSelectItem T="bool" Value="@false">لا يُخصم</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="ملاحظات" @bind-Value="_newExemption.Notes" Lines="2" />
                </MudItem>
            </MudGrid>
        </MudForm>

        @if (!string.IsNullOrWhiteSpace(_newExemption.ReasonCode))
        {
            <MudAlert Severity="@(_newExemption.IsDeductedExplicit ? Severity.Error : Severity.Success)" Class="mt-3">
                @if (ExemptionReasonCodes.IsErrandType(_newExemption.ReasonCode))
                {
                    <text>مأمورية / مهمة رسمية → <b>لا يُخصم</b> من الراتب (يُعامل حضور)</text>
                }
                else if (ExemptionReasonCodes.IsEarlyLeaveType(_newExemption.ReasonCode))
                {
                    <text>انصراف مبكر → <b>لا يُخصم</b> من الراتب (تسجيل فقط)</text>
                }
                else if (ExemptionReasonCodes.IsPermissionType(_newExemption.ReasonCode))
                {
                    <text>إذن شخصي → <b>@(_newExemption.IsDeductedExplicit ? "يُخصم" : "لا يُخصم")</b> من الراتب</text>
                }
                else
                {
                    <text>هذا السبب → <b>@(_newExemption.IsDeductedExplicit ? "يُخصم" : "لا يُخصم")</b> من الراتب</text>
                }
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitCreate" Disabled="@_savingCreate" type="button">
            @if (_savingCreate)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            حفظ
        </MudButton>
        <MudButton OnClick="CloseCreateDialog" type="button">إلغاء</MudButton>
    </DialogActions>
</MudDialog>

@* ═══ Reject Dialog ═══ *@
<MudDialog @bind-Visible="_rejectDialogOpen">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">رفض الاستثناء</MudText>
        <MudTextField T="string" Label="سبب الرفض (اختياري)" @bind-Value="_rejectReason" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="SubmitReject" type="button">رفض</MudButton>
        <MudButton OnClick="CloseRejectDialog" type="button">إلغاء</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<ExemptionListDto> _items = new();
    private ExemptionFilterDto _filter = new() { PageNumber = 1, PageSize = 25 };
    private ExemptionStatsDto _stats = new();
    private List<string> _departments = new();

    private bool _loading = true;
    private bool _savingCreate = false;
    private bool _hasViewPermission = false;
    private bool _hasAddPermission = false;
    private bool _hasDeletePermission = false;
    private bool _canApproveReject = false;
    private string? _errorMessage;

    private int _totalCount;
    private int _totalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)_filter.PageSize));
    private bool _hasPreviousPage => _filter.PageNumber > 1;
    private bool _hasNextPage => _filter.PageNumber < _totalPages;
    private int _fromRecord => _totalCount == 0 ? 0 : ((_filter.PageNumber - 1) * _filter.PageSize) + 1;
    private int _toRecord => Math.Min(_filter.PageNumber * _filter.PageSize, _totalCount);

    private bool _createDialogOpen = false;
    private MudForm _createForm = default!;
    private NewExemptionForm _newExemption = new();

    private bool _rejectDialogOpen = false;
    private int _rejectExemptionId = 0;
    private string _rejectReason = "";

    public class EmployeeSimple
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? Department { get; set; }
        public int? BioEmployeeId { get; set; }
    }

    public class NewExemptionForm
    {
        public EmployeeSimple? Employee { get; set; }
        public DateTime? Date { get; set; } = DateTime.Today;
        public string ReasonCode { get; set; } = "";
        public string? Description { get; set; }
        public bool IsFullDay { get; set; } = true;
        public decimal? Hours { get; set; }
        public bool IsDeductedExplicit { get; set; } = true;
        public string? Notes { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();

        if (!_hasViewPermission)
        {
            _loading = false;
            return;
        }

        await LoadReferenceDataAsync();
        await LoadData();
    }

    private async Task LoadPermissionsAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        _hasViewPermission = user.IsInRole("Admin") ||
                             user.IsInRole("AccountManager") ||
                             user.IsInRole("HrManager") ||
                             user.IsInRole("HRManager") ||
                             user.HasClaim("Permission", "frmDailyExemptions:View");

        _hasAddPermission = user.IsInRole("Admin") ||
                            user.IsInRole("AccountManager") ||
                            user.IsInRole("HrManager") ||
                            user.IsInRole("HRManager") ||
                            user.HasClaim("Permission", "frmDailyExemptions:Add");

        _hasDeletePermission = user.IsInRole("Admin") ||
                               user.IsInRole("HrManager") ||
                               user.IsInRole("HRManager") ||
                               user.HasClaim("Permission", "frmDailyExemptions:Delete");

        _canApproveReject = user.IsInRole("Admin") ||
                            user.IsInRole("AccountManager") ||
                            user.IsInRole("HrManager") ||
                            user.IsInRole("HRManager") ||
                            user.HasClaim("Permission", "frmDailyExemptions:Edit");
    }

    private async Task LoadReferenceDataAsync()
    {
        try
        {
            _departments = await EmployeeService.GetDepartmentsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"خطأ في تحميل البيانات المرجعية: {ex.Message}";
            _departments = new();
        }
    }

    private async Task LoadData()
    {
        if (!_hasViewPermission)
            return;

        _loading = true;
        _errorMessage = null;

        try
        {
            var result = await AttendanceService.GetExemptionsAsync(_filter);
            _items = result?.Items?.ToList() ?? new List<ExemptionListDto>();
            _totalCount = result?.TotalCount ?? 0;

            _stats = await AttendanceService.GetExemptionStatsAsync(_filter) ?? new ExemptionStatsDto();
        }
        catch (Exception ex)
        {
            _items = new();
            _totalCount = 0;
            _stats = new ExemptionStatsDto();
            _errorMessage = $"خطأ في تحميل البيانات: {ex.Message}";
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ApplyFilters()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task ClearFilters()
    {
        var pageSize = _filter.PageSize;
        _filter = new ExemptionFilterDto
        {
            PageNumber = 1,
            PageSize = pageSize
        };
        await LoadData();
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ApplyFilters();
    }

    private async Task FilterByStatus(string? status)
    {
        _filter.Status = status;
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task PreviousPage()
    {
        if (!_hasPreviousPage) return;
        _filter.PageNumber--;
        await LoadData();
    }

    private async Task NextPage()
    {
        if (!_hasNextPage) return;
        _filter.PageNumber++;
        await LoadData();
    }

    private async Task OnPageSizeChanged(int pageSize)
    {
        _filter.PageSize = pageSize;
        _filter.PageNumber = 1;
        await LoadData();
    }

    private void OpenCreateDialog()
    {
        if (!_hasAddPermission)
        {
            Snackbar.Add("ليس لديك صلاحية إضافة استثناء جديد", Severity.Error);
            return;
        }

        _newExemption = new NewExemptionForm
        {
            Date = DateTime.Today,
            IsFullDay = true,
            IsDeductedExplicit = true
        };
        _createDialogOpen = true;
    }

    private void CloseCreateDialog() => _createDialogOpen = false;

    private Task OnReasonChanged(string? reasonCode)
    {
        _newExemption.ReasonCode = reasonCode?.Trim() ?? "";
        _newExemption.IsDeductedExplicit = ExemptionReasonCodes.DefaultIsDeducted(_newExemption.ReasonCode);
        return Task.CompletedTask;
    }

    private async Task SubmitCreate()
    {
        if (!_hasAddPermission)
        {
            Snackbar.Add("ليس لديك صلاحية إضافة استثناء جديد", Severity.Error);
            return;
        }

        await _createForm.ValidateAsync();
        if (!_createForm.IsValid) return;

        if (_newExemption.Employee == null || _newExemption.Date == null || string.IsNullOrWhiteSpace(_newExemption.ReasonCode))
        {
            Snackbar.Add("يرجى ملء جميع الحقول المطلوبة", Severity.Warning);
            return;
        }

        if (!_newExemption.IsFullDay && (!_newExemption.Hours.HasValue || _newExemption.Hours.Value <= 0))
        {
            Snackbar.Add("يرجى تحديد عدد الساعات للاستثناء الجزئي", Severity.Warning);
            return;
        }

        _savingCreate = true;
        try
        {
            var dto = new ExemptionCreateDto
            {
                EmployeeId = _newExemption.Employee.Id,
                ExemptionDate = _newExemption.Date.Value,
                ReasonCode = _newExemption.ReasonCode.Trim(),
                Description = _newExemption.Description,
                IsFullDay = _newExemption.IsFullDay,
                Hours = _newExemption.IsFullDay ? null : _newExemption.Hours,
                IsDeducted = _newExemption.IsDeductedExplicit,
                Notes = _newExemption.Notes
            };

            var authState = await AuthState.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "System";

            var (success, message) = await AttendanceService.CreateExemptionAsync(dto, userName);
            Snackbar.Add(message, success ? Severity.Success : Severity.Error);

            if (success)
            {
                _createDialogOpen = false;
                _filter.PageNumber = 1;
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingCreate = false;
        }
    }

    private async Task<IEnumerable<EmployeeSimple>> SearchEmployees(string search, CancellationToken ct)
    {
        if (!_hasAddPermission)
            return Enumerable.Empty<EmployeeSimple>();

        var employees = await EmployeeService.SearchEmployeesAsync(search ?? string.Empty, 20);
        return employees.Select(e => new EmployeeSimple
        {
            Id = e.EmployeeId,
            Name = e.FullName,
            Department = e.Department,
            BioEmployeeId = e.BioEmployeeId
        });
    }

    private Task<IEnumerable<string>> SearchReasons(string search, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(search))
            return Task.FromResult(ExemptionReasonCodes.Suggestions.AsEnumerable());

        return Task.FromResult(ExemptionReasonCodes.Suggestions
            .Where(s => s.Contains(search, StringComparison.OrdinalIgnoreCase))
            .AsEnumerable());
    }

    private async Task ApproveExemption(int id)
    {
        if (!_canApproveReject)
        {
            Snackbar.Add("ليس لديك صلاحية اعتماد الاستثناءات", Severity.Error);
            return;
        }

        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "System";

            var (success, message) = await AttendanceService.ApproveExemptionAsync(id, userName);
            Snackbar.Add(message, success ? Severity.Success : Severity.Error);
            if (success) await LoadData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
    }

    private void OpenRejectDialog(int exemptionId)
    {
        if (!_canApproveReject)
        {
            Snackbar.Add("ليس لديك صلاحية رفض الاستثناءات", Severity.Error);
            return;
        }

        _rejectExemptionId = exemptionId;
        _rejectReason = string.Empty;
        _rejectDialogOpen = true;
    }

    private void CloseRejectDialog() => _rejectDialogOpen = false;

    private async Task SubmitReject()
    {
        if (!_canApproveReject)
        {
            Snackbar.Add("ليس لديك صلاحية رفض الاستثناءات", Severity.Error);
            return;
        }

        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "System";

            var (success, message) = await AttendanceService.RejectExemptionAsync(_rejectExemptionId, userName, _rejectReason);
            Snackbar.Add(message, success ? Severity.Success : Severity.Error);
            if (success)
            {
                _rejectDialogOpen = false;
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteExemption(int id)
    {
        if (!_hasDeletePermission)
        {
            Snackbar.Add("ليس لديك صلاحية حذف الاستثناءات", Severity.Error);
            return;
        }

        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "System";

            var (success, message) = await AttendanceService.DeleteExemptionAsync(id, userName);
            Snackbar.Add(message, success ? Severity.Success : Severity.Error);
            if (success)
            {
                if (_items.Count == 1 && _filter.PageNumber > 1)
                    _filter.PageNumber--;

                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
    }

    private Color GetReasonColor(string? code)
    {
        if (ExemptionReasonCodes.IsErrandType(code)) return Color.Info;
        if (ExemptionReasonCodes.IsEarlyLeaveType(code)) return Color.Warning;
        if (ExemptionReasonCodes.IsPermissionType(code)) return Color.Primary;
        return Color.Default;
    }

    private Color GetMudColorForStatus(string? status) => status switch
    {
        var s when s == ExemptionStatus.Pending => Color.Warning,
        var s when s == ExemptionStatus.Approved => Color.Success,
        var s when s == ExemptionStatus.Rejected => Color.Error,
        _ => Color.Default
    };

    private string GetStatusBorderStyle(string? status, string activeColor)
    {
        var borderColor = _filter.Status == status ? activeColor : "#94A3B8";
        return $"cursor:pointer; border-right:4px solid {borderColor};";
    }
}
