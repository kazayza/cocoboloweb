@page "/hr/reports/payroll"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using ApexCharts
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Radzen
@using Radzen.Blazor

@* ══ Aliases ══ *@
@using MudVariant    = MudBlazor.Variant
@using MudColor      = MudBlazor.Color
@using MudSize       = MudBlazor.Size
@using MudAlign      = MudBlazor.Align
@using ApexTooltip   = ApexCharts.Tooltip
@using ApexLegendPos = ApexCharts.LegendPosition

@inject IPayrollService PayrollService
@inject IEmployeeService EmployeeService
@inject IJSRuntime      JS
@inject ISnackbar       Snackbar

<PageTitle>كشف الرواتب الشهري</PageTitle>

<style>
    /* ═══════════════════════════════════════════
       PAYROLL REPORT 2026 — Premium Design
       ═══════════════════════════════════════════ */

    .pr-root {
        padding-top: max(1rem, env(safe-area-inset-top));
        padding-bottom: max(2rem, env(safe-area-inset-bottom));
        padding-left: max(1rem, env(safe-area-inset-left));
        padding-right: max(1rem, env(safe-area-inset-right));
        min-height: 100svh;
        background: #F8FAFC;
    }

    /* ─── Premium Header ─── */
    .pr-hero {
        border-radius: 28px !important;
        overflow: hidden;
        border: none !important;
        position: relative;
    }

    .pr-hero-bg {
        position: relative;
        background: linear-gradient(140deg, #0C1222 0%, #162033 35%, #1E3A5F 70%, #1A4B7A 100%);
        padding: 32px 28px;
    }

    .pr-hero-bg::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 15% 85%, rgba(212,175,55,0.18) 0%, transparent 40%),
            radial-gradient(circle at 85% 15%, rgba(59,130,246,0.12) 0%, transparent 40%),
            radial-gradient(circle at 50% 50%, rgba(255,255,255,0.02) 0%, transparent 60%);
        pointer-events: none;
    }

    .pr-hero-bg::after {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: rgba(212,175,55,0.04);
        filter: blur(60px);
        pointer-events: none;
    }

    .pr-hero-content {
        position: relative;
        z-index: 3;
    }

    .pr-hero-icon-wrap {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: rgba(212,175,55,0.12);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212,175,55,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .pr-hero-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: white;
        letter-spacing: -0.8px;
        line-height: 1.2;
    }

    .pr-hero-sub {
        color: rgba(255,255,255,0.45);
        font-size: 0.82rem;
        margin-top: 4px;
    }

    .pr-hero-btn {
        border-radius: 12px !important;
        font-weight: 600 !important;
        letter-spacing: 0.2px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.1) !important;
        transition: all 0.3s ease !important;
    }

    .pr-hero-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    }

    .pr-hero-btn-green {
        background: rgba(16,185,129,0.85) !important;
        color: white !important;
    }

    .pr-hero-btn-blue {
        background: rgba(59,130,246,0.85) !important;
        color: white !important;
    }

    /* ─── Filter Panel ─── */
    .pr-filter {
        border-radius: 20px !important;
        border: 1px solid #E2E8F0 !important;
        background: white !important;
        transition: all 0.3s ease;
    }

    .pr-filter:hover {
        box-shadow: 0 2px 16px rgba(0,0,0,0.03);
    }

    /* ─── Stat Pill Cards ─── */
    .stat-pill {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 14px;
        border: 1px solid #F1F5F9;
        background: white;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        cursor: default;
    }

    .stat-pill::before {
        content: '';
        position: absolute;
        right: 0;
        top: 0;
        width: 3px;
        height: 100%;
        border-radius: 0 6px 6px 0;
        transition: width 0.3s ease;
    }

    .stat-pill:hover {
        border-color: #E2E8F0;
        box-shadow: 0 4px 16px rgba(0,0,0,0.04);
        transform: translateY(-1px);
    }

    .stat-pill:hover::before {
        width: 4px;
    }

    .stat-pill-icon {
        width: 38px;
        height: 38px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-pill-val {
        font-size: 1.15rem;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.3px;
    }

    .stat-pill-lbl {
        font-size: 0.68rem;
        color: #94A3B8;
        font-weight: 500;
    }

    /* ─── Modern Card ─── */
    .mc {
        border: 1px solid #E2E8F0 !important;
        border-radius: 20px !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: white !important;
    }

    .mc:hover {
        border-color: #CBD5E1 !important;
        box-shadow: 0 8px 32px rgba(0,0,0,0.04) !important;
    }

    .mc-head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
    }

    .mc-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .mc-title {
        font-weight: 700;
        font-size: 0.92rem;
        color: #1E293B;
    }

    /* ─── RadzenDataGrid Premium ─── */
    .rz-pr-grid {
        border-radius: 0 0 16px 16px !important;
        overflow: hidden;
    }

    .rz-pr-grid .rz-datatable-thead > tr > th {
        background: #0F172A !important;
        color: rgba(255,255,255,0.9) !important;
        font-weight: 600 !important;
        font-size: 0.75rem !important;
        padding: 12px 14px !important;
        white-space: nowrap;
        border: none !important;
        text-transform: none;
        letter-spacing: 0.2px;
    }

    .rz-pr-grid .rz-datatable-thead > tr > th:first-child {
        border-radius: 0 !important;
    }

    .rz-pr-grid .rz-datatable-thead > tr > th .rz-sortable-column-icon {
        color: rgba(255,255,255,0.4) !important;
    }

    .rz-pr-grid .rz-datatable-thead > tr > th .rz-cell-filter {
        color: rgba(255,255,255,0.5) !important;
    }

    .rz-pr-grid .rz-datatable-tbody > tr > td {
        padding: 10px 14px !important;
        font-size: 0.8rem !important;
        border-bottom: 1px solid #F1F5F9 !important;
        color: #334155;
    }

    .rz-pr-grid .rz-datatable-tbody > tr:hover > td {
        background: #F0F9FF !important;
    }

    .rz-pr-grid .rz-datatable-tbody > tr:nth-child(even) > td {
        background: #FAFBFC;
    }

    .rz-pr-grid .rz-datatable-tbody > tr:nth-child(even):hover > td {
        background: #F0F9FF !important;
    }

    .rz-pr-grid .rz-datatable-tfoot > tr > td {
        background: #F1F5F9 !important;
        font-weight: 800 !important;
        border-top: 2px solid #CBD5E1 !important;
        padding: 12px 14px !important;
        font-size: 0.82rem !important;
    }

    .rz-pr-grid .rz-pager {
        border-top: 1px solid #E2E8F0;
        padding: 10px 16px;
        background: #FAFBFC;
    }

    /* ─── Value Styles ─── */
    .v-neg { color: #DC2626; font-weight: 600; }
    .v-gold { color: #B8860B; font-weight: 800; }
    .v-green { color: #059669; font-weight: 700; }
    .v-muted { color: #94A3B8; }

    .emp-name { font-weight: 700; font-size: 0.82rem; color: #1E293B; }
    .emp-title { font-size: 0.68rem; color: #94A3B8; margin-top: 1px; }

    .dept-tag {
        background: #F1F5F9;
        padding: 3px 10px;
        border-radius: 8px;
        font-size: 0.72rem;
        font-weight: 500;
        color: #475569;
    }

    .absence-tag {
        background: #FEF2F2;
        color: #DC2626;
        padding: 2px 10px;
        border-radius: 8px;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .status-pill {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    .status-paid {
        background: linear-gradient(135deg, #F0FDF4, #DCFCE7);
        color: #15803D;
    }

    .status-unpaid {
        background: linear-gradient(135deg, #FFFBEB, #FEF3C7);
        color: #B45309;
    }

    .status-review {
        background: linear-gradient(135deg, #FFF7ED, #FED7AA);
        color: #C2410C;
    }

    .status-approved {
        background: linear-gradient(135deg, #EFF6FF, #DBEAFE);
        color: #1D4ED8;
    }

    .status-rejected {
        background: linear-gradient(135deg, #FEF2F2, #FECACA);
        color: #B91C1C;
    }

    .status-cancelled {
        background: linear-gradient(135deg, #F8FAFC, #E2E8F0);
        color: #475569;
    }

    .grid-header-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1px solid #F1F5F9;
        background: white;
        border-radius: 20px 20px 0 0;
    }

    /* ─── ApexCharts RTL ─── */
    .apexcharts-canvas text,
    .apexcharts-legend-text { font-family: inherit !important; }
    .apexcharts-tooltip {
        direction: rtl !important;
        text-align: right !important;
        border-radius: 12px !important;
        box-shadow: 0 8px 32px rgba(0,0,0,0.12) !important;
    }

    /* ─── Empty State ─── */
    .empty-state-card {
        border-radius: 24px !important;
        border: 2px dashed #E2E8F0 !important;
        background: #FAFBFC !important;
    }

    /* ─── Print ─── */
    .print-only { display: none; }

    @@media print {
        .no-print { display: none !important; }
        .print-only { display: block !important; }
        .rz-pr-grid .rz-datatable-thead > tr > th {
            background: #1E293B !important;
            color: white !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .rz-pr-grid .rz-pager { display: none !important; }
        .stat-pill, .mc { break-inside: avoid; }
        .print-header {
            text-align: center;
            margin-bottom: 24px;
            border-bottom: 3px solid #0F172A;
            padding-bottom: 12px;
        }
        .print-header h2 { margin: 0; font-size: 1.5rem; font-weight: 800; }
        .print-header p { margin: 6px 0 0; color: #64748B; font-size: 0.85rem; }
        .print-footer {
            text-align: center;
            margin-top: 32px;
            padding-top: 12px;
            border-top: 1px solid #CBD5E1;
            font-size: 0.75rem;
            color: #94A3B8;
        }
    }

    /* ─── Responsive ─── */
    @@media (max-width: 768px) {
        .pr-hero-bg { padding: 24px 20px; }
        .pr-hero-title { font-size: 1.2rem; }
        .pr-hero-icon-wrap { width: 44px; height: 44px; border-radius: 12px; }
        .mc { border-radius: 16px !important; }
        .stat-pill { padding: 8px 12px; border-radius: 12px; }
        .stat-pill-icon { width: 32px; height: 32px; border-radius: 8px; }
        .stat-pill-val { font-size: 0.95rem; }
        .grid-header-bar { padding: 12px 16px; border-radius: 16px 16px 0 0; }
    }

    @@media (max-width: 380px) {
        .stat-pill-val { font-size: 0.85rem; }
        .stat-pill-lbl { font-size: 0.6rem; }
        .pr-hero-title { font-size: 1.05rem; }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 pr-root">

    @* ══════════════════════════════════════════════════════════
       PREMIUM HEADER
       ══════════════════════════════════════════════════════════ *@
    <MudPaper Class="mb-5 pr-hero no-print" Elevation="0">
        <div class="pr-hero-bg">
            <div class="pr-hero-content">
                <div class="d-flex align-center justify-space-between flex-wrap gap-4">
                    <div class="d-flex align-center gap-3">
                        <div class="pr-hero-icon-wrap">
                            <MudIcon Icon="@Icons.Material.Rounded.Payments"
                                     Size="@MudSize.Large" Style="color:#D4AF37;" />
                        </div>
                        <div>
                            <div class="pr-hero-title">تقرير الرواتب الذكي</div>
                            <div class="pr-hero-sub">
                                @HeroSubtitle
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <MudButton Class="pr-hero-btn pr-hero-btn-green"
                                   StartIcon="@Icons.Material.Rounded.FileDownload"
                                   Size="@MudSize.Small"
                                   OnClick="ExportExcelAsync"
                                   Disabled="@(!_data.Any() || _exporting)">
                            @(_exporting ? "جاري التصدير..." : "تصدير Excel")
                        </MudButton>
                        <MudButton Class="pr-hero-btn pr-hero-btn-blue"
                                   StartIcon="@Icons.Material.Rounded.Print"
                                   Size="@MudSize.Small"
                                   OnClick="@(() => JS.InvokeVoidAsync("printPage"))"
                                   Disabled="@(!_data.Any())">
                            طباعة التقرير
                        </MudButton>
                    </div>
                </div>
            </div>
        </div>
    </MudPaper>

    @* ══════════════════════════════════════════════════════════
       FILTER PANEL
       ══════════════════════════════════════════════════════════ *@
    <MudPaper Class="pa-5 mb-5 pr-filter no-print" Elevation="0">
        <div class="d-flex align-center justify-space-between flex-wrap gap-3 mb-4">
            <div>
                <MudText Typo="Typo.h6" Style="font-weight:800;color:#1E293B;">نمط التقرير</MudText>
                <MudText Typo="Typo.caption" Style="color:#94A3B8;">اختر هل تريد كشف شهر واحد أو فترة أو موظف معين عبر فترة</MudText>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <MudChip T="string" Variant="@(_reportMode == "single" ? MudVariant.Filled : MudVariant.Outlined)" Color="MudColor.Primary" OnClick='() => SetReportMode("single")'>شهر واحد</MudChip>
                <MudChip T="string" Variant="@(_reportMode == "range" ? MudVariant.Filled : MudVariant.Outlined)" Color="MudColor.Info" OnClick='() => SetReportMode("range")'>فترة</MudChip>
                <MudChip T="string" Variant="@(_reportMode == "employee" ? MudVariant.Filled : MudVariant.Outlined)" Color="MudColor.Secondary" OnClick='() => SetReportMode("employee")'>موظف</MudChip>
            </div>
        </div>

        <MudGrid Spacing="3">
            @if (_reportMode == "single")
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField T="string"
                                  @bind-Value="_month"
                                  Label="الشهر"
                                  InputType="InputType.Month"
                                  Variant="@MudVariant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                                  FullWidth />
                </MudItem>
            }
            else
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField T="string"
                                  @bind-Value="_monthFrom"
                                  Label="من شهر"
                                  InputType="InputType.Month"
                                  Variant="@MudVariant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.DateRange"
                                  FullWidth />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField T="string"
                                  @bind-Value="_monthTo"
                                  Label="إلى شهر"
                                  InputType="InputType.Month"
                                  Variant="@MudVariant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Event"
                                  FullWidth />
                </MudItem>
            }

            @if (_reportMode == "employee")
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="EmployeeListDto"
                                     Label="الموظف"
                                     Value="_selectedEmployee"
                                     ValueChanged="OnEmployeeChanged"
                                     SearchFunc="SearchEmployees"
                                     ToStringFunc="@(e => e?.FullName ?? string.Empty)"
                                     Variant="@MudVariant.Outlined"
                                     Margin="Margin.Dense"
                                     Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     FullWidth>
                        <ItemTemplate Context="emp">
                            <div style="padding:8px 12px;">
                                <strong>@emp.FullName</strong><br />
                                <small style="color:#94A3B8;">@(emp.Department ?? "بدون قسم")</small>
                            </div>
                        </ItemTemplate>
                    </MudAutocomplete>
                </MudItem>
            }
            else
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField T="string"
                                  @bind-Value="_departmentFilter"
                                  Label="القسم"
                                  Variant="@MudVariant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Apartment"
                                  FullWidth />
                </MudItem>
            }

            <MudItem xs="12" sm="6" md="3">
                <MudTextField T="string"
                              @bind-Value="_jobTitleFilter"
                              Label="الوظيفة"
                              Variant="@MudVariant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Badge"
                              Placeholder="مثال: محاسب / مشرف / بائع"
                              FullWidth />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudTextField T="string"
                              @bind-Value="_searchText"
                              Label="بحث نصي"
                              Variant="@MudVariant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Placeholder="اسم الموظف / القسم / الوظيفة / الشهر"
                              FullWidth />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string"
                           @bind-Value="_statusFilter"
                           Label="حالة الدفع"
                           Variant="@MudVariant.Outlined"
                           Margin="Margin.Dense"
                           Clearable FullWidth
                           AdornmentIcon="@Icons.Material.Filled.FactCheck"
                           Adornment="Adornment.Start">
                    <MudSelectItem T="string" Value="@PayrollPaymentStatuses.PendingReview">قيد المراجعة</MudSelectItem>
                    <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Approved">معتمد</MudSelectItem>
                    <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Paid">مدفوع</MudSelectItem>
                    <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Unpaid">غير مدفوع</MudSelectItem>
                    <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Rejected">مرفوض</MudSelectItem>
                    <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Cancelled">ملغي</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string"
                           @bind-Value="_attendanceSourceFilter"
                           Label="مصدر الحضور"
                           Variant="@MudVariant.Outlined"
                           Margin="Margin.Dense"
                           Clearable FullWidth>
                    <MudSelectItem T="string" Value="@("Manual")">يدوي</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Biometric")">بصمة</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="bool?"
                           @bind-Value="_hasLoansFilter"
                           Label="وجود سلفة"
                           Variant="@MudVariant.Outlined"
                           Margin="Margin.Dense"
                           Clearable FullWidth>
                    <MudSelectItem T="bool?" Value="@((bool?)true)">عليه سلفة</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">بدون سلفة</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="bool?"
                           @bind-Value="_hasAbsenceFilter"
                           Label="وجود غياب"
                           Variant="@MudVariant.Outlined"
                           Margin="Margin.Dense"
                           Clearable FullWidth>
                    <MudSelectItem T="bool?" Value="@((bool?)true)">عليه غياب</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">بدون غياب</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="bool?"
                           @bind-Value="_hasLateFilter"
                           Label="وجود تأخير"
                           Variant="@MudVariant.Outlined"
                           Margin="Margin.Dense"
                           Clearable FullWidth>
                    <MudSelectItem T="bool?" Value="@((bool?)true)">عليه تأخير</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@((bool?)false)">بدون تأخير</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudNumericField T="int?" @bind-Value="_minLateMinutes" Label="أقل دقائق تأخير" Variant="@MudVariant.Outlined" Margin="Margin.Dense" FullWidth />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudNumericField T="int?" @bind-Value="_maxLateMinutes" Label="أعلى دقائق تأخير" Variant="@MudVariant.Outlined" Margin="Margin.Dense" FullWidth />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudNumericField T="decimal?" @bind-Value="_minNetSalary" Label="أقل صافي" Variant="@MudVariant.Outlined" Margin="Margin.Dense" FullWidth />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField T="decimal?" @bind-Value="_maxNetSalary" Label="أعلى صافي" Variant="@MudVariant.Outlined" Margin="Margin.Dense" FullWidth />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField T="decimal?" @bind-Value="_minDeductions" Label="أقل خصومات" Variant="@MudVariant.Outlined" Margin="Margin.Dense" FullWidth />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudNumericField T="decimal?" @bind-Value="_maxDeductions" Label="أعلى خصومات" Variant="@MudVariant.Outlined" Margin="Margin.Dense" FullWidth />
            </MudItem>

            <MudItem xs="12" md="6" Class="d-flex align-end gap-2">
                <MudButton Variant="@MudVariant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.Search"
                           OnClick="LoadAsync"
                           Disabled="@_loading"
                           FullWidth
                           Style="height:40px;border-radius:12px;font-weight:700;">
                    @(_loading ? "جاري التحميل..." : "عرض التقرير")
                </MudButton>
                <MudButton Variant="@MudVariant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFilters"
                           Style="height:40px;border-radius:12px;font-weight:700;">
                    إعادة ضبط
                </MudButton>
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />

        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudCheckBox T="bool" @bind-Value="_enableComparison" Label="تفعيل المقارنة" Color="@MudColor.Info" />
            </MudItem>

            @if (_enableComparison)
            {
                @if (_reportMode == "single")
                {
                    <MudItem xs="12" sm="6" md="3">
                        <MudTextField T="string"
                                      @bind-Value="_compareMonth"
                                      Label="الشهر المقارن"
                                      InputType="InputType.Month"
                                      Variant="@MudVariant.Outlined"
                                      Margin="Margin.Dense"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.CompareArrows"
                                      FullWidth />
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12" sm="6" md="3">
                        <MudTextField T="string"
                                      @bind-Value="_compareMonthFrom"
                                      Label="من شهر (مقارنة)"
                                      InputType="InputType.Month"
                                      Variant="@MudVariant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudTextField T="string"
                                      @bind-Value="_compareMonthTo"
                                      Label="إلى شهر (مقارنة)"
                                      InputType="InputType.Month"
                                      Variant="@MudVariant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth />
                    </MudItem>
                }
            }
        </MudGrid>
    </MudPaper>

    @if (_searched && HasActiveFilters)
    {
        <MudPaper Class="pa-3 mb-4 no-print" Elevation="0" Style="border:1px dashed #CBD5E1;border-radius:16px;background:#F8FAFC;">
            <div class="d-flex align-center gap-2 flex-wrap">
                <MudText Typo="Typo.caption" Style="font-weight:700;color:#475569;">الفلاتر النشطة:</MudText>
                @foreach (var tag in ActiveFilterChips)
                {
                    <MudChip T="string" Size="@MudSize.Small" Variant="@MudVariant.Outlined" Color="@MudColor.Default">@tag</MudChip>
                }
            </div>
        </MudPaper>
    }

    @* ══════════════════════════════════════════════════════════
       LOADING SKELETON
       ══════════════════════════════════════════════════════════ *@
    @if (_loading)
    {
        <MudGrid Spacing="2" Class="mb-4">
            @for (int i = 0; i < 5; i++)
            {
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-3" Elevation="0" Style="border:1px solid #F1F5F9;border-radius:14px;">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="38px" Height="38px" Class="mb-2" />
                        <MudSkeleton Width="55%" Height="18px" Class="mb-1" />
                        <MudSkeleton Width="35%" Height="12px" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-5 mc" Elevation="0">
                    <MudSkeleton Width="30%" Height="20px" Class="mb-4" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="260px" Class="rounded-lg" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mc" Elevation="0">
                    <MudSkeleton Width="40%" Height="20px" Class="mb-4" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="260px" Class="rounded-lg" />
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudPaper Class="pa-5 mc" Elevation="0">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="350px" Class="rounded-lg" />
        </MudPaper>
    }
    else if (_data.Any())
    {
        @* ══════════════════════════════════════════════════════════
           STAT PILLS
           ══════════════════════════════════════════════════════════ *@
        <MudGrid Spacing="2" Class="mb-5 no-print">
            @foreach (var s in _stats)
            {
                <MudItem xs="6" sm="4" md="2">
                    <div class="stat-pill">
                        <div style="@($"position:absolute;right:0;top:0;width:3px;height:100%;background:{s.Accent};border-radius:0 6px 6px 0;")"></div>
                        <div class="stat-pill-icon" style="background:@s.IconBg;">
                            <MudIcon Icon="@s.Icon" Style="@($"color:{s.Accent};font-size:18px;")" />
                        </div>
                        <div>
                            <div class="stat-pill-val" style="color:@s.Accent;">@s.Value</div>
                            <div class="stat-pill-lbl">@s.Label</div>
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>

        @* ══════════════════════════════════════════════════════════
           CHARTS
           ══════════════════════════════════════════════════════════ *@
        @if (_comparisonEnabledAndLoaded)
        {
            <MudPaper Class="pa-4 mb-4 no-print" Elevation="0" Style="border:1px solid #E2E8F0;border-radius:18px;background:white;">
                <div class="d-flex align-center gap-2 mb-3">
                    <div class="mc-icon" style="background:#E0F2FE;">
                        <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Style="color:#0284C7;font-size:17px;" />
                    </div>
                    <span class="mc-title">مقارنة الفترة الحالية بالفترة المقارنة</span>
                </div>
                <MudGrid Spacing="2">
                    @foreach (var s in _comparisonStats)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3" Elevation="0" Style="border:1px solid #F1F5F9;border-radius:14px;">
                                <MudText Typo="Typo.caption" Style="color:#94A3B8;">@s.Label</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight:700;color:#1E293B;">الحالي: @s.CurrentValue</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight:700;color:#475569;">المقارن: @s.CompareValue</MudText>
                                <MudText Typo="Typo.caption" Style="@($"color:{s.DeltaColor};font-weight:700;")">الفرق: @s.DeltaValue</MudText>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        }

        <MudGrid Spacing="4" Class="mb-5 no-print">
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-5 mc" Elevation="0">
                    <div class="mc-head">
                        <div class="mc-icon" style="background:#DBEAFE;">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="color:#3B82F6;font-size:17px;" />
                        </div>
                        <span class="mc-title">@PrimaryChartTitle</span>
                    </div>
                    <ApexChart TItem="DeptChartItem" Options="_barOpts" Height="280">
                        <ApexPointSeries TItem="DeptChartItem" Items="_deptChartData"
                                         Name="صافي الرواتب" SeriesType="SeriesType.Bar"
                                         XValue="e => e.Department" YValue="e => e.TotalNet" />
                    </ApexChart>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mc" Elevation="0" Style="height:100%;">
                    <div class="mc-head">
                        <div class="mc-icon" style="background:#FEE2E2;">
                            <MudIcon Icon="@Icons.Material.Filled.DonutLarge" Style="color:#EF4444;font-size:17px;" />
                        </div>
                        <span class="mc-title">تحليل الخصومات</span>
                    </div>
                    <ApexChart TItem="DeductionChartItem" Options="_donutOpts" Height="280">
                        <ApexPointSeries TItem="DeductionChartItem" Items="_deductionChartData"
                                         Name="الخصومات" SeriesType="SeriesType.Donut"
                                         XValue="e => e.Type" YValue="e => e.Amount" />
                    </ApexChart>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ══════════════════════════════════════════════════════════
           PRINT HEADER
           ══════════════════════════════════════════════════════════ *@
        <div class="print-only print-header">
            <h2>كشف الرواتب</h2>
            <p>الفترة: @CurrentPeriodLabel | عدد السجلات: @_cachedFiltered.Count | طُبع: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</p>
        </div>

        @* ══════════════════════════════════════════════════════════
           DATA GRID
           ══════════════════════════════════════════════════════════ *@
        <MudPaper Class="mc overflow-hidden" Elevation="0" Style="border-radius:20px !important;">

            <div class="grid-header-bar no-print">
                <div class="d-flex align-center gap-2">
                    <div class="mc-icon" style="background:#FEF3C7;">
                        <MudIcon Icon="@Icons.Material.Filled.TableChart" Style="color:#D4AF37;font-size:17px;" />
                    </div>
                    <span class="mc-title">بيانات الرواتب التفصيلية</span>
                </div>
                <MudChip T="string" Size="@MudSize.Small"
                         Variant="@MudVariant.Text" Color="@MudColor.Primary"
                         Style="font-weight:700;">
                    @_cachedFiltered.Count موظف
                </MudChip>
            </div>

            <RadzenDataGrid Data="@_cachedFiltered"
                            TItem="PayrollListDto"
                            AllowSorting="true"
                            AllowFiltering="true"
                            AllowColumnResize="true"
                            AllowGrouping="true"
                            AllowPaging="true"
                            PageSize="25"
                            PagerHorizontalAlign="HorizontalAlign.Center"
                            ShowPagingSummary="true"
                            PagingSummaryFormat="عرض {0} إلى {1} من {2} سجل"
                            FilterMode="FilterMode.SimpleWithMenu"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Density="Density.Compact"
                            GridLines="DataGridGridLines.Horizontal"
                            Style="min-height:420px;"
                            Class="rz-pr-grid">
                <Columns>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Title="م" Width="50px"
                                          Sortable="false" Filterable="false"
                                          TextAlign="TextAlign.Center"
                                          Frozen="true">
                        <Template Context="data">
                            <span style="color:#94A3B8;font-weight:600;">@(_cachedFiltered.IndexOf(data) + 1)</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="EmployeeName"
                                          Title="الموظف" Width="200px"
                                          Frozen="true">
                        <Template Context="data">
                            <div>
                                <div class="emp-name">@data.EmployeeName</div>
                                <div class="emp-title">@data.JobTitle</div>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="Department"
                                          Title="القسم" Width="140px">
                        <Template Context="data">
                            <span class="dept-tag">@(data.Department ?? "—")</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="WorkingDaysInMonth"
                                          Title="أيام العمل" Width="85px"
                                          TextAlign="TextAlign.Center" />

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="PresentDays"
                                          Title="الحضور" Width="80px"
                                          TextAlign="TextAlign.Center">
                        <Template Context="data">
                            <span class="v-green">@data.PresentDays</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="AbsenceDays"
                                          Title="الغياب" Width="80px"
                                          TextAlign="TextAlign.Center">
                        <Template Context="data">
                            @if (data.AbsenceDays > 0)
                            {
                                <span class="absence-tag">@data.AbsenceDays</span>
                            }
                            else
                            {
                                <span class="v-green">✓</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="BasicSalary"
                                          Title="الراتب الأساسي" Width="120px"
                                          FormatString="{0:N2}"
                                          TextAlign="TextAlign.End" />

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="AbsenceDeduction"
                                          Title="خصم غياب" Width="100px"
                                          TextAlign="TextAlign.End">
                        <Template Context="data">
                            <span class="@(data.AbsenceDeduction > 0 ? "v-neg" : "v-muted")">
                                @(data.AbsenceDeduction > 0 ? $"-{data.AbsenceDeduction:N2}" : "—")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="LateDeduction"
                                          Title="خصم تأخير" Width="100px"
                                          TextAlign="TextAlign.End">
                        <Template Context="data">
                            <span class="@(data.LateDeduction > 0 ? "v-neg" : "v-muted")">
                                @(data.LateDeduction > 0 ? $"-{data.LateDeduction:N2}" : "—")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="LoanDeduction"
                                          Title="خصم سلفة" Width="100px"
                                          TextAlign="TextAlign.End">
                        <Template Context="data">
                            <span class="@(data.LoanDeduction > 0 ? "v-neg" : "v-muted")">
                                @(data.LoanDeduction > 0 ? $"-{data.LoanDeduction:N2}" : "—")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="NetSalary"
                                          Title="الصافي" Width="130px"
                                          TextAlign="TextAlign.End">
                        <Template Context="data">
                            <span class="v-gold" style="font-size:0.88rem;">@data.NetSalary.ToString("N2")</span>
                        </Template>
                        <FooterTemplate>
                            <span class="v-gold" style="font-size:0.9rem;">
                                @_cachedFiltered.Sum(d => d.NetSalary).ToString("N2")
                            </span>
                        </FooterTemplate>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="PaymentStatus"
                                          Title="الحالة" Width="110px"
                                          TextAlign="TextAlign.Center">
                        <Template Context="data">
                            <span class="status-pill @GetStatusPillClass(data.PaymentStatus)">
                                @data.PaymentStatus
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                </Columns>
            </RadzenDataGrid>
        </MudPaper>

        <div class="print-footer print-only">
            طُبع بواسطة نظام COCOBOLOERP | @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
        </div>
    }
    else if (_searched)
    {
        <MudPaper Class="pa-10 empty-state-card text-center" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="@MudSize.Large"
                     Style="color:#CBD5E1;font-size:64px;" />
            <MudText Typo="Typo.h6" Style="color:#64748B;font-weight:700;" Class="mt-4">
                لا توجد بيانات رواتب
            </MudText>
            <MudText Typo="Typo.body2" Style="color:#94A3B8;" Class="mt-1">
                @NoDataMessage
            </MudText>
        </MudPaper>
    }

</MudContainer>

@code {
    private string _reportMode = "single"; // single | range | employee
    private string _month = DateTime.Today.ToString("yyyy-MM");
    private string _monthFrom = DateTime.Today.ToString("yyyy-MM");
    private string _monthTo = DateTime.Today.ToString("yyyy-MM");
    private string _compareMonth = DateTime.Today.AddMonths(-1).ToString("yyyy-MM");
    private string _compareMonthFrom = DateTime.Today.AddMonths(-1).ToString("yyyy-MM");
    private string _compareMonthTo = DateTime.Today.AddMonths(-1).ToString("yyyy-MM");
    private string? _searchText;
    private string? _statusFilter;
    private string? _departmentFilter;
    private string? _jobTitleFilter;
    private string? _attendanceSourceFilter;
    private bool? _hasLoansFilter;
    private bool? _hasAbsenceFilter;
    private bool? _hasLateFilter;
    private int? _minLateMinutes;
    private int? _maxLateMinutes;
    private decimal? _minNetSalary;
    private decimal? _maxNetSalary;
    private decimal? _minDeductions;
    private decimal? _maxDeductions;
    private EmployeeListDto? _selectedEmployee;
    private bool    _loading;
    private bool    _searched;
    private bool    _exporting;
    private bool    _enableComparison;

    private List<PayrollListDto> _data           = new();
    private List<PayrollListDto> _cachedFiltered = new();
    private List<PayrollListDto> _compareData    = new();

    private List<DeptChartItem>      _deptChartData      = new();
    private List<DeductionChartItem> _deductionChartData = new();
    private List<StatCardModel>      _stats              = new();
    private List<ComparisonCardModel> _comparisonStats   = new();

    private ApexChartOptions<DeptChartItem>      _barOpts   = new();
    private ApexChartOptions<DeductionChartItem> _donutOpts = new();

    public record DeptChartItem(string Department, decimal TotalNet);
    public record DeductionChartItem(string Type, decimal Amount);
    public record StatCardModel(string Label, string Value, string Icon, string Accent, string IconBg);
    public record ComparisonCardModel(string Label, string CurrentValue, string CompareValue, string DeltaValue, string DeltaColor);

    private string CurrentPeriodLabel => _reportMode == "single"
        ? (_month ?? "—")
        : $"{_monthFrom ?? "—"} → {_monthTo ?? "—"}";

    private string ModeLabel => _reportMode switch
    {
        "single" => "شهر واحد",
        "range" => "فترة شهرية",
        "employee" => "ملف موظف",
        _ => "تقرير"
    };

    private string HeroSubtitle => _reportMode switch
    {
        "single" => $"تحليل شامل للرواتب والخصومات لشهر {CurrentPeriodLabel}",
        "range" => $"تحليل تراكمي للرواتب عبر الفترة {CurrentPeriodLabel}",
        "employee" => _selectedEmployee is null
            ? $"استعرض سجل رواتب موظف خلال الفترة {CurrentPeriodLabel}"
            : $"استعرض رواتب الموظف {_selectedEmployee.FullName} خلال الفترة {CurrentPeriodLabel}",
        _ => "تحليل رواتب متقدم"
    };

    private bool HasActiveFilters => ActiveFilterChips.Any();
    private bool _comparisonEnabledAndLoaded => _enableComparison && _comparisonStats.Any();

    private List<string> ActiveFilterChips
    {
        get
        {
            var chips = new List<string>();

            if (!string.IsNullOrWhiteSpace(_searchText))
                chips.Add($"بحث: {_searchText}");
            if (!string.IsNullOrWhiteSpace(_statusFilter))
                chips.Add($"الحالة: {_statusFilter}");
            if (!string.IsNullOrWhiteSpace(_departmentFilter) && _reportMode != "employee")
                chips.Add($"القسم: {_departmentFilter}");
            if (!string.IsNullOrWhiteSpace(_jobTitleFilter))
                chips.Add($"الوظيفة: {_jobTitleFilter}");
            if (!string.IsNullOrWhiteSpace(_attendanceSourceFilter))
                chips.Add($"الحضور: {(_attendanceSourceFilter == "Manual" ? "يدوي" : "بصمة")}");
            if (_hasLoansFilter.HasValue)
                chips.Add(_hasLoansFilter.Value ? "عليه سلفة" : "بدون سلفة");
            if (_hasAbsenceFilter.HasValue)
                chips.Add(_hasAbsenceFilter.Value ? "عليه غياب" : "بدون غياب");
            if (_hasLateFilter.HasValue)
                chips.Add(_hasLateFilter.Value ? "عليه تأخير" : "بدون تأخير");
            if (_minLateMinutes.HasValue || _maxLateMinutes.HasValue)
                chips.Add($"دقائق التأخير: {_minLateMinutes?.ToString() ?? "0"} → {_maxLateMinutes?.ToString() ?? "∞"}");
            if (_minNetSalary.HasValue || _maxNetSalary.HasValue)
                chips.Add($"الصافي: {_minNetSalary?.ToString("N0") ?? "0"} → {_maxNetSalary?.ToString("N0") ?? "∞"}");
            if (_minDeductions.HasValue || _maxDeductions.HasValue)
                chips.Add($"الخصومات: {_minDeductions?.ToString("N0") ?? "0"} → {_maxDeductions?.ToString("N0") ?? "∞"}");
            if (_reportMode == "employee" && _selectedEmployee is not null)
                chips.Add($"الموظف: {_selectedEmployee.FullName}");
            if (_enableComparison)
                chips.Add(_reportMode == "single"
                    ? $"مقارنة مع: {_compareMonth}"
                    : $"مقارنة مع: {_compareMonthFrom} → {_compareMonthTo}");

            return chips;
        }
    }

    private string PrimaryChartTitle => _reportMode == "employee"
        ? "صافي رواتب الموظف حسب الشهر"
        : "صافي الرواتب حسب القسم";

    private string NoDataMessage => _reportMode switch
    {
        "employee" when _selectedEmployee is null => "اختر موظفًا أولًا ثم اضغط عرض التقرير.",
        "employee" => $"لا توجد بيانات للموظف {_selectedEmployee?.FullName ?? "المحدد"} في الفترة المختارة.",
        "range" => "لا توجد رواتب مطابقة للفترة أو الفلاتر المحددة.",
        _ => "لا توجد رواتب مطابقة للشهر أو للفلاتر المحددة."
    };

    protected override void OnInitialized() => InitChartOptions();

    private void InitChartOptions()
    {
        _barOpts = new ApexChartOptions<DeptChartItem>
        {
            Colors = new List<string> { "#3B82F6", "#6366F1" },
            Chart  = new Chart { Toolbar = new Toolbar { Show = false }, FontFamily = "inherit" },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar { BorderRadius = 8, ColumnWidth = "50%" }
            },
            Grid       = new Grid { StrokeDashArray = 3, BorderColor = "#F1F5F9" },
            Xaxis      = new XAxis { Labels = new XAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit", FontSize = "12px" } } },
            Yaxis      = new List<YAxis>
            {
                new YAxis
                {
                    Opposite = true,
                    Labels = new YAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit" } }
                }
            },
            DataLabels = new DataLabels { Enabled = false },
            Tooltip    = new ApexTooltip { Theme = Mode.Light }
        };

        _donutOpts = new ApexChartOptions<DeductionChartItem>
        {
            Colors = new List<string> { "#DC2626", "#F59E0B", "#7C3AED" },
            PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    Donut = new PlotOptionsDonut
                    {
                        Size = "74%",
                        Labels = new DonutLabels
                        {
                            Show  = true,
                            Name  = new DonutLabelName  { Show = true, FontSize = "13px" },
                            Value = new DonutLabelValue { Show = true, FontSize = "16px" },
                            Total = new DonutLabelTotal { Show = true, Label = "إجمالي الخصومات", FontSize = "12px" }
                        }
                    }
                }
            },
            Legend     = new Legend { Position = ApexLegendPos.Bottom, FontFamily = "inherit", FontSize = "13px" },
            Chart      = new Chart  { FontFamily = "inherit" },
            Stroke     = new Stroke { Colors = new List<string> { "#FFFFFF" }, Width = 3 },
            DataLabels = new DataLabels { Enabled = false }
        };
    }

    private async Task LoadAsync()
    {
        if (_reportMode == "employee" && _selectedEmployee is null)
        {
            Snackbar.Add("اختر الموظف أولاً لعرض تقرير الموظف", Severity.Warning);
            return;
        }

        if ((_reportMode == "range" || _reportMode == "employee")
            && !string.IsNullOrWhiteSpace(_monthFrom)
            && !string.IsNullOrWhiteSpace(_monthTo)
            && string.Compare(_monthFrom, _monthTo, StringComparison.Ordinal) > 0)
        {
            Snackbar.Add("شهر البداية يجب أن يكون قبل أو يساوي شهر النهاية", Severity.Warning);
            return;
        }

        if (_enableComparison && !HasValidComparisonFilter())
        {
            Snackbar.Add("تأكد من إدخال فترة المقارنة بشكل صحيح", Severity.Warning);
            return;
        }

        _loading = true;
        _searched = true;
        StateHasChanged();

        try
        {
            var filter = BuildFilter();
            var result = await PayrollService.GetPayrollsAsync(filter);
            _data = result.Items;

            _compareData = new();
            _comparisonStats = new();
            if (_enableComparison && HasValidComparisonFilter())
            {
                var compareResult = await PayrollService.GetPayrollsAsync(BuildComparisonFilter());
                _compareData = compareResult.Items;
            }

            RebuildCached();
            BuildChartData();
            BuildStats();
            BuildComparisonStats();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private PayrollFilterDto BuildFilter()
    {
        var filter = new PayrollFilterDto
        {
            PaymentStatus = _statusFilter,
            SearchText = _searchText,
            Department = _reportMode == "employee" ? null : _departmentFilter,
            JobTitle = _jobTitleFilter,
            EmployeeID = _reportMode == "employee" ? _selectedEmployee?.EmployeeId : null,
            HasLoans = _hasLoansFilter,
            HasAbsence = _hasAbsenceFilter,
            HasLate = _hasLateFilter,
            AttendanceSource = _attendanceSourceFilter,
            MinLateMinutes = _minLateMinutes,
            MaxLateMinutes = _maxLateMinutes,
            MinNetSalary = _minNetSalary,
            MaxNetSalary = _maxNetSalary,
            MinDeductions = _minDeductions,
            MaxDeductions = _maxDeductions,
            PageNumber = 1,
            PageSize = 5000
        };

        if (_reportMode == "single")
        {
            filter.PayrollMonth = _month;
        }
        else
        {
            filter.MonthFrom = _monthFrom;
            filter.MonthTo = _monthTo;
        }

        return filter;
    }

    private PayrollFilterDto BuildComparisonFilter()
    {
        var filter = BuildFilter();
        filter.PayrollMonth = null;
        filter.MonthFrom = null;
        filter.MonthTo = null;

        if (_reportMode == "single")
        {
            filter.PayrollMonth = _compareMonth;
        }
        else
        {
            filter.MonthFrom = _compareMonthFrom;
            filter.MonthTo = _compareMonthTo;
        }

        return filter;
    }

    private void RebuildCached()
    {
        _cachedFiltered = _data.ToList();
    }

    private void BuildChartData()
    {
        _deptChartData = _reportMode == "employee"
            ? _cachedFiltered
                .GroupBy(d => d.PayrollMonth)
                .Select(g => new DeptChartItem(g.Key, g.Sum(x => x.NetSalary)))
                .OrderBy(x => x.Department)
                .ToList()
            : _cachedFiltered
                .GroupBy(d => d.Department ?? "بدون قسم")
                .Select(g => new DeptChartItem(g.Key, g.Sum(x => x.NetSalary)))
                .OrderByDescending(x => x.TotalNet)
                .ToList();

        _deductionChartData = new List<DeductionChartItem>
        {
            new("خصم غياب",  _cachedFiltered.Sum(d => d.AbsenceDeduction)),
            new("خصم تأخير", _cachedFiltered.Sum(d => d.LateDeduction)),
            new("خصم سلف",   _cachedFiltered.Sum(d => d.LoanDeduction))
        };
    }

    private void BuildStats()
    {
        _stats = new List<StatCardModel>
        {
            new("عدد الموظفين", _cachedFiltered.Select(d => d.EmployeeID).Distinct().Count().ToString(), Icons.Material.Filled.Groups, "#3B82F6", "#EFF6FF"),
            new("صافي الرواتب", _cachedFiltered.Sum(d => d.NetSalary).ToString("N0"), Icons.Material.Filled.AccountBalance, "#B8860B", "#FFFBEB"),
            new("إجمالي الخصومات", _cachedFiltered.Sum(d => d.TotalDeductions).ToString("N0"), Icons.Material.Filled.RemoveCircle, "#DC2626", "#FEF2F2"),
            new("قيد المراجعة", _cachedFiltered.Count(d => d.PaymentStatus == PayrollPaymentStatuses.PendingReview).ToString(), Icons.Material.Filled.HourglassTop, "#F59E0B", "#FFF7ED"),
            new("معتمد", _cachedFiltered.Count(d => d.PaymentStatus == PayrollPaymentStatuses.Approved).ToString(), Icons.Material.Filled.TaskAlt, "#2563EB", "#EFF6FF"),
            new("مدفوع", _cachedFiltered.Count(d => d.PaymentStatus == PayrollPaymentStatuses.Paid).ToString(), Icons.Material.Filled.CheckCircle, "#059669", "#F0FDF4")
        };
    }

    private bool HasValidComparisonFilter()
    {
        if (!_enableComparison)
            return false;

        if (_reportMode == "single")
            return !string.IsNullOrWhiteSpace(_compareMonth);

        return !string.IsNullOrWhiteSpace(_compareMonthFrom)
            && !string.IsNullOrWhiteSpace(_compareMonthTo)
            && string.Compare(_compareMonthFrom, _compareMonthTo, StringComparison.Ordinal) <= 0;
    }

    private void BuildComparisonStats()
    {
        _comparisonStats = new();
        if (!_enableComparison || !_compareData.Any())
            return;

        var currentNet = _cachedFiltered.Sum(x => x.NetSalary);
        var compareNet = _compareData.Sum(x => x.NetSalary);
        var currentDed = _cachedFiltered.Sum(x => x.TotalDeductions);
        var compareDed = _compareData.Sum(x => x.TotalDeductions);
        var currentEmployees = _cachedFiltered.Select(x => x.EmployeeID).Distinct().Count();
        var compareEmployees = _compareData.Select(x => x.EmployeeID).Distinct().Count();
        var currentPaid = _cachedFiltered.Count(x => x.PaymentStatus == PayrollPaymentStatuses.Paid);
        var comparePaid = _compareData.Count(x => x.PaymentStatus == PayrollPaymentStatuses.Paid);

        _comparisonStats = new List<ComparisonCardModel>
        {
            MakeComparisonCard("صافي الرواتب", currentNet, compareNet, true),
            MakeComparisonCard("إجمالي الخصومات", currentDed, compareDed, false),
            MakeComparisonCard("عدد الموظفين", currentEmployees, compareEmployees),
            MakeComparisonCard("عدد المدفوع", currentPaid, comparePaid)
        };
    }

    private ComparisonCardModel MakeComparisonCard(string label, decimal current, decimal compare, bool positiveWhenHigher = true)
    {
        var delta = current - compare;
        var deltaColor = delta == 0 ? "#64748B"
            : (positiveWhenHigher ? (delta > 0 ? "#059669" : "#DC2626") : (delta > 0 ? "#DC2626" : "#059669"));
        var sign = delta > 0 ? "+" : string.Empty;
        return new ComparisonCardModel(label, current.ToString("N0"), compare.ToString("N0"), $"{sign}{delta:N0}", deltaColor);
    }

    private ComparisonCardModel MakeComparisonCard(string label, int current, int compare)
    {
        var delta = current - compare;
        var deltaColor = delta == 0 ? "#64748B" : (delta > 0 ? "#059669" : "#DC2626");
        var sign = delta > 0 ? "+" : string.Empty;
        return new ComparisonCardModel(label, current.ToString(), compare.ToString(), $"{sign}{delta}", deltaColor);
    }

    private string GetStatusPillClass(string status) => status switch
    {
        var s when s == PayrollPaymentStatuses.Paid => "status-paid",
        var s when s == PayrollPaymentStatuses.PendingReview => "status-review",
        var s when s == PayrollPaymentStatuses.Approved => "status-approved",
        var s when s == PayrollPaymentStatuses.Rejected => "status-rejected",
        var s when s == PayrollPaymentStatuses.Cancelled => "status-cancelled",
        _ => "status-unpaid"
    };

    private async Task<IEnumerable<EmployeeListDto>> SearchEmployees(string value, CancellationToken ct)
    {
        return await EmployeeService.SearchEmployeesAsync(value ?? string.Empty, 20);
    }

    private Task OnEmployeeChanged(EmployeeListDto? employee)
    {
        _selectedEmployee = employee;
        return Task.CompletedTask;
    }

    private void SetReportMode(string mode)
    {
        _reportMode = mode;
        if (mode == "single")
        {
            _month = string.IsNullOrWhiteSpace(_month) ? DateTime.Today.ToString("yyyy-MM") : _month;
        }
        else
        {
            _monthFrom = string.IsNullOrWhiteSpace(_monthFrom) ? DateTime.Today.ToString("yyyy-MM") : _monthFrom;
            _monthTo = string.IsNullOrWhiteSpace(_monthTo) ? DateTime.Today.ToString("yyyy-MM") : _monthTo;
        }

        if (mode != "employee")
            _selectedEmployee = null;

        _compareMonth = DateTime.Today.AddMonths(-1).ToString("yyyy-MM");
        _compareMonthFrom = _compareMonth;
        _compareMonthTo = _compareMonth;
        _data = new();
        _cachedFiltered = new();
        _compareData = new();
        _comparisonStats = new();
        BuildChartData();
        BuildStats();
    }

    private async Task ResetFilters()
    {
        _reportMode = "single";
        _month = DateTime.Today.ToString("yyyy-MM");
        _monthFrom = _month;
        _monthTo = _month;
        _searchText = null;
        _statusFilter = null;
        _departmentFilter = null;
        _jobTitleFilter = null;
        _attendanceSourceFilter = null;
        _hasLoansFilter = null;
        _hasAbsenceFilter = null;
        _hasLateFilter = null;
        _minLateMinutes = null;
        _maxLateMinutes = null;
        _minNetSalary = null;
        _maxNetSalary = null;
        _minDeductions = null;
        _maxDeductions = null;
        _selectedEmployee = null;
        _enableComparison = false;
        _compareMonth = DateTime.Today.AddMonths(-1).ToString("yyyy-MM");
        _compareMonthFrom = _compareMonth;
        _compareMonthTo = _compareMonth;
        _compareData = new();
        _comparisonStats = new();
        await LoadAsync();
    }

    private async Task ExportExcelAsync()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            var filter = BuildFilter();
            var bytes = await PayrollService.ExportPayrollsExcelAsync(filter);
            var base64 = Convert.ToBase64String(bytes);
            var label = _reportMode == "single"
                ? _month
                : _reportMode == "employee" ? $"{_selectedEmployee?.FullName ?? "employee"}_{_monthFrom}_{_monthTo}" : $"{_monthFrom}_{_monthTo}";
            await JS.InvokeVoidAsync("downloadFileFromBase64", base64, $"تقرير_الرواتب_{label}.xlsx");
            Snackbar.Add("تم التصدير بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally { _exporting = false; }
    }
