@page "/hr/reports/payroll"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using ApexCharts
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudColor = MudBlazor.Color
@using MudSize  = MudBlazor.Size
@using MudAlign = MudBlazor.Align

@inject IPayrollService PayrollService
@inject IJSRuntime      JS
@inject ISnackbar       Snackbar

<PageTitle>تقرير مسير الرواتب</PageTitle>

<style>
    .payroll-root {
        padding-top: max(1rem, env(safe-area-inset-top));
        padding-bottom: max(1rem, env(safe-area-inset-bottom));
        padding-left: max(1rem, env(safe-area-inset-left));
        padding-right: max(1rem, env(safe-area-inset-right));
        min-height: 100svh;
    }

    .pr-header {
        border-radius: 24px !important;
        overflow: hidden;
        border: none !important;
    }

    .pr-header-bg {
        position: relative;
        background: linear-gradient(135deg, #0F172A 0%, #1E293B 40%, #334155 100%);
    }

    .pr-header-bg::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse at 25% 50%, rgba(212,175,55,0.12) 0%, transparent 50%),
            radial-gradient(ellipse at 75% 30%, rgba(59,130,246,0.1) 0%, transparent 50%);
        pointer-events: none;
    }

    .pr-header-content {
        position: relative;
        z-index: 2;
        padding: 24px;
    }

    .pr-header-avatar {
        background: rgba(212,175,55,0.15) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(212,175,55,0.25);
    }

    .mod-card {
        border: 1px solid #E2E8F0 !important;
        border-radius: 16px !important;
        transition: all 0.3s ease;
        background: white !important;
    }

    .mod-card:hover {
        border-color: #CBD5E1 !important;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04) !important;
    }

    .sec-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* ─── Mini Stat Cards ─── */
    .mini-stat {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border-radius: 12px;
        border: 1px solid #F1F5F9;
        background: white;
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
    }

    .mini-stat:hover {
        border-color: #E2E8F0;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    }

    .mini-stat-accent {
        position: absolute;
        right: 0;
        top: 0;
        width: 3px;
        height: 100%;
    }

    .mini-stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .mini-stat-val {
        font-size: 1.1rem;
        font-weight: 800;
        line-height: 1.2;
    }

    .mini-stat-lbl {
        font-size: 0.7rem;
        color: #94A3B8;
        line-height: 1.2;
    }

    /* ─── Filter Card ─── */
    .filter-card {
        border-radius: 16px !important;
        border: 1px solid #E2E8F0 !important;
    }

    /* ─── Table ─── */
    .payroll-table .mud-table-head .mud-table-cell {
        background: #0F172A !important;
        color: white !important;
        font-weight: 700 !important;
        font-size: 0.78rem !important;
        white-space: nowrap;
        padding: 8px 12px !important;
    }

    .payroll-table .mud-table-foot .mud-table-cell {
        background: #F8FAFC !important;
        font-weight: 700 !important;
        border-top: 2px solid #E2E8F0 !important;
        padding: 8px 12px !important;
    }

    .payroll-table .mud-table-body .mud-table-row:hover {
        background: #F0F9FF !important;
    }

    .payroll-table .mud-table-cell {
        padding: 6px 12px !important;
        font-size: 0.82rem !important;
    }

    .neg-val { color: #EF4444; }
    .gold-val { color: #D4AF37; font-weight: 800; }

    /* ─── ApexCharts RTL ─── */
    .apexcharts-canvas text,
    .apexcharts-legend-text { font-family: inherit !important; }
    .apexcharts-tooltip {
        direction: rtl !important;
        text-align: right !important;
        border-radius: 10px !important;
    }

    /* ─── Print ─── */
    .print-only { display: none; }

    @@media print {
        .no-print { display: none !important; }
        .print-only { display: block !important; }
        .payroll-table .mud-table-head .mud-table-cell {
            background: #1E293B !important;
            color: white !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .mini-stat, .mod-card { break-inside: avoid; }
        .print-header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #1E293B;
            padding-bottom: 10px;
        }
        .print-header h2 { margin: 0; font-size: 1.4rem; }
        .print-header p { margin: 4px 0 0; color: #64748B; font-size: 0.85rem; }
        .print-footer {
            text-align: center;
            margin-top: 30px;
            padding-top: 10px;
            border-top: 1px solid #CBD5E1;
            font-size: 0.75rem;
            color: #94A3B8;
        }
    }

    /* ─── Responsive ─── */
    @@media (max-width: 600px) {
        .pr-header { border-radius: 16px !important; }
        .mod-card { border-radius: 12px !important; }
        .pr-header-content { padding: 16px; }
        .mini-stat { padding: 10px 12px; }
        .mini-stat-val { font-size: 0.95rem; }
        .mini-stat-icon { width: 32px; height: 32px; }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 payroll-root">

    @* ══════════════════════════════════════════
       HEADER
       ══════════════════════════════════════════ *@
    <MudPaper Class="mb-4 pr-header no-print" Elevation="0">
        <div class="pr-header-bg">
            <div class="pr-header-content">
                <div class="d-flex align-center justify-space-between flex-wrap gap-3">
                    <div class="d-flex align-center gap-3">
                        <MudAvatar Size="@MudSize.Large" Class="pr-header-avatar">
                            <MudIcon Icon="@Icons.Material.Rounded.Payments"
                                     Size="@MudSize.Medium" Style="color:#D4AF37;" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h5" Style="color:white;font-weight:800;letter-spacing:-0.5px;">
                                تقرير مسير الرواتب
                            </MudText>
                            <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.55);">
                                ملخص شامل لرواتب الموظفين مع التحليلات
                            </MudText>
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <MudButton Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Rounded.TableChart"
                                   Style="background:rgba(16,185,129,0.9);color:white;border-radius:10px;"
                                   Size="@MudSize.Small"
                                   OnClick="ExportExcelAsync"
                                   Disabled="@(!_data.Any() || _exporting)">
                            @(_exporting ? "جاري..." : "Excel")
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Rounded.Print"
                                   Style="background:rgba(59,130,246,0.9);color:white;border-radius:10px;"
                                   Size="@MudSize.Small"
                                   OnClick="@(() => JS.InvokeVoidAsync("printPage"))"
                                   Disabled="@(!_data.Any())">
                            طباعة
                        </MudButton>
                    </div>
                </div>
            </div>
        </div>
    </MudPaper>

    @* ══════════════════════════════════════════
       FILTERS
       ══════════════════════════════════════════ *@
    <MudPaper Class="pa-4 mb-4 filter-card no-print" Elevation="0">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4">
                <MudTextField T="string"
                              @bind-Value="_month"
                              Label="الشهر"
                              InputType="InputType.Month"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                              FullWidth />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="string"
                           @bind-Value="_statusFilter"
                           Label="الحالة"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable FullWidth
                           AdornmentIcon="@Icons.Material.Filled.FactCheck"
                           Adornment="Adornment.Start">
                    <MudSelectItem T="string" Value="@("مدفوع")">مدفوع</MudSelectItem>
                    <MudSelectItem T="string" Value="@("غير مدفوع")">غير مدفوع</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.Search"
                           OnClick="LoadAsync"
                           Disabled="@_loading"
                           FullWidth
                           Style="height:40px;border-radius:10px;font-weight:700;">
                    @(_loading ? "جاري..." : "عرض التقرير")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ══════════════════════════════════════════
       LOADING
       ══════════════════════════════════════════ *@
    @if (_loading)
    {
        <MudGrid Spacing="3" Class="mb-4">
            @for (int i = 0; i < 5; i++)
            {
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-3" Elevation="0" Style="border:1px solid #F1F5F9;border-radius:12px;">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="36px" Height="36px" Class="mb-2" />
                        <MudSkeleton Width="50%" Height="16px" Class="mb-1" />
                        <MudSkeleton Width="35%" Height="12px" />
                    </MudPaper>
                </MudItem>
            }
            <MudItem xs="12">
                <MudPaper Class="pa-4 mod-card" Elevation="0">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="250px" Class="rounded-lg" />
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else if (_data.Any())
    {
        @* ══════════════════════════════════════════
           MINI STAT CARDS
           ══════════════════════════════════════════ *@
        <MudGrid Spacing="2" Class="mb-4 no-print">
            @foreach (var s in _stats)
            {
                <MudItem xs="6" sm="4" md="2">
                    <div class="mini-stat">
                        <div class="mini-stat-accent" style="background:@s.Accent;"></div>
                        <div class="mini-stat-icon" style="background:@s.IconBg;">
                            <MudIcon Icon="@s.Icon" Style="@($"color:{s.Accent};font-size:18px;")" />
                        </div>
                        <div>
                            <div class="mini-stat-val" style="color:@s.Accent;">@s.Value</div>
                            <div class="mini-stat-lbl">@s.Label</div>
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>

        @* ══════════════════════════════════════════
           CHARTS
           ══════════════════════════════════════════ *@
        <MudGrid Spacing="3" Class="mb-4 no-print">
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4 mod-card" Elevation="0">
                    <div class="d-flex align-center gap-2 mb-3">
                        <div class="sec-icon" style="background:#DBEAFE;">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="color:#3B82F6;font-size:16px;" />
                        </div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">الرواتب حسب القسم</MudText>
                    </div>
                    <ApexChart TItem="DeptChartItem" Options="_barOpts" Height="260">
                        <ApexPointSeries TItem="DeptChartItem" Items="_deptChartData"
                                         Name="صافي الرواتب" SeriesType="SeriesType.Bar"
                                         XValue="e => e.Department" YValue="e => e.TotalNet" />
                    </ApexChart>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 mod-card" Elevation="0" Style="height:100%;">
                    <div class="d-flex align-center gap-2 mb-3">
                        <div class="sec-icon" style="background:#FEE2E2;">
                            <MudIcon Icon="@Icons.Material.Filled.DonutLarge" Style="color:#EF4444;font-size:16px;" />
                        </div>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">توزيع الخصومات</MudText>
                    </div>
                    <ApexChart TItem="DeductionChartItem" Options="_donutOpts" Height="260">
                        <ApexPointSeries TItem="DeductionChartItem" Items="_deductionChartData"
                                         Name="الخصومات" SeriesType="SeriesType.Donut"
                                         XValue="e => e.Type" YValue="e => e.Amount" />
                    </ApexChart>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ══════════════════════════════════════════
           PRINT HEADER
           ══════════════════════════════════════════ *@
        <div class="print-only print-header">
            <h2>مسير الرواتب الشهري</h2>
            <p>الشهر: @_month | تاريخ الطباعة: @DateTime.Now.ToString("yyyy-MM-dd")</p>
        </div>

        @* ══════════════════════════════════════════
           TABLE
           ══════════════════════════════════════════ *@
        <MudPaper Class="mod-card overflow-hidden" Elevation="0">
            <div class="d-flex align-center justify-space-between pa-3 no-print" style="border-bottom:1px solid #F1F5F9;">
                <div class="d-flex align-center gap-2">
                    <div class="sec-icon" style="background:#FEF3C7;">
                        <MudIcon Icon="@Icons.Material.Filled.TableChart" Style="color:#D4AF37;font-size:16px;" />
                    </div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">البيانات التفصيلية</MudText>
                </div>
                <MudChip T="string" Size="@MudSize.Small" Variant="Variant.Text" Color="@MudColor.Primary">
                    @_cachedFiltered.Count موظف
                </MudChip>
            </div>

            <MudTable Items="@_cachedFiltered" Dense Hover Striped FixedHeader
                      Height="calc(100vh - 480px)"
                      Breakpoint="Breakpoint.Sm"
                      Class="payroll-table">
                <HeaderContent>
                    <MudTh>م</MudTh>
                    <MudTh>اسم الموظف</MudTh>
                    <MudTh>القسم</MudTh>
                    <MudTh Style="text-align:center;">أيام العمل</MudTh>
                    <MudTh Style="text-align:center;">الحضور</MudTh>
                    <MudTh Style="text-align:center;">الغياب</MudTh>
                    <MudTh Style="text-align:right;">الأساسي</MudTh>
                    <MudTh Style="text-align:right;color:#EF4444;">خصم غياب</MudTh>
                    <MudTh Style="text-align:right;color:#EF4444;">خصم تأخير</MudTh>
                    <MudTh Style="text-align:right;color:#EF4444;">خصم سلفة</MudTh>
                    <MudTh Style="text-align:right;color:#D4AF37;">الصافي</MudTh>
                    <MudTh Style="text-align:center;">الحالة</MudTh>
                </HeaderContent>

                <RowTemplate Context="row">
                    @{
                        var idx = _cachedFiltered.IndexOf(row) + 1;
                    }
                    <MudTd DataLabel="م">@idx</MudTd>
                    <MudTd DataLabel="الموظف">
                        <MudText Style="font-weight:600;font-size:0.82rem;">@row.EmployeeName</MudText>
                        <MudText Typo="Typo.caption" Style="color:#94A3B8;font-size:0.7rem;">@row.JobTitle</MudText>
                    </MudTd>
                    <MudTd DataLabel="القسم">
                        <MudChip T="string" Size="@MudSize.Small" Variant="Variant.Outlined"
                                 Style="border-radius:6px;font-size:0.72rem;">
                            @(row.Department ?? "—")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="أيام العمل">
                        <MudText Align="@MudAlign.Center" Style="font-weight:600;">@row.WorkingDaysInMonth</MudText>
                    </MudTd>
                    <MudTd DataLabel="الحضور">
                        <MudText Align="@MudAlign.Center" Style="color:#10B981;font-weight:700;">@row.PresentDays</MudText>
                    </MudTd>
                    <MudTd DataLabel="الغياب">
                        @if (row.AbsenceDays > 0)
                        {
                            <MudChip T="string" Size="@MudSize.Small" Color="@MudColor.Error"
                                     Style="border-radius:6px;">@row.AbsenceDays</MudChip>
                        }
                        else
                        {
                            <MudText Align="@MudAlign.Center" Style="color:#10B981;">✓</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="الأساسي">
                        <MudText Align="@MudAlign.Right">@row.BasicSalary.ToString("N2")</MudText>
                    </MudTd>
                    <MudTd DataLabel="خصم غياب">
                        <MudText Align="@MudAlign.Right" Class="neg-val">
                            @(row.AbsenceDeduction > 0 ? $"-{row.AbsenceDeduction:N2}" : "—")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="خصم تأخير">
                        <MudText Align="@MudAlign.Right" Class="neg-val">
                            @(row.LateDeduction > 0 ? $"-{row.LateDeduction:N2}" : "—")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="خصم سلفة">
                        <MudText Align="@MudAlign.Right" Class="neg-val">
                            @(row.LoanDeduction > 0 ? $"-{row.LoanDeduction:N2}" : "—")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="الصافي">
                        <MudText Align="@MudAlign.Right" Class="gold-val">
                            @row.NetSalary.ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="الحالة">
                        <MudChip T="string" Size="@MudSize.Small"
                                 Color="@StatusColor(row.PaymentStatus)"
                                 Style="border-radius:6px;">
                            @row.PaymentStatus
                        </MudChip>
                    </MudTd>
                </RowTemplate>

                <FooterContent>
                    <MudTd colspan="6">
                        <MudText Style="font-weight:700;font-size:0.82rem;">
                            الإجمالي (@_cachedFiltered.Count موظف)
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Align="@MudAlign.Right" Style="font-weight:700;">
                            @_cachedFiltered.Sum(d => d.BasicSalary).ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Align="@MudAlign.Right" Class="neg-val" Style="font-weight:700;">
                            @_cachedFiltered.Sum(d => d.AbsenceDeduction).ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Align="@MudAlign.Right" Class="neg-val" Style="font-weight:700;">
                            @_cachedFiltered.Sum(d => d.LateDeduction).ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Align="@MudAlign.Right" Class="neg-val" Style="font-weight:700;">
                            @_cachedFiltered.Sum(d => d.LoanDeduction).ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Align="@MudAlign.Right" Class="gold-val">
                            @_cachedFiltered.Sum(d => d.NetSalary).ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd />
                </FooterContent>
            </MudTable>
        </MudPaper>

        <div class="print-footer print-only">
            طُبع بواسطة نظام COCOBOLOERP | @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
        </div>
    }
    else if (_searched)
    {
        <MudPaper Class="pa-8 mod-card text-center" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="@MudSize.Large" Style="color:#CBD5E1;" />
            <MudText Typo="Typo.h6" Style="color:#94A3B8;" Class="mt-3">
                لا توجد بيانات رواتب للشهر المحدد
            </MudText>
            <MudText Typo="Typo.body2" Style="color:#CBD5E1;" Class="mt-1">
                جرب اختيار شهر آخر أو تغيير الفلتر
            </MudText>
        </MudPaper>
    }

</MudContainer>

@code {
    // ══════════════════ State ══════════════════
    private string  _month        = DateTime.Today.ToString("yyyy-MM");
    private string? _statusFilter;
    private bool    _loading;
    private bool    _searched;
    private bool    _exporting;

    private List<PayrollListDto> _data           = new();
    private List<PayrollListDto> _cachedFiltered = new();

    // ══════════════════ Chart Data ══════════════════
    private List<DeptChartItem>      _deptChartData      = new();
    private List<DeductionChartItem> _deductionChartData = new();
    private List<StatCardModel>      _stats              = new();

    // ══════════════════ Chart Options ══════════════════
    private ApexChartOptions<DeptChartItem>      _barOpts   = new();
    private ApexChartOptions<DeductionChartItem> _donutOpts = new();

    // ══════════════════ Models ══════════════════
    public record DeptChartItem(string Department, decimal TotalNet);
    public record DeductionChartItem(string Type, decimal Amount);
    public record StatCardModel(string Label, string Value, string Icon, string Accent, string IconBg);

    // ══════════════════ Lifecycle ══════════════════
    protected override void OnInitialized()
    {
        InitChartOptions();
    }

    private void InitChartOptions()
    {
        _barOpts = new ApexChartOptions<DeptChartItem>
        {
            Colors = new List<string> { "#3B82F6" },
            Chart  = new Chart { Toolbar = new Toolbar { Show = false }, FontFamily = "inherit" },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar { BorderRadius = 6, ColumnWidth = "55%" }
            },
            Grid       = new Grid       { StrokeDashArray = 4, BorderColor = "#F1F5F9" },
            Xaxis      = new XAxis      { Labels = new XAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit" } } },
            Yaxis      = new List<YAxis>
            {
                new YAxis
                {
                    Opposite = true,
                    Labels = new YAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit" } }
                }
            },
            DataLabels = new DataLabels { Enabled = false },
            Tooltip    = new Tooltip    { Theme = Mode.Light }
        };

        _donutOpts = new ApexChartOptions<DeductionChartItem>
        {
            Colors = new List<string> { "#EF4444", "#F59E0B", "#8B5CF6" },
            PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    Donut = new PlotOptionsDonut
                    {
                        Size = "72%",
                        Labels = new DonutLabels
                        {
                            Show  = true,
                            Name  = new DonutLabelName  { Show = true },
                            Value = new DonutLabelValue { Show = true },
                            Total = new DonutLabelTotal { Show = true, Label = "إجمالي الخصومات" }
                        }
                    }
                }
            },
            Legend     = new Legend     { Position = LegendPosition.Bottom, FontFamily = "inherit" },
            Chart      = new Chart      { FontFamily = "inherit" },
            Stroke     = new Stroke     { Colors = new List<string> { "#FFFFFF" } },
            DataLabels = new DataLabels { Enabled = false }
        };
    }

    // ══════════════════ Load ══════════════════
    private async Task LoadAsync()
    {
        _loading  = true;
        _searched = true;
        StateHasChanged();

        try
        {
            var filter = new PayrollFilterDto
            {
                PayrollMonth = _month,
                PageNumber   = 1,
                PageSize     = 1000
            };

            var result = await PayrollService.GetPayrollsAsync(filter);
            _data = result.Items;
            RebuildCached();
            BuildChartData();
            BuildStats();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    // ══════════════════ Filter ══════════════════
    private void RebuildCached()
    {
        _cachedFiltered = string.IsNullOrWhiteSpace(_statusFilter)
            ? _data.ToList()
            : _data.Where(d => d.PaymentStatus == _statusFilter).ToList();
    }

    // ══════════════════ Chart Data ══════════════════
    private void BuildChartData()
    {
        _deptChartData = _data
            .GroupBy(d => d.Department ?? "بدون قسم")
            .Select(g => new DeptChartItem(g.Key, g.Sum(x => x.NetSalary)))
            .OrderByDescending(x => x.TotalNet)
            .ToList();

        var absTotal  = _data.Sum(d => d.AbsenceDeduction);
        var lateTotal = _data.Sum(d => d.LateDeduction);
        var loanTotal = _data.Sum(d => d.LoanDeduction);

        _deductionChartData = new List<DeductionChartItem>
        {
            new("خصم غياب",  absTotal),
            new("خصم تأخير", lateTotal),
            new("خصم سلف",   loanTotal)
        };
    }

    private void BuildStats()
    {
        _stats = new List<StatCardModel>
        {
            new("الموظفين",
                _cachedFiltered.Count.ToString(),
                Icons.Material.Filled.Groups,
                "#3B82F6", "#EFF6FF"),

            new("صافي الإجمالي",
                _cachedFiltered.Sum(d => d.NetSalary).ToString("N0"),
                Icons.Material.Filled.AccountBalance,
                "#D4AF37", "#FFFBEB"),

            new("الخصومات",
                _cachedFiltered.Sum(d => d.TotalDeductions).ToString("N0"),
                Icons.Material.Filled.RemoveCircle,
                "#EF4444", "#FEF2F2"),

            new("مدفوع",
                _cachedFiltered.Count(d => d.PaymentStatus == "مدفوع").ToString(),
                Icons.Material.Filled.CheckCircle,
                "#10B981", "#F0FDF4"),

            new("غير مدفوع",
                _cachedFiltered.Count(d => d.PaymentStatus != "مدفوع").ToString(),
                Icons.Material.Filled.PauseCircle,
                "#F59E0B", "#FFFBEB")
        };
    }

    // ══════════════════ Helpers ══════════════════
    private MudBlazor.Color StatusColor(string status)
    {
        if (status == "مدفوع") return MudBlazor.Color.Success;
        return MudBlazor.Color.Warning;
    }

    // ══════════════════ Export ══════════════════
    private async Task ExportExcelAsync()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            var bytes  = await PayrollService.ExportMonthExcelAsync(_month);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBase64", base64,
                $"مسير_الرواتب_{_month}.xlsx");
            Snackbar.Add("تم التصدير بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exporting = false;
        }
    }
}