@code {
    private EmployeeStatsDto? _employeeStats;
    private AttendanceStatisticsDto? _todayStats;
    private AttendanceDashboardDto? _attendanceDashboard;
    private PayrollStatsDto? _payrollStats;
    private OffPayrollPaymentStatsDto? _offPayrollStats;
    private LoanStatsDto? _loanStats;
    private ShiftStatisticsDto? _shiftStats;
    private ExemptionStatsDto? _exemptionStats;
    private List<PayrollListDto> _pendingPayrolls = new();
    private List<PayrollListDto> _approvedPayrolls = new();
    private List<OffPayrollPaymentListDto> _pendingOffPayrolls = new();
    private List<OffPayrollPaymentListDto> _approvedOffPayrolls = new();
    private List<AttendanceListDto> _todayLateEmployees = new();
    private List<AttendanceListDto> _todayAbsentEmployees = new();
    private bool _loading = true;
    private int _activeTab;
    private string _currentUserDisplay = "system";

    private string CurrentMonthLabel => DateTime.Today.ToString("MMMM yyyy", new System.Globalization.CultureInfo("ar-EG"));
    private double LoanRemainingProgress => _loanStats is null || _loanStats.TotalLoanAmount <= 0 ? 0 : Math.Min((double)(_loanStats.TotalRemainingAmount / _loanStats.TotalLoanAmount * 100), 100);
    private double LoanCurrentMonthProgress => _loanStats is null || _loanStats.TotalLoanAmount <= 0 ? 0 : Math.Min((double)(_loanStats.ThisMonthDeductions / _loanStats.TotalLoanAmount * 100), 100);
    private double LoanAverageProgress => _loanStats is null || _loanStats.TotalLoanAmount <= 0 ? 0 : Math.Min((double)(_loanStats.AverageLoanAmount / _loanStats.TotalLoanAmount * 100), 100);
    private double ExemptionPendingProgress => ExemptionTotal == 0 ? 0 : Math.Min((double)(_exemptionStats?.PendingCount ?? 0) / ExemptionTotal * 100, 100);
    private double ExemptionApprovedProgress => ExemptionTotal == 0 ? 0 : Math.Min((double)(_exemptionStats?.ApprovedCount ?? 0) / ExemptionTotal * 100, 100);
    private double ExemptionDeductedProgress => ExemptionTotal == 0 ? 0 : Math.Min((double)(_exemptionStats?.DeductedCount ?? 0) / ExemptionTotal * 100, 100);
    private double ExemptionTotal => (_exemptionStats?.TotalCount ?? 0) <= 0 ? 1 : (_exemptionStats?.TotalCount ?? 0);

    private List<DashboardAlert> Alerts => OperationalAlerts.Concat(FinancialAlerts).ToList();

    private List<DashboardAlert> OperationalAlerts
    {
        get
        {
            var list = new List<DashboardAlert>();

            if ((_todayStats?.TodayAbsent ?? 0) > 0)
                list.Add(new DashboardAlert("hrd-alert-danger", "غياب اليوم", $"يوجد {_todayStats!.TodayAbsent} موظف غائب اليوم ويحتاج مراجعة سريعة من فريق الموارد البشرية."));

            if ((_todayStats?.TodayLate ?? 0) > 0)
                list.Add(new DashboardAlert("hrd-alert-warning", "تأخير اليوم", $"تم رصد {_todayStats!.TodayLate} حالة تأخير اليوم بإجمالي {FormatMinutes(_todayStats.TotalLateMinutes)}."));

            if ((_exemptionStats?.PendingCount ?? 0) > 0)
                list.Add(new DashboardAlert("hrd-alert-info", "استثناءات معلقة", $"هناك {_exemptionStats!.PendingCount} طلب استثناء بانتظار الاعتماد أو الرفض."));

            if ((_shiftStats?.ActiveCount ?? 0) == 0)
                list.Add(new DashboardAlert("hrd-alert-warning", "الشيفتات الفعالة", "لا توجد شيفتات فعالة حاليًا وفق الإحصائيات الحالية، راجع بيانات الشيفتات."));

            return list;
        }
    }

    private List<DashboardAlert> FinancialAlerts
    {
        get
        {
            var list = new List<DashboardAlert>();

            if ((_payrollStats?.ReviewCount ?? 0) > 0)
                list.Add(new DashboardAlert("hrd-alert-warning", "رواتب تنتظر المراجعة", $"يوجد {_payrollStats!.ReviewCount} راتب قيد المراجعة ويحتاج اعتمادًا من الحسابات."));

            if ((_payrollStats?.ApprovedCount ?? 0) > 0)
                list.Add(new DashboardAlert("hrd-alert-success", "رواتب جاهزة للصرف", $"يوجد {_payrollStats!.ApprovedCount} راتب معتمد وجاهز للصرف من سجل الرواتب أو من شاشة كشف الراتب."));

            if ((_offPayrollStats?.ReviewCount ?? 0) > 0)
                list.Add(new DashboardAlert("hrd-alert-info", "دفعات خارج الراتب", $"يوجد {_offPayrollStats!.ReviewCount} طلب دفعة خارج الراتب بانتظار المراجعة."));

            if ((_loanStats?.PendingInstallmentsCount ?? 0) > 0)
                list.Add(new DashboardAlert("hrd-alert-danger", "أقساط سلف pending", $"يوجد {_loanStats!.PendingInstallmentsCount} قسط سلفة معلق ويجب مراجعته ضمن الرواتب أو شاشة السلف."));

            return list;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserDisplay = user.Identity?.Name ?? "system";

        var canView = user.IsInRole("Admin")
                      || user.IsInRole("HrManager")
                      || user.IsInRole("HRManager")
                      || user.IsInRole("AccountManager")
                      || user.HasClaim("Permission", "frm_Employeeslist:View")
                      || user.HasClaim("Permission", "frm_empAttendance:View")
                      || user.HasClaim("Permission", "frm_Payroll:View");

        if (!canView)
        {
            Nav.NavigateTo("/access-denied");
            return;
        }

        await LoadAsync();
    }

    private async Task OnTabChangedAsync(int tabIndex)
    {
        _activeTab = tabIndex;
        await Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var currentMonth = DateTime.Today.ToString("yyyy-MM");
            var today = DateTime.Today;

            _employeeStats = await EmployeeService.GetStatsAsync();
            _todayStats = await AttendanceService.GetTodayStatisticsAsync();
            _attendanceDashboard = await AttendanceService.GetDashboardDataAsync();
            _payrollStats = await PayrollService.GetStatsAsync(currentMonth);
            _offPayrollStats = await PayrollService.GetOffPayrollPaymentStatsAsync(new OffPayrollPaymentFilterDto
            {
                Month = currentMonth
            });
            _loanStats = await LoanService.GetStatsAsync();
            _shiftStats = await ShiftService.GetStatisticsAsync();
            _exemptionStats = await AttendanceService.GetExemptionStatsAsync(new ExemptionFilterDto
            {
                DateFrom = new DateTime(today.Year, today.Month, 1),
                DateTo = today
            });

            var pendingPayrollResult = await PayrollService.GetPayrollsAsync(new PayrollFilterDto
            {
                PayrollMonth = currentMonth,
                PaymentStatus = PayrollPaymentStatuses.PendingReview,
                PageNumber = 1,
                PageSize = 8
            });
            _pendingPayrolls = pendingPayrollResult.Items;

            var approvedPayrollResult = await PayrollService.GetPayrollsAsync(new PayrollFilterDto
            {
                PayrollMonth = currentMonth,
                PaymentStatus = PayrollPaymentStatuses.Approved,
                PageNumber = 1,
                PageSize = 8
            });
            _approvedPayrolls = approvedPayrollResult.Items;

            _pendingOffPayrolls = (await PayrollService.GetOffPayrollPaymentsAsync(new OffPayrollPaymentFilterDto
            {
                Month = currentMonth,
                PaymentStatus = PayrollPaymentStatuses.PendingReview
            })).Take(8).ToList();

            _approvedOffPayrolls = (await PayrollService.GetOffPayrollPaymentsAsync(new OffPayrollPaymentFilterDto
            {
                Month = currentMonth,
                PaymentStatus = PayrollPaymentStatuses.Approved
            })).Take(8).ToList();

            _todayLateEmployees = (await AttendanceService.GetAttendanceAsync(new AttendanceFilterDto
            {
                DateFrom = today,
                DateTo = today,
                LateOnly = true,
                PageNumber = 1,
                PageSize = 8
            })).Items;

            _todayAbsentEmployees = (await AttendanceService.GetAttendanceAsync(new AttendanceFilterDto
            {
                DateFrom = today,
                DateTo = today,
                AbsentOnly = true,
                PageNumber = 1,
                PageSize = 8
            })).Items;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل لوحة HR: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenEmployeeProfile(int? employeeId)
    {
        if (!employeeId.HasValue)
            return;

        Nav.NavigateTo($"/employees/profile/{employeeId.Value}");
    }

