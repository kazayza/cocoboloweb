@page "/hr/dashboard"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IEmployeeService EmployeeService
@inject IAttendanceService AttendanceService
@inject IPayrollService PayrollService
@inject IEmployeeLoanService LoanService
@inject IEmployeeShiftService ShiftService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>لوحة تحكم الموارد البشرية</PageTitle>

<style>
    .hrd-root {
        direction: rtl;
        padding-bottom: 32px;
    }

    .hrd-hero {
        position: relative;
        overflow: hidden;
        border-radius: 28px !important;
        background: linear-gradient(135deg, #0b1220 0%, #13203b 45%, #1d4ed8 100%);
        color: white;
        border: none !important;
        box-shadow: 0 18px 40px rgba(15, 23, 42, .18);
    }

    .hrd-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 15% 20%, rgba(212,175,55,.22), transparent 30%),
            radial-gradient(circle at 85% 80%, rgba(255,255,255,.10), transparent 25%),
            linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px),
            linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px);
        background-size: auto, auto, 34px 34px, 34px 34px;
        pointer-events: none;
    }

    .hrd-hero-content {
        position: relative;
        z-index: 1;
        padding: 28px;
    }

    .hrd-title {
        font-size: 1.65rem;
        font-weight: 900;
        line-height: 1.15;
        letter-spacing: -.5px;
        margin-bottom: 6px;
    }

    .hrd-subtitle {
        font-size: .92rem;
        color: rgba(255,255,255,.78);
        max-width: 920px;
        line-height: 1.7;
    }

    .hrd-hero-chip {
        color: #fff !important;
        border-color: rgba(255,255,255,.28) !important;
        background: rgba(255,255,255,.08) !important;
        font-weight: 700 !important;
    }

    .hrd-hero-btn {
        min-height: 42px;
        border-radius: 14px !important;
        font-weight: 800 !important;
    }

    .hrd-metrics-grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 14px;
    }

    .hrd-metric-card {
        grid-column: span 2;
        min-height: 122px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        background: white;
        padding: 18px;
        transition: all .25s ease;
    }

    .hrd-metric-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 32px rgba(15,23,42,.07);
        border-color: #cbd5e1;
    }

    .hrd-metric-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 12px;
    }

    .hrd-metric-label {
        font-size: .76rem;
        color: #64748b;
        font-weight: 700;
    }

    .hrd-metric-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .hrd-metric-value {
        font-size: 1.3rem;
        font-weight: 900;
        letter-spacing: -.5px;
        line-height: 1.15;
    }

    .hrd-metric-note {
        font-size: .72rem;
        color: #94a3b8;
        margin-top: 8px;
        line-height: 1.5;
    }

    .hrd-shell-card {
        border-radius: 24px !important;
        border: 1px solid #e2e8f0 !important;
        background: white !important;
        overflow: hidden;
    }

    .hrd-tabs .mud-tabs-toolbar {
        padding: 16px 18px;
        background: linear-gradient(180deg, #fbfdff 0%, #f8fafc 100%);
        border-bottom: 1px solid #e2e8f0;
        gap: 8px;
    }

    .hrd-tabs .mud-tab {
        color: #64748b !important;
        font-weight: 800 !important;
        font-size: .92rem !important;
        border-radius: 14px !important;
        min-height: 48px;
        padding-inline: 18px !important;
        transition: all .25s ease;
    }

    .hrd-tabs .mud-tab:hover {
        background: rgba(37,99,235,.08) !important;
        color: #2563eb !important;
    }

    .hrd-tabs .mud-tab.mud-tab-active {
        background: linear-gradient(135deg, #2563eb, #1d4ed8) !important;
        color: white !important;
        box-shadow: 0 10px 24px rgba(37,99,235,.18);
    }

    .hrd-tabs .mud-tab.mud-tab-active .mud-icon-root {
        color: white !important;
    }

    .hrd-tabs .mud-tab:focus,
    .hrd-tabs .mud-tab:focus-visible,
    .hrd-tabs .mud-tab.mud-tab-active:focus,
    .hrd-tabs .mud-tab.mud-tab-active:focus-visible {
        outline: none !important;
        box-shadow: none !important;
    }

    ::deep .hrd-tabs .mud-tab::before,
    ::deep .hrd-tabs .mud-tab::after,
    ::deep .hrd-tabs .mud-tab-slider {
        display: none !important;
        content: none !important;
    }

    .hrd-tab-panel {
        padding: 0 !important;
    }

    .hrd-tab-content {
        padding: 22px;
    }

    .hrd-section-card {
        height: 100%;
        border-radius: 20px !important;
        border: 1px solid #e2e8f0 !important;
        background: white !important;
        padding: 18px;
    }

    .hrd-soft-card {
        background: #f8fafc !important;
    }

    .hrd-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .hrd-section-title-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .hrd-section-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .hrd-section-title {
        font-size: 1rem;
        font-weight: 900;
        color: #0f172a;
        margin: 0;
    }

    .hrd-section-subtitle {
        font-size: .78rem;
        color: #64748b;
        margin-top: 2px;
    }

    .hrd-action-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
    }

    .hrd-mini-metric {
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        background: white;
        padding: 14px;
        height: 100%;
    }

    .hrd-mini-label {
        font-size: .74rem;
        color: #64748b;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .hrd-mini-value {
        font-size: 1rem;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .hrd-item-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .hrd-item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px dashed #e2e8f0;
    }

    .hrd-item-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .hrd-item-name {
        font-size: .9rem;
        font-weight: 800;
        color: #0f172a;
    }

    .hrd-item-meta {
        font-size: .74rem;
        color: #64748b;
        margin-top: 2px;
        line-height: 1.5;
    }

    .hrd-inline-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 12px;
    }

    .hrd-dept-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px dashed #e2e8f0;
    }

    .hrd-dept-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .hrd-bar {
        height: 10px;
        border-radius: 999px;
        background: #e2e8f0;
        overflow: hidden;
        width: 140px;
        flex-shrink: 0;
    }

    .hrd-bar-fill {
        height: 100%;
        border-radius: 999px;
    }

    .hrd-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 180px;
        text-align: center;
        color: #94a3b8;
    }

    .hrd-empty .mud-icon-root {
        font-size: 52px !important;
        opacity: .45;
    }

    .hrd-alert-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .hrd-alert-item {
        border-radius: 16px;
        padding: 14px;
        border: 1px solid transparent;
    }

    .hrd-alert-warning {
        background: #fff7ed;
        border-color: #fdba74;
    }

    .hrd-alert-danger {
        background: #fef2f2;
        border-color: #fecaca;
    }

    .hrd-alert-info {
        background: #eff6ff;
        border-color: #bfdbfe;
    }

    .hrd-alert-success {
        background: #ecfdf5;
        border-color: #bbf7d0;
    }

    .hrd-alert-title {
        font-size: .88rem;
        font-weight: 900;
        margin-bottom: 4px;
        color: #0f172a;
    }

    .hrd-alert-text {
        font-size: .78rem;
        color: #475569;
        line-height: 1.65;
    }

    @@media (max-width: 1200px) {
        .hrd-metric-card {
            grid-column: span 3;
        }
    }

    @@media (max-width: 900px) {
        .hrd-metric-card {
            grid-column: span 4;
        }
    }

    @@media (max-width: 700px) {
        .hrd-metric-card {
            grid-column: span 6;
        }

        .hrd-hero-content,
        .hrd-tab-content {
            padding: 18px;
        }
    }

    @@media (max-width: 480px) {
        .hrd-metric-card {
            grid-column: span 12;
        }

        .hrd-title {
            font-size: 1.3rem;
        }
    }
</style>

<div class="hrd-root">
@if (_loading)
{
    <MudPaper Class="pa-10 rounded-xl text-center">
        <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="mt-4">جاري تحميل لوحة الموارد البشرية...</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">يتم الآن تجهيز مؤشرات التشغيل والحضور والرواتب.</MudText>
    </MudPaper>
}
else
{
    <MudPaper Class="hrd-hero mb-4" Elevation="0">
        <div class="hrd-hero-content">
            <div class="d-flex align-center justify-space-between flex-wrap gap-4">
                <div>
                    <div class="hrd-title">لوحة تحكم الموارد البشرية</div>
                    <div class="hrd-subtitle">
                        مركز قيادة تنفيذي لمتابعة القوة العاملة، الحضور اليومي، الرواتب، الدفعات خارج الراتب، السلف، والاستثناءات من شاشة موحدة.
                    </div>
                    <div class="d-flex gap-2 flex-wrap mt-3">
                        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Class="hrd-hero-chip">تاريخ اليوم: @DateTime.Today.ToString("dd/MM/yyyy")</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Class="hrd-hero-chip">شهر التشغيل: @CurrentMonthLabel</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Class="hrd-hero-chip">المستخدم الحالي: @_currentUserDisplay</MudChip>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.People" Class="hrd-hero-btn" OnClick='@(() => Nav.NavigateTo("/employees"))'>الموظفون</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Fingerprint" Class="hrd-hero-btn" OnClick='@(() => Nav.NavigateTo("/attendance"))'>الحضور</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Payments" Class="hrd-hero-btn" OnClick='@(() => Nav.NavigateTo("/hr/payroll"))'>الرواتب</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh" Class="hrd-hero-btn" OnClick="LoadAsync">تحديث</MudButton>
                </div>
            </div>
        </div>
    </MudPaper>

    <div class="hrd-metrics-grid mb-4">
        @MetricCard("إجمالي الموظفين", (_employeeStats?.TotalEmployees ?? 0).ToString(), "كل السجلات", "#2563eb", "#eff6ff", Icons.Material.Filled.Groups)
        @MetricCard("نشطين", (_employeeStats?.ActiveCount ?? 0).ToString(), "جاهزين للتشغيل", "#10b981", "#ecfdf5", Icons.Material.Filled.Badge)
        @MetricCard("حضور اليوم", (_todayStats?.TodayPresent ?? 0).ToString(), "المسجلين اليوم", "#0ea5e9", "#f0fdfa", Icons.Material.Filled.HowToReg)
        @MetricCard("غياب اليوم", (_todayStats?.TodayAbsent ?? 0).ToString(), "يحتاج متابعة", "#ef4444", "#fef2f2", Icons.Material.Filled.PersonOff)
        @MetricCard("تأخير اليوم", (_todayStats?.TodayLate ?? 0).ToString(), FormatMinutes(_todayStats?.TotalLateMinutes ?? 0), "#f59e0b", "#fff7ed", Icons.Material.Filled.Schedule)
        @MetricCard("الشيفتات النشطة", (_shiftStats?.ActiveCount ?? 0).ToString(), "من إجمالي الشيفتات", "#7c3aed", "#f5f3ff", Icons.Material.Filled.EventAvailable)
        @MetricCard("رواتب تنتظر المراجعة", (_payrollStats?.ReviewCount ?? 0).ToString(), "إجراء عاجل", "#f97316", "#fff7ed", Icons.Material.Filled.HourglassTop)
        @MetricCard("دفعات خارج الراتب", (_offPayrollStats?.ReviewCount ?? 0).ToString(), "طلبات معلقة", "#06b6d4", "#ecfeff", Icons.Material.Filled.CardGiftcard)
        @MetricCard("السلف النشطة", (_loanStats?.ActiveLoansCount ?? 0).ToString(), (_loanStats?.TotalRemainingAmount ?? 0).ToString("N0") + " جـ متبقي", "#8b5cf6", "#f5f3ff", Icons.Material.Filled.AccountBalanceWallet)
        @MetricCard("أقساط pending", (_loanStats?.PendingInstallmentsCount ?? 0).ToString(), "تحتاج متابعة", "#e11d48", "#fff1f2", Icons.Material.Filled.PendingActions)
        @MetricCard("إجمالي الرواتب", (_payrollStats?.TotalNetThisMonth ?? 0).ToString("N0") + " جـ", "صافي هذا الشهر", "#059669", "#ecfdf5", Icons.Material.Filled.PriceCheck)
        @MetricCard("استثناءات الشهر", ((_exemptionStats?.PendingCount ?? 0) + (_exemptionStats?.ApprovedCount ?? 0)).ToString(), "نشاط الاستثناءات", "#3b82f6", "#eff6ff", Icons.Material.Filled.EventBusy)
    </div>

    <MudPaper Class="hrd-shell-card" Elevation="0">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="hrd-tab-panel" Class="hrd-tabs" ActivePanelIndex="@_activeTab" ActivePanelIndexChanged="OnTabChangedAsync">

            <MudTabPanel Text="نظرة تنفيذية" Icon="@Icons.Material.Filled.DashboardCustomize">
                <div class="hrd-tab-content">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudPaper Class="hrd-section-card h-100" Elevation="0">
                                <div class="hrd-section-head">
                                    <div class="hrd-section-title-wrap">
                                        <div class="hrd-section-icon" style="background:#eff6ff;color:#2563eb;">
                                            <MudIcon Icon="@Icons.Material.Filled.Bolt" />
                                        </div>
                                        <div>
                                            <div class="hrd-section-title">الإجراءات السريعة</div>
                                            <div class="hrd-section-subtitle">اختصارات مباشرة لأهم العمليات اليومية</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="hrd-action-grid">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AttachMoney" OnClick='@(() => Nav.NavigateTo("/hr/payroll/processor"))'>معالجة المرتبات</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.ReceiptLong" OnClick='@(() => Nav.NavigateTo("/hr/payroll"))'>سجل الرواتب</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.CardGiftcard" OnClick='@(() => Nav.NavigateTo("/hr/payroll/bonuses"))'>دفعات خارج الراتب</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.EditCalendar" OnClick='@(() => Nav.NavigateTo("/hr/payroll/attendance"))'>الحضور اليدوي</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AccountBalance" OnClick='@(() => Nav.NavigateTo("/hr/loans"))'>السلف</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.EventBusy" OnClick='@(() => Nav.NavigateTo("/hr/exemptions"))'>الاستثناءات</MudButton>
                                </div>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Class="hrd-section-card h-100" Elevation="0">
                                <div class="hrd-section-head">
                                    <div class="hrd-section-title-wrap">
                                        <div class="hrd-section-icon" style="background:#ecfdf5;color:#059669;">
                                            <MudIcon Icon="@Icons.Material.Filled.FactCheck" />
                                        </div>
                                        <div>
                                            <div class="hrd-section-title">صحة الحضور اليوم</div>
                                            <div class="hrd-section-subtitle">مؤشرات فورية للحضور والانضباط</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="hrd-inline-stats">
                                    @MiniMetric("نسبة الحضور", (_todayStats?.AttendanceRate ?? 0).ToString("N1") + "%", Math.Min((double)(_todayStats?.AttendanceRate ?? 0), 100), "#10b981")
                                    @MiniMetric("إجمالي التأخير", FormatMinutes(_todayStats?.TotalLateMinutes ?? 0), Math.Min((_todayStats?.TotalLateMinutes ?? 0) / 5.0, 100), "#f59e0b")
                                    @MiniMetric("ساعات الجزاءات", (_todayStats?.TotalPenaltyHours ?? 0).ToString("N1") + " ساعة", Math.Min((double)(_todayStats?.TotalPenaltyHours ?? 0) * 10, 100), "#ef4444")
                                </div>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Class="hrd-section-card h-100" Elevation="0">
                                <div class="hrd-section-head">
                                    <div class="hrd-section-title-wrap">
                                        <div class="hrd-section-icon" style="background:#fff7ed;color:#f59e0b;">
                                            <MudIcon Icon="@Icons.Material.Filled.Savings" />
                                        </div>
                                        <div>
                                            <div class="hrd-section-title">ملخص مالي HR</div>
                                            <div class="hrd-section-subtitle">رواتب وسلف ودفعات مستقلة</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="hrd-item-list">
                                    @InfoLine("صافي الرواتب هذا الشهر", (_payrollStats?.TotalNetThisMonth ?? 0).ToString("N0") + " جـ")
                                    @InfoLine("خصومات السلف هذا الشهر", (_payrollStats?.TotalLoanDeductions ?? 0).ToString("N0") + " جـ")
                                    @InfoLine("إجمالي الدفعات خارج الراتب", (_offPayrollStats?.TotalAmount ?? 0).ToString("N0") + " جـ")
                                    @InfoLine("إجمالي المتبقي في السلف", (_loanStats?.TotalRemainingAmount ?? 0).ToString("N0") + " جـ")
                                </div>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudPaper Class="hrd-section-card" Elevation="0">
                                <div class="hrd-section-head">
                                    <div class="hrd-section-title-wrap">
                                        <div class="hrd-section-icon" style="background:#eff6ff;color:#2563eb;">
                                            <MudIcon Icon="@Icons.Material.Filled.Apartment" />
                                        </div>
                                        <div>
                                            <div class="hrd-section-title">أفضل أقسام الحضور</div>
                                            <div class="hrd-section-subtitle">أعلى نسب حضور من بيانات الداشبورد</div>
                                        </div>
                                    </div>
                                </div>

                                @if (_attendanceDashboard?.ByDepartment.Any() == true)
                                {
                                    @foreach (var dept in _attendanceDashboard.ByDepartment.OrderByDescending(x => x.AttendanceRate).Take(6))
                                    {
                                        <div class="hrd-dept-row">
                                            <div>
                                                <div class="hrd-item-name">@dept.Department</div>
                                                <div class="hrd-item-meta">@dept.PresentCount حاضر • @dept.AbsentCount غائب • @dept.EmployeeCount موظف</div>
                                            </div>
                                            <div class="d-flex align-center gap-2">
                                                <span class="hrd-item-name">@dept.AttendanceRate.ToString("N1")%</span>
                                                <div class="hrd-bar">
                                                    <div class="hrd-bar-fill" style="width:@Math.Min(dept.AttendanceRate, 100)%; background:linear-gradient(90deg,#10b981,#34d399);"></div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="hrd-empty">
                                        <MudIcon Icon="@Icons.Material.Filled.BarChart" />
                                        <div>لا توجد بيانات أقسام كافية حاليًا.</div>
                                    </div>
                                }
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudPaper Class="hrd-section-card" Elevation="0">
                                <div class="hrd-section-head">
                                    <div class="hrd-section-title-wrap">
                                        <div class="hrd-section-icon" style="background:#fef2f2;color:#ef4444;">
                                            <MudIcon Icon="@Icons.Material.Filled.WarningAmber" />
                                        </div>
                                        <div>
                                            <div class="hrd-section-title">مركز التنبيهات</div>
                                            <div class="hrd-section-subtitle">أهم الإجراءات التي تحتاج تدخل الآن</div>
                                        </div>
                                    </div>
                                </div>

