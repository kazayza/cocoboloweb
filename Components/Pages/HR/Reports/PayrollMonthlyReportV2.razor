@page "/hr/reports/payroll-v2"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using ApexCharts
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Radzen
@using Radzen.Blazor

@* ══ Aliases ══ *@
@using MudVariant    = MudBlazor.Variant
@using MudColor      = MudBlazor.Color
@using MudSize       = MudBlazor.Size
@using MudAlign      = MudBlazor.Align
@using ApexTooltip   = ApexCharts.Tooltip
@using ApexLegendPos = ApexCharts.LegendPosition

@inject IPayrollService PayrollService
@inject IJSRuntime      JS
@inject ISnackbar       Snackbar

<PageTitle>مسير الرواتب الشهري</PageTitle>

<style>
    /* ═══════════════════════════════════════════
       PAYROLL REPORT 2026 — Premium Design
       ═══════════════════════════════════════════ */

    .pr-root {
        padding-top: max(1rem, env(safe-area-inset-top));
        padding-bottom: max(2rem, env(safe-area-inset-bottom));
        padding-left: max(1rem, env(safe-area-inset-left));
        padding-right: max(1rem, env(safe-area-inset-right));
        min-height: 100svh;
        background: #F8FAFC;
    }

    /* ─── Premium Header ─── */
    .pr-hero {
        border-radius: 28px !important;
        overflow: hidden;
        border: none !important;
        position: relative;
    }

    .pr-hero-bg {
        position: relative;
        background: linear-gradient(140deg, #0C1222 0%, #162033 35%, #1E3A5F 70%, #1A4B7A 100%);
        padding: 32px 28px;
    }

    .pr-hero-bg::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 15% 85%, rgba(212,175,55,0.18) 0%, transparent 40%),
            radial-gradient(circle at 85% 15%, rgba(59,130,246,0.12) 0%, transparent 40%),
            radial-gradient(circle at 50% 50%, rgba(255,255,255,0.02) 0%, transparent 60%);
        pointer-events: none;
    }

    .pr-hero-bg::after {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        background: rgba(212,175,55,0.04);
        filter: blur(60px);
        pointer-events: none;
    }

    .pr-hero-content {
        position: relative;
        z-index: 3;
    }

    .pr-hero-icon-wrap {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: rgba(212,175,55,0.12);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212,175,55,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .pr-hero-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: white;
        letter-spacing: -0.8px;
        line-height: 1.2;
    }

    .pr-hero-sub {
        color: rgba(255,255,255,0.45);
        font-size: 0.82rem;
        margin-top: 4px;
    }

    .pr-hero-btn {
        border-radius: 12px !important;
        font-weight: 600 !important;
        letter-spacing: 0.2px;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.1) !important;
        transition: all 0.3s ease !important;
    }

    .pr-hero-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    }

    .pr-hero-btn-green {
        background: rgba(16,185,129,0.85) !important;
        color: white !important;
    }

    .pr-hero-btn-blue {
        background: rgba(59,130,246,0.85) !important;
        color: white !important;
    }

    /* ─── Filter Panel ─── */
    .pr-filter {
        border-radius: 20px !important;
        border: 1px solid #E2E8F0 !important;
        background: white !important;
        transition: all 0.3s ease;
    }

    .pr-filter:hover {
        box-shadow: 0 2px 16px rgba(0,0,0,0.03);
    }

    /* ─── Stat Pill Cards ─── */
    .stat-pill {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 14px;
        border: 1px solid #F1F5F9;
        background: white;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        cursor: default;
    }

    .stat-pill::before {
        content: '';
        position: absolute;
        right: 0;
        top: 0;
        width: 3px;
        height: 100%;
        border-radius: 0 6px 6px 0;
        transition: width 0.3s ease;
    }

    .stat-pill:hover {
        border-color: #E2E8F0;
        box-shadow: 0 4px 16px rgba(0,0,0,0.04);
        transform: translateY(-1px);
    }

    .stat-pill:hover::before {
        width: 4px;
    }

    .stat-pill-icon {
        width: 38px;
        height: 38px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-pill-val {
        font-size: 1.15rem;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.3px;
    }

    .stat-pill-lbl {
        font-size: 0.68rem;
        color: #94A3B8;
        font-weight: 500;
    }

    /* ─── Modern Card ─── */
    .mc {
        border: 1px solid #E2E8F0 !important;
        border-radius: 20px !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: white !important;
    }

    .mc:hover {
        border-color: #CBD5E1 !important;
        box-shadow: 0 8px 32px rgba(0,0,0,0.04) !important;
    }

    .mc-head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
    }

    .mc-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .mc-title {
        font-weight: 700;
        font-size: 0.92rem;
        color: #1E293B;
    }

    /* ─── RadzenDataGrid Premium ─── */
    .rz-pr-grid {
        border-radius: 0 0 16px 16px !important;
        overflow: hidden;
    }

    .rz-pr-grid .rz-datatable-thead > tr > th {
        background: #0F172A !important;
        color: rgba(255,255,255,0.9) !important;
        font-weight: 600 !important;
        font-size: 0.75rem !important;
        padding: 12px 14px !important;
        white-space: nowrap;
        border: none !important;
        text-transform: none;
        letter-spacing: 0.2px;
    }

    .rz-pr-grid .rz-datatable-thead > tr > th:first-child {
        border-radius: 0 !important;
    }

    .rz-pr-grid .rz-datatable-thead > tr > th .rz-sortable-column-icon {
        color: rgba(255,255,255,0.4) !important;
    }

    .rz-pr-grid .rz-datatable-thead > tr > th .rz-cell-filter {
        color: rgba(255,255,255,0.5) !important;
    }

    .rz-pr-grid .rz-datatable-tbody > tr > td {
        padding: 10px 14px !important;
        font-size: 0.8rem !important;
        border-bottom: 1px solid #F1F5F9 !important;
        color: #334155;
    }

    .rz-pr-grid .rz-datatable-tbody > tr:hover > td {
        background: #F0F9FF !important;
    }

    .rz-pr-grid .rz-datatable-tbody > tr:nth-child(even) > td {
        background: #FAFBFC;
    }

    .rz-pr-grid .rz-datatable-tbody > tr:nth-child(even):hover > td {
        background: #F0F9FF !important;
    }

    .rz-pr-grid .rz-datatable-tfoot > tr > td {
        background: #F1F5F9 !important;
        font-weight: 800 !important;
        border-top: 2px solid #CBD5E1 !important;
        padding: 12px 14px !important;
        font-size: 0.82rem !important;
    }

    .rz-pr-grid .rz-pager {
        border-top: 1px solid #E2E8F0;
        padding: 10px 16px;
        background: #FAFBFC;
    }

    /* ─── Value Styles ─── */
    .v-neg { color: #DC2626; font-weight: 600; }
    .v-gold { color: #B8860B; font-weight: 800; }
    .v-green { color: #059669; font-weight: 700; }
    .v-muted { color: #94A3B8; }

    .emp-name { font-weight: 700; font-size: 0.82rem; color: #1E293B; }
    .emp-title { font-size: 0.68rem; color: #94A3B8; margin-top: 1px; }

    .dept-tag {
        background: #F1F5F9;
        padding: 3px 10px;
        border-radius: 8px;
        font-size: 0.72rem;
        font-weight: 500;
        color: #475569;
    }

    .absence-tag {
        background: #FEF2F2;
        color: #DC2626;
        padding: 2px 10px;
        border-radius: 8px;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .status-pill {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.3px;
    }

    .status-paid {
        background: linear-gradient(135deg, #F0FDF4, #DCFCE7);
        color: #15803D;
    }

    .status-unpaid {
        background: linear-gradient(135deg, #FFFBEB, #FEF3C7);
        color: #B45309;
    }

    .grid-header-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        border-bottom: 1px solid #F1F5F9;
        background: white;
        border-radius: 20px 20px 0 0;
    }

    /* ─── ApexCharts RTL ─── */
    .apexcharts-canvas text,
    .apexcharts-legend-text { font-family: inherit !important; }
    .apexcharts-tooltip {
        direction: rtl !important;
        text-align: right !important;
        border-radius: 12px !important;
        box-shadow: 0 8px 32px rgba(0,0,0,0.12) !important;
    }

    /* ─── Empty State ─── */
    .empty-state-card {
        border-radius: 24px !important;
        border: 2px dashed #E2E8F0 !important;
        background: #FAFBFC !important;
    }

    /* ─── Print ─── */
    .print-only { display: none; }

    @@media print {
        .no-print { display: none !important; }
        .print-only { display: block !important; }
        .rz-pr-grid .rz-datatable-thead > tr > th {
            background: #1E293B !important;
            color: white !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .rz-pr-grid .rz-pager { display: none !important; }
        .stat-pill, .mc { break-inside: avoid; }
        .print-header {
            text-align: center;
            margin-bottom: 24px;
            border-bottom: 3px solid #0F172A;
            padding-bottom: 12px;
        }
        .print-header h2 { margin: 0; font-size: 1.5rem; font-weight: 800; }
        .print-header p { margin: 6px 0 0; color: #64748B; font-size: 0.85rem; }
        .print-footer {
            text-align: center;
            margin-top: 32px;
            padding-top: 12px;
            border-top: 1px solid #CBD5E1;
            font-size: 0.75rem;
            color: #94A3B8;
        }
    }

    /* ─── Responsive ─── */
    @@media (max-width: 768px) {
        .pr-hero-bg { padding: 24px 20px; }
        .pr-hero-title { font-size: 1.2rem; }
        .pr-hero-icon-wrap { width: 44px; height: 44px; border-radius: 12px; }
        .mc { border-radius: 16px !important; }
        .stat-pill { padding: 8px 12px; border-radius: 12px; }
        .stat-pill-icon { width: 32px; height: 32px; border-radius: 8px; }
        .stat-pill-val { font-size: 0.95rem; }
        .grid-header-bar { padding: 12px 16px; border-radius: 16px 16px 0 0; }
    }

    @@media (max-width: 380px) {
        .stat-pill-val { font-size: 0.85rem; }
        .stat-pill-lbl { font-size: 0.6rem; }
        .pr-hero-title { font-size: 1.05rem; }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 pr-root">

    @* ══════════════════════════════════════════════════════════
       PREMIUM HEADER
       ══════════════════════════════════════════════════════════ *@
    <MudPaper Class="mb-5 pr-hero no-print" Elevation="0">
        <div class="pr-hero-bg">
            <div class="pr-hero-content">
                <div class="d-flex align-center justify-space-between flex-wrap gap-4">
                    <div class="d-flex align-center gap-3">
                        <div class="pr-hero-icon-wrap">
                            <MudIcon Icon="@Icons.Material.Rounded.Payments"
                                     Size="@MudSize.Large" Style="color:#D4AF37;" />
                        </div>
                        <div>
                            <div class="pr-hero-title">مسير الرواتب الشهري</div>
                            <div class="pr-hero-sub">
                                تحليل شامل للرواتب والخصومات — @DateTime.Now.ToString("MMMM yyyy")
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <MudButton Class="pr-hero-btn pr-hero-btn-green"
                                   StartIcon="@Icons.Material.Rounded.FileDownload"
                                   Size="@MudSize.Small"
                                   OnClick="ExportExcelAsync"
                                   Disabled="@(!_data.Any() || _exporting)">
                            @(_exporting ? "جاري التصدير..." : "تصدير Excel")
                        </MudButton>
                        <MudButton Class="pr-hero-btn pr-hero-btn-blue"
                                   StartIcon="@Icons.Material.Rounded.Print"
                                   Size="@MudSize.Small"
                                   OnClick="@(() => JS.InvokeVoidAsync("printPage"))"
                                   Disabled="@(!_data.Any())">
                            طباعة التقرير
                        </MudButton>
                    </div>
                </div>
            </div>
        </div>
    </MudPaper>

    @* ══════════════════════════════════════════════════════════
       FILTER PANEL
       ══════════════════════════════════════════════════════════ *@
    <MudPaper Class="pa-5 mb-5 pr-filter no-print" Elevation="0">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4">
                <MudTextField T="string"
                              @bind-Value="_month"
                              Label="الشهر"
                              InputType="InputType.Month"
                              Variant="@MudVariant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                              FullWidth />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="string"
                           @bind-Value="_statusFilter"
                           Label="حالة الدفع"
                           Variant="@MudVariant.Outlined"
                           Margin="Margin.Dense"
                           Clearable FullWidth
                           AdornmentIcon="@Icons.Material.Filled.FactCheck"
                           Adornment="Adornment.Start">
                    <MudSelectItem T="string" Value="@("مدفوع")">مدفوع</MudSelectItem>
                    <MudSelectItem T="string" Value="@("غير مدفوع")">غير مدفوع</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-end">
                <MudButton Variant="@MudVariant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.Search"
                           OnClick="LoadAsync"
                           Disabled="@_loading"
                           FullWidth
                           Style="height:40px;border-radius:12px;font-weight:700;">
                    @(_loading ? "جاري التحميل..." : "عرض التقرير")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ══════════════════════════════════════════════════════════
       LOADING SKELETON
       ══════════════════════════════════════════════════════════ *@
    @if (_loading)
    {
        <MudGrid Spacing="2" Class="mb-4">
            @for (int i = 0; i < 5; i++)
            {
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Class="pa-3" Elevation="0" Style="border:1px solid #F1F5F9;border-radius:14px;">
                        <MudSkeleton SkeletonType="SkeletonType.Circle" Width="38px" Height="38px" Class="mb-2" />
                        <MudSkeleton Width="55%" Height="18px" Class="mb-1" />
                        <MudSkeleton Width="35%" Height="12px" />
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-5 mc" Elevation="0">
                    <MudSkeleton Width="30%" Height="20px" Class="mb-4" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="260px" Class="rounded-lg" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mc" Elevation="0">
                    <MudSkeleton Width="40%" Height="20px" Class="mb-4" />
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="260px" Class="rounded-lg" />
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudPaper Class="pa-5 mc" Elevation="0">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="350px" Class="rounded-lg" />
        </MudPaper>
    }
    else if (_data.Any())
    {
        @* ══════════════════════════════════════════════════════════
           STAT PILLS
           ══════════════════════════════════════════════════════════ *@
        <MudGrid Spacing="2" Class="mb-5 no-print">
            @foreach (var s in _stats)
            {
                <MudItem xs="6" sm="4" md="2">
                    <div class="stat-pill">
                        <div style="@($"position:absolute;right:0;top:0;width:3px;height:100%;background:{s.Accent};border-radius:0 6px 6px 0;")"></div>
                        <div class="stat-pill-icon" style="background:@s.IconBg;">
                            <MudIcon Icon="@s.Icon" Style="@($"color:{s.Accent};font-size:18px;")" />
                        </div>
                        <div>
                            <div class="stat-pill-val" style="color:@s.Accent;">@s.Value</div>
                            <div class="stat-pill-lbl">@s.Label</div>
                        </div>
                    </div>
                </MudItem>
            }
        </MudGrid>

        @* ══════════════════════════════════════════════════════════
           CHARTS
           ══════════════════════════════════════════════════════════ *@
        <MudGrid Spacing="4" Class="mb-5 no-print">
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-5 mc" Elevation="0">
                    <div class="mc-head">
                        <div class="mc-icon" style="background:#DBEAFE;">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="color:#3B82F6;font-size:17px;" />
                        </div>
                        <span class="mc-title">صافي الرواتب حسب القسم</span>
                    </div>
                    <ApexChart TItem="DeptChartItem" Options="_barOpts" Height="280">
                        <ApexPointSeries TItem="DeptChartItem" Items="_deptChartData"
                                         Name="صافي الرواتب" SeriesType="SeriesType.Bar"
                                         XValue="e => e.Department" YValue="e => e.TotalNet" />
                    </ApexChart>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mc" Elevation="0" Style="height:100%;">
                    <div class="mc-head">
                        <div class="mc-icon" style="background:#FEE2E2;">
                            <MudIcon Icon="@Icons.Material.Filled.DonutLarge" Style="color:#EF4444;font-size:17px;" />
                        </div>
                        <span class="mc-title">تحليل الخصومات</span>
                    </div>
                    <ApexChart TItem="DeductionChartItem" Options="_donutOpts" Height="280">
                        <ApexPointSeries TItem="DeductionChartItem" Items="_deductionChartData"
                                         Name="الخصومات" SeriesType="SeriesType.Donut"
                                         XValue="e => e.Type" YValue="e => e.Amount" />
                    </ApexChart>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ══════════════════════════════════════════════════════════
           PRINT HEADER
           ══════════════════════════════════════════════════════════ *@
        <div class="print-only print-header">
            <h2>مسير الرواتب الشهري</h2>
            <p>الشهر: @_month | عدد الموظفين: @_cachedFiltered.Count | طُبع: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</p>
        </div>

        @* ══════════════════════════════════════════════════════════
           DATA GRID
           ══════════════════════════════════════════════════════════ *@
        <MudPaper Class="mc overflow-hidden" Elevation="0" Style="border-radius:20px !important;">

            <div class="grid-header-bar no-print">
                <div class="d-flex align-center gap-2">
                    <div class="mc-icon" style="background:#FEF3C7;">
                        <MudIcon Icon="@Icons.Material.Filled.TableChart" Style="color:#D4AF37;font-size:17px;" />
                    </div>
                    <span class="mc-title">بيانات الرواتب التفصيلية</span>
                </div>
                <MudChip T="string" Size="@MudSize.Small"
                         Variant="@MudVariant.Text" Color="@MudColor.Primary"
                         Style="font-weight:700;">
                    @_cachedFiltered.Count موظف
                </MudChip>
            </div>

            <RadzenDataGrid Data="@_cachedFiltered"
                            TItem="PayrollListDto"
                            AllowSorting="true"
                            AllowFiltering="true"
                            AllowColumnResize="true"
                            AllowGrouping="true"
                            AllowPaging="true"
                            PageSize="25"
                            PagerHorizontalAlign="HorizontalAlign.Center"
                            ShowPagingSummary="true"
                            PagingSummaryFormat="عرض {0} إلى {1} من {2} سجل"
                            FilterMode="FilterMode.SimpleWithMenu"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Density="Density.Compact"
                            GridLines="DataGridGridLines.Horizontal"
                            Style="min-height:420px;"
                            Class="rz-pr-grid">
                <Columns>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Title="م" Width="50px"
                                          Sortable="false" Filterable="false"
                                          TextAlign="TextAlign.Center"
                                          Frozen="true">
                        <Template Context="data">
                            <span style="color:#94A3B8;font-weight:600;">@(_cachedFiltered.IndexOf(data) + 1)</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="EmployeeName"
                                          Title="الموظف" Width="200px"
                                          Frozen="true">
                        <Template Context="data">
                            <div>
                                <div class="emp-name">@data.EmployeeName</div>
                                <div class="emp-title">@data.JobTitle</div>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="Department"
                                          Title="القسم" Width="140px">
                        <Template Context="data">
                            <span class="dept-tag">@(data.Department ?? "—")</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="WorkingDaysInMonth"
                                          Title="أيام العمل" Width="85px"
                                          TextAlign="TextAlign.Center" />

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="PresentDays"
                                          Title="الحضور" Width="80px"
                                          TextAlign="TextAlign.Center">
                        <Template Context="data">
                            <span class="v-green">@data.PresentDays</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="AbsenceDays"
                                          Title="الغياب" Width="80px"
                                          TextAlign="TextAlign.Center">
                        <Template Context="data">
                            @if (data.AbsenceDays > 0)
                            {
                                <span class="absence-tag">@data.AbsenceDays</span>
                            }
                            else
                            {
                                <span class="v-green">✓</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="BasicSalary"
                                          Title="الراتب الأساسي" Width="120px"
                                          FormatString="{0:N2}"
                                          TextAlign="TextAlign.End" />

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="AbsenceDeduction"
                                          Title="خصم غياب" Width="100px"
                                          TextAlign="TextAlign.End">
                        <Template Context="data">
                            <span class="@(data.AbsenceDeduction > 0 ? "v-neg" : "v-muted")">
                                @(data.AbsenceDeduction > 0 ? $"-{data.AbsenceDeduction:N2}" : "—")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="LateDeduction"
                                          Title="خصم تأخير" Width="100px"
                                          TextAlign="TextAlign.End">
                        <Template Context="data">
                            <span class="@(data.LateDeduction > 0 ? "v-neg" : "v-muted")">
                                @(data.LateDeduction > 0 ? $"-{data.LateDeduction:N2}" : "—")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="LoanDeduction"
                                          Title="خصم سلفة" Width="100px"
                                          TextAlign="TextAlign.End">
                        <Template Context="data">
                            <span class="@(data.LoanDeduction > 0 ? "v-neg" : "v-muted")">
                                @(data.LoanDeduction > 0 ? $"-{data.LoanDeduction:N2}" : "—")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="NetSalary"
                                          Title="الصافي" Width="130px"
                                          TextAlign="TextAlign.End">
                        <Template Context="data">
                            <span class="v-gold" style="font-size:0.88rem;">@data.NetSalary.ToString("N2")</span>
                        </Template>
                        <FooterTemplate>
                            <span class="v-gold" style="font-size:0.9rem;">
                                @_cachedFiltered.Sum(d => d.NetSalary).ToString("N2")
                            </span>
                        </FooterTemplate>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="PayrollListDto"
                                          Property="PaymentStatus"
                                          Title="الحالة" Width="110px"
                                          TextAlign="TextAlign.Center">
                        <Template Context="data">
                            <span class="status-pill @(data.PaymentStatus == "مدفوع" ? "status-paid" : "status-unpaid")">
                                @data.PaymentStatus
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                </Columns>
            </RadzenDataGrid>
        </MudPaper>

        <div class="print-footer print-only">
            طُبع بواسطة نظام COCOBOLOERP | @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
        </div>
    }
    else if (_searched)
    {
        <MudPaper Class="pa-10 empty-state-card text-center" Elevation="0">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="@MudSize.Large"
                     Style="color:#CBD5E1;font-size:64px;" />
            <MudText Typo="Typo.h6" Style="color:#64748B;font-weight:700;" Class="mt-4">
                لا توجد بيانات رواتب
            </MudText>
            <MudText Typo="Typo.body2" Style="color:#94A3B8;" Class="mt-1">
                لم يتم العثور على سجلات للشهر المحدد — جرب فترة أخرى
            </MudText>
        </MudPaper>
    }

</MudContainer>

@code {
    private string  _month        = DateTime.Today.ToString("yyyy-MM");
    private string? _statusFilter;
    private bool    _loading;
    private bool    _searched;
    private bool    _exporting;

    private List<PayrollListDto> _data           = new();
    private List<PayrollListDto> _cachedFiltered = new();

    private List<DeptChartItem>      _deptChartData      = new();
    private List<DeductionChartItem> _deductionChartData = new();
    private List<StatCardModel>      _stats              = new();

    private ApexChartOptions<DeptChartItem>      _barOpts   = new();
    private ApexChartOptions<DeductionChartItem> _donutOpts = new();

    public record DeptChartItem(string Department, decimal TotalNet);
    public record DeductionChartItem(string Type, decimal Amount);
    public record StatCardModel(string Label, string Value, string Icon, string Accent, string IconBg);

    protected override void OnInitialized() => InitChartOptions();

    private void InitChartOptions()
    {
        _barOpts = new ApexChartOptions<DeptChartItem>
        {
            Colors = new List<string> { "#3B82F6", "#6366F1" },
            Chart  = new Chart { Toolbar = new Toolbar { Show = false }, FontFamily = "inherit" },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar { BorderRadius = 8, ColumnWidth = "50%" }
            },
            Grid       = new Grid { StrokeDashArray = 3, BorderColor = "#F1F5F9" },
            Xaxis      = new XAxis { Labels = new XAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit", FontSize = "12px" } } },
            Yaxis      = new List<YAxis>
            {
                new YAxis
                {
                    Opposite = true,
                    Labels = new YAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit" } }
                }
            },
            DataLabels = new DataLabels { Enabled = false },
            Tooltip    = new ApexTooltip { Theme = Mode.Light }
        };

        _donutOpts = new ApexChartOptions<DeductionChartItem>
        {
            Colors = new List<string> { "#DC2626", "#F59E0B", "#7C3AED" },
            PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    Donut = new PlotOptionsDonut
                    {
                        Size = "74%",
                        Labels = new DonutLabels
                        {
                            Show  = true,
                            Name  = new DonutLabelName  { Show = true, FontSize = "13px" },
                            Value = new DonutLabelValue { Show = true, FontSize = "16px" },
                            Total = new DonutLabelTotal { Show = true, Label = "إجمالي الخصومات", FontSize = "12px" }
                        }
                    }
                }
            },
            Legend     = new Legend { Position = ApexLegendPos.Bottom, FontFamily = "inherit", FontSize = "13px" },
            Chart      = new Chart  { FontFamily = "inherit" },
            Stroke     = new Stroke { Colors = new List<string> { "#FFFFFF" }, Width = 3 },
            DataLabels = new DataLabels { Enabled = false }
        };
    }

    private async Task LoadAsync()
    {
        _loading  = true;
        _searched = true;
        StateHasChanged();

        try
        {
            var filter = new PayrollFilterDto
            {
                PayrollMonth = _month,
                PageNumber   = 1,
                PageSize     = 1000
            };

            var result = await PayrollService.GetPayrollsAsync(filter);
            _data = result.Items;
            RebuildCached();
            BuildChartData();
            BuildStats();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; }
    }

    private void RebuildCached()
    {
        _cachedFiltered = string.IsNullOrWhiteSpace(_statusFilter)
            ? _data.ToList()
            : _data.Where(d => d.PaymentStatus == _statusFilter).ToList();
    }

    private void BuildChartData()
    {
        _deptChartData = _data
            .GroupBy(d => d.Department ?? "بدون قسم")
            .Select(g => new DeptChartItem(g.Key, g.Sum(x => x.NetSalary)))
            .OrderByDescending(x => x.TotalNet)
            .ToList();

        _deductionChartData = new List<DeductionChartItem>
        {
            new("خصم غياب",  _data.Sum(d => d.AbsenceDeduction)),
            new("خصم تأخير", _data.Sum(d => d.LateDeduction)),
            new("خصم سلف",   _data.Sum(d => d.LoanDeduction))
        };
    }

    private void BuildStats()
    {
        _stats = new List<StatCardModel>
        {
            new("عدد الموظفين",     _cachedFiltered.Count.ToString(),
                Icons.Material.Filled.Groups,        "#3B82F6", "#EFF6FF"),
            new("صافي الرواتب",     _cachedFiltered.Sum(d => d.NetSalary).ToString("N0"),
                Icons.Material.Filled.AccountBalance,"#B8860B", "#FFFBEB"),
            new("إجمالي الخصومات",  _cachedFiltered.Sum(d => d.TotalDeductions).ToString("N0"),
                Icons.Material.Filled.RemoveCircle,  "#DC2626", "#FEF2F2"),
            new("تم الدفع",         _cachedFiltered.Count(d => d.PaymentStatus == "مدفوع").ToString(),
                Icons.Material.Filled.CheckCircle,   "#059669", "#F0FDF4"),
            new("لم يُدفع",         _cachedFiltered.Count(d => d.PaymentStatus != "مدفوع").ToString(),
                Icons.Material.Filled.PauseCircle,   "#D97706", "#FFFBEB")
        };
    }

    private async Task ExportExcelAsync()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            var bytes  = await PayrollService.ExportMonthExcelAsync(_month);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBase64", base64,
                $"مسير_الرواتب_{_month}.xlsx");
            Snackbar.Add("تم التصدير بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally { _exporting = false; }
    }
}