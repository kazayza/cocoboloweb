@page "/hr/loans"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IEmployeeLoanService         LoanService
@inject ISnackbar                    Snackbar
@inject IDialogService               DialogService
@inject AuthenticationStateProvider  AuthProvider

<PageTitle>سلف الموظفين</PageTitle>

@* ══ Stats Cards ══ *@
@if (_loadingStats)
{
    <MudGrid Class="mb-4">
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="90px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else if (_stats is not null)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 rounded-xl d-flex flex-column gap-1" Style="background:#10b981;color:white">
                <MudText Typo="Typo.caption" Style="opacity:.8">سلف نشطة</MudText>
                <MudText Typo="Typo.h4"><b>@_stats.ActiveLoansCount</b></MudText>
                <MudText Typo="Typo.caption" Style="opacity:.8">لـ @_stats.EmployeesWithLoans موظف</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 rounded-xl d-flex flex-column gap-1" Style="background:#f59e0b;color:white">
                <MudText Typo="Typo.caption" Style="opacity:.8">إجمالي المتبقي</MudText>
                <MudText Typo="Typo.h5"><b>@_stats.TotalRemainingAmount.ToString("N0")</b> جـ</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 rounded-xl d-flex flex-column gap-1" Style="background:#3b82f6;color:white">
                <MudText Typo="Typo.caption" Style="opacity:.8">خصومات الشهر</MudText>
                <MudText Typo="Typo.h5"><b>@_stats.ThisMonthDeductions.ToString("N0")</b> جـ</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 rounded-xl d-flex flex-column gap-1" Style="background:#8b5cf6;color:white">
                <MudText Typo="Typo.caption" Style="opacity:.8">انتهت هذا الشهر</MudText>
                <MudText Typo="Typo.h4"><b>@_stats.CompletedThisMonth</b></MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@* ══ Toolbar ══ *@
<MudPaper Class="pa-3 mb-3 rounded-xl d-flex align-center gap-3 flex-wrap">
    <MudText Typo="Typo.h6">💰 سلف الموظفين</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">إجمالي @_totalCount سلفة</MudText>
    <MudSpacer />

    <MudTextField T="string"
                  Value="_filter.SearchText"
                  ValueChanged="OnSearchChanged"
                  Placeholder="بحث باسم الموظف..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Style="max-width:220px"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Clearable="true" />

    <MudSelect T="string"
               Value="_filter.Status"
               ValueChanged="OnStatusChanged"
               Placeholder="الحالة"
               Style="max-width:140px"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               Clearable="true">
        <MudSelectItem T="string" Value="@("Active")">نشطة</MudSelectItem>
        <MudSelectItem T="string" Value="@("Completed")">منتهية</MudSelectItem>
        <MudSelectItem T="string" Value="@("Cancelled")">ملغية</MudSelectItem>
    </MudSelect>

    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                   Color="Color.Default"
                   Title="تحديث"
                   OnClick="RefreshAsync" />

    @if (HasPermission("Add"))
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddDialogAsync">
            سلفة جديدة
        </MudButton>
    }
</MudPaper>

@* ══ Table ══ *@
<MudPaper Class="rounded-xl overflow-hidden">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" />
    }

    <MudTable Items="_loans" Dense Hover Striped Loading="_loading"
              LoadingProgressColor="Color.Primary" Elevation="0">
        <HeaderContent>
            <MudTh>الموظف</MudTh>
            <MudTh>قيمة السلفة</MudTh>
            <MudTh>القسط الشهري</MudTh>
            <MudTh>الأقساط</MudTh>
            <MudTh>المتبقي</MudTh>
            <MudTh>بداية الخصم</MudTh>
            <MudTh>الحالة</MudTh>
            <MudTh>إجراءات</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <div class="d-flex align-center gap-2">
                    <MudAvatar Size="Size.Small" Style="@($"background:{context.StatusColor};color:white")">
                        @context.EmployeeName.FirstOrDefault()
                    </MudAvatar>
                    <div>
                        <MudText><b>@context.EmployeeName</b></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(context.Department ?? "—")
                        </MudText>
                    </div>
                </div>
            </MudTd>
            <MudTd><b>@context.LoanAmount.ToString("N2")</b> جـ</MudTd>
            <MudTd>@context.MonthlyInstallment.ToString("N2") جـ</MudTd>
            <MudTd>
                <div class="d-flex flex-column gap-1">
                    <MudText Typo="Typo.body2">
                        @context.PaidInstallments / @context.TotalInstallments
                    </MudText>
                    <MudProgressLinear Value="@GetProgressValue(context)"
                                       Color="@GetProgressColor(context)"
                                       Rounded Size="Size.Small" />
                </div>
            </MudTd>
            <MudTd>
                <MudText Color="@(context.RemainingAmount > 0 ? Color.Error : Color.Success)">
                    <b>@context.RemainingAmount.ToString("N2")</b> جـ
                </MudText>
            </MudTd>
            <MudTd>@FormatMonth(context.StartDeductionMonth)</MudTd>
            <MudTd>
                <MudChip T="string"
                         Size="Size.Small"
                         Style="@($"background:{context.StatusColor};color:white")">
                    @context.StatusAr
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                               Size="Size.Small"
                               Color="Color.Primary"
                               Title="التفاصيل والأقساط"
                               OnClick="@(() => OpenDetailDialogAsync(context.LoanId))" />

                @if (context.Status == "Active" && HasPermission("Delete"))
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   Title="إلغاء السلفة"
                                   OnClick="@(() => ConfirmCancelAsync(context))" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4" Color="Color.Secondary" Align="Align.Center">
                لا توجد سلف مطابقة
            </MudText>
        </NoRecordsContent>
    </MudTable>

    @* Pagination *@
    @if (_totalPages > 1)
    {
        <div class="d-flex align-center justify-space-between pa-3">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                عرض @((_filter.PageNumber - 1) * _filter.PageSize + 1)
                إلى @(Math.Min(_filter.PageNumber * _filter.PageSize, _totalCount))
                من @_totalCount
            </MudText>
            <MudPagination Count="_totalPages"
                           Selected="_filter.PageNumber"
                           SelectedChanged="OnPageChangedAsync"
                           Color="Color.Primary" />
        </div>
    }
</MudPaper>

@code {
    private List<LoanListDto> _loans       = new();
    private LoanStatsDto?     _stats;
    private LoanFilterDto     _filter      = new() { PageSize = 15 };
    private bool              _loading     = true;
    private bool              _loadingStats= true;
    private int               _totalCount;
    private int               _totalPages  => (int)Math.Ceiling((double)_totalCount / _filter.PageSize);
    private string            _currentUser = "system";
    private ClaimsPrincipal?  _user;

    protected override async Task OnInitializedAsync()
    {
        var auth   = await AuthProvider.GetAuthenticationStateAsync();
        _user        = auth.User;
        _currentUser = _user.Identity?.Name ?? "system";
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
        => await Task.WhenAll(LoadLoansAsync(), LoadStatsAsync());

    private async Task LoadLoansAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await LoanService.GetLoansAsync(_filter);
            _loans      = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadStatsAsync()
    {
        _loadingStats = true;
        try   { _stats = await LoanService.GetStatsAsync(); }
        catch { /* silent */ }
        finally
        {
            _loadingStats = false;
            StateHasChanged();
        }
    }

    private async Task RefreshAsync()
    {
        _filter.PageNumber = 1;
        await LoadAllAsync();
        Snackbar.Add("تم التحديث", Severity.Info);
    }

    private async Task OnSearchChanged(string? value)
    {
        _filter.SearchText = value;
        _filter.PageNumber = 1;
        await LoadLoansAsync();
    }

    private async Task OnStatusChanged(string? value)
    {
        _filter.Status     = value;
        _filter.PageNumber = 1;
        await LoadLoansAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _filter.PageNumber = page;
        await LoadLoansAsync();
    }

    private async Task OpenAddDialogAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(LoanFormDialog.OnSaved)] =
                EventCallback.Factory.Create(this, LoadAllAsync)
        };
        var options = new DialogOptions
        {
            MaxWidth       = MaxWidth.Small,
            FullWidth      = true,
            CloseButton    = true,
            CloseOnEscapeKey = true,
            BackdropClick  = false
        };
        await DialogService.ShowAsync<LoanFormDialog>("إضافة سلفة جديدة", parameters, options);
    }

    private async Task OpenDetailDialogAsync(int loanId)
    {
        var parameters = new DialogParameters
        {
            [nameof(LoanDetailDialog.LoanId)]    = loanId,
            [nameof(LoanDetailDialog.OnUpdated)] =
                EventCallback.Factory.Create(this, LoadAllAsync)
        };
        var options = new DialogOptions
        {
            MaxWidth    = MaxWidth.Medium,
            FullWidth   = true,
            CloseButton = true
        };
        await DialogService.ShowAsync<LoanDetailDialog>("تفاصيل السلفة", parameters, options);
    }

    private async Task ConfirmCancelAsync(LoanListDto loan)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message,     $"هل تريد إلغاء سلفة {loan.EmployeeName} بقيمة {loan.LoanAmount:N2} جـ؟\nسيتم إلغاء جميع الأقساط المعلقة." },
            { x => x.YesText,     "إلغاء السلفة" },
            { x => x.CancelText,  "تراجع" }
        };

        var options = new DialogOptions
        {
            MaxWidth         = MaxWidth.ExtraSmall,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأكيد الإلغاء", parameters, options);

        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var r = await LoanService.CancelLoanAsync(loan.LoanId, _currentUser);
            Snackbar.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
            if (r.Success) await LoadAllAsync();
        }
    }

    private bool HasPermission(string action) =>
        _user?.Claims.Any(c =>
            c.Type  == "Permission" &&
            c.Value == $"frmEmployeeLoans:{action}") == true;

    private static double GetProgressValue(LoanListDto l) =>
        l.TotalInstallments > 0
            ? (double)l.PaidInstallments / l.TotalInstallments * 100
            : 0;

    private static Color GetProgressColor(LoanListDto l)
    {
        var pct = GetProgressValue(l);
        return pct switch
        {
            >= 100 => Color.Success,
            >= 50  => Color.Info,
            >= 25  => Color.Warning,
            _      => Color.Error
        };
    }

    private static string FormatMonth(string? ym)
    {
        if (string.IsNullOrWhiteSpace(ym)) return "—";
        return DateTime.TryParseExact(ym + "-01", "yyyy-MM-dd",
            null, System.Globalization.DateTimeStyles.None, out var d)
            ? d.ToString("MMM yyyy", new System.Globalization.CultureInfo("ar-EG"))
            : ym;
    }
}
