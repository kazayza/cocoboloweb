@page "/hr/loans"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IEmployeeLoanService LoanService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>إدارة السلف والأقساط</PageTitle>

<style>
    .loan-mode-btn {
        border-radius: 14px !important;
        font-weight: 800 !important;
        min-height: 42px;
    }

    .loan-shell-card {
        border: 1px solid #e2e8f0 !important;
        border-radius: 22px !important;
        background: white !important;
    }

    .loan-stat-card {
        height: 100%;
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        background: white;
        padding: 18px;
    }

    .loan-stat-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .loan-stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .loan-stat-label {
        font-size: .76rem;
        color: #64748b;
        font-weight: 700;
    }

    .loan-stat-value {
        font-size: 1.22rem;
        font-weight: 900;
        line-height: 1.15;
        letter-spacing: -.4px;
    }

    .loan-stat-note {
        font-size: .72rem;
        color: #94a3b8;
        margin-top: 8px;
    }

    .loan-section-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 14px;
    }

    .loan-section-title {
        font-size: 1rem;
        font-weight: 900;
        color: #0f172a;
    }

    .loan-section-subtitle {
        font-size: .78rem;
        color: #64748b;
    }

    .loan-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 180px;
        text-align: center;
        color: #94a3b8;
    }

    .loan-empty .mud-icon-root {
        font-size: 54px !important;
        opacity: .45;
    }
</style>

<MudPaper Class="pa-4 mb-4 rounded-xl" Style="background:linear-gradient(135deg,#0f172a,#1d4ed8);color:white;">
    <div class="d-flex align-center justify-space-between flex-wrap gap-3">
        <div>
            <MudText Typo="Typo.h5"><b>إدارة السلف والأقساط</b></MudText>
            <MudText Typo="Typo.body2" Style="opacity:.85;">تابع السلف النشطة، الأقساط المستحقة، وكشف حساب كل موظف في شاشة واحدة.</MudText>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            @if (HasPermission("Add"))
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialogAsync">
                    سلفة جديدة
                </MudButton>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshCurrentModeAsync">
                تحديث
            </MudButton>
        </div>
    </div>
</MudPaper>

@if (_loadingStats)
{
    <MudGrid Class="mb-4">
        @for (int i = 0; i < 6; i++)
        {
            <MudItem xs="12" sm="6" md="2">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="110px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else if (_stats is not null)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="2">@RenderStatCard("سلف نشطة", _stats.ActiveLoansCount.ToString(), "قروض مفتوحة", "#10b981", "#ecfdf5", Icons.Material.Filled.AccountBalance)</MudItem>
        <MudItem xs="12" sm="6" md="2">@RenderStatCard("إجمالي المتبقي", _stats.TotalRemainingAmount.ToString("N0") + " جـ", "الرصيد غير المسدد", "#ef4444", "#fef2f2", Icons.Material.Filled.AccountBalanceWallet)</MudItem>
        <MudItem xs="12" sm="6" md="2">@RenderStatCard("أقساط الشهر", _stats.ThisMonthDeductions.ToString("N0") + " جـ", "مستحق هذا الشهر", "#3b82f6", "#eff6ff", Icons.Material.Filled.Payments)</MudItem>
        <MudItem xs="12" sm="6" md="2">@RenderStatCard("أقساط معلقة", _stats.PendingInstallmentsCount.ToString(), "كل الأقساط pending", "#f59e0b", "#fff7ed", Icons.Material.Filled.HourglassTop)</MudItem>
        <MudItem xs="12" sm="6" md="2">@RenderStatCard("انتهت هذا الشهر", _stats.CompletedThisMonth.ToString(), "سلف أغلقت", "#8b5cf6", "#f5f3ff", Icons.Material.Filled.TaskAlt)</MudItem>
        <MudItem xs="12" sm="6" md="2">@RenderStatCard("متوسط السلفة", _stats.AverageLoanAmount.ToString("N0") + " جـ", $"إجمالي نشط {_stats.TotalLoanAmount:N0} جـ", "#06b6d4", "#f0fdfa", Icons.Material.Filled.Analytics)</MudItem>
    </MudGrid>
}

<MudPaper Class="pa-3 mb-4 rounded-xl d-flex align-center gap-2 flex-wrap">
    <MudButton Variant="@(_viewMode == "loans" ? Variant.Filled : Variant.Outlined)" Color="Color.Primary" Class="loan-mode-btn" StartIcon="@Icons.Material.Filled.ViewList" OnClick='@(() => ChangeViewModeAsync("loans"))'>كل السلف</MudButton>
    <MudButton Variant="@(_viewMode == "installments" ? Variant.Filled : Variant.Outlined)" Color="Color.Warning" Class="loan-mode-btn" StartIcon="@Icons.Material.Filled.CalendarMonth" OnClick='@(() => ChangeViewModeAsync("installments"))'>أقساط الشهر</MudButton>
    <MudButton Variant="@(_viewMode == "statement" ? Variant.Filled : Variant.Outlined)" Color="Color.Info" Class="loan-mode-btn" StartIcon="@Icons.Material.Filled.ReceiptLong" OnClick='@(() => ChangeViewModeAsync("statement"))'>كشف الموظف</MudButton>
</MudPaper>

@if (_viewMode == "loans")
{
    <MudPaper Class="loan-shell-card pa-4 mb-3" Elevation="0">
        <div class="loan-section-head">
            <div>
                <div class="loan-section-title">الفلاتر</div>
                <div class="loan-section-subtitle">ابحث وفلتر السلف حسب الحالة، المبلغ، أو الشهر.</div>
            </div>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">إجمالي @_totalCount سلفة</MudChip>
        </div>

        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField T="string" @bind-Value="_filter.SearchText" Label="بحث" Placeholder="اسم الموظف / القسم / الوظيفة" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudSelect T="string" @bind-Value="_filter.Status" Label="الحالة" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                    <MudSelectItem T="string" Value="@("Active")">نشطة</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Completed")">منتهية</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Cancelled")">ملغية</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudTextField T="string" @bind-Value="_filter.Month" Label="الشهر" Placeholder="2026-07" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.DateRange" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudNumericField T="decimal?" @bind-Value="_filter.MinLoanAmount" Label="أقل مبلغ" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudNumericField T="decimal?" @bind-Value="_filter.MaxLoanAmount" Label="أعلى مبلغ" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="6" md="1" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth OnClick="ApplyLoanFiltersAsync">عرض</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="loan-shell-card rounded-xl overflow-hidden" Elevation="0">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }

        <MudTable Items="_loans" Dense Hover Striped Elevation="0" Loading="_loading">
            <HeaderContent>
                <MudTh>الموظف</MudTh>
                <MudTh>قيمة السلفة</MudTh>
                <MudTh>القسط الشهري</MudTh>
                <MudTh>الأقساط</MudTh>
                <MudTh>المتبقي</MudTh>
                <MudTh>بداية الخصم</MudTh>
                <MudTh>الحالة</MudTh>
                <MudTh>إجراءات</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Size="Size.Small" Style="@($"background:{context.StatusColor};color:white")">@context.EmployeeName.FirstOrDefault()</MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2"><b>@context.EmployeeName</b></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.Department ?? "—") • @(context.JobTitle ?? "—")</MudText>
                        </div>
                    </div>
                </MudTd>
                <MudTd><b>@context.LoanAmount.ToString("N2")</b> جـ</MudTd>
                <MudTd>@context.MonthlyInstallment.ToString("N2") جـ</MudTd>
                <MudTd>
                    <div class="d-flex flex-column gap-1">
                        <MudText Typo="Typo.body2">@context.PaidInstallments / @context.TotalInstallments</MudText>
                        <MudProgressLinear Value="@GetProgressValue(context)" Color="@GetProgressColor(context)" Rounded Size="Size.Small" />
                    </div>
                </MudTd>
                <MudTd>
                    <MudText Color="@(context.RemainingAmount > 0 ? Color.Error : Color.Success)">
                        <b>@context.RemainingAmount.ToString("N2")</b> جـ
                    </MudText>
                </MudTd>
                <MudTd>@FormatMonth(context.StartDeductionMonth)</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Style="@($"background:{context.StatusColor};color:white")">@context.StatusAr</MudChip>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Small" Color="Color.Info" Title="كشف حساب الموظف" OnClick="@(() => OpenStatementAsync(context.EmployeeId))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" Title="ملف الموظف" OnClick="@(() => OpenEmployeeProfile(context.EmployeeId))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Secondary" Title="تفاصيل السلفة" OnClick="@(() => OpenDetailDialogAsync(context.LoanId))" />
                    @if (context.Status == "Active" && HasPermission("Delete"))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Error" Title="إلغاء السلفة" OnClick="@(() => ConfirmCancelAsync(context))" />
                    }
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="loan-empty">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" />
                    <div>لا توجد سلف مطابقة للفلاتر الحالية.</div>
                </div>
            </NoRecordsContent>
        </MudTable>

        @if (_totalPages > 1)
        {
            <div class="d-flex align-center justify-space-between pa-3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    عرض @((_filter.PageNumber - 1) * _filter.PageSize + 1) إلى @(Math.Min(_filter.PageNumber * _filter.PageSize, _totalCount)) من @_totalCount
                </MudText>
                <MudPagination Count="_totalPages" Selected="_filter.PageNumber" SelectedChanged="OnPageChangedAsync" Color="Color.Primary" />
            </div>
        }
    </MudPaper>
}
else if (_viewMode == "installments")
{
    <MudPaper Class="loan-shell-card pa-4 mb-3" Elevation="0">
        <div class="loan-section-head">
            <div>
                <div class="loan-section-title">أقساط الشهر</div>
                <div class="loan-section-subtitle">عرض كل الأقساط المستحقة لشهر معين لمراجعتها قبل أو أثناء الرواتب.</div>
            </div>
        </div>

        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField T="string" @bind-Value="_installmentMonth" Label="الشهر" Placeholder="2026-07" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Month" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth OnClick="LoadMonthInstallmentsAsync">تحميل</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="loan-shell-card rounded-xl overflow-hidden" Elevation="0">
        @if (_loadingInstallments)
        {
            <MudProgressLinear Indeterminate Color="Color.Warning" />
        }

        <MudTable Items="_monthInstallments" Dense Hover Striped Elevation="0">
            <HeaderContent>
                <MudTh>الموظف</MudTh>
                <MudTh>الشهر</MudTh>
                <MudTh>رقم القسط</MudTh>
                <MudTh>المبلغ</MudTh>
                <MudTh>الحالة</MudTh>
                <MudTh>إجراءات</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.body2"><b>@context.EmployeeName</b></MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.Department ?? "—")</MudText>
                </MudTd>
                <MudTd>@context.MonthDisplay</MudTd>
                <MudTd>@context.InstallmentNumber</MudTd>
                <MudTd><b>@context.Amount.ToString("N2") جـ</b></MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Style="@($"background:{context.StatusColor};color:white")">@context.StatusAr</MudChip></MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Small" Color="Color.Info" Title="كشف حساب الموظف" OnClick="@(() => OpenStatementAsync(context.EmployeeId))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" Title="ملف الموظف" OnClick="@(() => OpenEmployeeProfile(context.EmployeeId))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="loan-empty">
                    <MudIcon Icon="@Icons.Material.Filled.EventBusy" />
                    <div>لا توجد أقساط مستحقة في هذا الشهر.</div>
                </div>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
}
else if (_viewMode == "statement")
{
    <MudPaper Class="loan-shell-card pa-4 mb-3" Elevation="0">
        <div class="loan-section-head">
            <div>
                <div class="loan-section-title">كشف حساب الموظف</div>
                <div class="loan-section-subtitle">اختر الموظف لاستعراض السلف والأقساط والتزامات السداد الخاصة به.</div>
            </div>
        </div>

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudAutocomplete T="EmployeeLookupDto"
                                 @bind-Value="_selectedEmployee"
                                 Label="الموظف"
                                 SearchFunc="SearchEmployeesAsync"
                                 ToStringFunc="@(e => e?.DisplayText ?? string.Empty)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Clearable="true"
                                 ResetValueOnEmptyText="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Info" FullWidth OnClick="LoadStatementAsync">عرض الكشف</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_loadingStatement)
    {
        <MudPaper Class="pa-8 rounded-xl text-center">
            <MudProgressCircular Indeterminate Color="Color.Info" />
            <MudText Class="mt-3">جاري تحميل كشف الحساب...</MudText>
        </MudPaper>
    }
    else if (_statement is null)
    {
        <MudPaper Class="pa-8 rounded-xl text-center">
            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Large" Color="Color.Info" />
            <MudText Typo="Typo.h6" Class="mt-3">اختر موظفًا لعرض كشف حساب السلف</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">سيظهر هنا ملخص السلف، الأقساط، والمبالغ المسددة والمتبقية.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-4 mb-4 rounded-xl" Style="background:linear-gradient(135deg,#0f172a,#1e293b);color:white;">
            <div class="d-flex align-center justify-space-between flex-wrap gap-3">
                <div>
                    <MudText Typo="Typo.h5"><b>@_statement.EmployeeName</b></MudText>
                    <MudText Typo="Typo.body2" Style="opacity:.85;">@(_statement.Department ?? "—") • @(_statement.JobTitle ?? "—")</MudText>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Person" OnClick="@(() => OpenEmployeeProfile(_statement.EmployeeId))">ملف الموظف</MudButton>
                </div>
            </div>
        </MudPaper>

        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="6" md="2">@RenderStatCard("السلف النشطة", _statement.ActiveLoansCount.ToString(), "قروض ما زالت مفتوحة", "#10b981", "#ecfdf5", Icons.Material.Filled.AccountBalance)</MudItem>
            <MudItem xs="12" sm="6" md="2">@RenderStatCard("إجمالي السلف", _statement.TotalLoanAmount.ToString("N0") + " جـ", "كل ما تم صرفه", "#3b82f6", "#eff6ff", Icons.Material.Filled.Payments)</MudItem>
            <MudItem xs="12" sm="6" md="2">@RenderStatCard("المسدّد", _statement.TotalPaidAmount.ToString("N0") + " جـ", "ما تم تحصيله", "#06b6d4", "#f0fdfa", Icons.Material.Filled.CheckCircle)</MudItem>
            <MudItem xs="12" sm="6" md="2">@RenderStatCard("المتبقي", _statement.TotalRemainingAmount.ToString("N0") + " جـ", "الرصيد الحالي", "#ef4444", "#fef2f2", Icons.Material.Filled.AccountBalanceWallet)</MudItem>
            <MudItem xs="12" sm="6" md="2">@RenderStatCard("استحقاق الشهر", _statement.CurrentMonthDue.ToString("N0") + " جـ", FormatMonth(DateTime.Today.ToString("yyyy-MM")), "#f59e0b", "#fff7ed", Icons.Material.Filled.CalendarMonth)</MudItem>
            <MudItem xs="12" sm="6" md="2">@RenderStatCard("أقساط Pending", _statement.PendingInstallmentsCount.ToString(), "معلقة على الجدول", "#8b5cf6", "#f5f3ff", Icons.Material.Filled.HourglassTop)</MudItem>
        </MudGrid>

        <MudGrid>
            <MudItem xs="12" lg="5">
                <MudPaper Class="loan-shell-card pa-4 h-100" Elevation="0">
                    <div class="loan-section-head">
                        <div>
                            <div class="loan-section-title">السلف الخاصة بالموظف</div>
                            <div class="loan-section-subtitle">ملخص كل سلفة وحالتها الحالية.</div>
                        </div>
                    </div>

                    @if (_statement.Loans.Any())
                    {
                        <MudTable Items="_statement.Loans" Dense Hover Elevation="0">
                            <HeaderContent>
                                <MudTh>التاريخ</MudTh>
                                <MudTh>القيمة</MudTh>
                                <MudTh>المتبقي</MudTh>
                                <MudTh>الحالة</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.LoanDate.ToString("yyyy/MM/dd")</MudTd>
                                <MudTd>@context.LoanAmount.ToString("N2") جـ</MudTd>
                                <MudTd>@context.RemainingAmount.ToString("N2") جـ</MudTd>
                                <MudTd><MudChip T="string" Size="Size.Small" Style="@($"background:{context.StatusColor};color:white")">@context.StatusAr</MudChip></MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="loan-empty">
                            <MudIcon Icon="@Icons.Material.Filled.MoneyOff" />
                            <div>لا توجد سلف مسجلة لهذا الموظف.</div>
                        </div>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="7">
                <MudPaper Class="loan-shell-card pa-4 h-100" Elevation="0">
                    <div class="loan-section-head">
                        <div>
                            <div class="loan-section-title">كشف الأقساط</div>
                            <div class="loan-section-subtitle">تسلسل كامل لكل الأقساط المخصومة أو المؤجلة أو المعلقة.</div>
                        </div>
                    </div>

                    @if (_statement.Installments.Any())
                    {
                        <MudTable Items="_statement.Installments" Dense Hover Elevation="0">
                            <HeaderContent>
                                <MudTh>الشهر</MudTh>
                                <MudTh>رقم القسط</MudTh>
                                <MudTh>المبلغ</MudTh>
                                <MudTh>الحالة</MudTh>
                                <MudTh>تاريخ الخصم</MudTh>
                                <MudTh>ملاحظات</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.MonthDisplay</MudTd>
                                <MudTd>@context.InstallmentNumber</MudTd>
                                <MudTd>@context.Amount.ToString("N2") جـ</MudTd>
                                <MudTd><MudChip T="string" Size="Size.Small" Style="@($"background:{context.StatusColor};color:white")">@context.StatusAr</MudChip></MudTd>
                                <MudTd>@(context.DeductionDate?.ToString("yyyy/MM/dd") ?? "—")</MudTd>
                                <MudTd>@(context.Notes ?? "—")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="loan-empty">
                            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                            <div>لا توجد أقساط لهذا الموظف.</div>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
}

@code {
    private List<LoanListDto> _loans = new();
    private LoanStatsDto? _stats;
    private LoanFilterDto _filter = new() { PageSize = 15 };
    private bool _loading = true;
    private bool _loadingStats = true;
    private bool _loadingInstallments;
    private bool _loadingStatement;
    private int _totalCount;
    private int _totalPages => (int)Math.Ceiling((double)_totalCount / _filter.PageSize);
    private string _currentUser = "system";
    private ClaimsPrincipal? _user;
    private string _viewMode = "loans";
    private string _installmentMonth = DateTime.Today.ToString("yyyy-MM");
    private List<InstallmentListDto> _monthInstallments = new();
    private EmployeeLookupDto? _selectedEmployee;
    private EmployeeLoanStatementDto? _statement;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _user = auth.User;
        _currentUser = _user.Identity?.Name ?? "system";
        await LoadStatsAsync();
        await LoadLoansAsync();
    }

    private async Task RefreshCurrentModeAsync()
    {
        await LoadStatsAsync();

        if (_viewMode == "loans")
            await LoadLoansAsync();
        else if (_viewMode == "installments")
            await LoadMonthInstallmentsAsync();
        else if (_selectedEmployee is not null)
            await LoadStatementAsync();

        Snackbar.Add("تم التحديث", Severity.Info);
    }

    private async Task ChangeViewModeAsync(string mode)
    {
        _viewMode = mode;

        if (mode == "installments" && !_monthInstallments.Any())
            await LoadMonthInstallmentsAsync();
        else if (mode == "statement" && _selectedEmployee is not null && _statement is null)
            await LoadStatementAsync();
    }

    private async Task ApplyLoanFiltersAsync()
    {
        _filter.PageNumber = 1;
        await LoadLoansAsync();
    }

    private async Task LoadLoansAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await LoanService.GetLoansAsync(_filter);
            _loans = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل السلف: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadStatsAsync()
    {
        _loadingStats = true;
        try
        {
            _stats = await LoanService.GetStatsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل الإحصائيات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingStats = false;
            StateHasChanged();
        }
    }

    private async Task LoadMonthInstallmentsAsync()
    {
        if (string.IsNullOrWhiteSpace(_installmentMonth))
        {
            Snackbar.Add("اختر الشهر أولاً", Severity.Warning);
            return;
        }

        _loadingInstallments = true;
        StateHasChanged();
        try
        {
            _monthInstallments = await LoanService.GetMonthInstallmentsAsync(_installmentMonth);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل أقساط الشهر: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingInstallments = false;
            StateHasChanged();
        }
    }

    private async Task<IEnumerable<EmployeeLookupDto>> SearchEmployeesAsync(string? value, CancellationToken ct)
    {
        try
        {
            return await LoanService.GetEmployeesLookupAsync(value);
        }
        catch
        {
            return Enumerable.Empty<EmployeeLookupDto>();
        }
    }

    private async Task LoadStatementAsync()
    {
        if (_selectedEmployee is null)
        {
            Snackbar.Add("اختر الموظف أولاً", Severity.Warning);
            return;
        }

        _loadingStatement = true;
        StateHasChanged();
        try
        {
            _statement = await LoanService.GetEmployeeStatementAsync(_selectedEmployee.EmployeeId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل كشف الحساب: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingStatement = false;
            StateHasChanged();
        }
    }

    private async Task OpenStatementAsync(int employeeId)
    {
        _selectedEmployee = (await LoanService.GetEmployeesLookupAsync(null)).FirstOrDefault(x => x.EmployeeId == employeeId)
            ?? new EmployeeLookupDto { EmployeeId = employeeId, FullName = "الموظف" };
        _viewMode = "statement";
        await LoadStatementAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _filter.PageNumber = page;
        await LoadLoansAsync();
    }

    private async Task OpenAddDialogAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(LoanFormDialog.OnSaved)] = EventCallback.Factory.Create(this, AfterLoanChangedAsync)
        };

        await DialogService.ShowAsync<LoanFormDialog>(
            "إضافة سلفة جديدة",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true, CloseOnEscapeKey = true, BackdropClick = false });
    }

    private async Task OpenDetailDialogAsync(int loanId)
    {
        var parameters = new DialogParameters
        {
            [nameof(LoanDetailDialog.LoanId)] = loanId,
            [nameof(LoanDetailDialog.OnUpdated)] = EventCallback.Factory.Create(this, AfterLoanChangedAsync)
        };

        await DialogService.ShowAsync<LoanDetailDialog>(
            "تفاصيل السلفة",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
    }

    private async Task ConfirmCancelAsync(LoanListDto loan)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message, $"هل تريد إلغاء سلفة {loan.EmployeeName} بقيمة {loan.LoanAmount:N2} جـ؟\nسيتم إلغاء جميع الأقساط المعلقة وعكس الأثر المالي." },
            { x => x.YesText, "إلغاء السلفة" },
            { x => x.CancelText, "تراجع" }
        };

        var dialog = await DialogService.ShowAsync<MudMessageBox>("تأكيد الإلغاء", parameters, new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, CloseOnEscapeKey = true });
        var result = await dialog.Result;
        if (result is not { Canceled: false }) return;

        var response = await LoanService.CancelLoanAsync(loan.LoanId, _currentUser);
        Snackbar.Add(response.Message, response.Success ? Severity.Success : Severity.Error);
        if (response.Success)
            await AfterLoanChangedAsync();
    }

    private async Task AfterLoanChangedAsync()
    {
        await LoadStatsAsync();

        if (_viewMode == "loans")
            await LoadLoansAsync();
        else if (_viewMode == "installments")
            await LoadMonthInstallmentsAsync();
        else if (_selectedEmployee is not null)
            await LoadStatementAsync();
    }

    private void OpenEmployeeProfile(int employeeId) => Nav.NavigateTo($"/employees/profile/{employeeId}");

    private bool HasPermission(string action) =>
        _user?.Claims.Any(c => c.Type == "Permission" && c.Value == $"frmEmployeeLoans:{action}") == true;

    private static double GetProgressValue(LoanListDto loan) =>
        loan.TotalInstallments > 0 ? (double)loan.PaidInstallments / loan.TotalInstallments * 100 : 0;

    private static Color GetProgressColor(LoanListDto loan)
    {
        var pct = GetProgressValue(loan);
        return pct switch
        {
            >= 100 => Color.Success,
            >= 50 => Color.Info,
            >= 25 => Color.Warning,
            _ => Color.Error
        };
    }

    private static string FormatMonth(string? ym)
    {
        if (string.IsNullOrWhiteSpace(ym)) return "—";
        return DateTime.TryParseExact(ym + "-01", "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var d)
            ? d.ToString("MMMM yyyy", new System.Globalization.CultureInfo("ar-EG"))
            : ym;
    }

