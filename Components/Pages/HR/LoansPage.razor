@page "/hr/loans"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IEmployeeLoanService        LoanService
@inject ISnackbar                   Snackbar
@inject IDialogService              DialogService
@inject AuthenticationStateProvider AuthProvider

<PageTitle>سلف الموظفين</PageTitle>

@* ══════════════════════════════════════════
   Stats Cards
   ══════════════════════════════════════════ *@
@if (_loadingStats)
{
    <MudGrid Class="mb-4" Spacing="3">
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="12" sm="6" md="3">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                             Height="100px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else if (_stats is not null)
{
    <MudGrid Class="mb-4" Spacing="3">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 rounded-xl"
                      Style="background:linear-gradient(135deg,#10b981,#059669);color:white">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.8)">
                            سلف نشطة
                        </MudText>
                        <MudText Typo="Typo.h4" Style="color:white">
                            <b>@_stats.ActiveLoansCount</b>
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.7)">
                            لـ @_stats.EmployeesWithLoans موظف
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet"
                             Style="font-size:3rem;color:rgba(255,255,255,.25)" />
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 rounded-xl"
                      Style="background:linear-gradient(135deg,#f59e0b,#d97706);color:white">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.8)">
                            إجمالي المتبقي
                        </MudText>
                        <MudText Typo="Typo.h5" Style="color:white">
                            <b>@_stats.TotalRemainingAmount.ToString("N0")</b> جـ
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Savings"
                             Style="font-size:3rem;color:rgba(255,255,255,.25)" />
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 rounded-xl"
                      Style="background:linear-gradient(135deg,#3b82f6,#2563eb);color:white">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.8)">
                            خصومات الشهر
                        </MudText>
                        <MudText Typo="Typo.h5" Style="color:white">
                            <b>@_stats.ThisMonthDeductions.ToString("N0")</b> جـ
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.TrendingDown"
                             Style="font-size:3rem;color:rgba(255,255,255,.25)" />
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 rounded-xl"
                      Style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);color:white">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.8)">
                            انتهت هذا الشهر
                        </MudText>
                        <MudText Typo="Typo.h4" Style="color:white">
                            <b>@_stats.CompletedThisMonth</b>
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                             Style="font-size:3rem;color:rgba(255,255,255,.25)" />
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@* ══════════════════════════════════════════
   Toolbar
   ══════════════════════════════════════════ *@
<MudPaper Class="pa-3 mb-3 rounded-xl" Elevation="0"
          Style="border:1px solid #e5e7eb">
    <MudGrid Spacing="2" Class="align-center">
        <MudItem xs="12" md="4">
            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance"
                         Color="Color.Primary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h6">سلف الموظفين</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        إجمالي @_totalCount سلفة
                    </MudText>
                </div>
            </div>
        </MudItem>

        <MudItem xs="12" md="8">
            <div class="d-flex flex-wrap gap-2 justify-end align-center">

                <MudTextField T="string"
                              Value="@_filter.SearchText"
                              ValueChanged="OnSearchChanged"
                              Placeholder="بحث بالاسم أو القسم..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="400"
                              Style="min-width:210px" />

                <MudSelect T="string"
                           Value="@_filter.Status"
                           ValueChanged="OnStatusChanged"
                           Placeholder="الحالة"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true"
                           Style="min-width:130px">
                    <MudSelectItem T="string" Value="@("Active")">نشطة</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Completed")">منتهية</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Cancelled")">ملغية</MudSelectItem>
                </MudSelect>

                <MudTooltip Text="تحديث">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Variant="Variant.Outlined"
                                   OnClick="RefreshAsync" />
                </MudTooltip>

                @if (HasPermission("Add"))
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenAddDialogAsync">
                        سلفة جديدة
                    </MudButton>
                }
            </div>
        </MudItem>
    </MudGrid>
</MudPaper>

@* ══════════════════════════════════════════
   Table
   ══════════════════════════════════════════ *@
<MudPaper Class="rounded-xl overflow-hidden" Elevation="0"
          Style="border:1px solid #e5e7eb">

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }

    <MudTable Items="@_loans"
              Dense="true"
              Hover="true"
              Striped="true"
              Elevation="0">
        <HeaderContent>
            <MudTh>الموظف</MudTh>
            <MudTh Style="text-align:center">قيمة السلفة</MudTh>
            <MudTh Style="text-align:center">القسط الشهري</MudTh>
            <MudTh Style="text-align:center">الأقساط</MudTh>
            <MudTh Style="text-align:center">المتبقي</MudTh>
            <MudTh Style="text-align:center">بداية الخصم</MudTh>
            <MudTh Style="text-align:center">الحالة</MudTh>
            <MudTh Style="text-align:center">إجراءات</MudTh>
        </HeaderContent>

        <RowTemplate>
            <MudTd DataLabel="الموظف">
                <div class="d-flex align-center gap-2">
                    <MudAvatar Color="Color.Primary" Size="Size.Small">
                        @context.EmployeeName.FirstOrDefault()
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.body2"><b>@context.EmployeeName</b></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(context.Department ?? "—")
                        </MudText>
                    </div>
                </div>
            </MudTd>

            <MudTd DataLabel="قيمة السلفة" Style="text-align:center">
                <b>@context.LoanAmount.ToString("N2")</b> جـ
            </MudTd>

            <MudTd DataLabel="القسط" Style="text-align:center">
                @context.MonthlyInstallment.ToString("N2") جـ
            </MudTd>

            <MudTd DataLabel="الأقساط" Style="text-align:center">
                <MudTooltip Text="@($"مدفوع {context.PaidInstallments} من {context.TotalInstallments}")">
                    <div style="display:flex;flex-direction:column;align-items:center;gap:2px">
                        <MudProgressLinear Color="@GetProgressColor(context)"
                                           Value="@GetProgressValue(context)"
                                           Style="height:8px;border-radius:4px;width:80px" />
                        <MudText Typo="Typo.caption">
                            @context.PaidInstallments / @context.TotalInstallments
                        </MudText>
                    </div>
                </MudTooltip>
            </MudTd>

            <MudTd DataLabel="المتبقي" Style="text-align:center">
                <MudText Color="@(context.RemainingAmount > 0 ? Color.Error : Color.Success)">
                    <b>@context.RemainingAmount.ToString("N2")</b> جـ
                </MudText>
            </MudTd>

            <MudTd DataLabel="بداية الخصم" Style="text-align:center">
                @FormatMonth(context.StartDeductionMonth)
            </MudTd>

            <MudTd DataLabel="الحالة" Style="text-align:center">
                <MudChip T="string" Size="Size.Small"
                         Style="@($"background:{context.StatusColor};color:white")">
                    @context.StatusAr
                </MudChip>
            </MudTd>

            <MudTd DataLabel="إجراءات" Style="text-align:center">
                <MudTooltip Text="التفاصيل">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Size="Size.Small" Color="Color.Info"
                                   OnClick="() => OpenDetailDialogAsync(context.LoanId)" />
                </MudTooltip>

                @if (context.Status == "Active" && HasPermission("Delete"))
                {
                    <MudTooltip Text="إلغاء السلفة">
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                       Size="Size.Small" Color="Color.Error"
                                       OnClick="() => ConfirmCancelAsync(context)" />
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <div class="pa-8 d-flex flex-column align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff"
                         Size="Size.Large" Color="Color.Secondary" />
                <MudText Color="Color.Secondary">لا توجد سلف مطابقة</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>

    @* Pagination *@
    @if (_totalPages > 1)
    {
        <MudDivider />
        <div class="d-flex justify-space-between align-center pa-3 flex-wrap gap-2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                عرض @((_filter.PageNumber - 1) * _filter.PageSize + 1)
                إلى @(Math.Min(_filter.PageNumber * _filter.PageSize, _totalCount))
                من @_totalCount
            </MudText>
            <MudPagination Count="@_totalPages"
                           Selected="@_filter.PageNumber"
                           SelectedChanged="OnPageChangedAsync"
                           ShowFirstButton="true"
                           ShowLastButton="true"
                           Color="Color.Primary" />
        </div>
    }
</MudPaper>

@code {
    // ══════════════════════════════════════════
    // State
    // ══════════════════════════════════════════
    private List<LoanListDto> _loans       = new();
    private LoanStatsDto?     _stats;
    private LoanFilterDto     _filter      = new() { PageSize = 15 };
    private bool              _loading     = true;
    private bool              _loadingStats = true;
    private int               _totalCount;
    private int               _totalPages  => (int)Math.Ceiling((double)_totalCount / _filter.PageSize);
    private string            _currentUser = "system";
    private ClaimsPrincipal?  _user;

    // ══════════════════════════════════════════
    // Init
    // ══════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _user        = auth.User;
        _currentUser = _user.Identity?.Name ?? "system";
        await LoadAllAsync();
    }

    // ══════════════════════════════════════════
    // Data
    // ══════════════════════════════════════════
    private async Task LoadAllAsync()
    {
        await Task.WhenAll(LoadLoansAsync(), LoadStatsAsync());
    }

    private async Task LoadLoansAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result   = await LoanService.GetLoansAsync(_filter);
            _loans       = result.Items;
            _totalCount  = result.TotalCount;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadStatsAsync()
    {
        _loadingStats = true;
        try
        {
            _stats = await LoanService.GetStatsAsync();
        }
        catch { /* silent */ }
        finally
        {
            _loadingStats = false;
            StateHasChanged();
        }
    }

    private async Task RefreshAsync()
    {
        _filter.PageNumber = 1;
        await LoadAllAsync();
        Snackbar.Add("تم التحديث", Severity.Info);
    }

    // ══════════════════════════════════════════
    // Filters
    // ══════════════════════════════════════════
    private async Task OnSearchChanged(string? value)
    {
        _filter.SearchText = value;
        _filter.PageNumber = 1;
        await LoadLoansAsync();
    }

    private async Task OnStatusChanged(string? value)
    {
        _filter.Status     = value;
        _filter.PageNumber = 1;
        await LoadLoansAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _filter.PageNumber = page;
        await LoadLoansAsync();
    }

    // ══════════════════════════════════════════
    // Dialogs
    // ══════════════════════════════════════════
    private async Task OpenAddDialogAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(LoanFormDialog.OnSaved)] =
                EventCallback.Factory.Create(this, LoadAllAsync)
        };

        var options = new DialogOptions
        {
            MaxWidth         = MaxWidth.Small,
            FullWidth        = true,
            CloseButton      = true,
            CloseOnEscapeKey = true,
            BackdropClick    = false
        };

        await DialogService.ShowAsync<LoanFormDialog>(
            "إضافة سلفة جديدة", parameters, options);
    }

    private async Task OpenDetailDialogAsync(int loanId)
    {
        var parameters = new DialogParameters
        {
            [nameof(LoanDetailDialog.LoanId)]    = loanId,
            [nameof(LoanDetailDialog.OnUpdated)] =
                EventCallback.Factory.Create(this, LoadAllAsync)
        };

        var options = new DialogOptions
        {
            MaxWidth    = MaxWidth.Medium,
            FullWidth   = true,
            CloseButton = true
        };

        await DialogService.ShowAsync<LoanDetailDialog>(
            "تفاصيل السلفة", parameters, options);
    }

    private async Task ConfirmCancelAsync(LoanListDto loan)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message,
              $"هل تريد إلغاء سلفة {loan.EmployeeName} بقيمة {loan.LoanAmount:N2} جـ؟\nسيتم إلغاء جميع الأقساط المعلقة." },
            { x => x.YesText,    "إلغاء السلفة" },
            { x => x.CancelText, "تراجع" }
        };

        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأكيد الإلغاء",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var r = await LoanService.CancelLoanAsync(loan.LoanId, _currentUser);
            Snackbar.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
            if (r.Success) await LoadAllAsync();
        }
    }

    // ══════════════════════════════════════════
    // Permissions
    // ══════════════════════════════════════════
    private bool HasPermission(string action) =>
        _user?.Claims.Any(c =>
            c.Type  == "Permission" &&
            c.Value == $"frmEmployeeLoans:{action}") == true;

    // ══════════════════════════════════════════
    // Helpers
    // ══════════════════════════════════════════
    private static Color GetProgressColor(LoanListDto l)
    {
        var pct = l.TotalInstallments > 0
            ? (double)l.PaidInstallments / l.TotalInstallments * 100 : 0;
        return pct switch
        {
            >= 100 => Color.Success,
            >= 50  => Color.Info,
            >= 25  => Color.Warning,
            _      => Color.Error
        };
    }

    private static double GetProgressValue(LoanListDto l) =>
        l.TotalInstallments > 0
            ? (double)l.PaidInstallments / l.TotalInstallments * 100
            : 0;

    private static string FormatMonth(string? ym)
    {
        if (string.IsNullOrWhiteSpace(ym)) return "—";
        return DateTime.TryParseExact(ym + "-01", "yyyy-MM-dd",
            null, System.Globalization.DateTimeStyles.None, out var d)
            ? d.ToString("MMM yyyy", new System.Globalization.CultureInfo("ar-EG"))
            : ym;
    }
}