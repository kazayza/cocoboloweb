@page "/employees"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject IEmployeeService EmployeeService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@attribute [Authorize]

<div dir="rtl">

    <!-- ═══════════════════════════════════════════ -->
    <!-- Header -->
    <!-- ═══════════════════════════════════════════ -->
    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; color: white;">
        <div style="display:flex; align-items:center; gap:1rem;">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Inherit"
                           OnClick="@(() => Navigation.NavigateTo("/"))" />
            <div>
                <h1 style="margin:0; font-size:1.4rem; font-weight:800; display:flex; align-items:center; gap:0.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" />
                    إدارة الموظفين
                </h1>
                <p style="margin:0; font-size:0.85rem; opacity:0.9;">إدارة بيانات الموظفين والحالات والرواتب</p>
            </div>
        </div>
        <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
            @if (_canAdd)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="@(() => Navigation.NavigateTo("/employees/add"))">
                    إضافة موظف جديد
                </MudButton>
            }
        </div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Stats Cards -->
    <!-- ═══════════════════════════════════════════ -->
    @if (_stats != null)
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 0.75rem; margin-bottom: 1rem;">
            <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; padding: 1rem; text-align: center; color: white;">
                <div style="display:flex; align-items:center; justify-content:center; gap:0.4rem; margin-bottom:0.25rem;">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" />
                    <span style="font-size:0.78rem; opacity:0.85;">إجمالي الموظفين</span>
                </div>
                <div style="font-size:1.5rem; font-weight:800;">@_stats.TotalEmployees</div>
            </div>
            <div style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); border-radius: 12px; padding: 1rem; text-align: center; color: white;">
                <div style="display:flex; align-items:center; justify-content:center; gap:0.4rem; margin-bottom:0.25rem;">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                    <span style="font-size:0.78rem; opacity:0.85;">نشط</span>
                </div>
                <div style="font-size:1.5rem; font-weight:800;">@_stats.ActiveCount</div>
            </div>
            <div style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); border-radius: 12px; padding: 1rem; text-align: center; color: white;">
                <div style="display:flex; align-items:center; justify-content:center; gap:0.4rem; margin-bottom:0.25rem;">
                    <MudIcon Icon="@Icons.Material.Filled.PauseCircle" Size="Size.Small" />
                    <span style="font-size:0.78rem; opacity:0.85;">موقوف</span>
                </div>
                <div style="font-size:1.5rem; font-weight:800;">@_stats.SuspendedCount</div>
            </div>
            <div style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 12px; padding: 1rem; text-align: center; color: white;">
                <div style="display:flex; align-items:center; justify-content:center; gap:0.4rem; margin-bottom:0.25rem;">
                    <MudIcon Icon="@Icons.Material.Filled.BeachAccess" Size="Size.Small" />
                    <span style="font-size:0.78rem; opacity:0.85;">بالإجازة</span>
                </div>
                <div style="font-size:1.5rem; font-weight:800;">@_stats.OnLeaveCount</div>
            </div>
            <div style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); border-radius: 12px; padding: 1rem; text-align: center; color: white;">
                <div style="display:flex; align-items:center; justify-content:center; gap:0.4rem; margin-bottom:0.25rem;">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Small" />
                    <span style="font-size:0.78rem; opacity:0.85;">إجمالي الرواتب</span>
                </div>
                <div style="font-size:1.15rem; font-weight:800;">@_stats.TotalSalaries.ToString("N0")</div>
                <div style="font-size:0.72rem; opacity:0.7;">ج.م / شهر</div>
            </div>
            <div style="background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%); border-radius: 12px; padding: 1rem; text-align: center; color: white;">
                <div style="display:flex; align-items:center; justify-content:center; gap:0.4rem; margin-bottom:0.25rem;">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                    <span style="font-size:0.78rem; opacity:0.85;">متوسط المرتب</span>
                </div>
                <div style="font-size:1.15rem; font-weight:800;">@_stats.AverageSalary.ToString("N0")</div>
                <div style="font-size:0.72rem; opacity:0.7;">ج.م</div>
            </div>
        </div>
    }

    <!-- ═══════════════════════════════════════════ -->
    <!-- Filters -->
    <!-- ═══════════════════════════════════════════ -->
    <MudPaper Style="background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider); border-radius: 14px; padding: 1rem; margin-bottom: 1rem;" Elevation="0">
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.75rem;">
            <MudTextField T="string" Label="بحث بالاسم أو الرقم القومي" @bind-Value="_filter.SearchTerm"
                          Variant="Variant.Outlined" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnKeyUp="OnSearchKeyPress" />

            <MudSelect T="string" Label="القسم" Value="_selectedDepartment" ValueChanged="OnDepartmentChanged" Variant="Variant.Outlined" Clearable="true">
                @foreach (var dept in _departments)
                {
                    <MudSelectItem T="string" Value="@dept">@dept</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string" Label="الحالة" Value="_selectedStatus" ValueChanged="OnStatusChanged" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem T="string" Value="@EmployeeStatuses.Active">@EmployeeStatuses.Active</MudSelectItem>
                <MudSelectItem T="string" Value="@EmployeeStatuses.Suspended">@EmployeeStatuses.Suspended</MudSelectItem>
                <MudSelectItem T="string" Value="@EmployeeStatuses.Resigned">@EmployeeStatuses.Resigned</MudSelectItem>
                <MudSelectItem T="string" Value="@EmployeeStatuses.OnLeave">@EmployeeStatuses.OnLeave</MudSelectItem>
            </MudSelect>

            <MudSelect T="string" Label="النوع" Value="_selectedGender" ValueChanged="OnGenderChanged" Variant="Variant.Outlined" Clearable="true">
                <MudSelectItem T="string" Value="@("ذكر")">ذكر</MudSelectItem>
                <MudSelectItem T="string" Value="@("أنثى")">أنثى</MudSelectItem>
            </MudSelect>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilter"
                       StartIcon="@Icons.Material.Filled.FilterList" FullWidth="true">
                تطبيق الفلتر
            </MudButton>

            <MudButton Variant="Variant.Outlined" OnClick="ResetFilter"
                       StartIcon="@Icons.Material.Filled.Refresh" FullWidth="true">
                إعادة تعيين
            </MudButton>
        </div>
    </MudPaper>

    <!-- ═══════════════════════════════════════════ -->
    <!-- Employees Table -->
    <!-- ═══════════════════════════════════════════ -->
    <MudPaper Style="background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider); border-radius: 14px; padding: 1rem;" Elevation="0">
        @if (_isLoading)
        {
            <div style="display:flex; justify-content:center; padding:3rem;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_employees.Items.Any())
        {
            <MudTable T="EmployeeListDto" Items="@_employees.Items" Hover="true" Elevation="0" Dense="true">
                <ToolBarContent>
                    <MudText Typo="Typo.h6" Style="font-weight:700;">
                        قائمة الموظفين
                    </MudText>
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="ml-2">
                        @_employees.TotalCount موظف
                    </MudChip>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>#</MudTh>
                    <MudTh>الاسم</MudTh>
                    <MudTh>الوظيفة</MudTh>
                    <MudTh>القسم</MudTh>
                    <MudTh>النوع</MudTh>
                    <MudTh>الموبايل</MudTh>
                    <MudTh>المرتب</MudTh>
                    <MudTh>تاريخ التعيين</MudTh>
                    <MudTh>الحالة</MudTh>
                    <MudTh>إجراءات</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
                            @context.EmployeeId
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <div style="display:flex; align-items:center; gap:0.5rem;">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                                @context.FullName.Substring(0, Math.Min(2, context.FullName.Length))
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@context.FullName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.NationalId</MudText>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd>@context.JobTitle</MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.Department))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@context.Department</MudChip>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.Gender == "ذكر")
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Male" Color="Color.Primary" />
                        }
                        else if (context.Gender == "أنثى")
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Female" Color="Color.Secondary" />
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </MudTd>
                    <MudTd>@(context.MobilePhone ?? "-")</MudTd>
                    <MudTd>
                        <strong style="color: #2e7d32;">
                            @((context.CurrentSalaryBase ?? 0).ToString("N0")) ج.م
                        </strong>
                    </MudTd>
                    <MudTd>@(context.HireDate?.ToString("yyyy/MM/dd") ?? "-")</MudTd>
                    <MudTd>
                        @{
                            var sColor = context.Status switch
                            {
                                "نشط" => Color.Success,
                                "موقوف" => Color.Warning,
                                "مستقيل" => Color.Error,
                                "بالإجازة" => Color.Info,
                                _ => Color.Default
                            };
                        }
                        <MudChip T="string" Color="@sColor" Size="Size.Small" Variant="Variant.Filled">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="التفاصيل" Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small"
                                           OnClick="@(() => Navigation.NavigateTo($"/employees/{context.EmployeeId}"))" />
                        </MudTooltip>
                        @if (_canEdit)
                        {
                            <MudTooltip Text="تعديل" Placement="Placement.Top">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => Navigation.NavigateTo($"/employees/edit/{context.EmployeeId}"))" />
                            </MudTooltip>
                        }
                        @if (_canEdit && context.Status != EmployeeStatuses.Resigned)
                        {
                            <MudTooltip Text="تغيير الحالة" Placement="Placement.Top">
                                <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Warning" Size="Size.Small"
                                               OnClick="@(() => OpenStatusDialog(context))" />
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- Pagination -->
            <div style="display:flex; justify-content:space-between; align-items:center; margin-top:1rem; padding-top:0.75rem; border-top:1px solid var(--mud-palette-divider);">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    إجمالي @_employees.TotalCount موظف - صفحة @_employees.PageNumber من @_employees.TotalPages
                </MudText>
                <div style="display:flex; gap:0.5rem;">
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               Disabled="@(_employees.PageNumber <= 1)"
                               OnClick="@(() => GoToPage(_employees.PageNumber - 1))">
                        السابق
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               Disabled="@(!_employees.HasNext)"
                               OnClick="@(() => GoToPage(_employees.PageNumber + 1))">
                        التالي
                    </MudButton>
                </div>
            </div>
        }
        else
        {
            <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem;">
                <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-2">لا يوجد موظفين</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">أضف موظف جديد للبدء</MudText>
            </div>
        }
    </MudPaper>
</div>

<!-- ═══════════════════════════════════════════ -->
<!-- Status Change Dialog -->
<!-- ═══════════════════════════════════════════ -->
<MudDialog @bind-IsOpen="_statusDialogOpen">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">تغيير حالة الموظف</MudText>
        <MudText Typo="Typo.body1" Class="mb-3">
            <strong>@_selectedEmployee?.FullName</strong> - الحالة الحالية:
            <MudChip T="string" Size="Size.Small" Color="Color.Warning">@_selectedEmployee?.Status</MudChip>
        </MudText>
        <MudSelect T="string" Label="الحالة الجديدة" @bind-Value="_newStatus" Variant="Variant.Outlined" Class="mb-3">
            <MudSelectItem T="string" Value="@EmployeeStatuses.Active">@EmployeeStatuses.Active</MudSelectItem>
            <MudSelectItem T="string" Value="@EmployeeStatuses.Suspended">@EmployeeStatuses.Suspended</MudSelectItem>
            <MudSelectItem T="string" Value="@EmployeeStatuses.Resigned">@EmployeeStatuses.Resigned</MudSelectItem>
            <MudSelectItem T="string" Value="@EmployeeStatuses.OnLeave">@EmployeeStatuses.OnLeave</MudSelectItem>
        </MudSelect>
        <MudTextField T="string" Label="سبب التغيير" @bind-Value="_statusReason" Variant="Variant.Outlined" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="ChangeStatus" Variant="Variant.Filled">تأكيد</MudButton>
        <MudButton OnClick="@(() => _statusDialogOpen = false)">إلغاء</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _isLoading = false;
    private bool _canView = false;
    private bool _canAdd = false;
    private bool _canEdit = false;

    // Data
    private PagedResult<EmployeeListDto> _employees = new();
    private EmployeeFilterDto _filter = new();
    private EmployeeStatsDto? _stats;
    private List<string> _departments = new();

    // Filter select values
    private string? _selectedDepartment;
    private string? _selectedStatus;
    private string? _selectedGender;

    // Status dialog
    private bool _statusDialogOpen = false;
    private EmployeeListDto? _selectedEmployee;
    private string _newStatus = "";
    private string _statusReason = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _canView = user.HasClaim("Permission", "frm_Employeeslist:View") || user.IsInRole("Admin");
        _canAdd = user.HasClaim("Permission", "frm_Employees:Add") || user.IsInRole("Admin");
        _canEdit = user.HasClaim("Permission", "frm_Employeeslist:Edit") || user.IsInRole("Admin");

        if (!_canView)
        {
            Navigation.NavigateTo("/access-denied");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            _employees = await EmployeeService.GetEmployeesAsync(_filter);
            _stats = await EmployeeService.GetStatsAsync();
            _departments = await EmployeeService.GetDepartmentsAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ApplyFilter()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyFilter();
        }
    }

    private async Task OnDepartmentChanged(string? value)
    {
        _selectedDepartment = value;
        _filter.Department = value;
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnStatusChanged(string? value)
    {
        _selectedStatus = value;
        _filter.Status = value;
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnGenderChanged(string? value)
    {
        _selectedGender = value;
        _filter.Gender = value;
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task ResetFilter()
    {
        _filter = new EmployeeFilterDto();
        _selectedDepartment = null;
        _selectedStatus = null;
        _selectedGender = null;
        await LoadData();
    }

    private async Task GoToPage(int page)
    {
        _filter.PageNumber = page;
        await LoadData();
    }

    private void OpenStatusDialog(EmployeeListDto employee)
    {
        _selectedEmployee = employee;
        _newStatus = employee.Status;
        _statusReason = "";
        _statusDialogOpen = true;
    }

    private async Task ChangeStatus()
    {
        if (_selectedEmployee == null) return;

        var result = await EmployeeService.ChangeStatusAsync(
            _selectedEmployee.EmployeeId, _newStatus, _statusReason,
            (await AuthProvider.GetAuthenticationStateAsync()).User.Identity?.Name ?? "System");

        if (result.Success)
        {
            Snackbar.Add(result.Message, Severity.Success);
            _statusDialogOpen = false;
            await LoadData();
        }
        else
        {
            Snackbar.Add(result.Message, Severity.Error);
        }
    }
}