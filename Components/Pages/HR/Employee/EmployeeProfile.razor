            <MudTabPanel Text="السلف" Icon="@Icons.Material.Filled.AccountBalance">
                <div class="ep-tab-content">
                    <MudPaper Class="ep-section-card" Elevation="0">
                        <div class="ep-table-head">
                            <div>
                                <div class="ep-section-title">السلف الخاصة بالموظف</div>
