    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "HR";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[1][0].ToString()).ToUpperInvariant();
    }

    private static string StatusStyle(string status) => status switch
    {
        EmployeeStatuses.Active => "background:#10b981;color:white",
        EmployeeStatuses.Suspended => "background:#f59e0b;color:white",
        EmployeeStatuses.Resigned => "background:#ef4444;color:white",
        EmployeeStatuses.OnLeave => "background:#3b82f6;color:white",
        _ => "background:#94a3b8;color:white"
    };

