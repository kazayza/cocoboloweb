                                            <MudTh>الشهر</MudTh>
                                            <MudTh>النوع</MudTh>
                                            <MudTh>الوصف</MudTh>
                                            <MudTh>المبلغ</MudTh>
                                            <MudTh>الحالة</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@context.PayrollMonth</MudTd>
                                            <MudTd>@context.PaymentTypeAr</MudTd>
                                            <MudTd>@context.Description</MudTd>
                                            <MudTd>@context.Amount.ToString("N2") جـ</MudTd>
                                            <MudTd>
                                                <MudChip T="string" Size="Size.Small" Style="@($"background:{context.StatusColor};color:white")">@context.PaymentStatus</MudChip>
