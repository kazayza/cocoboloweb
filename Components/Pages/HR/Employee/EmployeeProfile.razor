                </div>
            </MudTabPanel>

            <MudTabPanel Text="الشيفت" Icon="@Icons.Material.Filled.Schedule">
                <div class="ep-tab-content">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudPaper Class="ep-section-card ep-section-soft" Elevation="0">
                                <div class="ep-section-head">
                                    <div class="ep-section-icon" style="background:#eff6ff;color:#2563eb;">
                                        <MudIcon Icon="@Icons.Material.Filled.EventAvailable" />
                                    </div>
                                    <div>
                                        <div class="ep-section-title">الشيفت الحالي</div>
                                        <div class="ep-section-subtitle">مواعيد الدوام وأيام الراحة</div>
                                    </div>
                                </div>

                                @if (_activeShift is not null)
                                {
                                    <div class="ep-info-list">
                                        @foreach (var field in ShiftFields)
