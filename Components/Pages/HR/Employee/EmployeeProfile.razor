                        }
                        else
                        {
                            <div class="ep-empty">
                                <MudIcon Icon="@Icons.Material.Filled.Timeline" />
                                <div>لا توجد أحداث كافية لعرض التايم لاين بعد.</div>
                            </div>
                        }
                    </MudPaper>
                </div>
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
}
</div>

@code {
    [Parameter] public int employeeId { get; set; }

    private EmployeeDetailDto? _employee;
    private AttendanceReportDto? _attendanceSummary;
    private List<AttendanceListDto> _recentAttendance = new();
    private List<PayrollListDto> _payrolls = new();
    private List<OffPayrollPaymentListDto> _offPayrolls = new();
    private List<LoanListDto> _employeeLoans = new();
    private List<EmployeeShiftListDto> _shifts = new();
    private List<ExemptionListDto> _exemptions = new();
    private EmployeeShiftListDto? _activeShift;
    private bool _loading = true;
    private bool _canEdit;
    private int _activeTab;

    private PayrollListDto? LatestPayroll => _payrolls.OrderByDescending(x => x.PayrollMonth).FirstOrDefault();
    private decimal ActiveLoansRemaining => _employeeLoans.Where(x => x.Status == "Active").Sum(x => x.RemainingAmount);
    private int ActiveLoansCount => _employeeLoans.Count(x => x.Status == "Active");
    private string EarlyLeaveDisplay => FormatMinutes(_attendanceSummary?.TotalEarlyLeaveMinutes ?? 0);
    private decimal PayrollAverageNet => _payrolls.Any() ? _payrolls.Average(x => x.NetSalary) : 0;
    private decimal PayrollAverageDeduction => _payrolls.Any() ? _payrolls.Average(x => x.TotalDeductions) : 0;
    private double PayrollAverageNetProgress => LatestPayroll is null || LatestPayroll.NetSalary <= 0 ? 0 : Math.Min((double)(PayrollAverageNet / LatestPayroll.NetSalary * 100), 100);
    private double PayrollAverageDeductionProgress => LatestPayroll is null || LatestPayroll.NetSalary <= 0 ? 0 : Math.Min((double)(PayrollAverageDeduction / Math.Max(LatestPayroll.NetSalary, 1) * 100), 100);
    private double PayrollPaidPercentage => _payrolls.Any() ? Math.Round((double)_payrolls.Count(x => x.PaymentStatus == PayrollPaymentStatuses.Paid) / _payrolls.Count * 100, 1) : 0;

    private List<(string Label, string Value)> PersonalFields => new()
    {
        ("الاسم", _employee?.FullName ?? "—"),
        ("القسم", _employee?.Department ?? "—"),
        ("الوظيفة", _employee?.JobTitle ?? "—"),
        ("النوع", _employee?.Gender ?? "—"),
        ("الرقم القومي", _employee?.NationalId ?? "—"),
        ("تاريخ التعيين", _employee?.HireDate?.ToString("yyyy/MM/dd") ?? "—"),
        ("البريد", _employee?.EmailAddress ?? "—"),
        ("الموبايل", _employee?.MobilePhone ?? "—"),
        ("العنوان", _employee?.Address ?? "—")
    };

    private List<(string Label, string Value)> OperationalFields => new()
    {
        ("الحالة", _employee?.Status ?? "—"),
        ("المرتب الحالي", ((_employee?.CurrentSalaryBase ?? 0).ToString("N2") + " جـ")),
        ("معفى من البصمة", _employee?.IsPermanentlyExempt == true ? "نعم" : "لا"),
        ("الشيفت الحالي", _activeShift?.ShiftType ?? "—"),
        ("أيام الراحة", _activeShift?.OffDaysDisplay ?? "—"),
        ("آخر راتب", LatestPayroll is null ? "—" : $"{LatestPayroll.PayrollMonth} • {LatestPayroll.PaymentStatus}"),
        ("عدد السلف النشطة", ActiveLoansCount.ToString()),
        ("عدد الاستثناءات", _exemptions.Count.ToString())
    };

    private List<(string Label, string Value)> AttendanceFields => new()
    {
        ("أيام العمل", _attendanceSummary?.WorkingDays.ToString() ?? "0"),
        ("أيام الحضور", _attendanceSummary?.PresentDays.ToString() ?? "0"),
        ("أيام الغياب", _attendanceSummary?.AbsentDays.ToString() ?? "0"),
        ("أيام التأخير", _attendanceSummary?.LateDays.ToString() ?? "0"),
        ("الانصراف المبكر", (_attendanceSummary?.EarlyLeaveDays ?? 0).ToString()),
        ("إجمالي التأخير", _attendanceSummary?.TotalLateDisplay ?? "—"),
        ("إجمالي الانصراف المبكر", EarlyLeaveDisplay),
        ("نسبة الحضور", (_attendanceSummary?.AttendancePercentage ?? 0).ToString("N1") + "%"),
        ("إجمالي الساعات", _attendanceSummary?.TotalHoursDisplay ?? "—")
    };

    private List<(string Label, string Value)> ShiftFields => new()
    {
        ("نوع الشيفت", _activeShift?.ShiftType ?? "—"),
        ("من", _activeShift?.StartTimeDisplay ?? "—"),
        ("إلى", _activeShift?.EndTimeDisplay ?? "—"),
        ("أيام الراحة", _activeShift?.OffDaysDisplay ?? "—"),
        ("فعال من", _activeShift?.EffectiveFromDisplay ?? "—")
    };

    private List<ActivityItem> ActivityFeed
    {
        get
        {
            var items = new List<ActivityItem>();

            if (_employee?.HireDate is not null)
                items.Add(new ActivityItem(_employee.HireDate.Value, "تعيين الموظف", $"تم تعيين {_employee.FullName} بتاريخ {_employee.HireDate.Value:yyyy/MM/dd}", Icons.Material.Filled.Badge, "#2563eb", "#eff6ff"));

            items.AddRange(_employee?.SalaryHistory.Select(x => new ActivityItem(x.CreatedAt ?? DateTime.Now,
                "تعديل مرتب", $"تم تحديث المرتب إلى {x.NewSalary:N2} جـ" + (!string.IsNullOrWhiteSpace(x.Reason) ? $" • السبب: {x.Reason}" : string.Empty),
                Icons.Material.Filled.TrendingUp, "#059669", "#ecfdf5")) ?? Enumerable.Empty<ActivityItem>());

            items.AddRange(_payrolls.Select(x => new ActivityItem(x.CreatedAt ?? DateTime.Now,
                "تسجيل راتب", $"راتب شهر {x.PayrollMonth} • الحالة: {x.PaymentStatus} • الصافي {x.NetSalary:N2} جـ",
                Icons.Material.Filled.Payments, "#0ea5e9", "#f0fdfa")));

            items.AddRange(_offPayrolls.Select(x => new ActivityItem(x.RequestedAt ?? DateTime.Now,
                x.PaymentTypeAr, $"{x.Description} • {x.Amount:N2} جـ • الحالة: {x.PaymentStatus}",
                Icons.Material.Filled.CardGiftcard, "#7c3aed", "#f5f3ff")));

            items.AddRange(_employeeLoans.Select(x => new ActivityItem(x.CreatedAt,
                "سلفة موظف", $"سلفة بقيمة {x.LoanAmount:N2} جـ • الحالة: {x.StatusAr}",
                Icons.Material.Filled.AccountBalanceWallet, "#d97706", "#fff7ed")));

            items.AddRange(_shifts.Select(x => new ActivityItem(x.CreatedAt ?? x.EffectiveFrom,
                "تحديث شيفت", $"{x.ShiftType} • من {x.EffectiveFromDisplay} إلى {x.EffectiveToDisplay}",
                Icons.Material.Filled.Schedule, "#2563eb", "#eff6ff")));

            items.AddRange(_exemptions.Select(x => new ActivityItem(x.CreatedDate ?? x.ExemptionDate,
                "استثناء", $"{x.ReasonCode} • {x.DateDisplay} • الحالة: {x.StatusAr}",
                Icons.Material.Filled.EventBusy, "#ef4444", "#fef2f2")));

            return items.OrderByDescending(x => x.Date).Take(16).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;

        var canView = user.HasClaim("Permission", "frm_Employeeslist:View")
                      || user.IsInRole("Admin")
                      || user.IsInRole("HrManager")
                      || user.IsInRole("HRManager");

        _canEdit = user.HasClaim("Permission", "frm_Employeeslist:Edit")
                   || user.IsInRole("Admin")
                   || user.IsInRole("HrManager")
                   || user.IsInRole("HRManager");

        if (!canView)
        {
            Nav.NavigateTo("/access-denied");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _employee = await EmployeeService.GetEmployeeDetailAsync(employeeId);
            if (_employee is null)
                return;

            var now = DateTime.Today;
            var monthStart = new DateTime(now.Year, now.Month, 1);
            var yearBack = DateTime.Today.AddMonths(-11).ToString("yyyy-MM");
            var currentMonth = DateTime.Today.ToString("yyyy-MM");

            _attendanceSummary = (await AttendanceService.GetAttendanceReportAsync(new AttendanceReportFilterDto
            {
                DateFrom = monthStart,
                DateTo = DateTime.Today,
                EmployeeId = employeeId,
                IncludeWeekends = false,
                IncludeHolidays = true
            })).FirstOrDefault();

            _recentAttendance = (await AttendanceService.GetAttendanceAsync(new AttendanceFilterDto
            {
                EmployeeId = employeeId,
                DateFrom = monthStart,
                DateTo = DateTime.Today,
                PageNumber = 1,
                PageSize = 12,
                SortBy = "LogDate",
                SortDescending = true
            })).Items;

            _payrolls = (await PayrollService.GetPayrollsAsync(new PayrollFilterDto
            {
                EmployeeID = employeeId,
                MonthFrom = yearBack,
                MonthTo = currentMonth,
                PageNumber = 1,
                PageSize = 24
            })).Items.OrderByDescending(x => x.PayrollMonth).ToList();

            _offPayrolls = (await PayrollService.GetOffPayrollPaymentsAsync(new OffPayrollPaymentFilterDto
            {
                EmployeeID = employeeId
            })).OrderByDescending(x => x.PayrollMonth).ThenByDescending(x => x.RequestedAt).ToList();

            _employeeLoans = (await LoanService.GetLoansAsync(new LoanFilterDto
            {
                EmployeeId = employeeId,
                PageNumber = 1,
                PageSize = 20
            })).Items.OrderByDescending(x => x.LoanDate).ToList();

            _shifts = (await ShiftService.GetShiftsAsync(new EmployeeShiftFilterDto
            {
                EmployeeId = employeeId,
                PageNumber = 1,
                PageSize = 20,
                SortBy = "EffectiveFrom",
                SortDescending = true
            })).Items.OrderByDescending(x => x.EffectiveFrom).ToList();

            _activeShift = _shifts.FirstOrDefault(x => x.IsActive) ?? _shifts.FirstOrDefault();

            _exemptions = (await AttendanceService.GetExemptionsAsync(new ExemptionFilterDto
            {
                EmployeeId = employeeId,
                PageNumber = 1,
                PageSize = 20,
                DateFrom = DateTime.Today.AddMonths(-6),
                DateTo = DateTime.Today
            })).Items.OrderByDescending(x => x.ExemptionDate).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل ملف الموظف: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

