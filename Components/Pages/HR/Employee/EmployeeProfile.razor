@page "/employees/profile/{employeeId:int}"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IEmployeeService EmployeeService
@inject IAttendanceService AttendanceService
@inject IPayrollService PayrollService
@inject IEmployeeLoanService LoanService
@inject IEmployeeShiftService ShiftService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>ملف الموظف</PageTitle>

<style>
    .ep-root {
        direction: rtl;
        padding-bottom: 32px;
    }

    .ep-hero {
        position: relative;
        overflow: hidden;
        border-radius: 28px !important;
        background: linear-gradient(135deg, #0f172a 0%, #172554 35%, #1d4ed8 100%);
        color: white;
        border: none !important;
    }

    .ep-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 15% 20%, rgba(212,175,55,.22), transparent 30%),
            radial-gradient(circle at 85% 80%, rgba(255,255,255,.10), transparent 28%);
        pointer-events: none;
    }

    .ep-hero-content {
        position: relative;
        z-index: 1;
        padding: 28px;
    }

    .ep-avatar {
        width: 74px !important;
        height: 74px !important;
        font-size: 1.35rem !important;
        font-weight: 900 !important;
        border: 2px solid rgba(255,255,255,.18);
        box-shadow: 0 10px 26px rgba(0,0,0,.18);
    }

    .ep-title {
        font-size: 1.6rem;
        font-weight: 900;
        line-height: 1.15;
        letter-spacing: -.5px;
        margin-bottom: 6px;
    }

    .ep-subtitle {
        color: rgba(255,255,255,.78);
        font-size: .95rem;
        font-weight: 500;
    }

    .ep-chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
    }

    .ep-hero-btn {
        border-radius: 14px !important;
        font-weight: 700 !important;
        min-height: 42px;
    }

    .ep-stat-card {
        height: 100%;
        border-radius: 22px !important;
        border: 1px solid #e2e8f0 !important;
        background: white !important;
        padding: 18px;
        transition: all .25s ease;
    }

    .ep-stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(15,23,42,.06) !important;
        border-color: #cbd5e1 !important;
    }

    .ep-stat-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .ep-stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .ep-stat-label {
        font-size: .76rem;
        color: #64748b;
        font-weight: 700;
    }

    .ep-stat-value {
        font-size: 1.25rem;
        font-weight: 900;
        line-height: 1.15;
        letter-spacing: -.5px;
    }

    .ep-stat-note {
        font-size: .72rem;
        color: #94a3b8;
        margin-top: 8px;
    }

    .ep-tabs-shell {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        overflow: hidden;
    }

    .ep-tabs .mud-tabs-toolbar {
        padding: 16px 18px;
        background: linear-gradient(180deg, #fbfdff 0%, #f8fafc 100%);
        border-bottom: 1px solid #e2e8f0;
        gap: 8px;
    }

    .ep-tabs .mud-tab {
        color: #64748b !important;
        font-weight: 800 !important;
        font-size: .92rem !important;
        border-radius: 14px !important;
        min-height: 48px;
        padding-inline: 18px !important;
        transition: all .25s ease;
    }

    .ep-tabs .mud-tab:hover {
        background: rgba(37,99,235,.08) !important;
        color: #2563eb !important;
    }

    .ep-tabs .mud-tab.mud-tab-active {
        background: linear-gradient(135deg, #2563eb, #1d4ed8) !important;
        color: white !important;
        box-shadow: 0 10px 24px rgba(37,99,235,.20);
        outline: none !important;
    }

    .ep-tabs .mud-tab.mud-tab-active .mud-icon-root {
        color: white !important;
    }

    .ep-tabs .mud-tab:focus,
    .ep-tabs .mud-tab:focus-visible,
    .ep-tabs .mud-tab.mud-tab-active:focus,
    .ep-tabs .mud-tab.mud-tab-active:focus-visible {
        outline: none !important;
        box-shadow: none !important;
    }

    ::deep .ep-tabs .mud-tab::before,
    ::deep .ep-tabs .mud-tab::after,
    ::deep .ep-tabs .mud-tab-slider {
        display: none !important;
        content: none !important;
    }

    .ep-tab-panel {
        padding: 0 !important;
    }

    .ep-tab-content {
        padding: 24px;
    }

    .ep-section-card {
        height: 100%;
        border-radius: 20px !important;
        border: 1px solid #e2e8f0 !important;
        background: white !important;
        padding: 20px;
    }

    .ep-section-soft {
        background: #f8fafc !important;
    }

    .ep-section-head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 18px;
    }

    .ep-section-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ep-section-title {
        font-size: 1rem;
        font-weight: 900;
        color: #0f172a;
        margin: 0;
    }

    .ep-section-subtitle {
        font-size: .78rem;
        color: #64748b;
        margin-top: 2px;
    }

    .ep-info-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .ep-info-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px dashed #e2e8f0;
    }

    .ep-info-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .ep-info-label {
        color: #64748b;
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .ep-info-value {
        color: #0f172a;
        font-size: .92rem;
        font-weight: 800;
        text-align: left;
    }

    .ep-grid-note {
        font-size: .72rem;
        color: #94a3b8;
    }

    .ep-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 180px;
        text-align: center;
        color: #94a3b8;
    }

    .ep-empty .mud-icon-root {
        font-size: 54px !important;
        opacity: .45;
    }

    .ep-table-shell {
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        overflow: hidden;
    }

    .ep-table-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 18px;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    .ep-pill {
        border-radius: 999px;
        padding: 6px 12px;
        font-size: .74rem;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .ep-row-action {
        min-width: 40px;
    }

    .ep-action-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
    }

    .ep-metric-card {
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 14px;
        background: #f8fafc;
    }

    .ep-metric-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
        gap: 10px;
    }

    .ep-metric-label {
        font-size: .8rem;
        font-weight: 800;
        color: #0f172a;
    }

    .ep-metric-value {
        font-size: .78rem;
        color: #475569;
        font-weight: 700;
    }

    .ep-activity-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .ep-activity-item {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        padding: 12px 0;
        border-bottom: 1px dashed #e2e8f0;
    }

    .ep-activity-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .ep-activity-icon {
        width: 36px;
        height: 36px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ep-activity-title {
        font-size: .9rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 3px;
    }

    .ep-activity-meta {
        font-size: .76rem;
        color: #64748b;
        line-height: 1.6;
    }

    @@media (max-width: 960px) {
        .ep-hero-content,
        .ep-tab-content {
            padding: 18px;
        }

        .ep-title {
            font-size: 1.28rem;
        }

        .ep-tabs .mud-tabs-toolbar {
            padding: 12px;
        }
    }
</style>

<div class="ep-root">
@if (_loading)
{
    <MudPaper Class="pa-10 rounded-xl text-center">
        <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="mt-4">جاري تحميل ملف الموظف...</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">يرجى الانتظار لحين تجهيز البيانات.</MudText>
    </MudPaper>
}
else if (_employee is null)
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
        لم يتم العثور على الموظف المطلوب.
    </MudAlert>
}
else
{
    <MudPaper Class="ep-hero mb-4" Elevation="0">
        <div class="ep-hero-content">
            <div class="d-flex align-center justify-space-between flex-wrap gap-4">
                <div class="d-flex align-center gap-3 flex-wrap">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Inherit" OnClick='@(() => Nav.NavigateTo("/employees"))' />
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="ep-avatar">
                        @GetInitials(_employee.FullName)
                    </MudAvatar>
                    <div>
                        <div class="ep-title">@_employee.FullName</div>
                        <div class="ep-subtitle">@(_employee.JobTitle ?? "بدون وظيفة") • @(_employee.Department ?? "بدون قسم")</div>
                        <div class="ep-chip-row">
                            <MudChip T="string" Size="Size.Small" Style="@StatusStyle(_employee.Status)">@_employee.Status</MudChip>
                            @if (_employee.BioEmployeeId.HasValue)
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info">كود البصمة: @_employee.BioEmployeeId</MudChip>
                            }
                            @if (_employee.IsPermanentlyExempt == true)
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Warning">معفى من البصمة</MudChip>
                            }
                            @if (_activeShift is not null)
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Success">الشيفت الحالي: @_activeShift.ShiftType</MudChip>
                            }
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Groups" Class="ep-hero-btn" OnClick='@(() => Nav.NavigateTo("/employees"))'>كل الموظفين</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.FactCheck" Class="ep-hero-btn" OnClick='@(() => Nav.NavigateTo("/attendance"))'>الحضور</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Payments" Class="ep-hero-btn" OnClick='@(() => Nav.NavigateTo("/hr/payroll"))'>الرواتب</MudButton>
                    @if (_canEdit)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Class="ep-hero-btn" OnClick='@(() => Nav.NavigateTo($"/employees/edit/{_employee.EmployeeId}"))'>تعديل</MudButton>
                    }
                </div>
            </div>
        </div>
    </MudPaper>

    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="4" md="2">
            @RenderStatCard("المرتب الحالي", ((_employee.CurrentSalaryBase ?? 0).ToString("N0") + " جـ"), "المرتب الأساسي النشط", "#2563eb", "#eff6ff", Icons.Material.Filled.AccountBalanceWallet)
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            @RenderStatCard("حضور الشهر", (_attendanceSummary?.PresentDays ?? 0).ToString(), "أيام حضور فعلية", "#10b981", "#ecfdf5", Icons.Material.Filled.HowToReg)
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            @RenderStatCard("غياب الشهر", (_attendanceSummary?.AbsentDays ?? 0).ToString(), "أيام تحتاج متابعة", "#ef4444", "#fef2f2", Icons.Material.Filled.PersonOff)
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            @RenderStatCard("التأخير", _attendanceSummary?.TotalLateDisplay ?? "—", "إجمالي التأخير الحالي", "#f59e0b", "#fff7ed", Icons.Material.Filled.Schedule)
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            @RenderStatCard("انصراف مبكر", EarlyLeaveDisplay, "إجمالي الانصراف المبكر", "#f97316", "#fff7ed", Icons.Material.Filled.ExitToApp)
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            @RenderStatCard("آخر راتب", LatestPayroll is null ? "—" : LatestPayroll.NetSalary.ToString("N0") + " جـ", LatestPayroll is null ? "لا يوجد راتب" : LatestPayroll.PayrollMonth, "#06b6d4", "#f0fdfa", Icons.Material.Filled.ReceiptLong)
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            @RenderStatCard("رصيد السلف", ActiveLoansRemaining.ToString("N0") + " جـ", ActiveLoansCount == 0 ? "بدون سلف نشطة" : $"{ActiveLoansCount} سلفة نشطة", "#7c3aed", "#f5f3ff", Icons.Material.Filled.AccountBalance)
        </MudItem>
    </MudGrid>

    <MudPaper Class="ep-section-card mb-4" Elevation="0">
        <div class="ep-section-head">
            <div class="ep-section-icon" style="background:#eff6ff;color:#2563eb;">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" />
            </div>
            <div>
                <div class="ep-section-title">إجراءات سريعة</div>
                <div class="ep-section-subtitle">اختصارات مباشرة لأكثر العمليات استخدامًا على الموظف</div>
            </div>
        </div>

        <div class="ep-action-grid">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick='@(() => Nav.NavigateTo($"/employees/edit/{_employee.EmployeeId}"))'>تعديل الموظف</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.FactCheck" OnClick='@(() => Nav.NavigateTo("/attendance"))'>متابعة الحضور</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Payments" OnClick='@(() => Nav.NavigateTo("/hr/payroll"))'>سجل الرواتب</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AccountBalance" OnClick='@(() => Nav.NavigateTo("/hr/loans"))'>السلف</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Schedule" OnClick='@(() => Nav.NavigateTo("/shifts"))'>الشيفتات</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.EventBusy" OnClick='@(() => Nav.NavigateTo("/hr/exemptions"))'>الاستثناءات</MudButton>
        </div>
    </MudPaper>

    <MudPaper Class="ep-tabs-shell" Elevation="0">
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="ep-tab-panel" Class="ep-tabs" ActivePanelIndex="@_activeTab" ActivePanelIndexChanged="OnTabChangedAsync">

            <MudTabPanel Text="نظرة عامة" Icon="@Icons.Material.Filled.DashboardCustomize">
                <div class="ep-tab-content">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudPaper Class="ep-section-card" Elevation="0">
                                <div class="ep-section-head">
                                    <div class="ep-section-icon" style="background:#eff6ff;color:#2563eb;">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                                    </div>
                                    <div>
                                        <div class="ep-section-title">البيانات الأساسية</div>
                                        <div class="ep-section-subtitle">البيانات الشخصية والتواصل</div>
                                    </div>
                                </div>

                                <div class="ep-info-list">
                                    @foreach (var field in PersonalFields)
                                    {
                                        @RenderInfoRow(field.Label, field.Value)
                                    }
                                </div>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudPaper Class="ep-section-card ep-section-soft" Elevation="0">
                                <div class="ep-section-head">
                                    <div class="ep-section-icon" style="background:#ecfdf5;color:#059669;">
                                        <MudIcon Icon="@Icons.Material.Filled.WorkHistory" />
                                    </div>
                                    <div>
                                        <div class="ep-section-title">معلومات تشغيلية</div>
                                        <div class="ep-section-subtitle">الحالة والراتب والشيفت والتشغيل</div>
                                    </div>
                                </div>

                                <div class="ep-info-list">
                                    @foreach (var field in OperationalFields)
                                    {
                                        @RenderInfoRow(field.Label, field.Value)
                                    }
                                </div>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12">
                            <MudPaper Class="ep-section-card" Elevation="0">
                                <div class="ep-table-head">
                                    <div>
                                        <div class="ep-section-title">سجل تغيّر المرتب</div>
                                        <div class="ep-section-subtitle">كل التعديلات السابقة على الراتب الأساسي</div>
                                    </div>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@_employee.SalaryHistory.Count سجل</MudChip>
                                </div>

                                @if (_employee.SalaryHistory.Any())
                                {
                                    <MudTable Items="_employee.SalaryHistory" Dense Hover Elevation="0">
                                        <HeaderContent>
                                            <MudTh>التاريخ</MudTh>
                                            <MudTh>المرتب القديم</MudTh>
                                            <MudTh>المرتب الجديد</MudTh>
                                            <MudTh>الفرق</MudTh>
                                            <MudTh>السبب</MudTh>
                                            <MudTh>بواسطة</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@context.ChangeDate.ToString("yyyy/MM/dd")</MudTd>
                                            <MudTd>@((context.OldSalary ?? 0).ToString("N2")) جـ</MudTd>
                                            <MudTd><b>@context.NewSalary.ToString("N2") جـ</b></MudTd>
                                            <MudTd>
                                                @{
                                                    var diff = context.NewSalary - (context.OldSalary ?? 0);
                                                    var diffColor = diff > 0 ? Color.Success : diff < 0 ? Color.Error : Color.Default;
                                                }
                                                <MudText Color="@diffColor" Style="font-weight:800;">
                                                    @(diff > 0 ? "+" : "")@diff.ToString("N2") جـ
                                                </MudText>
                                            </MudTd>
                                            <MudTd>@(context.Reason ?? "—")</MudTd>
                                            <MudTd>@(context.CreatedBy ?? "—")</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                                else
                                {
                                    <div class="ep-empty">
                                        <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" />
                                        <div>لا يوجد سجل تغييرات مرتبات حتى الآن.</div>
                                    </div>
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="الحضور" Icon="@Icons.Material.Filled.FactCheck">
                <div class="ep-tab-content">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="5">
                            <MudPaper Class="ep-section-card ep-section-soft" Elevation="0">
                                <div class="ep-section-head">
                                    <div class="ep-section-icon" style="background:#fff7ed;color:#f59e0b;">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
                                    </div>
                                    <div>
                                        <div class="ep-section-title">ملخص الحضور للشهر الحالي</div>
                                        <div class="ep-section-subtitle">أيام العمل والحضور والغياب والتأخير</div>
                                    </div>
                                </div>

                                @if (_attendanceSummary is not null)
                                {
                                    <div class="ep-info-list">
                                        @foreach (var field in AttendanceFields)
                                        {
                                            @RenderInfoRow(field.Label, field.Value)
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="ep-empty">
                                        <MudIcon Icon="@Icons.Material.Filled.EventBusy" />
                                        <div>لا توجد بيانات حضور للشهر الحالي.</div>
                                    </div>
                                }
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="7">
                            <MudGrid Spacing="2" Class="mb-2">
                                <MudItem xs="12" sm="4">
                                    @RenderMetricCard("معدل الحضور", (_attendanceSummary?.AttendancePercentage ?? 0).ToString("N1") + "%", (double)Math.Min((_attendanceSummary?.AttendancePercentage ?? 0), 100), "#10b981")
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    @RenderMetricCard("معدل الغياب", (_attendanceSummary is null || _attendanceSummary.WorkingDays == 0 ? 0 : ((double)_attendanceSummary.AbsentDays / _attendanceSummary.WorkingDays * 100)).ToString("N1") + "%", _attendanceSummary is null || _attendanceSummary.WorkingDays == 0 ? 0 : Math.Min(((double)_attendanceSummary.AbsentDays / _attendanceSummary.WorkingDays * 100), 100), "#ef4444")
                                </MudItem>
                                <MudItem xs="12" sm="4">
                                    @RenderMetricCard("التأخير/الحضور", (_attendanceSummary is null || _attendanceSummary.PresentDays == 0 ? 0 : ((double)_attendanceSummary.LateDays / _attendanceSummary.PresentDays * 100)).ToString("N1") + "%", _attendanceSummary is null || _attendanceSummary.PresentDays == 0 ? 0 : Math.Min(((double)_attendanceSummary.LateDays / _attendanceSummary.PresentDays * 100), 100), "#f59e0b")
                                </MudItem>
                            </MudGrid>

                            <MudPaper Class="ep-section-card" Elevation="0">
                                <div class="ep-table-head">
                                    <div>
                                        <div class="ep-section-title">آخر سجلات الحضور</div>
                                        <div class="ep-section-subtitle">أحدث الحركات المسجلة للموظف</div>
                                    </div>
