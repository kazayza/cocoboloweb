                                            <MudTh>التاريخ</MudTh>
                                            <MudTh>اليوم</MudTh>
                                            <MudTh>الحالة</MudTh>
                                            <MudTh>الحضور</MudTh>
                                            <MudTh>الانصراف</MudTh>
                                            <MudTh>التأخير</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@context.LogDateDisplay</MudTd>
                                            <MudTd>@context.DayName</MudTd>
                                            <MudTd>@context.StatusDisplay</MudTd>
                                            <MudTd>@context.TimeInDisplay</MudTd>
                                            <MudTd>@context.TimeOutDisplay</MudTd>
                                            <MudTd>@context.LateDisplay</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                                else
                                {
                                    <div class="ep-empty">
                                        <MudIcon Icon="@Icons.Material.Filled.Fingerprint" />
                                        <div>لا توجد سجلات حضور حديثة.</div>
                                    </div>
