                                    </div>
                                }
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="8">
                            <MudPaper Class="ep-section-card" Elevation="0">
                                <div class="ep-table-head">
                                    <div>
                                        <div class="ep-section-title">سجل الشيفتات</div>
                                        <div class="ep-section-subtitle">كل الشيفتات السابقة والحالية</div>
                                    </div>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@_shifts.Count سجل</MudChip>
                                </div>

                                @if (_shifts.Any())
                                {
                                    <MudTable Items="_shifts" Dense Hover Elevation="0">
                                        <HeaderContent>
                                            <MudTh>النوع</MudTh>
                                            <MudTh>الوقت</MudTh>
                                            <MudTh>أيام الراحة</MudTh>
                                            <MudTh>من</MudTh>
                                            <MudTh>إلى</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@context.ShiftType</MudTd>
                                            <MudTd>@context.StartTimeDisplay - @context.EndTimeDisplay</MudTd>
                                            <MudTd>@context.OffDaysDisplay</MudTd>
                                            <MudTd>@context.EffectiveFromDisplay</MudTd>
                                            <MudTd>@context.EffectiveToDisplay</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                                else
                                {
                                    <div class="ep-empty">
                                        <MudIcon Icon="@Icons.Material.Filled.EventBusy" />
                                        <div>لا يوجد سجل شيفتات لهذا الموظف.</div>
                                    </div>
                                }
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="الاستثناءات" Icon="@Icons.Material.Filled.EventBusy">
                <div class="ep-tab-content">
                    <MudPaper Class="ep-section-card" Elevation="0">
                        <div class="ep-table-head">
                            <div>
                                <div class="ep-section-title">الاستثناءات الخاصة بالموظف</div>
                                <div class="ep-section-subtitle">الاستثناءات المسجلة وحالتها والخصم المرتبط بها</div>
                            </div>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">@_exemptions.Count استثناء</MudChip>
                        </div>

                        @if (_exemptions.Any())
                        {
                            <MudTable Items="_exemptions" Dense Hover Elevation="0">
                                <HeaderContent>
                                    <MudTh>التاريخ</MudTh>
                                    <MudTh>السبب</MudTh>
                                    <MudTh>المدة</MudTh>
                                    <MudTh>الخصم</MudTh>
                                    <MudTh>الحالة</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.DateDisplay</MudTd>
                                    <MudTd>@context.ReasonCode</MudTd>
                                    <MudTd>@context.DurationDisplay</MudTd>
                                    <MudTd>@context.DeductionDisplay</MudTd>
                                    <MudTd>
                                        <MudChip T="string" Size="Size.Small" Style="@($"background:{context.StatusColor};color:white")">@context.StatusAr</MudChip>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="ep-empty">
                                <MudIcon Icon="@Icons.Material.Filled.EventNote" />
                                <div>لا توجد استثناءات مسجلة لهذا الموظف.</div>
                            </div>
                        }
                    </MudPaper>
                </div>
            </MudTabPanel>

            <MudTabPanel Text="النشاط" Icon="@Icons.Material.Filled.Timeline">
                <div class="ep-tab-content">
                    <MudPaper Class="ep-section-card" Elevation="0">
                        <div class="ep-table-head">
                            <div>
                                <div class="ep-section-title">التايم لاين الوظيفي</div>
                                <div class="ep-section-subtitle">أهم الأحداث التشغيلية والمالية الخاصة بالموظف</div>
                            </div>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">@ActivityFeed.Count حدث</MudChip>
                        </div>

                        @if (ActivityFeed.Any())
                        {
                            <div class="ep-activity-list">
                                @foreach (var item in ActivityFeed)
                                {
                                    <div class="ep-activity-item">
                                        <div class="ep-activity-icon" style="@($"background:{item.BgColor};color:{item.Color};")">
                                            <MudIcon Icon="@item.Icon" Size="Size.Small" />
                                        </div>
                                        <div>
                                            <div class="ep-activity-title">@item.Title</div>
                                            <div class="ep-activity-meta">@item.Meta</div>
                                        </div>
                                    </div>
                                }
