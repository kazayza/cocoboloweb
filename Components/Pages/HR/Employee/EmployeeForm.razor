@code {
    [Parameter] public int? EmployeeId { get; set; }

    private EmployeeFormDto form = new() { Status = EmployeeStatuses.Active };
    private List<SalaryHistoryDto> _salaryHistory = new();
    private List<string> _departments = new();
    private bool _isLoading = false;
    private bool isSaving = false;
    private bool isEdit = false;
    private bool _isExempt = false;
    private MudForm _form = new();
    private decimal _salaryValue = 0;
    private int _bioCodeValue = 0;

    // قائمة المؤهلات
    private List<string> _qualifications = new()
    {
        "بكالوريوس", "ليسانس", "ماجستير", "دكتوراه", "دبلوم فني",
        "دبلوم فوق المتوسط", "ثانوية عامة", "إعدادية", "أمي"
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var canAdd = user.HasClaim("Permission", "frm_Employees:Add") || user.IsInRole("Admin");
        var canEdit = user.HasClaim("Permission", "frm_Employeeslist:Edit") || user.IsInRole("Admin");

        if (EmployeeId.HasValue && EmployeeId.Value > 0)
        {
            isEdit = true;
            if (!canEdit)
            {
                Navigation.NavigateTo("/access-denied");
                return;
            }
            await LoadEmployee();
        }
        else
        {
            if (!canAdd)
            {
                Navigation.NavigateTo("/access-denied");
                return;
            }
        }

        _departments = await EmployeeService.GetDepartmentsAsync();
    }

    private async Task LoadEmployee()
    {
        _isLoading = true;
        try
        {
            var data = await EmployeeService.GetEmployeeForEditAsync(EmployeeId!.Value);
            if (data == null)
            {
                Snackbar.Add("لم يتم العثور على الموظف", Severity.Error);
                Navigation.NavigateTo("/employees");
                return;
            }

            form = data;
            _isExempt = form.IsPermanentlyExempt ?? false;
            _salaryValue = form.CurrentSalaryBase ?? 0;
            _bioCodeValue = form.BioEmployeeId ?? 0;


            _salaryHistory = await EmployeeService.GetSalaryHistoryAsync(EmployeeId!.Value);
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ═══════════════════════════════════════════
    // استخراج تاريخ الميلاد والنوع من الرقم القومي
    // ═══════════════════════════════════════════
    private void OnNationalIdKeyUp(KeyboardEventArgs e)
    {
        ExtractFromNationalId();
    }

    private void ExtractFromNationalId()
    {
        var nid = form.NationalId?.Trim() ?? "";

        if (nid.Length != 14 || !nid.All(char.IsDigit))
            return;

        try
        {
            // القرن: 2 = 1900-1999, 3 = 2000-2099
            var centuryDigit = nid[0];
            int yearPrefix = centuryDigit == '2' ? 1900 : centuryDigit == '3' ? 2000 : -1;
            if (yearPrefix == -1) return;

            // السنة (رقمين)
            var yearStr = nid.Substring(1, 2);
            if (!int.TryParse(yearStr, out var yearSuffix)) return;
            var year = yearPrefix + yearSuffix;

            // الشهر
            var monthStr = nid.Substring(3, 2);
            if (!int.TryParse(monthStr, out var month) || month < 1 || month > 12) return;

            // اليوم
            var dayStr = nid.Substring(5, 2);
            if (!int.TryParse(dayStr, out var day) || day < 1 || day > 31) return;

            // تعيين تاريخ الميلاد
            try
            {
                form.BirthDate = new DateTime(year, month, day);
            }
            catch
            {
                // تاريخ غير صالح
            }

            // النوع: الرقم الـ 13 (index 12) - فردي = ذكر، زوجي = أنثى
            var genderDigit = nid[12];
            if (char.IsDigit(genderDigit))
            {
                var digit = int.Parse(genderDigit.ToString());
                form.Gender = digit % 2 == 1 ? "ذكر" : "أنثى";
            }
        }
        catch
        {
            // في حالة أي خطأ في الاستخراج
        }
    }

    private void OnCreateDepartment(string newDept)
    {
        if (!_departments.Contains(newDept))
        {
            _departments.Add(newDept);
            form.Department = newDept;
        }
    }

    private void OnCreateQualification(string newQual)
    {
        if (!_qualifications.Contains(newQual))
        {
            _qualifications.Add(newQual);
            form.Qualification = newQual;
        }
    }

    private async Task SaveEmployee()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            Snackbar.Add("يرجى تصحيح الأخطاء في النموذج", Severity.Warning);
            return;
        }

        if (isEdit && form.SalaryChanged && string.IsNullOrWhiteSpace(form.SalaryChangeReason))
        {
            Snackbar.Add("يجب إدخال سبب تغيير المرتب", Severity.Warning);
            return;
        }

        isSaving = true;
        try
        {
            form.CurrentSalaryBase = _salaryValue;
            form.BioEmployeeId = _bioCodeValue > 0 ? _bioCodeValue : null;
            form.IsPermanentlyExempt = _isExempt;

            if (isEdit && form.OldSalary != _salaryValue)
            {
                form.SalaryChanged = true;
            }

            var userName = (await AuthProvider.GetAuthenticationStateAsync()).User.Identity?.Name ?? "System";

            if (isEdit)
            {
                var result = await EmployeeService.UpdateEmployeeAsync(EmployeeId!.Value, form, userName);
                if (result.Success)
                {
                    Snackbar.Add(result.Message, Severity.Success);
                    Navigation.NavigateTo("/employees");
                }
                else
                {
                    Snackbar.Add(result.Message, Severity.Error);
                }
            }
            else
            {
                var result = await EmployeeService.CreateEmployeeAsync(form, userName);
                if (result.Success)
                {
                    Snackbar.Add(result.Message, Severity.Success);
                    Navigation.NavigateTo("/employees");
                }
                else
                {
                    Snackbar.Add(result.Message, Severity.Error);
                }
            }
        }
        finally
        {
            isSaving = false;
        }
    }
}