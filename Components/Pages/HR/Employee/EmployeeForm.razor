@page "/employees/add"
@page "/employees/edit/{employeeId:int}"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject IEmployeeService EmployeeService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@attribute [Authorize]

@if (_isLoading)
{
    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:60vh;">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Class="mt-4" Color="Color.Primary">جاري تحميل البيانات...</MudText>
    </div>
}
else
{
    <div dir="rtl" class="employee-form-page">

        <!-- ═══════════════════════════════════════════ -->
        <!-- Header -->
        <!-- ═══════════════════════════════════════════ -->
        <div class="page-header">
            <div class="header-content">
                <button class="back-btn" @onclick="@(() => Navigation.NavigateTo("/employees"))">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
                </button>
                <div class="header-info">
                    <h1>@(isEdit ? form.FullName : "إضافة موظف جديد")</h1>
                    <div class="header-meta">
                        @if (isEdit)
                        {
                            <div class="meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" />
                                <span>كود: @form.EmployeeId</span>
                            </div>
                            <div class="meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                                <span>@(isEdit ? "تعديل بيانات" : "موظف جديد")</span>
                            </div>
                        }
                        else
                        {
                            <div class="meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" />
                                <span>موظف جديد</span>
                            </div>
                        }
                    </div>
                </div>
                @if (isEdit)
                {
                    var statusColor = form.Status switch
                    {
                        "نشط" => "#38ef7d",
                        "موقوف" => "#f5576c",
                        "مستقيل" => "#ff6b6b",
                        "بالإجازة" => "#00f2fe",
                        _ => "#999"
                    };
                    <span class="status-badge" style="background: @(statusColor)33; color: white; border: 1px solid @(statusColor)88;">
                        @form.Status
                    </span>
                }
            </div>
        </div>

        <!-- ═══════════════════════════════════════════ -->
        <!-- Tabs -->
        <!-- ═══════════════════════════════════════════ -->
        <MudPaper Class="tabs-container" Elevation="0">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
                     PanelClass="tab-panel" Class="custom-tabs">

                <!-- Tab 1: البيانات الشخصية -->
                <MudTabPanel Text="البيانات الشخصية" Icon="@Icons.Material.Filled.Person">
                    <div class="tab-content">
                        <div class="tab-header">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Class="tab-icon" />
                            <div class="tab-header-text">
                                <h2>البيانات الشخصية</h2>
                                <p>الاسم والرقم القومي وتاريخ الميلاد</p>
                            </div>
                        </div>

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>الاسم بالكامل <span class="required">*</span></label>
                                    <MudTextField T="string" @bind-Value="form.FullName"
                                                  Variant="Variant.Outlined" Placeholder="الاسم الثلاثي أو الرباعي"
                                                  Required="true" RequiredError="الاسم مطلوب"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Person" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>الرقم القومي <span class="required">*</span></label>
                                    <MudTextField T="string" @bind-Value="form.NationalId"
                                                  Variant="Variant.Outlined" Placeholder="14 رقم"
                                                  Required="true" RequiredError="الرقم القومي مطلوب"
                                                  Counter="14" MaxLength="14"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Badge"
                                                  OnKeyUp="OnNationalIdKeyUp" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>النوع</label>
                                    <MudSelect T="string" @bind-Value="form.Gender" Variant="Variant.Outlined"
                                               Placeholder="سيتم تحديده تلقائياً"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.Wc"
                                               Clearable="true">
                                        <MudSelectItem T="string" Value="@("ذكر")">ذكر</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("أنثى")">أنثى</MudSelectItem>
                                    </MudSelect>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>تاريخ الميلاد</label>
                                    <MudDatePicker Label="" @bind-Date="form.BirthDate" Variant="Variant.Outlined"
                                                   MaxDate="@DateTime.Now.AddYears(-16)"
                                                   Placeholder="سيتم تحديده تلقائياً" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>المؤهل العلمي</label>
                                    <MudSelect T="string" @bind-Value="form.Qualification" Variant="Variant.Outlined"
                                               Placeholder="اختر المؤهل"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.School"
                                               Clearable="true" Creatable="true" OnCreateValue="OnCreateQualification">
                                        @foreach (var q in _qualifications)
                                        {
                                            <MudSelectItem T="string" Value="@q">@q</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>سنة التخرج</label>
                                    <MudTextField T="string" @bind-Value="form.YearQualification"
                                                  Variant="Variant.Outlined" Placeholder="مثال: 2020"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>العنوان</label>
                                    <MudTextField T="string" @bind-Value="form.Address"
                                                  Variant="Variant.Outlined" Placeholder="العنوان التفصيلي"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.LocationOn" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudTabPanel>

                <!-- Tab 2: بيانات العمل -->
                <MudTabPanel Text="بيانات العمل" Icon="@Icons.Material.Filled.Work">
                    <div class="tab-content">
                        <div class="tab-header">
                            <MudIcon Icon="@Icons.Material.Filled.Work" Class="tab-icon" />
                            <div class="tab-header-text">
                                <h2>بيانات العمل</h2>
                                <p>الوظيفة والقسم والمرتب والحالة</p>
                            </div>
                        </div>

                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <div class="form-field">
                                    <label>المسمى الوظيفي <span class="required">*</span></label>
                                    <MudTextField T="string" @bind-Value="form.JobTitle"
                                                  Variant="Variant.Outlined" Placeholder="مثال: محاسب، مهندس"
                                                  Required="true" RequiredError="المسمى الوظيفي مطلوب"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Work" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <div class="form-field">
                                    <label>القسم</label>
                                    <MudSelect T="string" @bind-Value="form.Department" Variant="Variant.Outlined"
                                               Placeholder="اختر القسم أو أنشئ جديد"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.CorporateFare"
                                               Clearable="true" Creatable="true" OnCreateValue="OnCreateDepartment">
                                        @foreach (var dept in _departments)
                                        {
                                            <MudSelectItem T="string" Value="@dept">@dept</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <div class="form-field">
                                    <label>الحالة <span class="required">*</span></label>
                                    <MudSelect T="string" @bind-Value="form.Status" Variant="Variant.Outlined"
                                               Adornment="Adornment.Start"
                                               AdornmentIcon="@Icons.Material.Filled.ToggleOn">
                                        <MudSelectItem T="string" Value="@EmployeeStatuses.Active">
                                            <div style="display:flex; align-items:center; gap:0.5rem;">
                                                <span style="width:10px; height:10px; border-radius:50%; background:#38ef7d; display:inline-block;"></span>
                                                @EmployeeStatuses.Active
                                            </div>
                                        </MudSelectItem>
                                        <MudSelectItem T="string" Value="@EmployeeStatuses.Suspended">
                                            <div style="display:flex; align-items:center; gap:0.5rem;">
                                                <span style="width:10px; height:10px; border-radius:50%; background:#f5576c; display:inline-block;"></span>
                                                @EmployeeStatuses.Suspended
                                            </div>
                                        </MudSelectItem>
                                        <MudSelectItem T="string" Value="@EmployeeStatuses.OnLeave">
                                            <div style="display:flex; align-items:center; gap:0.5rem;">
                                                <span style="width:10px; height:10px; border-radius:50%; background:#00f2fe; display:inline-block;"></span>
                                                @EmployeeStatuses.OnLeave
                                            </div>
                                        </MudSelectItem>
                                        <MudSelectItem T="string" Value="@EmployeeStatuses.Resigned">
                                            <div style="display:flex; align-items:center; gap:0.5rem;">
                                                <span style="width:10px; height:10px; border-radius:50%; background:#ff6b6b; display:inline-block;"></span>
                                                @EmployeeStatuses.Resigned
                                            </div>
                                        </MudSelectItem>
                                    </MudSelect>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>تاريخ التعيين <span class="required">*</span></label>
                                    <MudDatePicker Label="" @bind-Date="form.HireDate" Variant="Variant.Outlined"
                                                   Required="true" Placeholder="اختر التاريخ" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>تاريخ الانتهاء</label>
                                    <MudDatePicker Label="" @bind-Date="form.EndDate" Variant="Variant.Outlined"
                                                   Placeholder="فارغ = مستمر" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>المرتب الأساسي</label>
                                    <MudNumericField T="decimal" @bind-Value="_salaryValue"
                                                     Variant="Variant.Outlined" Min="0"
                                                     Placeholder="0.00" Format="N2"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Filled.Payments" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <div class="form-field">
                                    <label>كود البصمة</label>
                                    <MudNumericField T="int" @bind-Value="_bioCodeValue"
                                                     Variant="Variant.Outlined" Min="0"
                                                     Placeholder="رقم الجهاز"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Filled.Fingerprint" />
                                </div>
                            </MudItem>
                        </MudGrid>

                        <!-- Salary Change Alert -->
                        @if (isEdit && form.SalaryChanged)
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mt-4">
                                <div style="display:flex; align-items:center; gap:0.75rem;">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" />
                                    <div>
                                        <strong>تنبيه:</strong> تم تغيير المرتب من
                                        <span style="color:var(--mud-palette-error); font-weight:700;">@form.OldSalary?.ToString("N2")</span>
                                        إلى
                                        <span style="color:var(--mud-palette-success); font-weight:700;">@form.CurrentSalaryBase?.ToString("N2")</span>
                                        ج.م
                                    </div>
                                </div>
                            </MudAlert>
                            <div class="mt-3" style="max-width:500px;">
                                <MudTextField T="string" Label="سبب تغيير المرتب *" @bind-Value="form.SalaryChangeReason"
                                              Variant="Variant.Outlined" Required="true"
                                              RequiredError="يجب إدخال سبب تغيير المرتب"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.EditNote" />
                            </div>
                        }
                    </div>
                </MudTabPanel>

                <!-- Tab 3: بيانات الاتصال -->
                <MudTabPanel Text="التواصل" Icon="@Icons.Material.Filled.ContactPhone">
                    <div class="tab-content">
                        <div class="tab-header">
                            <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Class="tab-icon" />
                            <div class="tab-header-text">
                                <h2>بيانات التواصل</h2>
                                <p>أرقام الموبايل والبريد الإلكتروني</p>
                            </div>
                        </div>

                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <div class="form-field">
                                    <label>موبايل 1</label>
                                    <MudTextField T="string" @bind-Value="form.MobilePhone"
                                                  Variant="Variant.Outlined" Placeholder="01xxxxxxxxx"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Phone" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <div class="form-field">
                                    <label>موبايل 2</label>
                                    <MudTextField T="string" @bind-Value="form.MobilePhone2"
                                                  Variant="Variant.Outlined" Placeholder="رقم إضافي"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.PhoneAndroid" />
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <div class="form-field">
                                    <label>البريد الإلكتروني</label>
                                    <MudTextField T="string" @bind-Value="form.EmailAddress"
                                                  Variant="Variant.Outlined" Placeholder="example@email.com"
                                                  InputType="InputType.Email"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Email" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudTabPanel>

                <!-- Tab 4: إعدادات إضافية -->
                <MudTabPanel Text="إعدادات إضافية" Icon="@Icons.Material.Filled.Settings">
                    <div class="tab-content">
                        <div class="tab-header">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Class="tab-icon" />
                            <div class="tab-header-text">
                                <h2>إعدادات إضافية</h2>
                                <p>الإعفاء والملاحظات</p>
                            </div>
                        </div>

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>إعفاء دائم من الحضور</label>
                                    <MudSwitch T="bool" @bind-Value="@_isExempt" Color="Color.Warning"
                                               Label="@(_isExempt ? "معفي من الحضور" : "غير معفي")" />
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="form-field">
                                    <label>ملاحظات</label>
                                    <MudTextField T="string" @bind-Value="form.Notes"
                                                  Variant="Variant.Outlined" Lines="4"
                                                  Placeholder="أي ملاحظات إضافية..."
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Notes" />
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudTabPanel>

                <!-- Tab 5: سجل المرتبات (Edit Only) -->
                @if (isEdit)
                {
                    <MudTabPanel Text="سجل المرتبات" Icon="@Icons.Material.Filled.History">
                        <div class="tab-content">
                            <div class="tab-header">
                                <MudIcon Icon="@Icons.Material.Filled.History" Class="tab-icon" />
                                <div class="tab-header-text">
                                    <h2>سجل تغييرات المرتب</h2>
                                    <p>جميع التغييرات السابقة على المرتب</p>
                                </div>
                            </div>

                            @if (_salaryHistory.Any())
                            {
                                <MudTable T="SalaryHistoryDto" Items="@_salaryHistory" Hover="true" Elevation="0"
                                          Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px; overflow: hidden;">
                                    <HeaderContent>
                                        <MudTh>التاريخ</MudTh>
                                        <MudTh>المرتب القديم</MudTh>
                                        <MudTh>المرتب الجديد</MudTh>
                                        <MudTh>الفرق</MudTh>
                                        <MudTh>السبب</MudTh>
                                        <MudTh>بواسطة</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.ChangeDate.ToString("yyyy/MM/dd")</MudTd>
                                        <MudTd>@(context.OldSalary?.ToString("N2") ?? "0") ج.م</MudTd>
                                        <MudTd Style="font-weight:600;">@context.NewSalary.ToString("N2") ج.م</MudTd>
                                        <MudTd>
                                            @{
                                                var diff = context.NewSalary - (context.OldSalary ?? 0);
                                                var diffColor = diff > 0 ? Color.Success : diff < 0 ? Color.Error : Color.Default;
                                            }
                                            <MudText Color="@diffColor" Style="font-weight:600;">
                                                @(diff > 0 ? "+" : "")@diff.ToString("N2") ج.م
                                            </MudText>
                                        </MudTd>
                                        <MudTd>@context.Reason</MudTd>
                                        <MudTd>@context.CreatedBy</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Size="Size.Large" />
                                    <h3>لا يوجد سجل تغييرات</h3>
                                    <p>لم يتم تسجيل أي تغييرات على المرتب بعد</p>
                                </div>
                            }
                        </div>
                    </MudTabPanel>
                }

            </MudTabs>
        </MudPaper>

        <!-- ═══════════════════════════════════════════ -->
        <!-- Sticky Action Buttons -->
        <!-- ═══════════════════════════════════════════ -->
        <div class="form-actions-sticky">
            <div class="form-actions">
                <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("/employees"))"
                           Size="Size.Large" StartIcon="@Icons.Material.Filled.Close"
                           Class="cancel-btn">
                    إلغاء
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SaveEmployee" Size="Size.Large"
                           Disabled="isSaving" Class="save-btn">
                    @if (isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Surface" Indeterminate="true" Class="me-2" />
                    }
                    @(isEdit ? "حفظ التعديلات" : "إضافة الموظف")
                </MudButton>
            </div>
        </div>

    </div>
}

<!-- ═══════════════════════════════════════════ -->
<!-- Styles -->
<!-- ═══════════════════════════════════════════ -->
<style>
    .employee-form-page {
        padding: 1rem;
        max-width: 1600px;
        margin: 0 auto;
        padding-bottom: 120px;
    }

    /* Header */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .back-btn {
        width: 48px;
        height: 48px;
        background: rgba(255,255,255,0.2);
        border: none;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        background: rgba(255,255,255,0.3);
        transform: translateX(5px);
    }

    .header-info { flex: 1; }

    .header-info h1 {
        color: white;
        font-size: 1.75rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
    }

    .header-meta {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255,255,255,0.9);
        font-size: 0.9rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.5rem 1.25rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 600;
        white-space: nowrap;
    }

    /* Tabs */
    .tabs-container {
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 2rem;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
    }

    .custom-tabs .mud-tabs-toolbar { padding: 1rem 1.5rem; }

    .custom-tabs .mud-tab {
        font-weight: 600;
        font-size: 0.95rem;
        padding: 0.75rem 1.5rem;
        transition: all 0.3s ease;
        color: var(--mud-palette-text-secondary) !important;
    }

    .custom-tabs .mud-tab:hover {
        background: rgba(102, 126, 234, 0.1) !important;
        color: #667eea !important;
    }

    .custom-tabs .mud-tab.mud-tab-active {
        background: var(--mud-palette-surface) !important;
        color: #667eea !important;
        border-radius: 12px 12px 0 0;
        font-weight: 700 !important;
    }

    ::deep .custom-tabs .mud-tab-slider { display: none !important; }

    .tab-panel { padding: 0 !important; }

    .tab-content { padding: 2rem; min-height: 350px; }

    .tab-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid var(--mud-palette-divider);
        flex-wrap: wrap;
    }

