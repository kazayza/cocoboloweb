@page "/my-attendance"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization

@inject IAttendanceService AttendanceService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>بصمتي وسجل حضوري — COCOBOLO ERP</PageTitle>

<AuthorizeView>
    <Authorized Context="authCtx">
        @if (_isLoading)
        {
            <div class="loading-screen">
                <div class="loading-content">
                    <div class="loading-logo">
                        <MudIcon Icon="@Icons.Material.Rounded.Fingerprint" Size="Size.Large" />
                        <div class="loading-ring"></div>
                        <div class="loading-ring ring-2"></div>
                    </div>
                    <MudText Typo="Typo.h6" Style="font-weight:700;margin-top:1rem">جاري تحميل سجل حضورك الموثق...</MudText>
                    <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Class="mt-3" Style="max-width:250px;border-radius:8px" />
                </div>
            </div>
        }
        else
        {
            <div dir="rtl" class="my-attendance-page animate-card">
                
                @* ═══════════════ HEADER (WIDE & IMMERSIVE - ERP STYLE) ═══════════════ *@
                <div class="page-header">
                    <div class="header-overlay"></div>
                    <div class="header-content">
                        <div class="header-info">
                            <div class="header-badge">
                                <MudIcon Icon="@Icons.Material.Rounded.Fingerprint" />
                            </div>
                            <div>
                                <h1>بصمتي وسجل حضوري</h1>
                                <p>الملف الشخصي لمتابعة الحضور والانصراف وساعات العمل اليومية والشهرية</p>
                            </div>
                        </div>
                        <div class="header-user-badge">
                            <MudIcon Icon="@Icons.Material.Rounded.VerifiedUser" Size="Size.Small" />
                            <span>مستند رسمي باسم: <strong>@_userName</strong></span>
                        </div>
                    </div>

                    @* الإحصائيات (Stunning Responsive KPI Cards Grid) *@
                    <div class="stats-row">
                        <div class="stat-card present">
                            <div class="stat-icon-wrap">
                                <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" />
                            </div>
                            <div class="stat-body">
                                <span class="stat-value">@_statistics.PresentCount</span>
                                <span class="stat-label">أيام حضور فعلية</span>
                            </div>
                        </div>
                        <div class="stat-card absent">
                            <div class="stat-icon-wrap">
                                <MudIcon Icon="@Icons.Material.Rounded.Cancel" />
                            </div>
                            <div class="stat-body">
                                <span class="stat-value">@_statistics.AbsentCount</span>
                                <span class="stat-label">أيام غياب</span>
                            </div>
                        </div>
                        <div class="stat-card late">
                            <div class="stat-icon-wrap">
                                <MudIcon Icon="@Icons.Material.Rounded.Alarm" />
                            </div>
                            <div class="stat-body">
                                <span class="stat-value">@_statistics.LateCount</span>
                                <span class="stat-label">أيام تأخير</span>
                            </div>
                        </div>
                        <div class="stat-card hours">
                            <div class="stat-icon-wrap">
                                <MudIcon Icon="@Icons.Material.Rounded.Timer" />
                            </div>
                            <div class="stat-body">
                                <span class="stat-value">@_statistics.TotalHours.ToString("F1")</span>
                                <span class="stat-label">إجمالي الساعات</span>
                            </div>
                        </div>
                        <div class="stat-card average">
                            <div class="stat-icon-wrap">
                                <MudIcon Icon="@Icons.Material.Rounded.Analytics" />
                            </div>
                            <div class="stat-body">
                                <span class="stat-value">@_statistics.AverageHours.ToString("F1")</span>
                                <span class="stat-label">متوسط الساعات اليومي</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ═══════════════ FILTERS CARD (PREMIUM MONTH/YEAR SELECTOR) ═══════════════ *@
                <div class="filters-card">
                    <div class="filters-title">
                        <MudIcon Icon="@Icons.Material.Rounded.FilterList" Size="Size.Small" />
                        <span>تصفية واختيار تاريخ عرض البصمة:</span>
                    </div>
                    <div class="filters-row">
                        @* Month Select *@
                        <div class="filter-field">
                            <MudSelect T="int"
                                       Label="اختر الشهر"
                                       Value="_selectedMonthVal"
                                       ValueChanged="OnMonthChanged"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                @foreach (var m in _arabicMonths)
                                {
                                    <MudSelectItem T="int" Value="@m.Key">@m.Value</MudSelectItem>
                                }
                            </MudSelect>
                        </div>

                        @* Year Select *@
                        <div class="filter-field">
                            <MudSelect T="int"
                                       Label="اختر السنة"
                                       Value="_selectedYearVal"
                                       ValueChanged="OnYearChanged"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                @foreach (var y in _years)
                                {
                                    <MudSelectItem T="int" Value="@y">@y</MudSelectItem>
                                }
                            </MudSelect>
                        </div>

                        @* Quick Nav Buttons *@
                        <div class="quick-nav-actions">
                            <button class="nav-arrow-btn" @onclick="PreviousMonth" title="الشهر السابق">
                                <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" />
                            </button>
                            <span class="current-date-lbl">
                                @_selectedMonth.ToString("MMMM yyyy", new CultureInfo("ar-EG"))
                            </span>
                            <button class="nav-arrow-btn" @onclick="NextMonth" title="الشهر التالي"
                                    disabled="@IsNextMonthDisabled()">
                                <MudIcon Icon="@Icons.Material.Rounded.ChevronLeft" />
                            </button>
                        </div>
                    </div>
                </div>

                @* ═══════════════ سجل البصمات (DATA GRID CARD) ═══════════════ *@
                <div class="table-card">
                    <div class="table-card-header">
                        <div class="tch-left">
                            <div class="tch-icon">
                                <MudIcon Icon="@Icons.Material.Rounded.History" />
                            </div>
                            <div>
                                <h3>سجل البصمات والحركات اليومية</h3>
                                <p>جدول تفصيلي لحركات الحضور والغياب وساعات التشغيل الفعلية</p>
                            </div>
                        </div>
                        <div class="tch-right">
                            <span class="days-count-badge">
                                @_attendance.Count يوم مسجل
                            </span>
                        </div>
                    </div>

                    @if (!_attendance.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-icon">
                                <MudIcon Icon="@Icons.Material.Rounded.EventBusy" />
                            </div>
                            <h3>لا توجد سجلات حضور معتمدة</h3>
                            <p>لم يتم العثور على أي حركات بصمة مسجلة باسمك في هذا الشهر المختار.</p>
                        </div>
                    }
                    else
                    {
                        <MudTable Items="_attendance" Hover="true" Elevation="0" Dense="false" Striped="true" Class="attendance-table">
                            <HeaderContent>
                                <MudTh>التاريخ</MudTh>
                                <MudTh>اليوم</MudTh>
                                <MudTh>بصمة الحضور</MudTh>
                                <MudTh>بصمة الانصراف</MudTh>
                                <MudTh>ساعات العمل</MudTh>
                                <MudTh>التأخير</MudTh>
                                <MudTh>حالة اليوم</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="item">
                                <MudTd DataLabel="التاريخ">
                                    <strong class="date-text">@item.LogDateDisplay</strong>
                                </MudTd>
                                <MudTd DataLabel="اليوم">
                                    <span class="day-chip @(item.IsWeekend ? "weekend" : "workday")">@item.DayName</span>
                                </MudTd>
                                <MudTd DataLabel="الحضور">
                                    <span class="time-text check-in @(item.TimeIn.HasValue ? "has-time" : "")">
                                        @(item.TimeIn.HasValue ? item.TimeInDisplay : "—")
                                    </span>
                                </MudTd>
                                <MudTd DataLabel="الانصراف">
                                    <span class="time-text check-out @(item.TimeOut.HasValue ? "has-time" : "")">
                                        @(item.TimeOut.HasValue ? item.TimeOutDisplay : "—")
                                    </span>
                                </MudTd>
                                <MudTd DataLabel="الساعات">
                                    <span class="hours-badge @(item.TotalHours >= 8 ? "full-hours" : "short-hours")">
                                        @item.TotalHoursDisplay
                                    </span>
                                </MudTd>
                                <MudTd DataLabel="التأخير">
                                    @if (item.IsLate)
                                    {
                                        <span class="late-badge">
                                            ⏰ @item.LateDisplay
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-disabled">—</span>
                                    }
                                </MudTd>
                                <MudTd DataLabel="الحالة">
                                    @if (item.IsAbsent)
                                    {
                                        <span class="status-badge absent">
                                            🔴 غائب
                                        </span>
                                    }
                                    else if (item.IsLate)
                                    {
                                        <span class="status-badge late">
                                            🟡 متأخر
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge present">
                                            🟢 حاضر
                                        </span>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="not-auth-screen animate-card">
            <div class="na-card">
                <div class="na-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Rounded.Lock" Size="Size.Large" />
                </div>
                <h3>تسجيل الدخول مطلوب</h3>
                <p>يرجى تسجيل الدخول إلى حسابك الخاص لتتمكن من تصفح ومتابعة حركات البصمة والرواتب.</p>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Login" OnClick='() => Navigation.NavigateTo("/login")'>تسجيل الدخول</MudButton>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    :root {
        --hdr-gradient: linear-gradient(135deg, #0f1d36 0%, #1b2a4a 50%, #2e4a7a 100%);
    }

    /* ═══ LOADING SCREEN ═══ */
    .loading-screen{display:flex;align-items:center;justify-content:center;min-height:80vh}
    .loading-content{display:flex;flex-direction:column;align-items:center;text-align:center}
    .loading-logo{position:relative;width:70px;height:70px;display:flex;align-items:center;justify-content:center;color:var(--mud-palette-secondary)}
    .loading-ring{position:absolute;inset:-8px;border:3px solid transparent;border-top-color:var(--mud-palette-secondary);border-radius:50%;animation:spin 1.2s linear infinite}
    .loading-ring.ring-2{inset:-16px;border-top-color:var(--mud-palette-primary);animation-duration:1.8s;animation-direction:reverse}
    @@keyframes spin{to{transform:rotate(360deg)}}

    /* ═══ PAGE LAYOUT ═══ */
    .my-attendance-page {
        padding: 0 1.5rem 3rem;
        max-width: 1200px;
        margin: 0 auto;
        direction: rtl;
    }

    /* ═══ HEADER (ERP PREMIUM STYLE) ═══ */
    .page-header {
        position: relative;
        background: var(--hdr-gradient);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        overflow: hidden;
        box-shadow: 0 12px 35px rgba(27,42,74,.22);
    }

    .header-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d4af37' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }

    .header-content {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
        z-index: 2;
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-badge {
        width: 54px;
        height: 54px;
        background: linear-gradient(135deg, #d4af37, #f0d060);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a2842;
        font-size: 1.6rem;
        box-shadow: 0 4px 15px rgba(212,175,55,0.4);
    }

    .header-info h1 {
        color: white;
        font-size: 1.7rem;
        font-weight: 900;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .header-info p {
        color: rgba(255,255,255,0.7);
        margin: 0.25rem 0 0 0;
        font-size: 0.88rem;
    }

    .header-user-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.18);
        padding: 6px 14px;
        border-radius: 20px;
        color: white;
        font-size: 0.8rem;
    }
    .header-user-badge strong { color: #ffd966; }

    /* ═══ STATS GRID (PREMIUM GLASS CARDS) ═══ */
    .stats-row {
        position: relative;
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.75rem;
        z-index: 2;
    }

    .stat-card {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 14px;
        padding: 0.85rem 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
    }
    .stat-card:hover {
        background: rgba(255,255,255,0.12);
        transform: translateY(-3px);
    }

    .stat-icon-wrap {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.2rem;
    }

    .stat-card.present { border-right: 4px solid #10b981; }
    .stat-card.present .stat-icon-wrap { background: rgba(16,185,129,0.15); color: #10b981; }
    
    .stat-card.absent { border-right: 4px solid #ef4444; }
    .stat-card.absent .stat-icon-wrap { background: rgba(239,68,68,0.15); color: #ef4444; }
    
    .stat-card.late { border-right: 4px solid #f59e0b; }
    .stat-card.late .stat-icon-wrap { background: rgba(245,158,11,0.15); color: #f59e0b; }
    
    .stat-card.hours { border-right: 4px solid #3b82f6; }
    .stat-card.hours .stat-icon-wrap { background: rgba(59,130,246,0.15); color: #3b82f6; }
    
    .stat-card.average { border-right: 4px solid #8b5cf6; }
    .stat-card.average .stat-icon-wrap { background: rgba(139,92,246,0.15); color: #8b5cf6; }

    .stat-body { display: flex; flex-direction: column; min-width: 0; }
    .stat-value {
        font-size: 1.25rem;
        font-weight: 900;
        color: white;
        line-height: 1.1;
    }
    .stat-label {
        font-size: 0.68rem;
        color: rgba(255,255,255,0.6);
        margin-top: 3px;
        white-space: nowrap;
    }

    /* ═══ FILTERS CARD (PREMIUM SELECTORS) ═══ */
    .filters-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 16px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .filters-title {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 0.85rem;
    }
    .filters-row {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
    }
    .filter-field {
        flex: 1;
        min-width: 150px;
    }
    .quick-nav-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--mud-palette-background);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 10px;
        padding: 4px 8px;
        flex-shrink: 0;
    }
    .nav-arrow-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: none;
        background: transparent;
        color: var(--mud-palette-text-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    .nav-arrow-btn:hover:not(:disabled) {
        background: var(--mud-palette-action-hover);
        color: var(--mud-palette-primary);
    }
    .nav-arrow-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .current-date-lbl {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
        padding: 0 0.5rem;
        white-space: nowrap;
    }

    /* ═══ TABLE CARD ═══ */
    .table-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .table-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem;
        background: var(--mud-palette-background);
        border-bottom: 1px solid var(--mud-palette-lines-default);
        flex-wrap: wrap;
        gap: 1rem;
    }
    .tch-left { display: flex; align-items: center; gap: 0.75rem; }
    .tch-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(212,175,55,0.1);
        color: var(--gold-dark, #b8860b);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .tch-left h3 { margin: 0; font-size: 1rem; font-weight: 800; color: var(--mud-palette-text-primary); }
    .tch-left p { margin: 2px 0 0; font-size: 0.75rem; color: var(--mud-palette-text-secondary); }
    .days-count-badge {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 4px 12px;
        background: rgba(212,175,55,0.15);
        color: var(--gold-dark);
        border-radius: 20px;
        border: 1px solid rgba(212,175,55,0.3);
    }

    .attendance-table {
        background: transparent;
    }
    .date-text { font-size: 0.88rem; color: var(--mud-palette-text-primary); font-weight: 700; }
    .day-chip {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 6px;
    }
    .day-chip.workday { background: var(--mud-palette-background-grey); color: var(--mud-palette-text-secondary); }
    .day-chip.weekend { background: rgba(139,92,246,0.1); color: #8b5cf6; }

    .time-text { font-size: 0.9rem; font-weight: 700; color: var(--mud-palette-text-disabled); }
    .time-text.has-time { color: var(--mud-palette-text-primary); }
    .time-text.check-in.has-time { color: #10b981; }
    .time-text.check-out.has-time { color: #ef4444; }

    .hours-badge {
        font-size: 0.78rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 8px;
        display: inline-block;
        border: 1px solid transparent;
    }
    .hours-badge.full-hours { background: rgba(16,185,129,0.06); color: #10b981; border-color: rgba(16,185,129,0.15); }
    .hours-badge.short-hours { background: rgba(245,158,11,0.06); color: #f59e0b; border-color: rgba(245,158,11,0.15); }

    .late-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 3px 8px;
        background: rgba(245,158,11,0.1);
        color: #d97706;
        border-radius: 6px;
    }

    .status-badge {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .status-badge.present { background: rgba(16,185,129,0.1); color: #10b981; }
    .status-badge.late { background: rgba(245,158,11,0.1); color: #d97706; }
    .status-badge.absent { background: rgba(239,68,68,0.1); color: #ef4444; }

    .empty-state { text-align: center; padding: 4rem 2rem; color: var(--mud-palette-text-disabled); }
    .empty-icon { width: 70px; height: 70px; border-radius: 50%; background: var(--mud-palette-background); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--mud-palette-text-disabled); border: 2px solid var(--mud-palette-lines-default); }
    .empty-state h3 { margin: .5rem 0 .2rem; color: var(--mud-palette-text-secondary); font-size: 1.1rem; font-weight: 800; }
    .empty-state p { font-size: 0.85rem; color: var(--mud-palette-text-secondary); }

    /* ═══ NOT AUTHORIZED SCREEN ═══ */
    .not-auth-screen {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 1.5rem;
    }
    .na-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 20px;
        padding: 3rem 2rem;
        max-width: 450px;
        width: 100%;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
    .na-icon-wrap {
