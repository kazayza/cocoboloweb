@code {
    private bool _isLoading = true;
    private string _userName = "";
    private DateTime _selectedMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private List<AttendanceListDto> _attendance = new();
    private AttendanceStatisticsDto _statistics = new();

    private int _selectedMonthVal;
    private int _selectedYearVal;

    // القوائم لفلترة التواريخ
    private readonly Dictionary<int, string> _arabicMonths = new()
    {
        { 1, "يناير" },
        { 2, "فبراير" },
        { 3, "مارس" },
        { 4, "أبريل" },
        { 5, "مايو" },
        { 6, "يونيو" },
        { 7, "يوليو" },
        { 8, "أغسطس" },
        { 9, "سبتمبر" },
        { 10, "أكتوبر" },
        { 11, "نوفمبر" },
        { 12, "ديسمبر" }
    };

    private readonly List<int> _years = Enumerable.Range(DateTime.Today.Year - 4, 5).OrderByDescending(y => y).ToList(); // من 2022 لـ 2026

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        _userName = authState.User.Identity?.Name ?? "مستخدم";

        // تعيين قيم الفلتر الافتراضية للشهر الحالي
        _selectedMonthVal = DateTime.Today.Month;
        _selectedYearVal = DateTime.Today.Year;

        await LoadData();
        _isLoading = false;
    }

    private async Task LoadData()
    {
        _attendance = await AttendanceService.GetMyAttendanceAsync(_userName, _selectedMonth);
        _statistics = await AttendanceService.GetMyStatisticsAsync(_userName, _selectedMonth);
    }

    private async Task OnMonthChanged(int month)
    {
        _selectedMonthVal = month;
        _selectedMonth = new DateTime(_selectedYearVal, _selectedMonthVal, 1);
        
        _isLoading = true;
        StateHasChanged();
        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task OnYearChanged(int year)
    {
        _selectedYearVal = year;
        _selectedMonth = new DateTime(_selectedYearVal, _selectedMonthVal, 1);
        
        _isLoading = true;
        StateHasChanged();
        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task PreviousMonth()
    {
        _selectedMonth = _selectedMonth.AddMonths(-1);
        _selectedMonthVal = _selectedMonth.Month;
        _selectedYearVal = _selectedMonth.Year;

        _isLoading = true;
        StateHasChanged();
        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task NextMonth()
    {
        _selectedMonth = _selectedMonth.AddMonths(1);
        _selectedMonthVal = _selectedMonth.Month;
        _selectedYearVal = _selectedMonth.Year;

        _isLoading = true;
        StateHasChanged();
        await LoadData();
        _isLoading = false;
        StateHasChanged();
    }

    private bool IsNextMonthDisabled()
    {
        return _selectedMonth.Month >= DateTime.Today.Month && _selectedMonth.Year >= DateTime.Today.Year;
    }
}