@code {
    private bool _isLoading;
    private bool _isExporting;
    private AttendanceReportFilterDto _filter = new();
    private List<AttendanceReportDto> _report = new();
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private EmployeeListDto? _selectedEmployee;

    protected override void OnInitialized()
    {
        _dateFrom = _filter.DateFrom;
        _dateTo = _filter.DateTo;
    }

    private int SummaryEmployeeCount => _report.Count;
    private int TotalPresentDays => _report.Sum(r => r.PresentDays);
    private int TotalAbsentDays => _report.Sum(r => r.AbsentDays);
    private int TotalLateDays => _report.Sum(r => r.LateDays);
    private int TotalLateMinutes => _report.Sum(r => r.TotalLateMinutes);
    private int TotalEarlyLeaveMinutes => _report.Sum(r => r.TotalEarlyLeaveMinutes);
    private decimal TotalHours => _report.Sum(r => r.TotalHours);
    private string TotalHoursDisplay => TotalHours.ToString("F0");
    private decimal AverageAttendanceRate => _report.Any() ? Math.Round(_report.Average(r => r.AttendancePercentage), 1) : 0;
    private decimal AverageAbsenceDays => _report.Any() ? Math.Round((decimal)_report.Average(r => r.AbsentDays), 1) : 0;
    private int AverageLateMinutes => _report.Any() ? (int)Math.Round(_report.Average(r => r.TotalLateMinutes), 0) : 0;
    private int AverageEarlyLeaveMinutes => _report.Any() ? (int)Math.Round(_report.Average(r => r.TotalEarlyLeaveMinutes), 0) : 0;

    private static decimal CalculateEmployeeCommitmentScore(AttendanceReportDto row)
    {
        var score = row.AttendancePercentage
                    - (row.AbsentDays * 2m)
                    - (row.TotalLateMinutes * 0.05m)
                    - (row.TotalEarlyLeaveMinutes * 0.03m);
        return Math.Max(0, Math.Round(score, 1));
    }

    private string TopDepartmentLabel => _report
        .Where(r => !string.IsNullOrWhiteSpace(r.Department))
        .GroupBy(r => r.Department!)
        .Select(g => new
        {
            Department = g.Key,
            Score = Math.Max(0, Math.Round(g.Average(x => CalculateEmployeeCommitmentScore(x)), 1))
        })
        .OrderByDescending(x => x.Score)
        .FirstOrDefault() is { } dept
            ? $"{dept.Department} • {dept.Score:F1}"
            : "—";

    private string TopAttendanceEmployeeLabel => _report
        .Select(r => new
        {
            r.EmployeeName,
            Score = CalculateEmployeeCommitmentScore(r)
        })
        .OrderByDescending(x => x.Score)
        .FirstOrDefault() is { } emp
            ? $"{emp.EmployeeName} • {emp.Score:F1}"
            : "—";

    private string CurrentRangeLabel =>
        _filter.DateFrom != default && _filter.DateTo != default
            ? $"من {_filter.DateFrom:yyyy/MM/dd} إلى {_filter.DateTo:yyyy/MM/dd}"
            : "فترة غير محددة";

    private async Task<IEnumerable<EmployeeListDto>> SearchEmployees(string value, CancellationToken ct)
    {
        return await EmployeeService.SearchEmployeesAsync(value ?? string.Empty, 20);
    }

    private Task OnEmployeeChanged(EmployeeListDto? employee)
    {
        _selectedEmployee = employee;
        _filter.EmployeeId = employee?.EmployeeId;
        return Task.CompletedTask;
    }

    private Task OnDateFromChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            _dateFrom = value.Value;
            _filter.DateFrom = value.Value;
        }
        return Task.CompletedTask;
    }

    private Task OnDateToChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            _dateTo = value.Value;
            _filter.DateTo = value.Value;
        }
        return Task.CompletedTask;
    }

    private Task SetTodayRange()
    {
        var today = DateTime.Today;
        _dateFrom = today;
        _dateTo = today;
        _filter.DateFrom = today;
        _filter.DateTo = today;
        return Task.CompletedTask;
    }

    private Task SetThisWeekRange()
    {
        var today = DateTime.Today;
        var diff = (7 + (today.DayOfWeek - DayOfWeek.Saturday)) % 7;
        _dateFrom = today.AddDays(-diff);
        _dateTo = today;
        _filter.DateFrom = _dateFrom.Value;
        _filter.DateTo = _dateTo.Value;
        return Task.CompletedTask;
    }

    private Task SetThisMonthRange()
    {
        var today = DateTime.Today;
        _dateFrom = new DateTime(today.Year, today.Month, 1);
        _dateTo = today;
        _filter.DateFrom = _dateFrom.Value;
        _filter.DateTo = _dateTo.Value;
        return Task.CompletedTask;
    }

    private Task SetLastMonthRange()
    {
        var refDate = DateTime.Today.AddMonths(-1);
        _dateFrom = new DateTime(refDate.Year, refDate.Month, 1);
        _dateTo = new DateTime(refDate.Year, refDate.Month, DateTime.DaysInMonth(refDate.Year, refDate.Month));
        _filter.DateFrom = _dateFrom.Value;
        _filter.DateTo = _dateTo.Value;
        return Task.CompletedTask;
    }

    private async Task ResetFilters()
    {
        _filter = new AttendanceReportFilterDto();
        _selectedEmployee = null;
        _dateFrom = _filter.DateFrom;
        _dateTo = _filter.DateTo;
        await GenerateReport();
    }

    private async Task GenerateReport()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _report = await AttendanceService.GetAttendanceReportAsync(_filter);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ExportReport()
    {
        _isExporting = true;
        StateHasChanged();

        try
        {
            var bytes = await AttendanceService.ExportReportToExcelAsync(_filter);
            var fileName = $"تقرير_الحضور_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync("downloadFileFromBase64", base64, fileName);
            Snackbar.Add("تم التصدير بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
        }
    }

    private string GetPercentageStyle(decimal percentage)
    {
        if (percentage >= 95) return "background: #E8F5E9; color: #2E7D32;";
        if (percentage >= 80) return "background: #FFF3E0; color: #E65100;";
        return "background: #FFEBEE; color: #C62828;";
    }
}
