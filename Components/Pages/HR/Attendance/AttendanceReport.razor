@page "/attendance/report"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject IAttendanceService AttendanceService
@inject IEmployeeService EmployeeService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS

<PageTitle>تقرير الحضور والانصراف</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 hr-page-shell attendance-report-v2">

            @* ================= HERO ================= *@
            <MudPaper Class="report-hero mb-4" Elevation="0">
                <div class="report-hero__content">
                    <div class="report-hero__headline">
                        <MudAvatar Size="Size.Large" Class="report-hero__avatar">
                            <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Medium" Color="Color.Surface" />
                        </MudAvatar>
                        <div>
                            <div class="section-header-chip mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.AutoGraph" Size="Size.Small" />
                                Attendance Reporting
                            </div>
                            <MudText Typo="Typo.h4" Color="Color.Surface" Class="font-weight-bold mb-1">
                                تقرير الحضور والانصراف
                            </MudText>
                            <MudText Typo="Typo.body2" Class="report-hero__subtitle">
                                تقرير تحليلي شامل يوضح الحضور والغياب والتأخير والساعات الفعلية حسب الفترة المحددة.
                            </MudText>
                        </div>
                    </div>

                    <div class="report-hero__actions">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Fingerprint"
                                   Href="/attendance"
                                   Class="report-action">
                            الحضور
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Dark"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="GenerateReport"
                                   Disabled="_isLoading"
                                   Class="report-action">
                            تحديث
                        </MudButton>
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                 Color="Color.Surface"
                                 Class="report-more-menu"
                                 AnchorOrigin="Origin.BottomRight"
                                 TransformOrigin="Origin.TopRight">
                            <MudMenuItem Icon="@Icons.Material.Filled.FileDownload"
                                         OnClick="ExportReport"
                                         Disabled="_isExporting || !_report.Any()">
                                @(_isExporting ? "جاري التصدير..." : "تصدير التقرير")
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.ArrowBack" Href="/attendance">
                                العودة إلى شاشة الحضور
                            </MudMenuItem>
                        </MudMenu>
                    </div>
                </div>
            </MudPaper>

            @* ================= CONTEXT BAR ================= *@
            <MudPaper Class="report-context-bar mb-3" Elevation="1">
                <div class="report-context-bar__wrap">
                    <div class="report-context-bar__group">
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                            @CurrentRangeLabel
                        </MudChip>
                        @if (!string.IsNullOrWhiteSpace(_filter.Department))
                        {
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small">
                                القسم: @_filter.Department
                            </MudChip>
                        }
                        @if (_selectedEmployee is not null)
                        {
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small">
                                الموظف: @_selectedEmployee.FullName
                            </MudChip>
                        }
                        @if (_filter.IncludeWeekends)
                        {
                            <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small">
                                يشمل الويك إند
                            </MudChip>
                        }
                    </div>

                    <div class="report-context-bar__meta">
                        <span>عدد الموظفين في التقرير: <strong>@_report.Count</strong></span>
                    </div>
                </div>
            </MudPaper>

            @* ================= FILTERS ================= *@
            <div class="sticky-filter-shell">
                <MudPaper Class="report-filter-card mb-4" Elevation="2">
                    <div class="report-filter-card__head">
                        <div>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">الفلاتر والتحكم في الفترة</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                حدد الفترة والقسم أو الموظف ثم أنشئ التقرير أو حدّثه.
                            </MudText>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SetTodayRange">اليوم</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SetThisWeekRange">هذا الأسبوع</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SetThisMonthRange">هذا الشهر</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SetLastMonthRange">الشهر الماضي</MudButton>
                        </div>
                    </div>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="3">
                            <MudDatePicker Label="من تاريخ"
                                           Date="_dateFrom"
                                           DateChanged="OnDateFromChanged"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Editable="true"
                                           DateFormat="yyyy/MM/dd" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudDatePicker Label="إلى تاريخ"
                                           Date="_dateTo"
                                           DateChanged="OnDateToChanged"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Editable="true"
                                           DateFormat="yyyy/MM/dd" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudAutocomplete T="EmployeeListDto"
                                             Label="الموظف (اختياري)"
                                             Value="_selectedEmployee"
                                             ValueChanged="OnEmployeeChanged"
                                             SearchFunc="SearchEmployees"
                                             ToStringFunc="@(e => e?.FullName ?? string.Empty)"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Clearable="true"
                                             ResetValueOnEmptyText="true">
                                <ItemTemplate Context="emp">
                                    <div class="report-employee-option">
                                        <strong>@emp.FullName</strong>
                                        <small>@(emp.Department ?? "بدون قسم")</small>
                                    </div>
                                </ItemTemplate>
                            </MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField T="string"
                                          Label="القسم"
                                          @bind-Value="_filter.Department"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Clearable="true" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudCheckBox T="bool"
                                         @bind-Value="_filter.IncludeWeekends"
                                         Color="Color.Primary"
                                         Label="تضمين الويك إند" />
                        </MudItem>
                        <MudItem xs="12" md="3" Class="d-flex align-end gap-2">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Search"
                                       OnClick="GenerateReport"
                                       Disabled="_isLoading">
                                @(_isLoading ? "جاري التحميل..." : "إنشاء التقرير")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="ResetFilters">
                                إعادة ضبط
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </div>

            @if (_isLoading)
            {
                <MudPaper Class="pa-8 text-center" Elevation="2" Style="border-radius: 16px;">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">جاري إنشاء التقرير...</MudText>
                </MudPaper>
            }
            else if (_report.Any())
            {
                @* ================= EXECUTIVE SUMMARY ================= *@
                <MudGrid Class="mb-3" Spacing="2">
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Class="pa-3 text-center rounded-xl soft-card">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">الموظفون</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@SummaryEmployeeCount</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Class="pa-3 text-center rounded-xl soft-card">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">متوسط الحضور</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-success">@AverageAttendanceRate%</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Class="pa-3 text-center rounded-xl soft-card">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">إجمالي الحضور</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-success">@TotalPresentDays</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Class="pa-3 text-center rounded-xl soft-card">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">إجمالي الغياب</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-error">@TotalAbsentDays</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Class="pa-3 text-center rounded-xl soft-card">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">إجمالي التأخير</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-warning">@TotalLateDays</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Class="pa-3 text-center rounded-xl soft-card">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">إجمالي الساعات</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-info">@TotalHoursDisplay</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Class="pa-3 text-center rounded-xl soft-card">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">الانصراف المبكر</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-secondary-v2">@TotalEarlyLeaveMinutes د</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @* ================= RESULTS SUMMARY STRIP ================= *@
                <MudPaper Class="report-summary-strip mb-3" Elevation="1">
                    <div class="report-summary-strip__grid">
                        <div class="report-summary-tile">
                            <span class="report-summary-tile__label">متوسط الغياب</span>
                            <strong class="report-summary-tile__value text-error">@AverageAbsenceDays</strong>
                        </div>
                        <div class="report-summary-tile">
                            <span class="report-summary-tile__label">متوسط التأخير</span>
                            <strong class="report-summary-tile__value text-warning">@AverageLateMinutes د</strong>
                        </div>
                        <div class="report-summary-tile">
                            <span class="report-summary-tile__label">متوسط الانصراف المبكر</span>
                            <strong class="report-summary-tile__value text-secondary-v2">@AverageEarlyLeaveMinutes د</strong>
                        </div>
                        <div class="report-summary-tile">
                            <span class="report-summary-tile__label">أفضل قسم (مؤشر التزام)</span>
                            <strong class="report-summary-tile__value">@TopDepartmentLabel</strong>
                        </div>
                        <div class="report-summary-tile">
                            <span class="report-summary-tile__label">أعلى التزام فردي</span>
                            <strong class="report-summary-tile__value text-success">@TopAttendanceEmployeeLabel</strong>
                        </div>
                    </div>
                </MudPaper>

                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                    <b>طريقة الحساب:</b>
                    يتم استخراج <b>مؤشر التزام</b> تقريبي = نسبة الحضور − (أيام الغياب × 2) − (دقائق التأخير × 0.05) − (دقائق الانصراف المبكر × 0.03).
                    أفضل قسم = أعلى متوسط مؤشر التزام على مستوى القسم.
                    أعلى التزام فردي = أعلى مؤشر التزام على مستوى الموظف.
                </MudAlert>

                @* ================= TABLE ================= *@
                <MudPaper Elevation="2" Style="border-radius: 16px; overflow: hidden;">
                    <div class="pa-4" style="background: var(--mud-palette-background-grey);">
                        <div class="d-flex align-center justify-space-between flex-wrap gap-2">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.TableChart" Color="Color.Primary" />
                                <MudText Typo="Typo.h6" Class="font-weight-bold">نتائج التقرير</MudText>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">
                                    @_report.Count موظف
                                </MudChip>
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @CurrentRangeLabel
                            </MudText>
                        </div>
                    </div>
                    <MudDivider />

                    <MudTable Items="_report" Hover="true" Elevation="0" Dense="false" Striped="true">
                        <HeaderContent>
                            <MudTh>الموظف</MudTh>
                            <MudTh>القسم</MudTh>
                            <MudTh>أيام العمل</MudTh>
                            <MudTh>حضور</MudTh>
                            <MudTh>غياب</MudTh>
                            <MudTh>تأخير</MudTh>
                            <MudTh>الساعات</MudTh>
                            <MudTh>نسبة الحضور</MudTh>
                            <MudTh>دقائق التأخير</MudTh>
                            <MudTh>دقائق الانصراف المبكر</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="item">
                            <MudTd DataLabel="الموظف">
                                <div class="d-flex align-center gap-2">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        @(item.EmployeeName.Length > 0 ? item.EmployeeName[0] : '?')
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body1" Class="font-weight-bold">@item.EmployeeName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@(item.Department ?? "--")</MudText>
                                    </div>
                                </div>
                            </MudTd>
                            <MudTd DataLabel="القسم">@(item.Department ?? "--")</MudTd>
                            <MudTd DataLabel="أيام العمل">
                                <MudText Typo="Typo.body1" Class="font-weight-bold">@item.WorkingDays</MudText>
                            </MudTd>
                            <MudTd DataLabel="حضور">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Success">
                                    @item.PresentDays
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="غياب">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(item.AbsentDays > 0 ? Color.Error : Color.Default)">
                                    @item.AbsentDays
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="تأخير">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(item.LateDays > 0 ? Color.Warning : Color.Default)">
                                    @item.LateDays
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="الساعات">
                                <MudText Typo="Typo.body1" Class="font-weight-bold text-info">
                                    @item.TotalHours.ToString("F1")
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="نسبة الحضور">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Style="@GetPercentageStyle(item.AttendancePercentage)">
                                    @item.AttendancePercentage%
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="دقائق التأخير">
                                @if (item.TotalLateMinutes > 0)
                                {
                                    <MudText Typo="Typo.body1" Color="Color.Warning" Class="font-weight-bold">
                                        @item.TotalLateMinutes د
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Color="Color.Secondary">--</MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="دقائق الانصراف المبكر">
                                @if (item.TotalEarlyLeaveMinutes > 0)
                                {
                                    <MudText Typo="Typo.body1" Class="font-weight-bold text-secondary-v2">
                                        @item.TotalEarlyLeaveMinutes د
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Color="Color.Secondary">--</MudText>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudDivider />
                    <div class="report-footer-totals">
                        <div class="report-footer-totals__grid">
                            <div class="report-footer-total-card">
                                <span class="report-footer-total-card__label">إجمالي الحضور</span>
                                <strong class="report-footer-total-card__value text-success">@TotalPresentDays</strong>
                            </div>
                            <div class="report-footer-total-card">
                                <span class="report-footer-total-card__label">إجمالي الغياب</span>
                                <strong class="report-footer-total-card__value text-error">@TotalAbsentDays</strong>
                            </div>
                            <div class="report-footer-total-card">
                                <span class="report-footer-total-card__label">إجمالي التأخير</span>
                                <strong class="report-footer-total-card__value text-warning">@TotalLateDays</strong>
                            </div>
                            <div class="report-footer-total-card">
                                <span class="report-footer-total-card__label">إجمالي الساعات</span>
                                <strong class="report-footer-total-card__value text-info">@TotalHoursDisplay</strong>
                            </div>
                            <div class="report-footer-total-card">
                                <span class="report-footer-total-card__label">إجمالي دقائق الانصراف المبكر</span>
                                <strong class="report-footer-total-card__value text-secondary-v2">@TotalEarlyLeaveMinutes</strong>
                            </div>
                        </div>
                    </div>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="pa-8 text-center" Elevation="2" Style="border-radius: 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.Assessment"
                             Size="Size.Large"
                             Style="font-size: 64px; color: #E0E0E0;" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">
                        اختر الفترة واضغط "إنشاء التقرير"
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        يمكنك تحديد موظف واحد أو قسم كامل أو تشغيل التقرير على جميع الموظفين.
                    </MudText>
                </MudPaper>
            }
        </MudContainer>
    </Authorized>

    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
            <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius:20px;">
                <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Large" Style="font-size:64px; color:#FF9800;" Class="mb-4" />
                <MudText Typo="Typo.h5" Color="Color.Warning" Class="mb-2">تسجيل الدخول مطلوب</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    يرجى تسجيل الدخول للوصول إلى شاشة التقارير
                </MudText>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

<style>
    .attendance-report-v2 {
        direction: rtl;
    }

    .report-hero {
        border-radius: 20px;
        overflow: hidden;
        background: linear-gradient(135deg, #4A148C 0%, #7B1FA2 50%, #9C27B0 100%);
        box-shadow: 0 12px 32px rgba(123, 31, 162, 0.18);
    }

    .report-hero__content {
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .report-hero__headline {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .report-hero__avatar {
        background: rgba(255,255,255,.15);
        backdrop-filter: blur(10px);
    }

    .report-hero__subtitle {
        color: rgba(255,255,255,.80);
        max-width: 760px;
    }

    .report-hero__actions {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .report-action {
        min-height: 44px;
        border-radius: 12px;
        padding-inline: 14px;
    }

    .report-context-bar,
    .report-summary-strip,
    .report-filter-card {
        border-radius: 16px;
        border: 1px solid rgba(148,163,184,.18);
    }

    .report-context-bar__wrap {
        padding: .8rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .report-context-bar__group {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .report-context-bar__meta {
        color: var(--mud-palette-text-secondary);
        font-size: .85rem;
    }

    .report-filter-card {
        padding: 1rem;
    }

    .report-filter-card__head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .report-summary-strip__grid {
        padding: .85rem 1rem;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .75rem;
    }

    .report-summary-tile {
        background: rgba(148,163,184,.08);
        border-radius: 14px;
        padding: .75rem .85rem;
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

    .report-summary-tile__label {
        font-size: .78rem;
        color: var(--mud-palette-text-secondary);
    }

    .report-summary-tile__value {
        font-size: 1.02rem;
        font-weight: 800;
        color: var(--mud-palette-text-primary);
    }

    .report-footer-totals {
        background: var(--mud-palette-background-grey);
        padding: 1rem;
    }

    .report-footer-totals__grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: .75rem;
    }

    .report-footer-total-card {
        background: var(--mud-palette-surface);
        border: 1px solid rgba(148,163,184,.18);
        border-radius: 14px;
        padding: .85rem;
        display: flex;
