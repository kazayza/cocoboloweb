@page "/attendance/dashboard"
@using ApexCharts
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudColor = MudBlazor.Color
@using MudSize  = MudBlazor.Size

@inject IAttendanceService AttendanceService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>لوحة تحليل الحضور</PageTitle>

<style>
    .dash-root {
        padding-top: max(1rem, env(safe-area-inset-top));
        padding-bottom: max(1rem, env(safe-area-inset-bottom));
        padding-left: max(1rem, env(safe-area-inset-left));
        padding-right: max(1rem, env(safe-area-inset-right));
        min-height: 100svh;
    }

    .dash-header { border-radius: 24px !important; overflow: hidden; border: none !important; }

    .dash-header-bg {
        position: relative;
        background: linear-gradient(135deg, #0F172A 0%, #1E293B 40%, #334155 100%);
    }

    .dash-header-bg::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse at 20% 50%, rgba(99,102,241,0.15) 0%, transparent 50%),
            radial-gradient(ellipse at 80% 20%, rgba(34,197,94,0.1)  0%, transparent 50%),
            radial-gradient(ellipse at 60% 80%, rgba(245,158,11,0.08) 0%, transparent 50%);
        pointer-events: none;
    }

    .dash-header-content {
        position: relative;
        z-index: 2;
        padding: 28px 24px 0;
    }

    .dash-header-avatar {
        background: rgba(255,255,255,0.1) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.15);
    }

    .period-chips .mud-chip {
        background: rgba(255,255,255,0.08) !important;
        color: rgba(255,255,255,0.7) !important;
        border: 1px solid rgba(255,255,255,0.12) !important;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        transition: all 0.3s ease;
        font-weight: 500;
    }
    .period-chips .mud-chip:hover { background: rgba(255,255,255,0.15) !important; color: white !important; }
    .period-chips .mud-chip-selected,
    .period-chips .mud-chip[aria-selected="true"] {
        background: rgba(255,255,255,0.2) !important;
        color: white !important;
        border-color: rgba(255,255,255,0.35) !important;
        font-weight: 700;
    }

    .dash-quick-stats {
        background: rgba(0,0,0,0.2);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        padding: 24px;
        position: relative;
        z-index: 2;
    }

    .glass-stat {
        background: rgba(255,255,255,0.07);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 16px;
        padding: 20px 16px;
        text-align: center;
        transition: all 0.3s ease;
    }
    .glass-stat:hover { background: rgba(255,255,255,0.12); transform: translateY(-2px); }

    .glass-stat-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 12px;
    }
    .glass-stat-val { font-size: 1.75rem !important; font-weight: 800 !important; color: white; letter-spacing: -0.5px; line-height: 1.2; }
    .glass-stat-lbl { font-size: 0.75rem !important; color: rgba(255,255,255,0.5) !important; margin-top: 4px; }

    .mod-card { border: 1px solid #E2E8F0 !important; border-radius: 20px !important; transition: all 0.3s ease; background: white !important; }
    .mod-card:hover { border-color: #CBD5E1 !important; box-shadow: 0 4px 24px rgba(0,0,0,0.04) !important; }

    .sec-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

    .st-mini { text-align: center; padding: 16px 8px; border-radius: 16px; transition: all 0.3s ease; }
    .st-mini:hover { transform: scale(1.03); }
    .st-present { background: #F0FDF4; }
    .st-absent  { background: #FEF2F2; }
    .st-late    { background: #FFFBEB; }

    .summary-box { background: #F8FAFC; border-radius: 12px; padding: 12px 16px; }

    .dept-row {
        padding: 12px; border-radius: 12px;
        background: #F8FAFC; border: 1px solid #F1F5F9; transition: all 0.2s ease;
    }
    .dept-row:hover { background: #F1F5F9; border-color: #E2E8F0; }

    .rank-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px; border-radius: 12px;
        background: #F8FAFC; border: 1px solid #F1F5F9; transition: all 0.2s ease;
    }
    .rank-row:hover { background: #F1F5F9; }
    .rank-row.warn-row { background: #FFFBEB; border-color: #FEF3C7; }
    .rank-row.warn-row:hover { background: #FEF3C7; }

    .rank-num {
        width: 32px; height: 32px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: 14px; flex-shrink: 0; color: white;
    }
    .rk-gold   { background: linear-gradient(135deg, #F59E0B, #D97706); }
    .rk-silver { background: linear-gradient(135deg, #9CA3AF, #6B7280); }
    .rk-bronze { background: linear-gradient(135deg, #D97706, #92400E); }
    .rk-def    { background: #E2E8F0; color: #64748B; }

    .live-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 4px 12px; border-radius: 20px;
        background: #F0FDF4; color: #22C55E; font-size: 12px; font-weight: 600;
    }
    .live-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: #22C55E; animation: pulseDot 2s infinite;
    }
    @@keyframes pulseDot {
        0%,100% { opacity:1; transform:scale(1); }
        50%      { opacity:0.5; transform:scale(0.8); }
    }

    .tl-wrap { max-height: 400px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: #E2E8F0 transparent; }
    .tl-wrap::-webkit-scrollbar { width: 4px; }
    .tl-wrap::-webkit-scrollbar-thumb { background: #E2E8F0; border-radius: 4px; }

    .tl-item { padding: 10px 12px; border-radius: 12px; background: #F8FAFC; border: 1px solid #F1F5F9; transition: all 0.2s ease; }
    .tl-item:hover { background: #F1F5F9; }

    .tl-dot { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .tl-in  { background: linear-gradient(135deg, #22C55E, #16A34A); }
    .tl-out { background: linear-gradient(135deg, #3B82F6, #2563EB); }

    .empty-state { text-align: center; padding: 32px 16px; }

    .apexcharts-canvas text,
    .apexcharts-legend-text { font-family: inherit !important; }
    .apexcharts-tooltip {
        direction: rtl !important; text-align: right !important;
        border-radius: 12px !important; box-shadow: 0 4px 20px rgba(0,0,0,0.1) !important;
    }

    @@media (max-width: 600px) {
        .dash-header  { border-radius: 16px !important; }
        .mod-card     { border-radius: 16px !important; }
        .glass-stat   { padding: 14px 10px; }
        .glass-stat-val { font-size: 1.3rem !important; }
        .glass-stat-lbl { font-size: 0.65rem !important; }
        .dash-header-content { padding: 20px 16px 0; }
        .dash-quick-stats    { padding: 16px; }
        .sec-icon { width: 30px; height: 30px; border-radius: 8px; }
    }
    @@media (max-width: 380px) {
        .glass-stat-val { font-size: 1.1rem !important; }
    }
</style>

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 dash-root">

            @* ══════════════════ HEADER ══════════════════ *@
            <MudPaper Class="mb-5 dash-header" Elevation="0">
                <div class="dash-header-bg">

                    <div class="dash-header-content">
                        <div class="d-flex align-center justify-space-between flex-wrap gap-3 mb-5">
                            <div class="d-flex align-center gap-3">
                                <MudAvatar Size="@MudSize.Large" Class="dash-header-avatar">
                                    <MudIcon Icon="@Icons.Material.Filled.Analytics"
                                             Size="@MudSize.Medium" Style="color:white;" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.h5" Style="color:white;font-weight:800;letter-spacing:-0.5px;">
                                        لوحة تحليل الحضور والانصراف
                                    </MudText>
                                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.6);">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth"
                                                 Size="@MudSize.Small" Style="vertical-align:middle;" />
                                        @_selectedPeriod — آخر تحديث: @DateTime.Now.ToString("hh:mm tt")
                                    </MudText>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2 align-center">
                                <MudChipSet T="string" SelectedValue="_periodFilter"
                                            SelectedValueChanged="OnPeriodChanged"
                                            SelectionMode="SelectionMode.SingleSelection"
                                            Class="period-chips">
                                    <MudChip T="string" Value="@("today")"   Icon="@Icons.Material.Filled.Today">اليوم</MudChip>
                                    <MudChip T="string" Value="@("week")"    Icon="@Icons.Material.Filled.DateRange">الأسبوع</MudChip>
                                    <MudChip T="string" Value="@("month")"   Icon="@Icons.Material.Filled.CalendarMonth">الشهر</MudChip>
                                    <MudChip T="string" Value="@("lastMonth")" Icon="@Icons.Material.Filled.History">الشهر الماضي</MudChip>
                                </MudChipSet>

                                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                               Style="color:white;background:rgba(255,255,255,0.15);"
                                               Size="@MudSize.Medium"
                                               OnClick="LoadDashboard"
                                               Disabled="_isLoading" />
                            </div>
                        </div>
                    </div>

                    <div class="dash-quick-stats">
                        <MudGrid Spacing="3">
                            <MudItem xs="6" sm="3">
                                <div class="glass-stat">
                                    <div class="glass-stat-icon" style="background:rgba(129,199,132,0.25);">
                                        <MudIcon Icon="@Icons.Material.Filled.Groups" Style="color:#81C784;" Size="@MudSize.Medium" />
                                    </div>
                                    <div class="glass-stat-val">@(_isLoading ? "—" : _dashboard.Statistics.TotalEmployees.ToString("N0"))</div>
                                    <div class="glass-stat-lbl">إجمالي الموظفين</div>
                                </div>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <div class="glass-stat">
                                    <div class="glass-stat-icon" style="background:rgba(100,181,246,0.25);">
                                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="color:#64B5F6;" Size="@MudSize.Medium" />
                                    </div>
                                    <div class="glass-stat-val" style="color:#81C784;">@(_isLoading ? "—" : $"{_dashboard.Statistics.AttendanceRate}%")</div>
                                    <div class="glass-stat-lbl">نسبة الحضور</div>
                                </div>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <div class="glass-stat">
                                    <div class="glass-stat-icon" style="background:rgba(255,183,77,0.25);">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Style="color:#FFB74D;" Size="@MudSize.Medium" />
                                    </div>
                                    <div class="glass-stat-val" style="color:#FFB74D;">@(_isLoading ? "—" : $"{_dashboard.Statistics.LateRate}%")</div>
                                    <div class="glass-stat-lbl">نسبة التأخير</div>
                                </div>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <div class="glass-stat">
                                    <div class="glass-stat-icon" style="background:rgba(206,147,216,0.25);">
                                        <MudIcon Icon="@Icons.Material.Filled.AvTimer" Style="color:#CE93D8;" Size="@MudSize.Medium" />
                                    </div>
                                    <div class="glass-stat-val" style="color:#CE93D8;">@(_isLoading ? "—" : _dashboard.Statistics.AverageHours.ToString("F1"))</div>
                                    <div class="glass-stat-lbl">متوسط الساعات</div>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </div>
            </MudPaper>

            @* ══════════════════ LOADING ══════════════════ *@
            @if (_isLoading)
            {
                <MudGrid Spacing="4">
                    @for (int i = 0; i < 3; i++)
                    {
                        <MudItem xs="12" md="4">
                            <MudPaper Class="pa-6 mod-card" Elevation="0">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="20px" Width="40%" Class="mb-4 rounded" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-lg" />
                            </MudPaper>
                        </MudItem>
                    }
                    @for (int i = 0; i < 2; i++)
                    {
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-6 mod-card" Elevation="0">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="20px" Width="30%" Class="mb-4 rounded" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="250px" Class="rounded-lg" />
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                @* ══════════════════ ROW 1 ══════════════════ *@
                <MudGrid Spacing="4" Class="mb-5">

                    @* حالة اليوم *@
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-5 mod-card" Elevation="0" Style="height:100%;">
                            <div class="d-flex align-center gap-2 mb-4">
                                <div class="sec-icon" style="background:#EEF2FF;">
                                    <MudIcon Icon="@Icons.Material.Filled.Today" Style="color:#6366F1;" Size="@MudSize.Small" />
                                </div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">حالة اليوم</MudText>
                            </div>

                            <MudGrid Spacing="3">
                                <MudItem xs="4">
                                    <div class="st-mini st-present">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="@MudColor.Success" Size="@MudSize.Small" />
                                        <MudText Typo="Typo.h4" Color="@MudColor.Success" Class="font-weight-bold mt-1">@_dashboard.Statistics.TodayPresent</MudText>
                                        <MudText Typo="Typo.caption" Style="color:#64748B;">حاضر</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="4">
                                    <div class="st-mini st-absent">
                                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="@MudColor.Error" Size="@MudSize.Small" />
                                        <MudText Typo="Typo.h4" Color="@MudColor.Error" Class="font-weight-bold mt-1">@_dashboard.Statistics.TodayAbsent</MudText>
                                        <MudText Typo="Typo.caption" Style="color:#64748B;">غائب</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="4">
                                    <div class="st-mini st-late">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Color="@MudColor.Warning" Size="@MudSize.Small" />
                                        <MudText Typo="Typo.h4" Color="@MudColor.Warning" Class="font-weight-bold mt-1">@_dashboard.Statistics.TodayLate</MudText>
                                        <MudText Typo="Typo.caption" Style="color:#64748B;">متأخر</MudText>
                                    </div>
                                </MudItem>
                            </MudGrid>

                            <div class="mt-5">
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2" Style="color:#64748B;">نسبة الحضور اليوم</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold"
                                             Style="@($"color:{GetRateColor(GetTodayRate())}")">
                                        @GetTodayRate()%
                                    </MudText>
                                </div>
                                <MudProgressLinear Value="@GetTodayRate()"
                                                   Color="@GetBarColor(GetTodayRate())"
                                                   Rounded="true" Size="@MudSize.Large"
                                                   Style="height:10px;" />
                            </div>

                            <div class="summary-box mt-4">
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.caption" Style="color:#94A3B8;">إجمالي ساعات العمل</MudText>
                                    <MudText Typo="Typo.caption" Class="font-weight-bold">
                                        @((_dashboard.Statistics.AverageHours * _dashboard.Statistics.TodayPresent).ToString("F0")) ساعة
                                    </MudText>
                                </div>
                                <div class="d-flex justify-space-between">
                                    <MudText Typo="Typo.caption" Style="color:#94A3B8;">متوسط وقت الوصول</MudText>
                                    <MudText Typo="Typo.caption" Class="font-weight-bold">08:12 ص</MudText>
                                </div>
                            </div>
                        </MudPaper>
                    </MudItem>

                    @* Donut *@
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-5 mod-card" Elevation="0" Style="height:100%;">
                            <div class="d-flex align-center gap-2 mb-4">
                                <div class="sec-icon" style="background:#FEF3C7;">
                                    <MudIcon Icon="@Icons.Material.Filled.DonutLarge" Style="color:#F59E0B;" Size="@MudSize.Small" />
                                </div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">توزيع الحالات</MudText>
                            </div>
                            <ApexChart TItem="StatusChartItem" Options="_donutOpts" Height="280">
                                <ApexPointSeries TItem="StatusChartItem"
                                                 Items="_statusData" Name="الحالة"
                                                 SeriesType="SeriesType.Donut"
                                                 XValue="e => e.Label"
                                                 YValue="e => e.Value" />
                            </ApexChart>
                        </MudPaper>
                    </MudItem>

                    @* Bar *@
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-5 mod-card" Elevation="0" Style="height:100%;">
                            <div class="d-flex align-center gap-2 mb-4">
                                <div class="sec-icon" style="background:#DBEAFE;">
                                    <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="color:#3B82F6;" Size="@MudSize.Small" />
                                </div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">توزيع الحضور بالساعة</MudText>
                            </div>
                            <ApexChart TItem="HourlyChartItem" Options="_barOpts" Height="280">
                                <ApexPointSeries TItem="HourlyChartItem"
                                                 Items="_hourlyData" Name="عدد الموظفين"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="e => e.Hour"
                                                 YValue="e => e.Count" />
                            </ApexChart>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @* ══════════════════ ROW 2 ══════════════════ *@
                <MudGrid Spacing="4" Class="mb-5">

                    @* Area Chart *@
                    <MudItem xs="12" lg="8">
                        <MudPaper Class="pa-5 mod-card" Elevation="0">
                            <div class="d-flex align-center justify-space-between mb-4 flex-wrap gap-2">
                                <div class="d-flex align-center gap-2">
                                    <div class="sec-icon" style="background:#F0FDF4;">
                                        <MudIcon Icon="@Icons.Material.Filled.ShowChart" Style="color:#22C55E;" Size="@MudSize.Small" />
                                    </div>
                                    <MudText Typo="Typo.h6" Class="font-weight-bold">اتجاه الحضور اليومي</MudText>
                                </div>
                                <div class="d-flex gap-3">
                                    <div class="d-flex align-center gap-1">
                                        <div style="width:10px;height:10px;background:#22C55E;border-radius:50%;"></div>
                                        <MudText Typo="Typo.caption">حضور</MudText>
                                    </div>
                                    <div class="d-flex align-center gap-1">
                                        <div style="width:10px;height:10px;background:#EF4444;border-radius:50%;"></div>
                                        <MudText Typo="Typo.caption">غياب</MudText>
                                    </div>
                                    <div class="d-flex align-center gap-1">
                                        <div style="width:10px;height:10px;background:#F59E0B;border-radius:50%;"></div>
                                        <MudText Typo="Typo.caption">تأخير</MudText>
                                    </div>
                                </div>
                            </div>
                            <ApexChart TItem="TrendChartItem" Options="_areaOpts" Height="320">
                                <ApexPointSeries TItem="TrendChartItem" Items="_trendData"
                                                 Name="نسبة الحضور" SeriesType="SeriesType.Area"
                                                 XValue="e => e.Day" YValue="e => e.AttendRate"
                                                 Color="#22C55E" />
                                <ApexPointSeries TItem="TrendChartItem" Items="_trendData"
                                                 Name="نسبة الغياب" SeriesType="SeriesType.Area"
                                                 XValue="e => e.Day" YValue="e => e.AbsentRate"
                                                 Color="#EF4444" />
                                <ApexPointSeries TItem="TrendChartItem" Items="_trendData"
                                                 Name="نسبة التأخير" SeriesType="SeriesType.Area"
                                                 XValue="e => e.Day" YValue="e => e.LateRate"
                                                 Color="#F59E0B" />
                            </ApexChart>
                        </MudPaper>
                    </MudItem>

                    @* الأقسام *@
                    <MudItem xs="12" lg="4">
                        <MudPaper Class="pa-5 mod-card" Elevation="0" Style="height:100%;">
                            <div class="d-flex align-center gap-2 mb-4">
                                <div class="sec-icon" style="background:#FEE2E2;">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Style="color:#EF4444;" Size="@MudSize.Small" />
                                </div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">الأقسام</MudText>
                            </div>

                            @if (_dashboard.ByDepartment.Any())
                            {
                                <div class="d-flex flex-column gap-3">
                                    @foreach (var dept in _dashboard.ByDepartment.OrderByDescending(d => d.AttendanceRate))
                                    {
                                        <div class="dept-row">
                                            <div class="d-flex justify-space-between align-center mb-2">
                                                <div class="d-flex align-center gap-2">
                                                    <MudAvatar Size="@MudSize.Small"
                                                               Style="@($"background:{DeptBg(dept.AttendanceRate)};color:{DeptFg(dept.AttendanceRate)};font-size:12px;font-weight:700;")">
                                                        @dept.Department[0]
                                                    </MudAvatar>
                                                    <div>
                                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@dept.Department</MudText>
                                                        <MudText Typo="Typo.caption" Style="color:#94A3B8;">
                                                            @dept.EmployeeCount موظف · @dept.AverageHours ساعة
                                                        </MudText>
                                                    </div>
                                                </div>
                                                <MudText Typo="Typo.body2" Class="font-weight-bold"
                                                         Style="@($"color:{GetRateColor((double)dept.AttendanceRate)}")">
                                                    @dept.AttendanceRate%
                                                </MudText>
                                            </div>
                                            <MudProgressLinear Value="@((double)dept.AttendanceRate)"
                                                               Color="@GetBarColor((double)dept.AttendanceRate)"
                                                               Rounded="true" Size="@MudSize.Small" />
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderOff" Size="@MudSize.Large" Style="color:#CBD5E1;" />
                                    <MudText Typo="Typo.body2" Style="color:#94A3B8;" Class="mt-2">لا توجد بيانات أقسام</MudText>
                                </div>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @* ══════════════════ ROW 3 ══════════════════ *@
                <MudGrid Spacing="4" Class="mb-5">

                    @* أفضل الموظفين *@
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-5 mod-card" Elevation="0" Style="height:100%;">
                            <div class="d-flex align-center gap-2 mb-4">
                                <div class="sec-icon" style="background:#FFFBEB;">
                                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Style="color:#F59E0B;" Size="@MudSize.Small" />
                                </div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">الأكثر التزاماً</MudText>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                @foreach (var (emp, idx) in _dashboard.TopEmployees.Select((e, i) => (e, i)))
                                {
                                    <div class="rank-row">
                                        <div class="d-flex align-center gap-3">
                                            <div class="rank-num @RankCls(idx)">@((idx + 1).ToString())</div>
                                            <div>
                                                <MudText Typo="Typo.body2" Class="font-weight-bold">@emp.EmployeeName</MudText>
                                                <MudText Typo="Typo.caption" Style="color:#94A3B8;">@emp.Department</MudText>
                                            </div>
                                        </div>
                                        <MudChip T="string" Size="@MudSize.Small"
                                                 Variant="Variant.Text" Color="@MudColor.Success"
                                                 Class="font-weight-bold">
                                            @emp.AttendanceRate%
                                        </MudChip>
                                    </div>
                                }
                            </div>
                        </MudPaper>
                    </MudItem>

                    @* يحتاجون متابعة *@
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-5 mod-card" Elevation="0" Style="height:100%;">
                            <div class="d-flex align-center gap-2 mb-4">
                                <div class="sec-icon" style="background:#FEF2F2;">
                                    <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Style="color:#EF4444;" Size="@MudSize.Small" />
                                </div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">يحتاجون متابعة</MudText>
                            </div>
                            @if (_dashboard.BottomEmployees.Any())
                            {
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var emp in _dashboard.BottomEmployees)
                                    {
                                        <div class="rank-row warn-row">
                                            <div class="d-flex align-center gap-3">
                                                <MudAvatar Size="@MudSize.Small" Style="background:#FEE2E2;color:#EF4444;">
                                                    <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="@MudSize.Small" />
                                                </MudAvatar>
                                                <div>
                                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@emp.EmployeeName</MudText>
                                                    <MudText Typo="Typo.caption" Style="color:#94A3B8;">
                                                        غياب @emp.AbsentDays يوم · تأخير @emp.LateDays يوم
                                                    </MudText>
                                                </div>
                                            </div>
                                            <MudChip T="string" Size="@MudSize.Small"
                                                     Variant="Variant.Text" Color="@MudColor.Error"
                                                     Class="font-weight-bold">
                                                @emp.AttendanceRate%
                                            </MudChip>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <MudIcon Icon="@Icons.Material.Filled.Verified" Size="@MudSize.Large" Style="color:#22C55E;" />
                                    <MudText Typo="Typo.body2" Style="color:#22C55E;" Class="mt-2 font-weight-bold">
                                        جميع الموظفين ملتزمين
                                    </MudText>
                                </div>
                            }
                        </MudPaper>
                    </MudItem>

                    @* آخر البصمات *@
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-5 mod-card" Elevation="0" Style="height:100%;">
                            <div class="d-flex align-center justify-space-between mb-4">
                                <div class="d-flex align-center gap-2">
                                    <div class="sec-icon" style="background:#F0F9FF;">
                                        <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Style="color:#0EA5E9;" Size="@MudSize.Small" />
                                    </div>
                                    <MudText Typo="Typo.h6" Class="font-weight-bold">آخر البصمات</MudText>
                                </div>
                                <div class="live-badge">
                                    <span class="live-dot"></span> مباشر
                                </div>
                            </div>

                            @if (_dashboard.RecentLogs.Any())
                            {
                                <div class="d-flex flex-column gap-2 tl-wrap">
                                    @foreach (var log in _dashboard.RecentLogs.Take(6))
                                    {
                                        <div class="tl-item">
                                            <div class="d-flex align-center gap-3">
                                                <div class="tl-dot @(log.LogType == "حضور" ? "tl-in" : "tl-out")">
                                                    <MudIcon Icon="@(log.LogType == "حضور" ? Icons.Material.Filled.Login : Icons.Material.Filled.Logout)"
                                                             Size="@MudSize.Small" Style="color:white;" />
                                                </div>
                                                <div style="flex:1;">
                                                    <div class="d-flex justify-space-between align-center">
                                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@log.EmployeeName</MudText>
                                                        <MudText Typo="Typo.caption" Class="font-weight-bold" Style="color:#64748B;">@log.LogTimeDisplay</MudText>
                                                    </div>
                                                    <div class="d-flex align-center gap-2 mt-1">
                                                        <MudText Typo="Typo.caption" Style="color:#94A3B8;">@log.Department</MudText>
                                                        @if (log.IsLate)
                                                        {
                                                            <MudChip T="string" Size="@MudSize.Small"
                                                                     Variant="Variant.Text" Color="@MudColor.Warning"
                                                                     Style="height:20px;font-size:10px;">متأخر</MudChip>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state">
                                    <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Size="@MudSize.Large" Style="color:#CBD5E1;" />
                                    <MudText Typo="Typo.body2" Style="color:#94A3B8;" Class="mt-2">لا توجد بصمات بعد</MudText>
                                </div>
                            }
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }

        </MudContainer>
    </Authorized>
</AuthorizeView>

@code {
    // ══════════════════════════════════════════
    // Type Aliases — حل تعارض ApexCharts/MudBlazor
    // ══════════════════════════════════════════
    private bool _isLoading = true;
    private string _periodFilter = "month";
    private string _selectedPeriod = "";
    private AttendanceDashboardDto _dashboard = new();

    // ══════════════════ Chart Data ══════════════════
    private List<StatusChartItem> _statusData  = new();
    private List<HourlyChartItem> _hourlyData  = new();
    private List<TrendChartItem>  _trendData   = new();

    // ══════════════════ Chart Options ══════════════════
    private ApexChartOptions<StatusChartItem> _donutOpts = new();
    private ApexChartOptions<HourlyChartItem> _barOpts   = new();
    private ApexChartOptions<TrendChartItem>  _areaOpts  = new();

    // ══════════════════ Chart Models ══════════════════
    public record StatusChartItem(string Label, decimal Value);
    public record HourlyChartItem(string Hour,  decimal Count);
    public record TrendChartItem (string Day, decimal AttendRate, decimal AbsentRate, decimal LateRate);

    // ══════════════════ Lifecycle ══════════════════
    protected override async Task OnInitializedAsync()
    {
        InitChartOptions();
        await LoadDashboard();
    }

    private void InitChartOptions()
    {
        // ── Donut ──
        _donutOpts = new ApexChartOptions<StatusChartItem>
        {
            Colors = new List<string> { "#22C55E", "#EF4444", "#F59E0B" },
            PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    Donut = new PlotOptionsDonut
                    {
                        Size = "75%",
                        Labels = new DonutLabels
                        {
                            Show  = true,
                            Name  = new DonutLabelName  { Show = true },
                            Value = new DonutLabelValue { Show = true },
                            Total = new DonutLabelTotal { Show = true, Label = "الإجمالي" }
                        }
                    }
                }
            },
            Legend      = new Legend      { Position = LegendPosition.Bottom, FontFamily = "inherit" },
            Chart       = new Chart       { FontFamily = "inherit" },
            Stroke      = new Stroke      { Colors = new List<string> { "#FFFFFF" } },
            DataLabels  = new DataLabels  { Enabled = false }
        };

        // ── Bar ──
        _barOpts = new ApexChartOptions<HourlyChartItem>
        {
            Colors  = new List<string> { "#6366F1" },
            Chart   = new Chart  { Toolbar = new Toolbar { Show = false }, FontFamily = "inherit" },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar { BorderRadius = 6, ColumnWidth = "60%" }
            },
            Grid        = new Grid       { StrokeDashArray = 4, BorderColor = "#F1F5F9" },
            Xaxis       = new XAxis      { Labels = new XAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit" } } },
            Yaxis       = new List<YAxis>
            {
                new YAxis
                {
                    Opposite = true,
                    Labels   = new YAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit" } }
                }
            },
            DataLabels  = new DataLabels { Enabled = false },
            Tooltip = new Tooltip { Theme = Mode.Light }
        };

        // ── Area ──
        _areaOpts = new ApexChartOptions<TrendChartItem>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
                FontFamily = "inherit",
                Zoom = new Zoom { Enabled = false }
            },
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 3 },
            Fill   = new Fill
            {
                Type     = new List<FillType> { FillType.Gradient },
                Gradient = new FillGradient
                {
                    ShadeIntensity = 1,
                    OpacityFrom    = 0.25,
                    OpacityTo      = 0.02,
                    Stops          = new List<double> { 0, 95, 100 }
                }
            },
            Grid  = new Grid { StrokeDashArray = 4, BorderColor = "#F1F5F9" },
            Xaxis = new XAxis
            {
                Labels = new XAxisLabels
                {
                    Style = new AxisLabelStyle { FontFamily = "inherit" },
                    HideOverlappingLabels = true
                }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Opposite = true,
                    Max      = 100,
                    Min      = 0,
                    Labels   = new YAxisLabels { Style = new AxisLabelStyle { FontFamily = "inherit" } }
                }
            },
            DataLabels = new DataLabels { Enabled = false },
            Tooltip = new Tooltip { Theme = Mode.Light },
            Legend     = new Legend     { Show = false }
        };
    }

    private async Task LoadDashboard()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var (from, to) = GetDateRange();
            _dashboard      = await AttendanceService.GetDashboardDataAsync(from, to);
            _selectedPeriod = GetPeriodText();
            BuildChartData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل البيانات: {ex.Message}", Severity.Error);
        }
        _isLoading = false;
        StateHasChanged();
    }

    private void BuildChartData()
    {
        _statusData = new List<StatusChartItem>
        {
            new("حاضر",  _dashboard.Statistics.PresentCount),
            new("غائب",  _dashboard.Statistics.AbsentCount),
            new("متأخر", _dashboard.Statistics.LateCount)
        };

        _hourlyData = _dashboard.TodayHourlyDistribution
    .Select(h => new HourlyChartItem($"{h.Hour:00}:00", h.Count))
    .ToList();

        // ── AbsenceRate و LateRate محسوبة هنا لو مش موجودة في الـ DTO ──
        _trendData = _dashboard.DailyTrend
            .TakeLast(14)
            .Select(d => new TrendChartItem(
                d.Date.ToString("MM/dd"),
                d.AttendanceRate,
                100m - d.AttendanceRate - (d.LateCount > 0
                    ? Math.Round((decimal)d.LateCount / (d.PresentCount + d.AbsentCount + d.LateCount) * 100, 1)
                    : 0m),
                d.LateCount > 0
                    ? Math.Round((decimal)d.LateCount / (d.PresentCount + d.AbsentCount + d.LateCount) * 100, 1)
                    : 0m
            ))
            .ToList();
    }

    private async Task OnPeriodChanged(string value)
    {
        _periodFilter = value;
        await LoadDashboard();
    }

    private (DateTime from, DateTime to) GetDateRange()
    {
        var today = DateTime.Today;
        return _periodFilter switch
        {
            "today"     => (today, today),
            "week"      => (today.AddDays(-(int)today.DayOfWeek + (int)DayOfWeek.Saturday), today),
            "month"     => (new DateTime(today.Year, today.Month, 1), today),
            "lastMonth" => (new DateTime(today.Year, today.Month, 1).AddMonths(-1),
                            new DateTime(today.Year, today.Month, 1).AddDays(-1)),
            _           => (new DateTime(today.Year, today.Month, 1), today)
        };
    }

    private string GetPeriodText()
    {
        var (from, to) = GetDateRange();
        return _periodFilter switch
        {
            "today"     => $"اليوم — {DateTime.Today:yyyy/MM/dd}",
            "week"      => $"هذا الأسبوع — {from:MM/dd} إلى {to:MM/dd}",
            "month"     => $"شهر {from:MMMM yyyy}",
            "lastMonth" => $"شهر {from:MMMM yyyy}",
            _           => $"{from:yyyy/MM/dd} — {to:yyyy/MM/dd}"
        };
    }

    private double GetTodayRate()
    {
        var total = _dashboard.Statistics.TodayPresent + _dashboard.Statistics.TodayAbsent;
        return total > 0
            ? Math.Round((double)_dashboard.Statistics.TodayPresent / total * 100, 1)
            : 0;
    }

    private MudBlazor.Color GetBarColor(double v)
        => v >= 90 ? MudBlazor.Color.Success : v >= 70 ? MudBlazor.Color.Warning : MudBlazor.Color.Error;

    private string GetRateColor(double v)
        => v >= 90 ? "#22C55E" : v >= 70 ? "#F59E0B" : "#EF4444";

    private string RankCls(int i) => i switch { 0 => "rk-gold", 1 => "rk-silver", 2 => "rk-bronze", _ => "rk-def" };

    private string DeptBg(decimal r) => r >= 90 ? "#F0FDF4" : r >= 70 ? "#FFFBEB" : "#FEF2F2";
    private string DeptFg(decimal r) => r >= 90 ? "#22C55E" : r >= 70 ? "#F59E0B" : "#EF4444";
}