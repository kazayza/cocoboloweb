@namespace COCOBOLOERPNEW.Components.Pages.HR.Attendance.Components
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@inject IAttendanceService AttendanceService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState

<MudDialog Visible="Visible" VisibleChanged="OnVisibleChanged" Options="@_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-3">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                <MudIcon Icon="@Icons.Material.Filled.Edit" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h6">تعديل سجل الحضور</MudText>
                @if (Attendance != null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @Attendance.EmployeeName - @Attendance.LogDateDisplay
                    </MudText>
                }
            </div>
        </div>
    </TitleContent>
    
    <DialogContent>
        @if (Attendance != null)
        {
            @* معلومات الموظف *@
            <MudPaper Class="pa-3 mb-4" Elevation="0" 
                      Style="background: linear-gradient(135deg, #E3F2FD, #BBDEFB); border-radius: 12px;">
                <div class="d-flex flex-wrap align-center gap-4">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2" Class="font-weight-bold">@Attendance.EmployeeName</MudText>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Info" />
                        <MudText Typo="Typo.body2">@Attendance.LogDateDisplay (@Attendance.DayName)</MudText>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small" Color="Color.Secondary" />
                        <MudText Typo="Typo.body2">كود: @Attendance.BiometricCode</MudText>
                    </div>
                </div>
            </MudPaper>

            <MudGrid Spacing="3">
                @* وقت الحضور *@
                <MudItem xs="6">
                    <MudTimePicker Label="وقت الحضور"
                                   @bind-Time="_timeIn"
                                   AmPm="false"
                                   Editable="true"
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Login"
                                   AdornmentColor="Color.Success" />
                </MudItem>

                @* وقت الانصراف *@
                <MudItem xs="6">
                    <MudTimePicker Label="وقت الانصراف"
                                   @bind-Time="_timeOut"
                                   AmPm="false"
                                   Editable="true"
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.Logout"
                                   AdornmentColor="Color.Error" />
                </MudItem>

                @* الحالة *@
                <MudItem xs="12">
                    <MudSelect T="string"
                               Label="الحالة"
                               @bind-Value="_status"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        <MudSelectItem T="string" Value="@AttendanceStatus.Present">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                حاضر
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.Absent">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Error" />
                                غائب
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.Late">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Warning" />
                                متأخر
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.Holiday">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.BeachAccess" Size="Size.Small" Color="Color.Info" />
                                إجازة
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.OffDay">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Weekend" Size="Size.Small" Color="Color.Default" />
                                راحة
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.Permission">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" Color="Color.Secondary" />
                                إذن
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.Errand">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.WorkOutline" Size="Size.Small" Color="Color.Info" />
                                مأمورية
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.EarlyLeave">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.ExitToApp" Size="Size.Small" Color="Color.Warning" />
                                انصراف مبكر
                            </div>
                        </MudSelectItem>
                    </MudSelect>
                </MudItem>

                @* سبب التعديل *@
                <MudItem xs="12">
                    <MudTextField T="string"
                                  Label="سبب التعديل"
                                  @bind-Value="_editReason"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Lines="2"
                                  Placeholder="اكتب سبب التعديل (إجباري للتوثيق)..."
                                  Required="true"
                                  RequiredError="يجب كتابة سبب التعديل" />
                </MudItem>
            </MudGrid>

            @* ملخص التغييرات *@
            @if (HasChanges)
            {
                <MudPaper Class="pa-3 mt-4" Elevation="0" 
                          Style="background: #FFF8E1; border-radius: 12px; border-right: 4px solid #FFC107;">
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">التغييرات:</MudText>
                    </div>
                    <div class="d-flex flex-column gap-1">
                        @if (OriginalTimeIn != _timeIn)
                        {
                            <MudText Typo="Typo.body2">
                                • الحضور: @FormatTime(OriginalTimeIn) ← @FormatTime(_timeIn)
                            </MudText>
                        }
                        @if (OriginalTimeOut != _timeOut)
                        {
                            <MudText Typo="Typo.body2">
                                • الانصراف: @FormatTime(OriginalTimeOut) ← @FormatTime(_timeOut)
                            </MudText>
                        }
                        @if (Attendance.Status != _status)
                        {
                            <MudText Typo="Typo.body2">
                                • الحالة: @(Attendance.Status ?? "--") ← @_status
                            </MudText>
                        }
                    </div>
                </MudPaper>
            }
        }
    </DialogContent>
    
    <DialogActions>
        <MudButton Variant="Variant.Text" 
                   Color="Color.Default" 
                   OnClick="Close"
                   Disabled="_isSaving">
            إلغاء
        </MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary"
                   StartIcon="@(_isSaving ? null : Icons.Material.Filled.Save)"
                   OnClick="SaveChanges"
                   Disabled="_isSaving || !HasChanges || string.IsNullOrWhiteSpace(_editReason)">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-2" />
                <span>جاري الحفظ...</span>
            }
            else
            {
                <span>حفظ التعديلات</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public AttendanceListDto? Attendance { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private TimeSpan? _timeIn;
    private TimeSpan? _timeOut;
    private string? _status;
    private string? _editReason;
    private bool _isSaving;

    // للمقارنة
    private TimeSpan? OriginalTimeIn;
    private TimeSpan? OriginalTimeOut;

    private DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseButton = true,
        CloseOnEscapeKey = true,
        BackdropClick = false
    };

    private bool HasChanges => 
        OriginalTimeIn != _timeIn || 
        OriginalTimeOut != _timeOut || 
        Attendance?.Status != _status;

    protected override void OnParametersSet()
    {
        if (Attendance != null && Visible)
        {
            _timeIn = Attendance.TimeIn?.ToTimeSpan();
            _timeOut = Attendance.TimeOut?.ToTimeSpan();
            _status = Attendance.Status ?? AttendanceStatus.Present;
            _editReason = null;

            OriginalTimeIn = _timeIn;
            OriginalTimeOut = _timeOut;
        }
    }

    private async Task SaveChanges()
    {
        if (Attendance == null || string.IsNullOrWhiteSpace(_editReason)) return;

        _isSaving = true;
        StateHasChanged();

        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "System";

            var dto = new AttendanceEditDto
            {
                AttendanceId = Attendance.AttendanceId,
                BiometricCode = Attendance.BiometricCode,
                LogDate = Attendance.LogDate,
                TimeIn = _timeIn.HasValue ? TimeOnly.FromTimeSpan(_timeIn.Value) : null,
                TimeOut = _timeOut.HasValue ? TimeOnly.FromTimeSpan(_timeOut.Value) : null,
                Status = _status,
                EditReason = _editReason
            };

            var result = await AttendanceService.UpdateAttendanceAsync(dto, userName);

            if (result.Success)
            {
                Snackbar.Add(result.Message, Severity.Success);
                await OnSaved.InvokeAsync();
                await Close();
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task Close()
    {
        _editReason = null;
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task OnVisibleChanged(bool value)
    {
        Visible = value;
        await VisibleChanged.InvokeAsync(value);
    }

    private string FormatTime(TimeSpan? time) => 
        time.HasValue ? $"{time.Value:hh\\:mm}" : "--:--";
}