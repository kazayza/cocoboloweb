@namespace COCOBOLOERPNEW.Components.Pages.HR.Attendance.Components
@using COCOBOLOERPNEW.DTOs

<MudPaper Elevation="2" Style="border-radius: 16px; overflow: hidden;">
    
    @* Table Header *@
    <div class="pa-3 d-flex align-center justify-space-between" style="background: var(--mud-palette-background-grey);">
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">سجل الحضور</MudText>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">
                @TotalCount سجل
            </MudChip>
        </div>
        
        @if (SelectedItems.Count > 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Primary" Class="font-weight-bold">
                تم تحديد @SelectedItems.Count
            </MudText>
        }
    </div>

    <MudDivider />

    @if (IsLoading)
    {
        <div class="pa-4">
            @for (int i = 0; i < 5; i++)
            {
                <div class="d-flex gap-4 mb-3">
                    <MudSkeleton Width="5%" Height="24px" />
                    <MudSkeleton Width="18%" Height="24px" />
                    <MudSkeleton Width="10%" Height="24px" />
                    <MudSkeleton Width="10%" Height="24px" />
                    <MudSkeleton Width="8%" Height="24px" />
                    <MudSkeleton Width="8%" Height="24px" />
                    <MudSkeleton Width="8%" Height="24px" />
                    <MudSkeleton Width="8%" Height="24px" />
                    <MudSkeleton Width="10%" Height="24px" />
                    <MudSkeleton Width="8%" Height="24px" />
                </div>
            }
        </div>
    }
    else if (Items.Count == 0)
    {
        <div class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Filled.EventBusy" 
                     Size="Size.Large" 
                     Style="font-size: 64px; color: #E0E0E0;" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">
                لا توجد سجلات حضور
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                جرب تغيير الفلاتر أو اختر فترة مختلفة
            </MudText>
        </div>
    }
    else
    {
        <MudTable Items="@Items" 
                  Hover="true" 
                  Elevation="0"
                  Dense="false"
                  Striped="true"
                  MultiSelection="true"
                  @bind-SelectedItems="SelectedItems"
                  T="AttendanceListDto">
            <HeaderContent>
                <MudTh Style="width: 50px;"><MudCheckBox T="bool" /></MudTh>
                <MudTh>الموظف</MudTh>
                <MudTh>التاريخ</MudTh>
                <MudTh>اليوم</MudTh>
                <MudTh>الحضور</MudTh>
                <MudTh>الانصراف</MudTh>
                <MudTh>الساعات</MudTh>
                <MudTh>التأخير</MudTh>
                <MudTh>الحالة</MudTh>
                @if (HasEditPermission)
                {
                    <MudTh Style="width: 80px;">إجراءات</MudTh>
                }
            </HeaderContent>
            <RowTemplate Context="item">
                <MudTd><MudCheckBox T="bool" Value="@SelectedItems.Contains(item)" /></MudTd>
                <MudTd DataLabel="الموظف">
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                            @(item.EmployeeName.Length > 0 ? item.EmployeeName[0] : '?')
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@item.EmployeeName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(item.Department ?? $"كود: {item.BiometricCode}")</MudText>
                        </div>
                    </div>
                </MudTd>
                <MudTd DataLabel="التاريخ">
                    <MudText Typo="Typo.body1" Class="font-weight-medium">@item.LogDateDisplay</MudText>
                </MudTd>
                <MudTd DataLabel="اليوم">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" 
                             Color="@(item.IsWeekend ? Color.Secondary : Color.Default)">
                        @item.DayName
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="الحضور">
                    <MudText Typo="Typo.body1" Class="font-weight-bold" 
                             Color="@(item.TimeIn.HasValue ? Color.Success : Color.Default)">
                        @item.TimeInDisplay
                    </MudText>
                </MudTd>
                <MudTd DataLabel="الانصراف">
                    <MudText Typo="Typo.body1" Class="font-weight-bold"
                             Color="@(item.TimeOut.HasValue ? Color.Error : Color.Default)">
                        @item.TimeOutDisplay
                    </MudText>
                </MudTd>
                <MudTd DataLabel="الساعات">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" 
                             Color="@(item.TotalHours >= 8 ? Color.Success : Color.Warning)">
                        @item.TotalHoursDisplay
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="التأخير">
                    @if (item.IsLate)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" 
                                 Style="background: #FFF3E0; color: #E65100;">
                            @item.LateDisplay
                        </MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">--</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="الحالة">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                             Style="@GetStatusStyle(item)">
                        <MudIcon Icon="@GetStatusIcon(item)" Size="Size.Small" Class="ml-1" />
                        @GetStatusText(item)
                    </MudChip>
                </MudTd>
                @if (HasEditPermission)
                {
                    <MudTd DataLabel="إجراءات">
                        <MudTooltip Text="تعديل">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                           Size="Size.Small" 
                                           Color="Color.Primary"
                                           OnClick="@(() => OnEdit.InvokeAsync(item))" />
                        </MudTooltip>
                    </MudTd>
                }
            </RowTemplate>
        </MudTable>

        @* Pagination *@
        <MudDivider />
        <div class="pa-3 d-flex flex-wrap align-center justify-space-between gap-3" style="background: var(--mud-palette-background-grey);">
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.body2" Color="Color.Secondary">عرض</MudText>
                <MudSelect T="int" 
                           Value="@PageSize"
                           ValueChanged="@(v => OnPageSizeChanged.InvokeAsync(v))"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Style="width: 80px;">
                    <MudSelectItem T="int" Value="10">10</MudSelectItem>
                    <MudSelectItem T="int" Value="25">25</MudSelectItem>
                    <MudSelectItem T="int" Value="50">50</MudSelectItem>
                    <MudSelectItem T="int" Value="100">100</MudSelectItem>
                </MudSelect>
                <MudText Typo="Typo.body2" Color="Color.Secondary">سجل</MudText>
            </div>

            <div class="d-flex align-center gap-2">
                <MudIconButton Icon="@Icons.Material.Filled.FirstPage" 
                               Size="Size.Small"
                               Disabled="@(!HasPrevious)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(1))" />
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" 
                               Size="Size.Small"
                               Disabled="@(!HasPrevious)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(CurrentPage - 1))" />
                
                <MudText Typo="Typo.body2" Class="px-2 font-weight-bold">
                    صفحة @CurrentPage من @TotalPages
                </MudText>
                
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" 
                               Size="Size.Small"
                               Disabled="@(!HasNext)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(CurrentPage + 1))" />
                <MudIconButton Icon="@Icons.Material.Filled.LastPage" 
                               Size="Size.Small"
                               Disabled="@(!HasNext)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(TotalPages))" />
            </div>

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-weight-medium">
                إجمالي: <strong>@TotalCount</strong>
            </MudText>
        </div>
    }
</MudPaper>

@code {
    [Parameter] public List<AttendanceListDto> Items { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public int PageSize { get; set; } = 25;
    [Parameter] public bool HasPrevious { get; set; }
    [Parameter] public bool HasNext { get; set; }
    [Parameter] public bool HasEditPermission { get; set; }
    [Parameter] public HashSet<AttendanceListDto> SelectedItems { get; set; } = new();
    [Parameter] public EventCallback<AttendanceListDto> OnEdit { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    private string GetStatusIcon(AttendanceListDto item)
    {
        if (item.IsAbsent) return Icons.Material.Filled.Cancel;
        if (item.IsLate) return Icons.Material.Filled.Schedule;
        return Icons.Material.Filled.CheckCircle;
    }

    private string GetStatusText(AttendanceListDto item)
    {
        if (item.IsAbsent) return "غائب";
        if (item.IsLate) return "متأخر";
        return "حاضر";
    }

    private string GetStatusStyle(AttendanceListDto item)
    {
        if (item.IsAbsent) return "background: #FFEBEE; color: #C62828;";
        if (item.IsLate) return "background: #FFF3E0; color: #E65100;";
        return "background: #E8F5E9; color: #2E7D32;";
    }
}