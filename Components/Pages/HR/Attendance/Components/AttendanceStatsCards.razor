@namespace COCOBOLOERPNEW.Components.Pages.HR.Attendance.Components
@using COCOBOLOERPNEW.DTOs

<div class="pa-4 pt-0">
    <MudGrid Spacing="2">
        @* عدد الموظفين *@
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(255,255,255,0.1); border-radius: 12px; backdrop-filter: blur(10px);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Medium" 
                             Style="color: rgba(255,255,255,0.9);" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">
                        @Statistics.TotalEmployees
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">موظف</MudText>
                }
            </MudPaper>
        </MudItem>

        @* عدد الأيام *@
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(33, 150, 243, 0.25); border-radius: 12px; border: 1px solid rgba(33, 150, 243, 0.4);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Medium" 
                             Style="color: #2196F3;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">
                        @Statistics.TotalDays
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">يوم</MudText>
                }
            </MudPaper>
        </MudItem>

        @* نسبة الحضور *@
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(76, 175, 80, 0.25); border-radius: 12px; border: 1px solid rgba(76, 175, 80, 0.4);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Medium" 
                             Style="color: #4CAF50;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">
                        @Statistics.AttendanceRate%
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">نسبة الحضور</MudText>
                }
            </MudPaper>
        </MudItem>

        @* نسبة الغياب *@
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(244, 67, 54, 0.25); border-radius: 12px; border: 1px solid rgba(244, 67, 54, 0.4);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Size="Size.Medium" 
                             Style="color: #F44336;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">
                        @Statistics.AbsenceRate%
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">نسبة الغياب</MudText>
                }
            </MudPaper>
        </MudItem>

        @* نسبة التأخير *@
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(255, 152, 0, 0.25); border-radius: 12px; border: 1px solid rgba(255, 152, 0, 0.4);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Medium" 
                             Style="color: #FF9800;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">
                        @Statistics.LateRate%
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">نسبة التأخير</MudText>
                }
            </MudPaper>
        </MudItem>

        @* متوسط الساعات *@
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(156, 39, 176, 0.25); border-radius: 12px; border: 1px solid rgba(156, 39, 176, 0.4);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Medium" 
                             Style="color: #9C27B0;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">
                        @Statistics.AverageHours
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);">متوسط س/يوم</MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter] public AttendanceStatisticsDto Statistics { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
}