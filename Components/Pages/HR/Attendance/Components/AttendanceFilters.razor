@namespace COCOBOLOERPNEW.Components.Pages.HR.Attendance.Components
@using COCOBOLOERPNEW.DTOs

<MudPaper Class="mb-4" Elevation="2" Style="border-radius: 16px; overflow: hidden;">
    
    @* Filter Header *@
    <MudButton FullWidth="true" 
               Variant="Variant.Text" 
               Color="Color.Default"
               Class="pa-4 justify-space-between"
               Style="text-transform: none; border-radius: 0;"
               OnClick="ToggleFilters">
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.FilterList" Color="Color.Primary" />
            <MudText Typo="Typo.subtitle1" Class="font-weight-medium">الفلاتر والبحث</MudText>
            @if (ActiveFiltersCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                    @ActiveFiltersCount فلتر
                </MudChip>
            }
        </div>
        <MudIcon Icon="@(_isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" />
    </MudButton>

    <MudCollapse Expanded="_isExpanded">
        <MudDivider />
        <div class="pa-4">
            <MudGrid Spacing="3">
                
                @* التاريخ من *@
                <MudItem xs="6" md="2">
                    <MudDatePicker Label="من تاريخ"
                                   @bind-Date="_dateFrom"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Editable="true"
                                   Clearable="true"
                                   DateFormat="yyyy/MM/dd"
                                   Placeholder="اختر" />
                </MudItem>

                @* التاريخ إلى *@
                <MudItem xs="6" md="2">
                    <MudDatePicker Label="إلى تاريخ"
                                   @bind-Date="_dateTo"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Editable="true"
                                   Clearable="true"
                                   DateFormat="yyyy/MM/dd"
                                   Placeholder="اختر" />
                </MudItem>

                @* البحث *@
                <MudItem xs="12" md="3">
                    <MudTextField T="string"
                                  Label="بحث (اسم / قسم)"
                                  @bind-Value="_searchText"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Clearable="true"
                                  Immediate="true"
                                  OnKeyUp="HandleKeyUp"
                                  Placeholder="ابحث..." />
                </MudItem>

                @* الحالة *@
                <MudItem xs="6" md="2">
                    <MudSelect T="string"
                               Label="الحالة"
                               @bind-Value="_status"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="string" Value="@AttendanceStatus.Present">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                حاضر
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.Absent">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Error" />
                                غائب
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@AttendanceStatus.Late">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Warning" />
                                متأخر
                            </div>
                        </MudSelectItem>
                    </MudSelect>
                </MudItem>

                                @* فلاتر سريعة *@
                <MudItem xs="6" md="2">
                    <MudSelect T="string"
                               Label="فلتر سريع"
                               Value="_quickFilter"
                               ValueChanged="OnQuickFilterChanged"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true">
                        <MudSelectItem T="string" Value="@("today")">اليوم</MudSelectItem>
                        <MudSelectItem T="string" Value="@("yesterday")">أمس</MudSelectItem>
                        <MudSelectItem T="string" Value="@("thisWeek")">هذا الأسبوع</MudSelectItem>
                        <MudSelectItem T="string" Value="@("thisMonth")">هذا الشهر</MudSelectItem>
                        <MudSelectItem T="string" Value="@("lastMonth")">الشهر الماضي</MudSelectItem>
                    </MudSelect>
                </MudItem>

                @* زرار البحث *@
                <MudItem xs="12" md="1" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="ExecuteSearch"
                               Style="border-radius: 8px; min-height: 40px;">
                        <MudIcon Icon="@Icons.Material.Filled.Search" />
                    </MudButton>
                </MudItem>
            </MudGrid>

            @* Active Filters Chips *@
            @if (ActiveFiltersCount > 0)
            {
                <MudDivider Class="my-3" />
                <div class="d-flex flex-wrap align-center gap-2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">الفلاتر:</MudText>
                    
                    @if (_dateFrom.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                 OnClose="@(() => { _dateFrom = null; ExecuteSearch(); })">
                            من: @_dateFrom.Value.ToString("MM/dd")
                        </MudChip>
                    }
                    
                    @if (_dateTo.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                 OnClose="@(() => { _dateTo = null; ExecuteSearch(); })">
                            إلى: @_dateTo.Value.ToString("MM/dd")
                        </MudChip>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(_searchText))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                 OnClose="@(() => { _searchText = null; ExecuteSearch(); })">
                            بحث: @_searchText
                        </MudChip>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(_status))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                 OnClose="@(() => { _status = null; ExecuteSearch(); })">
                            @_status
                        </MudChip>
                    }

                    <MudButton Variant="Variant.Text" 
                               Color="Color.Error" 
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.ClearAll"
                               OnClick="ResetAll">
                        مسح الكل
                    </MudButton>
                </div>
            }
        </div>
    </MudCollapse>
</MudPaper>

@code {
    [Parameter] public AttendanceFilterDto Filter { get; set; } = new();
    [Parameter] public EventCallback OnSearch { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }

    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private string? _searchText;
    private string? _status;
    private string? _quickFilter;
    private bool _isExpanded = true;

    protected override void OnInitialized()
    {
        _dateFrom = Filter.DateFrom;
        _dateTo = Filter.DateTo;
        _searchText = Filter.SearchText;
        _status = Filter.Status;
    }

    private int ActiveFiltersCount =>
        (_dateFrom.HasValue ? 1 : 0) +
        (_dateTo.HasValue ? 1 : 0) +
        (string.IsNullOrWhiteSpace(_searchText) ? 0 : 1) +
        (string.IsNullOrWhiteSpace(_status) ? 0 : 1);

    private void ToggleFilters() => _isExpanded = !_isExpanded;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await ExecuteSearch();
    }

    private async Task OnQuickFilterChanged(string value)
    {
        _quickFilter = value;
        var today = DateTime.Today;

        switch (value)
        {
            case "today":
                _dateFrom = today;
                _dateTo = today;
                break;
            case "yesterday":
                _dateFrom = today.AddDays(-1);
                _dateTo = today.AddDays(-1);
                break;
            case "thisWeek":
                var diff = (7 + (today.DayOfWeek - DayOfWeek.Saturday)) % 7;
                _dateFrom = today.AddDays(-diff);
                _dateTo = today;
                break;
            case "thisMonth":
                _dateFrom = new DateTime(today.Year, today.Month, 1);
                _dateTo = today;
                break;
            case "lastMonth":
                var lastMonth = today.AddMonths(-1);
                _dateFrom = new DateTime(lastMonth.Year, lastMonth.Month, 1);
                _dateTo = new DateTime(lastMonth.Year, lastMonth.Month, DateTime.DaysInMonth(lastMonth.Year, lastMonth.Month));
                break;
        }

        await ExecuteSearch();
    }

    private async Task ExecuteSearch()
    {
        Filter.DateFrom = _dateFrom;
        Filter.DateTo = _dateTo;
        Filter.SearchText = _searchText;
        Filter.Status = _status;
        
        await OnSearch.InvokeAsync();
    }

    private async Task ResetAll()
    {
        _dateFrom = null;
        _dateTo = null;
        _searchText = null;
        _status = null;
        _quickFilter = null;
        
        await OnReset.InvokeAsync();
    }
}