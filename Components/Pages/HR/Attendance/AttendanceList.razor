@page "/attendance"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Components.Pages.HR.Attendance.Components
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>سجل الحضور والانصراف</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (!_hasViewPermission)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
                <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius: 20px;">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large"
                             Style="font-size: 64px; color: #EF5350;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Color="Color.Error" Class="mb-2">غير مصرح</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">
                        ليس لديك صلاحية الوصول لهذه الصفحة
                    </MudText>
                </MudPaper>
            </MudContainer>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 hr-page-shell attendance-list-v2">

                @* ================= HERO ================= *@
                <MudPaper Class="attendance-hero mb-4" Elevation="0">
                    <div class="attendance-hero__content">
                        <div class="attendance-hero__headline">
                            <MudAvatar Size="Size.Large" Class="attendance-hero__avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Medium" Color="Color.Surface" />
                            </MudAvatar>
                            <div>
                                <div class="section-header-chip mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Insights" Size="Size.Small" />
                                    Attendance Control Center
                                </div>
                                <MudText Typo="Typo.h4" Color="Color.Surface" Class="font-weight-bold mb-1">
                                    سجل الحضور والانصراف
                                </MudText>
                                <MudText Typo="Typo.body2" Class="attendance-hero__subtitle">
                                    متابعة يومية لحضور الموظفين مع أدوات التعديل والتقارير والتحليلات في مكان واحد.
                                </MudText>
                            </div>
                        </div>

                        <div class="attendance-hero__actions">
                            @if (_hasEditPermission)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.EditCalendar"
                                           Href="/attendance/manual-daily"
                                           Class="attendance-action attendance-action--primary">
                                    حضور يدوي
                                </MudButton>
                            }

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Warning"
                                       StartIcon="@Icons.Material.Filled.Dashboard"
                                       Href="/attendance/dashboard"
                                       Class="attendance-action">
                                التحليلات
                            </MudButton>

                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Color="Color.Surface"
                                           Class="attendance-action-icon"
                                           OnClick="ApplyFilter"
                                           Title="تحديث البيانات" />

                            <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                     Color="Color.Surface"
                                     Class="attendance-more-menu"
                                     AnchorOrigin="Origin.BottomRight"
                                     TransformOrigin="Origin.TopRight">
                                <MudMenuItem Icon="@Icons.Material.Filled.FileDownload" OnClick="ExportExcel">
                                    @(_isExporting ? "جاري التصدير..." : "تصدير Excel")
                                </MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Assessment" Href="/attendance/report">
                                    تقرير الحضور
                                </MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.History" Href="/attendance/logs">
                                    سجلات البصمة الخام
                                </MudMenuItem>
                            </MudMenu>
                        </div>
                    </div>

                    <AttendanceStatsCards Statistics="_statistics" IsLoading="_isLoadingStats" />
                </MudPaper>

                @* ================= CONTEXT BAR ================= *@
                <MudPaper Class="attendance-context-bar mb-3" Elevation="1">
                    <div class="attendance-context-bar__wrap">
                        <div class="attendance-context-bar__group">
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                                @CurrentScopeLabel
                            </MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small">
                                @CurrentRangeLabel
                            </MudChip>
                            @if (ActiveFiltersCount > 0)
                            {
                                <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small">
                                    @ActiveFiltersCount فلتر نشط
                                </MudChip>
                            }
                        </div>

                        <div class="attendance-context-bar__meta">
                            <span>عرض <strong>@FromRecord</strong> - <strong>@ToRecord</strong> من <strong>@_totalCount</strong></span>
                        </div>
                    </div>
                </MudPaper>

                @* ================= FILTERS ================= *@
                <div class="sticky-filter-shell">
                    <AttendanceFilters Filter="_filter"
                                       OnSearch="ApplyFilter"
                                       OnReset="ResetFilters" />
                </div>

                @* ================= RESULTS SUMMARY ================= *@
                <MudPaper Class="attendance-summary-strip mb-3" Elevation="1">
                    <div class="attendance-summary-strip__grid">
                        <div class="attendance-summary-tile">
                            <span class="attendance-summary-tile__label">حضور</span>
                            <strong class="attendance-summary-tile__value text-success">@SummaryPresentCount</strong>
                        </div>
                        <div class="attendance-summary-tile">
                            <span class="attendance-summary-tile__label">غياب</span>
                            <strong class="attendance-summary-tile__value text-error">@SummaryAbsentCount</strong>
                        </div>
                        <div class="attendance-summary-tile">
                            <span class="attendance-summary-tile__label">تأخير</span>
                            <strong class="attendance-summary-tile__value text-warning">@SummaryLateCount</strong>
                        </div>
                        <div class="attendance-summary-tile">
                            <span class="attendance-summary-tile__label">حالات خاصة</span>
                            <strong class="attendance-summary-tile__value text-info">@SummarySpecialCount</strong>
                        </div>
                    </div>
                </MudPaper>

                @* ================= DATA GRID ================= *@
                <AttendanceDataGrid Items="_items"
                                    IsLoading="_isLoadingData"
                                    TotalCount="_totalCount"
                                    CurrentPage="_currentPage"
                                    TotalPages="_totalPages"
                                    PageSize="_filter.PageSize"
                                    HasPrevious="_hasPrevious"
                                    HasNext="_hasNext"
                                    HasEditPermission="_hasEditPermission"
                                    SelectedItems="_selectedItems"
                                    OnEdit="OpenEditDialog"
                                    OnPageChanged="OnPageChanged"
                                    OnPageSizeChanged="OnPageSizeChanged" />
            </MudContainer>

            <AttendanceEditDialog Visible="_showEditDialog"
                                  VisibleChanged="@(v => _showEditDialog = v)"
                                  Attendance="_attendanceToEdit"
                                  OnSaved="OnAttendanceSaved" />
        }
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
            <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius: 20px;">
                <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Large"
                         Style="font-size: 64px; color: #FF9800;" Class="mb-4" />
                <MudText Typo="Typo.h5" Color="Color.Warning" Class="mb-2">تسجيل الدخول مطلوب</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    يرجى تسجيل الدخول للوصول لهذه الصفحة
                </MudText>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

<style>
    .attendance-hero {
        border-radius: 20px;
        overflow: hidden;
        background: linear-gradient(135deg, #1A237E 0%, #3949AB 50%, #5C6BC0 100%);
    }

    .attendance-hero__content {
        padding: 1.35rem 1.5rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .attendance-hero__headline {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .attendance-hero__avatar {
        background: rgba(255,255,255,.16);
        backdrop-filter: blur(8px);
    }

    .attendance-hero__subtitle {
        color: rgba(255,255,255,.78);
        max-width: 760px;
    }

    .attendance-hero__actions {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .attendance-action {
        min-height: 44px;
        border-radius: 12px;
        padding-inline: 14px;
    }

    .attendance-action--primary {
        box-shadow: 0 10px 22px rgba(16, 185, 129, .25);
    }

    .attendance-action-icon {
        border: 1px solid rgba(255,255,255,.28);
        border-radius: 12px;
        background: rgba(255,255,255,.08);
    }

    .attendance-context-bar,
    .attendance-summary-strip {
        border-radius: 16px;
        border: 1px solid rgba(148,163,184,.18);
    }

    .attendance-context-bar__wrap {
        padding: .8rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .attendance-context-bar__group {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .attendance-context-bar__meta {
        color: var(--mud-palette-text-secondary);
        font-size: .85rem;
    }

    .attendance-summary-strip__grid {
        padding: .85rem 1rem;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .75rem;
    }

    .attendance-summary-tile {
        background: rgba(148,163,184,.08);
        border-radius: 14px;
        padding: .75rem .85rem;
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

    .attendance-summary-tile__label {
        font-size: .78rem;
        color: var(--mud-palette-text-secondary);
    }

    .attendance-summary-tile__value {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--mud-palette-text-primary);
    }

    .text-success { color: #2E7D32; }
    .text-error { color: #C62828; }
    .text-warning { color: #E65100; }
    .text-info { color: #1565C0; }

    @@media (max-width: 900px) {
        .attendance-summary-strip__grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 600px) {
        .attendance-hero__content {
            padding: 1rem 1rem .75rem;
        }

        .attendance-hero__headline {
            align-items: flex-start;
        }

        .attendance-hero__actions {
            width: 100%;
        }

        .attendance-action {
            flex: 1 1 calc(50% - .5rem);
        }

        .attendance-action-icon,
        .attendance-more-menu {
            flex: 1 1 calc(50% - .5rem);
        }

        .attendance-summary-strip__grid {
            grid-template-columns: 1fr 1fr;
            padding: .75rem;
        }

        .attendance-context-bar__meta {
            width: 100%;
        }
    }
</style>