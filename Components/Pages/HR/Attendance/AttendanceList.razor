@page "/attendance"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Components.Pages.HR.Attendance.Components
@using Microsoft.AspNetCore.Components.Authorization



<PageTitle>سجل الحضور والانصراف</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (!_hasViewPermission)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
                <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius: 20px;">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" 
                             Style="font-size: 64px; color: #EF5350;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Color="Color.Error" Class="mb-2">غير مصرح</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">
                        ليس لديك صلاحية الوصول لهذه الصفحة
                    </MudText>
                </MudPaper>
            </MudContainer>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
                
                @* ═══════════════ HEADER ═══════════════ *@
                <MudPaper Class="mb-4 overflow-hidden" Elevation="0" 
                          Style="border-radius: 20px; background: linear-gradient(135deg, #1A237E 0%, #3949AB 50%, #5C6BC0 100%);">
                    <div class="pa-5">
                        <div class="d-flex align-center justify-space-between flex-wrap gap-3">
                            <div class="d-flex align-center gap-3">
                                <MudAvatar Size="Size.Large" 
                                           Style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px);">
                                    <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Medium" Color="Color.Surface" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">
                                        سجل الحضور والانصراف
                                    </MudText>
                                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.7);">
                                        متابعة وإدارة بصمات الموظفين
                                    </MudText>
                                </div>
                            </div>
                            
                                                        <div class="d-flex flex-wrap gap-2">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.Dashboard"
                                           Href="/attendance/dashboard">
                                    لوحة التحليل
                                </MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Dark"
                                           StartIcon="@Icons.Material.Filled.FileDownload"
                                           OnClick="ExportExcel"
                                           Disabled="_isExporting">
                                    @(_isExporting ? "جاري التصدير..." : "تصدير Excel")
                                </MudButton>
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" 
                                         Color="Color.Surface"
                                         AnchorOrigin="Origin.BottomRight">
                                    <MudMenuItem Icon="@Icons.Material.Filled.Assessment"
                                                 Href="/attendance/report">
                                        تقرير الحضور
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.History"
                                                 Href="/attendance/logs">
                                        سجلات البصمة الخام
                                    </MudMenuItem>
                                </MudMenu>
                            </div>
                        </div>
                    </div>
                    
                    @* Stats Cards *@
                    <AttendanceStatsCards Statistics="_statistics" IsLoading="_isLoadingStats" />
                </MudPaper>

                @* ═══════════════ FILTERS ═══════════════ *@
                <AttendanceFilters Filter="_filter"
                                   OnSearch="ApplyFilter"
                                   OnReset="ResetFilters" />

                @* ═══════════════ DATA GRID ═══════════════ *@
                <AttendanceDataGrid Items="_items"
                                    IsLoading="_isLoadingData"
                                    TotalCount="_totalCount"
                                    CurrentPage="_currentPage"
                                    TotalPages="_totalPages"
                                    PageSize="_filter.PageSize"
                                    HasPrevious="_hasPrevious"
                                    HasNext="_hasNext"
                                    HasEditPermission="_hasEditPermission"
                                    SelectedItems="_selectedItems"
                                    OnEdit="OpenEditDialog"
                                    OnPageChanged="OnPageChanged"
                                    OnPageSizeChanged="OnPageSizeChanged" />
            </MudContainer>

            @* ═══════════════ EDIT DIALOG ═══════════════ *@
            <AttendanceEditDialog Visible="_showEditDialog"
                                  VisibleChanged="@(v => _showEditDialog = v)"
                                  Attendance="_attendanceToEdit"
                                  OnSaved="OnAttendanceSaved" />
        }
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
            <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius: 20px;">
                <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Large" 
                         Style="font-size: 64px; color: #FF9800;" Class="mb-4" />
                <MudText Typo="Typo.h5" Color="Color.Warning" Class="mb-2">تسجيل الدخول مطلوب</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    يرجى تسجيل الدخول للوصول لهذه الصفحة
                </MudText>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>