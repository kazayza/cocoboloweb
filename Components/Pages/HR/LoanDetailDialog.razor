@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@inject IEmployeeLoanService         LoanService
@inject ISnackbar                    Snackbar
@inject IDialogService               DialogService
@inject AuthenticationStateProvider  AuthProvider

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" />
            <MudText Typo="Typo.h6">تفاصيل السلفة</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        @if (_loading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" />
            </div>
        }
        else if (_detail is null)
        {
            <MudAlert Severity="Severity.Error">السلفة غير موجودة</MudAlert>
        }
        else
        {
            var loan = _detail.Loan;

            @* ── Header ── *@
            <div class="d-flex align-center gap-3 mb-4">
                <MudAvatar Size="Size.Large" Style="@($"background:{loan.StatusColor};color:white;font-size:1.2rem")">
                    @loan.EmployeeName.FirstOrDefault()
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h6"><b>@loan.EmployeeName</b></MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @(loan.Department ?? "—") | @(loan.JobTitle ?? "—")
                    </MudText>
                </div>
                <MudSpacer />
                <MudChip T="string"
                         Style="@($"background:{loan.StatusColor};color:white")"
                         Size="Size.Medium">
                    @loan.StatusAr
                </MudChip>
            </div>

            @* ── Info Grid ── *@
            <MudGrid Class="mb-4">
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">قيمة السلفة</MudText>
                    <MudText><b>@loan.LoanAmount.ToString("N2")</b> جـ</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">القسط الشهري</MudText>
                    <MudText><b>@loan.MonthlyInstallment.ToString("N2")</b> جـ</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">المتبقي</MudText>
                    <MudText Color="@(loan.RemainingAmount > 0 ? Color.Error : Color.Success)">
                        <b>@loan.RemainingAmount.ToString("N2")</b> جـ
                    </MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">تم سداده</MudText>
                    <MudText Color="Color.Success"><b>@loan.PaidAmount.ToString("N2")</b> جـ</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">تاريخ السلفة</MudText>
                    <MudText>@loan.LoanDate.ToString("dd/MM/yyyy")</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">بداية الخصم</MudText>
                    <MudText>@FormatMonth(loan.StartDeductionMonth)</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">الأقساط</MudText>
                    <MudText>@loan.PaidInstallments / @loan.TotalInstallments</MudText>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">الخزينة</MudText>
                    <MudText>@(loan.CashBoxName ?? "—")</MudText>
                </MudItem>

                @if (!string.IsNullOrWhiteSpace(loan.Notes))
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">ملاحظات</MudText>
                        <MudText>@loan.Notes</MudText>
                    </MudItem>
                }
            </MudGrid>

            @* ── Progress ── *@
            <div class="mb-4">
                <div class="d-flex justify-space-between mb-1">
                    <MudText Typo="Typo.body2">تقدم السداد</MudText>
                    <MudText Typo="Typo.body2"><b>@GetProgressPercent(loan).ToString("N0")%</b></MudText>
                </div>
                <MudProgressLinear Value="@GetProgressPercent(loan)"
                                   Color="@GetProgressColor(loan)"
                                   Rounded Size="Size.Medium" />
            </div>

            @* ── Installments Table ── *@
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                <b>الأقساط (@_detail.Installments.Count)</b>
            </MudText>

            <MudTable Items="_detail.Installments" Dense Hover Elevation="0"
                      Style="border:1px solid rgba(0,0,0,.1);border-radius:8px;overflow:hidden">
                <HeaderContent>
                    <MudTh>#</MudTh>
                    <MudTh>الشهر</MudTh>
                    <MudTh>المبلغ</MudTh>
                    <MudTh>الحالة</MudTh>
                    <MudTh>تاريخ الخصم</MudTh>
                    <MudTh>إجراء</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.InstallmentNumber</MudTd>
                    <MudTd>@context.MonthDisplay</MudTd>
                    <MudTd><b>@context.Amount.ToString("N2")</b> جـ</MudTd>
                    <MudTd>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Style="@($"background:{context.StatusColor};color:white")">
                            @context.StatusAr
                        </MudChip>
                    </MudTd>
                    <MudTd>@(context.DeductionDate?.ToString("dd/MM/yyyy") ?? "—")</MudTd>
                    <MudTd>
                        @if (context.Status == "Pending" && loan.Status == "Active")
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCut"
                                           Size="Size.Small"
                                           Color="Color.Info"
                                           Title="تجزئة القسط وترحيل جزء"
                                           OnClick="@(() => OpenSplitDialog(context))" />
                            <MudIconButton Icon="@Icons.Material.Filled.SkipNext"
                                           Size="Size.Small"
                                           Color="Color.Warning"
                                           Title="تأجيل للشهر القادم"
                                           OnClick="@(() => SkipInstallmentAsync(context))" />
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">إغلاق</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_splitDialogOpen">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">تجزئة القسط وترحيل جزء</MudText>

        @if (_splitInstallment is not null)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                قيمة القسط الحالية: <b>@_splitInstallment.Amount.ToString("N2") جـ</b> — أدخل القيمة المطلوب خصمها في هذا الشهر، وسيتم ترحيل الباقي للشهر القادم.
            </MudAlert>

            <MudNumericField T="decimal"
                             @bind-Value="_splitCurrentAmount"
                             Label="القيمة المطلوب خصمها هذا الشهر"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Min="0.01m"
                             Max="@(_splitInstallment.Amount - 0.01m)"
                             FullWidth />

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2 mb-2">
                المتبقي الذي سيتم ترحيله: <b>@GetSplitRemainingDisplay()</b>
            </MudText>

            <MudTextField T="string"
                          @bind-Value="_splitReason"
                          Label="سبب التجزئة / الملاحظة"
                          Variant="Variant.Outlined"
                          Lines="3"
                          FullWidth />
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick='@(() => _splitDialogOpen = false)'>إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="SubmitSplitAsync">حفظ</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter]          public int               LoanId     { get; set; }
    [Parameter]          public EventCallback     OnUpdated  { get; set; }

    private LoanDetailDto? _detail;
    private bool           _loading     = true;
    private string         _currentUser = "system";
    private bool _splitDialogOpen;
    private InstallmentListDto? _splitInstallment;
    private decimal _splitCurrentAmount;
    private string? _splitReason;

    protected override async Task OnInitializedAsync()
    {
        var auth     = await AuthProvider.GetAuthenticationStateAsync();
        _currentUser = auth.User.Identity?.Name ?? "system";
        await LoadDetailAsync();
    }

    private async Task LoadDetailAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _detail = await LoanService.GetLoanDetailAsync(LoanId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenSplitDialog(InstallmentListDto installment)
    {
        _splitInstallment = installment;
        _splitCurrentAmount = installment.Amount;
        _splitReason = null;
        _splitDialogOpen = true;
    }

     private async Task SkipInstallmentAsync(InstallmentListDto installment)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message,    $"هل تريد تأجيل القسط رقم {installment.InstallmentNumber} بمبلغ {installment.Amount:N2} جـ للشهر القادم؟" },
            { x => x.YesText,    "تأجيل" },
            { x => x.CancelText, "إلغاء" }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأجيل القسط", parameters, options);

        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            var skipResult = await LoanService.SkipInstallmentAsync(
                installment.InstallmentId, "تأجيل يدوي", _currentUser);

            Snackbar.Add(
                skipResult.Message,
                skipResult.Success ? Severity.Success : Severity.Error);

            if (skipResult.Success)
            {
                await LoadDetailAsync();
                await OnUpdated.InvokeAsync();
            }
        }
    }

    private async Task SubmitSplitAsync()
    {
        if (_splitInstallment is null)
            return;

        if (_splitCurrentAmount <= 0 || _splitCurrentAmount >= _splitInstallment.Amount)
        {
            Snackbar.Add("أدخل قيمة أقل من مبلغ القسط الحالي وأكبر من صفر", Severity.Warning);
            return;
        }

        var result = await LoanService.SplitInstallmentAsync(
            _splitInstallment.InstallmentId,
            _splitCurrentAmount,
            _splitReason ?? string.Empty,
            _currentUser);

        Snackbar.Add(result.Message, result.Success ? Severity.Success : Severity.Error);
        if (result.Success)
        {
            _splitDialogOpen = false;
            await LoadDetailAsync();
            await OnUpdated.InvokeAsync();
        }
    }

    private string GetSplitRemainingDisplay()
    {
        if (_splitInstallment is null) return "—";
        var remaining = _splitInstallment.Amount - _splitCurrentAmount;
        return remaining <= 0 ? "—" : remaining.ToString("N2") + " جـ";
    }

    private void Close() => MudDialog.Close();

    private static string FormatMonth(string? yearMonth)
    {
        if (string.IsNullOrWhiteSpace(yearMonth)) return "—";
        return DateTime.TryParseExact(yearMonth + "-01", "yyyy-MM-dd",
            null, System.Globalization.DateTimeStyles.None, out var date)
            ? date.ToString("MMMM yyyy", new System.Globalization.CultureInfo("ar-EG"))
            : yearMonth;
    }

    private static double GetProgressPercent(LoanListDto loan) =>
        loan.TotalInstallments > 0
            ? (double)loan.PaidInstallments / loan.TotalInstallments * 100
            : 0;

    private static Color GetProgressColor(LoanListDto loan)
    {
        var p = GetProgressPercent(loan);
        return p switch
        {
            >= 100 => Color.Success,
            >= 50  => Color.Info,
            >= 25  => Color.Warning,
            _      => Color.Error
        };
    }
}
