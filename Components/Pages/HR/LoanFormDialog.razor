@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IEmployeeLoanService LoanService
@inject ISnackbar            Snackbar
@inject AuthenticationStateProvider AuthProvider

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.AddCard" Color="Color.Success" />
            <MudText Typo="Typo.h6">إضافة سلفة جديدة</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        @if (_initialLoading)
        {
            <div class="d-flex justify-center align-center" style="height:200px">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_formValid">
                <MudGrid Spacing="3">

                    <!-- ═══ الموظف ═══ -->
                    <MudItem xs="12">
                        <MudAutocomplete T="EmployeeLookupDto"
                                         Label="الموظف *"
                                         @bind-Value="_selectedEmployee"
                                         SearchFunc="SearchEmployeesAsync"
                                         ToStringFunc="@(e => e?.DisplayText ?? "")"
                                         Variant="Variant.Outlined"
                                         Dense="true"
                                         Required="true"
                                         RequiredError="يجب اختيار الموظف"
                                         ResetValueOnEmptyText="true"
                                         AdornmentIcon="@Icons.Material.Filled.Person"
                                         Adornment="Adornment.Start"
                                         MaxItems="20"
                                         MinCharacters="0"
                                         DebounceInterval="300"
                                         ShowProgressIndicator="true">
                            <ItemTemplate Context="emp">
                                <div class="d-flex align-center gap-2">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        @emp.FullName.FirstOrDefault()
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body2">@emp.FullName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @(emp.Department ?? "بدون قسم")
                                        </MudText>
                                    </div>
                                </div>
                            </ItemTemplate>
                            <NoItemsTemplate>
                                <MudText Class="pa-2" Color="Color.Secondary">
                                    لا يوجد موظفين مطابقين
                                </MudText>
                            </NoItemsTemplate>
                        </MudAutocomplete>
                    </MudItem>

                    <!-- ═══ قيمة السلفة ═══ -->
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal"
                                         Value="_dto.LoanAmount"
                                         ValueChanged="OnAmountChanged"
                                         Label="قيمة السلفة (جـ) *"
                                         Variant="Variant.Outlined"
                                         Dense="true"
                                         Required="true"
                                         RequiredError="أدخل قيمة السلفة"
                                         Min="1M"
                                         Format="N2"
                                         Adornment="Adornment.End"
                                         AdornmentText="جـ"
                                         Immediate="true" />
                    </MudItem>

                    <!-- ═══ عدد الأقساط ═══ -->
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Value="_dto.TotalInstallments"
                                         ValueChanged="OnInstallmentsChanged"
                                         Label="عدد الأقساط *"
                                         Variant="Variant.Outlined"
                                         Dense="true"
                                         Required="true"
                                         RequiredError="أدخل عدد الأقساط"
                                         Min="1"
                                         Max="60"
                                         Immediate="true" />
                    </MudItem>

                    <!-- ═══ القسط الشهري (محسوب) ═══ -->
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string"
                                      Value="@_installmentDisplay"
                                      Label="القسط الشهري"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      ReadOnly="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Calculate"
                                      Style="background:#f0fdf4" />
                    </MudItem>

                    <!-- ═══ تاريخ السلفة ═══ -->
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_loanDate"
                                       Label="تاريخ السلفة *"
                                       Variant="Variant.Outlined"
                                       Dense="true"
                                       Required="true"
                                       RequiredError="حدد تاريخ السلفة"
                                       DateFormat="dd/MM/yyyy"
                                       Editable="true" />
                    </MudItem>

                    <!-- ═══ شهر بداية الخصم ═══ -->
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string"
                                      @bind-Value="_dto.StartDeductionMonth"
                                      Label="شهر بداية الخصم *"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      Required="true"
                                      RequiredError="حدد شهر بداية الخصم"
                                      Placeholder="مثال: 2025-02"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                                      HelperText="صيغة: سنة-شهر (مثال: 2025-02)" />
                    </MudItem>

                    <!-- ═══ الخزينة ═══ -->
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   @bind-Value="_dto.CashBoxId"
                                   Label="الخزينة *"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Required="true"
                                   RequiredError="اختر الخزينة"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var cb in _cashBoxes)
                            {
                                <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">
                                    @cb.CashBoxName (@cb.CurrentBalance.ToString("N0") جـ)
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <!-- ═══ الموافق ═══ -->
                    <MudItem xs="12" sm="6">
                        <MudTextField T="string"
                                      @bind-Value="_dto.ApprovedBy"
                                      Label="الموافق على السلفة"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.VerifiedUser" />
                    </MudItem>

                    <!-- ═══ ملاحظات ═══ -->
                    <MudItem xs="12">
                        <MudTextField T="string"
                                      @bind-Value="_dto.Notes"
                                      Label="ملاحظات"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      Lines="2" />
                    </MudItem>

                    <!-- ═══ ملخص السلفة ═══ -->
                    @if (_dto.LoanAmount > 0 && _dto.TotalInstallments > 0 && _selectedEmployee != null)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Success"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      Icon="@Icons.Material.Filled.Summarize">
                                <div class="d-flex flex-column gap-1">
                                    <MudText Typo="Typo.subtitle2">📋 ملخص السلفة</MudText>
                                    <MudText Typo="Typo.body2">
                                        الموظف: <b>@_selectedEmployee.FullName</b>
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        المبلغ: <b>@_dto.LoanAmount.ToString("N2") جـ</b>
                                        على <b>@_dto.TotalInstallments</b> قسط
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        القسط الشهري: <b>@_dto.MonthlyInstallment.ToString("N2") جـ</b>
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        يبدأ الخصم من: <b>@_dto.StartDeductionMonth</b>
                                    </MudText>
                                </div>
                            </MudAlert>
                        </MudItem>
                    }

                </MudGrid>
            </MudForm>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel"
                   Variant="Variant.Text"
                   Disabled="_saving">
            إلغاء
        </MudButton>
        <MudButton OnClick="SubmitAsync"
                   Variant="Variant.Filled"
                   Color="Color.Success"
                   Disabled="@(!_formValid || _saving)"
                   StartIcon="@Icons.Material.Filled.Save">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                <span>جاري الحفظ...</span>
            }
            else
            {
                <span>حفظ السلفة</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public EventCallback OnSaved { get; set; }

    private MudForm?              _form;
    private bool                  _formValid;
    private bool                  _saving;
    private bool                  _initialLoading = true;

    private LoanFormDto _dto = new()
    {
        LoanDate            = DateTime.Today,
        StartDeductionMonth = DateTime.Today.AddMonths(1).ToString("yyyy-MM"),
        TotalInstallments   = 1
    };

    private DateTime?              _loanDate = DateTime.Today;
    private EmployeeLookupDto?     _selectedEmployee;
    private List<CashBoxLookupDto> _cashBoxes = new();
    private string                 _installmentDisplay = "0.00 جـ";
    private string                 _currentUser = "system";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            _currentUser = authState.User.Identity?.Name ?? "system";

            _cashBoxes = await LoanService.GetCashBoxesLookupAsync();

            var defaultBox = _cashBoxes.FirstOrDefault(c => c.IsDefault)
                             ?? _cashBoxes.FirstOrDefault();
            if (defaultBox != null)
                _dto.CashBoxId = defaultBox.CashBoxId;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _initialLoading = false;
        }
    }

    private async Task<IEnumerable<EmployeeLookupDto>> SearchEmployeesAsync(
        string? value, CancellationToken ct)
    {
        try
        {
            return await LoanService.GetEmployeesLookupAsync(value);
        }
        catch
        {
            return Enumerable.Empty<EmployeeLookupDto>();
        }
    }

    private void OnAmountChanged(decimal value)
    {
        _dto.LoanAmount = value;
        RecalculateInstallment();
    }

    private void OnInstallmentsChanged(int value)
    {
        _dto.TotalInstallments = value;
        RecalculateInstallment();
    }

    private void RecalculateInstallment()
    {
        _dto.MonthlyInstallment = (_dto.TotalInstallments > 0 && _dto.LoanAmount > 0)
            ? Math.Round(_dto.LoanAmount / _dto.TotalInstallments, 2)
            : 0;
        _installmentDisplay = $"{_dto.MonthlyInstallment:N2} جـ";
        StateHasChanged();
    }

    private async Task SubmitAsync()
    {
        if (_form is null) return;
        await _form.Validate();
        if (!_formValid) return;

        if (_selectedEmployee is null)
        {
            Snackbar.Add("يجب اختيار الموظف", Severity.Warning);
            return;
        }

        if (_dto.LoanAmount <= 0)
        {
            Snackbar.Add("قيمة السلفة يجب أن تكون أكبر من صفر", Severity.Warning);
            return;
        }

        if (!_dto.CashBoxId.HasValue)
        {
            Snackbar.Add("يجب اختيار الخزينة", Severity.Warning);
            return;
        }

        if (!ValidateMonthFormat(_dto.StartDeductionMonth))
        {
            Snackbar.Add("صيغة شهر البداية غير صحيحة (مثال: 2025-02)", Severity.Warning);
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            _dto.EmployeeId   = _selectedEmployee.EmployeeId;
            _dto.EmployeeName = _selectedEmployee.FullName;
            _dto.LoanDate     = _loanDate ?? DateTime.Today;

            var result = await LoanService.SaveLoanAsync(_dto, _currentUser);

            if (result.Success)
            {
                Snackbar.Add(result.Message, Severity.Success);
                await OnSaved.InvokeAsync();
                MudDialog.Close(DialogResult.Ok(result.LoanId));
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private static bool ValidateMonthFormat(string? month)
    {
        if (string.IsNullOrWhiteSpace(month)) return false;
        return DateTime.TryParseExact(
            month + "-01", "yyyy-MM-dd",
            null, System.Globalization.DateTimeStyles.None, out _);
    }

    private void Cancel() => MudDialog.Cancel();
}