@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IEmployeeLoanService         LoanService
@inject ISnackbar                    Snackbar
@inject AuthenticationStateProvider  AuthProvider

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.AddCard" Color="Color.Success" />
            <MudText Typo="Typo.h6">إضافة سلفة جديدة</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        @if (_initialLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" />
            </div>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_formValid">
                <MudGrid>

                    @* ── الموظف ── *@
                    <MudItem xs="12">
                        <MudAutocomplete T="EmployeeLookupDto"
                                         Label="الموظف *"
                                         @bind-Value="_selectedEmployee"
                                         SearchFunc="SearchEmployeesAsync"
                                         ToStringFunc="e => e?.FullName ?? string.Empty"
                                         Variant="Variant.Outlined"
                                         AdornmentIcon="@Icons.Material.Filled.Person"
                                         Adornment="Adornment.Start"
                                         ResetValueOnEmptyText="true"
                                         CoerceValue="true"
                                         Required="true"
                                         RequiredError="يجب اختيار الموظف">
                            <ItemTemplate Context="emp">
                                <div class="d-flex align-center gap-2 pa-1">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        @emp.FullName.FirstOrDefault()
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body2"><b>@emp.FullName</b></MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @(emp.Department ?? "بدون قسم")
                                        </MudText>
                                    </div>
                                </div>
                            </ItemTemplate>
                            <NoItemsTemplate>
                                <MudText Class="pa-2" Color="Color.Secondary">
                                    لا يوجد موظفين مطابقين
                                </MudText>
                            </NoItemsTemplate>
                        </MudAutocomplete>
                    </MudItem>

                    @* ── قيمة السلفة ── *@
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="decimal"
                                         Label="قيمة السلفة (جـ) *"
                                         Value="_dto.LoanAmount"
                                         ValueChanged="OnAmountChanged"
                                         Min="1"
                                         Format="N2"
                                         Variant="Variant.Outlined"
                                         Adornment="Adornment.End"
                                         AdornmentText="جـ"
                                         Required="true"
                                         RequiredError="أدخل قيمة السلفة" />
                    </MudItem>

                    @* ── عدد الأقساط ── *@
                    <MudItem xs="12" sm="6">
                        <MudNumericField T="int"
                                         Label="عدد الأقساط *"
                                         Value="_dto.TotalInstallments"
                                         ValueChanged="OnInstallmentsChanged"
                                         Min="1"
                                         Max="60"
                                         Variant="Variant.Outlined"
                                         Required="true" />
                    </MudItem>

                    @* ── القسط الشهري (للعرض) ── *@
                    <MudItem xs="12" sm="6">
                        <MudTextField Label="القسط الشهري"
                                      Value="_installmentDisplay"
                                      Variant="Variant.Outlined"
                                      ReadOnly="true"
                                      Style="background:#f0fdf4" />
                    </MudItem>

                    @* ── تاريخ السلفة ── *@
                    <MudItem xs="12" sm="6">
                        <MudDatePicker @bind-Date="_loanDate"
                                       Label="تاريخ السلفة *"
                                       Variant="Variant.Outlined"
                                       DateFormat="dd/MM/yyyy"
                                       Required="true" />
                    </MudItem>

                    @* ── شهر بداية الخصم ── *@
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_dto.StartDeductionMonth"
                                      Label="بداية الخصم *"
                                      Placeholder="مثال: 2026-07"
                                      Variant="Variant.Outlined"
                                      HelperText="الصيغة: YYYY-MM"
                                      Required="true"
                                      RequiredError="أدخل شهر بداية الخصم"
                                      Validation="@((string v) => ValidateMonthFormat(v) ? null : "صيغة غير صحيحة (مثال: 2026-07)")" />
                    </MudItem>

                    @* ── الخزينة ── *@
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   @bind-Value="_dto.CashBoxId"
                                   Label="الخزينة *"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   RequiredError="يجب اختيار الخزينة">
                            @foreach (var cb in _cashBoxes)
                            {
                                <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">
                                    @cb.CashBoxName
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        (@cb.CurrentBalance.ToString("N0") جـ)
                                    </MudText>
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* ── الموافق ── *@
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_dto.ApprovedBy"
                                      Label="الموافق على السلفة"
                                      Variant="Variant.Outlined" />
                    </MudItem>

                    @* ── ملاحظات ── *@
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_dto.Notes"
                                      Label="ملاحظات"
                                      Lines="2"
                                      Variant="Variant.Outlined" />
                    </MudItem>

                    @* ── ملخص ── *@
                    @if (_dto.LoanAmount > 0 && _dto.TotalInstallments > 0 && _selectedEmployee != null)
                    {
                        <MudItem xs="12">
                            <MudPaper Class="pa-3 rounded-xl"
                                      Style="background:#f0fdf4;border:1px solid #10b981">
                                <MudText Typo="Typo.subtitle2" Color="Color.Success" Class="mb-1">
                                    📋 ملخص السلفة
                                </MudText>
                                <MudGrid Spacing="1">
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.body2">الموظف:</MudText>
                                        <MudText><b>@_selectedEmployee.FullName</b></MudText>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.body2">المبلغ:</MudText>
                                        <MudText><b>@_dto.LoanAmount.ToString("N2") جـ</b></MudText>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.body2">عدد الأقساط:</MudText>
                                        <MudText><b>@_dto.TotalInstallments</b></MudText>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudText Typo="Typo.body2">القسط الشهري:</MudText>
                                        <MudText><b>@_dto.MonthlyInstallment.ToString("N2") جـ</b></MudText>
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.body2">يبدأ الخصم من:</MudText>
                                        <MudText><b>@_dto.StartDeductionMonth</b></MudText>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </MudForm>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">إلغاء</MudButton>
        <MudButton OnClick="SubmitAsync"
                   Variant="Variant.Filled"
                   Color="Color.Success"
                   Disabled="_saving || _initialLoading"
                   StartIcon="@Icons.Material.Filled.Save">
            @(_saving ? "جاري الحفظ..." : "حفظ السلفة")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter]          public EventCallback     OnSaved   { get; set; }

    private MudForm?             _form;
    private bool                 _formValid;
    private bool                 _saving;
    private bool                 _initialLoading = true;

    private LoanFormDto _dto = new()
    {
        LoanDate            = DateTime.Today,
        StartDeductionMonth = DateTime.Today.AddMonths(1).ToString("yyyy-MM"),
        TotalInstallments   = 1
    };

    private DateTime?           _loanDate         = DateTime.Today;
    private EmployeeLookupDto?  _selectedEmployee;
    private List<CashBoxLookupDto> _cashBoxes      = new();
    private string              _installmentDisplay = "0.00 جـ";
    private string              _currentUser        = "system";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            _currentUser  = authState.User.Identity?.Name ?? "system";
            _cashBoxes    = await LoanService.GetCashBoxesLookupAsync();

            var defaultBox = _cashBoxes.FirstOrDefault(c => c.IsDefault)
                          ?? _cashBoxes.FirstOrDefault();
            if (defaultBox != null)
                _dto.CashBoxId = defaultBox.CashBoxId;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _initialLoading = false;
        }
    }

    private async Task<IEnumerable<EmployeeLookupDto>> SearchEmployeesAsync(
        string? value, CancellationToken ct)
    {
        try   { return await LoanService.GetEmployeesLookupAsync(value); }
        catch { return Enumerable.Empty<EmployeeLookupDto>(); }
    }

    private void OnAmountChanged(decimal value)
    {
        _dto.LoanAmount = value;
        RecalculateInstallment();
    }

    private void OnInstallmentsChanged(int value)
    {
        _dto.TotalInstallments = value;
        RecalculateInstallment();
    }

    private void RecalculateInstallment()
    {
        _dto.MonthlyInstallment = (_dto.TotalInstallments > 0 && _dto.LoanAmount > 0)
            ? Math.Round(_dto.LoanAmount / _dto.TotalInstallments, 2)
            : 0;
        _installmentDisplay = $"{_dto.MonthlyInstallment:N2} جـ";
        StateHasChanged();
    }

    private async Task SubmitAsync()
    {
        if (_form is null) return;
        await _form.ValidateAsync();
        if (!_formValid) return;

        if (_selectedEmployee is null)
        {
            Snackbar.Add("يجب اختيار الموظف", Severity.Warning);
            return;
        }
        if (_dto.LoanAmount <= 0)
        {
            Snackbar.Add("قيمة السلفة يجب أن تكون أكبر من صفر", Severity.Warning);
            return;
        }
        if (!_dto.CashBoxId.HasValue)
        {
            Snackbar.Add("يجب اختيار الخزينة", Severity.Warning);
            return;
        }
        if (!ValidateMonthFormat(_dto.StartDeductionMonth))
        {
            Snackbar.Add("صيغة شهر البداية غير صحيحة (مثال: 2026-07)", Severity.Warning);
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            _dto.EmployeeId   = _selectedEmployee.EmployeeId;
            _dto.EmployeeName = _selectedEmployee.FullName;
            _dto.LoanDate     = _loanDate ?? DateTime.Today;

            var result = await LoanService.SaveLoanAsync(_dto, _currentUser);

            if (result.Success)
            {
                Snackbar.Add(result.Message, Severity.Success);
                await OnSaved.InvokeAsync();
                MudDialog.Close(DialogResult.Ok(result.LoanId));
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private static bool ValidateMonthFormat(string? month)
    {
        if (string.IsNullOrWhiteSpace(month)) return false;
        return DateTime.TryParseExact(
            month + "-01", "yyyy-MM-dd",
            null, System.Globalization.DateTimeStyles.None, out _);
    }

    private void Cancel() => MudDialog.Cancel();
}
