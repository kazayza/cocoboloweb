@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IEmployeeLoanService LoanService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<style>
    .lf-hero {
        border-radius: 22px;
        padding: 18px;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 45%, #1d4ed8 100%);
        color: white;
        position: relative;
        overflow: hidden;
        margin-bottom: 16px;
    }

    .lf-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 15% 20%, rgba(212,175,55,.18), transparent 28%),
            radial-gradient(circle at 85% 80%, rgba(255,255,255,.09), transparent 25%);
        pointer-events: none;
    }

    .lf-hero-content {
        position: relative;
        z-index: 1;
    }

    .lf-card {
        border-radius: 18px;
        border: 1px solid #e2e8f0;
        background: white;
        padding: 16px;
        height: 100%;
    }

    .lf-card-soft {
        background: #f8fafc;
    }

    .lf-card-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .95rem;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 14px;
    }

    .lf-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 12px;
    }

    .lf-summary-box {
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        background: white;
        padding: 14px;
    }

    .lf-summary-label {
        font-size: .74rem;
        color: #64748b;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .lf-summary-value {
        font-size: 1rem;
        color: #0f172a;
        font-weight: 900;
    }

    .lf-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: .72rem;
        font-weight: 800;
        background: #eff6ff;
        color: #1d4ed8;
        border: 1px solid #bfdbfe;
    }
</style>

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.AddCard" Color="Color.Success" />
            <MudText Typo="Typo.h6">إضافة سلفة جديدة</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        @if (_initialLoading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" />
            </div>
        }
        else
        {
            <div class="lf-hero">
                <div class="lf-hero-content d-flex align-center justify-space-between flex-wrap gap-3">
                    <div>
                        <MudText Typo="Typo.h6"><b>تسجيل سلفة موظف</b></MudText>
                        <MudText Typo="Typo.body2" Style="opacity:.82;">
                            يتم صرف السلفة من الخزينة الآن، ثم إنشاء جدول أقساط تلقائيًا للخصم على المرتبات القادمة.
                        </MudText>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <span class="lf-pill">الخصم يبدأ من شهر: @_dto.StartDeductionMonth</span>
                        <span class="lf-pill">الأقساط حتى: @EstimatedEndMonth</span>
                    </div>
                </div>
            </div>

            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-4">
                لو احتجت لاحقًا خصم جزء من القسط فقط، يتم ذلك من تفاصيل السلفة عبر "تجزئة القسط وترحيل جزء" وليس من شاشة إنشاء السلفة.
            </MudAlert>

            <MudForm @ref="_form" @bind-IsValid="_formValid">
                <MudGrid Spacing="2">
                    <MudItem xs="12" lg="8">
                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <div class="lf-card">
                                    <div class="lf-card-title">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                        بيانات الموظف والسلفة
                                    </div>

                                    <MudGrid Spacing="2">
                                        <MudItem xs="12">
                                            <MudAutocomplete T="EmployeeLookupDto"
                                                             Label="الموظف *"
                                                             @bind-Value="_selectedEmployee"
                                                             SearchFunc="SearchEmployeesAsync"
                                                             ToStringFunc="e => e?.FullName ?? string.Empty"
                                                             Variant="Variant.Outlined"
                                                             AdornmentIcon="@Icons.Material.Filled.Person"
                                                             Adornment="Adornment.Start"
                                                             ResetValueOnEmptyText="true"
                                                             CoerceValue="true"
                                                             Required="true"
                                                             RequiredError="يجب اختيار الموظف">
                                                <ItemTemplate Context="emp">
                                                    <div class="d-flex align-center gap-2 pa-1">
                                                        <MudAvatar Size="Size.Small" Color="Color.Primary">
                                                            @emp.FullName.FirstOrDefault()
                                                        </MudAvatar>
                                                        <div>
                                                            <MudText Typo="Typo.body2"><b>@emp.FullName</b></MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                @(emp.Department ?? "بدون قسم")
                                                            </MudText>
                                                        </div>
                                                    </div>
                                                </ItemTemplate>
                                                <NoItemsTemplate>
                                                    <MudText Class="pa-2" Color="Color.Secondary">لا يوجد موظفون مطابقون</MudText>
                                                </NoItemsTemplate>
                                            </MudAutocomplete>
                                        </MudItem>

                                        <MudItem xs="12" sm="6">
                                            <MudNumericField T="decimal"
                                                             Label="قيمة السلفة (جـ) *"
                                                             Value="_dto.LoanAmount"
                                                             ValueChanged="OnAmountChanged"
                                                             Min="1"
                                                             Format="N2"
                                                             Variant="Variant.Outlined"
                                                             Adornment="Adornment.End"
                                                             AdornmentText="جـ"
                                                             Required="true"
                                                             RequiredError="أدخل قيمة السلفة" />
                                        </MudItem>

                                        <MudItem xs="12" sm="6">
                                            <MudNumericField T="int"
                                                             Label="عدد الأقساط *"
                                                             Value="_dto.TotalInstallments"
                                                             ValueChanged="OnInstallmentsChanged"
                                                             Min="1"
                                                             Max="60"
                                                             Variant="Variant.Outlined"
                                                             Required="true" />
                                        </MudItem>

                                        <MudItem xs="12" sm="6">
                                            <MudDatePicker @bind-Date="_loanDate"
                                                           Label="تاريخ السلفة *"
                                                           Variant="Variant.Outlined"
                                                           DateFormat="dd/MM/yyyy"
                                                           Required="true" />
                                        </MudItem>

                                        <MudItem xs="12" sm="6">
                                            <MudTextField @bind-Value="_dto.StartDeductionMonth"
                                                          Label="بداية الخصم *"
                                                          Placeholder="مثال: 2026-07"
                                                          Variant="Variant.Outlined"
                                                          HelperText="الصيغة: YYYY-MM"
                                                          Required="true"
                                                          RequiredError="أدخل شهر بداية الخصم"
                                                          Validation="@((string v) => ValidateMonthFormat(v) ? null : "صيغة غير صحيحة (مثال: 2026-07)")" />
                                        </MudItem>

                                        <MudItem xs="12" sm="6">
                                            <MudSelect T="int?"
                                                       @bind-Value="_dto.CashBoxId"
                                                       Label="الخزينة *"
                                                       Variant="Variant.Outlined"
                                                       Required="true"
                                                       RequiredError="يجب اختيار الخزينة">
                                                @foreach (var cb in _cashBoxes)
                                                {
                                                    <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">
                                                        @cb.CashBoxName
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            (@cb.CurrentBalance.ToString("N0") جـ)
                                                        </MudText>
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>

                                        <MudItem xs="12" sm="6">
                                            <MudTextField @bind-Value="_dto.ApprovedBy"
                                                          Label="الموافق على السلفة"
                                                          Variant="Variant.Outlined"
                                                          Adornment="Adornment.Start"
                                                          AdornmentIcon="@Icons.Material.Filled.VerifiedUser" />
                                        </MudItem>

                                        <MudItem xs="12">
                                            <MudTextField @bind-Value="_dto.Notes"
                                                          Label="ملاحظات"
                                                          Lines="3"
                                                          Variant="Variant.Outlined"
                                                          Adornment="Adornment.Start"
                                                          AdornmentIcon="@Icons.Material.Filled.Notes" />
                                        </MudItem>
                                    </MudGrid>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </MudItem>

                    <MudItem xs="12" lg="4">
                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <div class="lf-card lf-card-soft">
                                    <div class="lf-card-title">
                                        <MudIcon Icon="@Icons.Material.Filled.Calculate" Size="Size.Small" />
                                        ملخص القسط
                                    </div>

                                    <div class="lf-summary-grid">
                                        <div class="lf-summary-box">
                                            <div class="lf-summary-label">القسط الشهري</div>
                                            <div class="lf-summary-value">@_installmentDisplay</div>
                                        </div>
                                        <div class="lf-summary-box">
                                            <div class="lf-summary-label">الشهر الأخير المتوقع</div>
                                            <div class="lf-summary-value">@EstimatedEndMonth</div>
                                        </div>
                                    </div>
                                </div>
                            </MudItem>

                            @if (_dto.LoanAmount > 0 && _dto.TotalInstallments > 0 && _selectedEmployee != null)
                            {
                                <MudItem xs="12">
                                    <div class="lf-card">
                                        <div class="lf-card-title">
                                            <MudIcon Icon="@Icons.Material.Filled.Summarize" Size="Size.Small" />
                                            ملخص السلفة
                                        </div>

                                        <div class="lf-summary-grid">
                                            <div class="lf-summary-box">
                                                <div class="lf-summary-label">الموظف</div>
                                                <div class="lf-summary-value">@_selectedEmployee.FullName</div>
                                            </div>
                                            <div class="lf-summary-box">
                                                <div class="lf-summary-label">المبلغ</div>
                                                <div class="lf-summary-value">@_dto.LoanAmount.ToString("N2") جـ</div>
                                            </div>
                                            <div class="lf-summary-box">
                                                <div class="lf-summary-label">عدد الأقساط</div>
                                                <div class="lf-summary-value">@_dto.TotalInstallments</div>
                                            </div>
                                            <div class="lf-summary-box">
                                                <div class="lf-summary-label">أول خصم</div>
                                                <div class="lf-summary-value">@_dto.StartDeductionMonth</div>
                                            </div>
                                        </div>
                                    </div>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">إلغاء</MudButton>
        <MudButton OnClick="SubmitAsync"
                   Variant="Variant.Filled"
                   Color="Color.Success"
                   Disabled="_saving || _initialLoading"
                   StartIcon="@Icons.Material.Filled.Save">
            @(_saving ? "جاري الحفظ..." : "حفظ السلفة")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public EventCallback OnSaved { get; set; }

    private MudForm? _form;
    private bool _formValid;
    private bool _saving;
    private bool _initialLoading = true;

    private LoanFormDto _dto = new()
    {
        LoanDate = DateTime.Today,
        StartDeductionMonth = DateTime.Today.AddMonths(1).ToString("yyyy-MM"),
        TotalInstallments = 1
    };

    private DateTime? _loanDate = DateTime.Today;
    private EmployeeLookupDto? _selectedEmployee;
    private List<CashBoxLookupDto> _cashBoxes = new();
    private string _installmentDisplay = "0.00 جـ";
    private string _currentUser = "system";

    private string EstimatedEndMonth
    {
        get
        {
            if (!ValidateMonthFormat(_dto.StartDeductionMonth)) return "—";
            if (!DateTime.TryParseExact(_dto.StartDeductionMonth + "-01", "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var startDate))
                return "—";
            return startDate.AddMonths(Math.Max(_dto.TotalInstallments - 1, 0)).ToString("yyyy-MM");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            _currentUser = authState.User.Identity?.Name ?? "system";
            _cashBoxes = await LoanService.GetCashBoxesLookupAsync();

            var defaultBox = _cashBoxes.FirstOrDefault(c => c.IsDefault) ?? _cashBoxes.FirstOrDefault();
            if (defaultBox != null)
                _dto.CashBoxId = defaultBox.CashBoxId;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _initialLoading = false;
        }
    }

    private async Task<IEnumerable<EmployeeLookupDto>> SearchEmployeesAsync(string? value, CancellationToken ct)
    {
        try { return await LoanService.GetEmployeesLookupAsync(value); }
        catch { return Enumerable.Empty<EmployeeLookupDto>(); }
    }

    private void OnAmountChanged(decimal value)
    {
        _dto.LoanAmount = value;
        RecalculateInstallment();
    }

    private void OnInstallmentsChanged(int value)
    {
        _dto.TotalInstallments = value;
        RecalculateInstallment();
    }

    private void RecalculateInstallment()
    {
        _dto.MonthlyInstallment = (_dto.TotalInstallments > 0 && _dto.LoanAmount > 0)
            ? Math.Round(_dto.LoanAmount / _dto.TotalInstallments, 2)
            : 0;
        _installmentDisplay = $"{_dto.MonthlyInstallment:N2} جـ";
        StateHasChanged();
    }

    private async Task SubmitAsync()
    {
        if (_form is null) return;
        await _form.ValidateAsync();
        if (!_formValid) return;

        if (_selectedEmployee is null)
        {
            Snackbar.Add("يجب اختيار الموظف", Severity.Warning);
            return;
        }
        if (_dto.LoanAmount <= 0)
        {
            Snackbar.Add("قيمة السلفة يجب أن تكون أكبر من صفر", Severity.Warning);
            return;
        }
        if (!_dto.CashBoxId.HasValue)
        {
            Snackbar.Add("يجب اختيار الخزينة", Severity.Warning);
            return;
        }
        if (!ValidateMonthFormat(_dto.StartDeductionMonth))
        {
            Snackbar.Add("صيغة شهر البداية غير صحيحة (مثال: 2026-07)", Severity.Warning);
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            _dto.EmployeeId = _selectedEmployee.EmployeeId;
            _dto.EmployeeName = _selectedEmployee.FullName;
            _dto.LoanDate = _loanDate ?? DateTime.Today;

            var result = await LoanService.SaveLoanAsync(_dto, _currentUser);

            if (result.Success)
            {
                Snackbar.Add(result.Message, Severity.Success);
                await OnSaved.InvokeAsync();
                MudDialog.Close(DialogResult.Ok(result.LoanId));
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private static bool ValidateMonthFormat(string? month)
    {
        if (string.IsNullOrWhiteSpace(month)) return false;
        return DateTime.TryParseExact(month + "-01", "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out _);
    }

    private void Cancel() => MudDialog.Cancel();
}
