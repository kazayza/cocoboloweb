@* ═══════════════ CONFLICT DIALOG ═══════════════ *@
<MudDialog @bind-Visible="_showConflictDialog" Options="@_conflictDialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-3">
            <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Medium">
                <MudIcon Icon="@Icons.Material.Filled.Warning" />
            </MudAvatar>
            <MudText Typo="Typo.h6">يوجد شيفت نشط لهذا الموظف</MudText>
        </div>
    </TitleContent>
    
    <DialogContent>
        @if (_existingActiveShift != null)
        {
            <MudPaper Class="pa-4 mb-4" Elevation="0" Style="background: #FFF3E0; border-radius: 12px; border-right: 4px solid #FF9800;">
                <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">الشيفت الحالي:</MudText>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.body2">
                            <strong>@_existingActiveShift.ShiftType</strong> (@_existingActiveShift.StartTimeDisplay - @_existingActiveShift.EndTimeDisplay)
                        </MudText>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Color="Color.Info" />
                        <MudText Typo="Typo.body2">
                            من: <strong>@_existingActiveShift.EffectiveFromDisplay</strong> - @_existingActiveShift.EffectiveToDisplay
                        </MudText>
                    </div>
                </div>
            </MudPaper>

            <MudText Typo="Typo.body1" Class="mb-4">اختر كيف تريد المتابعة:</MudText>

            <MudRadioGroup T="ConflictResolution" @bind-Value="_conflictResolution">
                <MudPaper Class="pa-3 mb-2" Elevation="1" Style="border-radius: 12px;">
                    <MudRadio T="ConflictResolution" Value="ConflictResolution.CloseOldAndAddNew" Color="Color.Primary">
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">إغلاق الشيفت القديم وفتح الجديد</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                سيتم تحديد تاريخ انتهاء الشيفت القديم إلى @(_effectiveFrom?.AddDays(-1).ToString("yyyy/MM/dd") ?? "يوم قبل الجديد")
                            </MudText>
                        </div>
                    </MudRadio>
                </MudPaper>
                
                <MudPaper Class="pa-3" Elevation="1" Style="border-radius: 12px;">
                    <MudRadio T="ConflictResolution" Value="ConflictResolution.KeepBoth" Color="Color.Warning">
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">إضافة الشيفت الجديد مع الإبقاء على القديم</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Error">
                                ⚠️ سيكون هناك شيفتين نشطين في نفس الوقت (غير موصى به)
                            </MudText>
                        </div>
                    </MudRadio>
                </MudPaper>
            </MudRadioGroup>
        }
    </DialogContent>
    
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CloseConflictDialog">إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProceedWithConflictResolution">
            متابعة
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .sticky-top {
        position: sticky;
    }
    
    .cursor-pointer {
        cursor: pointer;
    }
    
    .cursor-pointer:hover {
        transform: translateY(-2px);
        transition: transform 0.2s ease;
    }
</style>

@code {
    [Parameter] public int ShiftId { get; set; }

    #region State
    
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _hasPermission = false;
    private bool _isEdit => ShiftId > 0;

    private MudForm _formRef = null!;
    private EmployeeShiftFormDto _form = new();
    private ShiftEmployeeLookupDto? _selectedEmployee;
    private List<string> _validationErrors = new();

    private TimeSpan? _startTimeSpan;
    private TimeSpan? _endTimeSpan;
    private DateTime? _effectiveFrom;
    private DateTime? _effectiveTo;

    // Conflict Dialog
    private bool _showConflictDialog = false;
    private EmployeeShiftListDto? _existingActiveShift;
    private ConflictResolution _conflictResolution = ConflictResolution.CloseOldAndAddNew;
    
    private DialogOptions _conflictDialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseButton = true,
        CloseOnEscapeKey = true,
        BackdropClick = false
    };

    private enum ConflictResolution
    {
        CloseOldAndAddNew,
        KeepBoth
    }

    #endregion

    #region Computed

    private bool IsActiveShift => !_effectiveTo.HasValue || _effectiveTo.Value >= DateTime.Today;
    
    private bool IsFormValid => (_selectedEmployee != null || _isEdit)
                                && !string.IsNullOrEmpty(_form.ShiftType) 
                                && _startTimeSpan.HasValue 
                                && _endTimeSpan.HasValue 
                                && _effectiveFrom.HasValue;

    #endregion

    #region Lifecycle

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        _hasPermission = user.IsInRole("Admin")
            || user.HasClaim("Permission", _isEdit ? "frm_EmpolyeeShifts:Edit" : "frm_EmpolyeeShifts:Add");

        if (!_hasPermission)
        {
            _isLoading = false;
            return;
        }

        if (_isEdit)
        {
            await LoadExistingShift();
        }
        else
        {
            InitializeNewShift();
        }

        _isLoading = false;
    }

    private async Task LoadExistingShift()
    {
        var existingShift = await ShiftService.GetShiftByIdAsync(ShiftId);
        
        if (existingShift == null)
        {
            Snackbar.Add("الشيفت غير موجود", Severity.Error);
            Nav.NavigateTo("/shifts");
            return;
        }

        _form = existingShift;
        _startTimeSpan = _form.StartTime.ToTimeSpan();
        _endTimeSpan = _form.EndTime.ToTimeSpan();
        _effectiveFrom = _form.EffectiveFrom;
        _effectiveTo = _form.EffectiveTo;

        if (existingShift.EmployeeId.HasValue)
        {
            var employees = await ShiftService.SearchEmployeesAsync("", CancellationToken.None);
            _selectedEmployee = employees.FirstOrDefault(e => e.EmployeeId == existingShift.EmployeeId.Value);
        }
    }

    private void InitializeNewShift()
    {
        _form = new EmployeeShiftFormDto
        {
            ShiftType = ShiftTypes.Morning,
            EffectiveFrom = DateTime.Today
        };
        
        _startTimeSpan = _form.StartTime.ToTimeSpan();
        _endTimeSpan = _form.EndTime.ToTimeSpan();
        _effectiveFrom = _form.EffectiveFrom;
    }

    #endregion

    #region Employee

    private async Task<IEnumerable<ShiftEmployeeLookupDto>> SearchEmployees(string search, CancellationToken ct)
    {
        return await ShiftService.SearchEmployeesAsync(search ?? "", ct);
    }

    private void OnEmployeeSelected(ShiftEmployeeLookupDto? employee)
    {
        _selectedEmployee = employee;
        
        if (employee != null)
        {
            _form.EmployeeId = employee.EmployeeId;
            _form.BiometricCode = employee.BiometricCode;
        }
        else
        {
            _form.EmployeeId = null;
            _form.BiometricCode = null;
        }
    }

    #endregion

    #region Shift Type

    private void OnShiftTypeChanged(string shiftType)
    {
        _form.ShiftType = shiftType;

        if (ShiftTypes.DefaultStartTimes.TryGetValue(shiftType, out var startTime))
        {
            _startTimeSpan = startTime;
            _form.StartTime = TimeOnly.FromTimeSpan(startTime);
        }
        
        if (ShiftTypes.DefaultEndTimes.TryGetValue(shiftType, out var endTime))
        {
            _endTimeSpan = endTime;
            _form.EndTime = TimeOnly.FromTimeSpan(endTime);
        }
    }

    private string GetShiftCardStyle(string shiftType)
    {
        var isSelected = _form.ShiftType == shiftType;
        var baseStyle = "border-radius: 12px; transition: all 0.2s ease; cursor: pointer;";
        
        if (!isSelected)
            return $"{baseStyle} border: 2px solid transparent;";

        return shiftType switch
        {
            "صباحي" => $"{baseStyle} border: 2px solid #FFC107; background: #FFFDE7;",
            "مسائي" => $"{baseStyle} border: 2px solid #9C27B0; background: #F3E5F5;",
            _ => $"{baseStyle} border: 2px solid #9E9E9E;"
        };
    }

    #endregion

    #region Time & Date Calculations

    private string CalculateDuration()
    {
        if (!_startTimeSpan.HasValue || !_endTimeSpan.HasValue) 
            return "--";

        var start = _startTimeSpan.Value;
        var end = _endTimeSpan.Value;
        var duration = end > start ? end - start : TimeSpan.FromHours(24) - start + end;

        var hours = (int)duration.TotalHours;
        var minutes = duration.Minutes;

        if (minutes > 0)
            return $"{hours}س {minutes}د";
        
        return $"{hours} ساعة";
    }

    private string GetTimeBarStyle()
    {
        if (!_startTimeSpan.HasValue || !_endTimeSpan.HasValue)
            return "display: none;";

        var start = _startTimeSpan.Value.TotalHours;
        var end = _endTimeSpan.Value.TotalHours;
        
        var left = (start / 24.0) * 100;
        var width = end > start 
            ? ((end - start) / 24.0) * 100 
            : ((24 - start + end) / 24.0) * 100;

        var color = _form.ShiftType switch
        {
            "صباحي" => "#FFC107",
            "مسائي" => "#9C27B0",
            _ => "#9E9E9E"
        };

        return $"position: absolute; top: 0; bottom: 0; left: {left:F1}%; width: {width:F1}%; background: {color}; border-radius: 10px;";
    }

    private string GetPeriodDuration()
    {
        if (!_effectiveFrom.HasValue || !_effectiveTo.HasValue)
            return "";

        var days = (_effectiveTo.Value - _effectiveFrom.Value).Days;
        
        if (days < 7) return $"{days} يوم";
        if (days < 30) return $"{days / 7} أسبوع";
        if (days < 365) return $"{days / 30} شهر";
        
        return $"{days / 365} سنة";
    }

    private string GetStatusCardStyle()
    {
        return IsActiveShift
            ? "background: linear-gradient(135deg, #E8F5E9, #C8E6C9); border-radius: 12px;"
            : "background: linear-gradient(135deg, #FAFAFA, #EEEEEE); border-radius: 12px;";
    }

    #endregion

    #region Save

    private async Task SaveShift()
    {
        _validationErrors.Clear();
        
        // Validation
        if (_selectedEmployee == null && !_isEdit)
        {
            _validationErrors.Add("يرجى اختيار الموظف");
            Snackbar.Add("يرجى اختيار الموظف", Severity.Warning);
            return;
        }

        if (string.IsNullOrEmpty(_form.ShiftType))
        {
            _validationErrors.Add("يرجى اختيار نوع الشيفت");
            Snackbar.Add("يرجى اختيار نوع الشيفت", Severity.Warning);
            return;
        }

        if (!_startTimeSpan.HasValue || !_endTimeSpan.HasValue)
        {
            _validationErrors.Add("يرجى تحديد أوقات الشيفت");
            Snackbar.Add("يرجى تحديد أوقات الشيفت", Severity.Warning);
            return;
        }

        if (!_effectiveFrom.HasValue)
        {
            _validationErrors.Add("يرجى تحديد تاريخ البدء");
            Snackbar.Add("يرجى تحديد تاريخ البدء", Severity.Warning);
            return;
        }

        // Update form values
        _form.StartTime = TimeOnly.FromTimeSpan(_startTimeSpan.Value);
        _form.EndTime = TimeOnly.FromTimeSpan(_endTimeSpan.Value);
        _form.EffectiveFrom = _effectiveFrom.Value;
        _form.EffectiveTo = _effectiveTo;

        // Check for existing active shift (only for new shifts)
        if (!_isEdit && _selectedEmployee != null)
        {
            var existingShift = await CheckForExistingActiveShift(_selectedEmployee.EmployeeId);
            if (existingShift != null)
            {
                _existingActiveShift = existingShift;
                _showConflictDialog = true;
                return;
            }
        }

        await ExecuteSave();
    }

    private async Task<EmployeeShiftListDto?> CheckForExistingActiveShift(int employeeId)
    {
        var filter = new EmployeeShiftFilterDto
        {
            EmployeeId = employeeId,
            ActiveOnly = true,
            PageSize = 1
        };
        
        var result = await ShiftService.GetShiftsAsync(filter);
        return result.Items.FirstOrDefault();
    }

    private void CloseConflictDialog()
    {
        _showConflictDialog = false;
        _existingActiveShift = null;
    }

    private async Task ProceedWithConflictResolution()
    {
        _showConflictDialog = false;

        if (_conflictResolution == ConflictResolution.CloseOldAndAddNew && _existingActiveShift != null)
        {
            // Close the old shift first
            var closeDate = _effectiveFrom?.AddDays(-1) ?? DateTime.Today.AddDays(-1);
            var oldShiftForm = new EmployeeShiftFormDto
            {
                EmployeeShiftId = _existingActiveShift.EmployeeShiftId,
                EmployeeId = _existingActiveShift.EmployeeId,
                ShiftType = _existingActiveShift.ShiftType,
                StartTime = _existingActiveShift.StartTime,
                EndTime = _existingActiveShift.EndTime,
                EffectiveFrom = _existingActiveShift.EffectiveFrom,
                EffectiveTo = closeDate
            };

            var authState = await AuthState.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "System";

            var closeResult = await ShiftService.UpdateShiftAsync(_existingActiveShift.EmployeeShiftId, oldShiftForm, userName);
            if (!closeResult.Success)
            {
                Snackbar.Add($"فشل إغلاق الشيفت القديم: {closeResult.Message}", Severity.Error);
                return;
            }

            Snackbar.Add($"تم إغلاق الشيفت القديم ({_existingActiveShift.ShiftType})", Severity.Info);
        }

        await ExecuteSave();
    }

    private async Task ExecuteSave()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "System";

            if (_isEdit)
            {
                var result = await ShiftService.UpdateShiftAsync(ShiftId, _form, userName);
                HandleResult(result);
            }
            else
            {
                var dto = new AddEmployeeShiftDto
                {
                    EmployeeId = _selectedEmployee?.EmployeeId,
                    BiometricCode = _form.BiometricCode ?? _selectedEmployee?.BiometricCode,
                    ShiftType = _form.ShiftType,
                    StartTime = _form.StartTime,
                    EndTime = _form.EndTime,
                    EffectiveFrom = _form.EffectiveFrom,
                    EffectiveTo = _form.EffectiveTo
                };

                var result = await ShiftService.AddShiftAsync(dto, userName);
                HandleResult(result);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void HandleResult((bool Success, string Message) result)
    {
        if (result.Success)
        {
            Snackbar.Add(result.Message, Severity.Success);
            Nav.NavigateTo("/shifts");
        }
        else
        {
            Snackbar.Add(result.Message, Severity.Error);
        }
    }
