@page "/shifts/new"
@page "/shifts/edit/{ShiftId:int}"
@page "/shifts/new-v2"
@page "/shifts/edit-v2/{ShiftId:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject IEmployeeShiftService ShiftService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState

<PageTitle>@(_isEdit ? "تعديل الشيفت" : "إضافة شيفت جديد")</PageTitle>

<style>
    .sf-root {
        padding-top: max(1rem, env(safe-area-inset-top));
        padding-bottom: max(2rem, env(safe-area-inset-bottom));
        padding-left: max(1rem, env(safe-area-inset-left));
        padding-right: max(1rem, env(safe-area-inset-right));
        min-height: 100svh;
        background: linear-gradient(180deg, var(--mud-palette-background) 0%, var(--mud-palette-background-grey) 100%);
    }

    .sf-hero {
        border-radius: 24px !important;
        overflow: hidden;
        border: none !important;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.16);
    }

    .sf-hero-bg {
        position: relative;
        background: linear-gradient(140deg, #0C1222 0%, #162033 35%, #1E3A5F 70%, #1A4B7A 100%);
        padding: 28px 24px;
    }

    .sf-hero-bg::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 15% 85%, rgba(99,102,241,0.15) 0%, transparent 40%),
            radial-gradient(circle at 85% 15%, rgba(34,197,94,0.1) 0%, transparent 40%);
        pointer-events: none;
    }

    .sf-hero-content { position: relative; z-index: 3; }

    .sf-hero-icon {
        width: 56px; height: 56px;
        border-radius: 16px;
        background: rgba(99,102,241,0.15);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(99,102,241,0.2);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .sf-section {
        border: 1px solid rgba(148,163,184,.16) !important;
        border-radius: 22px !important;
        background: var(--mud-palette-surface) !important;
        transition: all 0.3s ease;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .sf-section:hover {
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08) !important;
    }

    .sf-sec-head {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 20px;
    }

    .sf-sec-icon {
        width: 38px; height: 38px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .sf-sec-title {
        font-weight: 800;
        font-size: 1rem;
        color: var(--mud-palette-text-primary);
    }

    .sf-sec-num {
        width: 26px; height: 26px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.72rem; font-weight: 800; color: white;
        flex-shrink: 0;
    }

    /* ─── Shift Cards ─── */
    .shift-card {
        border: 1.5px solid rgba(148,163,184,.22);
        border-radius: 22px;
        padding: 22px 18px 18px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
        min-height: 230px;
        height: 100%;
        text-align: right;
        background: linear-gradient(180deg, rgba(255,255,255,.95), rgba(248,250,252,.92));
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: .75rem;
    }

    .shift-card::after {
        content: "";
        position: absolute;
        inset-inline-start: 0;
        inset-block-start: 0;
        inline-size: 100%;
        block-size: 4px;
        background: transparent;
        transition: all .3s ease;
    }

    .shift-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 28px rgba(15,23,42,.10);
        border-color: rgba(99,102,241,.28);
    }

    .shift-card.selected {
        transform: translateY(-4px);
        box-shadow: 0 16px 30px rgba(15,23,42,.14);
    }

    .shift-card.sc-morning.selected {
        border-color: rgba(245,158,11,.55);
        background: linear-gradient(180deg, rgba(255,251,235,1), rgba(254,243,199,.9));
    }

    .shift-card.sc-morning.selected::after { background: #F59E0B; }

    .shift-card.sc-evening.selected {
        border-color: rgba(139,92,246,.55);
        background: linear-gradient(180deg, rgba(245,243,255,1), rgba(237,233,254,.92));
    }

    .shift-card.sc-evening.selected::after { background: #8B5CF6; }

    .shift-card-check {
        position: absolute;
        top: 14px;
        left: 14px;
        width: 28px; height: 28px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 6px 18px rgba(0,0,0,.12);
    }

    .shift-card-badge {
        align-self: flex-start;
        font-size: .68rem;
        font-weight: 800;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(148,163,184,.10);
        color: var(--mud-palette-text-secondary);
        border: 1px solid rgba(148,163,184,.18);
    }

    .shift-card.sc-morning .shift-card-badge {
        background: rgba(245,158,11,.10);
        color: #B45309;
        border-color: rgba(245,158,11,.2);
    }

    .shift-card.sc-evening .shift-card-badge {
        background: rgba(139,92,246,.10);
        color: #6D28D9;
        border-color: rgba(139,92,246,.2);
    }

    .shift-card-icon {
        width: 74px; height: 74px; border-radius: 22px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 8px;
    }

    .shift-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .shift-card-title-wrap {
        display: flex;
        flex-direction: column;
        gap: .2rem;
        flex: 1;
    }

    .shift-card-name {
        font-weight: 900;
        font-size: 1.14rem;
        margin: 0;
        line-height: 1.2;
    }

    .shift-card-desc {
        font-size: 0.76rem;
        color: var(--mud-palette-text-secondary);
        font-weight: 600;
        line-height: 1.4;
    }

    .shift-card-time {
        font-size: 1rem;
        color: var(--mud-palette-text-primary);
        font-weight: 800;
    }

    .shift-card-meta {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .65rem;
    }

    .shift-card-meta-item {
        padding: .7rem .75rem;
        border-radius: 14px;
        background: rgba(148,163,184,.08);
        border: 1px solid rgba(148,163,184,.14);
        text-align: center;
    }

    .shift-card-meta-label {
        display: block;
        font-size: .68rem;
        color: var(--mud-palette-text-secondary);
        margin-bottom: .2rem;
    }

    .shift-card-meta-value {
        font-size: .84rem;
        font-weight: 800;
        color: var(--mud-palette-text-primary);
    }

    .shift-card-dur {
        font-size: .82rem;
        color: var(--mud-palette-text-secondary);
        font-weight: 700;
    }

    /* ─── Day Picker ─── */
    .day-btn {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 16px;
        border: 1.5px solid rgba(148,163,184,.22);
        background: var(--mud-palette-surface);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        cursor: pointer;
        transition: all 0.25s ease;
        gap: 4px;
    }

    .day-btn:hover {
        border-color: rgba(148,163,184,.45);
        background: var(--mud-palette-background-grey);
        transform: translateY(-2px);
    }

    .day-btn.day-off {
        border-color: rgba(245,158,11,.5);
        background: linear-gradient(135deg, rgba(255,251,235,1), rgba(254,243,199,.9));
        box-shadow: 0 10px 20px rgba(245,158,11,.12);
    }

    .day-btn-name { font-size: 0.76rem; font-weight: 800; color: var(--mud-palette-text-primary); }
    .day-btn-label { font-size: 0.6rem; color: var(--mud-palette-text-secondary); }
    .day-btn.day-off .day-btn-name { color: #D97706; }
    .day-btn.day-off .day-btn-label { color: #F59E0B; }

    /* ─── Time Bar ─── */
    .time-bar-wrap {
        background: var(--mud-palette-background-grey);
        border-radius: 14px;
        padding: 18px;
        border: 1px solid rgba(148,163,184,.14);
    }

    .time-bar-track {
        height: 12px;
        background: rgba(148,163,184,.22);
        border-radius: 6px;
        position: relative;
        overflow: hidden;
    }

    .time-bar-fill {
        position: absolute;
        top: 0; bottom: 0;
        border-radius: 6px;
        transition: all 0.5s ease;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.18);
    }

    .time-bar-labels {
        display: flex;
        justify-content: space-between;
        margin-top: 8px;
    }

    .time-bar-labels span { font-size: 0.68rem; color: var(--mud-palette-text-secondary); }

    /* ─── Summary ─── */
    .sf-summary {
        border: 1px solid rgba(148,163,184,.16) !important;
        border-radius: 22px !important;
        background: var(--mud-palette-surface) !important;
        position: sticky;
        top: 80px;
        box-shadow: 0 10px 26px rgba(15,23,42,.05);
    }

    .sf-sum-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        gap: .75rem;
    }

    .sf-sum-label { font-size: 0.82rem; color: var(--mud-palette-text-secondary); }
    .sf-sum-value { font-size: 0.84rem; font-weight: 800; color: var(--mud-palette-text-primary); text-align: left; }
    .sf-sum-divider { height: 1px; background: rgba(148,163,184,.14); margin: 6px 0; }

    /* ─── Info Box ─── */
    .info-box {
        border-radius: 14px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-box-success { background: rgba(16,185,129,.08); border: 1px solid rgba(16,185,129,.18); }
    .info-box-info { background: rgba(14,165,233,.08); border: 1px solid rgba(14,165,233,.18); }
    .info-box-warning { background: rgba(245,158,11,.08); border: 1px solid rgba(245,158,11,.18); }

    body.dark-mode .sf-root {
        background: linear-gradient(180deg, #0b1220 0%, #111827 100%);
    }

    body.dark-mode .sf-section,
    body.dark-mode .sf-summary {
        background: #111c2f !important;
        border-color: rgba(71,85,105,.55) !important;
        box-shadow: 0 10px 28px rgba(0,0,0,.24) !important;
    }

    body.dark-mode .sf-sec-title,
    body.dark-mode .sf-sum-value,
    body.dark-mode .day-btn-name,
    body.dark-mode .shift-card-time,
    body.dark-mode .shift-card-meta-value,
    body.dark-mode .shift-card-name {
        color: #E5E7EB !important;
    }

    body.dark-mode .shift-card {
        background: linear-gradient(180deg, rgba(17,28,47,.98), rgba(15,23,42,.98));
        border-color: rgba(71,85,105,.45);
        box-shadow: 0 8px 20px rgba(0,0,0,.18);
    }

    body.dark-mode .shift-card:hover {
        box-shadow: 0 14px 28px rgba(0,0,0,.30);
        border-color: rgba(129,140,248,.45);
    }

    body.dark-mode .shift-card.sc-morning.selected {
        background: linear-gradient(180deg, rgba(120,53,15,.45), rgba(69,39,3,.32));
        border-color: rgba(245,158,11,.55);
    }

    body.dark-mode .shift-card.sc-evening.selected {
        background: linear-gradient(180deg, rgba(76,29,149,.44), rgba(49,19,103,.32));
        border-color: rgba(139,92,246,.55);
    }

    body.dark-mode .sc-morning .shift-card-icon {
        background: rgba(245,158,11,.14) !important;
    }

    body.dark-mode .sc-evening .shift-card-icon {
        background: rgba(139,92,246,.14) !important;
    }

    body.dark-mode .shift-card-badge {
        background: rgba(15,23,42,.55);
        border-color: rgba(71,85,105,.42);
        color: #CBD5E1;
    }

    body.dark-mode .sc-morning .shift-card-badge {
        background: rgba(245,158,11,.14);
        color: #FBBF24;
        border-color: rgba(245,158,11,.32);
    }

    body.dark-mode .sc-evening .shift-card-badge {
        background: rgba(139,92,246,.14);
        color: #C4B5FD;
        border-color: rgba(139,92,246,.32);
    }

    body.dark-mode .shift-card-desc,
    body.dark-mode .shift-card-dur,
    body.dark-mode .sf-sum-label,
    body.dark-mode .time-bar-labels span,
    body.dark-mode .day-btn-label {
        color: #94A3B8 !important;
    }

    body.dark-mode .shift-card-meta-item,
    body.dark-mode .time-bar-wrap,
    body.dark-mode .day-btn:not(.day-off) {
        background: rgba(15,23,42,.55);
        border-color: rgba(71,85,105,.45);
    }

    body.dark-mode .time-bar-track {
        background: rgba(71,85,105,.45);
    }

    body.dark-mode .day-btn:hover {
        background: rgba(30,41,59,.82);
    }

    body.dark-mode .day-btn.day-off {
        background: linear-gradient(135deg, rgba(120,53,15,.45), rgba(92,39,0,.30));
    }

    body.dark-mode .info-box-success { background: rgba(6,78,59,.55); border-color: rgba(16,185,129,.26); }
    body.dark-mode .info-box-info { background: rgba(8,47,73,.55); border-color: rgba(14,165,233,.26); }
    body.dark-mode .info-box-warning { background: rgba(69,39,3,.55); border-color: rgba(245,158,11,.26); }

    /* ─── Responsive ─── */
    @@media (max-width: 768px) {
        .sf-hero-bg { padding: 20px 16px; }
        .sf-section { border-radius: 18px !important; }
        .shift-card {
            min-height: 210px;
            padding: 18px 14px 16px;
        }
        .shift-card-icon { width: 60px; height: 60px; border-radius: 18px; }
        .shift-card-name { font-size: 1.02rem; }
        .sf-summary { position: static; }
    }

    @@media (max-width: 380px) {
        .day-btn { border-radius: 12px; }
        .shift-card-name { font-size: 0.92rem; }
        .shift-card-meta { grid-template-columns: 1fr; }
    }
</style>

<AuthorizeView>
    <Authorized Context="authCtx">
        @if (!_hasPermission)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
                <MudPaper Class="pa-10 text-center sf-section" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large"
                             Style="font-size:64px;color:#EF4444;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Style="font-weight:800;color:#EF4444;" Class="mb-2">غير مصرح</MudText>
                    <MudText Typo="Typo.body1" Style="color:#94A3B8;" Class="mb-4">
                        ليس لديك صلاحية الوصول لهذه الصفحة
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="@(() => Nav.NavigateTo("/shifts"))"
                               Style="border-radius:12px;">العودة</MudButton>
                </MudPaper>
            </MudContainer>
        }
        else if (_isLoading)
        {
            <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
                <MudPaper Class="pa-10 text-center sf-section" Elevation="0">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                    <MudText Typo="Typo.h6" Style="color:#94A3B8;" Class="mt-4">جاري تحميل البيانات...</MudText>
                </MudPaper>
            </MudContainer>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 sf-root">

                @* ══════════════ HEADER ══════════════ *@
                <MudPaper Class="mb-5 sf-hero" Elevation="0">
                    <div class="sf-hero-bg">
                        <div class="sf-hero-content">
                            <div class="d-flex align-center justify-space-between flex-wrap gap-3">
                                <div class="d-flex align-center gap-3">
                                    <div class="sf-hero-icon">
                                        <MudIcon Icon="@(_isEdit ? Icons.Material.Filled.EditCalendar : Icons.Material.Filled.PostAdd)"
                                                 Size="Size.Medium" Style="color:#818CF8;" />
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.h5" Style="color:white;font-weight:800;letter-spacing:-0.5px;">
                                            @(_isEdit ? "تعديل الشيفت" : "إضافة شيفت جديد")
                                        </MudText>
                                        <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.5);">
                                            @if (_selectedEmployee != null)
                                            {
                                                @_selectedEmployee.FullName
                                                @if (!string.IsNullOrEmpty(_selectedEmployee.Department))
                                                {
                                                    <span> — @_selectedEmployee.Department</span>
                                                }
                                            }
                                            else
                                            {
                                                <span>حدد الموظف ونوع الشيفت والفترة</span>
                                            }
                                        </MudText>
                                    </div>
                                </div>
                                <MudButton Variant="Variant.Filled"
                                           StartIcon="@Icons.Material.Filled.ArrowBack"
                                           Style="background:rgba(255,255,255,0.1);color:white;border-radius:12px;"
                                           Size="Size.Small" OnClick="Cancel">العودة</MudButton>
                            </div>
                        </div>
                    </div>
                </MudPaper>

                <MudForm @ref="_formRef">
                    <MudGrid Spacing="4">

                        @* ══════════════ LEFT — Sections ══════════════ *@
                        <MudItem xs="12" lg="8">

                            @* ──── 1: الموظف ──── *@
                            <MudPaper Class="pa-5 mb-4 sf-section" Elevation="0">
                                <div class="sf-sec-head">
                                    <div class="sf-sec-num" style="background:#6366F1;">1</div>
                                    <div class="sf-sec-icon" style="background:#EEF2FF;">
                                        <MudIcon Icon="@Icons.Material.Filled.PersonSearch" Style="color:#6366F1;font-size:18px;" />
                                    </div>
                                    <span class="sf-sec-title">اختيار الموظف</span>
                                </div>

                                <MudGrid Spacing="3">
                                    <MudItem xs="12" md="8">
                                        <MudAutocomplete T="ShiftEmployeeLookupDto"
                                                         Label="ابحث عن الموظف"
                                                         Placeholder="اسم الموظف أو الرقم القومي..."
                                                         Value="_selectedEmployee"
                                                         ValueChanged="OnEmployeeSelected"
                                                         SearchFunc="@SearchEmployees"
                                                         ToStringFunc="@(e => e?.FullName ?? "")"
                                                         Disabled="_isEdit"
                                                         Required="true"
                                                         RequiredError="يرجى اختيار الموظف"
                                                         Clearable="true"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         ShowProgressIndicator="true"
                                                         MinCharacters="0"
                                                         DebounceInterval="300"
                                                         MaxItems="20">
                                            <ItemTemplate Context="empCtx">
                                                <div class="d-flex align-center gap-3 py-1">
                                                    <MudAvatar Color="Color.Primary" Size="Size.Small"
                                                               Style="font-size:0.75rem;font-weight:700;">
                                                        @(empCtx.FullName.Length > 0 ? empCtx.FullName[0] : '?')
                                                    </MudAvatar>
                                                    <div>
                                                        <MudText Typo="Typo.body2" Style="font-weight:700;">@empCtx.FullName</MudText>
                                                        <MudText Typo="Typo.caption" Style="color:#94A3B8;">
                                                            @(empCtx.Department ?? "بدون قسم")
                                                            @if (empCtx.BiometricCode.HasValue)
                                                            {
                                                                <span> • كود: @empCtx.BiometricCode</span>
                                                            }
                                                        </MudText>
                                                    </div>
                                                </div>
                                            </ItemTemplate>
                                        </MudAutocomplete>
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudNumericField T="int?"
                                                         Label="كود البصمة"
                                                         Value="_form.BiometricCode"
                                                         ValueChanged="@(v => _form.BiometricCode = v)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         ReadOnly="@(_selectedEmployee?.BiometricCode.HasValue ?? false)"
                                                         Min="0"
                                                         Adornment="Adornment.Start"
                                                         AdornmentIcon="@Icons.Material.Filled.Fingerprint" />
                                    </MudItem>
                                </MudGrid>

                                @if (_selectedEmployee != null)
                                {
                                    <div class="info-box info-box-info mt-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Badge" Style="color:#0EA5E9;" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Style="color:#0369A1;">
                                            <strong>@_selectedEmployee.FullName</strong> —
                                            @(_selectedEmployee.Department ?? "بدون قسم")
                                            @if (_selectedEmployee.BiometricCode.HasValue)
                                            {
                                                <span> — كود: @_selectedEmployee.BiometricCode</span>
                                            }
                                        </MudText>
                                    </div>
                                }
                            </MudPaper>

                            @* ──── 2: نوع الشيفت ──── *@
                            <MudPaper Class="pa-5 mb-4 sf-section" Elevation="0">
                                <div class="sf-sec-head">
                                    <div class="sf-sec-num" style="background:#F59E0B;">2</div>
                                    <div class="sf-sec-icon" style="background:#FFFBEB;">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Style="color:#F59E0B;font-size:18px;" />
                                    </div>
                                    <span class="sf-sec-title">نوع الشيفت والأوقات</span>
                                </div>

                                <MudGrid Spacing="3" Class="mb-4">
                                    @* صباحي *@
                                    <MudItem xs="12" md="6">
                                        <div class="shift-card sc-morning @(_form.ShiftType == ShiftTypes.Morning ? "selected" : "")"
                                             @onclick="@(() => OnShiftTypeChanged(ShiftTypes.Morning))">
                                            @if (_form.ShiftType == ShiftTypes.Morning)
                                            {
                                                <div class="shift-card-check" style="background:#F59E0B;">
                                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="color:white;font-size:14px;" />
                                                </div>
                                            }

                                            <span class="shift-card-badge">شيفت صباحى</span>

                                            <div class="shift-card-head">
                                                <div class="shift-card-title-wrap">
                                                    <div class="shift-card-name" style="color:#92400E;">صباحي</div>
                                                    <div class="shift-card-desc">أفضل للفرق الإدارية والتشغيل اليومي والعمل المكتبي</div>
                                                </div>
                                                <div class="shift-card-icon" style="background:#FEF3C7;">
                                                    <MudIcon Icon="@Icons.Material.Filled.WbSunny" Style="color:#F59E0B;font-size:32px;" />
                                                </div>
                                            </div>

                                            <div class="shift-card-time">10:00 ص — 6:00 م</div>

                                            <div class="shift-card-meta">
                                                <div class="shift-card-meta-item">
                                                    <span class="shift-card-meta-label">المدة</span>
                                                    <span class="shift-card-meta-value">8 ساعات</span>
                                                </div>
                                                <div class="shift-card-meta-item">
                                                    <span class="shift-card-meta-label">النمط</span>
                                                    <span class="shift-card-meta-value">شيفت صباحى</span>
                                                </div>
                                            </div>
                                        </div>
                                    </MudItem>

                                    @* مسائي *@
                                    <MudItem xs="12" md="6">
                                        <div class="shift-card sc-evening @(_form.ShiftType == ShiftTypes.Evening ? "selected" : "")"
                                             @onclick="@(() => OnShiftTypeChanged(ShiftTypes.Evening))">
                                            @if (_form.ShiftType == ShiftTypes.Evening)
                                            {
