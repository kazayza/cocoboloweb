                                             style="height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                                            <MudIcon Icon="@(IsActiveShift ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.PauseCircle)"
                                                     Style="@($"color:{(IsActiveShift ? "#059669" : "#D97706")};font-size:28px;")" />
                                            <MudText Typo="Typo.caption"
                                                     Style="@($"color:{(IsActiveShift ? "#065F46" : "#92400E")};font-weight:700;margin-top:4px;")">
                                                @(IsActiveShift ? "نشط" : "منتهي")
                                            </MudText>
                                        </div>
                                    </MudItem>
                                </MudGrid>

                                @if (_effectiveFrom.HasValue)
                                {
                                    <div class="info-box info-box-info mt-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Style="color:#0EA5E9;" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Style="color:#0C4A6E;">
                                            يبدأ: <strong>@_effectiveFrom.Value.ToString("dddd، dd MMMM yyyy")</strong>
                                            @if (_effectiveTo.HasValue)
                                            {
                                                <span> — ينتهي: <strong>@_effectiveTo.Value.ToString("dddd، dd MMMM yyyy")</strong></span>
                                                <span> (@GetPeriodDuration())</span>
                                            }
                                            else
                                            {
                                                <span> — <strong>مستمر</strong></span>
                                            }
                                        </MudText>
                                    </div>
                                }
                            </MudPaper>
                        </MudItem>

                        @* ══════════════ RIGHT — Summary ══════════════ *@
                        <MudItem xs="12" lg="4">
                            <MudPaper Class="pa-5 sf-summary" Elevation="0">

                                <div class="d-flex align-center gap-2 mb-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Summarize" Style="color:#6366F1;" />
                                    <MudText Typo="Typo.h6" Style="font-weight:800;color:#1E293B;">ملخص الشيفت</MudText>
                                </div>

                                @if (_selectedEmployee != null)
                                {
                                    <div class="d-flex align-center gap-3 mb-3">
                                        <MudAvatar Color="Color.Primary" Size="Size.Medium" Style="font-weight:700;">
                                            @(_selectedEmployee.FullName[0])
                                        </MudAvatar>
                                        <div>
                                            <MudText Typo="Typo.subtitle2" Style="font-weight:700;">@_selectedEmployee.FullName</MudText>
                                            <MudText Typo="Typo.caption" Style="color:#94A3B8;">@(_selectedEmployee.Department ?? "بدون قسم")</MudText>
                                        </div>
                                    </div>
                                    <div class="sf-sum-divider"></div>
                                }

                                <div class="sf-sum-row">
                                    <span class="sf-sum-label">نوع الشيفت</span>
                                    <span class="sf-sum-value" style="@GetShiftTypeColor()">@(_form.ShiftType ?? "—")</span>
                                </div>
                                <div class="sf-sum-row">
                                    <span class="sf-sum-label">التوقيت</span>
                                    <span class="sf-sum-value">
                                        @(_startTimeSpan.HasValue ? $"{_startTimeSpan.Value:hh\\:mm}" : "--")
                                        —
                                        @(_endTimeSpan.HasValue ? $"{_endTimeSpan.Value:hh\\:mm}" : "--")
                                    </span>
                                </div>
                                <div class="sf-sum-row">
                                    <span class="sf-sum-label">المدة</span>
                                    <span class="sf-sum-value" style="color:#059669;">@CalculateDuration()</span>
                                </div>
                                <div class="sf-sum-divider"></div>
                                <div class="sf-sum-row">
                                    <span class="sf-sum-label">أيام الراحة</span>
                                    <span class="sf-sum-value">
                                        @if (_form.OffDay1.HasValue)
                                        {
                                            @GetOffDayName(_form.OffDay1)
                                            @if (_form.OffDay2.HasValue)
                                            {
                                                <span> + @GetOffDayName(_form.OffDay2)</span>
                                            }
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </span>
                                </div>
                                <div class="sf-sum-row">
                                    <span class="sf-sum-label">أيام العمل/شهر</span>
                                    <span class="sf-sum-value" style="color:#059669;">~@CalculateWorkDays() يوم</span>
                                </div>
                                <div class="sf-sum-divider"></div>
                                <div class="sf-sum-row">
                                    <span class="sf-sum-label">يبدأ من</span>
                                    <span class="sf-sum-value">@(_effectiveFrom?.ToString("yyyy/MM/dd") ?? "—")</span>
                                </div>
                                <div class="sf-sum-row">
                                    <span class="sf-sum-label">ينتهي في</span>
                                    <span class="sf-sum-value">@(_effectiveTo?.ToString("yyyy/MM/dd") ?? "مستمر")</span>
                                </div>
                                <div class="sf-sum-row">
                                    <span class="sf-sum-label">الحالة</span>
                                    <span class="sf-sum-value" style="@($"color:{(IsActiveShift ? "#059669" : "#D97706")}")">
                                        @(IsActiveShift ? "● نشط" : "○ منتهي")
                                    </span>
                                </div>

                                @if (_validationErrors.Any())
                                {
                                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-3"
                                              Style="border-radius:10px;">
                                        @_validationErrors.First()
                                    </MudAlert>
                                }

                                <div class="d-flex flex-column gap-2 mt-4">
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                               FullWidth="true"
                                               StartIcon="@(_isSaving ? null : Icons.Material.Filled.Save)"
                                               OnClick="SaveShift"
                                               Disabled="_isSaving || !IsFormValid"
                                               Style="border-radius:14px;height:48px;font-weight:700;">
                                        @if (_isSaving)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-2" />
                                            <span>جاري الحفظ...</span>
                                        }
                                        else
                                        {
                                            <span>@(_isEdit ? "حفظ التعديلات" : "إضافة الشيفت")</span>
                                        }
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                                               FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.Close"
                                               OnClick="Cancel" Disabled="_isSaving"
                                               Style="border-radius:14px;">إلغاء</MudButton>
                                </div>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudForm>
            </MudContainer>
        }
    </Authorized>

    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
            <MudPaper Class="pa-10 text-center sf-section" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Large"
                         Style="font-size:64px;color:#F59E0B;" Class="mb-4" />
                <MudText Typo="Typo.h5" Style="font-weight:800;color:#F59E0B;" Class="mb-2">تسجيل الدخول مطلوب</MudText>
                <MudText Typo="Typo.body1" Style="color:#94A3B8;">يرجى تسجيل الدخول للوصول لهذه الصفحة</MudText>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@* ══════════════ CONFLICT DIALOG ══════════════ *@
<MudDialog @bind-Visible="_showConflictDialog" Options="@_conflictDialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-3">
            <MudAvatar Style="background:#FEF3C7;" Size="Size.Medium">
                <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Style="color:#F59E0B;" />
            </MudAvatar>
            <MudText Typo="Typo.h6" Style="font-weight:700;">يوجد شيفت نشط</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_existingActiveShift != null)
        {
            <div class="info-box info-box-warning mb-4">
                <div>
                    <MudText Typo="Typo.body2" Style="font-weight:700;color:#92400E;" Class="mb-1">الشيفت الحالي:</MudText>
                    <MudText Typo="Typo.body2" Style="color:#78350F;">
                        @_existingActiveShift.ShiftType — @_existingActiveShift.StartTimeDisplay إلى @_existingActiveShift.EndTimeDisplay
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#A16207;">من: @_existingActiveShift.EffectiveFromDisplay</MudText>
                </div>
            </div>

            <MudRadioGroup T="ConflictResolution" @bind-Value="_conflictResolution">
                <MudPaper Class="pa-3 mb-2 sf-section" Elevation="0">
                    <MudRadio T="ConflictResolution" Value="ConflictResolution.CloseOldAndAddNew" Color="Color.Primary">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">إغلاق القديم وفتح الجديد</MudText>
                        <MudText Typo="Typo.caption" Style="color:#94A3B8;">
                            ينتهي القديم في @(_effectiveFrom?.AddDays(-1).ToString("yyyy/MM/dd"))
                        </MudText>
                    </MudRadio>
                </MudPaper>
                <MudPaper Class="pa-3 sf-section" Elevation="0">
                    <MudRadio T="ConflictResolution" Value="ConflictResolution.KeepBoth" Color="Color.Warning">
                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">إبقاء الاثنين معاً</MudText>
                        <MudText Typo="Typo.caption" Style="color:#EF4444;">⚠️ غير موصى به</MudText>
                    </MudRadio>
                </MudPaper>
            </MudRadioGroup>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="CloseConflictDialog">إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProceedWithConflictResolution">متابعة</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int ShiftId { get; set; }

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _hasPermission = false;
    private bool _isEdit => ShiftId > 0;

    private MudForm _formRef = null!;
    private EmployeeShiftFormDto _form = new();
    private ShiftEmployeeLookupDto? _selectedEmployee;
    private List<string> _validationErrors = new();

    private TimeSpan? _startTimeSpan;
    private TimeSpan? _endTimeSpan;
    private DateTime? _effectiveFrom;
    private DateTime? _effectiveTo;

    private bool _showConflictDialog = false;
    private EmployeeShiftListDto? _existingActiveShift;
    private ConflictResolution _conflictResolution = ConflictResolution.CloseOldAndAddNew;

    private DialogOptions _conflictDialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseButton = true,
        CloseOnEscapeKey = true,
        BackdropClick = false
    };

    private enum ConflictResolution { CloseOldAndAddNew, KeepBoth }

    private record DayInfo(byte Value, string Short, string Full);
    private List<DayInfo> _weekDays = new()
    {
        new(0, "أحد", "الأحد"),
        new(1, "اثنين", "الاثنين"),
        new(2, "ثلاثاء", "الثلاثاء"),
        new(3, "اربعاء", "الأربعاء"),
        new(4, "خميس", "الخميس"),
        new(5, "جمعه", "الجمعة"),
        new(6, "سبت", "السبت")
    };

    private bool IsActiveShift => !_effectiveTo.HasValue || _effectiveTo.Value >= DateTime.Today;

    private bool IsFormValid => (_selectedEmployee != null || _isEdit)
                                && !string.IsNullOrEmpty(_form.ShiftType)
                                && _startTimeSpan.HasValue
                                && _endTimeSpan.HasValue
                                && _effectiveFrom.HasValue;

    // ══════════════ Lifecycle ══════════════
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        _hasPermission = user.IsInRole("Admin")
            || user.HasClaim("Permission", _isEdit ? "frm_EmpolyeeShifts:Edit" : "frm_EmpolyeeShifts:Add");

        if (!_hasPermission) { _isLoading = false; return; }

        if (_isEdit)
            await LoadExistingShift();
        else
            InitializeNewShift();

        _isLoading = false;
    }

    private async Task LoadExistingShift()
    {
        var s = await ShiftService.GetShiftByIdAsync(ShiftId);
        if (s == null)
        {
            Snackbar.Add("الشيفت غير موجود", Severity.Error);
            Nav.NavigateTo("/shifts");
            return;
        }

        _form = s;
        _startTimeSpan = _form.StartTime.ToTimeSpan();
        _endTimeSpan = _form.EndTime.ToTimeSpan();
        _effectiveFrom = _form.EffectiveFrom;
        _effectiveTo = _form.EffectiveTo;

        if (s.EmployeeId.HasValue)
        {
            var emps = await ShiftService.SearchEmployeesAsync("", CancellationToken.None);
            _selectedEmployee = emps.FirstOrDefault(e => e.EmployeeId == s.EmployeeId.Value);
        }
    }

    private void InitializeNewShift()
    {
        _form = new EmployeeShiftFormDto
        {
            ShiftType = ShiftTypes.Morning,
            EffectiveFrom = DateTime.Today
        };
        _startTimeSpan = _form.StartTime.ToTimeSpan();
        _endTimeSpan = _form.EndTime.ToTimeSpan();
        _effectiveFrom = _form.EffectiveFrom;
    }

    // ══════════════ Employee ══════════════
    private async Task<IEnumerable<ShiftEmployeeLookupDto>> SearchEmployees(string search, CancellationToken ct)
        => await ShiftService.SearchEmployeesAsync(search ?? "", ct);

    private void OnEmployeeSelected(ShiftEmployeeLookupDto? emp)
    {
        _selectedEmployee = emp;
        _form.EmployeeId = emp?.EmployeeId;
        _form.BiometricCode = emp?.BiometricCode;
    }

    // ══════════════ Shift Type ══════════════
    private void OnShiftTypeChanged(string type)
    {
        _form.ShiftType = type;
        if (ShiftTypes.DefaultStartTimes.TryGetValue(type, out var st))
        {
            _startTimeSpan = st;
            _form.StartTime = TimeOnly.FromTimeSpan(st);
        }
        if (ShiftTypes.DefaultEndTimes.TryGetValue(type, out var et))
        {
            _endTimeSpan = et;
            _form.EndTime = TimeOnly.FromTimeSpan(et);
        }
    }

    private string GetShiftTypeColor()
    {
        if (_form.ShiftType == "صباحي") return "color:#D97706;";
        if (_form.ShiftType == "مسائي") return "color:#7C3AED;";
        return "color:#94A3B8;";
    }

    // ══════════════ Off Days ══════════════
    private void ToggleOffDay(byte day)
    {
        if (_form.OffDay1 == day) { _form.OffDay1 = null; return; }
        if (_form.OffDay2 == day) { _form.OffDay2 = null; return; }
        if (!_form.OffDay1.HasValue) { _form.OffDay1 = day; return; }
        if (!_form.OffDay2.HasValue) { _form.OffDay2 = day; return; }
        _form.OffDay1 = _form.OffDay2;
        _form.OffDay2 = day;
    }

    // ══════════════ Calculations ══════════════
    private string CalculateDuration()
    {
        if (!_startTimeSpan.HasValue || !_endTimeSpan.HasValue) return "—";
        var d = _endTimeSpan.Value > _startTimeSpan.Value
            ? _endTimeSpan.Value - _startTimeSpan.Value
            : TimeSpan.FromHours(24) - _startTimeSpan.Value + _endTimeSpan.Value;
        if (d.Minutes > 0) return $"{(int)d.TotalHours}س {d.Minutes}د";
        return $"{(int)d.TotalHours} ساعة";
    }

    private string GetTimeBarStyle()
    {
        if (!_startTimeSpan.HasValue || !_endTimeSpan.HasValue) return "display:none;";
        var s = _startTimeSpan.Value.TotalHours;
        var e = _endTimeSpan.Value.TotalHours;
        var left = (s / 24.0) * 100;
        var width = e > s ? ((e - s) / 24.0) * 100 : ((24 - s + e) / 24.0) * 100;

        string c;
        if (_form.ShiftType == "صباحي") c = "#F59E0B";
        else if (_form.ShiftType == "مسائي") c = "#8B5CF6";
        else c = "#94A3B8";

        return $"left:{left:F1}%;width:{width:F1}%;background:{c};";
    }

    private string GetPeriodDuration()
    {
        if (!_effectiveFrom.HasValue || !_effectiveTo.HasValue) return "";
        var d = (_effectiveTo.Value - _effectiveFrom.Value).Days;
        if (d < 7) return $"{d} يوم";
        if (d < 30) return $"{d / 7} أسبوع";
        if (d < 365) return $"{d / 30} شهر";
        return $"{d / 365} سنة";
    }

    private static string GetOffDayName(byte? day)
    {
        if (!day.HasValue) return "";
        return day.Value switch
        {
            0 => "الأحد",
            1 => "الاثنين",
            2 => "الثلاثاء",
            3 => "الأربعاء",
            4 => "الخميس",
            5 => "الجمعة",
            6 => "السبت",
            _ => ""
        };
    }

    private int CalculateWorkDays()
    {
        var offs = new List<DayOfWeek>();
        if (_form.OffDay1.HasValue) offs.Add((DayOfWeek)_form.OffDay1.Value);
        if (_form.OffDay2.HasValue) offs.Add((DayOfWeek)_form.OffDay2.Value);
        var refDate = _effectiveFrom ?? DateTime.Today;
        int total = DateTime.DaysInMonth(refDate.Year, refDate.Month);
        int count = 0;
        for (int i = 1; i <= total; i++)
        {
            if (!offs.Contains(new DateTime(refDate.Year, refDate.Month, i).DayOfWeek)) count++;
        }
        return count;
    }

    // ══════════════ Save ══════════════
    private async Task SaveShift()
    {
        _validationErrors.Clear();

        if (_selectedEmployee == null && !_isEdit) { AddError("يرجى اختيار الموظف"); return; }
        if (string.IsNullOrEmpty(_form.ShiftType)) { AddError("يرجى اختيار نوع الشيفت"); return; }
        if (!_startTimeSpan.HasValue || !_endTimeSpan.HasValue) { AddError("يرجى تحديد أوقات الشيفت"); return; }
        if (!_effectiveFrom.HasValue) { AddError("يرجى تحديد تاريخ البدء"); return; }

        _form.StartTime = TimeOnly.FromTimeSpan(_startTimeSpan.Value);
        _form.EndTime = TimeOnly.FromTimeSpan(_endTimeSpan.Value);
        _form.EffectiveFrom = _effectiveFrom.Value;
        _form.EffectiveTo = _effectiveTo;

        if (!_isEdit && _selectedEmployee != null)
        {
            var existing = await CheckForExistingActiveShift(_selectedEmployee.EmployeeId);
            if (existing != null)
            {
                _existingActiveShift = existing;
                _showConflictDialog = true;
                return;
            }
        }

        await ExecuteSave();
    }

    private void AddError(string msg)
    {
        _validationErrors.Add(msg);
        Snackbar.Add(msg, Severity.Warning);
    }

    private async Task<EmployeeShiftListDto?> CheckForExistingActiveShift(int empId)
    {
        var f = new EmployeeShiftFilterDto { EmployeeId = empId, ActiveOnly = true, PageSize = 1 };
        var r = await ShiftService.GetShiftsAsync(f);
        return r.Items.FirstOrDefault();
    }

    private void CloseConflictDialog()
    {
        _showConflictDialog = false;
        _existingActiveShift = null;
    }

    private async Task ProceedWithConflictResolution()
    {
        _showConflictDialog = false;

        if (_conflictResolution == ConflictResolution.CloseOldAndAddNew && _existingActiveShift != null)
        {
            var closeDate = _effectiveFrom?.AddDays(-1) ?? DateTime.Today.AddDays(-1);
            var old = new EmployeeShiftFormDto
            {
                EmployeeShiftId = _existingActiveShift.EmployeeShiftId,
                EmployeeId = _existingActiveShift.EmployeeId,
                ShiftType = _existingActiveShift.ShiftType,
                StartTime = _existingActiveShift.StartTime,
                EndTime = _existingActiveShift.EndTime,
                EffectiveFrom = _existingActiveShift.EffectiveFrom,
                EffectiveTo = closeDate
            };
            var auth = await AuthState.GetAuthenticationStateAsync();
            var res = await ShiftService.UpdateShiftAsync(
                _existingActiveShift.EmployeeShiftId,
                old,
                auth.User.Identity?.Name ?? "System");

            if (!res.Success)
            {
                Snackbar.Add($"فشل إغلاق القديم: {res.Message}", Severity.Error);
                return;
            }
            Snackbar.Add("تم إغلاق الشيفت القديم", Severity.Info);
        }

        await ExecuteSave();
    }

    private async Task ExecuteSave()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var user = auth.User.Identity?.Name ?? "System";

            if (_isEdit)
            {
                var r = await ShiftService.UpdateShiftAsync(ShiftId, _form, user);
                HandleResult(r);
            }
            else
            {
                var dto = new AddEmployeeShiftDto
                {
                    EmployeeId = _selectedEmployee?.EmployeeId,
                    BiometricCode = _form.BiometricCode ?? _selectedEmployee?.BiometricCode,
                    ShiftType = _form.ShiftType,
                    StartTime = _form.StartTime,
                    EndTime = _form.EndTime,
                    EffectiveFrom = _form.EffectiveFrom,
                    EffectiveTo = _form.EffectiveTo,
                    OffDay1 = _form.OffDay1,
                    OffDay2 = _form.OffDay2
                };
                var r = await ShiftService.AddShiftAsync(dto, user);
                HandleResult(r);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void HandleResult((bool Success, string Message) r)
    {
        if (r.Success)
        {
            Snackbar.Add(r.Message, Severity.Success);
            Nav.NavigateTo("/shifts");
        }
        else
        {
            Snackbar.Add(r.Message, Severity.Error);
        }
    }

    private void Cancel() => Nav.NavigateTo("/shifts");
}