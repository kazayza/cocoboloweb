                                                           @bind-Time="_startTimeSpan"
                                                           AmPm="false" Editable="true"
                                                           ReadOnly="true"
                                                           Variant="Variant.Outlined" Margin="Margin.Dense"
                                                           Adornment="Adornment.Start"
                                                           AdornmentIcon="@Icons.Material.Filled.Login"
                                                           AdornmentColor="Color.Success" />
                                        </MudItem>
                                        <MudItem xs="6" md="4">
                                            <MudTimePicker Label="وقت الانتهاء"
                                                           @bind-Time="_endTimeSpan"
                                                           AmPm="false" Editable="true"
                                                           ReadOnly="true"
                                                           Variant="Variant.Outlined" Margin="Margin.Dense"
                                                           Adornment="Adornment.Start"
                                                           AdornmentIcon="@Icons.Material.Filled.Logout"
                                                           AdornmentColor="Color.Error" />
                                        </MudItem>
                                        <MudItem xs="12" md="4">
                                            <div class="info-box info-box-success" style="height:100%;display:flex;align-items:center;">
                                                <MudIcon Icon="@Icons.Material.Filled.Timer" Style="color:#059669;" Size="Size.Small" />
                                                <MudText Style="color:#065F46;font-weight:700;">المدة: @CalculateDuration()</MudText>
                                            </div>
                                        </MudItem>
                                    </MudGrid>

                                    @* Time Bar *@
                                    <div class="time-bar-wrap">
                                        <div class="time-bar-track">
