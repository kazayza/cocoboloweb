                            @* ──── 3: أيام الراحة ──── *@
                            <MudPaper Class="pa-5 mb-4 sf-section" Elevation="0">
                                <div class="sf-sec-head">
                                    <div class="sf-sec-num" style="background:#10B981;">3</div>
                                    <div class="sf-sec-icon" style="background:#F0FDF4;">
