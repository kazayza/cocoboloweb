                                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="color:white;font-size:14px;" />
                                                </div>
                                            }

                                            <span class="shift-card-badge">شيفت مسائى</span>

                                            <div class="shift-card-head">
                                                <div class="shift-card-title-wrap">
                                                    <div class="shift-card-name" style="color:#5B21B6;">مسائي</div>
                                                    <div class="shift-card-desc">مثالي للشيفتات المسائية وخدمات المتابعة خارج ساعات النهار</div>
                                                </div>
                                                <div class="shift-card-icon" style="background:#EDE9FE;">
                                                    <MudIcon Icon="@Icons.Material.Filled.NightsStay" Style="color:#8B5CF6;font-size:32px;" />
                                                </div>
                                            </div>

                                            <div class="shift-card-time">2:00 م — 10:00 م</div>

                                            <div class="shift-card-meta">
                                                <div class="shift-card-meta-item">
                                                    <span class="shift-card-meta-label">المدة</span>
                                                    <span class="shift-card-meta-value">8 ساعات</span>
                                                </div>
                                                <div class="shift-card-meta-item">
                                                    <span class="shift-card-meta-label">النمط</span>
                                                    <span class="shift-card-meta-value">شيفت مسائى</span>
                                                </div>
                                            </div>
                                        </div>
                                    </MudItem>
                                </MudGrid>

                                @* أوقات الشيفت — ReadOnly *@
                                @if (!string.IsNullOrEmpty(_form.ShiftType))
                                {
                                    <MudGrid Spacing="3" Class="mb-3">
                                        <MudItem xs="6" md="4">
