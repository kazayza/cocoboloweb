private static string GetOffDayName(byte? day) => day switch
{
    0 => "الأحد",
    1 => "الاثنين",
    2 => "الثلاثاء",
    3 => "الأربعاء",
    4 => "الخميس",
    5 => "الجمعة",
    6 => "السبت",
    _ => ""
};

// ── Helper: احسب أيام العمل في الشهر الحالي للمعاينة ───────
private int CalculateWorkDays()
{
    var offDays = new List<DayOfWeek>();
    if (_form.OffDay1.HasValue) offDays.Add((DayOfWeek)_form.OffDay1.Value);
    if (_form.OffDay2.HasValue) offDays.Add((DayOfWeek)_form.OffDay2.Value);

    var now = DateTime.Today;
    int total = DateTime.DaysInMonth(now.Year, now.Month);
    int count = 0;
    for (int i = 1; i <= total; i++)
    {
        var dow = new DateTime(now.Year, now.Month, i).DayOfWeek;
        if (!offDays.Contains(dow)) count++;
    }
    return count;
}

