                            </MudPaper>

                            @* ──── 4: الفترة ──── *@
                            <MudPaper Class="pa-5 mb-4 sf-section" Elevation="0">
                                <div class="sf-sec-head">
                                    <div class="sf-sec-num" style="background:#3B82F6;">4</div>
                                    <div class="sf-sec-icon" style="background:#EFF6FF;">
                                        <MudIcon Icon="@Icons.Material.Filled.DateRange" Style="color:#3B82F6;font-size:18px;" />
                                    </div>
                                    <span class="sf-sec-title">فترة سريان الشيفت</span>
                                </div>

                                <MudGrid Spacing="3">
                                    <MudItem xs="12" md="5">
