@page "/shifts/new"
@page "/shifts/edit/{ShiftId:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject IEmployeeShiftService ShiftService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState

<PageTitle>@(_isEdit ? "تعديل الشيفت" : "إضافة شيفت جديد")</PageTitle>

<AuthorizeView>
    <Authorized Context="authCtx">
        @if (!_hasPermission)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
                <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius: 20px;">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" 
                             Style="font-size: 64px; color: #EF5350;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Color="Color.Error" Class="mb-2">غير مصرح</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                        ليس لديك صلاحية الوصول لهذه الصفحة
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="@(() => Nav.NavigateTo("/shifts"))">
                        العودة للقائمة
                    </MudButton>
                </MudPaper>
            </MudContainer>
        }
        else if (_isLoading)
        {
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
                <MudPaper Class="pa-8" Elevation="3" Style="border-radius: 20px;">
                    <div class="d-flex flex-column align-center gap-4">
                        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">جاري تحميل البيانات...</MudText>
                    </div>
                </MudPaper>
            </MudContainer>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
                
                @* ═══════════════ HEADER ═══════════════ *@
                <MudPaper Class="mb-4 overflow-hidden" Elevation="0" 
                          Style="border-radius: 20px; background: linear-gradient(135deg, #0d1220 0%, #152033 50%, #1a2744 100%); box-shadow: 0 12px 35px rgba(21,32,51,.25);">
                    <div class="pa-5">
                        <div class="d-flex align-center justify-space-between flex-wrap gap-3">
                            <div class="d-flex align-center gap-3">
                                <MudAvatar Size="Size.Large" 
                                           Style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px);">
                                    <MudIcon Icon="@(_isEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" 
                                             Size="Size.Medium" Color="Color.Surface" />
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">
                                        @(_isEdit ? "تعديل الشيفت" : "إضافة شيفت جديد")
                                    </MudText>
                                    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.7);">
                                        @if (_selectedEmployee != null)
                                        {
                                            <span>@_selectedEmployee.FullName</span>
                                            @if (!string.IsNullOrEmpty(_selectedEmployee.Department))
                                            {
                                                <span> • @_selectedEmployee.Department</span>
                                            }
                                        }
                                        else
                                        {
                                            <span>اختر الموظف لتعيين الشيفت</span>
                                        }
                                    </MudText>
                                </div>
                            </div>
                            
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Dark"
                                       StartIcon="@Icons.Material.Filled.ArrowBack"
                                       OnClick="Cancel">
                                العودة للقائمة
                            </MudButton>
                        </div>
                    </div>
                    
                    @* Progress Steps *@
                    <div style="background: rgba(0,0,0,0.1); padding: 12px 20px;">
                        <div class="d-flex justify-center gap-8">
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Size="Size.Small" 
                                           Style="@(_selectedEmployee != null ? "background: #10b981;" : "background: rgba(255,255,255,0.3);")">
                                    @if (_selectedEmployee != null)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                    }
                                    else
                                    {
                                        <span style="font-size: 12px;">1</span>
                                    }
                                </MudAvatar>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.9);">الموظف</MudText>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Size="Size.Small" 
                                           Style="@(!string.IsNullOrEmpty(_form.ShiftType) ? "background: #10b981;" : "background: rgba(255,255,255,0.3);")">
                                    @if (!string.IsNullOrEmpty(_form.ShiftType))
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                    }
                                    else
                                    {
                                        <span style="font-size: 12px;">2</span>
                                    }
                                </MudAvatar>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.9);">الشيفت</MudText>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Size="Size.Small" 
                                           Style="@(_effectiveFrom.HasValue ? "background: #10b981;" : "background: rgba(255,255,255,0.3);")">
                                    @if (_effectiveFrom.HasValue)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                                    }
                                    else
                                    {
                                        <span style="font-size: 12px;">3</span>
                                    }
                                </MudAvatar>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.9);">الفترة</MudText>
                            </div>
                        </div>
                    </div>
                </MudPaper>

                <MudForm @ref="_formRef">
                    <MudGrid Spacing="4">
                        
                        @* ═══════════════ RIGHT COLUMN ═══════════════ *@
                        <MudItem xs="12" lg="8">
                            
                            @* === SECTION 1: الموظف === *@
                            <MudPaper Class="pa-5 mb-4" Elevation="2" Style="border-radius: 16px;">
                                <div class="d-flex align-center gap-2 mb-4">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                    </MudAvatar>
                                    <MudText Typo="Typo.h6" Color="Color.Primary">بيانات الموظف</MudText>
                                </div>

                                <MudGrid Spacing="3">
                                    <MudItem xs="12" md="6">
                                        <MudAutocomplete T="ShiftEmployeeLookupDto"
                                                         Label="الموظف"
                                                         Placeholder="ابحث باسم الموظف أو الرقم القومي..."
                                                         Value="_selectedEmployee"
                                                         ValueChanged="OnEmployeeSelected"
                                                         SearchFunc="@SearchEmployees"
                                                         ToStringFunc="@(e => e?.FullName ?? "")"
                                                         Disabled="_isEdit"
                                                         Required="true"
                                                         RequiredError="يرجى اختيار الموظف"
                                                         Clearable="true"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         ShowProgressIndicator="true"
                                                         MinCharacters="0"
                                                         DebounceInterval="300"
                                                         MaxItems="20">
                                            <ItemTemplate Context="empCtx">
                                                <div class="d-flex align-center gap-3 py-1">
                                                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                                                        @(empCtx.FullName.Length > 0 ? empCtx.FullName[0] : '?')
                                                    </MudAvatar>
                                                    <div>
                                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@empCtx.FullName</MudText>
                                                        <div class="d-flex align-center gap-2">
                                                            @if (!string.IsNullOrEmpty(empCtx.Department))
                                                            {
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@empCtx.Department</MudText>
                                                            }
                                                            @if (empCtx.BiometricCode.HasValue)
                                                            {
                                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info"
                                                                         Style="height: 18px; font-size: 10px;">
                                                                    كود: @empCtx.BiometricCode
                                                                </MudChip>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </ItemTemplate>
                                            <NoItemsTemplate>
                                                <div class="pa-3 text-center">
                                                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Secondary" />
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">لا توجد نتائج</MudText>
                                                </div>
                                            </NoItemsTemplate>
                                        </MudAutocomplete>
                                    </MudItem>
                                    
                                    <MudItem xs="12" md="3">
                                        <MudNumericField T="int?"
                                                         Label="كود البصمة"
                                                         Value="_form.BiometricCode"
                                                         ValueChanged="@(v => _form.BiometricCode = v)"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense"
                                                         Min="0"
                                                         Adornment="Adornment.Start"
                                                         AdornmentIcon="@Icons.Material.Filled.Fingerprint" />
                                    </MudItem>
                                    
                                    <MudItem xs="12" md="3">
                                        @if (_selectedEmployee != null)
                                        {
                                            <MudPaper Class="pa-3 h-100 d-flex flex-column justify-center" 
                                                      Elevation="0" 
                                                      Style="background: linear-gradient(135deg, #E8EAF6, #C5CAE9); border-radius: 12px;">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">رقم الموظف</MudText>
                                                <MudText Typo="Typo.h5" Color="Color.Primary" Class="font-weight-bold">
                                                    #@_selectedEmployee.EmployeeId
                                                </MudText>
                                            </MudPaper>
                                        }
                                    </MudItem>
                                </MudGrid>

                                @* معلومات الموظف المختار *@
                                @if (_selectedEmployee != null)
                                {
                                    <MudPaper Class="pa-3 mt-4" Elevation="0" 
                                              Style="background: linear-gradient(135deg, #E3F2FD, #BBDEFB); border-radius: 12px; border-right: 4px solid #1976D2;">
                                        <div class="d-flex flex-wrap align-center gap-4">
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                                                <MudText Typo="Typo.body2" Class="font-weight-medium">@_selectedEmployee.FullName</MudText>
                                            </div>
                                            @if (!string.IsNullOrEmpty(_selectedEmployee.Department))
                                            {
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Color="Color.Secondary" />
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_selectedEmployee.Department</MudText>
                                                </div>
                                            }
                                            @if (_selectedEmployee.BiometricCode.HasValue)
                                            {
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small" Color="Color.Info" />
                                                    <MudText Typo="Typo.body2" Color="Color.Info">كود: @_selectedEmployee.BiometricCode</MudText>
                                                </div>
                                            }
                                        </div>
                                    </MudPaper>
                                }
                            </MudPaper>

                            @* === SECTION 2: الشيفت والأوقات === *@
                            <MudPaper Class="pa-5 mb-4" Elevation="2" Style="border-radius: 16px;">
                                <div class="d-flex align-center gap-2 mb-4">
                                    <MudAvatar Size="Size.Small" Color="Color.Warning">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                                    </MudAvatar>
                                    <MudText Typo="Typo.h6" Color="Color.Primary">نوع الشيفت والأوقات</MudText>
                                </div>

                                <MudGrid Spacing="3">
                                    @* Shift Type Cards - صباحي ومسائي فقط *@
                                    <MudItem xs="6" md="3">
                                        <MudPaper Class="pa-3 cursor-pointer h-100" 
                                                  Elevation="@(_form.ShiftType == ShiftTypes.Morning ? 4 : 1)"
                                                  Style="@GetShiftCardStyle(ShiftTypes.Morning)"
                                                  @onclick="@(() => OnShiftTypeChanged(ShiftTypes.Morning))">
                                            <div class="d-flex align-center gap-3">
                                                <MudAvatar Size="Size.Medium" 
                                                           Style="@(_form.ShiftType == ShiftTypes.Morning ? "background: #FFC107; color: white;" : "background: #FFF8E1; color: #FFC107;")">
                                                    <MudIcon Icon="@Icons.Material.Filled.WbSunny" Size="Size.Small" />
                                                </MudAvatar>
                                                <div>
                                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@ShiftTypes.Morning</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">10:00 - 18:00</MudText>
                                                </div>
                                                @if (_form.ShiftType == ShiftTypes.Morning)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                                }
                                            </div>
                                        </MudPaper>
                                    </MudItem>
                                    
                                    <MudItem xs="6" md="3">
                                        <MudPaper Class="pa-3 cursor-pointer h-100" 
                                                  Elevation="@(_form.ShiftType == ShiftTypes.Evening ? 4 : 1)"
                                                  Style="@GetShiftCardStyle(ShiftTypes.Evening)"
                                                  @onclick="@(() => OnShiftTypeChanged(ShiftTypes.Evening))">
                                            <div class="d-flex align-center gap-3">
                                                <MudAvatar Size="Size.Medium" 
                                                           Style="@(_form.ShiftType == ShiftTypes.Evening ? "background: #9C27B0; color: white;" : "background: #F3E5F5; color: #9C27B0;")">
                                                    <MudIcon Icon="@Icons.Material.Filled.NightsStay" Size="Size.Small" />
                                                </MudAvatar>
                                                <div>
                                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@ShiftTypes.Evening</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">14:00 - 22:00</MudText>
                                                </div>
                                                @if (_form.ShiftType == ShiftTypes.Evening)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                                }
                                            </div>
                                        </MudPaper>
                                    </MudItem>

                                    @* أوقات الشيفت *@
                                    <MudItem xs="6" md="2">
                                        <MudTimePicker Label="وقت البدء"
                                                       @bind-Time="_startTimeSpan"
                                                       AmPm="false"
                                                       Editable="true"
                                                       Required="true"
                                                       RequiredError="مطلوب"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Adornment="Adornment.Start"
                                                       AdornmentIcon="@Icons.Material.Filled.Login"
                                                       AdornmentColor="Color.Success" />
                                    </MudItem>
                                    
                                    <MudItem xs="6" md="2">
                                        <MudTimePicker Label="وقت الانتهاء"
                                                       @bind-Time="_endTimeSpan"
                                                       AmPm="false"
                                                       Editable="true"
                                                       Required="true"
                                                       RequiredError="مطلوب"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Adornment="Adornment.Start"
                                                       AdornmentIcon="@Icons.Material.Filled.Logout"
                                                       AdornmentColor="Color.Error" />
                                    </MudItem>
                                    
                                    <MudItem xs="12" md="2">
                                        <MudPaper Class="pa-2 h-100 d-flex align-center" Elevation="0" 
                                                  Style="background: linear-gradient(135deg, #E8F5E9, #C8E6C9); border-radius: 12px;">
                                            <div class="d-flex align-center gap-2">
                                                <MudIcon Icon="@Icons.Material.Filled.Timer" Color="Color.Success" Size="Size.Small" />
                                                <div>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">المدة</MudText>
                                                    <MudText Typo="Typo.subtitle2" Color="Color.Success" Class="font-weight-bold">
                                                        @CalculateDuration()
                                                    </MudText>
                                                </div>
                                            </div>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>

                                @* Visual Time Bar *@
                                <MudPaper Class="pa-3 mt-4" Elevation="0" Style="background: var(--mud-palette-background-grey); border-radius: 12px;">
                                    <div class="d-flex align-center justify-space-between mb-2">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">00:00</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">06:00</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">12:00</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">18:00</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">24:00</MudText>
                                    </div>
                                    <div style="position: relative; height: 20px; background: var(--mud-palette-grey-lighter); border-radius: 10px; overflow: hidden;">
                                        <div style="@GetTimeBarStyle()"></div>
                                    </div>
                                    <div class="d-flex justify-center mt-2">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" 
                                                 Color="@(_form.ShiftType == ShiftTypes.Morning ? Color.Warning : Color.Secondary)">
                                            @(_startTimeSpan.HasValue ? $"{_startTimeSpan.Value:hh\\:mm}" : "--:--")
                                            ➜
                                            @(_endTimeSpan.HasValue ? $"{_endTimeSpan.Value:hh\\:mm}" : "--:--")
                                        </MudChip>
                                    </div>
                                </MudPaper>
                            </MudPaper>
                            @* === SECTION 2.5: يومي الراحة الأسبوعية === *@
<MudCard Elevation="2" Class="mb-4" Style="border-radius:12px;">
    <MudCardContent Class="pa-4">

        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Rounded.EventAvailable"
                     Style="color:#D4AF37;" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">
                أيام الراحة الأسبوعية
            </MudText>
        </MudStack>

        <MudAlert Severity="Severity.Info" Dense Class="mb-3">
            حدد يومي الراحة الأسبوعية للموظف — هيأثر مباشرة على حساب الراتب
        </MudAlert>

        @* اختيار اليومين *@
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="byte?"
                           @bind-Value="_form.OffDay1"
                           Label="يوم الراحة الأول"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           AdornmentIcon="@Icons.Material.Rounded.WbSunny"
                           Adornment="Adornment.Start"
                           AdornmentColor="Color.Warning"
                           Clearable>
                    <MudSelectItem T="byte?" Value="@((byte?)0)">الأحد</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)1)">الاثنين</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)2)">الثلاثاء</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)3)">الأربعاء</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)4)">الخميس</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)5)">الجمعة</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)6)">السبت</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="byte?"
                           @bind-Value="_form.OffDay2"
                           Label="يوم الراحة الثاني"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           AdornmentIcon="@Icons.Material.Rounded.NightlightRound"
                           Adornment="Adornment.Start"
                           AdornmentColor="Color.Secondary"
                           Clearable>
                    <MudSelectItem T="byte?" Value="@((byte?)0)">الأحد</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)1)">الاثنين</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)2)">الثلاثاء</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)3)">الأربعاء</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)4)">الخميس</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)5)">الجمعة</MudSelectItem>
                    <MudSelectItem T="byte?" Value="@((byte?)6)">السبت</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>

        @* معاينة أيام العمل *@
        @if (_form.OffDay1.HasValue || _form.OffDay2.HasValue)
        {
            <MudPaper Elevation="0" Class="mt-3 pa-3"
                      Style="background:#F0FDF4; border-radius:8px; border:1px solid #86EFAC;">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Rounded.CheckCircle"
                             Style="color:#10B981;" Size="Size.Small" />
                    <MudText Typo="Typo.body2">
                        <strong>أيام الراحة:</strong>
                        @GetOffDayName(_form.OffDay1)
                        @if (_form.OffDay2.HasValue)
                        { <span> و @GetOffDayName(_form.OffDay2)</span> }
                        &nbsp;|&nbsp;
                        <strong>أيام العمل في الشهر الحالي: ~@CalculateWorkDays() يوم</strong>
                    </MudText>
                </MudStack>
            </MudPaper>
        }

    </MudCardContent>
</MudCard>

                            @* === SECTION 3: الفترة === *@
                            <MudPaper Class="pa-5 mb-4" Elevation="2" Style="border-radius: 16px;">
                                <div class="d-flex align-center gap-2 mb-4">
                                    <MudAvatar Size="Size.Small" Color="Color.Info">
                                        <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" />
                                    </MudAvatar>
                                    <MudText Typo="Typo.h6" Color="Color.Primary">فترة الشيفت</MudText>
                                </div>

                                <MudGrid Spacing="3">
                                    <MudItem xs="12" md="4">
                                        <MudDatePicker Label="تاريخ البدء"
                                                       @bind-Date="_effectiveFrom"
                                                       Editable="true"
                                                       Required="true"
                                                       RequiredError="مطلوب"
                                                       DateFormat="yyyy/MM/dd"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Adornment="Adornment.Start"
                                                       AdornmentIcon="@Icons.Material.Filled.Today"
                                                       AdornmentColor="Color.Primary" />
                                    </MudItem>
                                    
                                    <MudItem xs="12" md="4">
                                        <MudDatePicker Label="تاريخ الانتهاء (اختياري)"
                                                       @bind-Date="_effectiveTo"
                                                       Editable="true"
                                                       Clearable="true"
                                                       DateFormat="yyyy/MM/dd"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Placeholder="مستمر"
                                                       Adornment="Adornment.Start"
                                                       AdornmentIcon="@Icons.Material.Filled.Event"
                                                       AdornmentColor="Color.Secondary" />
                                    </MudItem>
                                    
                                    <MudItem xs="12" md="4">
                                        <MudPaper Class="pa-3 h-100 d-flex align-center justify-center" 
                                                  Elevation="0" 
                                                  Style="@GetStatusCardStyle()">
                                            @if (IsActiveShift)
                                            {
                                                <div class="d-flex align-center gap-2">
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
