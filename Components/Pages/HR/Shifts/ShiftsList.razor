@page "/shifts"
@using COCOBOLOERPNEW.Components.Pages.HR.Shifts.ShiftsComponents

<PageTitle>متابعة وجدولة الشيفتات — COCOBOLO ERP</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (!_hasViewPermission)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4" Style="border-radius:12px;">
                <MudText Typo="Typo.body1">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Class="ml-2" />
                    ليس لديك صلاحية الوصول لهذه الصفحة
                </MudText>
            </MudAlert>
        }
        else
        {
            <div dir="rtl" class="shifts-list-page animate-card">
                
                @* ═══════════════ HEADER SECTION (WIDE & IMMERSIVE ERP STYLE) ═══════════════ *@
                <div class="page-header">
                    <div class="header-overlay"></div>
                    <div class="header-content">
                        <div class="header-info">
                            <div class="header-badge">
                                <MudIcon Icon="@Icons.Material.Rounded.Schedule" />
                            </div>
                            <div>
                                <h1>@(_canSeeAllShifts ? "إدارة وجدولة الشيفتات" : "جدول شيفتاتي المعتمدة")</h1>
                                <p>@(_canSeeAllShifts ? "شاشة الإدارة العامة لمتابعة وتوزيع شيفتات الموظفين والورديات" : "الملف الشخصي لمتابعة وردياتك وساعات حضورك الرسمية المعينة من الإدارة")</p>
                            </div>
                        </div>

                        @* Action Buttons (Hides completely for regular employees) *@
                        @if (_canSeeAllShifts)
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @if (_hasAddPermission)
                                {
                                    <MudButton Variant="Variant.Filled" 
                                               OnClick="NavigateToAdd"
                                               StartIcon="@Icons.Material.Filled.Add"
                                               Class="add-btn">
                                        إضافة شيفت جديد
                                    </MudButton>
                                }
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" 
                                         Color="Color.Surface"
                                         AnchorOrigin="Origin.BottomRight" 
                                         TransformOrigin="Origin.TopRight">
                                    <MudMenuItem Icon="@Icons.Material.Filled.FileDownload" 
                                                 OnClick="ExportExcel"
                                                 Disabled="_isExporting">
                                        @(_isExporting ? "جاري التصدير..." : "تصدير Excel")
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.FileUpload" 
                                                 OnClick="OpenImportDialog">
                                        استيراد Excel
                                    </MudMenuItem>
                                    <MudDivider />
                                    <MudMenuItem Icon="@Icons.Material.Filled.Description" 
                                                 OnClick="DownloadTemplate">
                                        تحميل قالب الاستيراد
                                    </MudMenuItem>
                                </MudMenu>
                            </div>
                        }
                        else
                        {
                            <div class="header-user-badge">
                                <MudIcon Icon="@Icons.Material.Rounded.VerifiedUser" Size="Size.Small" />
                                <span>جدول الموظف الموثق: <strong>@_userName</strong></span>
                            </div>
                        }
                    </div>

                    @* Stats Cards (Only visible for managers/accountants) *@
                    @if (_canSeeAllShifts)
                    {
                        <ShiftStatsCards TotalCount="_totalCount"
                                         ActiveCount="_activeCount"
                                         MorningCount="_morningCount"
                                         EveningCount="_eveningCount"
                                         DailyCount="_dailyCount"
                                         IsLoading="_isLoadingStats" />
                    }
                </div>

                @* ═══════════════ FILTERS SECTION (Only visible for managers) ═══════════════ *@
                @if (_canSeeAllShifts)
                {
                    <div class="filters-wrap">
                        <ShiftFilters Filter="_filter"
                                      OnSearch="ApplyFilter"
                                      OnReset="ResetFilters" />
                    </div>
                }

                @* ═══════════════ DATA GRID SECTION ═══════════════ *@
                <div class="table-card">
                    <div class="table-card-header">
                        <div class="tch-left">
                            <div class="tch-icon">
                                <MudIcon Icon="@Icons.Material.Rounded.Badge" />
                            </div>
                            <div>
                                <h3>@(_canSeeAllShifts ? "قائمة شيفتات الموظفين" : "سجل حركات وردياتي")</h3>
                                <p>@(_canSeeAllShifts ? "استعراض ومتابعة الشيفتات النشطة لجميع موظفي الأقسام" : "استعراض وتفاصيل شيفتاتك ووردياتك الحالية والسابقة")</p>
                            </div>
                        </div>
                        <div class="tch-right">
                            <span class="days-count-badge">
                                @_totalCount شيفت مسجل
                            </span>
                        </div>
                    </div>

                    <ShiftDataGrid Shifts="_shifts"
                                   IsLoading="_isLoadingData"
                                   TotalCount="_totalCount"
                                   CurrentPage="_currentPage"
                                   TotalPages="_totalPages"
                                   HasPrevious="_hasPrevious"
                                   HasNext="_hasNext"
                                   HasEditPermission="_hasEditPermission"
                                   HasDeletePermission="_hasDeletePermission"
                                   OnEdit="NavigateToEdit"
                                   OnDelete="ConfirmDelete"
                                   OnPageChanged="OnPageChanged"
                                   OnPageSizeChanged="OnPageSizeChanged"
                                   SelectedShifts="_selectedShifts"
                                   OnSelectionChanged="OnSelectionChanged" />
                </div>

            </div>

            @* ═══════════════ DIALOGS (Managers Only) ═══════════════ *@
            @if (_canSeeAllShifts)
            {
                <ShiftImportDialog @bind-Visible="_showImportDialog"
                                   OnImportCompleted="OnImportCompleted" />

                <ShiftDeleteDialog @bind-Visible="_showDeleteDialog"
                                   ShiftToDelete="_shiftToDelete"
                                   OnConfirmDelete="DeleteShift"
                                   IsDeleting="_isDeleting" />
            }
        }
    </Authorized>
    <NotAuthorized>
        <div class="not-auth-screen animate-card">
            <div class="na-card">
                <div class="na-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Rounded.Lock" Size="Size.Large" />
                </div>
                <h3>تسجيل الدخول مطلوب</h3>
                <p>يرجى تسجيل الدخول إلى حسابك لتتمكن من تصفح ومتابعة حركات البصمة والشيفتات والرواتب المخصصة لك.</p>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Login" OnClick='() => Nav.NavigateTo("/login")'>تسجيل الدخول</MudButton>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    :root {
        --hdr-gradient: linear-gradient(135deg, #0d1220 0%, #152033 50%, #1a2744 100%);
    }

    .shifts-list-page {
        padding: 0 1.5rem 3rem;
        max-width: 1300px;
        margin: 0 auto;
        direction: rti;
    }

    /* ===== Page Header (Wide & Immersive ERP Style) ===== */
    .page-header {
        position: relative;
        background: var(--hdr-gradient);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        overflow: hidden;
        box-shadow: 0 12px 35px rgba(21,32,51,.25);
    }

    .header-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d4af37' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }

    .header-content {
        position: relative;
        display: flex;
        align-items: center;
        justify-space-between: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 1rem;
        z-index: 2;
    }

    .header-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-badge {
        width: 54px;
        height: 54px;
        background: linear-gradient(135deg, #d4af37, #f0d060);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a2842;
        font-size: 1.6rem;
        box-shadow: 0 4px 15px rgba(212,175,55,0.4);
    }

    .header-info h1 {
        color: white;
        font-size: 1.7rem;
        font-weight: 900;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .header-info p {
        color: rgba(255,255,255,0.7);
        margin: 0.25rem 0 0 0;
        font-size: 0.88rem;
    }

    .header-user-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.18);
        padding: 6px 14px;
        border-radius: 20px;
        color: white;
        font-size: 0.8rem;
    }
    .header-user-badge strong { color: #ffd966; }

    .add-btn {
        background: linear-gradient(135deg, #d4af37, #f0d060) !important;
        color: #1a2842 !important;
        font-weight: 700 !important;
        border-radius: 12px !important;
        box-shadow: 0 4px 20px rgba(212,175,55,0.4) !important;
        transition: all 0.3s ease !important;
    }
    .add-btn:hover {
        transform: translateY(-2px) !important;
        box-shadow: 0 8px 25px rgba(212,175,55,0.5) !important;
    }

    /* ===== Filters ===== */
    .filters-wrap {
        margin-bottom: 1.25rem;
    }

    /* ===== Table Card ===== */
    .table-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        margin-top: 1rem;
    }
    .table-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem;
        background: var(--mud-palette-background);
        border-bottom: 1px solid var(--mud-palette-lines-default);
        flex-wrap: wrap;
        gap: 1rem;
    }
    .tch-left { display: flex; align-items: center; gap: 0.75rem; }
    .tch-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(212,175,55,0.1);
        color: var(--gold-dark, #b8860b);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .tch-left h3 { margin: 0; font-size: 1rem; font-weight: 800; color: var(--mud-palette-text-primary); }
    .tch-left p { margin: 2px 0 0; font-size: 0.75rem; color: var(--mud-palette-text-secondary); }
    .days-count-badge {
        font-size: 0.72rem;
        font-weight: 700;
        padding: 4px 12px;
        background: rgba(212,175,55,0.15);
        color: var(--gold-dark);
        border-radius: 20px;
        border: 1px solid rgba(212,175,55,0.3);
    }

    /* ═══ NOT AUTHORIZED SCREEN ═══ */
    .not-auth-screen {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding: 1.5rem;
    }
    .na-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 20px;
        padding: 3rem 2rem;
        max-width: 450px;
        width: 100%;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }
    .na-icon-wrap {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: rgba(245,158,11,0.1);
        color: #f59e0b;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
        border: 2px solid rgba(245,158,11,0.25);
    }
    .na-card h3 { margin: 0 0 0.5rem; font-size: 1.25rem; font-weight: 800; color: var(--mud-palette-text-primary); }
    .na-card p { margin: 0 0 1.5rem; font-size: 0.88rem; color: var(--mud-palette-text-secondary); line-height: 1.6; }

    /* ═══ RESPONSIVE ═══ */
    @@media (max-width: 960px) {
        .shifts-list-page { padding: 0 1rem 2rem; }
        .page-header { padding: 1.25rem; }
        .header-info h1 { font-size: 1.35rem; }
    }
    @@media (max-width: 600px) {
        .header-content { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
        .header-user-badge { width: 100%; justify-content: center; }
    }
</style>
