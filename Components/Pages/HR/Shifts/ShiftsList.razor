@page "/shifts"
@using COCOBOLOERPNEW.Components.Pages.HR.Shifts.ShiftsComponents

<PageTitle>متابعة وجدولة الشيفتات — COCOBOLO ERP</PageTitle>

<AuthorizeView>
    <Authorized>
        @if (!_hasViewPermission)
        {
            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
                <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius:20px;">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Style="font-size:64px; color:#EF5350;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Color="Color.Error" Class="mb-2">غير مصرح</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">
                        ليس لديك صلاحية الوصول إلى شاشة الشيفتات
                    </MudText>
                </MudPaper>
            </MudContainer>
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4 hr-page-shell shifts-page-v2">

                @* ================= HERO ================= *@
                <MudPaper Class="shifts-hero mb-4" Elevation="0">
                    <div class="shifts-hero__content">
                        <div class="shifts-hero__headline">
                            <MudAvatar Size="Size.Large" Class="shifts-hero__avatar">
                                <MudIcon Icon="@Icons.Material.Rounded.Schedule" Size="Size.Medium" Color="Color.Surface" />
                            </MudAvatar>
                            <div>
                                <div class="section-header-chip mb-2">
                                    <MudIcon Icon="@Icons.Material.Rounded.Timeline" Size="Size.Small" />
                                    Shift Operations Center
                                </div>
                                <MudText Typo="Typo.h4" Color="Color.Surface" Class="font-weight-bold mb-1">
                                    @(_canSeeAllShifts ? "إدارة وجدولة الشيفتات" : "جدول شيفتاتي المعتمدة")
                                </MudText>
                                <MudText Typo="Typo.body2" Class="shifts-hero__subtitle">
                                    @(_canSeeAllShifts
                                        ? "متابعة الشيفتات النشطة والمنتهية وربطها بالحضور اليومي والتعديلات والعمليات الجماعية."
                                        : "استعراض وردياتك الحالية والسابقة ومتابعة وضعك التشغيلي المعتمد من الإدارة.")
                                </MudText>
                            </div>
                        </div>

                        <div class="shifts-hero__actions">
                            @if (_canSeeAllShifts && _hasAddPermission)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="NavigateToAdd"
                                           Class="shifts-action shifts-action--primary">
                                    إضافة شيفت جديد
                                </MudButton>
                            }

                            @if (_canOpenAttendance)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           StartIcon="@Icons.Material.Filled.Fingerprint"
                                           Href="/attendance"
                                           Class="shifts-action">
                                    الحضور
                                </MudButton>
                            }

                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Color="Color.Surface"
                                           Class="shifts-action-icon"
                                           OnClick="RefreshView"
                                           Title="تحديث البيانات" />

                            @if (_canSeeAllShifts)
                            {
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                         Color="Color.Surface"
                                         Class="shifts-more-menu"
                                         AnchorOrigin="Origin.BottomRight"
                                         TransformOrigin="Origin.TopRight">
                                    <MudMenuItem Icon="@Icons.Material.Filled.FileDownload"
                                                 OnClick="ExportExcel"
                                                 Disabled="_isExporting">
                                        @(_isExporting ? "جاري التصدير..." : "تصدير Excel")
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.FileUpload"
                                                 OnClick="OpenImportDialog">
                                        استيراد Excel
                                    </MudMenuItem>
                                    <MudDivider />
                                    <MudMenuItem Icon="@Icons.Material.Filled.Description"
                                                 OnClick="DownloadTemplate">
                                        تحميل قالب الاستيراد
                                    </MudMenuItem>
                                </MudMenu>
                            }
                        </div>
                    </div>

                    @if (_canSeeAllShifts)
                    {
                        <ShiftStatsCards TotalCount="_totalCount"
                                         ActiveCount="_activeCount"
                                         MorningCount="_morningCount"
                                         EveningCount="_eveningCount"
                                         DailyCount="_dailyCount"
                                         IsLoading="_isLoadingStats" />
                    }
                    else
                    {
                        <div class="pa-4 pt-0">
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Surface" Size="Size.Small">
                                الموظف الحالي: @_userName
                            </MudChip>
                        </div>
                    }
                </MudPaper>

                @* ================= CONTEXT BAR ================= *@
                <MudPaper Class="shifts-context-bar mb-3" Elevation="1">
                    <div class="shifts-context-bar__wrap">
                        <div class="shifts-context-bar__group">
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                                @CurrentScopeLabel
                            </MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small">
                                @CurrentRangeLabel
                            </MudChip>
                            @if (_canSeeAllShifts && ActiveFiltersCount > 0)
                            {
                                <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small">
                                    @ActiveFiltersCount فلتر نشط
                                </MudChip>
                            }
                        </div>

                        <div class="shifts-context-bar__meta">
                            <span>عرض <strong>@FromRecord</strong> - <strong>@ToRecord</strong> من <strong>@_totalCount</strong></span>
                        </div>
                    </div>
                </MudPaper>

                @* ================= FILTERS ================= *@
                @if (_canSeeAllShifts)
                {
                    <div class="sticky-filter-shell">
                        <ShiftFilters Filter="_filter"
                                      OnSearch="ApplyFilter"
                                      OnReset="ResetFilters" />
                    </div>
                }

                @* ================= SUMMARY STRIP ================= *@
                <MudPaper Class="shifts-summary-strip mb-3" Elevation="1">
                    <div class="shifts-summary-strip__grid">
                        <div class="shifts-summary-tile">
                            <span class="shifts-summary-tile__label">نشطة</span>
                            <strong class="shifts-summary-tile__value text-success">@SummaryActiveCount</strong>
                        </div>
                        <div class="shifts-summary-tile">
                            <span class="shifts-summary-tile__label">صباحي</span>
                            <strong class="shifts-summary-tile__value text-warning">@SummaryMorningCount</strong>
                        </div>
                        <div class="shifts-summary-tile">
                            <span class="shifts-summary-tile__label">مسائي</span>
                            <strong class="shifts-summary-tile__value text-secondary-v2">@SummaryEveningCount</strong>
                        </div>
                        <div class="shifts-summary-tile">
                            <span class="shifts-summary-tile__label">عمل يومي</span>
                            <strong class="shifts-summary-tile__value text-info">@SummaryDailyCount</strong>
                        </div>
                        <div class="shifts-summary-tile">
                            <span class="shifts-summary-tile__label">منتهية</span>
                            <strong class="shifts-summary-tile__value text-error">@SummaryEndedCount</strong>
                        </div>
                    </div>
                </MudPaper>

                @* ================= TABLE ================= *@
                <div class="table-card">
                    <div class="table-card-header">
                        <div class="tch-left">
                            <div class="tch-icon">
                                <MudIcon Icon="@Icons.Material.Rounded.Badge" />
                            </div>
                            <div>
                                <h3>@(_canSeeAllShifts ? "قائمة شيفتات الموظفين" : "سجل حركات وردياتي")</h3>
                                <p>@(_canSeeAllShifts ? "استعراض ومتابعة الشيفتات وربطها بالإدارة التشغيلية والحضور." : "استعراض وتفاصيل وردياتك الحالية والسابقة المعتمدة.")</p>
                            </div>
                        </div>
                        <div class="tch-right d-flex align-center gap-2 flex-wrap">
                            @if (_selectedShifts.Count > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                    @_selectedShifts.Count محدد
                                </MudChip>
                            }
                            <span class="days-count-badge">@_totalCount شيفت مسجل</span>
                        </div>
                    </div>

                    <ShiftDataGrid Shifts="_shifts"
                                   IsLoading="_isLoadingData"
                                   TotalCount="_totalCount"
                                   CurrentPage="_currentPage"
                                   TotalPages="_totalPages"
                                   HasPrevious="_hasPrevious"
                                   HasNext="_hasNext"
                                   HasEditPermission="_hasEditPermission"
                                   HasDeletePermission="_hasDeletePermission"
                                   OnEdit="NavigateToEdit"
                                   OnDelete="ConfirmDelete"
                                   OnPageChanged="OnPageChanged"
                                   OnPageSizeChanged="OnPageSizeChanged"
                                   SelectedShifts="_selectedShifts"
                                   OnSelectionChanged="OnSelectionChanged" />
                </div>

            </MudContainer>

            @if (_canSeeAllShifts)
            {
                <ShiftImportDialog @bind-Visible="_showImportDialog"
                                   OnImportCompleted="OnImportCompleted" />

                <ShiftDeleteDialog @bind-Visible="_showDeleteDialog"
                                   ShiftToDelete="_shiftToDelete"
                                   OnConfirmDelete="DeleteShift"
                                   IsDeleting="_isDeleting" />
            }
        }
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
            <MudPaper Class="pa-8 text-center" Elevation="3" Style="border-radius:20px;">
                <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Large" Style="font-size:64px; color:#FF9800;" Class="mb-4" />
                <MudText Typo="Typo.h5" Color="Color.Warning" Class="mb-2">تسجيل الدخول مطلوب</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                    يرجى تسجيل الدخول للوصول إلى شاشة الشيفتات
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login" OnClick='() => Nav.NavigateTo("/login")'>
                    تسجيل الدخول
                </MudButton>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

<style>
    .shifts-page-v2 {
        direction: rtl;
    }

    .shifts-hero {
        border-radius: 20px;
        overflow: hidden;
        background: linear-gradient(135deg, #0d1220 0%, #152033 50%, #1a2744 100%);
        box-shadow: 0 12px 35px rgba(21,32,51,.20);
        position: relative;
    }

    .shifts-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23d4af37' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        pointer-events: none;
    }

    .shifts-hero__content {
        position: relative;
        z-index: 1;
        padding: 1.35rem 1.5rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .shifts-hero__headline {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .shifts-hero__avatar {
        background: rgba(255,255,255,.16);
        backdrop-filter: blur(8px);
    }

    .shifts-hero__subtitle {
        color: rgba(255,255,255,.78);
        max-width: 760px;
    }

    .shifts-hero__actions {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .shifts-action {
        min-height: 44px;
        border-radius: 12px;
        padding-inline: 14px;
    }

    .shifts-action--primary {
        box-shadow: 0 10px 22px rgba(16, 185, 129, .25);
    }

    .shifts-action-icon {
        border: 1px solid rgba(255,255,255,.28);
        border-radius: 12px;
        background: rgba(255,255,255,.08);
    }

    .shifts-context-bar,
    .shifts-summary-strip {
        border-radius: 16px;
        border: 1px solid rgba(148,163,184,.18);
    }

    .shifts-context-bar__wrap {
        padding: .8rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .shifts-context-bar__group {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
    }

    .shifts-context-bar__meta {
        color: var(--mud-palette-text-secondary);
        font-size: .85rem;
    }

    .shifts-summary-strip__grid {
        padding: .85rem 1rem;
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: .75rem;
    }

    .shifts-summary-tile {
        background: rgba(148,163,184,.08);
        border-radius: 14px;
        padding: .75rem .85rem;
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

    .shifts-summary-tile__label {
        font-size: .78rem;
        color: var(--mud-palette-text-secondary);
    }

    .shifts-summary-tile__value {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--mud-palette-text-primary);
    }

    .text-success { color: #2E7D32; }
    .text-warning { color: #E65100; }
    .text-secondary-v2 { color: #7B1FA2; }
    .text-info { color: #1565C0; }
    .text-error { color: #C62828; }

    .table-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        margin-top: .25rem;
    }

    .table-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.1rem 1.25rem;
        background: var(--mud-palette-background);
        border-bottom: 1px solid var(--mud-palette-lines-default);
        flex-wrap: wrap;
        gap: 1rem;
    }

    .tch-left { display: flex; align-items: center; gap: .75rem; }

    .tch-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(212,175,55,0.1);
        color: #b8860b;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tch-left h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
        color: var(--mud-palette-text-primary);
    }

    .tch-left p {
        margin: 2px 0 0;
        font-size: .75rem;
        color: var(--mud-palette-text-secondary);
    }

    .days-count-badge {
        font-size: .72rem;
        font-weight: 700;
        padding: 4px 12px;
        background: rgba(212,175,55,0.15);
        color: #b8860b;
        border-radius: 20px;
        border: 1px solid rgba(212,175,55,0.3);
    }

    @@media (max-width: 1100px) {
        .shifts-summary-strip__grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 900px) {
        .shifts-context-bar__meta {
            width: 100%;
        }
    }

    @@media (max-width: 600px) {
        .shifts-hero__content {
            padding: 1rem 1rem .75rem;
        }

        .shifts-hero__headline {
            align-items: flex-start;
        }

        .shifts-hero__actions {
            width: 100%;
        }

        .shifts-action {
            flex: 1 1 calc(50% - .5rem);
        }

        .shifts-action-icon,
        .shifts-more-menu {
            flex: 1 1 calc(50% - .5rem);
        }

        .shifts-summary-strip__grid {
            grid-template-columns: 1fr 1fr;
            padding: .75rem;
        }
    }
</style>
