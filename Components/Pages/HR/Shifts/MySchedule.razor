@code {
    private bool _isLoading = true;
    private bool _hasPermission = false;
    private string _userName = "";
    private string? _currentEmployeeInfo;
    private List<EmployeeShiftListDto> _shifts = new();
    
    private EmployeeShiftListDto? CurrentShift => _shifts.FirstOrDefault(s => s.IsActive) ?? _shifts.OrderByDescending(s => s.EffectiveFrom).FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;

        _userName = user.Identity?.Name ?? "مستخدم";
        _hasPermission = user.IsInRole("Admin") || user.HasClaim("Permission", "frm_MySchedule:View");

        if (_hasPermission)
        {
            _shifts = await ShiftService.GetMyShiftsAsync(_userName);
            
            if (_shifts.Any())
            {
                var first = _shifts.First();
                _currentEmployeeInfo = first.Department;
            }
        }

        _isLoading = false;
    }

    #region Planner Logic (Day Off Detector)

    private class PlannerDayDto
    {
        public int DayIndex { get; set; }
        public string DayName { get; set; } = "";
        public string DateDisplay { get; set; } = "";
        public DateTime Date { get; set; }
    }

    private List<PlannerDayDto> GetWeeklyPlannerDays()
    {
        var days = new List<PlannerDayDto>();
        var names = new[] { "السبت", "الأحد", "الاثنين", "الثلاثاء", "الأربعاء", "الخميس", "الجمعة" };
        
        var today = DateTime.Today;
        int currentDayOfWeek = (int)today.DayOfWeek; // 0=Sunday, ..., 6=Saturday
        int diff = (currentDayOfWeek + 1) % 7; 
        var startOfWeek = today.AddDays(-diff);

        for (int i = 0; i < 7; i++)
        {
            var d = startOfWeek.AddDays(i);
            int actualDayOfWeek = (i + 6) % 7; // تحويل الفهرس ليتطابق مع الـ DayOfWeek الفعلي للويندوز (0=Sunday ... 6=Saturday)
            days.Add(new PlannerDayDto
            {
                DayIndex = actualDayOfWeek,
                DayName = names[i],
                DateDisplay = d.ToString("dd MMM"),
                Date = d
            });
        }
        return days;
    }

    private EmployeeShiftListDto? GetShiftForDay(DateTime date)
    {
        // البحث عن الشيفت الذي يغطي هذا التاريخ الفعلي بدقة
        return _shifts.FirstOrDefault(s => s.EffectiveFrom.Date <= date.Date && (!s.EffectiveTo.HasValue || s.EffectiveTo.Value.Date >= date.Date));
    }

    private bool IsDayOffForDate(DateTime date)
    {
        var shift = GetShiftForDay(date);
        if (shift == null) return false;
        
        int dayIndex = (int)date.DayOfWeek; // 0 = Sunday, 1 = Monday ... 6 = Saturday
        bool off1 = shift.OffDay1.HasValue && shift.OffDay1.Value == dayIndex;
        bool off2 = shift.OffDay2.HasValue && shift.OffDay2.Value == dayIndex;
        
        return off1 || off2;
    }

    private string GetShiftThemeColor(string shiftType) => shiftType switch
    {
        "صباحى" => "#FF9800",
        "مسائى" => "#9C27B0",
        _ => "#1A2842"
    };

    private string GetShiftEmoji(string shiftType) => shiftType switch
    {
        "صباحى" => "☀️",
        "مسائى" => "🌙",
        _ => "🏢"
    };

    #endregion

    #region UI Helpers

    private string GetShiftIcon(string shiftType) => shiftType switch
    {
        "صباحى" => Icons.Material.Filled.WbSunny,
        "مسائى" => Icons.Material.Filled.NightsStay,
        _ => Icons.Material.Filled.Schedule
    };

    private string GetShiftAvatarStyle(string shiftType) => shiftType switch
    {
        "صباحى" => "background: #FFF8E1; color: #F57C00;",
        "مسائى" => "background: #F3E5F5; color: #7B1FA2;",
        _ => "background: #EEEEEE; color: #616161;"
    };

    private string GetShiftGradient(string shiftType) => shiftType switch
    {
        "صباحى" => "linear-gradient(135deg, #FF8F00 0%, #FFA726 50%, #FFB74D 100%)",
        "مسائى" => "linear-gradient(135deg, #6A1B9A 0%, #8E24AA 50%, #AB47BC 100%)",
        _ => "linear-gradient(135deg, #37474F 0%, #546E7A 50%, #78909C 100%)"
    };

    private string GetTimeBarStyle(EmployeeShiftListDto shift)
    {
        var start = shift.StartTime.ToTimeSpan().TotalHours;
        var end = shift.EndTime.ToTimeSpan().TotalHours;
        
        var left = (start / 24.0) * 100;
        var width = end > start 
            ? ((end - start) / 24.0) * 100 
            : ((24 - start + end) / 24.0) * 100;

        var color = shift.ShiftType switch
        {
            "صباحى" => "#FFC107",
            "مسائى" => "#9C27B0",
            _ => "#9E9E9E"
        };

        return $"position: absolute; top: 0; bottom: 0; left: {left:F1}%; width: {width:F1}%; background: {color}; border-radius: 8px; opacity: 0.7;";
    }

    private string GetCurrentTimeIndicatorStyle()
    {
        var now = DateTime.Now.TimeOfDay.TotalHours;
        var left = (now / 24.0) * 100;
        
        return $"position: absolute; top: -4px; bottom: -4px; left: {left:F1}%; width: 3px; background: #F44336; border-radius: 2px; box-shadow: 0 0 4px rgba(244, 67, 54, 0.5);";
    }

    private string GetCurrentTimeStatus(EmployeeShiftListDto shift)
    {
        var now = DateTime.Now.TimeOfDay;
        var start = shift.StartTime.ToTimeSpan();
        var end = shift.EndTime.ToTimeSpan();

        // Handle overnight shifts
        bool isInShift;
        if (end > start)
        {
            isInShift = now >= start && now <= end;
        }
        else
        {
            isInShift = now >= start || now <= end;
        }

        if (isInShift)
        {
            TimeSpan remaining;
            if (end > start)
            {
                remaining = end - now;
            }
            else
            {
                remaining = now > start ? TimeSpan.FromHours(24) - now + end : end - now;
            }

            var hours = (int)remaining.TotalHours;
            var minutes = remaining.Minutes;

            if (hours > 0)
                return $"⏰ أنت الآن في الشيفت • متبقي {hours} ساعة و {minutes} دقيقة";
            else
                return $"⏰ أنت الآن في الشيفت • متبقي {minutes} دقيقة";
        }
        else if (now < start)
        {
            var until = start - now;
            var hours = (int)until.TotalHours;
            var minutes = until.Minutes;

            if (hours > 0)
                return $"🕐 الشيفت يبدأ بعد {hours} ساعة و {minutes} دقيقة";
            else
                return $"🕐 الشيفت يبدأ بعد {minutes} دقيقة";
        }
        else
        {
            return "✅ انتهى شيفت اليوم";
        }
    }

    #endregion
}
