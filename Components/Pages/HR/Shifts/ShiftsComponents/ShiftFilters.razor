@namespace COCOBOLOERPNEW.Components.Pages.HR.Shifts.ShiftsComponents
@using COCOBOLOERPNEW.DTOs

<MudPaper Class="mb-4" Elevation="2" Style="border-radius: 16px; overflow: hidden;">
    
    @* Filter Header *@
    <MudButton FullWidth="true" 
               Variant="Variant.Text" 
               Color="Color.Default"
               Class="pa-4 justify-space-between"
               Style="text-transform: none; border-radius: 0;"
               OnClick="ToggleFilters">
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.FilterList" Color="Color.Primary" />
            <MudText Typo="Typo.subtitle1" Class="font-weight-medium">الفلاتر والبحث</MudText>
            @if (ActiveFiltersCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                    @ActiveFiltersCount فلتر نشط
                </MudChip>
            }
        </div>
        <MudIcon Icon="@(_isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" />
    </MudButton>

    <MudCollapse Expanded="_isExpanded">
        <MudDivider />
        <div class="pa-4">
            <MudGrid Spacing="3">
                
                @* ✅ Search - بدون Immediate *@
                
                     <MudItem xs="12" md="3">
                    <MudTextField T="string"
                                  Label="بحث (اسم / قسم / رقم قومي)"
                                  @bind-Value="_searchText"
                                  Immediate="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Clearable="true"
                                  OnClearButtonClick="OnSearchCleared"
                                  OnKeyUp="HandleKeyUp"
                                  Placeholder="اكتب واضغط Enter..." />
                </MudItem>

                @* Shift Type *@
                <MudItem xs="6" md="2">
                    <MudSelect T="string"
                               Label="نوع الشيفت"
                               @bind-Value="_shiftType"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="string" Value="@ShiftTypes.Morning">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.WbSunny" Size="Size.Small" Style="color: #FFC107;" />
                                @ShiftTypes.Morning
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@ShiftTypes.Evening">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.NightsStay" Size="Size.Small" Style="color: #9C27B0;" />
                                @ShiftTypes.Evening
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="string" Value="@ShiftTypes.DailyWork">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Work" Size="Size.Small" Style="color: #2196F3;" />
                                @ShiftTypes.DailyWork
                            </div>
                        </MudSelectItem>
                    </MudSelect>
                </MudItem>

                @* Date From *@
                <MudItem xs="6" md="2">
                    <MudDatePicker Label="من تاريخ"
                                   @bind-Date="_dateFrom"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Editable="true"
                                   Clearable="true"
                                   DateFormat="yyyy/MM/dd"
                                   Placeholder="اختر تاريخ" />
                </MudItem>

                @* Date To *@
                <MudItem xs="6" md="2">
                    <MudDatePicker Label="إلى تاريخ"
                                   @bind-Date="_dateTo"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Editable="true"
                                   Clearable="true"
                                   DateFormat="yyyy/MM/dd"
                                   Placeholder="اختر تاريخ" />
                </MudItem>

                @* Status *@
                <MudItem xs="6" md="2">
                    <MudSelect T="bool?"
                               Label="الحالة"
                               @bind-Value="_activeOnly"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem T="bool?" Value="@((bool?)true)">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                نشط فقط
                            </div>
                        </MudSelectItem>
                        <MudSelectItem T="bool?" Value="@((bool?)false)">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Color="Color.Default" />
                                منتهي فقط
                            </div>
                        </MudSelectItem>
                    </MudSelect>
                </MudItem>

                @* ✅ زرار البحث *@
                <MudItem xs="12" md="1" Class="d-flex align-end gap-1">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="ExecuteSearch"
                               Style="border-radius: 8px; min-height: 40px;">
                        <MudIcon Icon="@Icons.Material.Filled.Search" />
                    </MudButton>
                </MudItem>
            </MudGrid>

            @* Active Filters Chips *@
            @if (ActiveFiltersCount > 0)
            {
                <MudDivider Class="my-3" />
                <div class="d-flex flex-wrap align-center gap-2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">الفلاتر النشطة:</MudText>
                    
                    @if (!string.IsNullOrWhiteSpace(_searchText))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                 OnClose="@(async() => { _searchText = null; await ExecuteSearch(); })">
                            بحث: @_searchText
                        </MudChip>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(_shiftType))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                 OnClose="@(async() => { _shiftType = null; await ExecuteSearch(); })">
                            @_shiftType
                        </MudChip>
                    }
                    
                    @if (_dateFrom.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                 OnClose="@(async() => { _dateFrom = null; await ExecuteSearch(); })">
                            من: @_dateFrom.Value.ToString("yyyy/MM/dd")
                        </MudChip>
                    }
                    
                    @if (_dateTo.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                 OnClose="@(async() => { _dateTo = null; await ExecuteSearch(); })">
                            إلى: @_dateTo.Value.ToString("yyyy/MM/dd")
                        </MudChip>
                    }
                    
                    @if (_activeOnly.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" 
                                 Color="@(_activeOnly.Value ? Color.Success : Color.Default)"
                                 OnClose="@(async() => { _activeOnly = null; await ExecuteSearch(); })">
                            @(_activeOnly.Value ? "نشط فقط" : "منتهي فقط")
                        </MudChip>
                    }

                    <MudButton Variant="Variant.Text" 
                               Color="Color.Error" 
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.ClearAll"
                               OnClick="ResetAll">
                        مسح الكل
                    </MudButton>
                </div>
            }
        </div>
    </MudCollapse>
</MudPaper>

@code {
    [Parameter] public EmployeeShiftFilterDto Filter { get; set; } = new();
    [Parameter] public EventCallback OnSearch { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }

    // ✅ متغيرات محلية - مش مرتبطة بالـ Filter مباشرة
    private string? _searchText;
    private string? _shiftType;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private bool? _activeOnly;
    private bool _isExpanded = true;
     protected override void OnInitialized()
    {
        _searchText = Filter.SearchText;
        _shiftType = Filter.ShiftType;
        _dateFrom = Filter.EffectiveFrom;
        _dateTo = Filter.EffectiveTo;
        _activeOnly = Filter.ActiveOnly;
    }

    protected override void OnParametersSet()
    {
        // ✅ تحميل القيم من الفلتر مرة واحدة
        _searchText = Filter.SearchText;
        _shiftType = Filter.ShiftType;
        _dateFrom = Filter.EffectiveFrom;
        _dateTo = Filter.EffectiveTo;
        _activeOnly = Filter.ActiveOnly;
    }

    private int ActiveFiltersCount =>
        (string.IsNullOrWhiteSpace(_searchText) ? 0 : 1) +
        (string.IsNullOrWhiteSpace(_shiftType) ? 0 : 1) +
        (_dateFrom.HasValue ? 1 : 0) +
        (_dateTo.HasValue ? 1 : 0) +
        (_activeOnly.HasValue ? 1 : 0);

    private void ToggleFilters() => _isExpanded = !_isExpanded;

    // ✅ البحث فقط عند الضغط على Enter أو زرار البحث
    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ExecuteSearch();
        }
    }

    // ✅ تحديث الفلتر وتنفيذ البحث
    private async Task ExecuteSearch()
    {
        Filter.SearchText = _searchText;
        Filter.ShiftType = _shiftType;
        Filter.EffectiveFrom = _dateFrom;
        Filter.EffectiveTo = _dateTo;
        Filter.ActiveOnly = _activeOnly;
        
        await OnSearch.InvokeAsync();
    }

    private async Task OnSearchCleared()
    {
        _searchText = null;
        await ExecuteSearch();
    }

    // ✅ إعادة تعيين كل الفلاتر
    private async Task ResetAll()
    {
        _searchText = null;
        _shiftType = null;
        _dateFrom = null;
        _dateTo = null;
        _activeOnly = null;
        
        await OnReset.InvokeAsync();
    }
}