@namespace COCOBOLOERPNEW.Components.Pages.HR.Shifts.ShiftsComponents
@using COCOBOLOERPNEW.DTOs

<MudPaper Elevation="2" Style="border-radius:12px; overflow:hidden;">

    @* Table Header *@
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
              Class="pa-3" Style="background:#F8FAFC; border-bottom:1px solid #E2E8F0;">
        <MudText Typo="Typo.h6" Style="font-weight:700;">
            قائمة الشيفتات
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Class="mr-2">
                @TotalCount سجل
            </MudChip>
        </MudText>

        @if (SelectedShifts.Count > 0)
        {
            <MudStack Row Spacing="2">
                <MudChip T="string" Color="Color.Info" Size="Size.Small">
                    تم تحديد @SelectedShifts.Count
                </MudChip>
                @if (HasDeletePermission)
                {
                    <MudButton Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Rounded.Delete">
                        حذف المحدد
                    </MudButton>
                }
            </MudStack>
        }
    </MudStack>

    @if (IsLoading)
    {
        @* Skeleton Loading *@
        <MudTable Items="@(Enumerable.Range(0, 5))" Elevation="0">
            <RowTemplate>
                <MudTd><MudSkeleton /></MudTd>
                <MudTd><MudSkeleton /></MudTd>
                <MudTd><MudSkeleton /></MudTd>
                <MudTd><MudSkeleton /></MudTd>
                <MudTd><MudSkeleton /></MudTd>
                <MudTd><MudSkeleton /></MudTd>  @* ✅ الجديد *@
                <MudTd><MudSkeleton /></MudTd>
                <MudTd><MudSkeleton /></MudTd>
            </RowTemplate>
        </MudTable>
    }
    else if (Shifts.Count == 0)
    {
        @* Empty State *@
        <MudStack AlignItems="AlignItems.Center" Class="pa-8">
            <MudIcon Icon="@Icons.Material.Rounded.Schedule"
                     Style="font-size:4rem; color:#CBD5E1;" />
            <MudText Typo="Typo.h6" Style="color:#94A3B8;">لا توجد شيفتات</MudText>
            <MudText Typo="Typo.body2" Style="color:#CBD5E1;">
                جرب تغيير الفلاتر أو إضافة شيفت جديد
            </MudText>
        </MudStack>
    }
    else
    {
        @* ═══════════════════════════════════════════════════════
           Data Table
           ═══════════════════════════════════════════════════════ *@
        <MudTable Items="@Shifts" Hover Striped Dense Elevation="0"
                  SelectedItems="SelectedShifts"
                  MultiSelection
                  OnSelectedItemsChanged="@((HashSet<EmployeeShiftListDto> s) => OnSelectionChanged.InvokeAsync(s))">
            <HeaderContent>
                <MudTh Style="background:#1E293B; color:white;">الموظف</MudTh>
                <MudTh Style="background:#1E293B; color:white;">القسم</MudTh>
                <MudTh Style="background:#1E293B; color:white;">الشيفت</MudTh>
                <MudTh Style="background:#1E293B; color:white;">التوقيت</MudTh>
                <MudTh Style="background:#1E293B; color:white;">المدة</MudTh>

                @* ✅ الجديد - عمود أيام الراحة بعد المدة وقبل الفترة *@
                <MudTh Style="background:#1E293B; color:#D4AF37;">أيام الراحة</MudTh>

                <MudTh Style="background:#1E293B; color:white;">الفترة</MudTh>
                <MudTh Style="background:#1E293B; color:white;">الحالة</MudTh>
                @if (HasEditPermission || HasDeletePermission)
                {
                    <MudTh Style="background:#1E293B; color:white;">إجراءات</MudTh>
                }
            </HeaderContent>

            <RowTemplate>
                @* ── عمود الموظف ── *@
                <MudTd>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudAvatar Size="Size.Small" Color="Color.Primary"
                                   Style="font-size:0.75rem;">
                            @(context.EmployeeName.Length > 0 ? context.EmployeeName[0] : '?')
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body2" Style="font-weight:600;">
                                @context.EmployeeName
                            </MudText>
                            @if (context.BiometricCode.HasValue)
                            {
                                <MudText Typo="Typo.caption" Style="color:#94A3B8;">
                                    كود: @context.BiometricCode
                                </MudText>
                            }
                        </div>
                    </MudStack>
                </MudTd>

                @* ── عمود القسم ── *@
                <MudTd>@(context.Department ?? "—")</MudTd>

                @* ── عمود الشيفت ── *@
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@GetShiftColor(context.ShiftType)">
                        @context.ShiftType
                    </MudChip>
                </MudTd>

                @* ── عمود التوقيت ── *@
                <MudTd>
                    <MudText Typo="Typo.body2" Style="font-family:monospace;">
                        @context.StartTimeDisplay - @context.EndTimeDisplay
                    </MudText>
                </MudTd>

                @* ── عمود المدة ── *@
                <MudTd>@context.DurationDisplay</MudTd>

                @* ══════════════════════════════════════════════
                   ✅ الجديد - عمود أيام الراحة
                   بعد المدة مباشرة وقبل الفترة
                   ══════════════════════════════════════════════ *@
                <MudTd>
                    @if (context.OffDay1.HasValue || context.OffDay2.HasValue)
                    {
                        <MudStack Row Spacing="1">
                            @if (context.OffDay1.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="Color.Warning"
                                         Variant="Variant.Outlined"
                                         Style="font-size:0.7rem;">
                                    @GetDayName(context.OffDay1)
                                </MudChip>
                            }
                            @if (context.OffDay2.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="Color.Secondary"
                                         Variant="Variant.Outlined"
                                         Style="font-size:0.7rem;">
                                    @GetDayName(context.OffDay2)
                                </MudChip>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Style="color:#94A3B8;">
                            غير محدد
                        </MudText>
                    }
                </MudTd>
                @* ══════════════════════════════════════════════ *@

                @* ── عمود الفترة ── *@
                <MudTd>
                    <MudText Typo="Typo.caption">
                        @context.EffectiveFromDisplay
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:#94A3B8;">
                        إلى @context.EffectiveToDisplay
                    </MudText>
                </MudTd>

                @* ── عمود الحالة ── *@
                <MudTd>
                    @if (context.IsActive)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">
                            نشط
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error">
                            منتهي
                        </MudChip>
                    }
                </MudTd>

                @* ── عمود الإجراءات ── *@
                @if (HasEditPermission || HasDeletePermission)
                {
                    <MudTd>
                        <MudStack Row Spacing="1">
                            @if (HasEditPermission)
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                               Size="Size.Small" Color="Color.Primary"
                                               OnClick="@(() => OnEdit.InvokeAsync(context))" />
                            }
                            @if (HasDeletePermission)
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => OnDelete.InvokeAsync(context))" />
                            }
                        </MudStack>
                    </MudTd>
                }
            </RowTemplate>
        </MudTable>

        @* ── Pagination ── *@
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                  Class="pa-3" Style="border-top:1px solid #E2E8F0;">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.caption">عرض</MudText>
                <MudSelect T="int" Value="PageSize" Dense
                           ValueChanged="@(v => OnPageSizeChanged.InvokeAsync(v))"
                           Style="width:80px;">
                    <MudSelectItem Value="10">10</MudSelectItem>
                    <MudSelectItem Value="25">25</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                    <MudSelectItem Value="100">100</MudSelectItem>
                </MudSelect>
                <MudText Typo="Typo.caption">سجل</MudText>
            </MudStack>

            <MudText Typo="Typo.caption">
                صفحة @CurrentPage من @TotalPages
            </MudText>

            <MudStack Row Spacing="1">
                <MudIconButton Icon="@Icons.Material.Rounded.ChevronRight"
                               Disabled="@(!HasPrevious)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(CurrentPage - 1))" />
                <MudIconButton Icon="@Icons.Material.Rounded.ChevronLeft"
                               Disabled="@(!HasNext)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(CurrentPage + 1))" />
            </MudStack>

            <MudText Typo="Typo.caption">
                إجمالي: <strong>@TotalCount</strong> سجل
            </MudText>
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter] public List<EmployeeShiftListDto> Shifts { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public int PageSize { get; set; } = 25;
    [Parameter] public bool HasPrevious { get; set; }
    [Parameter] public bool HasNext { get; set; }
    [Parameter] public bool HasEditPermission { get; set; }
    [Parameter] public bool HasDeletePermission { get; set; }
    [Parameter] public HashSet<EmployeeShiftListDto> SelectedShifts { get; set; } = new();
    [Parameter] public EventCallback<HashSet<EmployeeShiftListDto>> OnSelectionChanged { get; set; }
    [Parameter] public EventCallback<EmployeeShiftListDto> OnEdit { get; set; }
    [Parameter] public EventCallback<EmployeeShiftListDto> OnDelete { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    // ── Helpers ──────────────────────────────────────────────

    // ✅ الجديد - اسم اليوم
    private static string GetDayName(byte? day) => day switch
    {
        0 => "الأحد",
        1 => "الاثنين",
        2 => "الثلاثاء",
        3 => "الأربعاء",
        4 => "الخميس",
        5 => "الجمعة",
        6 => "السبت",
        _ => "—"
    };

    private string GetShiftTypeIcon(string shiftType) => shiftType switch
    {
        "صباحي" => Icons.Material.Filled.WbSunny,
        "مسائي" => Icons.Material.Filled.NightsStay,
        _ => Icons.Material.Filled.Schedule
    };

    private string GetShiftTypeStyle(string shiftType) => shiftType switch
    {
        "صباحي" => "background: #FFF8E1; color: #F57C00;",
        "مسائي" => "background: #F3E5F5; color: #7B1FA2;",
        _ => "background: #EEEEEE; color: #616161;"
    };

    private Color GetShiftColor(string shiftType) => shiftType switch
    {
        "صباحي" => Color.Warning,
        "مسائي" => Color.Secondary,
        _ => Color.Default
    };

    private double GetTimeProgress(EmployeeShiftListDto shift)
    {
        var start = shift.StartTime.ToTimeSpan();
        var end = shift.EndTime.ToTimeSpan();
        var duration = end > start ? end - start : TimeSpan.FromHours(24) - start + end;
        return (duration.TotalHours / 24.0) * 100;
    }
}