@namespace COCOBOLOERPNEW.Components.Pages.HR.Shifts.ShiftsComponents
@using COCOBOLOERPNEW.DTOs

<MudPaper Elevation="2" Style="border-radius: 16px; overflow: hidden;">
    
    @* Table Header *@
    <div class="pa-3 d-flex align-center justify-space-between" style="background: var(--mud-palette-background-grey);">
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.TableChart" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">قائمة الشيفتات</MudText>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">
                @TotalCount سجل
            </MudChip>
        </div>
        
        @if (SelectedShifts.Count > 0)
        {
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.body2" Color="Color.Primary" Class="font-weight-bold">
                    تم تحديد @SelectedShifts.Count
                </MudText>
                @if (HasDeletePermission)
                {
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Error" 
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Delete">
                        حذف المحدد
                    </MudButton>
                }
            </div>
        }
    </div>

    <MudDivider />

    @if (IsLoading)
    {
        @* Skeleton Loading *@
        <div class="pa-4">
            @for (int i = 0; i < 5; i++)
            {
                <div class="d-flex gap-4 mb-3">
                    <MudSkeleton Width="5%" Height="24px" />
                    <MudSkeleton Width="20%" Height="24px" />
                    <MudSkeleton Width="12%" Height="24px" />
                    <MudSkeleton Width="10%" Height="24px" />
                    <MudSkeleton Width="12%" Height="24px" />
                    <MudSkeleton Width="8%" Height="24px" />
                    <MudSkeleton Width="12%" Height="24px" />
                    <MudSkeleton Width="8%" Height="24px" />
                    <MudSkeleton Width="8%" Height="24px" />
                </div>
            }
        </div>
    }
    else if (Shifts.Count == 0)
    {
        @* Empty State *@
        <div class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Filled.EventBusy" 
                     Size="Size.Large" 
                     Style="font-size: 64px; color: #E0E0E0;" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">
                لا توجد شيفتات
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                جرب تغيير الفلاتر أو إضافة شيفت جديد
            </MudText>
        </div>
    }
    else
    {
        @* Data Table *@
        <MudTable Items="@Shifts" 
                  Hover="true" 
                  Elevation="0"
                  Dense="false"
                  Striped="true"
                  MultiSelection="true"
                  @bind-SelectedItems="SelectedShifts"
                  T="EmployeeShiftListDto"
                  RowClass="shift-row"
                  OnRowClick="@(args => HandleRowClick(args.Item))">
            <HeaderContent>
                <MudTh Style="width: 50px;"><MudCheckBox T="bool" /></MudTh>
                <MudTh><MudTableSortLabel T="EmployeeShiftListDto" SortBy="new Func<EmployeeShiftListDto, object>(x => x.EmployeeName)">الموظف</MudTableSortLabel></MudTh>
                <MudTh>القسم</MudTh>
                <MudTh><MudTableSortLabel T="EmployeeShiftListDto" SortBy="new Func<EmployeeShiftListDto, object>(x => x.ShiftType)">الشيفت</MudTableSortLabel></MudTh>
                <MudTh>التوقيت</MudTh>
                <MudTh>المدة</MudTh>
                <MudTh><MudTableSortLabel T="EmployeeShiftListDto" SortBy="new Func<EmployeeShiftListDto, object>(x => x.EffectiveFrom)">الفترة</MudTableSortLabel></MudTh>
                <MudTh>الحالة</MudTh>
                @if (HasEditPermission || HasDeletePermission)
                {
                    <MudTh Style="width: 100px; text-align: center;">إجراءات</MudTh>
                }
            </HeaderContent>
            <RowTemplate Context="shift">
                <MudTd DataLabel="#">
                    <MudCheckBox T="bool" Value="@SelectedShifts.Contains(shift)" />
                </MudTd>
                <MudTd DataLabel="الموظف">
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                            @(shift.EmployeeName.Length > 0 ? shift.EmployeeName[0] : '?')
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@shift.EmployeeName</MudText>
                            @if (shift.BiometricCode.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">كود: @shift.BiometricCode</MudText>
                            }
                        </div>
                    </div>
                </MudTd>
                <MudTd DataLabel="القسم">
                    <MudText Typo="Typo.body1" Class="font-weight-medium">@(shift.Department ?? "—")</MudText>
                </MudTd>
                <MudTd DataLabel="الشيفت">
                    <MudChip T="string" 
                             Size="Size.Small" 
                             Variant="Variant.Filled"
                             Style="@GetShiftTypeStyle(shift.ShiftType)">
                        <MudIcon Icon="@GetShiftTypeIcon(shift.ShiftType)" Size="Size.Small" Class="ml-1" />
                        @shift.ShiftType
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="التوقيت">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body1" Class="font-weight-bold">
                            @shift.StartTimeDisplay - @shift.EndTimeDisplay
                        </MudText>
                        <MudProgressLinear Value="@GetTimeProgress(shift)" 
                                           Color="@GetShiftColor(shift.ShiftType)" 
                                           Size="Size.Small"
                                           Style="width: 80px; margin-top: 4px;" />
                    </div>
                </MudTd>
                <MudTd DataLabel="المدة">
                    <MudText Typo="Typo.body1" Class="font-weight-bold" Color="Color.Primary">
                        @shift.DurationDisplay
                    </MudText>
                </MudTd>
                <MudTd DataLabel="الفترة">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body1" Class="font-weight-medium">@shift.EffectiveFromDisplay</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            إلى @shift.EffectiveToDisplay
                        </MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="الحالة">
                    @if (shift.IsActive)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" 
                                 Style="background: #E8F5E9; color: #2E7D32;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="ml-1" />
                            نشط
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                 Style="background: #EEEEEE; color: #757575;">
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Class="ml-1" />
                            منتهي
                        </MudChip>
                    }
                </MudTd>
                @if (HasEditPermission || HasDeletePermission)
                {
                    <MudTd DataLabel="إجراءات">
                        <div class="d-flex justify-center gap-1">
                            @if (HasEditPermission)
                            {
                                <MudTooltip Text="تعديل">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                                   Size="Size.Small" 
                                                   Color="Color.Primary"
                                                   OnClick="@(() => OnEdit.InvokeAsync(shift))"
                                                   OnClick:stopPropagation="true" />
                                </MudTooltip>
                            }
                            @if (HasDeletePermission)
                            {
                                <MudTooltip Text="حذف">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Size="Size.Small" 
                                                   Color="Color.Error"
                                                   OnClick="@(() => OnDelete.InvokeAsync(shift))"
                                                   OnClick:stopPropagation="true" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                }
            </RowTemplate>
        </MudTable>

        @* Pagination *@
        <MudDivider />
        <div class="pa-3 d-flex flex-wrap align-center justify-space-between gap-3" style="background: var(--mud-palette-background-grey);">
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.body2" Color="Color.Secondary">عرض</MudText>
                <MudSelect T="int" 
                           Value="@PageSize"
                           ValueChanged="@(v => OnPageSizeChanged.InvokeAsync(v))"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Style="width: 80px;">
                    <MudSelectItem T="int" Value="10">10</MudSelectItem>
                    <MudSelectItem T="int" Value="25">25</MudSelectItem>
                    <MudSelectItem T="int" Value="50">50</MudSelectItem>
                    <MudSelectItem T="int" Value="100">100</MudSelectItem>
                </MudSelect>
                <MudText Typo="Typo.body2" Color="Color.Secondary">سجل</MudText>
            </div>

            <div class="d-flex align-center gap-2">
                <MudIconButton Icon="@Icons.Material.Filled.FirstPage" 
                               Size="Size.Small"
                               Disabled="@(!HasPrevious)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(1))" />
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" 
                               Size="Size.Small"
                               Disabled="@(!HasPrevious)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(CurrentPage - 1))" />
                
                <MudText Typo="Typo.body2" Class="px-2 font-weight-bold">
                    صفحة @CurrentPage من @TotalPages
                </MudText>
                
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" 
                               Size="Size.Small"
                               Disabled="@(!HasNext)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(CurrentPage + 1))" />
                <MudIconButton Icon="@Icons.Material.Filled.LastPage" 
                               Size="Size.Small"
                               Disabled="@(!HasNext)"
                               OnClick="@(() => OnPageChanged.InvokeAsync(TotalPages))" />
            </div>

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="font-weight-medium">
                إجمالي: <strong>@TotalCount</strong> سجل
            </MudText>
        </div>
    }
</MudPaper>

@code {
    [Parameter] public List<EmployeeShiftListDto> Shifts { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public int PageSize { get; set; } = 25;
    [Parameter] public bool HasPrevious { get; set; }
    [Parameter] public bool HasNext { get; set; }
    [Parameter] public bool HasEditPermission { get; set; }
    [Parameter] public bool HasDeletePermission { get; set; }
    [Parameter] public HashSet<EmployeeShiftListDto> SelectedShifts { get; set; } = new();
    [Parameter] public EventCallback<HashSet<EmployeeShiftListDto>> OnSelectionChanged { get; set; }
    [Parameter] public EventCallback<EmployeeShiftListDto> OnEdit { get; set; }
    [Parameter] public EventCallback<EmployeeShiftListDto> OnDelete { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<int> OnPageSizeChanged { get; set; }

    private void HandleRowClick(EmployeeShiftListDto shift)
    {
        if (SelectedShifts.Contains(shift))
            SelectedShifts.Remove(shift);
        else
            SelectedShifts.Add(shift);
        
        OnSelectionChanged.InvokeAsync(SelectedShifts);
    }

    private string GetShiftTypeIcon(string shiftType) => shiftType switch
    {
        "صباحي" => Icons.Material.Filled.WbSunny,
        "مسائي" => Icons.Material.Filled.NightsStay,
        _ => Icons.Material.Filled.Schedule
    };

    private string GetShiftTypeStyle(string shiftType) => shiftType switch
    {
        "صباحي" => "background: #FFF8E1; color: #F57C00;",
        "مسائي" => "background: #F3E5F5; color: #7B1FA2;",
        _ => "background: #EEEEEE; color: #616161;"
    };

    private Color GetShiftColor(string shiftType) => shiftType switch
    {
        "صباحي" => Color.Warning,
        "مسائي" => Color.Secondary,
        _ => Color.Default
    };

    private double GetTimeProgress(EmployeeShiftListDto shift)
    {
        var start = shift.StartTime.ToTimeSpan();
        var end = shift.EndTime.ToTimeSpan();
        var duration = end > start ? end - start : TimeSpan.FromHours(24) - start + end;
        return (duration.TotalHours / 24.0) * 100;
    }
}