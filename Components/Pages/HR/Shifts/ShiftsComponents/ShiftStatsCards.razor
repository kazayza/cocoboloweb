@namespace COCOBOLOERPNEW.Components.Pages.HR.Shifts.ShiftsComponents

<div class="pa-4 pt-0">
    <MudGrid Spacing="2">
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(255,255,255,0.10); border-radius: 12px;">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto mb-1" />
                    <MudSkeleton Width="30%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Medium" Style="color: rgba(255,255,255,0.9);" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">@TotalCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.72);">إجمالي</MudText>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(76, 175, 80, 0.20); border-radius: 12px; border: 1px solid rgba(76, 175, 80, 0.30);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto mb-1" />
                    <MudSkeleton Width="30%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Medium" Style="color: #4CAF50;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">@ActiveCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.72);">نشط</MudText>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(255, 193, 7, 0.20); border-radius: 12px; border: 1px solid rgba(255, 193, 7, 0.30);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto mb-1" />
                    <MudSkeleton Width="30%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.WbSunny" Size="Size.Medium" Style="color: #FFC107;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">@MorningCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.72);">صباحي</MudText>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(156, 39, 176, 0.20); border-radius: 12px; border: 1px solid rgba(156, 39, 176, 0.30);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto mb-1" />
                    <MudSkeleton Width="30%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.NightsStay" Size="Size.Medium" Style="color: #9C27B0;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">@EveningCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.72);">مسائي</MudText>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-3 text-center" Elevation="0"
                      Style="background: rgba(33, 150, 243, 0.20); border-radius: 12px; border: 1px solid rgba(33, 150, 243, 0.30);">
                @if (IsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="32px" Height="32px" Class="mx-auto mb-2" />
                    <MudSkeleton Width="50%" Class="mx-auto mb-1" />
                    <MudSkeleton Width="30%" Class="mx-auto" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Work" Size="Size.Medium" Style="color: #2196F3;" Class="mb-1" />
                    <MudText Typo="Typo.h5" Color="Color.Surface" Class="font-weight-bold">@DailyCount.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.72);">عمل يومي</MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int ActiveCount { get; set; }
    [Parameter] public int MorningCount { get; set; }
    [Parameter] public int EveningCount { get; set; }
    [Parameter] public int DailyCount { get; set; }
    [Parameter] public bool IsLoading { get; set; }
}
