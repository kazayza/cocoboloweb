@namespace COCOBOLOERPNEW.Components.Pages.HR.Shifts.ShiftsComponents
@using COCOBOLOERPNEW.DTOs

<MudDialog @bind-Visible="Visible" Options="@_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-3">
            <MudAvatar Color="Color.Error" Variant="Variant.Filled" Size="Size.Medium">
                <MudIcon Icon="@Icons.Material.Filled.DeleteForever" />
            </MudAvatar>
            <MudText Typo="Typo.h6">تأكيد الحذف</MudText>
        </div>
    </TitleContent>
    
    <DialogContent>
        <MudPaper Class="pa-4" Elevation="0" Style="background: #FFEBEE; border-radius: 12px;">
            <div class="d-flex align-start gap-3">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.body1" Class="font-weight-medium">
                        هل أنت متأكد من حذف هذا الشيفت؟
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                        لا يمكن التراجع عن هذا الإجراء بعد تنفيذه.
                    </MudText>
                </div>
            </div>
        </MudPaper>

        @if (ShiftToDelete != null)
        {
            <MudPaper Class="pa-4 mt-4" Elevation="1" Style="border-radius: 12px;">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-3">
                    تفاصيل الشيفت المراد حذفه:
                </MudText>
                
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">الموظف</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-medium">@ShiftToDelete.EmployeeName</MudText>
                            </div>
                        </div>
                    </MudItem>
                    
                    <MudItem xs="6">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">القسم</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-medium">@(ShiftToDelete.Department ?? "—")</MudText>
                            </div>
                        </div>
                    </MudItem>
                    
                    <MudItem xs="6">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@GetShiftTypeIcon(ShiftToDelete.ShiftType)" Size="Size.Small" 
                                     Style="@GetShiftTypeColor(ShiftToDelete.ShiftType)" />
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">نوع الشيفت</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-medium">@ShiftToDelete.ShiftType</MudText>
                            </div>
                        </div>
                    </MudItem>
                    
                    <MudItem xs="6">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">التوقيت</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                    @ShiftToDelete.StartTimeDisplay - @ShiftToDelete.EndTimeDisplay
                                </MudText>
                            </div>
                        </div>
                    </MudItem>
                    
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">فترة الشيفت</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                    من @ShiftToDelete.EffectiveFromDisplay إلى @ShiftToDelete.EffectiveToDisplay
                                </MudText>
                            </div>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }
    </DialogContent>
    
    <DialogActions>
        <MudButton Variant="Variant.Text" 
                   Color="Color.Default" 
                   OnClick="Close"
                   Disabled="IsDeleting">
            إلغاء
        </MudButton>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Error"
                   StartIcon="@(IsDeleting ? null : Icons.Material.Filled.Delete)"
                   OnClick="ConfirmDelete"
                   Disabled="IsDeleting">
            @if (IsDeleting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="ml-2" />
                <span>جاري الحذف...</span>
            }
            else
            {
                <span>حذف الشيفت</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public EmployeeShiftListDto? ShiftToDelete { get; set; }
    [Parameter] public EventCallback OnConfirmDelete { get; set; }
    [Parameter] public bool IsDeleting { get; set; }

    private DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseButton = true,
        CloseOnEscapeKey = true,
        BackdropClick = false
    };

    private async Task Close()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task ConfirmDelete()
    {
        await OnConfirmDelete.InvokeAsync();
    }

    private string GetShiftTypeIcon(string shiftType) => shiftType switch
    {
        "صباحي" => Icons.Material.Filled.WbSunny,
        "مسائي" => Icons.Material.Filled.NightsStay,
        "عمل يومي" => Icons.Material.Filled.Work,
        _ => Icons.Material.Filled.Schedule
    };

    private string GetShiftTypeColor(string shiftType) => shiftType switch
    {
        "صباحي" => "color: #F57C00;",
        "مسائي" => "color: #7B1FA2;",
        "عمل يومي" => "color: #1976D2;",
        _ => "color: #757575;"
    };
}