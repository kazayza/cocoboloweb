@page "/hr/payroll/attendance"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IPayrollService              PayrollService
@inject ISnackbar                    Snackbar
@inject AuthenticationStateProvider  AuthProvider

<PageTitle>الحضور اليدوي للموظفين المعفيين</PageTitle>

<MudPaper Class="pa-4 mb-4 rounded-xl">
    <div class="d-flex align-center gap-3 flex-wrap">
        <div>
            <MudText Typo="Typo.h5">الحضور اليدوي</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                للموظفين المعفيين من البصمة (IsPermanentlyExempt)
            </MudText>
        </div>
        <MudSpacer />
        <MudTextField @bind-Value="_month"
                      Label="الشهر"
                      Placeholder="2026-05"
                      Variant="Variant.Outlined"
                      Style="max-width:160px"
                      Margin="Margin.Dense" />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="LoadAsync"
                   Disabled="_loading">
            عرض
        </MudButton>
        @if (_records.Any())
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAllAsync"
                       Disabled="_saving">
                @(_saving ? "جاري الحفظ..." : "حفظ الكل")
            </MudButton>
        }
    </div>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-3" />
}
else if (_records.Any())
{
    <MudPaper Class="rounded-xl overflow-hidden">
        <MudTable Items="_records" Dense Hover Striped Elevation="0">
            <HeaderContent>
                <MudTh>الموظف</MudTh>
                <MudTh>القسم</MudTh>
                <MudTh>أيام الحضور</MudTh>
                <MudTh>أيام الغياب</MudTh>
                <MudTh>دقائق التأخير</MudTh>
                <MudTh>ملاحظات</MudTh>
                <MudTh>حفظ</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Size="Size.Small" Color="Color.Primary">
                            @context.EmployeeName.FirstOrDefault()
                        </MudAvatar>
                        <MudText><b>@context.EmployeeName</b></MudText>
                    </div>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @(context.Department ?? "—")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudNumericField T="int"
                                     @bind-Value="context.PresentDays"
                                     Min="0" Max="31"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Style="max-width:90px" />
                </MudTd>
                <MudTd>
                    <MudNumericField T="int"
                                     @bind-Value="context.AbsenceDays"
                                     Min="0" Max="31"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Style="max-width:90px" />
                </MudTd>
                <MudTd>
                    <MudNumericField T="int"
                                     @bind-Value="context.LateMinutes"
                                     Min="0"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Style="max-width:100px" />
                </MudTd>
                <MudTd>
                    <MudTextField @bind-Value="context.Notes"
                                  Placeholder="ملاحظة..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Style="max-width:200px" />
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Save"
                                   Color="Color.Success"
                                   Size="Size.Small"
                                   Title="حفظ"
                                   OnClick="@(() => SaveOneAsync(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>

        <div class="pa-3 d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Info"
                     Color="Color.Info" Size="Size.Small" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                الموظفون المعفيون من البصمة يظهرون هنا بحضور كامل افتراضياً.
                عدّل الأرقام لو فيه غياب أو تأخير ثم احفظ.
            </MudText>
        </div>
    </MudPaper>
}
else if (_searched)
{
    <MudPaper Class="pa-6 rounded-xl text-center">
        <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                 Color="Color.Success" Size="Size.Large" />
        <MudText Class="mt-2">
            لا يوجد موظفون معفيون من البصمة في النظام
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            لإضافة موظف معفى: اذهب لبيانات الموظف وفعّل خيار "معفى من البصمة"
        </MudText>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-6 rounded-xl text-center">
        <MudText Color="Color.Secondary">
            اختر الشهر واضغط "عرض"
        </MudText>
    </MudPaper>
}

@code {
    private string                    _month       = DateTime.Today.ToString("yyyy-MM");
    private List<ManualAttendanceDto> _records     = new();
    private bool                      _loading;
    private bool                      _saving;
    private bool                      _searched;
    private string                    _currentUser = "system";

    protected override async Task OnInitializedAsync()
    {
        var auth     = await AuthProvider.GetAuthenticationStateAsync();
        _currentUser = auth.User.Identity?.Name ?? "system";
    }

    private async Task LoadAsync()
    {
        if (!ValidateMonth(_month))
        {
            Snackbar.Add("صيغة الشهر غير صحيحة (مثال: 2026-05)", Severity.Warning);
            return;
        }

        _loading  = true;
        _searched = false;
        StateHasChanged();

        try
        {
            _records  = await PayrollService.GetManualAttendanceAsync(_month);
            _searched = true;

            if (_records.Any())
                Snackbar.Add($"تم تحميل {_records.Count} موظف معفى", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    // حفظ موظف واحد
    private async Task SaveOneAsync(ManualAttendanceDto dto)
    {
        var (ok, msg) = await PayrollService.SaveManualAttendanceAsync(dto, _currentUser);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadAsync(); // إعادة تحميل لتحديث الـ ManualID
    }

    // حفظ الكل دفعة واحدة
    private async Task SaveAllAsync()
    {
        _saving = true;
        StateHasChanged();

        int success = 0, failed = 0;
        foreach (var dto in _records)
        {
            var (ok, _) = await PayrollService.SaveManualAttendanceAsync(dto, _currentUser);
            if (ok) success++; else failed++;
        }

        _saving = false;
        Snackbar.Add(
            $"تم حفظ {success} موظف" + (failed > 0 ? $" | فشل {failed}" : ""),
            failed > 0 ? Severity.Warning : Severity.Success);

        if (success > 0) await LoadAsync();
    }

    private static bool ValidateMonth(string? m) =>
        !string.IsNullOrWhiteSpace(m) &&
        DateTime.TryParseExact(m + "-01", "yyyy-MM-dd",
            null, System.Globalization.DateTimeStyles.None, out _);
}
