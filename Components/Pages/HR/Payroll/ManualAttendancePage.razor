@page "/hr/payroll/attendance"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IPayrollService              PayrollService
@inject ISnackbar                    Snackbar
@inject AuthenticationStateProvider  AuthProvider

<PageTitle>الحضور اليدوي</PageTitle>

<MudPaper Class="pa-4 mb-4 rounded-xl d-flex align-center gap-3 flex-wrap">
    <div>
        <MudText Typo="Typo.h5">📅 الحضور اليدوي للموظفين</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            للموظفين الذين ليس لديهم بصمة
        </MudText>
    </div>
    <MudSpacer />
    <MudTextField @bind-Value="_month"
                  Label="الشهر"
                  Placeholder="2026-05"
                  Variant="Variant.Outlined"
                  Style="max-width:160px" Margin="Margin.Dense" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Search"
               OnClick="LoadAsync">
        عرض
    </MudButton>
</MudPaper>

<MudPaper Class="rounded-xl overflow-hidden">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" />
    }

    <MudTable Items="_records" Dense Hover Elevation="0">
        <HeaderContent>
            <MudTh>الموظف</MudTh>
            <MudTh>أيام الحضور</MudTh>
            <MudTh>أيام الغياب</MudTh>
            <MudTh>دقائق التأخير</MudTh>
            <MudTh>ملاحظات</MudTh>
            <MudTh>حفظ</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><b>@context.EmployeeName</b></MudTd>
            <MudTd>
                <MudNumericField T="int" @bind-Value="context.PresentDays"
                                 Min="0" Max="31" Variant="Variant.Outlined"
                                 Margin="Margin.Dense" Style="max-width:80px" />
            </MudTd>
            <MudTd>
                <MudNumericField T="int" @bind-Value="context.AbsenceDays"
                                 Min="0" Max="31" Variant="Variant.Outlined"
                                 Margin="Margin.Dense" Style="max-width:80px" />
            </MudTd>
            <MudTd>
                <MudNumericField T="int" @bind-Value="context.LateMinutes"
                                 Min="0" Variant="Variant.Outlined"
                                 Margin="Margin.Dense" Style="max-width:100px" />
            </MudTd>
            <MudTd>
                <MudTextField @bind-Value="context.Notes"
                              Placeholder="ملاحظة..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Save"
                               Color="Color.Success" Size="Size.Small"
                               OnClick="@(() => SaveAsync(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4" Color="Color.Secondary" Align="Align.Center">
                اختر الشهر واضغط "عرض"
            </MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private string                   _month   = DateTime.Today.ToString("yyyy-MM");
    private List<ManualAttendanceDto> _records = new();
    private bool                      _loading;
    private string                    _currentUser = "system";

    protected override async Task OnInitializedAsync()
    {
        var auth     = await AuthProvider.GetAuthenticationStateAsync();
        _currentUser = auth.User.Identity?.Name ?? "system";
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try { _records = await PayrollService.GetManualAttendanceAsync(_month); }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task SaveAsync(ManualAttendanceDto dto)
    {
        var (ok, msg) = await PayrollService.SaveManualAttendanceAsync(dto, _currentUser);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
    }
}
