@* قسيمة الراتب - نسخة احترافية V2 *@
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IPayrollService     PayrollService
@inject ICompanyInfoService CompanyInfoService
@inject ISnackbar           Snackbar
@inject IJSRuntime          JS

<style>
    .ps-root {
        direction: rtl;
        color: #0f172a;
    }

    .ps-shell {
        background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        overflow: hidden;
    }

    .ps-header {
        position: relative;
        padding: 24px;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
        color: white;
        overflow: hidden;
    }

    .ps-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 15% 20%, rgba(212,175,55,.18), transparent 35%),
            radial-gradient(circle at 85% 80%, rgba(59,130,246,.18), transparent 35%);
        pointer-events: none;
    }

    .ps-header-content {
        position: relative;
        z-index: 1;
    }

    .ps-brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .ps-logo {
        width: 62px;
        height: 62px;
        border-radius: 16px;
        object-fit: cover;
        border: 1px solid rgba(255,255,255,.18);
        background: rgba(255,255,255,.08);
        padding: 4px;
    }

    .ps-logo-fallback {
        width: 62px;
        height: 62px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.18);
        color: #d4af37;
        font-weight: 900;
        font-size: 1.3rem;
    }

    .ps-company-name {
        font-size: 1.18rem;
        font-weight: 900;
        letter-spacing: -.3px;
    }

    .ps-company-meta {
        color: rgba(255,255,255,.72);
        font-size: .78rem;
        margin-top: 4px;
        line-height: 1.55;
    }

    .ps-doc-title {
        font-size: 1.28rem;
        font-weight: 900;
        letter-spacing: -.4px;
        text-align: left;
    }

    .ps-doc-subtitle {
        color: rgba(255,255,255,.72);
        font-size: .8rem;
        margin-top: 6px;
        text-align: left;
    }

    .ps-status-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: .74rem;
        font-weight: 800;
        color: white;
        margin-top: 10px;
        box-shadow: 0 6px 18px rgba(15,23,42,.22);
    }

    .ps-grid {
        padding: 20px;
    }

    .ps-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        padding: 18px;
        height: 100%;
    }

    .ps-card-soft {
        background: #f8fafc;
    }

    .ps-card-title {
        font-size: .92rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ps-mini-label {
        font-size: .72rem;
        color: #64748b;
        margin-bottom: 4px;
    }

    .ps-mini-value {
        font-size: .9rem;
        font-weight: 800;
        color: #0f172a;
    }

    .ps-stat {
        border-radius: 18px;
        padding: 18px;
        color: white;
        min-height: 104px;
        position: relative;
        overflow: hidden;
    }

    .ps-stat::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top left, rgba(255,255,255,.14), transparent 35%);
        pointer-events: none;
    }

    .ps-stat-label {
        position: relative;
        z-index: 1;
        font-size: .76rem;
        opacity: .85;
        margin-bottom: 10px;
    }

    .ps-stat-value {
        position: relative;
        z-index: 1;
        font-size: 1.35rem;
        font-weight: 900;
        letter-spacing: -.6px;
    }

    .ps-stat-note {
        position: relative;
        z-index: 1;
        font-size: .72rem;
        opacity: .82;
        margin-top: 8px;
    }

    .ps-slate { background: linear-gradient(135deg, #0f172a, #1e293b); }
    .ps-green { background: linear-gradient(135deg, #059669, #10b981); }
    .ps-red { background: linear-gradient(135deg, #dc2626, #ef4444); }
    .ps-blue { background: linear-gradient(135deg, #2563eb, #3b82f6); }

    .ps-line-item {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px dashed #e2e8f0;
    }

    .ps-line-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .ps-line-label {
        font-size: .84rem;
        color: #0f172a;
        line-height: 1.5;
        font-weight: 600;
    }

    .ps-line-sub {
        font-size: .72rem;
        color: #64748b;
        margin-top: 3px;
    }

    .ps-line-amount {
        font-size: .86rem;
        font-weight: 900;
        white-space: nowrap;
    }

    .ps-amount-positive { color: #059669; }
    .ps-amount-negative { color: #dc2626; }
    .ps-amount-neutral { color: #0f172a; }
    .ps-amount-info { color: #2563eb; }

    .ps-empty {
        color: #94a3b8;
        font-size: .82rem;
        font-weight: 600;
        padding: 10px 0 4px;
    }

    .ps-chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .ps-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 999px;
        padding: 6px 12px;
        font-size: .72rem;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .ps-chip-default {
        background: #f8fafc;
        color: #475569;
        border-color: #e2e8f0;
    }

    .ps-chip-success {
        background: #ecfdf5;
        color: #047857;
        border-color: #bbf7d0;
    }

    .ps-chip-warning {
        background: #fff7ed;
        color: #c2410c;
        border-color: #fdba74;
    }

    .ps-chip-danger {
        background: #fef2f2;
        color: #b91c1c;
        border-color: #fecaca;
    }

    .ps-chip-info {
        background: #eff6ff;
        color: #1d4ed8;
        border-color: #bfdbfe;
    }

    .ps-note-box {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        border-radius: 16px;
        padding: 14px;
    }

    .ps-note-item {
        font-size: .82rem;
        color: #334155;
        line-height: 1.7;
        padding: 6px 0;
        border-bottom: 1px dashed #e2e8f0;
    }

    .ps-note-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .ps-signatures {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-top: 8px;
    }

    .ps-sign-box {
        text-align: center;
        padding-top: 18px;
    }

    .ps-sign-line {
        height: 1px;
        background: #94a3b8;
        margin-bottom: 10px;
    }

    .ps-sign-label {
        color: #64748b;
        font-size: .74rem;
        font-weight: 700;
    }

    .ps-print-meta {
        text-align: center;
        color: #94a3b8;
        font-size: .72rem;
        margin-top: 18px;
    }

    @@media (max-width: 768px) {
        .ps-header {
            padding: 18px;
        }

        .ps-doc-title,
        .ps-doc-subtitle {
            text-align: right;
        }

        .ps-signatures {
            grid-template-columns: 1fr;
        }
    }

    @@media print {
        body * {
            visibility: hidden !important;
        }

        #payslip-print-root,
        #payslip-print-root * {
            visibility: visible !important;
        }

        #payslip-print-root {
            position: absolute;
            inset: 0;
            width: 100%;
            background: white;
            padding: 0;
            margin: 0;
        }

        .mud-dialog-title,
        .mud-dialog-actions,
        .no-print {
            display: none !important;
        }

        .ps-shell {
            border: none !important;
            box-shadow: none !important;
            border-radius: 0 !important;
        }

        .ps-card,
        .ps-stat,
        .ps-note-box {
            break-inside: avoid;
            page-break-inside: avoid;
        }
    }
</style>

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2 flex-wrap no-print">
            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Color="Color.Primary" />
            <MudText Typo="Typo.h6">قسيمة الراتب</MudText>
            <MudSpacer />
            @if (_slip is not null)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Print"
                           OnClick="PrintAsync"
                           Size="Size.Small">
                    طباعة
                </MudButton>
            }
        </div>
    </TitleContent>

    <DialogContent>
        @if (_loading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Indeterminate Color="Color.Primary" />
            </div>
        }
        else if (_slip is null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                قسيمة الراتب غير موجودة أو تعذر تحميلها.
            </MudAlert>
        }
        else
        {
            <div id="payslip-print-root" class="ps-root">
                <div class="ps-shell">

                    <div class="ps-header">
                        <div class="ps-header-content d-flex justify-space-between align-start flex-wrap gap-4">
                            <div class="ps-brand">
                                @if (!string.IsNullOrWhiteSpace(CompanyLogoSrc))
                                {
                                    <img src="@CompanyLogoSrc" alt="Company Logo" class="ps-logo" />
                                }
                                else
                                {
                                    <div class="ps-logo-fallback">@CompanyInitials</div>
                                }

                                <div>
                                    <div class="ps-company-name">@(CompanyName)</div>
                                    <div class="ps-company-meta">
                                        @if (!string.IsNullOrWhiteSpace(_company?.Address))
                                        {
                                            <div>@_company.Address</div>
                                        }
                                        <div>
                                            @CompanyPhoneDisplay
                                            @if (!string.IsNullOrWhiteSpace(_company?.SalesEmail))
                                            {
                                                <span> • @_company.SalesEmail</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <div class="ps-doc-title">@DocumentTitle</div>
                                <div class="ps-doc-subtitle">
                                    رقم القسيمة: #@PayrollId<br />
                                    تاريخ الإصدار: @DateTime.Now.ToString("dd/MM/yyyy")<br />
                                    الفترة: @_slip.MonthDisplay
                                </div>
                                <div class="ps-status-pill" style="@StatusPillStyle">@_slip.PaymentStatus</div>
                            </div>
                        </div>
                    </div>

                    <div class="ps-grid">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="8">
                                <div class="ps-card h-100">
                                    <div class="ps-card-title">
                                        <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" />
                                        بيانات الموظف
                                    </div>

                                    <MudGrid Spacing="2">
                                        <MudItem xs="12" sm="6" md="3">
                                            <div class="ps-mini-label">اسم الموظف</div>
                                            <div class="ps-mini-value">@_slip.EmployeeName</div>
                                        </MudItem>
                                        <MudItem xs="12" sm="6" md="3">
                                            <div class="ps-mini-label">القسم</div>
                                            <div class="ps-mini-value">@(_slip.Department ?? "—")</div>
                                        </MudItem>
                                        <MudItem xs="12" sm="6" md="3">
                                            <div class="ps-mini-label">الوظيفة</div>
                                            <div class="ps-mini-value">@(_slip.JobTitle ?? "—")</div>
                                        </MudItem>
                                        <MudItem xs="12" sm="6" md="3">
                                            <div class="ps-mini-label">الرقم القومي</div>
                                            <div class="ps-mini-value">@(_slip.NationalId ?? "—")</div>
                                        </MudItem>
                                    </MudGrid>

                                    <MudDivider Class="my-3" />

                                    <div class="ps-chip-row">
                                        <span class="ps-chip ps-chip-default">مصدر الحضور: @_slip.AttendanceSource</span>
                                        <span class="ps-chip @( _slip.AbsenceDays > 0 ? "ps-chip-danger" : "ps-chip-success")">غياب: @_slip.AbsenceDays يوم</span>
                                        <span class="ps-chip @( _slip.LateMinutesTotal > 0 ? "ps-chip-warning" : "ps-chip-success")">تأخير: @_slip.LateDisplay</span>
                                        <span class="ps-chip ps-chip-info">أيام العمل: @_slip.WorkingDaysInMonth</span>
                                        <span class="ps-chip ps-chip-success">الحضور: @_slip.PresentDays</span>
                                    </div>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <div class="ps-card ps-card-soft h-100">
                                    <div class="ps-card-title">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                                        ملخص الصرف
                                    </div>

                                    <div class="ps-mini-label">الخزينة</div>
                                    <div class="ps-mini-value">@(_slip.CashBoxName ?? "لم يتم الصرف بعد")</div>

                                    <div class="ps-mini-label mt-3">تاريخ الصرف</div>
                                    <div class="ps-mini-value">@(_slip.PaymentDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>

                                    <div class="ps-mini-label mt-3">نوع المستند</div>
                                    <div class="ps-mini-value">@DocumentTypeLabel</div>
                                </div>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="3">
                                <div class="ps-stat ps-slate">
                                    <div class="ps-stat-label">إجمالي المستحقات</div>
                                    <div class="ps-stat-value">@_slip.GrossSalary.ToString("N2") جـ</div>
                                    <div class="ps-stat-note">الأساسي + الإضافات داخل الراتب</div>
                                </div>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="3">
                                <div class="ps-stat ps-red">
                                    <div class="ps-stat-label">إجمالي الخصومات</div>
                                    <div class="ps-stat-value">@_slip.TotalDeductions.ToString("N2") جـ</div>
                                    <div class="ps-stat-note">غياب + تأخير + سلف + جزاءات</div>
                                </div>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="3">
                                <div class="ps-stat ps-green">
                                    <div class="ps-stat-label">صافي الراتب</div>
                                    <div class="ps-stat-value">@_slip.NetSalary.ToString("N2") جـ</div>
                                    <div class="ps-stat-note">المبلغ داخل كشف الراتب</div>
                                </div>
                            </MudItem>

                            <MudItem xs="12" sm="6" md="3">
                                <div class="ps-stat ps-blue">
                                    <div class="ps-stat-label">دفعات منفصلة</div>
                                    <div class="ps-stat-value">@SeparateTotal.ToString("N2") جـ</div>
                                    <div class="ps-stat-note">لا تدخل في صافي الراتب</div>
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="ps-card h-100">
                                    <div class="ps-card-title">
                                        <MudIcon Icon="@Icons.Material.Filled.AddCard" Size="Size.Small" />
                                        المستحقات
                                    </div>

                                    <div class="ps-line-item">
                                        <div>
                                            <div class="ps-line-label">الراتب الأساسي</div>
                                            <div class="ps-line-sub">القيمة الأساسية للموظف في هذا الشهر</div>
                                        </div>
                                        <div class="ps-line-amount ps-amount-neutral">@_slip.BasicSalary.ToString("N2") جـ</div>
                                    </div>

                                    @foreach (var b in _slip.BonusItems)
                                    {
                                        <div class="ps-line-item">
                                            <div>
                                                <div class="ps-line-label">@b.DetailTypeAr</div>
                                                <div class="ps-line-sub">@b.Description</div>
                                            </div>
                                            <div class="ps-line-amount ps-amount-positive">+ @b.Amount.ToString("N2") جـ</div>
                                        </div>
                                    }

                                    @if (!_slip.BonusItems.Any())
                                    {
                                        <div class="ps-empty">لا توجد إضافات داخل الراتب.</div>
                                    }
                                </div>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <div class="ps-card h-100">
                                    <div class="ps-card-title">
                                        <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" Size="Size.Small" />
                                        الخصومات
                                    </div>

                                    @if (_slip.AbsenceDeduction > 0)
                                    {
                                        <div class="ps-line-item">
                                            <div>
                                                <div class="ps-line-label">خصم غياب</div>
                                                <div class="ps-line-sub">@_slip.AbsenceDays يوم</div>
                                            </div>
                                            <div class="ps-line-amount ps-amount-negative">- @_slip.AbsenceDeduction.ToString("N2") جـ</div>
                                        </div>
                                    }

                                    @if (_slip.LateDeduction > 0)
                                    {
                                        <div class="ps-line-item">
                                            <div>
                                                <div class="ps-line-label">خصم تأخير</div>
                                                <div class="ps-line-sub">@_slip.LateDisplay</div>
                                            </div>
                                            <div class="ps-line-amount ps-amount-negative">- @_slip.LateDeduction.ToString("N2") جـ</div>
                                        </div>
                                    }

                                    @foreach (var inst in _slip.LoanItems)
                                    {
                                        <div class="ps-line-item">
                                            <div>
                                                <div class="ps-line-label">@inst.DetailTypeAr</div>
                                                <div class="ps-line-sub">@inst.Description</div>
                                            </div>
                                            <div class="ps-line-amount ps-amount-negative">- @inst.Amount.ToString("N2") جـ</div>
                                        </div>
                                    }

                                    @foreach (var p in _slip.Penalties)
                                    {
                                        <div class="ps-line-item">
                                            <div>
                                                <div class="ps-line-label">@p.DetailTypeAr</div>
                                                <div class="ps-line-sub">@p.Description</div>
                                            </div>
                                            <div class="ps-line-amount ps-amount-negative">- @p.Amount.ToString("N2") جـ</div>
                                        </div>
                                    }

                                    @if (_slip.TotalDeductions == 0)
                                    {
                                        <div class="ps-empty">لا توجد خصومات على هذا الراتب.</div>
                                    }
                                </div>
                            </MudItem>

                            @if (_slip.SeparateBonuses.Any())
                            {
                                <MudItem xs="12">
                                    <div class="ps-card">
                                        <div class="ps-card-title">
                                            <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Size="Size.Small" />
                                            دفعات منفصلة خارج الراتب
                                        </div>

                                        @foreach (var item in _slip.SeparateBonuses)
                                        {
                                            <div class="ps-line-item">
                                                <div>
                                                    <div class="ps-line-label">@item.DetailTypeAr</div>
                                                    <div class="ps-line-sub">@item.Description</div>
                                                </div>
                                                <div class="ps-line-amount ps-amount-info">@item.Amount.ToString("N2") جـ</div>
                                            </div>
                                        }
                                    </div>
                                </MudItem>
                            }

                            @if (WorkflowLines.Any())
                            {
                                <MudItem xs="12">
                                    <div class="ps-card">
                                        <div class="ps-card-title">
                                            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" />
                                            ملاحظات واعتمادات ومسار العمل
                                        </div>

                                        <div class="ps-note-box">
                                            @foreach (var line in WorkflowLines)
                                            {
                                                <div class="ps-note-item">@line</div>
                                            }
                                        </div>
                                    </div>
                                </MudItem>
                            }

                            <MudItem xs="12">
                                <div class="ps-card ps-card-soft">
                                    <div class="ps-card-title">
                                        <MudIcon Icon="@Icons.Material.Filled.EditNote" Size="Size.Small" />
                                        التوقيعات
                                    </div>

                                    <div class="ps-signatures">
                                        <div class="ps-sign-box">
                                            <div class="ps-sign-line"></div>
                                            <div class="ps-sign-label">إعداد / HR</div>
                                        </div>
                                        <div class="ps-sign-box">
                                            <div class="ps-sign-line"></div>
                                            <div class="ps-sign-label">مراجعة / حسابات</div>
                                        </div>
                                        <div class="ps-sign-box">
                                            <div class="ps-sign-line"></div>
                                            <div class="ps-sign-label">استلام الموظف</div>
                                        </div>
                                    </div>

                                    <div class="ps-print-meta">
                                        تم إنشاء هذه القسيمة بواسطة نظام الرواتب • @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
                                    </div>
                                </div>
                            </MudItem>
                        </MudGrid>
                    </div>
                </div>
            </div>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">إغلاق</MudButton>
        @if (_slip is not null)
        {
            <MudButton OnClick="PrintAsync"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Print">
                طباعة القسيمة
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int PayrollId { get; set; }
    [Parameter] public string CurrentUser { get; set; } = "system";

    private PayslipDto? _slip;
    private CompanyInfoDto? _company;
    private bool _loading = true;

    private decimal SeparateTotal => _slip?.SeparateBonuses.Sum(x => x.Amount) ?? 0;

    private string CompanyName => !string.IsNullOrWhiteSpace(_company?.CompanyName)
        ? _company!.CompanyName
        : "الشركة";

    private string CompanyInitials => string.IsNullOrWhiteSpace(CompanyName)
        ? "CO"
        : new string(CompanyName.Trim().Take(2).ToArray()).ToUpperInvariant();

    private string? CompanyLogoSrc => !string.IsNullOrWhiteSpace(_company?.LogoBase64)
        ? $"data:image/png;base64,{_company!.LogoBase64}"
        : _company?.LogoPath;

    private string CompanyPhoneDisplay
    {
        get
        {
            var phones = new List<string>();
            if (!string.IsNullOrWhiteSpace(_company?.Phone1)) phones.Add(_company.Phone1);
            if (!string.IsNullOrWhiteSpace(_company?.Phone2)) phones.Add(_company.Phone2!);
            return phones.Any() ? string.Join(" • ", phones) : "";
        }
    }

    private bool IsOffPayroll => !string.IsNullOrWhiteSpace(_slip?.Notes)
                                 && _slip!.Notes!.Contains("[OFFPAYROLL]", StringComparison.OrdinalIgnoreCase);

    private string DocumentTitle => IsOffPayroll ? "قسيمة دفعة خارج الراتب" : "قسيمة الراتب الشهرية";
    private string DocumentTypeLabel => IsOffPayroll ? "دفعة مستقلة خارج الراتب" : "راتب شهري";

    private string StatusPillStyle => $"background:{GetStatusColor(_slip?.PaymentStatus)};";

    private List<string> WorkflowLines => string.IsNullOrWhiteSpace(_slip?.Notes)
        ? new()
        : _slip!.Notes!
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x) && !x.Contains("[OFFPAYROLL]", StringComparison.OrdinalIgnoreCase))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _slip = await PayrollService.GetPayslipAsync(PayrollId);
            _company = await CompanyInfoService.GetCompanyInfoAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل القسيمة: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PrintAsync()
    {
        await JS.InvokeVoidAsync("printPage");
    }

    private void Close() => MudDialog.Close();

    private static string GetStatusColor(string? status) => status switch
    {
        PayrollPaymentStatuses.Paid => "#10b981",
        PayrollPaymentStatuses.PendingReview => "#f59e0b",
        PayrollPaymentStatuses.Approved => "#3b82f6",
        PayrollPaymentStatuses.Rejected => "#ef4444",
        PayrollPaymentStatuses.Cancelled => "#64748b",
        PayrollPaymentStatuses.Unpaid => "#94a3b8",
        _ => "#94a3b8"
    };
}
