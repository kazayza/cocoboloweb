@page "/hr/payroll/processor"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IPayrollService              PayrollService
@inject ICashBoxService              CashBoxService
@inject ISnackbar                    Snackbar
@inject IDialogService               DialogService
@inject AuthenticationStateProvider  AuthProvider

<PageTitle>معالجة المرتبات</PageTitle>

@* ══ Header ══ *@
<MudPaper Class="pa-4 mb-4 rounded-xl d-flex align-center gap-3 flex-wrap">
    <div>
        <MudText Typo="Typo.h5">💰 معالجة المرتبات الشهرية</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">احسب واصرف مرتبات الموظفين</MudText>
    </div>
    <MudSpacer />

    <MudTextField @bind-Value="_selectedMonth"
                  Label="الشهر"
                  Placeholder="2026-05"
                  Variant="Variant.Outlined"
                  Style="max-width:160px"
                  Margin="Margin.Dense"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Calculate"
               OnClick="CalculateAsync"
               Disabled="_calculating || string.IsNullOrWhiteSpace(_selectedMonth)">
        @(_calculating ? "جاري الحساب..." : "احسب المرتبات")
    </MudButton>
</MudPaper>

@* ══ Stats ══ *@
@if (_calculations.Any())
{
    <MudGrid Class="mb-3">
        <MudItem xs="6" md="3">
            <MudPaper Class="pa-3 rounded-xl text-center" Style="border:2px solid #10b981">
                <MudText Typo="Typo.caption">الموظفين المختارين</MudText>
                <MudText Typo="Typo.h5" Color="Color.Success">
                    <b>@_calculations.Count(c => c.IsSelected && !c.HasExistingPayroll)</b>
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="pa-3 rounded-xl text-center" Style="border:2px solid #3b82f6">
                <MudText Typo="Typo.caption">إجمالي المستحقات</MudText>
                <MudText Typo="Typo.h6" Color="Color.Info">
                    <b>@SelectedSum(c => c.GrossSalary).ToString("N0")</b> جـ
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="pa-3 rounded-xl text-center" Style="border:2px solid #ef4444">
                <MudText Typo="Typo.caption">إجمالي الخصومات</MudText>
                <MudText Typo="Typo.h6" Color="Color.Error">
                    <b>@SelectedSum(c => c.TotalDeductions).ToString("N0")</b> جـ
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" md="3">
            <MudPaper Class="pa-3 rounded-xl text-center" Style="border:2px solid #f59e0b">
                <MudText Typo="Typo.caption">صافي الإجمالي</MudText>
                <MudText Typo="Typo.h5" Color="Color.Warning">
                    <b>@SelectedSum(c => c.NetSalary).ToString("N0")</b> جـ
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ══ Toolbar الصرف ══ *@
    <MudPaper Class="pa-3 mb-3 rounded-xl d-flex align-center gap-3 flex-wrap">
        <MudSelect T="int?"
                   @bind-Value="_selectedCashBoxId"
                   Label="الخزينة *"
                   Variant="Variant.Outlined"
                   Style="max-width:260px"
                   Margin="Margin.Dense">
            @foreach (var cb in _cashBoxes)
            {
                <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">
                    @cb.CashBoxName (@cb.CurrentBalance.ToString("N0") جـ)
                </MudSelectItem>
            }
        </MudSelect>

        @* ✅ زرار حفظ بدون صرف *@
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveWithoutPayAsync"
                   Disabled="_processing || !HasSelected">
            حفظ بدون صرف
        </MudButton>

        @* زرار الصرف الكامل *@
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Payment"
                   OnClick="ConfirmProcessAsync"
                   Disabled="_processing || !_selectedCashBoxId.HasValue || !HasSelected">
            @(_processing ? "جاري الصرف..." : $"صرف المرتبات ({SelectedCount} موظف)")
        </MudButton>
    </MudPaper>

    @* ══ Table ══ *@
    <MudPaper Class="rounded-xl overflow-hidden">
        @if (_calculating)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }

        <MudTable Items="_calculations" Dense Hover Striped Elevation="0">
            <HeaderContent>
                <MudTh>
                    <MudCheckBox T="bool" Value="_allSelected"
                                 ValueChanged="ToggleAll" />
                </MudTh>
                <MudTh>الموظف</MudTh>
                <MudTh>الأساسي</MudTh>
                <MudTh>الحضور</MudTh>
                <MudTh>خصم غياب</MudTh>
                <MudTh>خصم تأخير</MudTh>
                <MudTh>خصم سلف</MudTh>
                <MudTh>مكافآت</MudTh>
                <MudTh>جزاءات</MudTh>
                <MudTh>الصافي</MudTh>
                <MudTh>إجراءات</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudCheckBox T="bool"
                                 Value="@context.IsSelected"
                                 ValueChanged="@(v => { context.IsSelected = v; StateHasChanged(); })"
                                 Disabled="context.HasExistingPayroll" />
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2"><b>@context.EmployeeName</b></MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @(context.Department ?? "—")
                    </MudText>
                    @if (context.HasExistingPayroll)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">مصروف مسبقاً</MudChip>
                    }
                    @if (!string.IsNullOrWhiteSpace(context.Warning) && !context.HasExistingPayroll)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Warning</MudChip>
                    }
                </MudTd>
                <MudTd>@context.BasicSalary.ToString("N2") جـ</MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@context.PresentDays / @context.WorkingDaysInMonth</MudText>
                    <MudChip T="string" Size="Size.Small"
                             Color="@(context.IsManualAttendance ? Color.Warning : Color.Default)">
                        @(context.IsManualAttendance ? "يدوي" : "بصمة")
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudText Color="@(context.AbsenceDeduction > 0 ? Color.Error : Color.Default)">
                        @(context.AbsenceDeduction > 0 ? $"- {context.AbsenceDeduction:N2}" : "—")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Color="@(context.LateDeduction > 0 ? Color.Error : Color.Default)">
                        @(context.LateDeduction > 0 ? $"- {context.LateDeduction:N2}" : "—")
                    </MudText>
                    @if (context.LateMinutesTotal > 0)
                    {
                        <MudText Typo="Typo.caption">(@context.LateDisplay)</MudText>
                    }
                </MudTd>
                <MudTd>
                    <MudText Color="@(context.LoanDeduction > 0 ? Color.Error : Color.Default)">
                        @(context.LoanDeduction > 0 ? $"- {context.LoanDeduction:N2}" : "—")
                    </MudText>
                    @if (context.LoanItems.Any())
                    {
                        <MudText Typo="Typo.caption">
                            (@context.LoanItems.Count قسط)
                        </MudText>
                    }
                </MudTd>
                <MudTd>
                    <MudText Color="Color.Success">
                        @(context.TotalBonusInPayroll > 0 ? $"+ {context.TotalBonusInPayroll:N2}" : "—")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText Color="@(context.TotalPenalties > 0 ? Color.Error : Color.Default)">
                        @(context.TotalPenalties > 0 ? $"- {context.TotalPenalties:N2}" : "—")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudText><b>@context.NetSalary.ToString("N2") جـ</b></MudText>
                </MudTd>
                <MudTd>
                    @if (!context.HasExistingPayroll)
                    {
                        @* تعديل البنود *@
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small" Color="Color.Primary"
                                       Title="إضافة جزاء أو مكافأة"
                                       OnClick="@(() => OpenItemsDialogAsync(context))" />

                        @* ✅ إزالة موظف من القائمة *@
                        <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                       Size="Size.Small" Color="Color.Error"
                                       Title="إزالة من القائمة"
                                       OnClick="@(() => RemoveEmployee(context))" />
                    }
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4" Color="Color.Secondary" Align="Align.Center">
                    اضغط "احسب المرتبات" أولاً
                </MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
}

@code {
    private string  _selectedMonth    = DateTime.Today.ToString("yyyy-MM");
    private int?    _selectedCashBoxId;
    private bool    _calculating;
    private bool    _processing;
    private bool    _allSelected      = true;
    private string  _currentUser      = "system";

    private List<PayrollCalculationDto> _calculations = new();
    private List<CashBoxListDto>        _cashBoxes    = new();

    private bool    HasSelected   => _calculations.Any(c => c.IsSelected && !c.HasExistingPayroll);
    private int     SelectedCount => _calculations.Count(c => c.IsSelected && !c.HasExistingPayroll);
    private decimal SelectedSum(Func<PayrollCalculationDto, decimal> selector) =>
        _calculations.Where(c => c.IsSelected && !c.HasExistingPayroll).Sum(selector);

    protected override async Task OnInitializedAsync()
    {
        var auth     = await AuthProvider.GetAuthenticationStateAsync();
        _currentUser = auth.User.Identity?.Name ?? "system";
        _cashBoxes   = await CashBoxService.GetCashBoxesAsync(activeOnly: true);
        var def = _cashBoxes.FirstOrDefault(c => c.IsDefault) ?? _cashBoxes.FirstOrDefault();
        if (def != null) _selectedCashBoxId = def.CashBoxId;
    }

    private async Task CalculateAsync()
    {
        if (!ValidateMonth(_selectedMonth))
        {
            Snackbar.Add("صيغة الشهر غير صحيحة (مثال: 2026-05)", Severity.Warning);
            return;
        }
        _calculating = true;
        StateHasChanged();
        try
        {
            _calculations = await PayrollService.CalculateMonthAsync(_selectedMonth);
            foreach (var c in _calculations)
                c.IsSelected = !c.HasExistingPayroll;
            _allSelected = true;
            Snackbar.Add($"تم حساب {_calculations.Count} موظف", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _calculating = false;
        }
    }

    private void RemoveEmployee(PayrollCalculationDto calc)
    {
        _calculations.Remove(calc);
        StateHasChanged();
        Snackbar.Add($"تم إزالة {calc.EmployeeName}", Severity.Info);
    }

    private async Task SaveWithoutPayAsync()
    {
        if (!HasSelected) { Snackbar.Add("لم يتم اختيار أي موظف", Severity.Warning); return; }

        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message,    $"حفظ {SelectedCount} راتب بدون صرف؟" },
            { x => x.YesText,    "نعم، حفظ" },
            { x => x.CancelText, "إلغاء" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأكيد الحفظ", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });
        if ((await dialog.Result) is { Canceled: true }) return;

        _processing = true;
        StateHasChanged();
        try
        {
            var (ok, msg, _) = await PayrollService.SaveOnlyAsync(
                _selectedMonth, _calculations, _currentUser);
            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
            if (ok) await CalculateAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally { _processing = false; }
    }

    private async Task ConfirmProcessAsync()
    {
        if (!_selectedCashBoxId.HasValue)
        {
            Snackbar.Add("يرجى اختيار الخزينة", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message,    $"صرف مرتبات {SelectedCount} موظف؟\nالإجمالي: {SelectedSum(c => c.NetSalary):N2} جـ" },
            { x => x.YesText,    "نعم، صرف" },
            { x => x.CancelText, "إلغاء" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأكيد الصرف", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });
        if ((await dialog.Result) is { Canceled: true }) return;

        _processing = true;
        StateHasChanged();
        try
        {
            var (ok, msg, _) = await PayrollService.ProcessMonthAsync(
                _selectedMonth, _calculations, _selectedCashBoxId!.Value, _currentUser);
            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
            if (ok) await CalculateAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally { _processing = false; }
    }

    private async Task OpenItemsDialogAsync(PayrollCalculationDto calc)
    {
        var parameters = new DialogParameters
        {
            [nameof(PayrollItemsDialog.Calc)]    = calc,
            [nameof(PayrollItemsDialog.OnSaved)] =
                EventCallback.Factory.Create(this, StateHasChanged)
        };
        await DialogService.ShowAsync<PayrollItemsDialog>(
            $"بنود راتب {calc.EmployeeName}",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
    }

    private void ToggleAll(bool val)
    {
        _allSelected = val;
        foreach (var c in _calculations.Where(c => !c.HasExistingPayroll))
            c.IsSelected = val;
        StateHasChanged();
    }

    private static bool ValidateMonth(string? m) =>
        !string.IsNullOrWhiteSpace(m) &&
        DateTime.TryParseExact(m + "-01", "yyyy-MM-dd",
            null, System.Globalization.DateTimeStyles.None, out _);
}
