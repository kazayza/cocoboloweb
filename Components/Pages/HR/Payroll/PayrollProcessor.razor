@page "/hr/payroll/processor"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IPayrollService PayrollService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<PageTitle>معالجة المرتبات</PageTitle>

<MudPaper Class="pa-4 mb-4 rounded-xl d-flex align-center gap-3 flex-wrap">
    <div>
        <MudText Typo="Typo.h5">معالجة المرتبات الشهرية</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            احسب المرتبات، راجع البنود، ثم أرسلها للمراجعة بدون صرف مباشر.
        </MudText>
    </div>

    <MudSpacer />

    <MudTextField @bind-Value="_selectedMonth"
                  Label="الشهر"
                  Placeholder="2026-05"
                  Variant="Variant.Outlined"
                  Style="max-width:160px"
                  Margin="Margin.Dense"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Calculate"
               OnClick="CalculateAsync"
               Disabled="_calculating || string.IsNullOrWhiteSpace(_selectedMonth)">
        @(_calculating ? "جاري الحساب..." : "احسب المرتبات")
    </MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Default"
               StartIcon="@Icons.Material.Filled.ListAlt"
               OnClick='@(() => Nav.NavigateTo("/hr/payroll"))'>
        سجل الرواتب
    </MudButton>

    <MudButton Variant="Variant.Outlined"
               Color="Color.Info"
               StartIcon="@Icons.Material.Filled.CardGiftcard"
               OnClick='@(() => Nav.NavigateTo("/hr/payroll/bonuses"))'>
        دفعات خارج الراتب
    </MudButton>
</MudPaper>

<MudGrid Class="mb-4">
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-4 rounded-xl h-100" Style="border:1px solid rgba(59,130,246,.22);background:linear-gradient(135deg, rgba(59,130,246,.10), rgba(59,130,246,.03));">
            <MudText Typo="Typo.caption" Color="Color.Secondary">خطوات العمل</MudText>
            <MudStack Spacing="1" Class="mt-2">
                <MudText Typo="Typo.body2">1) احسب مرتبات الشهر</MudText>
                <MudText Typo="Typo.body2">2) راجع وعدّل البنود لكل موظف</MudText>
                <MudText Typo="Typo.body2">3) احفظ وأرسل للمراجعة</MudText>
                <MudText Typo="Typo.body2">4) الاعتماد والصرف من سجل الرواتب</MudText>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-3">
            هذه الشاشة لا تقوم بالصرف. بعد الإرسال للمراجعة سيتم إشعار مدير الحسابات والأدمن، ثم يتم الاعتماد والصرف الفردي من شاشة سجل الرواتب.
        </MudAlert>

        <MudGrid>
            <MudItem xs="6" md="3">
                <MudPaper Class="pa-3 rounded-xl text-center h-100" Style="border:1px solid rgba(16,185,129,.25)">
                    <MudText Typo="Typo.caption">جاهز للإرسال</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Success"><b>@SelectedCount</b></MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="pa-3 rounded-xl text-center h-100" Style="border:1px solid rgba(239,68,68,.25)">
                    <MudText Typo="Typo.caption">إجمالي الخصومات</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Error"><b>@SelectedSum(c => c.TotalDeductions).ToString("N0")</b> جـ</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="pa-3 rounded-xl text-center h-100" Style="border:1px solid rgba(14,165,233,.25)">
                    <MudText Typo="Typo.caption">إضافات خارج الراتب</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Info"><b>@SelectedSum(c => c.TotalSeparateBonuses).ToString("N0")</b> جـ</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="pa-3 rounded-xl text-center h-100" Style="border:1px solid rgba(245,158,11,.25)">
                    <MudText Typo="Typo.caption">صافي داخل الراتب</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Warning"><b>@SelectedSum(c => c.NetSalary).ToString("N0")</b> جـ</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudItem>
</MudGrid>

@if (_calculations.Any())
{
    <MudPaper Class="pa-3 mb-3 rounded-xl d-flex align-center gap-3 flex-wrap">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Send"
                   OnClick="SaveWithoutPayAsync"
                   Disabled="_processing || !HasSelected">
            @(_processing ? "جاري الإرسال..." : $"حفظ وإرسال للمراجعة ({SelectedCount} موظف)")
        </MudButton>

        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined">
            تم تعديل خصومات تلقائية: @_calculations.Count(c => c.HasManualOverrides)
        </MudChip>

        <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined">
            مرتبات مسجلة مسبقًا: @_calculations.Count(c => c.HasExistingPayroll)
        </MudChip>

        <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined">
            إضافات داخل الراتب: @_calculations.Sum(c => c.TotalBonusInPayroll).ToString("N0") جـ
        </MudChip>
    </MudPaper>

    <MudPaper Class="rounded-xl overflow-hidden">
        @if (_calculating)
        {
            <MudProgressLinear Indeterminate Color="Color.Primary" />
        }

        <MudTable Items="_calculations" Dense Hover Striped Elevation="0">
            <HeaderContent>
                <MudTh Style="width:50px">
                    <MudCheckBox T="bool" Value="_allSelected" ValueChanged="ToggleAll" />
                </MudTh>
                <MudTh>الموظف</MudTh>
                <MudTh>الحضور</MudTh>
                <MudTh>الخصومات الآلية</MudTh>
                <MudTh>التعديلات اليدوية</MudTh>
                <MudTh>الصافي داخل الراتب</MudTh>
                <MudTh>إضافات منفصلة</MudTh>
                <MudTh>الحالة</MudTh>
                <MudTh>إجراءات</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudCheckBox T="bool"
                                 Value="@context.IsSelected"
                                 ValueChanged="@(v => UpdateSelection(context, v))"
                                 Disabled="context.HasExistingPayroll" />
                </MudTd>

                <MudTd>
                    <MudText Typo="Typo.body2"><b>@context.EmployeeName</b></MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @(context.Department ?? "—") · أساسي @context.BasicSalary.ToString("N2") جـ
                    </MudText>
                </MudTd>

                <MudTd>
                    <MudText Typo="Typo.body2">@context.PresentDays / @context.WorkingDaysInMonth</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        غياب @context.AbsenceDays يوم · تأخير @context.LateDisplay
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsManualAttendance ? Color.Warning : Color.Default)">
                        @(context.IsManualAttendance ? "يدوي" : "بصمة")
                    </MudChip>
                </MudTd>

                <MudTd>
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption">غياب: @FormatMoney(context.AbsenceDeduction)</MudText>
                        <MudText Typo="Typo.caption">تأخير: @FormatMoney(context.LateDeduction)</MudText>
                        <MudText Typo="Typo.caption">سلف: @FormatMoney(context.LoanDeduction)</MudText>
                        @if (context.HasManualOverrides)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                خصومات معدلة يدويًا
                            </MudChip>
                        }
                    </MudStack>
                </MudTd>

                <MudTd>
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption">جزاءات/خصومات: @FormatMoney(context.TotalPenalties)</MudText>
                        <MudText Typo="Typo.caption">إضافات داخل الراتب: @FormatMoney(context.TotalBonusInPayroll)</MudText>
                        <MudText Typo="Typo.caption">عدد البنود: @(context.Penalties.Count + context.BonusItems.Count + context.SeparateBonuses.Count)</MudText>
                    </MudStack>
                </MudTd>

                <MudTd>
                    <MudText Typo="Typo.body1"><b>@context.NetSalary.ToString("N2") جـ</b></MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        إجمالي المستحق @context.GrossSalary.ToString("N2") جـ
                    </MudText>
                </MudTd>

                <MudTd>
                    @if (context.TotalSeparateBonuses > 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Info"><b>@context.TotalSeparateBonuses.ToString("N2") جـ</b></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.SeparateBonuses.Count بند منفصل</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">لا يوجد</MudText>
                    }
                </MudTd>

                <MudTd>
                    @if (context.HasExistingPayroll)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">مسجل مسبقًا</MudChip>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Warning</MudText>
                    }
                    else if (!string.IsNullOrWhiteSpace(context.Warning))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">ملاحظة</MudChip>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Warning</MudText>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">جاهز للمراجعة</MudChip>
                    }
                </MudTd>

                <MudTd>
                    @if (!context.HasExistingPayroll)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       Title="تعديل البنود"
                                       OnClick="@(() => OpenItemsDialogAsync(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       Title="إزالة من المعالجة"
                                       OnClick="@(() => RemoveEmployee(context))" />
                    }
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4" Color="Color.Secondary" Align="Align.Center">
                    اضغط "احسب المرتبات" أولاً
                </MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-6 rounded-xl text-center">
        <MudIcon Icon="@Icons.Material.Filled.Payments" Size="Size.Large" Color="Color.Default" Class="mb-2" />
        <MudText Typo="Typo.h6">ابدأ بحساب المرتبات للشهر المطلوب</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            بعد الحساب ستتمكن من مراجعة الغياب والتأخير والجزاءات والمكافآت ثم إرسال البيانات للمراجعة.
        </MudText>
    </MudPaper>
}

@code {
    private string _selectedMonth = DateTime.Today.ToString("yyyy-MM");
    private bool _calculating;
    private bool _processing;
    private bool _allSelected = true;
    private string _currentUser = "system";

    private List<PayrollCalculationDto> _calculations = new();

    private bool HasSelected => _calculations.Any(c => c.IsSelected && !c.HasExistingPayroll);
    private int SelectedCount => _calculations.Count(c => c.IsSelected && !c.HasExistingPayroll);
    private decimal SelectedSum(Func<PayrollCalculationDto, decimal> selector) =>
        _calculations.Where(c => c.IsSelected && !c.HasExistingPayroll).Sum(selector);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUser = user.Identity?.Name ?? "system";

        var canView = user.IsInRole("Admin")
                      || user.IsInRole("HrManager")
                      || user.IsInRole("HRManager")
                      || user.IsInRole("AccountManager")
                      || user.IsInRole("Accountant")
                      || user.IsInRole("AccountsManager")
                      || user.HasClaim("Permission", "frm_Payroll:View");

        if (!canView)
        {
            Nav.NavigateTo("/access-denied");
            return;
        }
    }

    private async Task CalculateAsync()
    {
        if (!ValidateMonth(_selectedMonth))
        {
            Snackbar.Add("صيغة الشهر غير صحيحة (مثال: 2026-05)", Severity.Warning);
            return;
        }

        _calculating = true;
        StateHasChanged();

        try
        {
            _calculations = await PayrollService.CalculateMonthAsync(_selectedMonth);
            foreach (var calc in _calculations)
                calc.IsSelected = !calc.HasExistingPayroll;

            _allSelected = _calculations.Any(c => !c.HasExistingPayroll);
            Snackbar.Add($"تم حساب {_calculations.Count} موظف", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _calculating = false;
            StateHasChanged();
        }
    }

    private void RemoveEmployee(PayrollCalculationDto calc)
    {
        _calculations.Remove(calc);
        SyncSelectAll();
        Snackbar.Add($"تم إزالة {calc.EmployeeName} من هذه المعالجة", Severity.Info);
    }

    private async Task SaveWithoutPayAsync()
    {
        if (!HasSelected)
        {
            Snackbar.Add("لم يتم اختيار أي موظف", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message,    $"سيتم حفظ وإرسال {SelectedCount} راتب للمراجعة. هل تريد المتابعة؟" },
            { x => x.YesText,    "نعم، إرسال للمراجعة" },
            { x => x.CancelText, "إلغاء" }
        };

        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأكيد الإرسال", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if ((await dialog.Result) is { Canceled: true })
            return;

        _processing = true;
        StateHasChanged();

        try
        {
            var (ok, msg, _) = await PayrollService.SaveOnlyAsync(_selectedMonth, _calculations, _currentUser);
            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
            if (ok)
                await CalculateAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
            StateHasChanged();
        }
    }

    private async Task OpenItemsDialogAsync(PayrollCalculationDto calc)
    {
        var parameters = new DialogParameters
        {
            [nameof(PayrollItemsDialog.Calc)] = calc,
            [nameof(PayrollItemsDialog.OnSaved)] = EventCallback.Factory.Create(this, StateHasChanged)
        };

        await DialogService.ShowAsync<PayrollItemsDialog>(
            $"بنود راتب {calc.EmployeeName}",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true });
    }

    private void ToggleAll(bool value)
    {
        _allSelected = value;
        foreach (var calc in _calculations.Where(c => !c.HasExistingPayroll))
            calc.IsSelected = value;

        StateHasChanged();
    }

    private void UpdateSelection(PayrollCalculationDto calc, bool value)
    {
        calc.IsSelected = value;
        SyncSelectAll();
        StateHasChanged();
    }

    private void SyncSelectAll()
    {
        var selectable = _calculations.Where(c => !c.HasExistingPayroll).ToList();
        _allSelected = selectable.Any() && selectable.All(c => c.IsSelected);
    }

    private static string FormatMoney(decimal amount) => amount <= 0 ? "—" : amount.ToString("N2") + " جـ";

    private static bool ValidateMonth(string? month) =>
        !string.IsNullOrWhiteSpace(month)
        && DateTime.TryParseExact(month + "-01", "yyyy-MM-dd", null,
            System.Globalization.DateTimeStyles.None, out _);
}
