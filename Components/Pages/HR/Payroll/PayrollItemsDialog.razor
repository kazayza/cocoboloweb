@* Dialog لإضافة جزاءات ومكافآت على راتب موظف *@
@using COCOBOLOERPNEW.DTOs
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">✏️ بنود راتب @Calc.EmployeeName</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            @* ── ملخص ── *@
            <MudItem xs="12">
                <MudPaper Class="pa-3 rounded-xl" Style="background:#f8fafc">
                    <MudGrid Spacing="1">
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption">الأساسي</MudText>
                            <MudText><b>@Calc.BasicSalary.ToString("N2") جـ</b></MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption">خصم غياب</MudText>
                            <MudText Color="Color.Error">@Calc.AbsenceDeduction.ToString("N2") جـ</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption">خصم تأخير</MudText>
                            <MudText Color="Color.Error">@Calc.LateDeduction.ToString("N2") جـ</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption">خصم سلف</MudText>
                            <MudText Color="Color.Error">@Calc.LoanDeduction.ToString("N2") جـ</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudDivider Class="my-1" />
                            <MudText Typo="Typo.subtitle1">
                                الصافي: <b>@Calc.NetSalary.ToString("N2") جـ</b>
                            </MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            @* ── جزاءات ── *@
            <MudItem xs="12">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle2" Color="Color.Error">🔴 جزاءات وخصومات</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small" Color="Color.Error"
                                   OnClick="AddPenalty" />
                </div>
                @foreach (var (item, idx) in Calc.Penalties.Select((x, i) => (x, i)))
                {
                    <MudPaper Class="pa-2 mb-1 rounded-lg d-flex gap-2 align-center"
                              Style="border:1px solid #fee2e2">
                        <MudTextField @bind-Value="item.Description"
                                      Placeholder="وصف الجزاء"
                                      Variant="Variant.Text"
                                      Margin="Margin.Dense"
                                      Style="flex:1" />
                        <MudNumericField T="decimal"
                                         @bind-Value="item.Amount"
                                         Placeholder="المبلغ"
                                         Variant="Variant.Text"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Style="max-width:120px" />
                        <MudText>جـ</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => Calc.Penalties.RemoveAt(idx))" />
                    </MudPaper>
                }
                @if (!Calc.Penalties.Any())
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">لا توجد جزاءات</MudText>
                }
            </MudItem>

            @* ── مكافآت داخل الراتب ── *@
            <MudItem xs="12">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle2" Color="Color.Success">🟢 مكافآت داخل الراتب</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small" Color="Color.Success"
                                   OnClick="AddBonus" />
                </div>
                @foreach (var (item, idx) in Calc.BonusItems.Select((x, i) => (x, i)))
                {
                    <MudPaper Class="pa-2 mb-1 rounded-lg d-flex gap-2 align-center"
                              Style="border:1px solid #dcfce7">
                        <MudTextField @bind-Value="item.Description"
                                      Placeholder="وصف المكافأة"
                                      Variant="Variant.Text"
                                      Margin="Margin.Dense"
                                      Style="flex:1" />
                        <MudNumericField T="decimal"
                                         @bind-Value="item.Amount"
                                         Placeholder="المبلغ"
                                         Variant="Variant.Text"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Style="max-width:120px" />
                        <MudText>جـ</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => Calc.BonusItems.RemoveAt(idx))" />
                    </MudPaper>
                }
                @if (!Calc.BonusItems.Any())
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        لا توجد مكافآت - تأثر في صافي الراتب
                    </MudText>
                }
            </MudItem>

            @* ── مكافآت منفصلة ── *@
            <MudItem xs="12">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle2" Color="Color.Info">🔵 مكافآت منفصلة (خارج الراتب)</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small" Color="Color.Info"
                                   OnClick="AddSeparateBonus" />
                </div>
                @foreach (var (item, idx) in Calc.SeparateBonuses.Select((x, i) => (x, i)))
                {
                    <MudPaper Class="pa-2 mb-1 rounded-lg d-flex gap-2 align-center"
                              Style="border:1px solid #dbeafe">
                        <MudTextField @bind-Value="item.Description"
                                      Placeholder="وصف المكافأة"
                                      Variant="Variant.Text"
                                      Margin="Margin.Dense"
                                      Style="flex:1" />
                        <MudNumericField T="decimal"
                                         @bind-Value="item.Amount"
                                         Placeholder="المبلغ"
                                         Variant="Variant.Text"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Style="max-width:120px" />
                        <MudText>جـ</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => Calc.SeparateBonuses.RemoveAt(idx))" />
                    </MudPaper>
                }
                @if (!Calc.SeparateBonuses.Any())
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        لا توجد - حركة خزينة مستقلة
                    </MudText>
                }
            </MudItem>

            @* ── الصافي المحدّث ── *@
            <MudItem xs="12">
                <MudPaper Class="pa-3 rounded-xl" Style="background:#f0fdf4;border:2px solid #10b981">
                    <MudText Typo="Typo.subtitle1" Color="Color.Success">
                        الصافي المحدّث: <b>@Calc.NetSalary.ToString("N2") جـ</b>
                    </MudText>
                    @if (Calc.TotalSeparateBonuses > 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Info">
                            + مكافآت منفصلة: @Calc.TotalSeparateBonuses.ToString("N2") جـ
                        </MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">إلغاء</MudButton>
        <MudButton OnClick="Save"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Check">
            تأكيد
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter]          public PayrollCalculationDto Calc   { get; set; } = null!;
    [Parameter]          public EventCallback OnSaved        { get; set; }

    private void AddPenalty() => Calc.Penalties.Add(new PayrollDetailDto
    {
        DetailType  = "Penalty",
        IsDeduction = true,
        PaymentType = "InPayroll"
    });

    private void AddBonus() => Calc.BonusItems.Add(new PayrollDetailDto
    {
        DetailType  = "Bonus",
        IsDeduction = false,
        PaymentType = "InPayroll"
    });

    private void AddSeparateBonus() => Calc.SeparateBonuses.Add(new PayrollDetailDto
    {
        DetailType  = "BonusSeparate",
        IsDeduction = false,
        PaymentType = "Separate"
    });

    private async Task Save()
    {
        // حذف البنود الفاضية
        Calc.Penalties.RemoveAll(p => p.Amount <= 0 || string.IsNullOrWhiteSpace(p.Description));
        Calc.BonusItems.RemoveAll(b => b.Amount <= 0 || string.IsNullOrWhiteSpace(b.Description));
        Calc.SeparateBonuses.RemoveAll(b => b.Amount <= 0 || string.IsNullOrWhiteSpace(b.Description));

        await OnSaved.InvokeAsync();
        MudDialog.Close();
    }

    private void Cancel() => MudDialog.Cancel();
}
