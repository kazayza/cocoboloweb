@page "/hr/payroll"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IPayrollService PayrollService
@inject ICashBoxService CashBoxService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS

<PageTitle>سجل المرتبات</PageTitle>

<MudPaper Class="pa-4 mb-4 rounded-xl d-flex align-center gap-3 flex-wrap">
    <div>
        <MudText Typo="Typo.h5"> سجل المرتبات</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            مراجعة واعتماد وصرف المرتبات المحفوظة من شاشة المعالجة.
        </MudText>
    </div>

    <MudSpacer />

    <MudButton Variant="Variant.Outlined"
               Color="Color.Info"
               StartIcon="@Icons.Material.Filled.CardGiftcard"
               OnClick='@(() => Nav.NavigateTo("/hr/payroll/bonuses"))'>
        دفعات خارج الراتب
    </MudButton>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick='@(() => Nav.NavigateTo("/hr/payroll/processor"))'>
        معالجة مرتبات جديدة
    </MudButton>
</MudPaper>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-4">
    المسار الصحيح: <b>معالجة الشهر</b> ← <b>حفظ وإرسال للمراجعة</b> ← <b>اعتماد</b> ← <b>صرف فردي</b>. 
    الإضافات المنفصلة تُسجل داخل الراتب للمراجعة ولكن تُصرف كحركة مستقلة عند الدفع.
</MudAlert>

@if (_stats is not null)
{
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-xl h-100" Style="background:linear-gradient(135deg,#10b981,#059669);color:white">
                <MudText Typo="Typo.caption" Style="opacity:.85">إجمالي الصافي</MudText>
                <MudText Typo="Typo.h6"><b>@_stats.TotalNetThisMonth.ToString("N0")</b> جـ</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-xl h-100" Style="background:linear-gradient(135deg,#f59e0b,#d97706);color:white">
                <MudText Typo="Typo.caption" Style="opacity:.85">قيد المراجعة</MudText>
                <MudText Typo="Typo.h4"><b>@_stats.ReviewCount</b></MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-xl h-100" Style="background:linear-gradient(135deg,#3b82f6,#2563eb);color:white">
                <MudText Typo="Typo.caption" Style="opacity:.85">معتمد</MudText>
                <MudText Typo="Typo.h4"><b>@_stats.ApprovedCount</b></MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-xl h-100" Style="background:linear-gradient(135deg,#14b8a6,#0f766e);color:white">
                <MudText Typo="Typo.caption" Style="opacity:.85">مدفوع</MudText>
                <MudText Typo="Typo.h4"><b>@_stats.PaidCount</b></MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-xl h-100" Style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);color:white">
                <MudText Typo="Typo.caption" Style="opacity:.85">إضافات منفصلة</MudText>
                <MudText Typo="Typo.h6"><b>@_stats.TotalSeparateBonuses.ToString("N0")</b> جـ</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudPaper Class="pa-4 rounded-xl h-100" Style="background:linear-gradient(135deg,#64748b,#475569);color:white">
                <MudText Typo="Typo.caption" Style="opacity:.85">غير مدفوع قديم</MudText>
                <MudText Typo="Typo.h4"><b>@_stats.PendingCount</b></MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

<div class="sticky-filter-shell">
    <MudPaper Class="pa-3 mb-3 rounded-xl d-flex align-center gap-3 flex-wrap">
        <MudTextField @bind-Value="_filter.SearchText"
                      Placeholder="بحث باسم الموظف أو القسم"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Style="min-width:220px"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Clearable="true"
                      OnKeyUp="OnSearchKeyUp" />

        <MudTextField @bind-Value="_filter.PayrollMonth"
                      Placeholder="الشهر 2026-05"
                      Style="max-width:150px"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      OnKeyUp="OnSearchKeyUp" />

        <MudSelect T="string"
                   @bind-Value="_selectedStatus"
                   Placeholder="الحالة"
                   Style="min-width:170px"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Clearable="true">
            <MudSelectItem T="string" Value="@PayrollPaymentStatuses.PendingReview">قيد المراجعة</MudSelectItem>
            <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Approved">معتمد</MudSelectItem>
            <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Paid">مدفوع</MudSelectItem>
            <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Rejected">مرفوض</MudSelectItem>
            <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Unpaid">غير مدفوع</MudSelectItem>
            <MudSelectItem T="string" Value="@PayrollPaymentStatuses.Cancelled">ملغي</MudSelectItem>
        </MudSelect>

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="SearchAsync">
            بحث
        </MudButton>

        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Rounded.TableChart"
                   Style="color:#10B981; border-color:#10B981;"
                   OnClick="ExportExcelAsync"
                   Disabled="_exporting"
                   Class="no-print">
            @(_exporting ? "جاري..." : "تصدير Excel")
        </MudButton>
    </MudPaper>
</div>

<MudPaper Class="rounded-xl overflow-hidden">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" />
    }

    <MudTable Items="_payrolls" Dense Hover Striped Elevation="0" Loading="_loading">
        <HeaderContent>
            <MudTh>الموظف</MudTh>
            <MudTh>الشهر</MudTh>
            <MudTh>المبالغ</MudTh>
            <MudTh>الحضور</MudTh>
            <MudTh>الحالة</MudTh>
            <MudTh>إجراءات</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText><b>@context.EmployeeName</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @EmployeeMeta(context)
                </MudText>
            </MudTd>

            <MudTd>
                <MudText Typo="Typo.body2">@FormatMonth(context.PayrollMonth)</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.PayrollMonth</MudText>
            </MudTd>

            <MudTd>
                <MudText Typo="Typo.body2">أساسي: <b>@context.BasicSalary.ToString("N2")</b> جـ</MudText>
                <MudText Typo="Typo.caption" Color="Color.Success">إضافات: @context.BonusInPayroll.ToString("N2") جـ</MudText>
                <MudText Typo="Typo.caption" Color="Color.Error">خصومات: @context.TotalDeductions.ToString("N2") جـ</MudText>
                <MudText Typo="Typo.body2"><b>الصافي: @context.NetSalary.ToString("N2") جـ</b></MudText>
            </MudTd>

            <MudTd>
                <MudText Typo="Typo.body2">@context.PresentDays / @context.WorkingDaysInMonth</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    غياب @context.AbsenceDays يوم · تأخير @context.LateDisplay
                </MudText>
                <MudChip T="string" Size="Size.Small" Color="@(context.IsManualAttendance ? Color.Warning : Color.Default)">
                    @(context.IsManualAttendance ? "يدوي" : "بصمة")
                </MudChip>
            </MudTd>

            <MudTd>
                <MudChip T="string"
                         Size="Size.Small"
                         Style="@($"background:{context.StatusColor};color:white")">
                    @context.PaymentStatus
                </MudChip>
                @if (context.PaymentDate.HasValue)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @context.PaymentDate.Value.ToString("dd/MM/yyyy HH:mm")
                    </MudText>
                }
                else if (context.CreatedAt.HasValue)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        تم الإنشاء @context.CreatedAt.Value.ToString("dd/MM/yyyy")
                    </MudText>
                }
            </MudTd>

            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Receipt"
                               Size="Size.Small"
                               Color="Color.Primary"
                               Title="قسيمة الراتب"
                               OnClick="@(() => OpenPayslipAsync(context.PayrollID))" />

                @if (context.PaymentStatus == PayrollPaymentStatuses.PendingReview && _canReview)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                   Size="Size.Small"
                                   Color="Color.Success"
                                   Title="اعتماد"
                                   OnClick="@(() => ApproveAsync(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   Title="رفض"
                                   OnClick="@(() => OpenRejectDialog(context))" />
                }

                @if ((context.PaymentStatus == PayrollPaymentStatuses.Approved || context.PaymentStatus == PayrollPaymentStatuses.Unpaid) && _canPay)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Payment"
                                   Size="Size.Small"
                                   Color="Color.Success"
                                   Title="صرف فردي"
                                   OnClick="@(() => OpenPayDialog(context))" />
                }

                @if (context.PaymentStatus != PayrollPaymentStatuses.Paid)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   Title="إلغاء"
                                   OnClick="@(() => CancelAsync(context))" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4" Color="Color.Secondary" Align="Align.Center">
                لا توجد مرتبات مطابقة للفلاتر الحالية
            </MudText>
        </NoRecordsContent>
    </MudTable>

    @if (_totalPages > 1)
    {
        <div class="d-flex align-center justify-space-between pa-3">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                إجمالي @_totalCount مرتب
            </MudText>
            <MudPagination Count="_totalPages"
                           Selected="_filter.PageNumber"
                           SelectedChanged="OnPageChangedAsync"
                           Color="Color.Primary" />
        </div>
    }
</MudPaper>

<MudDialog @bind-Visible="_payDialogOpen">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">صرف راتب فردي</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            سيتم صرف صافي الراتب، وأي إضافات منفصلة محفوظة على هذا الراتب ستُصرف كحركات مستقلة من نفس الخزينة.
        </MudText>
        <MudSelect T="int?" @bind-Value="_selectedPayCashBoxId" Label="الخزينة" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth>
            @foreach (var cb in _cashBoxes)
            {
                <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName (@cb.CurrentBalance.ToString("N0") جـ)</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick='@(() => _payDialogOpen = false)'>إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SubmitPayAsync">صرف</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_rejectDialogOpen">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">رفض راتب</MudText>
        <MudTextField T="string" @bind-Value="_rejectReason" Label="سبب الرفض (اختياري)" Variant="Variant.Outlined" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick='@(() => _rejectDialogOpen = false)'>إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="SubmitRejectAsync">رفض</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<PayrollListDto> _payrolls = new();
    private PayrollStatsDto? _stats;
    private PayrollFilterDto _filter = new()
    {
        PayrollMonth = DateTime.Today.ToString("yyyy-MM"),
        PageSize = 20
    };

    private string _selectedStatus = string.Empty;
    private bool _loading = true;
    private bool _exporting;
    private int _totalCount;
    private int _totalPages => (int)Math.Ceiling((double)_totalCount / _filter.PageSize);
    private string _currentUser = "system";
    private bool _canReview;
    private bool _canPay;
    private List<CashBoxListDto> _cashBoxes = new();
    private bool _payDialogOpen;
    private int _payPayrollId;
    private int? _selectedPayCashBoxId;
    private bool _rejectDialogOpen;
    private int _rejectPayrollId;
    private string? _rejectReason;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUser = user.Identity?.Name ?? "system";

        var canView = user.IsInRole("Admin")
                      || user.IsInRole("HrManager")
                      || user.IsInRole("HRManager")
                      || user.IsInRole("AccountManager")
                      || user.IsInRole("Accountant")
                      || user.IsInRole("AccountsManager")
                      || user.HasClaim("Permission", "frmPayrollProcessor:View")
                      || user.HasClaim("Permission", "frm_Payroll:View");

        _canReview = user.IsInRole("Admin") || user.IsInRole("AccountManager");
        _canPay = user.IsInRole("Admin") || user.IsInRole("AccountManager");

        if (!canView)
        {
            Nav.NavigateTo("/access-denied");
            return;
        }

        _cashBoxes = await CashBoxService.GetCashBoxesAsync(activeOnly: true);
        await LoadAsync();
        await LoadStatsAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var result = await PayrollService.GetPayrollsAsync(_filter);
            _payrolls = result.Items;
            _totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل المرتبات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            _stats = await PayrollService.GetStatsAsync(_filter.PayrollMonth ?? DateTime.Today.ToString("yyyy-MM"));
        }
        catch
        {
            _stats = null;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _filter.PaymentStatus = string.IsNullOrWhiteSpace(_selectedStatus) ? null : _selectedStatus;
        _filter.PageNumber = 1;
        await LoadAsync();
        await LoadStatsAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _filter.PageNumber = page;
        await LoadAsync();
    }

    private async Task ExportExcelAsync()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            var exportFilter = new PayrollFilterDto
            {
                PayrollMonth = _filter.PayrollMonth,
                MonthFrom = _filter.MonthFrom,
                MonthTo = _filter.MonthTo,
                EmployeeID = _filter.EmployeeID,
                Department = _filter.Department,
                PaymentStatus = string.IsNullOrWhiteSpace(_selectedStatus) ? null : _selectedStatus,
                SearchText = _filter.SearchText,
                HasLoans = _filter.HasLoans,
                AttendanceSource = _filter.AttendanceSource,
                MinNetSalary = _filter.MinNetSalary,
                MaxNetSalary = _filter.MaxNetSalary,
                MinDeductions = _filter.MinDeductions,
                MaxDeductions = _filter.MaxDeductions,
                PageNumber = 1,
                PageSize = 100000
            };

            var bytes = await PayrollService.ExportPayrollsExcelAsync(exportFilter);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFileFromBase64", base64,
                $"سجل_المرتبات_{_filter.PayrollMonth ?? DateTime.Today.ToString("yyyy-MM")}.xlsx");

            Snackbar.Add("✅ تم التصدير بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private async Task OpenPayslipAsync(int payrollId)
    {
        var parameters = new DialogParameters
        {
            [nameof(PayslipDialog.PayrollId)] = payrollId,
            [nameof(PayslipDialog.CurrentUser)] = _currentUser
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        await DialogService.ShowAsync<PayslipDialog>("قسيمة الراتب", parameters, options);
    }

    private async Task ApproveAsync(PayrollListDto payroll)
    {
        var (ok, msg) = await PayrollService.ApprovePayrollAsync(payroll.PayrollID, _currentUser);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            await LoadAsync();
            await LoadStatsAsync();
        }
    }

    private void OpenRejectDialog(PayrollListDto payroll)
    {
        _rejectPayrollId = payroll.PayrollID;
        _rejectReason = null;
        _rejectDialogOpen = true;
    }

    private async Task SubmitRejectAsync()
    {
        var (ok, msg) = await PayrollService.RejectPayrollAsync(_rejectPayrollId, _currentUser, _rejectReason);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            _rejectDialogOpen = false;
            await LoadAsync();
            await LoadStatsAsync();
        }
    }

    private void OpenPayDialog(PayrollListDto payroll)
    {
        _payPayrollId = payroll.PayrollID;
        _selectedPayCashBoxId = _cashBoxes.FirstOrDefault(c => c.IsDefault)?.CashBoxId ?? _cashBoxes.FirstOrDefault()?.CashBoxId;
        _payDialogOpen = true;
    }

    private async Task SubmitPayAsync()
    {
        if (!_selectedPayCashBoxId.HasValue)
        {
            Snackbar.Add("يرجى اختيار الخزينة", Severity.Warning);
            return;
        }

        var (ok, msg) = await PayrollService.PayOneAsync(_payPayrollId, _selectedPayCashBoxId.Value, _currentUser);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            _payDialogOpen = false;
            await LoadAsync();
            await LoadStatsAsync();
        }
    }

    private async Task CancelAsync(PayrollListDto payroll)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message,    $"هل تريد إلغاء راتب {payroll.EmployeeName} لشهر {payroll.PayrollMonth}؟" },
            { x => x.YesText,    "إلغاء الراتب" },
            { x => x.CancelText, "تراجع" }
        };

        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأكيد الإلغاء", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        if ((await dialog.Result) is { Canceled: true })
            return;

        var (ok, msg) = await PayrollService.CancelAsync(payroll.PayrollID, _currentUser);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            await LoadAsync();
            await LoadStatsAsync();
        }
    }

    private static string EmployeeMeta(PayrollListDto payroll) =>
        string.IsNullOrWhiteSpace(payroll.JobTitle)
            ? (payroll.Department ?? "—")
            : $"{payroll.Department ?? "—"} · {payroll.JobTitle}";

    private static string FormatMonth(string? month) =>
        string.IsNullOrWhiteSpace(month)
            ? "—"
            : DateTime.TryParseExact(month + "-01", "yyyy-MM-dd", null,
                System.Globalization.DateTimeStyles.None, out var date)
                ? date.ToString("MMMM yyyy", new System.Globalization.CultureInfo("ar-EG"))
                : month;
}
