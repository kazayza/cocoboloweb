@code {
    // ════════════════════════════════════════════════════════════════════════════
    // STATE
    // ════════════════════════════════════════════════════════════════════════════
    private bool _isLoading = true;
    private bool _isTableLoading = false;
    private bool _filterExpanded = true;
    private string _searchDisplay = "";

    // Delete
    private bool _showDeleteDialog = false;
    private bool _isDeleting = false;
    private PersonalAccountListDto? _selectedAccount;

    private PersonalAccountFilterDto _filter = new();
    private PagedResult<PersonalAccountListDto> _pagedResult = new();
    private decimal _totalCreditors = 0;
    private decimal _totalDebtors = 0;

    private bool _canAdd, _canEdit, _canDelete;
    private System.Timers.Timer? _searchTimer;

    // ════════════════════════════════════════════════════════════════════════════
    // LIFECYCLE
    // ════════════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frmPersonalAccounts:View") || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        _canAdd = user.HasClaim("Permission", "frmPersonalAccounts:Add") || user.IsInRole("Admin");
        _canEdit = user.HasClaim("Permission", "frmPersonalAccounts:Edit") || user.IsInRole("Admin");
        _canDelete = user.HasClaim("Permission", "frmPersonalAccounts:Delete") || user.IsInRole("Admin");

        await LoadData();
        _isLoading = false;
    }

    // ════════════════════════════════════════════════════════════════════════════
    // DATA
    // ════════════════════════════════════════════════════════════════════════════
    private async Task LoadData()
    {
        _isTableLoading = true;
        StateHasChanged();
        _pagedResult = await AccountService.GetAccountsAsync(_filter);
        var (cred, deb) = await AccountService.GetTotalBalancesAsync();
        _totalCreditors = cred;
        _totalDebtors = deb;
        _isTableLoading = false;
        StateHasChanged();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // SEARCH WITH ARABIC NORMALIZE + DEBOUNCE
    // ════════════════════════════════════════════════════════════════════════════
    private void OnSearchInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        _searchDisplay = value;
        _filter.SearchText = value.NormalizeArabic();

        _searchTimer?.Stop();
        _searchTimer?.Dispose();
        _searchTimer = new System.Timers.Timer(400);
        _searchTimer.Elapsed += async (_, _) =>
        {
            _searchTimer?.Stop();
            await InvokeAsync(async () =>
            {
                _filter.PageNumber = 1;
                await LoadData();
                StateHasChanged();
            });
        };
        _searchTimer.AutoReset = false;
        _searchTimer.Start();
    }

    private async Task ClearSearch()
    {
        _searchDisplay = "";
        _filter.SearchText = "";
        _filter.PageNumber = 1;
        await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // FILTERS
    // ════════════════════════════════════════════════════════════════════════════
    private bool HasActiveFilters() =>
        !string.IsNullOrWhiteSpace(_searchDisplay) ||
        !string.IsNullOrEmpty(_filter.AccountType) ||
        !string.IsNullOrEmpty(_filter.BalanceFilter) ||
        _filter.IsActive.HasValue;

    private async Task OnFilterChange()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnPageChanged(int p)
    {
        _filter.PageNumber = p;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _searchDisplay = "";
        _filter = new();
        await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // DELETE (Fixed - No ShowMessageBox)
    // ════════════════════════════════════════════════════════════════════════════
    private void ConfirmDelete(PersonalAccountListDto acc)
    {
        _selectedAccount = acc;
        _showDeleteDialog = true;
    }

    private async Task ExecuteDelete()
    {
        if (_selectedAccount == null) return;

        _isDeleting = true;
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userName = auth.User.Identity?.Name ?? "System";

        var (ok, msg) = await AccountService.DeleteAccountAsync(_selectedAccount.PersonalAccountId, userName);
        _isDeleting = false;
        _showDeleteDialog = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // HELPERS
    // ════════════════════════════════════════════════════════════════════════════
    private string GetIcon(string? iconName) => iconName switch
    {
        "Stars" => Icons.Material.Filled.Stars,
        "Diamond" => Icons.Material.Filled.Diamond,
        "AccountBalance" => Icons.Material.Filled.AccountBalance,
        "Person" => Icons.Material.Filled.Person,
        "PersonOutline" => Icons.Material.Filled.PersonOutline,
        _ => Icons.Material.Filled.Person
    };

    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);
}
