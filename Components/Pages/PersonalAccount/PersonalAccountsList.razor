@page "/cashbox/personal-accounts"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IPersonalAccountService AccountService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ LOADING                                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <p>جاري تحميل الحسابات...</p>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else
{
    <div class="acc-page" dir="rtl">

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ BACKGROUND                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="page-bg-decorations">
            <div class="bg-orb bg-orb-1"></div>
            <div class="bg-orb bg-orb-2"></div>
        </div>

        <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ PREMIUM HEADER                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="acc-header">
            <div class="header-bg">
                <div class="header-gradient"></div>
                <div class="header-orbs">
                    <div class="header-orb orb-1"></div>
                    <div class="header-orb orb-2"></div>
                </div>
                <div class="header-grid"></div>
            </div>

            <div class="header-content">
                <div class="header-top">
                    <div class="header-info">
                        <div class="header-icon-wrapper">
                            <div class="header-icon-glow"></div>
                            <div class="header-icon">
                                <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Large" />
                            </div>
                            <div class="header-icon-badge">
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                            </div>
                        </div>
                        <div class="header-text">
                            <div class="header-title-row">
                                <h1>حسابات الذمم</h1>
                                <span class="premium-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                                    Premium
                                </span>
                            </div>
                            <p>
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" Class="subtitle-icon" />
                                إدارة حسابات الأشخاص (مالك، مستثمر، مقرض، موظفين)
                            </p>
                        </div>
                    </div>

                    <div class="header-actions">
                        @if (_canAdd)
                        {
                            <MudButton Variant="Variant.Filled"
                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                       OnClick="@(() => Navigation.NavigateTo("/cashbox/personal-accounts/new"))"
                                       Class="btn-add-new">
                                <span class="btn-shine"></span>
                                حساب جديد
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Dashboard"
                                   OnClick="@(() => Navigation.NavigateTo("/cashbox/dashboard"))"
                                   Class="btn-secondary">
                            Dashboard
                        </MudButton>
                    </div>
                </div>

                <!-- Stats inside header -->
                <div class="stats-grid">
                    <div class="stat-card stat-all animate-card" style="--delay:0.05s">
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.Groups" />
                            </div>
                            <div class="stat-data">
                                <span class="stat-value">@_pagedResult.TotalCount</span>
                                <div class="stat-label">إجمالي الحسابات</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-credit animate-card" style="--delay:0.1s">
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" />
                            </div>
                            <div class="stat-data">
                                <span class="stat-value">@FormatMoney(_totalCreditors)</span>
                                <div class="stat-label">عليكم (دائن)</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-debit animate-card" style="--delay:0.15s">
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" />
                            </div>
                            <div class="stat-data">
                                <span class="stat-value">@FormatMoney(_totalDebtors)</span>
                                <div class="stat-label">لكم (مدين)</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-net animate-card" style="--delay:0.2s">
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.Balance" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class="stat-value">@FormatMoney(Math.Abs(_totalDebtors - _totalCreditors))</span>
                                    <span class="stat-net-badge @(_totalDebtors >= _totalCreditors ? "net-positive" : "net-negative")">
                                        <MudIcon Icon="@(_totalDebtors >= _totalCreditors ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)" Size="Size.Small" />
                                        @(_totalDebtors >= _totalCreditors ? "لصالحكم" : "عليكم")
                                    </span>
                                </div>
                                <div class="stat-label">الصافي</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ FILTER BAR                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="filter-container animate-card" style="--delay:0.25s">
            <div class="filter-header" @onclick="() => _filterExpanded = !_filterExpanded">
                <div class="filter-header-right">
                    <div class="filter-icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
                    </div>
                    <span class="filter-title">بحث وتصفية</span>
                    @if (HasActiveFilters())
                    {
                        <span class="filter-active-badge">
                            <span class="badge-pulse"></span>
                            فلتر نشط
                        </span>
                    }
                </div>
                <div class="filter-header-left">
                    @if (HasActiveFilters())
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="ResetFilters" Class="btn-reset-filter">
                            مسح الكل
                        </MudButton>
                    }
                    <div class="filter-expand-icon @(_filterExpanded ? "expanded" : "")">
                        <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" />
                    </div>
                </div>
            </div>

            @if (_filterExpanded)
            {
                <div class="filter-content">
                    <div class="filter-grid">
                        <div class="search-box-wrapper">
                            <div class="search-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                            </div>
                            <input type="text"
                                   value="@_searchDisplay"
                                   @oninput="OnSearchInput"
                                   placeholder="بحث بالاسم أو الهاتف أو الرقم القومي..."
                                   class="search-input" />
                            @if (!string.IsNullOrWhiteSpace(_searchDisplay))
                            {
                                <button class="search-clear" @onclick="ClearSearch">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            }
                        </div>

                        <MudSelect T="string" @bind-Value="_filter.AccountType" @bind-Value:after="OnFilterChange"
                                   Label="نوع الحساب" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" AnchorOrigin="Origin.BottomCenter" Class="filter-select">
                            @foreach (var t in PersonalAccountTypes.All)
                            {
                                <MudSelectItem T="string" Value="@t.Key">@t.Value</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="string" @bind-Value="_filter.BalanceFilter" @bind-Value:after="OnFilterChange"
                                   Label="حالة الرصيد" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" AnchorOrigin="Origin.BottomCenter" Class="filter-select">
                            <MudSelectItem T="string" Value="@("Positive")">له (دائن)</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Negative")">عليه (مدين)</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Zero")">مسوى (صفر)</MudSelectItem>
                        </MudSelect>

                        <MudSelect T="bool?" @bind-Value="_filter.IsActive" @bind-Value:after="OnFilterChange"
                                   Label="الحالة" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" AnchorOrigin="Origin.BottomCenter" Class="filter-select">
                            <MudSelectItem T="bool?" Value="@((bool?)true)">نشط</MudSelectItem>
                            <MudSelectItem T="bool?" Value="@((bool?)false)">معطّل</MudSelectItem>
                        </MudSelect>
                    </div>
                </div>
            }
        </div>

        @if (_isTableLoading)
        {
            <div class="loading-bar"><MudProgressLinear Color="Color.Primary" Indeterminate="true" /></div>
        }

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ ACCOUNTS GRID                                                    -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        @if (_pagedResult.Items.Any())
        {
            <div class="accounts-grid">
                @foreach (var acc in _pagedResult.Items)
                {
                    var balanceColor = acc.CurrentBalance > 0 ? "#ef4444"
                        : acc.CurrentBalance < 0 ? "#10b981" : "#94a3b8";

                    <div class="acc-card @(acc.IsActive ? "" : "card-inactive") animate-card" style="--delay:0.3s">
                        <!-- Glow on hover -->
                        <div class="card-glow" style="background:radial-gradient(circle,@(acc.AccountTypeColor)15,transparent 60%);"></div>

                        <!-- Top Color Strip -->
                        <div class="card-strip" style="background:linear-gradient(135deg, @acc.AccountTypeColor, @(acc.AccountTypeColor)cc);">
                        </div>

                        <!-- Type & Status Badges -->
                        <div class="card-badges-row">
                            <span class="type-badge" style="background:@(acc.AccountTypeColor)15; color:@acc.AccountTypeColor; border:1px solid @(acc.AccountTypeColor)30;">
                                <MudIcon Icon="@GetIcon(acc.AccountTypeIcon)" Size="Size.Small" />
                                @acc.AccountTypeAr
                            </span>
                            @if (!acc.IsActive)
                            {
                                <span class="inactive-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Small" />
                                    معطّل
                                </span>
                            }
                        </div>

                        <!-- Card Body -->
                        <div class="card-body">
                            <!-- Account Info -->
                            <div class="card-info-section">
                                <div class="card-avatar" style="background:linear-gradient(135deg,@acc.AccountTypeColor,@(acc.AccountTypeColor)cc);">
                                    @(acc.AccountName?.Length >= 2 ? acc.AccountName.Substring(0, 2) : acc.AccountName)
                                </div>
                                <div class="card-name-block">
                                    <h3 class="card-name">@acc.AccountName</h3>
                                    <div class="card-contacts">
                                        @if (!string.IsNullOrEmpty(acc.Phone))
                                        {
                                            <span class="contact-item">
                                                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                                                <span dir="ltr">@acc.Phone</span>
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(acc.Email))
                                        {
                                            <span class="contact-item">
                                                <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" />
                                                @acc.Email
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Balance Box -->
                            <div class="balance-box" style="--bal-color:@balanceColor;">
                                <div class="bal-top">
                                    <span class="bal-label">الرصيد الحالي</span>
                                    <span class="bal-status">@acc.BalanceStatus</span>
                                </div>
                                <div class="bal-amount">
                                    @FormatMoney(Math.Abs(acc.CurrentBalance))
                                    <span class="bal-curr">ج.م</span>
                                </div>
                                <!-- Mini progress -->
                                @if (acc.TotalIn + acc.TotalOut > 0)
                                {
                                    var inPct = (double)acc.TotalIn / (double)(acc.TotalIn + acc.TotalOut) * 100;
                                    <div class="bal-progress">
                                        <div class="bal-progress-in" style="width:@inPct.ToString("F0")%;"></div>
                                    </div>
                                }
                            </div>

                            <!-- Mini Stats -->
                            <div class="card-mini-stats">
                                <div class="mini-stat mini-in">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" />
                                    <div>
                                        <span class="mini-label">إيداع</span>
                                        <strong>@FormatMoney(acc.TotalIn)</strong>
                                    </div>
                                </div>
                                <div class="mini-stat mini-out">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" />
                                    <div>
                                        <span class="mini-label">سحب</span>
                                        <strong>@FormatMoney(acc.TotalOut)</strong>
                                    </div>
                                </div>
                                <div class="mini-stat mini-count">
                                    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" />
                                    <div>
                                        <span class="mini-label">حركات</span>
                                        <strong>@acc.TransactionsCount</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Card Actions -->
                        <div class="card-actions">
                            <button class="card-action-btn action-statement" @onclick="@(() => Navigation.NavigateTo($"/cashbox/personal-accounts/{acc.PersonalAccountId}/statement"))">
                                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                                <span>كشف حساب</span>
                            </button>
                            @if (_canAdd && acc.IsActive)
                            {
                                <button class="card-action-btn action-transaction" @onclick="@(() => Navigation.NavigateTo($"/cashbox/personal-accounts/{acc.PersonalAccountId}/transaction"))">
                                    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" />
                                    <span>حركة</span>
                                </button>
                            }
                            @if (_canEdit)
                            {
                                <button class="card-action-btn action-edit" @onclick="@(() => Navigation.NavigateTo($"/cashbox/personal-accounts/{acc.PersonalAccountId}/edit"))">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                    <span>تعديل</span>
                                </button>
                            }
                            @if (_canDelete && acc.TransactionsCount == 0)
                            {
                                <button class="card-action-btn action-delete" @onclick="@(() => ConfirmDelete(acc))">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-illustration">
                    <div class="empty-icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.PeopleOutline" Size="Size.Large" />
                    </div>
                    <div class="empty-particles">
                        <span class="particle particle-1"></span>
                        <span class="particle particle-2"></span>
                    </div>
                </div>
                <h3>لا توجد حسابات بعد</h3>
                <p>ابدأ بإضافة حساب شخصي جديد لتتبع الذمم المالية</p>
                @if (_canAdd)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="@(() => Navigation.NavigateTo("/cashbox/personal-accounts/new"))"
                               Class="empty-btn">
                        حساب جديد
                    </MudButton>
                }
            </div>
        }

        <!-- Pagination -->
        @if (_pagedResult.TotalPages > 1)
        {
            <div class="pagination-bar">
                <span class="pagination-info">صفحة <strong>@_filter.PageNumber</strong> من <strong>@_pagedResult.TotalPages</strong></span>
                <MudPagination Count="@_pagedResult.TotalPages"
                               Selected="@_filter.PageNumber"
                               SelectedChanged="OnPageChanged"
                               Color="Color.Primary"
                               ShowFirstButton="true" ShowLastButton="true" />
            </div>
        }

        <!-- Footer -->
        <div class="page-footer">
            <div class="footer-content">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="footer-icon" />
                <span>COCOBOLO ERP — حسابات الذمم</span>
                <span class="footer-premium">Premium</span>
            </div>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DELETE DIALOG                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showDeleteDialog" Class="premium-dialog">
    <TitleContent>
        <div class="dialog-header dialog-header-danger">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.PersonRemove" />
                </div>
                <span class="dialog-title">حذف الحساب</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showDeleteDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body dialog-body-centered">
            <div class="delete-icon-box">
                <MudIcon Icon="@Icons.Material.Filled.PersonRemove" Size="Size.Large" />
            </div>
            <h3 class="delete-title">هل أنت متأكد؟</h3>
            <p class="delete-message">
                سيتم حذف حساب '<strong>@(_selectedAccount?.AccountName ?? "")</strong>' نهائياً
            </p>
            <span class="delete-note">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                هذا الإجراء لا يمكن التراجع عنه
            </span>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions dialog-actions-centered">
            <MudButton OnClick="@(() => _showDeleteDialog = false)" Variant="Variant.Text" Class="btn-cancel">إلغاء</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       OnClick="ExecuteDelete" Disabled="@_isDeleting"
                       StartIcon="@Icons.Material.Filled.Delete" Class="btn-danger">
                @if (_isDeleting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" /> }
                نعم، احذف
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐⭐⭐ PREMIUM STYLES ⭐⭐⭐                                                          -->
<!-- ═══════════════════════════════════════════════════════════════════════════════════ -->
<style>
    :root { --gold:#D4A853; --gold-dark:#B8912A; --gold-bg:#FEFBF3; --navy:#1B2A4A; --navy-dark:#0F1D36; --navy-light:#2D4A7A; }

    @@keyframes fadeInUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-15px)} }
    @@keyframes pulseGlow { 0%,100%{box-shadow:0 0 0 0 rgba(212,168,83,0.4)} 50%{box-shadow:0 0 25px 8px rgba(212,168,83,0.15)} }
    @@keyframes shimmer { 0%{transform:translateX(-100%)} 100%{transform:translateX(100%)} }
    @@keyframes ping { 75%,100%{transform:scale(2);opacity:0} }
    @@keyframes bounceSoft { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
    @@keyframes loadingDots { 0%,80%,100%{transform:scale(0)} 40%{transform:scale(1)} }
    .animate-card { animation:fadeInUp 0.6s ease-out forwards; animation-delay:var(--delay,0s); opacity:0; }

    .loading-screen { display:flex; align-items:center; justify-content:center; min-height:70vh; }
    .loading-content { text-align:center; }
    .loading-content p { color:var(--mud-palette-text-secondary); margin-top:1rem; }
    .loading-dots { display:flex; justify-content:center; gap:0.5rem; margin-top:0.75rem; }
    .loading-dots span { width:10px; height:10px; background:var(--gold); border-radius:50%; animation:loadingDots 1.4s infinite both; }
    .loading-dots span:nth-child(1) { animation-delay:-0.32s; }
    .loading-dots span:nth-child(2) { animation-delay:-0.16s; }

    .acc-page { position:relative; max-width:1800px; margin:0 auto; padding:0 1rem; }
    .page-bg-decorations { position:fixed; inset:0; pointer-events:none; z-index:0; }
    .bg-orb { position:absolute; border-radius:50%; filter:blur(80px); }
    .bg-orb-1 { width:400px; height:400px; top:-200px; right:-150px; background:radial-gradient(circle,rgba(212,168,83,0.12),transparent 70%); animation:float 10s ease-in-out infinite; }
    .bg-orb-2 { width:350px; height:350px; bottom:-150px; left:-100px; background:radial-gradient(circle,rgba(139,92,246,0.06),transparent 70%); }

    .top-accent-bar { height:5px; background:linear-gradient(90deg,var(--gold),var(--gold-dark),var(--gold)); position:relative; overflow:hidden; margin-bottom:1.5rem; border-radius:0 0 10px 10px; }
    .accent-shimmer { position:absolute; inset:0; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent); animation:shimmer 3s ease-in-out infinite; }

    /* ═══════ HEADER ═══════ */
    .acc-header { position:relative; border-radius:24px; overflow:hidden; margin-bottom:1.5rem; }
    .header-bg { position:absolute; inset:0; }
    .header-gradient { position:absolute; inset:0; background:linear-gradient(135deg,var(--navy-dark) 0%,var(--navy) 40%,var(--navy-light) 100%); }
    .header-orbs { position:absolute; inset:0; overflow:hidden; }
    .header-orb { position:absolute; border-radius:50%; }
    .header-orb.orb-1 { width:350px; height:350px; top:-150px; right:-100px; background:radial-gradient(circle,rgba(212,168,83,0.25),transparent 60%); animation:float 8s ease-in-out infinite; }
    .header-orb.orb-2 { width:250px; height:250px; bottom:-100px; left:20%; background:radial-gradient(circle,rgba(212,168,83,0.15),transparent 60%); }
    .header-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px); background-size:40px 40px; }
    .header-content { position:relative; z-index:2; padding:2rem 2.5rem; }
    .header-top { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1.5rem; margin-bottom:2rem; }
