@page "/login"
@layout COCOBOLOERPNEW.Components.Layout.EmptyLayout
@attribute [AllowAnonymous]

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>تسجيل الدخول - COCOBOLO</PageTitle>

<div class="login-premium" dir="rtl">

    <!-- Right Side: Form (الأهم في RTL) -->
    <div class="form-section">
        <div class="form-wrapper">
            
            <!-- Logo Mini (visible on mobile only) -->
            <div class="mobile-logo">
                <img src="/logo.png" alt="COCOBOLO" />
                <h3>COCOBOLO</h3>
            </div>

            <div class="welcome-block">
                <span class="welcome-eyebrow">مرحباً بعودتك</span>
                <h1>تسجيل الدخول</h1>
                <p>أدخل بياناتك للوصول إلى لوحة التحكم</p>
            </div>

            <EditForm Model="_model" OnValidSubmit="HandleLogin" class="login-form">
                <DataAnnotationsValidator />

                <!-- Username -->
                <div class="input-block">
                    <label for="username">اسم المستخدم</label>
                    <div class="input-wrapper">
                        <MudIcon Icon="@Icons.Material.Outlined.Person" Class="input-icon" />
                        <input id="username"
                               type="text"
                               @bind="_model.Username"
                               placeholder="أدخل اسم المستخدم"
                               disabled="@_isSubmitting"
                               autocomplete="username" />
                    </div>
                    <ValidationMessage For="@(() => _model.Username)" />
                </div>

                <!-- Password -->
                <div class="input-block">
                    <label for="password">كلمة المرور</label>
                    <div class="input-wrapper">
                        <MudIcon Icon="@Icons.Material.Outlined.Lock" Class="input-icon" />
                        <input id="password"
                               type="@(_showPassword ? "text" : "password")"
                               @bind="_model.Password"
                               placeholder="••••••••"
                               disabled="@_isSubmitting"
                               autocomplete="current-password" />
                        <button type="button" class="toggle-pwd" @onclick="TogglePassword">
                            <MudIcon Icon="@(_showPassword ? Icons.Material.Outlined.VisibilityOff : Icons.Material.Outlined.Visibility)" />
                        </button>
                    </div>
                    <ValidationMessage For="@(() => _model.Password)" />
                </div>

                <!-- Options -->
                <div class="options-row">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_rememberMe" />
                        <span class="checkbox-custom"></span>
                        <span>تذكرني لمدة 30 يوم</span>
                    </label>
                    <a href="#" class="forgot" @onclick:preventDefault @onclick="ShowForgotInfo">
                        نسيت كلمة المرور؟
                    </a>
                </div>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="error-box">
                        <MudIcon Icon="@Icons.Material.Outlined.ErrorOutline" />
                        <span>@_error</span>
                    </div>
                }

                <!-- Submit -->
                <button type="submit" class="login-btn" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="spinner"></span>
                        <span>جاري التحقق...</span>
                    }
                    else
                    {
                        <span>تسجيل الدخول</span>
                        <MudIcon Icon="@Icons.Material.Outlined.ArrowForward" />
                    }
                </button>

            </EditForm>

            <div class="footer-text">
                © 2026 COCOBOLO Luxury Furniture
            </div>

        </div>
    </div>

    <!-- Left Side: Brand -->
    <div class="brand-section">
        <div class="brand-overlay"></div>
        
        <div class="brand-content">
            <div class="brand-logo-area">
                <img src="/logo.png" alt="COCOBOLO" />
            </div>

            <div class="brand-text">
                <h1>COCOBOLO</h1>
                <span class="brand-sub">Luxury Furniture</span>
                <div class="gold-line"></div>
                <p>
                    نظام إدارة متكامل للأعمال<br />
                    حلول احترافية لإدارة مؤسستك بكل سهولة
                </p>
            </div>

            <div class="testimonial">
                <div class="quote-mark">"</div>
                <p>
                   هذا النظام تم تصميمه لشركة COCOBOLO.
                </p>
                <div class="testimonial-author">
                    <strong>تصميم </strong>
                    <span>محاسب / احمد الرفاعى</span>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
    /* ==============================================
       Premium Split Screen Login
       ============================================== */
    .login-premium {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        font-family: 'Tajawal', 'Cairo', 'Segoe UI', sans-serif;
        overflow: hidden;
    }

    /* ============================================
       Form Section (Right in RTL)
       ============================================ */
    .form-section {
        background: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        position: relative;
    }

    .form-wrapper {
        width: 100%;
        max-width: 420px;
    }

    .mobile-logo {
        display: none;
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .mobile-logo img {
        width: 70px;
        margin-bottom: 0.5rem;
    }

    .mobile-logo h3 {
        margin: 0;
        color: #1a2842;
        font-size: 1.25rem;
        font-weight: 800;
    }

    .welcome-block {
        margin-bottom: 2rem;
    }

    .welcome-eyebrow {
        display: inline-block;
        color: #d4af37;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.5rem;
        padding: 0.25rem 0.75rem;
        background: rgba(212, 175, 55, 0.1);
        border-radius: 6px;
    }

    .welcome-block h1 {
        font-size: 2rem;
        font-weight: 900;
        color: #1a2842;
        margin: 0 0 0.5rem 0;
        line-height: 1.2;
    }

    .welcome-block p {
        color: #64748b;
        font-size: 0.95rem;
        margin: 0;
    }

    /* Input Blocks */
    .login-form {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .input-block label {
        display: block;
        color: #334155;
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    ::deep .input-icon {
        position: absolute;
        right: 14px;
        color: #94a3b8 !important;
        font-size: 20px !important;
        pointer-events: none;
        z-index: 1;
        transition: color 0.2s ease;
    }

    .input-wrapper input {
        width: 100%;
        height: 52px;
        padding: 0 44px 0 44px;
        background: #f8fafc;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        font-size: 1rem;
        color: #1a2842;
        font-family: inherit;
        transition: all 0.2s ease;
        direction: ltr;
        text-align: left;
    }

    .input-wrapper input::placeholder {
        color: #cbd5e1;
        text-align: left;
        direction: ltr;
    }

    .input-wrapper input:hover {
        border-color: #cbd5e1;
        background: #ffffff;
    }

    .input-wrapper input:focus {
        outline: none;
        border-color: #d4af37;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.1);
    }

    .input-wrapper input:focus + ::deep .input-icon,
    .input-wrapper:focus-within ::deep .input-icon {
        color: #d4af37 !important;
    }

    .toggle-pwd {
        position: absolute;
        left: 8px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 8px;
        color: #94a3b8;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

    .toggle-pwd:hover {
        color: #d4af37;
        background: rgba(212, 175, 55, 0.1);
    }

    .toggle-pwd ::deep .mud-icon-root {
        font-size: 20px !important;
    }

    /* Options */
    .options-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        color: #64748b;
        font-size: 0.85rem;
        user-select: none;
    }

    .checkbox-label input[type="checkbox"] {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .checkbox-custom {
        width: 18px;
        height: 18px;
        border: 2px solid #cbd5e1;
        border-radius: 5px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .checkbox-label input[type="checkbox"]:checked + .checkbox-custom {
        background: #d4af37;
        border-color: #d4af37;
    }

    .checkbox-label input[type="checkbox"]:checked + .checkbox-custom::after {
        content: '✓';
        color: white;
        font-size: 14px;
        font-weight: bold;
    }

    .forgot {
        color: #d4af37;
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .forgot:hover {
        color: #b8941f;
        text-decoration: underline;
    }

    /* Error */
    .error-box {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        color: #dc2626;
        font-size: 0.88rem;
    }

    .error-box ::deep .mud-icon-root {
        color: #dc2626 !important;
        font-size: 20px !important;
    }

    /* Login Button */
    .login-btn {
        width: 100%;
        height: 54px;
        background: linear-gradient(135deg, #1a2842 0%, #2c3e5f 100%);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 800;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 14px rgba(26, 40, 66, 0.25);
        font-family: inherit;
        margin-top: 0.5rem;
    }

    .login-btn:hover:not(:disabled) {
        background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
        box-shadow: 0 8px 24px rgba(212, 175, 55, 0.35);
        transform: translateY(-2px);
    }

    .login-btn:active {
        transform: translateY(0);
    }

    .login-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .login-btn ::deep .mud-icon-root {
        color: white !important;
        font-size: 22px !important;
    }

    .spinner {
        width: 20px;
        height: 20px;
        border: 2.5px solid rgba(255, 255, 255, 0.25);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .footer-text {
        text-align: center;
        margin-top: 2rem;
        color: #94a3b8;
        font-size: 0.78rem;
    }

    /* Validation */
    ::deep .validation-message {
        display: block;
        margin-top: 0.4rem;
        color: #dc2626;
        font-size: 0.78rem;
    }

    /* ============================================
       Brand Section (Left in RTL)
       ============================================ */
    .brand-section {
        position: relative;
        background:
            linear-gradient(135deg, rgba(26, 40, 66, 0.85), rgba(15, 26, 46, 0.95)),
            radial-gradient(circle at 30% 20%, rgba(212, 175, 55, 0.2), transparent 50%);
        background-color: #1a2842;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        overflow: hidden;
    }

    .brand-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(circle at 80% 80%, rgba(212, 175, 55, 0.15), transparent 50%),
            radial-gradient(circle at 20% 20%, rgba(212, 175, 55, 0.1), transparent 50%);
        animation: shift 15s ease-in-out infinite alternate;
    }

    @@keyframes shift {
        0% { transform: scale(1); }
        100% { transform: scale(1.1); }
    }

    .brand-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 0%, rgba(15, 26, 46, 0.4) 100%);
    }

    .brand-content {
        position: relative;
        z-index: 1;
        max-width: 400px;
        text-align: center;
        color: white;
    }

    .brand-logo-area {
        margin-bottom: 2rem;
    }

    .brand-logo-area img {
        width: 130px;
        height: auto;
        filter: drop-shadow(0 12px 32px rgba(212, 175, 55, 0.4));
        animation: float 4s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .brand-text h1 {
        font-size: 2.75rem;
        font-weight: 900;
        margin: 0;
        background: linear-gradient(135deg, #d4af37, #f5d96e, #d4af37);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: 0.08em;
    }

    .brand-sub {
        display: block;
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.7);
        margin-top: 0.25rem;
        letter-spacing: 0.25em;
        font-weight: 500;
    }

    .gold-line {
        width: 80px;
        height: 3px;
        background: linear-gradient(90deg, transparent, #d4af37, transparent);
        margin: 1.5rem auto;
        border-radius: 2px;
    }

    .brand-text p {
        color: rgba(255, 255, 255, 0.8);
        line-height: 1.8;
        font-size: 1rem;
        margin: 0;
    }

    /* Testimonial */
    .testimonial {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 1.5rem;
        margin-top: 2.5rem;
        position: relative;
    }

    .quote-mark {
        position: absolute;
        top: -20px;
        right: 20px;
        font-size: 4rem;
        color: #d4af37;
        line-height: 1;
        font-family: Georgia, serif;
        opacity: 0.6;
    }

    .testimonial p {
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.92rem;
        line-height: 1.7;
        margin: 0 0 1rem 0;
        font-style: italic;
    }

    .testimonial-author {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: right;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .testimonial-author strong {
        color: #d4af37;
        font-size: 0.9rem;
        font-weight: 700;
    }

    .testimonial-author span {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.78rem;
        margin-top: 0.15rem;
    }

    /* ============================================
       Responsive
       ============================================ */
    @@media (max-width: 992px) {
        .login-premium {
            grid-template-columns: 1fr;
        }

        .brand-section {
            display: none;
        }

        .mobile-logo {
            display: block;
        }

        .form-section {
            padding: 1.5rem 1rem;
        }
    }

    @@media (max-width: 480px) {
        .welcome-block h1 {
            font-size: 1.6rem;
        }

        .input-wrapper input {
            height: 48px;
        }

        .login-btn {
            height: 50px;
        }
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "ReturnUrl")]
    public string? ReturnUrl { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private readonly LoginInputModel _model = new();
    private bool _showPassword;
    private bool _isSubmitting;
    private bool _rememberMe = false;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (AuthenticationStateTask is null) return;
        var authState = await AuthenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo(SafeReturnUrl(ReturnUrl), forceLoad: true);
        }
    }

    private async Task HandleLogin()
    {
        _error = null;
        _isSubmitting = true;
        try
        {
            var result = await JS.InvokeAsync<LoginResult>(
                "cocoboloAuth.login", _model.Username, _model.Password);

            if (result?.Ok == true)
            {
                Navigation.NavigateTo(SafeReturnUrl(ReturnUrl), forceLoad: true);
                return;
            }

            _error = string.IsNullOrWhiteSpace(result?.Message)
                ? "تعذر تسجيل الدخول. حاول مرة أخرى."
                : result!.Message;
        }
        catch
        {
            _error = "حدث خطأ غير متوقع. حاول مرة أخرى.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void TogglePassword() => _showPassword = !_showPassword;

    private void ShowForgotInfo() =>
        _error = "يرجى التواصل مع مدير النظام لإعادة تعيين كلمة المرور.";

    private static string SafeReturnUrl(string? url)
    {
        if (!string.IsNullOrWhiteSpace(url) && url.StartsWith("/")
            && !url.StartsWith("//") && !url.StartsWith("/\\"))
            return url;
        return "/";
    }

    private sealed class LoginInputModel
    {
        [Required(ErrorMessage = "اسم المستخدم مطلوب")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "كلمة المرور مطلوبة")]
        public string Password { get; set; } = "";
    }

    private sealed class LoginResult
    {
        public bool Ok { get; set; }
        public string? Message { get; set; }
    }
}
