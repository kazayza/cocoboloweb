    .node-row { display:flex; align-items:center; gap:0.75rem; padding:0.875rem 1rem; background:var(--mud-palette-background); border:1px solid var(--mud-palette-divider); border-radius:12px; transition:all 0.3s ease; margin-bottom:0.35rem; }
    .node-row:hover { border-color:var(--expense-color); background:rgba(245,158,11,0.04); transform:translateX(-4px); }
