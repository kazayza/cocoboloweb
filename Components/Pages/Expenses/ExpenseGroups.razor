    .footer-icon { color:var(--expense-color) !important; }

    /* ═══════ DIALOGS ═══════ */
    .premium-dialog .mud-dialog { border-radius:24px !important; overflow:hidden; box-shadow:0 25px 80px rgba(0,0,0,0.15) !important; }
    .premium-dialog .mud-dialog-title { padding:0 !important; }
    .premium-dialog .mud-dialog-content { padding:0 !important; }
