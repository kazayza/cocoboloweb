@code {
    // ════════════════════════════════════════════════════════════════════════════
    // STATE
    // ════════════════════════════════════════════════════════════════════════════
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _showDialog = false;

    // Delete
    private bool _showDeleteDialog = false;
    private bool _isDeleting = false;
    private ExpenseGroupDto? _selectedGroup;

    private List<ExpenseGroupDto> _tree = new();
    private List<ExpenseGroupDto> _allGroups = new();
    private ExpenseGroupFormDto _editing = new();

    private bool _canAdd, _canEdit, _canDelete;

    // ════════════════════════════════════════════════════════════════════════════
    // LIFECYCLE
    // ════════════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frmExpenseGroups:View") || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        _canAdd = user.HasClaim("Permission", "frmExpenseGroups:Add") || user.IsInRole("Admin");
        _canEdit = user.HasClaim("Permission", "frmExpenseGroups:Edit") || user.IsInRole("Admin");
        _canDelete = user.HasClaim("Permission", "frmExpenseGroups:Delete") || user.IsInRole("Admin");

        await LoadData();
        _isLoading = false;
    }

    // ════════════════════════════════════════════════════════════════════════════
    // DATA
    // ════════════════════════════════════════════════════════════════════════════
    private async Task LoadData()
    {
        _tree = await ExpenseService.GetExpenseGroupsAsync(asTree: true);
        _allGroups = await ExpenseService.GetExpenseGroupsAsync(asTree: false);
        StateHasChanged();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // ADD / EDIT
    // ════════════════════════════════════════════════════════════════════════════
    private void OpenAddDialog(int? parentId)
    {
        _editing = new ExpenseGroupFormDto { ParentGroupId = parentId };
        _showDialog = true;
    }

    private void OpenEditDialog(ExpenseGroupDto group)
    {
        _editing = new ExpenseGroupFormDto
        {
            ExpenseGroupId = group.ExpenseGroupId,
            ExpenseGroupName = group.ExpenseGroupName,
            ParentGroupId = group.ParentGroupId
        };
        _showDialog = true;
    }

    private async Task SaveGroup()
    {
        if (string.IsNullOrWhiteSpace(_editing.ExpenseGroupName)) return;

        _isSaving = true;
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userName = auth.User.Identity?.Name ?? "System";

        var (ok, msg, _) = await ExpenseService.SaveExpenseGroupAsync(_editing, userName);
        _isSaving = false;
        _showDialog = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // DELETE (Fixed - No ShowMessageBox)
    // ════════════════════════════════════════════════════════════════════════════
    private void ConfirmDelete(ExpenseGroupDto group)
    {
        _selectedGroup = group;
        _showDeleteDialog = true;
    }

    private async Task ExecuteDelete()
    {
        if (_selectedGroup == null) return;

        _isDeleting = true;
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userName = auth.User.Identity?.Name ?? "System";

        var (ok, msg) = await ExpenseService.DeleteExpenseGroupAsync(_selectedGroup.ExpenseGroupId, userName);
        _isDeleting = false;
        _showDeleteDialog = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // HELPERS
    // ════════════════════════════════════════════════════════════════════════════
    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);

    private void ExpandAll()
    {
        _expandedNodes = new HashSet<int>(_allGroups.Where(g => g.ChildrenCount > 0).Select(g => g.ExpenseGroupId));
        StateHasChanged();
    }

    private void CollapseAll()
    {
        _expandedNodes.Clear();
        StateHasChanged();
    }
}
