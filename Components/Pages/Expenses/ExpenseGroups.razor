    .top-list { display:flex; flex-direction:column; gap:0.5rem; }
    .top-row { display:flex; align-items:center; gap:0.75rem; padding:0.65rem 0.75rem; background:var(--mud-palette-background); border-radius:10px; transition:background 0.2s; }
    .top-row:hover { background:rgba(245,158,11,0.05); }
    .top-rank { width:28px; height:28px; background:linear-gradient(135deg,var(--expense-color),var(--expense-dark)); color:white; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:0.75rem; font-weight:800; flex-shrink:0; }
    .top-info { flex:1; min-width:0; }
