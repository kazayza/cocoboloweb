@page "/expense-groups"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IExpenseService ExpenseService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ LOADING                                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <p>جاري تحميل المجموعات...</p>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else
{
    <div class="grp-page" dir="rtl">

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ BACKGROUND                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="page-bg-decorations">
            <div class="bg-orb bg-orb-1"></div>
            <div class="bg-orb bg-orb-2"></div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ ACCENT BAR                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ PREMIUM HEADER                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="grp-header">
            <div class="header-bg">
                <div class="header-gradient"></div>
                <div class="header-orbs">
                    <div class="header-orb orb-1"></div>
                    <div class="header-orb orb-2"></div>
                </div>
                <div class="header-grid"></div>
            </div>

            <div class="header-content">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" />
                        </div>
                        <div class="header-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                        </div>
                    </div>
                    <div class="header-text">
                        <h1>مجموعات المصروفات</h1>
                        <p>
                            <MudIcon Icon="@Icons.Material.Filled.Schema" Size="Size.Small" Class="subtitle-icon" />
                            تنظيم المصروفات في مجموعات وفروع (Tree)
                        </p>
                    </div>
                </div>

                <div class="header-actions">
                    @if (_canAdd)
                    {
                        <MudButton Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.CreateNewFolder"
                                   OnClick="@(() => OpenAddDialog(null))"
                                   Class="btn-add-new">
                            <span class="btn-shine"></span>
                            مجموعة جديدة
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.MoneyOff"
                               OnClick="@(() => Navigation.NavigateTo("/expenses"))"
                               Class="btn-secondary">
                        المصروفات
                    </MudButton>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ CONTENT GRID                                                     -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="content-grid">

            <!-- ─── Tree Panel ─── -->
            <div class="tree-panel animate-card" style="--delay:0.1s">
                <div class="panel-header">
                    <div class="panel-header-right">
                        <div class="panel-icon">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" />
                        </div>
                        <div>
                            <h3>شجرة المجموعات</h3>
                            <p>@_allGroups.Count مجموعة</p>
                        </div>
                    </div>
                    @if (_tree.Any(t => t.Children.Any()))
                    {
                        <div class="tree-controls">
                            <MudTooltip Text="فتح الكل">
                                <button class="tree-ctrl-btn" @onclick="ExpandAll">
                                    <MudIcon Icon="@Icons.Material.Filled.UnfoldMore" Size="Size.Small" />
                                </button>
                            </MudTooltip>
                            <MudTooltip Text="إغلاق الكل">
                                <button class="tree-ctrl-btn" @onclick="CollapseAll">
                                    <MudIcon Icon="@Icons.Material.Filled.UnfoldLess" Size="Size.Small" />
                                </button>
                            </MudTooltip>
                        </div>
                    }
                </div>

                @if (_tree.Any())
                {
                    <div class="tree-list">
                        @foreach (var root in _tree)
                        {
                            @RenderNode(root, 0)
                        }
                    </div>
                }
                else
                {
                    <div class="empty-tree">
                        <div class="empty-illustration">
                            <div class="empty-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" />
                            </div>
                            <div class="empty-particles">
                                <span class="particle particle-1"></span>
                                <span class="particle particle-2"></span>
                            </div>
                        </div>
                        <h3>لا توجد مجموعات بعد</h3>
                        <p>أنشئ أول مجموعة لتنظيم المصروفات</p>
                        @if (_canAdd)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CreateNewFolder"
                                       OnClick="@(() => OpenAddDialog(null))"
                                       Class="empty-btn">
                                إضافة أول مجموعة
                            </MudButton>
                        }
                    </div>
                }
            </div>

            <!-- ─── Stats Panel ─── -->
            <div class="stats-panel animate-card" style="--delay:0.2s">
                <div class="panel-header">
                    <div class="panel-icon panel-icon-stats">
                        <MudIcon Icon="@Icons.Material.Filled.Insights" />
                    </div>
                    <div>
                        <h3>إحصائيات</h3>
                        <p>نظرة عامة</p>
                    </div>
                </div>

                <!-- Quick Stats -->
                <div class="quick-stats">
                    <div class="qs-card">
                        <div class="qs-icon qs-purple">
                            <MudIcon Icon="@Icons.Material.Filled.FolderCopy" Size="Size.Small" />
                        </div>
                        <div class="qs-data">
                            <span class="qs-value">@_allGroups.Count</span>
                            <span class="qs-label">إجمالي المجموعات</span>
                        </div>
                    </div>
                    <div class="qs-card">
                        <div class="qs-icon qs-amber">
                            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                        </div>
                        <div class="qs-data">
                            <span class="qs-value">@_tree.Count</span>
                            <span class="qs-label">رئيسية</span>
                        </div>
                    </div>
                    <div class="qs-card">
                        <div class="qs-icon qs-blue">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" />
                        </div>
                        <div class="qs-data">
                            <span class="qs-value">@_allGroups.Sum(g => g.ExpensesCount)</span>
                            <span class="qs-label">مصروف</span>
                        </div>
                    </div>
                    <div class="qs-card">
                        <div class="qs-icon qs-red">
                            <MudIcon Icon="@Icons.Material.Filled.Money" Size="Size.Small" />
                        </div>
                        <div class="qs-data">
                            <span class="qs-value qs-red-text">@FormatMoney(_allGroups.Sum(g => g.TotalAmount))</span>
                            <span class="qs-label">ج.م إجمالي</span>
                        </div>
                    </div>
                </div>

                <!-- Top Groups -->
                @{ var topGroups = _allGroups.OrderByDescending(g => g.TotalAmount).Take(5).Where(g => g.TotalAmount > 0).ToList(); }
                @if (topGroups.Any())
                {
                    <div class="top-groups-section">
                        <h4 class="top-title">
                            <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Size="Size.Small" />
                            أكثر المجموعات قيمة
                        </h4>
                        <div class="top-list">
                            @foreach (var (top, idx) in topGroups.Select((t, i) => (t, i)))
                            {
                                <div class="top-row">
                                    <div class="top-rank">@(idx + 1)</div>
                                    <div class="top-info">
                                        <strong>@top.ExpenseGroupName</strong>
                                        <small>@top.ExpensesCount مصروف</small>
                                    </div>
                                    <span class="top-amount">@FormatMoney(top.TotalAmount)</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ FOOTER                                                           -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="page-footer">
            <div class="footer-content">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="footer-icon" />
                <span>COCOBOLO ERP — مجموعات المصروفات</span>
            </div>
        </div>

    </div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ TREE NODE RENDERER                                                       -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@code {
    private HashSet<int> _expandedNodes = new();

    private void ToggleNode(int nodeId)
    {
        if (_expandedNodes.Contains(nodeId))
            _expandedNodes.Remove(nodeId);
        else
            _expandedNodes.Add(nodeId);
    }

    private bool IsExpanded(int nodeId) => _expandedNodes.Contains(nodeId);

    private RenderFragment RenderNode(ExpenseGroupDto node, int depth) => __builder =>
    {
        var hasChildren = node.Children.Any();
        var isOpen = IsExpanded(node.ExpenseGroupId);

        <div class="tree-node" style="padding-right: @(depth * 28)px;">
            <div class="node-row @(depth > 0 ? "node-child" : "node-root") @(hasChildren && isOpen ? "node-expanded" : "")">

                <!-- Toggle button for parents -->
                @if (hasChildren)
                {
                    <button class="node-toggle @(isOpen ? "toggled" : "")" @onclick="@(() => ToggleNode(node.ExpenseGroupId))">
                        <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small" />
                    </button>
                }
                else if (depth > 0)
                {
                    <div class="node-connector">
                        <div class="connector-line"></div>
                        <div class="connector-dot"></div>
                    </div>
                }
                else
                {
                    <div class="node-spacer"></div>
                }

                <div class="node-icon @(hasChildren ? "node-icon-parent" : "")">
                    <MudIcon Icon="@(hasChildren ? (isOpen ? Icons.Material.Filled.FolderOpen : Icons.Material.Filled.Folder) : Icons.Material.Filled.InsertDriveFile)" />
                </div>

                <div class="node-info" @onclick="@(() => { if (hasChildren) ToggleNode(node.ExpenseGroupId); })"
                     style="@(hasChildren ? "cursor:pointer;" : "")">
                    <div class="node-name">@node.ExpenseGroupName</div>
                    <div class="node-meta">
                        @if (node.ChildrenCount > 0)
                        {
                            <span class="meta-chip meta-folder">
                                <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                                @node.ChildrenCount فرعية
                                <span class="meta-toggle-hint">@(isOpen ? "▲" : "▼")</span>
                            </span>
                        }
                        @if (node.ExpensesCount > 0)
                        {
                            <span class="meta-chip meta-expense">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" />
                                @node.ExpensesCount مصروف
                            </span>
                        }
                    </div>
                </div>

                <div class="node-amount">
                    @if (node.TotalAmount > 0)
                    {
                        <span class="amount-tag">@FormatMoney(node.TotalAmount) ج.م</span>
                    }
                </div>

                <div class="node-actions">
                    @if (_canAdd)
                    {
                        <MudTooltip Text="إضافة فرعية" Placement="Placement.Top">
                            <button class="action-btn action-add" @onclick="@(() => OpenAddDialog(node.ExpenseGroupId))">
                                <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Size="Size.Small" />
                            </button>
                        </MudTooltip>
                    }
                    @if (_canEdit)
                    {
                        <MudTooltip Text="تعديل" Placement="Placement.Top">
                            <button class="action-btn action-edit" @onclick="@(() => OpenEditDialog(node))">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                            </button>
                        </MudTooltip>
                    }
                    @if (_canDelete && node.ChildrenCount == 0 && node.ExpensesCount == 0)
                    {
                        <MudTooltip Text="حذف" Placement="Placement.Top">
                            <button class="action-btn action-delete" @onclick="@(() => ConfirmDelete(node))">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                            </button>
                        </MudTooltip>
                    }
                </div>
            </div>

            <!-- Children (collapsible) -->
            @if (hasChildren && isOpen)
            {
                <div class="node-children">
                    @foreach (var child in node.Children)
                    {
                        @RenderNode(child, depth + 1)
                    }
                </div>
            }
        </div>
    };
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ ADD/EDIT DIALOG                                                          -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showDialog" Class="premium-dialog">
    <TitleContent>
        <div class="dialog-header dialog-header-primary">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@(_editing.ExpenseGroupId == 0 ? Icons.Material.Filled.CreateNewFolder : Icons.Material.Filled.Edit)" />
                </div>
                <span class="dialog-title">@(_editing.ExpenseGroupId == 0 ? "مجموعة جديدة" : "تعديل المجموعة")</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body">
            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.DriveFileRenameOutline" Size="Size.Small" />
                    اسم المجموعة <span class="required">*</span>
                </label>
                <MudTextField @bind-Value="_editing.ExpenseGroupName"
                              Variant="Variant.Outlined"
                              Placeholder="أدخل اسم المجموعة..."
                              Class="premium-input" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" />
                    المجموعة الأم (اختياري)
                </label>
                <MudSelect T="int?" @bind-Value="_editing.ParentGroupId"
                           Variant="Variant.Outlined"
                           Placeholder="بدون مجموعة أم (رئيسية)"
                           Clearable="true"
                           Class="premium-input">
                    @foreach (var g in _allGroups.Where(x => x.ExpenseGroupId != _editing.ExpenseGroupId))
                    {
                        <MudSelectItem T="int?" Value="@((int?)g.ExpenseGroupId)">
                            <div class="select-group-item">
                                <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                                @g.ExpenseGroupName
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions">
            <MudButton OnClick="@(() => _showDialog = false)" Variant="Variant.Text" Class="btn-cancel">
                إلغاء
            </MudButton>
            <MudButton OnClick="SaveGroup" Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="@(_isSaving || string.IsNullOrWhiteSpace(_editing.ExpenseGroupName))"
                       Class="btn-save">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                }
                حفظ
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DELETE DIALOG                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showDeleteDialog" Class="premium-dialog">
    <TitleContent>
        <div class="dialog-header dialog-header-danger">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" />
                </div>
                <span class="dialog-title">تأكيد الحذف</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showDeleteDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body dialog-body-centered">
            <div class="delete-icon-box">
                <MudIcon Icon="@Icons.Material.Filled.FolderDelete" Size="Size.Large" />
            </div>
            <h3 class="delete-title">حذف المجموعة؟</h3>
            <p class="delete-message">
                سيتم حذف '<strong>@(_selectedGroup?.ExpenseGroupName ?? "")</strong>' نهائياً
            </p>
            <span class="delete-note">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                هذا الإجراء لا يمكن التراجع عنه
            </span>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions dialog-actions-centered">
            <MudButton OnClick="@(() => _showDeleteDialog = false)" Variant="Variant.Text" Class="btn-cancel">
                إلغاء
            </MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       OnClick="ExecuteDelete" Disabled="@_isDeleting"
                       StartIcon="@Icons.Material.Filled.Delete" Class="btn-danger">
                @if (_isDeleting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                }
                نعم، احذف
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐⭐⭐ PREMIUM STYLES ⭐⭐⭐                                                          -->
<!-- ═══════════════════════════════════════════════════════════════════════════════════ -->
<style>
    :root { --expense-color:#f59e0b; --expense-dark:#d97706; --gold:#D4A853; --gold-dark:#B8912A; --gold-bg:#FEFBF3; --navy:#1B2A4A; --navy-dark:#0F1D36; --navy-light:#2D4A7A; }

    @@keyframes fadeInUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-15px)} }
    @@keyframes pulseGlow { 0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,0.4)} 50%{box-shadow:0 0 25px 8px rgba(245,158,11,0.15)} }
    @@keyframes shimmer { 0%{transform:translateX(-100%)} 100%{transform:translateX(100%)} }
    @@keyframes ping { 75%,100%{transform:scale(2);opacity:0} }
    @@keyframes bounceSoft { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
    @@keyframes loadingDots { 0%,80%,100%{transform:scale(0)} 40%{transform:scale(1)} }
    .animate-card { animation:fadeInUp 0.6s ease-out forwards; animation-delay:var(--delay,0s); opacity:0; }

    .loading-screen { display:flex; align-items:center; justify-content:center; min-height:70vh; }
    .loading-content { text-align:center; }
    .loading-content p { color:var(--mud-palette-text-secondary); margin-top:1rem; }
    .loading-dots { display:flex; justify-content:center; gap:0.5rem; margin-top:0.75rem; }
    .loading-dots span { width:10px; height:10px; background:var(--expense-color); border-radius:50%; animation:loadingDots 1.4s infinite both; }
    .loading-dots span:nth-child(1) { animation-delay:-0.32s; }
    .loading-dots span:nth-child(2) { animation-delay:-0.16s; }

    .grp-page { position:relative; max-width:1800px; margin:0 auto; padding:0 1rem; }
    .page-bg-decorations { position:fixed; inset:0; pointer-events:none; z-index:0; }
    .bg-orb { position:absolute; border-radius:50%; filter:blur(80px); }
    .bg-orb-1 { width:400px; height:400px; top:-200px; right:-150px; background:radial-gradient(circle,rgba(245,158,11,0.12),transparent 70%); animation:float 10s ease-in-out infinite; }
    .bg-orb-2 { width:350px; height:350px; bottom:-150px; left:-100px; background:radial-gradient(circle,rgba(139,92,246,0.06),transparent 70%); }

    .top-accent-bar { height:5px; background:linear-gradient(90deg,var(--expense-color),var(--expense-dark),var(--expense-color)); position:relative; overflow:hidden; margin-bottom:1.5rem; border-radius:0 0 10px 10px; }
    .accent-shimmer { position:absolute; inset:0; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent); animation:shimmer 3s ease-in-out infinite; }

    /* ═══════ HEADER ═══════ */
    .grp-header { position:relative; border-radius:24px; overflow:hidden; margin-bottom:1.5rem; }
    .header-bg { position:absolute; inset:0; }
    .header-gradient { position:absolute; inset:0; background:linear-gradient(135deg,#78350f 0%,#92400e 40%,#b45309 100%); }
    .header-orbs { position:absolute; inset:0; overflow:hidden; }
    .header-orb.orb-1 { position:absolute; width:300px; height:300px; top:-120px; right:-80px; background:radial-gradient(circle,rgba(251,191,36,0.25),transparent 60%); border-radius:50%; animation:float 8s ease-in-out infinite; }
    .header-orb.orb-2 { position:absolute; width:200px; height:200px; bottom:-80px; left:15%; background:radial-gradient(circle,rgba(251,191,36,0.15),transparent 60%); border-radius:50%; }
    .header-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px); background-size:40px 40px; }
    .header-content { position:relative; z-index:2; padding:2rem 2.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1.5rem; }
    .header-info { display:flex; align-items:center; gap:1.25rem; }
    .header-icon-wrapper { position:relative; }
    .header-icon-glow { position:absolute; inset:-10px; background:var(--expense-color); border-radius:20px; filter:blur(20px); opacity:0.3; animation:pulseGlow 4s ease-in-out infinite; }
    .header-icon { position:relative; width:64px; height:64px; background:rgba(255,255,255,0.1); backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,0.2); border-radius:20px; display:flex; align-items:center; justify-content:center; color:var(--expense-color); }
    .header-icon::before { content:''; position:absolute; inset:0; border-radius:20px; background:linear-gradient(135deg,rgba(255,255,255,0.2),transparent 50%); }
    .header-icon-badge { position:absolute; top:-6px; right:-6px; width:24px; height:24px; background:linear-gradient(135deg,var(--expense-color),var(--expense-dark)); border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; box-shadow:0 4px 12px rgba(245,158,11,0.4); animation:bounceSoft 2s ease-in-out infinite; }
    .header-icon-badge .mud-icon-root { font-size:12px !important; }
    .header-text h1 { margin:0; font-size:1.8rem; font-weight:900; color:white; }
    .header-text p { margin:0.5rem 0 0; font-size:0.9rem; color:rgba(255,255,255,0.6); display:flex; align-items:center; gap:0.5rem; }
    .subtitle-icon { color:#fbbf24 !important; font-size:16px !important; }
    .header-actions { display:flex; gap:0.75rem; flex-wrap:wrap; }
    .btn-add-new { position:relative; overflow:hidden; background:linear-gradient(135deg,var(--expense-color),var(--expense-dark)) !important; color:white !important; font-weight:700 !important; padding:0.875rem 1.75rem !important; border-radius:16px !important; box-shadow:0 8px 25px rgba(245,158,11,0.35) !important; transition:all 0.4s cubic-bezier(0.175,0.885,0.32,1.275) !important; }
    .btn-add-new:hover { transform:translateY(-3px) scale(1.02); }
    .btn-shine { position:absolute; top:0; left:-100%; width:100%; height:100%; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.25),transparent); transition:left 0.6s; }
    .btn-add-new:hover .btn-shine { left:100%; }
    .btn-secondary { background:rgba(255,255,255,0.1) !important; border-color:rgba(255,255,255,0.3) !important; color:white !important; font-weight:600 !important; border-radius:14px !important; }

    /* ═══════ CONTENT GRID ═══════ */
    .content-grid { display:grid; grid-template-columns:1.7fr 1fr; gap:1.25rem; margin-bottom:1.5rem; }

    /* ═══════ PANELS ═══════ */
    .tree-panel, .stats-panel { background:var(--mud-palette-surface); border:1px solid var(--mud-palette-divider); border-radius:20px; padding:1.5rem; }
    .panel-header { display:flex; align-items:center; justify-content:space-between; gap:0.875rem; margin-bottom:1.5rem; padding-bottom:1rem; border-bottom:2px solid var(--expense-color); }
    .panel-header-right { display:flex; align-items:center; gap:0.875rem; }
    .tree-controls { display:flex; gap:0.35rem; }
    .tree-ctrl-btn {
        width: 34px; height: 34px; border-radius: 8px;
