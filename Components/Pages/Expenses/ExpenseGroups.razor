    .dialog-header { position:relative; padding:1.25rem 1.5rem; display:flex; align-items:center; overflow:hidden; }
    .dialog-header-bg { position:absolute; inset:0; opacity:0.08; }
    .dialog-header-primary .dialog-header-bg { background:linear-gradient(135deg,var(--expense-color),var(--expense-dark)); }
    .dialog-header-danger .dialog-header-bg { background:linear-gradient(135deg,#ef4444,#dc2626); }
    .dialog-header::after { content:''; position:absolute; bottom:0; left:0; right:0; height:2px; }
    .dialog-header-primary::after { background:linear-gradient(90deg,var(--expense-color),var(--expense-dark)); }
    .dialog-header-danger::after { background:linear-gradient(90deg,#ef4444,#dc2626); }
    .dialog-header-content { position:relative; z-index:2; display:flex; align-items:center; gap:0.875rem; flex:1; }
    .dialog-icon-box { width:44px; height:44px; border-radius:14px; display:flex; align-items:center; justify-content:center; }
    .dialog-header-primary .dialog-icon-box { background:rgba(245,158,11,0.15); color:var(--expense-color); }
    .dialog-header-danger .dialog-icon-box { background:rgba(239,68,68,0.15); color:#ef4444; }
    .dialog-title { font-size:1.1rem; font-weight:700; color:var(--mud-palette-text-primary); }
    .dialog-close-btn { position:absolute !important; left:1rem; top:50%; transform:translateY(-50%); color:var(--mud-palette-text-secondary) !important; z-index:3; }
    .dialog-body { padding:1.5rem; display:flex; flex-direction:column; gap:1.25rem; }
    .dialog-body-centered { text-align:center; align-items:center; }
    .dialog-actions { display:flex; align-items:center; justify-content:flex-end; gap:0.625rem; padding:1.25rem 1.5rem; background:var(--mud-palette-background-gray); border-top:1px solid var(--mud-palette-divider); width:100%; }
    .dialog-actions-centered { justify-content:center; }
    .form-group { display:flex; flex-direction:column; gap:0.5rem; }
