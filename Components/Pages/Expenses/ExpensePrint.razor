@page "/expenses/print"
@layout COCOBOLOERPNEW.Components.Layout.EmptyLayout

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IExpenseService ExpenseService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="print-container" dir="rtl">
    <div class="letterhead-bg"></div>

    <table class="layout-table">
        <!-- مساحة الهيدر الثابتة في كل صفحة -->
        <thead>
            <tr>
                <td><div class="header-space"></div></td>
            </tr>
        </thead>
        
        <!-- المحتوى الفعلي للتقرير -->
        <tbody>
            <tr>
                <td>
                    <div class="content-wrapper">
                        <div class="report-header">
                            <h2>تقرير المصروفات التفصيلي</h2>
                            <div class="report-meta">
                                <span>تاريخ الطباعة: @DateTime.Now.ToString("yyyy/MM/dd HH:mm")</span>
                                @if (DateFrom.HasValue || DateTo.HasValue)
                                {
                                    <span>
                                        الفترة: 
                                        @(DateFrom?.ToString("yyyy/MM/dd") ?? "البداية") - 
                                        @(DateTo?.ToString("yyyy/MM/dd") ?? "النهاية")
                                    </span>
                                }
                            </div>
                        </div>

                        @if (_isLoading)
                        {
                            <div class="text-center py-5">جاري التحميل...</div>
                        }
                        else if (_expenses != null && _expenses.Any())
                        {
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th width="12%">التاريخ</th>
                                        <th width="28%">اسم المصروف</th>
                                        <th width="20%">المجموعة / النوع</th>
                                        <th width="15%">الخزينة</th>
                                        <th width="15%">المستلم</th>
                                        <th width="10%" class="text-left">المبلغ</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var exp in _expenses)
                                    {
                                        <tr>
                                            <td>@exp.ExpenseDate.ToString("yyyy/MM/dd")</td>
                                            <td>
                                                <strong>@exp.ExpenseName</strong>
                                                @if (exp.IsAdvance)
                                                {
                                                    <br /><small class="text-muted">مقدم (@exp.AdvanceMonths شهور)</small>
                                                }
                                            </td>
                                            <td>@(exp.FullGroupPath ?? exp.ExpenseGroupName)</td>
                                            <td>@exp.CashBoxName</td>
                                            <td>@(string.IsNullOrEmpty(exp.Recipient) ? "—" : exp.Recipient)</td>
                                            <td class="text-left amount-col">@exp.Amount.ToString("N2", CultureInfo.InvariantCulture) ج</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="5" class="text-left foot-label">إجمالي المصروفات:</td>
                                        <td class="text-left foot-total">@_totalAmount.ToString("N2", CultureInfo.InvariantCulture) ج</td>
                                    </tr>
                                </tfoot>
                            </table>
                        }
                        else
                        {
                            <div class="text-center py-5">لا توجد بيانات متاحة للطباعة بهذه الفلاتر.</div>
                        }
                    </div>
                </td>
            </tr>
        </tbody>
        
        <!-- مساحة الفوتر الثابتة في كل صفحة -->
        <tfoot>
            <tr>
                <td><div class="footer-space"></div></td>
            </tr>
        </tfoot>
    </table>
</div>

<style>
    /* إعدادات الشاشة والطباعة الأساسية */
    body, html { margin: 0; padding: 0; background-color: #525659; font-family: 'Cairo', Tahoma, sans-serif; }
    
    .print-container {
        width: 210mm;
        min-height: 297mm;
        margin: 10mm auto;
        background-color: white;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
        position: relative;
    }

    /* صورة الشركة كخلفية تتكرر في الطباعة */
    .letterhead-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-image: url('/images/design-background.png');
        background-size: 210mm 297mm;
        background-repeat: repeat-y; /* تتكرر مع كل صفحة بناءً على الطول */
        z-index: 0;
        pointer-events: none;
    }

    /* الجدول الهيكلي الذي سيجبر المتصفح على ترك المساحات */
    .layout-table { width: 100%; border-collapse: collapse; position: relative; z-index: 1; }
    
    /* المساحات المطلوبة للورق الرسمي: 4 سم من فوق، 2 سم من تحت */
    .header-space { height: 4cm; }
    .footer-space { height: 2cm; }

    .content-wrapper { padding: 0 1.5cm; } /* هوامش جانبية للجدول */

    /* تنسيقات محتوى التقرير */
    .report-header { text-align: center; margin-bottom: 20px; border-bottom: 2px solid #222; padding-bottom: 10px; }
    .report-header h2 { margin: 0; font-size: 24px; color: #111; }
    .report-meta { display: flex; justify-content: space-between; font-size: 14px; color: #444; margin-top: 10px; font-weight: bold; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 14px; background: rgba(255,255,255,0.9); }
    .data-table th, .data-table td { border: 1px solid #ccc; padding: 8px; vertical-align: middle; }
    .data-table th { background-color: #f0f0f0 !important; color: #111; font-weight: bold; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .data-table tbody tr:nth-child(even) { background-color: #fafafa !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    
    .amount-col { font-weight: bold; color: #cc0000 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .foot-label { font-weight: bold; font-size: 16px; }
    .foot-total { font-weight: bold; font-size: 18px; color: #cc0000 !important; background-color: #f0f0f0 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

    /* 🖨️ إعدادات الطباعة الحقيقية 🖨️ */
    @@media print {
        body, html { background-color: transparent; margin: 0; padding: 0; }
        .print-container { width: 100%; margin: 0; box-shadow: none; border: none; }
        
        @@page { size: A4; margin: 0; } /* إزالة هوامش المتصفح الافتراضية بالكامل */

        /* تثبيت الخلفية لتطبع على كل ورقة في الخلفية */
        .letterhead-bg { position: fixed; top: 0; left: 0; width: 210mm; height: 297mm; z-index: -1; background-size: cover; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

        /* تفعيل المسافات لكل صفحة */
        .layout-table { width: 100%; }
        .layout-table thead { display: table-header-group; }
        .layout-table tfoot { display: table-footer-group; }

        /* منع انقسام الصفوف بين الصفحات */
        .data-table tr { page-break-inside: avoid; }
    }
</style>

@code {
    [SupplyParameterFromQuery] public DateTime? DateFrom { get; set; }
    [SupplyParameterFromQuery] public DateTime? DateTo { get; set; }
    [SupplyParameterFromQuery] public int? GroupId { get; set; }
    [SupplyParameterFromQuery] public int? BoxId { get; set; }
    
    private bool _isLoading = true;
    private List<ExpenseListDto> _expenses = new();
    private decimal _totalAmount = 0;

    protected override async Task OnInitializedAsync()
    {
        var filter = new ExpenseFilterDto
        {
            DateFrom = DateFrom,
            DateTo = DateTo,
            ExpenseGroupId = GroupId,
            CashBoxId = BoxId,
            PageSize = 10000 // Get all
        };

        var result = await ExpenseService.GetExpensesAsync(filter);
        _expenses = result.Items.ToList();
        _totalAmount = _expenses.Sum(e => e.Amount);
        
        _isLoading = false;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isLoading && _expenses.Any() && firstRender)
        {
            await Task.Delay(500); // إعطاء فرصة لتحميل الصورة
            await JS.InvokeVoidAsync("window.print");
        }
    }
}
