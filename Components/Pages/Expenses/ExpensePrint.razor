@page "/expenses/print"
@layout COCOBOLOERPNEW.Components.Layout.EmptyLayout

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IExpenseService ExpenseService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="print-container" dir="rtl">
    <!-- Letterhead Background applied via CSS to print on every page -->
    <div class="letterhead-bg"></div>

    <div class="print-content">
        <div class="report-header">
            <h2>تقرير المصروفات التفصيلي</h2>
            <div class="report-meta">
                <span>تاريخ التقرير: @DateTime.Now.ToString("yyyy/MM/dd HH:mm")</span>
                @if (DateFrom.HasValue || DateTo.HasValue)
                {
                    <span>
                        الفترة: 
                        @(DateFrom?.ToString("yyyy/MM/dd") ?? "البداية") - 
                        @(DateTo?.ToString("yyyy/MM/dd") ?? "النهاية")
                    </span>
                }
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="text-center py-5">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_expenses != null && _expenses.Any())
        {
            <table class="report-table">
                <thead>
                    <tr>
                        <th width="15%">التاريخ</th>
                        <th width="25%">اسم المصروف</th>
                        <th width="20%">المجموعة</th>
                        <th width="15%">الخزينة</th>
                        <th width="15%">المستلم</th>
                        <th width="10%" class="text-left">المبلغ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var exp in _expenses)
                    {
                        <tr>
                            <td>@exp.ExpenseDate.ToString("yyyy/MM/dd")</td>
                            <td>
                                <strong>@exp.ExpenseName</strong>
                                @if (exp.IsAdvance)
                                {
                                    <br /><small class="text-muted">مقدم (@exp.AdvanceMonths شهور)</small>
                                }
                            </td>
                            <td>@exp.ExpenseGroupName</td>
                            <td>@exp.CashBoxName</td>
                            <td>@(string.IsNullOrEmpty(exp.Recipient) ? "—" : exp.Recipient)</td>
                            <td class="text-left amount-col">@exp.Amount.ToString("N2", CultureInfo.InvariantCulture) ج</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5" class="text-left"><strong>إجمالي المصروفات:</strong></td>
                        <td class="text-left total-col">@_totalAmount.ToString("N2", CultureInfo.InvariantCulture) ج</td>
                    </tr>
                </tfoot>
            </table>
        }
        else
        {
            <div class="text-center py-5">
                <p>لا توجد بيانات متاحة للطباعة بهذه الفلاتر.</p>
            </div>
        }
    </div>
</div>

<style>
    /* CSS Settings for Screen Preview and Printing */
    body, html {
        background-color: #f3f4f6;
        margin: 0;
        padding: 0;
    }

    .print-container {
        position: relative;
        background-color: white;
        margin: 0 auto;
        min-height: 100vh;
        box-shadow: 0 0 20px rgba(0,0,0,0.1);
        width: 210mm; /* A4 Width */
    }

    /* Fixed background that prints on every page */
    .letterhead-bg {
        position: absolute; /* Using absolute for screen, will change to fixed for print */
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('/images/design-background.png');
        background-size: 100% 100%;
        background-repeat: no-repeat;
        z-index: 0;
        pointer-events: none;
    }

    .print-content {
        position: relative;
        z-index: 1;
        padding-top: 4.5cm; /* Top Margin for Letterhead */
        padding-bottom: 2.5cm; /* Bottom Margin for Letterhead */
        padding-left: 1.5cm;
        padding-right: 1.5cm;
    }

    .report-header {
        text-align: center;
        margin-bottom: 2rem;
        border-bottom: 2px solid #333;
        padding-bottom: 1rem;
    }

    .report-header h2 {
        font-family: 'Cairo', sans-serif;
        font-weight: 800;
        font-size: 1.8rem;
        color: #1f2937;
        margin: 0 0 0.5rem 0;
    }

    .report-meta {
        display: flex;
        justify-content: space-between;
        font-size: 0.9rem;
        color: #4b5563;
        font-weight: 600;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
        font-family: 'Cairo', Tahoma, sans-serif;
    }

    .report-table th, .report-table td {
        border: 1px solid #d1d5db;
        padding: 0.5rem;
        vertical-align: middle;
    }

    .report-table th {
        background-color: #f3f4f6;
        color: #111827;
        font-weight: 700;
        -webkit-print-color-adjust: exact;
        color-adjust: exact;
    }

    .report-table tbody tr:nth-child(even) {
        background-color: #f9fafb;
        -webkit-print-color-adjust: exact;
        color-adjust: exact;
    }

    .amount-col {
        font-weight: 700;
        color: #ef4444;
    }

    .total-col {
        font-weight: 800;
        font-size: 1.1rem;
        background-color: #f3f4f6;
        color: #dc2626;
        -webkit-print-color-adjust: exact;
        color-adjust: exact;
    }

    @@media print {
        body, html {
            background-color: white;
        }

        .print-container {
            width: auto;
            box-shadow: none;
            margin: 0;
        }

        /* Essential settings for multi-page letterhead */
        @@page {
            size: A4;
            margin: 0 !important; /* Remove browser margins */
        }

        .letterhead-bg {
            position: fixed; /* Repeats on every printed page */
            top: 0;
            left: 0;
            width: 210mm;
            height: 297mm;
            z-index: -1;
            background-size: cover;
            -webkit-print-color-adjust: exact;
            color-adjust: exact;
        }

        .print-content {
            /* We use padding so content flows properly across pages */
            padding-top: 4.5cm;
            padding-bottom: 2.5cm;
            padding-left: 1.5cm;
            padding-right: 1.5cm;
        }
        
        .report-table { page-break-inside: auto; }
        .report-table tr { page-break-inside: avoid; page-break-after: auto; }
        .report-table thead { display: table-header-group; }
        .report-table tfoot { display: table-footer-group; }
    }
</style>

@code {
    [SupplyParameterFromQuery] public DateTime? DateFrom { get; set; }
    [SupplyParameterFromQuery] public DateTime? DateTo { get; set; }
    [SupplyParameterFromQuery] public int? GroupId { get; set; }
    [SupplyParameterFromQuery] public int? BoxId { get; set; }
    
    private bool _isLoading = true;
    private List<ExpenseListDto> _expenses = new();
    private decimal _totalAmount = 0;

    protected override async Task OnInitializedAsync()
    {
        // Load data with max page size for print report
        var filter = new ExpenseFilterDto
        {
            DateFrom = DateFrom,
            DateTo = DateTo,
            ExpenseGroupId = GroupId,
            CashBoxId = BoxId,
            PageSize = 5000 // Get all
        };

        var result = await ExpenseService.GetExpensesAsync(filter);
        _expenses = result.Items.ToList();
        _totalAmount = _expenses.Sum(e => e.Amount);
        
        _isLoading = false;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isLoading && _expenses.Any() && firstRender)
        {
            // Auto trigger print dialog after small delay to let image load
            await Task.Delay(1000);
            await JS.InvokeVoidAsync("window.print");
        }
    }
}
