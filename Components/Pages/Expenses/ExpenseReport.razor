@page "/expenses/report"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IExpenseService ExpenseService
@inject ICashBoxService CashBoxService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="exp-report-page" dir="rtl">

    <!-- ============ HERO HEADER ============ -->
    <div class="hero-header">
        <div class="hero-bg-pattern"></div>
        <div class="hero-content">
            <div class="hero-title-block">
                <div class="hero-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large" />
                </div>
                <div>
                    <h1>تقرير المصروفات</h1>
                    <p>مراجعة وفلترة المصروفات مع إمكانية الطباعة والتصدير</p>
                </div>
            </div>

            <div class="hero-actions">
                <button class="hero-btn hero-btn-glass" @onclick="@(() => Navigation.NavigateTo("/expenses/dashboard"))">
                    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" />
                    <span>لوحة التحكم</span>
                </button>
                <button class="hero-btn hero-btn-glass" @onclick="@(() => Navigation.NavigateTo("/expenses"))">
                    <MudIcon Icon="@Icons.Material.Filled.List" Size="Size.Small" />
                    <span>إدارة المصروفات</span>
                </button>
            </div>
        </div>
    </div>

    <!-- ============ KPI CARDS ============ -->
    <div class="kpi-grid">
        <div class="kpi-card kpi-blue">
            <div class="kpi-icon"><MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" /></div>
            <div class="kpi-body">
                <span class="kpi-label">إجمالي المصروفات</span>
                <span class="kpi-value">@_totalAmount.ToString("N0", CultureInfo.InvariantCulture) <small>ج</small></span>
            </div>
        </div>

        <div class="kpi-card kpi-orange">
            <div class="kpi-icon"><MudIcon Icon="@Icons.Material.Filled.Receipt" /></div>
            <div class="kpi-body">
                <span class="kpi-label">عدد العمليات</span>
                <span class="kpi-value">@_expenses.Count</span>
            </div>
        </div>

        <div class="kpi-card kpi-green">
            <div class="kpi-icon"><MudIcon Icon="@Icons.Material.Filled.TrendingUp" /></div>
            <div class="kpi-body">
                <span class="kpi-label">متوسط المصروف</span>
                <span class="kpi-value">@_avgAmount.ToString("N0", CultureInfo.InvariantCulture) <small>ج</small></span>
            </div>
        </div>

        <div class="kpi-card kpi-red">
            <div class="kpi-icon"><MudIcon Icon="@Icons.Material.Filled.ArrowUpward" /></div>
            <div class="kpi-body">
                <span class="kpi-label">أعلى مصروف</span>
                <span class="kpi-value">@_maxAmount.ToString("N0", CultureInfo.InvariantCulture) <small>ج</small></span>
            </div>
        </div>
    </div>

    <!-- ============ FILTERS ============ -->
    <div class="filters-card filters-card--compact">
        <div class="filters-toolbar-head">
            <div class="filters-toolbar-title">
                <span class="filters-toolbar-icon"><MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" /></span>
                <div>
                    <h3>شريط الفلاتر</h3>
                    <p>فلترة سريعة واحترافية لتقرير المصروفات</p>
                </div>
            </div>
            <div class="filters-toolbar-meta">
                <span class="filters-count">@GetActiveFiltersCount() فلتر نشط</span>
                <span class="filters-note">نوع المصروف يعمل بشكل مستقل عن المجموعة الرئيسية</span>
            </div>
        </div>

        <div class="filters-quick-row">
            <div class="quick-range-group">
                <span class="quick-range-label">فلاتر سريعة:</span>
                <button class="quick-chip @(IsQuickRangeActive("today") ? "active" : "")" @onclick='() => ApplyQuickRangeAsync("today")'>اليوم</button>
                <button class="quick-chip @(IsQuickRangeActive("month") ? "active" : "")" @onclick='() => ApplyQuickRangeAsync("month")'>هذا الشهر</button>
                <button class="quick-chip @(IsQuickRangeActive("lastMonth") ? "active" : "")" @onclick='() => ApplyQuickRangeAsync("lastMonth")'>الشهر السابق</button>
                <button class="quick-chip @(IsQuickRangeActive("year") ? "active" : "")" @onclick='() => ApplyQuickRangeAsync("year")'>هذه السنة</button>
                <button class="quick-chip @(IsQuickRangeActive("all") ? "active" : "")" @onclick='() => ApplyQuickRangeAsync("all")'>كل الفترات</button>
            </div>

            @if (ActiveFilterLabels.Any())
            {
                <div class="active-filter-strip">
                    @foreach (var chip in ActiveFilterLabels)
                    {
                        <span class="active-filter-chip">@chip</span>
                    }
                </div>
            }
        </div>

        <div class="filters-toolbar-row">
            <div class="toolbar-field toolbar-field--search">
                <MudTextField T="string" @bind-Value="_filter.SearchText"
                              Label="بحث نصي"
                              Placeholder="اسم المصروف / النوع / المجموعة / المستفيد / الملاحظات"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Dense="true"
                              Clearable="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Class="toolbar-control" />
            </div>

            <div class="toolbar-field toolbar-field--date">
                <MudDatePicker @bind-Date="_filter.DateFrom"
                               Label="من"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               Class="toolbar-control" />
            </div>

            <div class="toolbar-field toolbar-field--date">
                <MudDatePicker @bind-Date="_filter.DateTo"
                               Label="إلى"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               Class="toolbar-control" />
            </div>

            <div class="toolbar-field toolbar-field--group">
                <MudSelect T="int?" Value="@_filter.ParentGroupId"
                           ValueChanged="OnParentGroupChanged"
                           Label="المجموعة الرئيسية"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Dense="true"
                           Clearable="true"
                           Class="toolbar-control">
                    @foreach (var g in _mainGroups)
                    {
                        <MudSelectItem T="int?" Value="@((int?)g.ExpenseGroupId)">@g.ExpenseGroupName</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <div class="toolbar-field toolbar-field--type">
                <MudSelect T="int?" @bind-Value="_filter.ExpenseGroupId"
                           Label="نوع المصروف"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Dense="true"
                           Clearable="true"
                           Class="toolbar-control">
                    @foreach (var g in _typeGroups)
                    {
                        <MudSelectItem T="int?" Value="@((int?)g.ExpenseGroupId)">@GetGroupOptionLabel(g)</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <div class="toolbar-field toolbar-field--cashbox">
                <MudSelect T="int?" @bind-Value="_filter.CashBoxId"
                           Label="الخزينة"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Dense="true"
                           Clearable="true"
                           Class="toolbar-control">
                    @foreach (var box in _boxes)
                    {
                        <MudSelectItem T="int?" Value="@((int?)box.CashBoxId)">@box.CashBoxName</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <div class="toolbar-actions">
                <button class="btn btn-primary" @onclick="LoadData">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                    <span>بحث</span>
                </button>
                <button class="btn btn-ghost" @onclick="ClearFilters">
                    <MudIcon Icon="@Icons.Material.Filled.Clear" Size="Size.Small" />
                    <span>تفريغ</span>
                </button>
                <button class="btn btn-purple" disabled="@(!_expenses.Any())" @onclick="PrintReport">
                    <MudIcon Icon="@Icons.Material.Filled.Print" Size="Size.Small" />
                    <span>PDF</span>
                </button>
                <button class="btn btn-success" disabled="@(!_expenses.Any())" @onclick="ExportExcel">
                    <MudIcon Icon="@Icons.Material.Filled.TableView" Size="Size.Small" />
                    <span>Excel</span>
                </button>
            </div>
        </div>
    </div>

    <!-- ============ DATA TABLE ============ -->
    <div class="table-card">
        <div class="card-header">
            <div class="card-title">
                <MudIcon Icon="@Icons.Material.Filled.TableChart" />
                <h3>نتائج التقرير</h3>
            </div>
            @if (_expenses.Any())
            {
                <span class="results-count">@_expenses.Count سجل</span>
            }
        </div>

        @if (_isLoading)
        {
            <div class="skeleton-wrap">
                @for (int i = 0; i < 5; i++)
                {
                    <div class="skeleton-row"></div>
                }
            </div>
        }
        else if (!_expenses.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Size="Size.Large" />
                </div>
                <h4>لا توجد نتائج</h4>
                <p>لم نعثر على أي مصروفات مطابقة للفلاتر المحددة. جرّب تعديل الفلاتر أو إعادة تعيينها.</p>
                <button class="btn btn-ghost" @onclick="ClearFilters">
                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                    <span>إعادة تعيين الفلاتر</span>
                </button>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="report-table">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>المصروف</th>
                            <th>المجموعة</th>
                            <th>الخزينة</th>
                            <th>المستلم</th>
                            <th class="text-left">المبلغ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exp in _expenses)
                        {
                            <tr>
                                <td>
                                    <div class="date-cell">
                                        <span class="date-day">@exp.ExpenseDate.ToString("dd")</span>
                                        <span class="date-rest">@exp.ExpenseDate.ToString("MM/yyyy")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="name-cell">
                                        <strong>@exp.ExpenseName</strong>
                                        @if (exp.IsAdvance)
                                        {
                                            <span class="badge badge-advance">مقدم</span>
                                        }
                                    </div>
                                </td>
                                <td><span class="badge badge-group">@(string.IsNullOrWhiteSpace(exp.FullGroupPath) ? exp.ExpenseGroupName : exp.FullGroupPath)</span></td>
                                <td>@exp.CashBoxName</td>
                                <td>@exp.Recipient</td>
                                <td class="text-left amount">
                                    @exp.Amount.ToString("N2", CultureInfo.InvariantCulture)
                                    <small>ج</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="5" class="text-left foot-label">
                                <MudIcon Icon="@Icons.Material.Filled.Functions" Size="Size.Small" />
                                إجمالي المصروفات
                            </td>
                            <td class="text-left foot-total">
                                @_totalAmount.ToString("N2", CultureInfo.InvariantCulture) <small>ج</small>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

<style>
    /* ============ PAGE WRAPPER ============ */
    .exp-report-page {
        max-width: 1400px;
        margin: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        font-family: 'Cairo', 'Tajawal', sans-serif;
    }

    /* ============ HERO HEADER ============ */
    .hero-header {
        position: relative;
        background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 50%, #9333EA 100%);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        color: white;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(79, 70, 229, 0.3);
    }

    .hero-bg-pattern {
        position: absolute;
        inset: 0;
        background-image: 
            radial-gradient(circle at 20% 20%, rgba(255,255,255,0.1) 0%, transparent 50%),
            radial-gradient(circle at 80% 80%, rgba(255,255,255,0.08) 0%, transparent 50%);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        z-index: 1;
    }

    .hero-title-block {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .hero-icon-wrap {
        width: 60px; height: 60px;
        background: rgba(255,255,255,0.18);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.25);
        border-radius: 16px;
        display: grid; place-items: center;
        color: white;
    }

    .hero-title-block h1 {
        margin: 0; font-size: 1.75rem; font-weight: 800; color: white;
    }
    .hero-title-block p {
        margin: .25rem 0 0; opacity: .9; font-size: .95rem;
    }

    .hero-actions { display: flex; gap: .75rem; flex-wrap: wrap; }
    .hero-btn {
        display: inline-flex; align-items: center; gap: .5rem;
        padding: .65rem 1.25rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: .9rem;
        cursor: pointer;
        transition: all .2s ease;
        border: 1px solid rgba(255,255,255,0.25);
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        color: white;
    }
    .hero-btn:hover { background: rgba(255,255,255,0.25); transform: translateY(-2px); }

    /* ============ KPI CARDS ============ */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
    }
    .kpi-card {
        background: white;
        border-radius: 16px;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: 1px solid #f1f5f9;
        position: relative;
        overflow: hidden;
        transition: all .3s ease;
    }
    .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    .kpi-card::before {
        content: ''; position: absolute; top: 0; right: 0; left: 0; height: 4px;
    }
    .kpi-blue::before   { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
    .kpi-orange::before { background: linear-gradient(90deg, #f97316, #fb923c); }
    .kpi-green::before  { background: linear-gradient(90deg, #10b981, #34d399); }
    .kpi-red::before    { background: linear-gradient(90deg, #ef4444, #f87171); }

    .kpi-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: grid; place-items: center;
        flex-shrink: 0;
    }
    .kpi-blue   .kpi-icon { background: #dbeafe; color: #2563eb; }
    .kpi-orange .kpi-icon { background: #ffedd5; color: #ea580c; }
    .kpi-green  .kpi-icon { background: #d1fae5; color: #059669; }
    .kpi-red    .kpi-icon { background: #fee2e2; color: #dc2626; }

    .kpi-body { display: flex; flex-direction: column; gap: .25rem; }
    .kpi-label { font-size: .85rem; color: #64748b; font-weight: 500; }
    .kpi-value { font-size: 1.5rem; font-weight: 800; color: #0f172a; }
    .kpi-value small { font-size: .85rem; font-weight: 600; color: #64748b; margin-right: .25rem; }

    /* ============ CARDS ============ */
    .filters-card, .table-card {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: 1px solid #f1f5f9;
    }

    .filters-card--compact {
        position: sticky;
        top: 1rem;
        z-index: 20;
        padding: 1.1rem 1.25rem 1.25rem;
        background: linear-gradient(180deg, rgba(255,255,255,.96) 0%, rgba(250,251,255,.98) 100%);
        backdrop-filter: blur(14px);
        box-shadow: 0 10px 30px rgba(79, 70, 229, 0.06);
    }

    .card-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 1.25rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #f1f5f9;
    }
    .card-title { display: flex; align-items: center; gap: .6rem; color: #4F46E5; }
    .card-title h3 { margin: 0; font-size: 1.1rem; font-weight: 700; color: #0f172a; }

    .filters-toolbar-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: .9rem;
        padding-bottom: .85rem;
        border-bottom: 1px solid #eef2ff;
        flex-wrap: wrap;
    }

    .filters-toolbar-title {
        display: flex;
        align-items: center;
        gap: .8rem;
    }

    .filters-toolbar-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: grid;
        place-items: center;
        color: #4F46E5;
        background: #eef2ff;
        flex-shrink: 0;
    }

    .filters-toolbar-title h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
        color: #0f172a;
    }

    .filters-toolbar-title p {
        margin: .15rem 0 0;
        font-size: .82rem;
        color: #64748b;
    }

    .filters-toolbar-meta {
        display: flex;
        align-items: center;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .filters-count, .results-count {
        background: #eef2ff;
        color: #4F46E5;
        padding: .35rem .85rem;
        border-radius: 100px;
        font-size: .8rem;
        font-weight: 600;
    }

    .filters-note {
        background: #f8fafc;
        color: #475569;
        padding: .35rem .75rem;
        border: 1px solid #e2e8f0;
        border-radius: 100px;
        font-size: .78rem;
        font-weight: 600;
    }

    .filters-quick-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        margin-bottom: .85rem;
        flex-wrap: wrap;
    }

    .quick-range-group,
    .active-filter-strip {
        display: flex;
        align-items: center;
        gap: .45rem;
        flex-wrap: wrap;
    }

    .quick-range-label {
        font-size: .78rem;
        font-weight: 700;
        color: #64748b;
        margin-inline-end: .1rem;
    }

    .quick-chip,
    .active-filter-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 30px;
        padding: .35rem .8rem;
        border-radius: 999px;
        font-size: .77rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .quick-chip {
        background: white;
        color: #475569;
        border: 1px solid #dbe3f3;
        cursor: pointer;
        transition: all .2s ease;
        font-family: inherit;
    }

    .quick-chip:hover {
        border-color: #6366f1;
        color: #4338ca;
        background: #f5f7ff;
        transform: translateY(-1px);
    }

    .quick-chip.active {
        background: linear-gradient(135deg, #4F46E5, #6366F1);
        color: white;
        border-color: transparent;
        box-shadow: 0 8px 20px rgba(79, 70, 229, 0.18);
    }

    .active-filter-strip {
        justify-content: flex-end;
    }

    .active-filter-chip {
        background: #eef2ff;
        color: #4338ca;
        border: 1px solid #c7d2fe;
    }

    .filters-toolbar-row {
        display: flex;
        align-items: flex-end;
        gap: .75rem;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: .15rem;
    }

    .toolbar-field {
        flex: 0 0 auto;
    }

    .toolbar-field--search { width: 340px; }
    .toolbar-field--date { width: 140px; }
    .toolbar-field--group { width: 190px; }
    .toolbar-field--type { width: 250px; }
    .toolbar-field--cashbox { width: 180px; }

    .toolbar-actions {
        display: flex;
        align-items: center;
        gap: .55rem;
        margin-inline-start: auto;
        padding-inline-start: .25rem;
        flex: 0 0 auto;
    }

    .toolbar-control {
        min-width: 100%;
    }

    ::deep .toolbar-control .mud-input-control {
        margin-top: 0 !important;
    }

    ::deep .toolbar-control .mud-input-outlined-border {
        border-radius: 12px !important;
    }

    /* ============ BUTTONS ============ */
    .btn {
        display: inline-flex; align-items: center; gap: .5rem;
        padding: .65rem 1.25rem;
        border-radius: 10px;
        font-weight: 600; font-size: .9rem;
        cursor: pointer; transition: all .2s ease;
        border: none;
        font-family: inherit;
    }
    .btn:disabled { opacity: .5; cursor: not-allowed; }
    .btn:not(:disabled):hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0,0,0,0.1); }

    .btn-primary { background: linear-gradient(135deg, #4F46E5, #6366F1); color: white; }
    .btn-purple  { background: linear-gradient(135deg, #7C3AED, #9333EA); color: white; }
    .btn-success { background: linear-gradient(135deg, #059669, #10b981); color: white; }
    .btn-ghost   { background: #f1f5f9; color: #475569; }
    .btn-ghost:hover { background: #e2e8f0; }

    /* ============ TABLE ============ */
    .table-responsive { overflow-x: auto; border-radius: 12px; }
    .report-table { width: 100%; border-collapse: separate; border-spacing: 0; }

    .report-table th {
        padding: 1rem 1.25rem;
        font-weight: 700;
        font-size: .85rem;
        color: #475569;
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        text-align: right;
        position: sticky; top: 0;
    }
    .report-table th:first-child { border-top-right-radius: 12px; }
    .report-table th:last-child  { border-top-left-radius: 12px; }

    .report-table td {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        font-size: .92rem;
        color: #334155;
    }
    .report-table tbody tr { transition: all .15s ease; }
    .report-table tbody tr:hover td { background: #fafbff; }

    .text-left { text-align: left !important; }

    .date-cell { display: flex; flex-direction: column; line-height: 1.2; }
