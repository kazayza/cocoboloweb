@code {
    private bool _isLoading = true;
    private ExpenseFilterDto _filter = new();

    private List<ExpenseListDto> _expenses = new();
    private decimal _totalAmount = 0;
    private decimal _avgAmount = 0;
    private decimal _maxAmount = 0;

    private List<ExpenseGroupDto> _allGroups = new();
    private List<ExpenseGroupDto> _mainGroups = new();
    private List<ExpenseGroupDto> _typeGroups = new();

    private List<CashBoxListDto> _boxes = new();

    protected override async Task OnInitializedAsync()
    {
        _allGroups = await ExpenseService.GetExpenseGroupsAsync();
        _mainGroups = _allGroups
            .Where(g => g.ParentGroupId == null)
            .OrderBy(g => g.ExpenseGroupName)
            .ToList();
        _typeGroups = _allGroups
            .OrderBy(g => g.ParentGroupId.HasValue ? 0 : 1)
            .ThenBy(g => g.ParentGroupName)
            .ThenBy(g => g.ExpenseGroupName)
            .ToList();

        _boxes = await CashBoxService.GetCashBoxesAsync();

        var today = DateTime.Today;
        _filter.DateFrom = new DateTime(today.Year, today.Month, 1);
        _filter.DateTo = _filter.DateFrom.Value.AddMonths(1).AddDays(-1);

        await LoadData();
    }

    private void OnParentGroupChanged(int? parentId)
    {
        _filter.ParentGroupId = parentId;
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        _filter.PageSize = 5000;
        var result = await ExpenseService.GetExpensesAsync(_filter);

        _expenses = result.Items.ToList();
        _totalAmount = _expenses.Sum(e => e.Amount);
        _avgAmount = _expenses.Any() ? _expenses.Average(e => e.Amount) : 0;
        _maxAmount = _expenses.Any() ? _expenses.Max(e => e.Amount) : 0;

        _isLoading = false;
        StateHasChanged();
    }

    private async Task ClearFilters()
    {
        _filter = new ExpenseFilterDto { PageSize = 5000 };
        await LoadData();
    }

    private string GetGroupOptionLabel(ExpenseGroupDto group)
    {
        if (string.IsNullOrWhiteSpace(group.ParentGroupName))
            return group.ExpenseGroupName;

        return $"{group.ParentGroupName} / {group.ExpenseGroupName}";
    }

    private IEnumerable<string> ActiveFilterLabels
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(_filter.SearchText))
                yield return $"بحث: {_filter.SearchText}";

            if (_filter.DateFrom.HasValue || _filter.DateTo.HasValue)
            {
                var fromText = _filter.DateFrom?.ToString("yyyy/MM/dd") ?? "البداية";
                var toText = _filter.DateTo?.ToString("yyyy/MM/dd") ?? "النهاية";
                yield return $"الفترة: {fromText} → {toText}";
            }

            if (_filter.ParentGroupId.HasValue)
            {
                var parent = _mainGroups.FirstOrDefault(g => g.ExpenseGroupId == _filter.ParentGroupId.Value);
                if (parent != null)
                    yield return $"المجموعة: {parent.ExpenseGroupName}";
            }

            if (_filter.ExpenseGroupId.HasValue)
            {
                var group = _typeGroups.FirstOrDefault(g => g.ExpenseGroupId == _filter.ExpenseGroupId.Value);
                if (group != null)
                    yield return $"النوع: {GetGroupOptionLabel(group)}";
            }

            if (_filter.CashBoxId.HasValue)
            {
                var box = _boxes.FirstOrDefault(b => b.CashBoxId == _filter.CashBoxId.Value);
                if (box != null)
                    yield return $"الخزينة: {box.CashBoxName}";
            }
        }
    }

    private async Task ApplyQuickRangeAsync(string preset)
    {
        var (from, to) = GetQuickRange(preset);
        _filter.DateFrom = from;
        _filter.DateTo = to;
        await LoadData();
    }

    private bool IsQuickRangeActive(string preset)
    {
        var (from, to) = GetQuickRange(preset);
        return _filter.DateFrom == from && _filter.DateTo == to;
    }

    private static (DateTime? From, DateTime? To) GetQuickRange(string preset)
    {
        var today = DateTime.Today;
        return preset switch
        {
            "today" => (today, today),
            "month" => (new DateTime(today.Year, today.Month, 1), new DateTime(today.Year, today.Month, 1).AddMonths(1).AddDays(-1)),
            "lastMonth" => (new DateTime(today.Year, today.Month, 1).AddMonths(-1), new DateTime(today.Year, today.Month, 1).AddDays(-1)),
            "year" => (new DateTime(today.Year, 1, 1), new DateTime(today.Year, 12, 31)),
            "all" => (null, null),
            _ => (null, null)
        };
    }

    private int GetActiveFiltersCount()
    {
        int count = 0;
        if (!string.IsNullOrWhiteSpace(_filter.SearchText)) count++;
        if (_filter.DateFrom.HasValue) count++;
        if (_filter.DateTo.HasValue) count++;
        if (_filter.ParentGroupId.HasValue) count++;
        if (_filter.ExpenseGroupId.HasValue) count++;
        if (_filter.CashBoxId.HasValue) count++;
        return count;
    }

    private async Task PrintReport()
    {
        var query = new List<string>();
        if (!string.IsNullOrWhiteSpace(_filter.SearchText)) query.Add($"SearchText={Uri.EscapeDataString(_filter.SearchText.Trim())}");
        if (_filter.DateFrom.HasValue) query.Add($"DateFrom={_filter.DateFrom.Value:yyyy-MM-dd}");
        if (_filter.DateTo.HasValue) query.Add($"DateTo={_filter.DateTo.Value:yyyy-MM-dd}");
        if (_filter.ParentGroupId.HasValue) query.Add($"ParentGroupId={_filter.ParentGroupId.Value}");
        if (_filter.ExpenseGroupId.HasValue) query.Add($"GroupId={_filter.ExpenseGroupId.Value}");
        if (_filter.CashBoxId.HasValue) query.Add($"BoxId={_filter.CashBoxId.Value}");

        var url = "/expenses/print" + (query.Any() ? "?" + string.Join("&", query) : "");
        await JS.InvokeVoidAsync("window.open", url, "_blank");
    }

    private async Task ExportExcel()
    {
        var fileBytes = await ExpenseService.ExportExpensesToExcelAsync(_filter);
        var base64 = Convert.ToBase64String(fileBytes);
        await JS.InvokeVoidAsync("downloadFileFromBase64", base64, "ExpenseReport.xlsx");
    }
}