@page "/expenses"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IExpenseService ExpenseService
@inject ICashBoxService CashBoxService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ LOADING                                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <p>جاري تحميل المصروفات...</p>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else
{
    <div class="exp-page" dir="rtl">

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ BACKGROUND                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="page-bg-decorations">
            <div class="bg-orb bg-orb-1"></div>
            <div class="bg-orb bg-orb-2"></div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ ACCENT BAR                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ PREMIUM HEADER                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="exp-header">
            <div class="header-bg">
                <div class="header-gradient"></div>
                <div class="header-orbs">
                    <div class="header-orb orb-1"></div>
                    <div class="header-orb orb-2"></div>
                </div>
                <div class="header-grid"></div>
            </div>

            <div class="header-content">
                <div class="header-top">
                    <div class="header-info">
                        <div class="header-icon-wrapper">
                            <div class="header-icon-glow"></div>
                            <div class="header-icon">
                                <MudIcon Icon="@Icons.Material.Filled.MoneyOff" Size="Size.Large" />
                            </div>
                            <div class="header-icon-badge">
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                            </div>
                        </div>
                        <div class="header-text">
                            <div class="header-title-row">
                                <h1>المصروفات</h1>
                                <span class="premium-badge">
                                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                                    Premium
                                </span>
                            </div>
                            <p>
                                <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" Class="subtitle-icon" />
                                إدارة وتسجيل كل المصروفات 
                            </p>
                        </div>
                    </div>

                    <div class="header-actions">
                        @if (_canAdd)
                        {
                            <MudButton Variant="Variant.Filled"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="@(() => Navigation.NavigateTo("/expenses/new"))"
                                       Class="btn-add-new">
                                <span class="btn-shine"></span>
                                مصروف جديد
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.AccountTree"
                                   OnClick="@(() => Navigation.NavigateTo("/expense-groups"))"
                                   Class="btn-secondary">
                            المجموعات
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.Dashboard"
                                   OnClick="@(() => Navigation.NavigateTo("/cashbox/dashboard"))"
                                   Class="btn-secondary">
                            Dashboard
                        </MudButton>
                    </div>
                </div>

                <!-- Premium Stats -->
                <div class="stats-grid">
                    <div class="stat-card stat-today animate-card" style="--delay:0.05s">
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.Today" />
                            </div>
                            <div class="stat-data">
                                <span class="stat-value">@FormatMoney(_stats.TodayAmount)</span>
                                <div class="stat-label">مصروفات اليوم</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-month animate-card" style="--delay:0.1s">
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
                            </div>
                            <div class="stat-data">
                                <span class="stat-value">@FormatMoney(_stats.MonthAmount)</span>
                                <div class="stat-label">هذا الشهر</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-year animate-card" style="--delay:0.15s">
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.DateRange" />
                            </div>
                            <div class="stat-data">
                                <span class="stat-value">@FormatMoney(_stats.YearAmount)</span>
                                <div class="stat-label">هذه السنة</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-total animate-card" style="--delay:0.2s">
                        <div class="stat-glow"></div>
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.MonetizationOn" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-value-row">
                                    <span class="stat-value">@FormatMoney(_stats.TotalAmount)</span>
                                    <span class="stat-count-badge">@_stats.TotalCount مصروف</span>
                                </div>
                                <div class="stat-label">الإجمالي</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ FILTER BAR                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="filter-container animate-card" style="--delay:0.25s">
            <div class="filter-header" @onclick="() => _filterExpanded = !_filterExpanded">
                <div class="filter-header-right">
                    <div class="filter-icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
                    </div>
                    <span class="filter-title">بحث وتصفية</span>
                    @if (HasActiveFilters())
                    {
                        <span class="filter-active-badge">
                            <span class="badge-pulse"></span>
                            فلتر نشط
                        </span>
                    }
                </div>
                <div class="filter-header-left">
                    @if (HasActiveFilters())
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   OnClick="ResetFilters" Class="btn-reset-filter">
                            مسح الكل
                        </MudButton>
                    }
                    <div class="filter-expand-icon @(_filterExpanded ? "expanded" : "")">
                        <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" />
                    </div>
                </div>
            </div>

            @if (_filterExpanded)
            {
                <div class="filter-content">
                    <div class="filter-grid">
                        <!-- Search -->
                        <div class="search-box-wrapper">
                            <div class="search-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                            </div>
                            <input type="text"
                                   value="@_searchDisplay"
                                   @oninput="OnSearchInput"
                                   placeholder="بحث في الاسم / المستلم / الملاحظات..."
                                   class="search-input" />
                            @if (!string.IsNullOrWhiteSpace(_searchDisplay))
                            {
                                <button class="search-clear" @onclick="ClearSearch">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            }
                        </div>

                        <!-- المجموعة -->
                        <MudSelect T="int?" @bind-Value="_filter.ExpenseGroupId" @bind-Value:after="OnFilterChange"
                                   Label="المجموعة" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" AnchorOrigin="Origin.BottomCenter"
                                   Class="filter-select">
                            @foreach (var g in _groups)
                            {
                                <MudSelectItem T="int?" Value="@((int?)g.ExpenseGroupId)">@g.ExpenseGroupName</MudSelectItem>
                            }
                        </MudSelect>

                        <!-- الخزينة -->
                        <MudSelect T="int?" @bind-Value="_filter.CashBoxId" @bind-Value:after="OnFilterChange"
                                   Label="الخزينة" Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true" AnchorOrigin="Origin.BottomCenter"
                                   Class="filter-select">
                            @foreach (var cb in _boxes)
                            {
                                <MudSelectItem T="int?" Value="@((int?)cb.CashBoxId)">@cb.CashBoxName</MudSelectItem>
                            }
                        </MudSelect>

                        <!-- من تاريخ -->
                        <MudDatePicker Date="_dateFrom"
                                       DateChanged="@(d => { _dateFrom = d; _filter.DateFrom = d; _ = OnFilterChange(); })"
                                       Label="من تاريخ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Clearable="true" Class="filter-select"
                                       Adornment="Adornment.Start"
                                       AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />

                        <!-- إلى تاريخ -->
                        <MudDatePicker Date="_dateTo"
                                       DateChanged="@(d => { _dateTo = d; _filter.DateTo = d; _ = OnFilterChange(); })"
                                       Label="إلى تاريخ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       Clearable="true" Class="filter-select" />
                    </div>

                    <!-- Advanced Toggle -->
                    <div class="filter-advanced">
                        <div class="advance-toggle">
                            <MudSwitch T="bool" Value="@(_filter.OnlyParents == true)"
                                       ValueChanged="@(async (bool v) => { _filter.OnlyParents = v ? (bool?)true : null; await OnFilterChange(); })"
                                       Color="Color.Primary" />
                            <span class="advance-label">
                                <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" />
                                إخفاء أشهر المصروف المقدم
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Loading Bar -->
        @if (_isTableLoading)
        {
            <div class="loading-bar"><MudProgressLinear Color="Color.Primary" Indeterminate="true" /></div>
        }

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ TABLE                                                            -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="table-container animate-card" style="--delay:0.3s">
            <div class="table-header-bar">
                <div class="table-header-right">
                    <div class="table-dot-wrapper">
                        <span class="table-dot"></span>
                        <span class="table-dot-ping"></span>
                    </div>
                    <span class="table-title">قائمة المصروفات</span>
                    <span class="table-count">@_pagedResult.TotalCount مصروف</span>
                </div>
            </div>

            <MudTable Items="@_pagedResult.Items" Hover="true" Striped="true" Class="expenses-table">
                <HeaderContent>
                    <MudTh>التاريخ</MudTh>
                    <MudTh>المصروف</MudTh>
                    <MudTh>المجموعة</MudTh>
                    <MudTh>المستلم</MudTh>
                    <MudTh>الخزينة</MudTh>
                    <MudTh>المبلغ</MudTh>
                    <MudTh Style="width:70px;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <!-- التاريخ -->
                    <MudTd DataLabel="التاريخ">
                        <div class="date-cell">
                            <span class="date-main">@context.ExpenseDate.ToString("yyyy/MM/dd")</span>
                            <span class="date-day">@context.ExpenseDate.ToString("dddd", new CultureInfo("ar-EG"))</span>
                        </div>
                        @if (context.IsAdvanceChild)
                        {
                            <span class="advance-badge child">
                                <MudIcon Icon="@Icons.Material.Filled.SubdirectoryArrowLeft" Size="Size.Small" />
                                شهر فرعي
                            </span>
                        }
                        else if (context.IsAdvance && context.AdvanceMonths > 1)
                        {
                            <span class="advance-badge parent">
                                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                                مصروف مقدم
                            </span>
                        }
                    </MudTd>

                    <!-- المصروف -->
                    <MudTd DataLabel="المصروف">
                        <div class="expense-name-cell">
                            @if (context.IsAdvanceChild)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.SubdirectoryArrowLeft" Size="Size.Small" Class="child-arrow" />
                            }
                            <div>
                                <div class="expense-name">@context.ExpenseName</div>
                                @if (!string.IsNullOrEmpty(context.Notes))
                                {
                                    <div class="expense-notes">@context.Notes</div>
                                }
                            </div>
                        </div>
                    </MudTd>

                    <!-- المجموعة -->
                    <MudTd DataLabel="المجموعة">
                        <span class="group-badge">
                            <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" />
                            @(string.IsNullOrEmpty(context.FullGroupPath) ? context.ExpenseGroupName : context.FullGroupPath)
                        </span>
                    </MudTd>

                    <!-- المستلم -->
                    <MudTd DataLabel="المستلم">
                        @if (!string.IsNullOrEmpty(context.Recipient))
                        {
                            <div class="recipient-cell">
                                <div class="recipient-avatar">
                                    @(context.Recipient.Length >= 2 ? context.Recipient.Substring(0, 2) : context.Recipient)
                                </div>
                                <span>@context.Recipient</span>
                            </div>
                        }
                        else
                        {
                            <span class="empty-cell">—</span>
                        }
                    </MudTd>

                    <!-- الخزينة -->
                    <MudTd DataLabel="الخزينة">
                        <span class="cashbox-badge">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Small" />
                            @(context.CashBoxName ?? "—")
                        </span>
                    </MudTd>

                    <!-- المبلغ -->
                    <MudTd DataLabel="المبلغ">
                        <div class="amount-cell">
                            <span class="amount-value">-@FormatMoney(context.Amount)</span>
                            <span class="amount-currency">ج.م</span>
                        </div>
                        @if (context.IsAdvance && context.AdvanceMonths > 1 && !context.IsAdvanceChild)
                        {
                            <div class="months-info">
                                <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" />
                                @context.AdvanceMonths شهور
                            </div>
                        }
                    </MudTd>

                    <!-- الإجراءات -->
<MudTd>
    <div class="table-actions">
        @{
            // تحديد لو ده مصروف مقدم (أصل أو شهر فرعي)
            var isAdvanceExpense = (context.IsAdvance && context.AdvanceMonths > 1)
                                  || context.AdvanceParentExpenseId.HasValue;
        }

        @* ⭐ زرار التعديل - مخفي للمصروف المقدم *@
        @if (_canEdit && !isAdvanceExpense)
        {
            <MudTooltip Text="تعديل" Placement="Placement.Top">
                <button class="action-btn action-edit"
                        @onclick="@(() => Navigation.NavigateTo($"/expenses/{context.ExpenseId}/edit"))">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                </button>
            </MudTooltip>
        }
        else if (_canEdit && isAdvanceExpense)
        {
            @* تنبيه إن المصروف مقدم - مش قابل للتعديل *@
            <MudTooltip Text="مصروف مقدم - غير قابل للتعديل" Placement="Placement.Top">
                <button class="action-btn action-locked" disabled>
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                </button>
            </MudTooltip>
        }

        @if (_canDelete)
        {
            <MudTooltip Text="حذف" Placement="Placement.Top">
                <button class="action-btn action-delete" @onclick="@(() => ConfirmDelete(context))">
                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                </button>
            </MudTooltip>
        }
    </div>
</MudTd>
                </RowTemplate>
            </MudTable>

            @if (!_pagedResult.Items.Any())
            {
                <div class="empty-state">
                    <div class="empty-illustration">
                        <div class="empty-icon-box">
                            <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" />
                        </div>
                        <div class="empty-particles">
                            <span class="particle particle-1"></span>
                            <span class="particle particle-2"></span>
                        </div>
                    </div>
                    <h3>لا توجد مصروفات</h3>
                    <p>لم يتم العثور على أي مصروفات بالفلاتر الحالية</p>
                </div>
            }
        </div>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ GROUP BREAKDOWN                                                  -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        @if (_stats.GroupBreakdown.Any())
        {
            <div class="breakdown-container animate-card" style="--delay:0.35s">
                <div class="breakdown-header">
                    <div class="breakdown-icon">
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" />
                    </div>
                    <div>
                        <h3>تفصيل المصروفات حسب المجموعة</h3>
                        <p>أعلى 10 مجموعات</p>
                    </div>
                </div>
                <div class="breakdown-list">
                    @foreach (var b in _stats.GroupBreakdown.Take(10))
                    {
                        <div class="bd-row">
                            <span class="bd-name">@b.GroupName</span>
                            <div class="bd-bar-wrap">
                                <div class="bd-bar" style="width: @b.Percentage%;"></div>
                            </div>
                            <span class="bd-amount">@FormatMoney(b.Total) ج.م</span>
                            <span class="bd-pct">@b.Percentage%</span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ PAGINATION                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        @if (_pagedResult.TotalPages > 1)
        {
            <div class="pagination-bar">
                <span class="pagination-info">
                    صفحة <strong>@_filter.PageNumber</strong> من <strong>@_pagedResult.TotalPages</strong>
                </span>
                <MudPagination Count="@_pagedResult.TotalPages"
                               Selected="@_filter.PageNumber"
                               SelectedChanged="OnPageChanged"
                               Color="Color.Primary"
                               ShowFirstButton="true" ShowLastButton="true"
                               BoundaryCount="1" MiddleCount="3"
                               Class="pagination-component" />
            </div>
        }

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ⭐ FOOTER                                                           -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <div class="page-footer">
            <div class="footer-content">
                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="footer-icon" />
                <span>COCOBOLO ERP — نظام إدارة المصروفات</span>
                <span class="footer-premium">Premium</span>
            </div>
        </div>

    </div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DELETE DIALOG                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showDeleteDialog" Class="premium-dialog">
    <TitleContent>
        <div class="dialog-header dialog-header-danger">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" />
                </div>
                <span class="dialog-title">تأكيد الحذف</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showDeleteDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body dialog-body-centered">
            <div class="delete-icon-box">
                <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Large" />
            </div>
            <h3 class="delete-title">هل أنت متأكد؟</h3>
            @if (_selectedExpense != null)
            {
                <p class="delete-message">
                    @if (_selectedExpense.IsAdvance && _selectedExpense.AdvanceMonths > 1)
                    {
                        <span>سيتم حذف '<strong>@_selectedExpense.ExpenseName</strong>' وكل الـ <strong>@_selectedExpense.AdvanceMonths</strong> شهور المرتبطة</span>
                    }
                    else
                    {
                        <span>سيتم حذف '<strong>@_selectedExpense.ExpenseName</strong>'</span>
                    }
                </p>
                <div class="delete-amount">
                    <MudIcon Icon="@Icons.Material.Filled.Money" Size="Size.Small" />
                    المبلغ: <strong>@FormatMoney(_selectedExpense.Amount) ج.م</strong>
                </div>
            }
            <span class="delete-note">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                هذا الإجراء لا يمكن التراجع عنه
            </span>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions dialog-actions-centered">
            <MudButton OnClick="@(() => _showDeleteDialog = false)" Variant="Variant.Text" Class="btn-cancel">
                إلغاء
            </MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       OnClick="ExecuteDelete" Disabled="@_isDeleting"
                       StartIcon="@Icons.Material.Filled.Delete" Class="btn-danger">
                @if (_isDeleting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                }
                نعم، احذف
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>


<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐⭐⭐ PREMIUM STYLES ⭐⭐⭐                                                                              -->
<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════════ -->
<style>
    :root {
        --gold: #D4A853;
        --gold-dark: #B8912A;
        --gold-bg: #FEFBF3;
        --navy: #1B2A4A;
        --navy-dark: #0F1D36;
        --navy-light: #2D4A7A;
        --expense-color: #f59e0b;
        --expense-dark: #d97706;
    }

    @@keyframes fadeInUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
    @@keyframes float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-15px); } }
    @@keyframes pulseGlow { 0%,100% { box-shadow:0 0 0 0 rgba(245,158,11,0.4); } 50% { box-shadow:0 0 25px 8px rgba(245,158,11,0.15); } }
    @@keyframes shimmer { 0% { transform:translateX(-100%); } 100% { transform:translateX(100%); } }
    @@keyframes ping { 75%,100% { transform:scale(2); opacity:0; } }
    @@keyframes loadingDots { 0%,80%,100% { transform:scale(0); } 40% { transform:scale(1); } }
    @@keyframes bounceSoft { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-5px); } }
    .animate-card { animation: fadeInUp 0.6s ease-out forwards; animation-delay:var(--delay,0s); opacity:0; }

    /* ═══════ LOADING ═══════ */
    .loading-screen { display:flex; align-items:center; justify-content:center; min-height:70vh; }
    .loading-content { text-align:center; }
    .loading-content p { color:var(--mud-palette-text-secondary); margin-top:1rem; }
    .loading-dots { display:flex; justify-content:center; gap:0.5rem; margin-top:0.75rem; }
    .loading-dots span { width:10px; height:10px; background:var(--expense-color); border-radius:50%; animation:loadingDots 1.4s infinite both; }
    .loading-dots span:nth-child(1) { animation-delay:-0.32s; }
    .loading-dots span:nth-child(2) { animation-delay:-0.16s; }

    /* ═══════ PAGE ═══════ */
    .exp-page { position:relative; max-width:1800px; margin:0 auto; padding:0 1rem; }
    .page-bg-decorations { position:fixed; inset:0; pointer-events:none; z-index:0; }
    .bg-orb { position:absolute; border-radius:50%; filter:blur(80px); }
    .bg-orb-1 { width:400px; height:400px; top:-200px; right:-150px; background:radial-gradient(circle,rgba(245,158,11,0.12),transparent 70%); animation:float 10s ease-in-out infinite; }
    .bg-orb-2 { width:350px; height:350px; bottom:-150px; left:-100px; background:radial-gradient(circle,rgba(59,130,246,0.06),transparent 70%); }

    .top-accent-bar { height:5px; background:linear-gradient(90deg,var(--expense-color),var(--expense-dark),var(--expense-color)); position:relative; overflow:hidden; margin-bottom:1.5rem; border-radius:0 0 10px 10px; }
    .accent-shimmer { position:absolute; inset:0; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.4),transparent); animation:shimmer 3s ease-in-out infinite; }

    /* ═══════ HEADER ═══════ */
    .exp-header { position:relative; border-radius:24px; overflow:hidden; margin-bottom:1.5rem; }
    .header-bg { position:absolute; inset:0; }
    .header-gradient { position:absolute; inset:0; background:linear-gradient(135deg,#78350f 0%,#92400e 40%,#b45309 100%); }
    .header-orbs { position:absolute; inset:0; overflow:hidden; }
    .header-orb { position:absolute; border-radius:50%; }
    .header-orb.orb-1 { width:350px; height:350px; top:-150px; right:-100px; background:radial-gradient(circle,rgba(251,191,36,0.25),transparent 60%); animation:float 8s ease-in-out infinite; }
    .header-orb.orb-2 { width:250px; height:250px; bottom:-100px; left:20%; background:radial-gradient(circle,rgba(251,191,36,0.15),transparent 60%); }
    .header-grid { position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px); background-size:40px 40px; }
    .header-content { position:relative; z-index:2; padding:2rem 2.5rem; }
    .header-top { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1.5rem; margin-bottom:2rem; }
    .header-info { display:flex; align-items:center; gap:1.25rem; }
    .header-icon-wrapper { position:relative; }
    .header-icon-glow { position:absolute; inset:-10px; background:var(--expense-color); border-radius:20px; filter:blur(20px); opacity:0.3; animation:pulseGlow 4s ease-in-out infinite; }
    .header-icon { position:relative; width:64px; height:64px; background:rgba(255,255,255,0.1); backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,0.2); border-radius:20px; display:flex; align-items:center; justify-content:center; color:var(--expense-color); box-shadow:0 8px 32px rgba(0,0,0,0.2); }
    .header-icon::before { content:''; position:absolute; inset:0; border-radius:20px; background:linear-gradient(135deg,rgba(255,255,255,0.2),transparent 50%); }
    .header-icon-badge { position:absolute; top:-6px; right:-6px; width:24px; height:24px; background:linear-gradient(135deg,var(--expense-color),var(--expense-dark)); border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; box-shadow:0 4px 12px rgba(245,158,11,0.4); animation:bounceSoft 2s ease-in-out infinite; }
    .header-icon-badge .mud-icon-root { font-size:12px !important; }
    .header-text h1 { margin:0; font-size:1.8rem; font-weight:900; color:white; }
    .header-title-row { display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap; }
    .premium-badge { display:inline-flex; align-items:center; gap:0.35rem; background:rgba(255,255,255,0.1); border:1px solid rgba(251,191,36,0.3); color:var(--expense-color); font-size:0.7rem; font-weight:700; padding:0.3rem 0.6rem; border-radius:20px; }
    .premium-badge .mud-icon-root { font-size:10px !important; }
    .header-text p { margin:0.5rem 0 0; font-size:0.9rem; color:rgba(255,255,255,0.6); display:flex; align-items:center; gap:0.5rem; }
    .subtitle-icon { color:#fbbf24 !important; font-size:16px !important; }
    .header-actions { display:flex; gap:0.75rem; flex-wrap:wrap; }
    .btn-add-new { position:relative; overflow:hidden; background:linear-gradient(135deg,var(--expense-color),var(--expense-dark)) !important; color:white !important; font-weight:700 !important; padding:0.875rem 1.75rem !important; border-radius:16px !important; box-shadow:0 8px 25px rgba(245,158,11,0.35) !important; transition:all 0.4s cubic-bezier(0.175,0.885,0.32,1.275) !important; }
    .btn-add-new:hover { transform:translateY(-3px) scale(1.02); box-shadow:0 12px 35px rgba(245,158,11,0.45) !important; }
    .btn-shine { position:absolute; top:0; left:-100%; width:100%; height:100%; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.25),transparent); transition:left 0.6s; }
    .btn-add-new:hover .btn-shine { left:100%; }
    .btn-secondary { background:rgba(255,255,255,0.1) !important; border-color:rgba(255,255,255,0.3) !important; color:white !important; font-weight:600 !important; border-radius:14px !important; }
    .btn-secondary:hover { background:rgba(255,255,255,0.15) !important; }

    /* ═══════ STATS ═══════ */
    .stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; }
    .stat-card { position:relative; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12); border-radius:16px; padding:1.25rem; overflow:hidden; transition:all 0.4s ease; cursor:default; }
    .stat-card:hover { background:rgba(255,255,255,0.12); transform:translateY(-3px); border-color:rgba(251,191,36,0.3); }
    .stat-glow { position:absolute; inset:-50%; opacity:0; transition:opacity 0.5s; }
    .stat-card:hover .stat-glow { opacity:1; }
    .stat-accent { position:absolute; top:0; left:0; right:0; height:3px; transform:scaleX(0); transform-origin:right; transition:transform 0.4s; }
    .stat-card:hover .stat-accent { transform:scaleX(1); }
    .stat-content { position:relative; z-index:2; display:flex; align-items:center; gap:0.875rem; }
    .stat-icon-box { width:48px; height:48px; border-radius:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:transform 0.3s; }
    .stat-card:hover .stat-icon-box { transform:scale(1.1); }
    .stat-data { min-width:0; flex:1; }
    .stat-value-row { display:flex; align-items:center; gap:0.5rem; }
    .stat-value { font-size:1.4rem; font-weight:900; color:#F1F5F9; line-height:1; }
    .stat-count-badge { font-size:0.6rem; font-weight:700; background:rgba(255,255,255,0.15); color:rgba(255,255,255,0.8); padding:0.15rem 0.4rem; border-radius:6px; }
    .stat-label { font-size:0.72rem; font-weight:600; color:rgba(241,245,249,0.6); margin-top:0.15rem; }

    .stat-today .stat-glow { background:radial-gradient(circle,rgba(34,197,94,0.2),transparent 70%); }
    .stat-today .stat-accent { background:linear-gradient(90deg,#22c55e,#16a34a); }
    .stat-today .stat-icon-box { background:rgba(34,197,94,0.2); color:#22c55e; }
    .stat-month .stat-glow { background:radial-gradient(circle,rgba(59,130,246,0.2),transparent 70%); }
    .stat-month .stat-accent { background:linear-gradient(90deg,#3b82f6,#2563eb); }
    .stat-month .stat-icon-box { background:rgba(59,130,246,0.2); color:#3b82f6; }
    .stat-year .stat-glow { background:radial-gradient(circle,rgba(139,92,246,0.2),transparent 70%); }
    .stat-year .stat-accent { background:linear-gradient(90deg,#8b5cf6,#7c3aed); }
    .stat-year .stat-icon-box { background:rgba(139,92,246,0.2); color:#8b5cf6; }
    .stat-total .stat-glow { background:radial-gradient(circle,rgba(245,158,11,0.2),transparent 70%); }
    .stat-total .stat-accent { background:linear-gradient(90deg,var(--expense-color),var(--expense-dark)); }
    .stat-total .stat-icon-box { background:rgba(245,158,11,0.2); color:var(--expense-color); }

    /* ═══════ FILTER ═══════ */
    .filter-container { background:var(--mud-palette-surface); border:1px solid var(--mud-palette-divider); border-radius:20px; margin-bottom:1.25rem; overflow:hidden; }
    .filter-header { display:flex; align-items:center; justify-content:space-between; padding:1rem 1.5rem; cursor:pointer; transition:background 0.2s; }
    .filter-header:hover { background:var(--mud-palette-background-gray); }
    .filter-header-right { display:flex; align-items:center; gap:0.75rem; }
    .filter-icon-box { width:36px; height:36px; background:var(--mud-palette-background-gray); border-radius:10px; display:flex; align-items:center; justify-content:center; color:var(--mud-palette-text-secondary); transition:all 0.3s; }
    .filter-header:hover .filter-icon-box { background:var(--expense-color); color:white; }
    .filter-title { font-size:0.9rem; font-weight:700; color:var(--mud-palette-text-primary); }
    .filter-active-badge { position:relative; background:var(--expense-color); color:white; font-size:0.68rem; font-weight:700; padding:0.25rem 0.6rem; border-radius:12px; overflow:hidden; }
    .badge-pulse { position:absolute; inset:0; background:white; border-radius:12px; opacity:0; animation:ping 1.5s ease-in-out infinite; }
    .filter-header-left { display:flex; align-items:center; gap:0.5rem; }
    .btn-reset-filter { font-size:0.75rem !important; }
    .filter-expand-icon { transition:transform 0.3s; }
    .filter-expand-icon.expanded { transform:rotate(180deg); }
    .filter-content { padding:0 1.5rem 1.25rem; border-top:1px solid var(--mud-palette-divider); }
    .filter-grid { display:grid; grid-template-columns:2fr repeat(4,1fr); gap:0.875rem; padding-top:1rem; }
    .search-box-wrapper { display:flex; align-items:center; background:var(--mud-palette-background); border:1px solid var(--mud-palette-divider); border-radius:12px; padding:0 0.75rem; height:42px; transition:all 0.3s; }
    .search-box-wrapper:focus-within { border-color:var(--expense-color); box-shadow:0 0 0 3px rgba(245,158,11,0.1); }
    .search-icon { color:var(--mud-palette-text-secondary); margin-left:0.5rem; }
    .search-input { flex:1; background:transparent; border:none; outline:none; color:var(--mud-palette-text-primary); font-size:0.875rem; padding:0 0.5rem; font-family:inherit; }
    .search-input::placeholder { color:var(--mud-palette-text-secondary); }
    .search-clear { width:24px; height:24px; border-radius:6px; display:flex; align-items:center; justify-content:center; background:var(--mud-palette-background-gray); border:none; cursor:pointer; color:var(--mud-palette-text-secondary); transition:all 0.2s; }
    .search-clear:hover { background:#fef2f2; color:#ef4444; }
    ::deep .filter-select .mud-input-outlined-border { border-radius:12px !important; }
    .filter-advanced { padding-top:1rem; border-top:1px dashed var(--mud-palette-divider); margin-top:1rem; }
    .advance-toggle { display:flex; align-items:center; gap:0.5rem; }
    .advance-label { display:flex; align-items:center; gap:0.35rem; font-size:0.82rem; color:var(--mud-palette-text-secondary); font-weight:600; }
    .advance-label .mud-icon-root { font-size:16px !important; }

    .loading-bar { margin-bottom:1rem; border-radius:10px; overflow:hidden; }

    /* ═══════ TABLE ═══════ */
    .table-container { background:var(--mud-palette-surface); border:1px solid var(--mud-palette-divider); border-radius:20px; overflow:hidden; margin-bottom:1.5rem; }
    .table-header-bar { padding:1rem 1.5rem; border-bottom:1px solid var(--mud-palette-divider); display:flex; align-items:center; justify-content:space-between; background:linear-gradient(90deg,var(--mud-palette-background-gray),var(--mud-palette-surface)); }
    .table-header-right { display:flex; align-items:center; gap:0.625rem; }
    .table-dot-wrapper { position:relative; width:12px; height:12px; }
    .table-dot { position:absolute; inset:2px; background:linear-gradient(135deg,var(--expense-color),var(--expense-dark)); border-radius:50%; }
    .table-dot-ping { position:absolute; inset:0; background:var(--expense-color); border-radius:50%; animation:ping 2s ease-in-out infinite; }
    .table-title { font-size:0.9rem; font-weight:700; color:var(--mud-palette-text-primary); }
    .table-count { font-size:0.72rem; color:var(--mud-palette-text-secondary); background:var(--mud-palette-background-gray); padding:0.25rem 0.6rem; border-radius:12px; font-weight:600; }

    ::deep .expenses-table .mud-table-head th { background:var(--mud-palette-background-gray) !important; font-size:0.8rem !important; font-weight:700 !important; color:var(--mud-palette-text-secondary) !important; padding:0.875rem 1rem !important; }
    ::deep .expenses-table .mud-table-body tr { transition:all 0.3s; }
    ::deep .expenses-table .mud-table-body tr:hover { background:rgba(245,158,11,0.04) !important; }
    ::deep .expenses-table .mud-table-body td { padding:1rem !important; vertical-align:middle !important; }

    .date-cell { display:flex; flex-direction:column; }
    .date-main { font-size:0.85rem; font-weight:600; color:var(--mud-palette-text-primary); }
    .date-day { font-size:0.68rem; color:var(--mud-palette-text-secondary); }
    .advance-badge { display:inline-flex; align-items:center; gap:0.25rem; padding:0.2rem 0.5rem; border-radius:6px; font-size:0.65rem; font-weight:700; margin-top:0.35rem; }
    .advance-badge .mud-icon-root { font-size:12px !important; }
    .advance-badge.parent { background:rgba(245,158,11,0.12); color:#d97706; border:1px solid rgba(245,158,11,0.3); }
    .advance-badge.child { background:rgba(99,102,241,0.12); color:#4f46e5; border:1px solid rgba(99,102,241,0.3); }

    .expense-name-cell { display:flex; align-items:flex-start; gap:0.5rem; }
    .child-arrow { color:#6366f1 !important; margin-top:3px; }
    .expense-name { font-weight:700; font-size:0.88rem; color:var(--mud-palette-text-primary); }
    .expense-notes { font-size:0.72rem; color:var(--mud-palette-text-secondary); margin-top:0.15rem; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    .group-badge { display:inline-flex; align-items:center; gap:0.3rem; background:var(--gold-bg); color:var(--gold-dark); padding:0.3rem 0.6rem; border-radius:8px; font-size:0.75rem; font-weight:700; border:1px solid rgba(212,168,83,0.2); }
    .group-badge .mud-icon-root { font-size:14px !important; }

    .recipient-cell { display:flex; align-items:center; gap:0.5rem; font-size:0.85rem; }
    .recipient-avatar { width:30px; height:30px; background:linear-gradient(135deg,var(--expense-color),var(--expense-dark)); color:white; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:0.65rem; font-weight:800; }
    .empty-cell { color:var(--mud-palette-text-disabled); }

    .cashbox-badge { display:inline-flex; align-items:center; gap:0.3rem; background:rgba(59,130,246,0.08); color:#3b82f6; padding:0.3rem 0.6rem; border-radius:8px; font-size:0.75rem; font-weight:600; border:1px solid rgba(59,130,246,0.15); }
    .cashbox-badge .mud-icon-root { font-size:14px !important; }

    .amount-cell { display:flex; align-items:baseline; gap:0.25rem; }
    .amount-value { font-size:1rem; font-weight:900; color:#ef4444; }
    .amount-currency { font-size:0.65rem; font-weight:600; color:var(--mud-palette-text-disabled); background:var(--mud-palette-background-gray); padding:0.15rem 0.35rem; border-radius:4px; }
    .months-info { display:flex; align-items:center; gap:0.25rem; font-size:0.68rem; color:var(--mud-palette-text-secondary); margin-top:0.25rem; }
    .months-info .mud-icon-root { font-size:12px !important; }

    .table-actions { display:flex; justify-content:center; opacity:0.4; transition:opacity 0.3s; }
    tr:hover .table-actions { opacity:1; }
    .action-btn { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; background:transparent; border:1px solid var(--mud-palette-divider); cursor:pointer; transition:all 0.2s; }
    .action-btn:hover { transform:scale(1.1); }
    .action-delete { color:#ef4444; }
    .action-delete:hover { background:#fef2f2; border-color:#ef4444; }
    .action-edit {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(59, 130, 246, 0.05));
    color: #3b82f6;
    border-color: rgba(59, 130, 246, 0.3);
}

.action-edit:hover {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(59, 130, 246, 0.1));
    color: #2563eb;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
}

.action-locked {
    background: linear-gradient(135deg, rgba(156, 163, 175, 0.1), rgba(156, 163, 175, 0.05));
    color: #9ca3af;
    border-color: rgba(156, 163, 175, 0.3);
    cursor: not-allowed !important;
    opacity: 0.6;
}

.action-locked:hover {
    transform: none;
}

    /* ═══════ EMPTY STATE ═══════ */
    .empty-state { text-align:center; padding:4rem 2rem; }
    .empty-illustration { position:relative; width:120px; height:120px; margin:0 auto 1.5rem; }
    .empty-icon-box { position:absolute; inset:10px; background:var(--mud-palette-background-gray); border-radius:24px; display:flex; align-items:center; justify-content:center; color:var(--mud-palette-text-disabled); z-index:2; }
    .empty-particles { position:absolute; inset:0; }
    .particle { position:absolute; border-radius:50%; animation:bounceSoft 2s ease-in-out infinite; }
    .particle-1 { width:14px; height:14px; top:-5px; right:-5px; background:var(--expense-color); }
    .particle-2 { width:10px; height:10px; bottom:0; left:-5px; background:#3b82f6; animation-delay:0.3s; }
    .empty-state h3 { font-size:1.2rem; font-weight:700; color:var(--mud-palette-text-primary); margin:0 0 0.5rem; }
    .empty-state p { color:var(--mud-palette-text-secondary); margin:0; }

    /* ═══════ BREAKDOWN ═══════ */
    .breakdown-container { background:var(--mud-palette-surface); border:1px solid var(--mud-palette-divider); border-radius:20px; padding:1.5rem; margin-bottom:1.5rem; }
    .breakdown-header { display:flex; align-items:center; gap:0.875rem; margin-bottom:1.5rem; padding-bottom:1rem; border-bottom:2px solid var(--expense-color); }
    .breakdown-icon { width:44px; height:44px; background:rgba(245,158,11,0.1); border-radius:12px; display:flex; align-items:center; justify-content:center; color:var(--expense-color); }
    .breakdown-header h3 { margin:0; font-size:1rem; font-weight:700; color:var(--mud-palette-text-primary); }
    .breakdown-header p { margin:0.15rem 0 0; font-size:0.78rem; color:var(--mud-palette-text-secondary); }
    .breakdown-list { display:flex; flex-direction:column; gap:0.5rem; }
    .bd-row { display:grid; grid-template-columns:2fr 3fr auto auto; gap:0.75rem; align-items:center; padding:0.6rem 0.75rem; border-radius:10px; background:var(--mud-palette-background); transition:all 0.2s; }
    .bd-row:hover { background:rgba(245,158,11,0.05); }
    .bd-name { font-weight:600; font-size:0.85rem; color:var(--mud-palette-text-primary); }
    .bd-bar-wrap { background:var(--mud-palette-divider); height:10px; border-radius:5px; overflow:hidden; }
    .bd-bar { height:100%; background:linear-gradient(90deg,var(--expense-color),var(--expense-dark)); border-radius:5px; transition:width 0.8s ease; }
    .bd-amount { font-weight:700; font-size:0.85rem; color:var(--mud-palette-text-primary); }
    .bd-pct { font-size:0.75rem; background:rgba(245,158,11,0.1); color:var(--expense-dark); padding:0.2rem 0.5rem; border-radius:6px; font-weight:700; }

    /* ═══════ PAGINATION ═══════ */
    .pagination-bar { display:flex; align-items:center; justify-content:center; gap:1.5rem; margin-bottom:1.5rem; flex-wrap:wrap; }
    .pagination-info { font-size:0.82rem; color:var(--mud-palette-text-secondary); }
    .pagination-info strong { color:var(--mud-palette-text-primary); }

    /* ═══════ FOOTER ═══════ */
    .page-footer { text-align:center; padding-bottom:1.5rem; }
    .footer-content { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.75rem; color:var(--mud-palette-text-secondary); background:var(--mud-palette-surface); padding:0.6rem 1.25rem; border-radius:20px; border:1px solid var(--mud-palette-divider); }
    .footer-icon { color:var(--expense-color) !important; }
    .footer-premium { color:var(--expense-color); font-weight:700; }

    /* ═══════ DELETE DIALOG ═══════ */
