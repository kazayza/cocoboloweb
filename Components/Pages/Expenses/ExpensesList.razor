@code {
    // ════════════════════════════════════════════════════════════════════════════
    // STATE
    // ════════════════════════════════════════════════════════════════════════════
    private bool _isLoading = true;
    private bool _isTableLoading = false;
    private bool _filterExpanded = true;
    private string _searchDisplay = "";

    // Delete Dialog
    private bool _showDeleteDialog = false;
    private bool _isDeleting = false;
    private ExpenseListDto? _selectedExpense;

    private ExpenseFilterDto _filter = new() { OnlyParents = true };
    private PagedResult<ExpenseListDto> _pagedResult = new();
    private ExpenseStatsDto _stats = new();
    private List<CashBoxListDto> _boxes = new();
    private List<ExpenseGroupDto> _groups = new();
    private DateTime? _dateFrom, _dateTo;

    private bool _canAdd, _canEdit, _canDelete;

    private System.Timers.Timer? _searchTimer;

    // ════════════════════════════════════════════════════════════════════════════
    // LIFECYCLE
    // ════════════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frm_ExpensesList:View") || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        _canAdd = user.HasClaim("Permission", "frm_ExpensesList:Add") || user.IsInRole("Admin");
        _canEdit = user.HasClaim("Permission", "frm_ExpensesList:Edit") || user.IsInRole("Admin");
        _canDelete = user.HasClaim("Permission", "frm_ExpensesList:Delete") || user.IsInRole("Admin");

        _boxes = await CashBoxService.GetCashBoxesAsync();
        _groups = await ExpenseService.GetExpenseGroupsAsync();
        await LoadData();
        _isLoading = false;
    }

    // ════════════════════════════════════════════════════════════════════════════
    // DATA
    // ════════════════════════════════════════════════════════════════════════════
    private async Task LoadData()
    {
        _isTableLoading = true;
        StateHasChanged();
        _pagedResult = await ExpenseService.GetExpensesAsync(_filter);
        _stats = await ExpenseService.GetStatsAsync();
        _isTableLoading = false;
        StateHasChanged();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // SEARCH WITH ARABIC NORMALIZE + DEBOUNCE
    // ════════════════════════════════════════════════════════════════════════════
    private void OnSearchInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        _searchDisplay = value;
        _filter.SearchText = value.NormalizeArabic();

        _searchTimer?.Stop();
        _searchTimer?.Dispose();
        _searchTimer = new System.Timers.Timer(400);
        _searchTimer.Elapsed += async (_, _) =>
        {
            _searchTimer?.Stop();
            await InvokeAsync(async () =>
            {
                _filter.PageNumber = 1;
                await LoadData();
                StateHasChanged();
            });
        };
        _searchTimer.AutoReset = false;
        _searchTimer.Start();
    }

    private async Task ClearSearch()
    {
        _searchDisplay = "";
        _filter.SearchText = "";
        _filter.PageNumber = 1;
        await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // FILTERS
    // ════════════════════════════════════════════════════════════════════════════
    private bool HasActiveFilters() =>
        !string.IsNullOrWhiteSpace(_searchDisplay) ||
        _filter.ExpenseGroupId.HasValue ||
        _filter.CashBoxId.HasValue ||
        _dateFrom.HasValue ||
        _dateTo.HasValue;

    private async Task OnFilterChange()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnPageChanged(int p)
    {
        _filter.PageNumber = p;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _searchDisplay = "";
        _filter = new() { OnlyParents = true };
        _dateFrom = null;
        _dateTo = null;
        await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // DELETE (Fixed - No ShowMessageBox)
    // ════════════════════════════════════════════════════════════════════════════
    private void ConfirmDelete(ExpenseListDto exp)
    {
        _selectedExpense = exp;
        _showDeleteDialog = true;
    }

    private async Task ExecuteDelete()
    {
        if (_selectedExpense == null) return;

        _isDeleting = true;
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userName = auth.User.Identity?.Name ?? "System";

        var (ok, message) = await ExpenseService.DeleteExpenseAsync(_selectedExpense.ExpenseId, userName);
        _isDeleting = false;
        _showDeleteDialog = false;

        Snackbar.Add(message, ok ? Severity.Success : Severity.Error);
        if (ok) await LoadData();
    }

    // ════════════════════════════════════════════════════════════════════════════
    // HELPERS
    // ════════════════════════════════════════════════════════════════════════════
    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);
}
