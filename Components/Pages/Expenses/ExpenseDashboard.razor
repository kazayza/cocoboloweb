                        {
                            <ApexChart TItem="ExpenseParetoDto" Height="220" Options="_paretoBarOptions">
                                <ApexPointSeries TItem="ExpenseParetoDto"
                                                 Items="_dashboard.ParetoAnalysis.Take(6)"
                                                 SeriesType="SeriesType.Bar"
                                                 Name="المبلغ"
                                                 XValue="e => e.ItemName"
                                                 YValue="e => e.Amount" />
                            </ApexChart>

                            <MudDivider Class="my-3" />

                            <MudStack Spacing="1">
                                @foreach (var item in _dashboard.ParetoAnalysis.Take(6))
                                {
                                    var isFocus = item.CumulativePercentage <= 80 || Math.Abs(item.CumulativePercentage - 80) < 0.1m;
                                    <div class="pareto-row">
                                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2" Class="page-title">@item.ItemName</MudText>
                                                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                                                    @item.Amount.ToString("N0") ج • @item.Percentage%
                                                </MudText>
                                            </MudStack>

                                            <MudStack Spacing="1" AlignItems="MudBlazor.AlignItems.End">
                                                <MudChip T="string"
                                                         Size="MudBlazor.Size.Small"
                                                         Color="@(isFocus ? MudBlazor.Color.Primary : MudBlazor.Color.Default)"
                                                         Variant="@(isFocus ? Variant.Filled : Variant.Outlined)">
                                                    تراكمي @item.CumulativePercentage%
                                                </MudChip>
                                            </MudStack>
                                        </MudStack>
                                    </div>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <div class="empty-soft">لا توجد بيانات لتحليل باريتو</div>
                        }
                    </MudPaper>
                </MudItem>

            </MudGrid>

            <MudGrid Spacing="3">

                <MudItem xs="12" lg="4">
                    <MudPaper Elevation="0" Class="section-card pa-4" Style="min-height:360px;">
                        <MudStack Spacing="2">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6" Class="section-title">
                                    <MudIcon Icon="@Icons.Material.Filled.Speed" Class="me-1" />
                                    مؤشر الإنفاق المتوقع
                                </MudText>
                                <MudText Typo="Typo.body2" Class="section-subtitle">
                                    تقدير نهاية الشهر بناءً على المتوسط الحالي
                                </MudText>
                            </MudStack>

                            <MudPaper Elevation="0" Class="metric-soft-box pa-4">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.caption" Class="muted-label">المصروف المتوقع نهاية الشهر</MudText>
                                    <MudText Typo="Typo.h4" Class="page-title">@projectedAmount.ToString("N0") ج</MudText>
                                    <MudText Typo="Typo.caption" Color="@spendColor" Class="page-title">
                                        @(projectedVsPrev > 0 ? "+" : "")@projectedVsPrev.ToString("N1")%
                                        مقارنة بالشهر السابق
                                    </MudText>
                                </MudStack>
                            </MudPaper>

                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Class="muted-label">نسبة التقدم مقابل الشهر السابق</MudText>
                                <MudProgressLinear Rounded
                                                   Color="@spendColor"
                                                   Value="@GetProgressPercent()"
                                                   Max="150"
                                                   Size="MudBlazor.Size.Large"
                                                   Style="height:18px;" />
                            </MudStack>

                            <MudPaper Elevation="0" Class="insight-box pa-4">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.caption" Class="muted-label">قراءة سريعة</MudText>
                                    <MudText Typo="Typo.body1" Class="insight-status" Color="@spendColor">
                                        @GetSpendingStatusText(projectedVsPrev)
                                    </MudText>
                                    <MudText Typo="Typo.body2" Color="MudBlazor.Color.Secondary">
                                        @GetSpendingStatusDescription(projectedVsPrev)
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="8">
                    <MudPaper Elevation="0" Class="section-card pa-4" Style="min-height:360px;">
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6" Class="section-title">
                                    <MudIcon Icon="@Icons.Material.Filled.ViewList" Class="me-1" />
                                    تفاصيل التوزيع حسب المجموعات
                                </MudText>
                                <MudText Typo="Typo.body2" Class="section-subtitle">
                                    مساهمة كل مجموعة في إجمالي المصروفات منذ بداية السنة
                                </MudText>
                            </MudStack>
                        </MudStack>

                        @if (_dashboard.GroupDistribution.Any())
                        {
                            <MudStack Spacing="3">
                                @for (int i = 0; i < _dashboard.GroupDistribution.Count; i++)
                                {
                                    var g = _dashboard.GroupDistribution[i];
                                    <MudStack Spacing="1">
                                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Spacing="1">
                                                <span class="legend-dot" style="background:@GetPaletteColor(i)"></span>
                                                <MudText Typo="Typo.body2" Class="page-title">@g.GroupName</MudText>
                                                <MudChip T="string" Size="MudBlazor.Size.Small" Variant="Variant.Text" Color="MudBlazor.Color.Default">
                                                    @g.Count عملية
                                                </MudChip>
                                            </MudStack>

                                            <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Spacing="2">
                                                <MudText Typo="Typo.body2" Class="page-title">@g.Total.ToString("N0") ج</MudText>
                                                <MudChip T="string" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Primary" Variant="Variant.Outlined">
                                                    @g.Percentage%
                                                </MudChip>
                                            </MudStack>
                                        </MudStack>

                                        <MudProgressLinear Rounded
                                                           Color="MudBlazor.Color.Primary"
                                                           Value="@((double)g.Percentage)"
                                                           Max="100"
                                                           Size="MudBlazor.Size.Medium"
                                                           Style="height:12px;" />
                                    </MudStack>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <div class="empty-soft">لا توجد بيانات تفصيلية للتوزيع</div>
                        }
                    </MudPaper>
                </MudItem>

            </MudGrid>
        }
    </MudContainer>
</div>

@code {
    private readonly CultureInfo _arCulture = new("ar-EG");

    private bool _loading = true;
    private ExpenseDashboardDto? _dashboard;

    private ApexChartOptions<ExpenseMonthlyTrendDto> _monthlyTrendOptions = new();
    private ApexChartOptions<ExpenseGroupStatsDto> _donutOptions = new();
    private ApexChartOptions<ExpenseDailyTrendDto> _dailyTrendOptions = new();
    private ApexChartOptions<ExpenseParetoDto> _paretoBarOptions = new();

    protected override async Task OnInitializedAsync()
    {
        InitializeChartOptions();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _dashboard = await ExpenseService.GetDashboardDataAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Expense dashboard error: {ex.Message}");
            _dashboard = null;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void InitializeChartOptions()
    {
        _monthlyTrendOptions = new ApexChartOptions<ExpenseMonthlyTrendDto>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
                FontFamily = "inherit",
                Animations = new Animations { Enabled = true }
            },
            Colors = new List<string> { "#2563eb" },
            Stroke = new Stroke
            {
                Curve = Curve.Smooth,
                Width = 3
            },
            Fill = new Fill
            {
                Type = new List<FillType> { FillType.Gradient },
                Gradient = new FillGradient
                {
                    ShadeIntensity = 1,
                    OpacityFrom = 0.38,
                    OpacityTo = 0.05,
                    Stops = new List<double> { 0, 100 }
                }
            },
            DataLabels = new DataLabels { Enabled = false },
            Grid = new Grid
            {
                BorderColor = "#eef2f7",
                StrokeDashArray = 4
            },
            Xaxis = new XAxis
            {
                Labels = new XAxisLabels
                {
                    Style = new AxisLabelStyle { FontSize = "11px" }
                }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Formatter = @"function(val){
                            if(val>=1000000) return (val/1000000).toFixed(1)+'M';
                            if(val>=1000) return (val/1000).toFixed(0)+'K';
                            return val.toFixed(0);
                        }"
                    }
                }
            },
            Tooltip = new Tooltip
            {
                Y = new TooltipY
                {
                    Formatter = @"function(val){
                        return val.toLocaleString('ar-EG') + ' ج';
                    }"
                }
            }
        };

        _donutOptions = new ApexChartOptions<ExpenseGroupStatsDto>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
                FontFamily = "inherit"
            },
            Colors = new List<string>
            {
                "#2563eb", "#7c3aed", "#0f766e", "#f59e0b", "#ef4444",
                "#06b6d4", "#8b5cf6", "#10b981", "#f97316", "#64748b"
            },
            Legend = new Legend { Show = false },
            DataLabels = new DataLabels { Enabled = false },
            PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    Donut = new PlotOptionsDonut
                    {
                        Size = "72%",
                        Labels = new DonutLabels
                        {
                            Show = true,
                            Total = new DonutLabelTotal
                            {
                                Show = true,
                                Label = "الإجمالي",
                                Formatter = @"function(w){
                                    var total = w.globals.seriesTotals.reduce((a,b)=>a+b,0);
                                    return total.toLocaleString('ar-EG');
                                }"
                            }
                        }
                    }
                }
            },
            Tooltip = new Tooltip
            {
                Y = new TooltipY
                {
                    Formatter = @"function(val){
                        return val.toLocaleString('ar-EG') + ' ج';
                    }"
                }
            }
        };

        _dailyTrendOptions = new ApexChartOptions<ExpenseDailyTrendDto>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
                FontFamily = "inherit"
            },
            Colors = new List<string> { "#0ea5e9" },
            DataLabels = new DataLabels { Enabled = false },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar
                {
                    BorderRadius = 5,
                    ColumnWidth = "58%"
                }
            },
            Grid = new Grid
            {
                BorderColor = "#eef2f7",
                StrokeDashArray = 4
            },
            Xaxis = new XAxis
            {
                Labels = new XAxisLabels
                {
                    Style = new AxisLabelStyle { FontSize = "10px" }
                }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Formatter = @"function(val){
                            if(val>=1000) return (val/1000).toFixed(0)+'K';
                            return val.toFixed(0);
                        }"
                    }
                }
            },
            Tooltip = new Tooltip
            {
                Y = new TooltipY
                {
                    Formatter = @"function(val){
                        return val.toLocaleString('ar-EG') + ' ج';
                    }"
                }
            }
        };

        _paretoBarOptions = new ApexChartOptions<ExpenseParetoDto>
        {
            Chart = new Chart
            {
                Toolbar = new Toolbar { Show = false },
