@* ============================================================
   📁 Pages/Expenses/ExpenseDashboard.razor
   ⭐ شاشة مؤشرات أداء المصروفات - احترافية
   ============================================================ *@

@page "/expenses/dashboard"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using ApexCharts
@using MudBlazor
@using Microsoft.AspNetCore.Authorization

@inject IExpenseService ExpenseService
@attribute [Authorize]
@rendermode InteractiveServer

@* ── نحل تعارض Color و Size و Align بين ApexCharts و MudBlazor ── *@
@* في الـ HTML نستخدم MudBlazor.Color و MudBlazor.Size صراحةً *@

<PageTitle>مؤشرات أداء المصروفات</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-6">

    @* ── Header ── *@
    <MudStack Row AlignItems="MudBlazor.AlignItems.Center"
              Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4" Class="fw-bold" Style="color:#1a237e;">
                <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="me-2" />
                مؤشرات أداء المصروفات
            </MudText>
            <MudText Typo="Typo.body2" Color="MudBlazor.Color.Secondary">
                تحليل مالي شامل • آخر تحديث: @DateTime.Now.ToString("hh:mm tt - yyyy/MM/dd")
            </MudText>
        </MudStack>
        <MudStack Row Spacing="2">
            <MudButton Variant="Variant.Outlined"
                       Color="MudBlazor.Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadDataAsync"
                       Disabled="_loading">
                تحديث
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="MudBlazor.Color.Primary"
                       StartIcon="@Icons.Material.Filled.ListAlt"
                       Href="/expenses">
                قائمة المصروفات
            </MudButton>
        </MudStack>
    </MudStack>

    @* ── Loading ── *@
    @if (_loading)
    {
        <MudStack AlignItems="MudBlazor.AlignItems.Center"
                  Justify="Justify.Center"
                  Style="min-height:400px;">
            <MudProgressCircular Indeterminate
                                 Size="MudBlazor.Size.Large"
                                 Color="MudBlazor.Color.Primary" />
            <MudText Typo="Typo.body1" Color="MudBlazor.Color.Secondary" Class="mt-3">
                جارٍ تحميل البيانات...
            </MudText>
        </MudStack>
    }
    else if (_dashboard == null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">
            حدث خطأ في تحميل البيانات. حاول مرة أخرى.
        </MudAlert>
    }
    else
    {
        @* ═══════════════════════════════════════════════════════
           ROW 1: KPI Cards الرئيسية
           ═══════════════════════════════════════════════════════ *@
        <MudGrid Spacing="3" Class="mb-4">

            @* Card 1: مصروفات الشهر الحالي *@
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-4 rounded-lg"
                          Style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);
                                 color:white; min-height:160px;">
                    <MudStack Spacing="1">
                        <MudStack Row
                                  AlignItems="MudBlazor.AlignItems.Center"
                                  Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2" Style="opacity:0.85;">
                                مصروفات الشهر الحالي
                            </MudText>
                            <MudAvatar Style="background:rgba(255,255,255,0.2);"
                                       Size="MudBlazor.Size.Medium">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
                            </MudAvatar>
                        </MudStack>
                        <MudText Typo="Typo.h4" Class="fw-bold">
                            @_dashboard.CurrentMonthAmount.ToString("N0") ج
                        </MudText>
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@GetGrowthIcon(_dashboard.MonthOverMonthGrowth)"
                                     Size="MudBlazor.Size.Small" />
                            <MudText Typo="Typo.caption"
                                     Style="@GetGrowthStyle(_dashboard.MonthOverMonthGrowth)">
                                @GetGrowthText(_dashboard.MonthOverMonthGrowth) عن الشهر السابق
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @* Card 2: الشهر السابق *@
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-4 rounded-lg"
                          Style="background:linear-gradient(135deg,#f093fb 0%,#f5576c 100%);
                                 color:white; min-height:160px;">
                    <MudStack Spacing="1">
                        <MudStack Row
                                  AlignItems="MudBlazor.AlignItems.Center"
                                  Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2" Style="opacity:0.85;">
                                مصروفات الشهر السابق
                            </MudText>
                            <MudAvatar Style="background:rgba(255,255,255,0.2);"
                                       Size="MudBlazor.Size.Medium">
                                <MudIcon Icon="@Icons.Material.Filled.History" />
                            </MudAvatar>
                        </MudStack>
                        <MudText Typo="Typo.h4" Class="fw-bold">
                            @_dashboard.PreviousMonthAmount.ToString("N0") ج
                        </MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.8;">
                            @DateTime.Today.AddMonths(-1).ToString("MMMM yyyy",
                                new System.Globalization.CultureInfo("ar-EG"))
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @* Card 3: المتوسط اليومي *@
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-4 rounded-lg"
                          Style="background:linear-gradient(135deg,#4facfe 0%,#00f2fe 100%);
                                 color:white; min-height:160px;">
                    <MudStack Spacing="1">
                        <MudStack Row
                                  AlignItems="MudBlazor.AlignItems.Center"
                                  Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2" Style="opacity:0.85;">
                                المتوسط اليومي
                            </MudText>
                            <MudAvatar Style="background:rgba(255,255,255,0.2);"
                                       Size="MudBlazor.Size.Medium">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                            </MudAvatar>
                        </MudStack>
                        <MudText Typo="Typo.h4" Class="fw-bold">
                            @_dashboard.DailyAverage.ToString("N0") ج
                        </MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.8;">
                            المتوقع نهاية الشهر: @GetProjectedAmount().ToString("N0") ج
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @* Card 4: المصروفات المقدمة *@
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="0" Class="pa-4 rounded-lg"
                          Style="background:linear-gradient(135deg,#43e97b 0%,#38f9d7 100%);
                                 color:white; min-height:160px;">
                    <MudStack Spacing="1">
                        <MudStack Row
                                  AlignItems="MudBlazor.AlignItems.Center"
                                  Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.body2" Style="opacity:0.85;">
                                مصروفات مقدمة نشطة
                            </MudText>
                            <MudAvatar Style="background:rgba(255,255,255,0.2);"
                                       Size="MudBlazor.Size.Medium">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" />
                            </MudAvatar>
                        </MudStack>
                        <MudText Typo="Typo.h4" Class="fw-bold">
                            @_dashboard.ActiveAdvanceExpensesCount
                        </MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.8;">
                            بإجمالي: @_dashboard.ActiveAdvanceExpensesAmount.ToString("N0") ج
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ═══════════════════════════════════════════════════════
           ROW 2: الاتجاه الشهري + توزيع المجموعات
           ═══════════════════════════════════════════════════════ *@
        <MudGrid Spacing="3" Class="mb-4">

            @* Monthly Trend Chart *@
            <MudItem xs="12" md="8">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="min-height:420px;">
                    <MudStack Row
                              AlignItems="MudBlazor.AlignItems.Center"
                              Justify="Justify.SpaceBetween"
                              Class="mb-3">
                        <MudText Typo="Typo.h6" Class="fw-bold" Style="color:#1a237e;">
                            <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="me-1" />
                            الاتجاه الشهري للمصروفات
                        </MudText>
                        <MudChip T="string" Color="MudBlazor.Color.Info"
                                 Size="MudBlazor.Size.Small"
                                 Variant="Variant.Outlined">
                            آخر 12 شهر
                        </MudChip>
                    </MudStack>

                    @if (_dashboard.MonthlyTrends.Any())
                    {
                        <ApexChart TItem="ExpenseMonthlyTrendDto"
                                   Height="340"
                                   Options="_monthlyTrendOptions">
                            <ApexPointSeries TItem="ExpenseMonthlyTrendDto"
                                             Items="_dashboard.MonthlyTrends"
                                             SeriesType="SeriesType.Area"
                                             Name="المصروفات"
                                             XValue="e => e.MonthName"
                                             YValue="e => e.TotalAmount"
                                             OrderBy="e => e.X" />
                        </ApexChart>
                    }
                    else
                    {
                        <MudText Color="MudBlazor.Color.Secondary"
                                 Align="MudBlazor.Align.Center" Class="mt-10">
                            لا توجد بيانات
                        </MudText>
                    }
                </MudPaper>
            </MudItem>

            @* Group Distribution (Donut) *@
            <MudItem xs="12" md="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="min-height:420px;">
                    <MudText Typo="Typo.h6" Class="fw-bold mb-3" Style="color:#1a237e;">
                        <MudIcon Icon="@Icons.Material.Filled.DonutLarge" Class="me-1" />
                        توزيع المصروفات
                    </MudText>

                    @if (_dashboard.GroupDistribution.Any())
                    {
                        <ApexChart TItem="ExpenseGroupStatsDto"
                                   Height="280"
                                   Options="_donutOptions">
                            <ApexPointSeries TItem="ExpenseGroupStatsDto"
                                             Items="_dashboard.GroupDistribution"
                                             SeriesType="SeriesType.Donut"
                                             Name="المبلغ"
                                             XValue="e => e.GroupName"
                                             YValue="e => e.Total"
                                             OrderByDescending="e => e.Y" />
                        </ApexChart>

                        <MudDivider Class="my-2" />
                        <MudStack Spacing="1">
                            @foreach (var g in _dashboard.GroupDistribution.Take(6))
                            {
                                <MudStack Row
                                          AlignItems="MudBlazor.AlignItems.Center"
                                          Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.caption">@g.GroupName</MudText>
                                    <MudChip T="string"
                                             Size="MudBlazor.Size.Small"
                                             Color="MudBlazor.Color.Primary"
                                             Variant="Variant.Text">
                                        @g.Percentage%
                                    </MudChip>
                                </MudStack>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Color="MudBlazor.Color.Secondary"
                                 Align="MudBlazor.Align.Center" Class="mt-10">
                            لا توجد بيانات
                        </MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ═══════════════════════════════════════════════════════
           ROW 3: الاتجاه اليومي + أعلى المصروفات
           ═══════════════════════════════════════════════════════ *@
        <MudGrid Spacing="3" Class="mb-4">

            @* Daily Trend *@
            <MudItem xs="12" md="7">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="min-height:380px;">
                    <MudStack Row
                              AlignItems="MudBlazor.AlignItems.Center"
                              Justify="Justify.SpaceBetween"
                              Class="mb-3">
                        <MudText Typo="Typo.h6" Class="fw-bold" Style="color:#1a237e;">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarViewDay" Class="me-1" />
                            الاتجاه اليومي -
                            @DateTime.Today.ToString("MMMM yyyy",
                                new System.Globalization.CultureInfo("ar-EG"))
                        </MudText>
                        <MudChip T="string"
                                 Color="MudBlazor.Color.Warning"
                                 Size="MudBlazor.Size.Small"
                                 Variant="Variant.Outlined">
                            المتوسط: @_dashboard.DailyAverage.ToString("N0") ج
                        </MudChip>
                    </MudStack>

                    @if (_dashboard.DailyTrend.Any())
                    {
                        <ApexChart TItem="ExpenseDailyTrendDto"
                                   Height="300"
                                   Options="_dailyTrendOptions">
                            <ApexPointSeries TItem="ExpenseDailyTrendDto"
                                             Items="_dashboard.DailyTrend"
                                             SeriesType="SeriesType.Bar"
                                             Name="المصروفات اليومية"
                                             XValue="e => e.Day.ToString()"
                                             YValue="e => e.Amount"
                                             OrderBy="e => e.X" />
                        </ApexChart>
                    }
                    else
                    {
                        <MudText Color="MudBlazor.Color.Secondary"
                                 Align="MudBlazor.Align.Center" Class="mt-10">
                            لا توجد بيانات
                        </MudText>
                    }
                </MudPaper>
            </MudItem>

            @* Top 5 Expenses *@
            <MudItem xs="12" md="5">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="min-height:380px;">
                    <MudText Typo="Typo.h6" Class="fw-bold mb-3" Style="color:#1a237e;">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Class="me-1" />
                        أعلى 5 مصروفات هذا الشهر
                    </MudText>

                    @if (_dashboard.TopExpenses.Any())
                    {
                        <MudStack Spacing="2">
                            @{int rank = 0;}
                            @foreach (var exp in _dashboard.TopExpenses)
                            {
                                rank++;
                                var pct = _dashboard.CurrentMonthAmount > 0
                                    ? (exp.Amount / _dashboard.CurrentMonthAmount) * 100 : 0;

                                <MudPaper Elevation="0" Class="pa-3 rounded-lg"
                                          Style="@($"background:{GetRankBg(rank)};")">
                                    <MudStack Row
                                              AlignItems="MudBlazor.AlignItems.Center"
                                              Justify="Justify.SpaceBetween">
                                        <MudStack Row
                                                  AlignItems="MudBlazor.AlignItems.Center"
                                                  Spacing="2">
                                            <MudAvatar Size="MudBlazor.Size.Small"
                                                       Style="@($"background:{GetRankColor(rank)};color:white;font-weight:bold;")">
                                                @rank
                                            </MudAvatar>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2" Class="fw-bold">
                                                    @exp.ExpenseName
                                                </MudText>
                                                <MudText Typo="Typo.caption"
                                                         Color="MudBlazor.Color.Secondary">
                                                    @exp.ExpenseGroupName •
                                                    @exp.ExpenseDate.ToString("MM/dd")
                                                </MudText>
                                            </MudStack>
                                        </MudStack>
                                        <MudStack Spacing="0"
                                                  AlignItems="MudBlazor.AlignItems.End">
                                            <MudText Typo="Typo.body2" Class="fw-bold"
                                                     Color="MudBlazor.Color.Error">
                                                @exp.Amount.ToString("N0") ج
                                            </MudText>
                                            <MudText Typo="Typo.caption"
                                                     Color="MudBlazor.Color.Secondary">
                                                @pct.ToString("N1")%
                                            </MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    }
                    else
                    {
                        <MudText Color="MudBlazor.Color.Secondary"
                                 Align="MudBlazor.Align.Center" Class="mt-10">
                            لا توجد مصروفات هذا الشهر
                        </MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ═══════════════════════════════════════════════════════
           ROW 4: تحليل الانحراف + تحليل باريتو
           ═══════════════════════════════════════════════════════ *@
        <MudGrid Spacing="3" Class="mb-4">

            @* Variance Analysis *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="min-height:400px;">
                    <MudStack Row
                              AlignItems="MudBlazor.AlignItems.Center"
                              Justify="Justify.SpaceBetween"
                              Class="mb-3">
                        <MudText Typo="Typo.h6" Class="fw-bold" Style="color:#1a237e;">
                            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Class="me-1" />
                            تحليل الانحراف
                        </MudText>
                        <MudChip T="string"
                                 Color="MudBlazor.Color.Secondary"
                                 Size="MudBlazor.Size.Small"
                                 Variant="Variant.Outlined">
                            الشهر الحالي vs متوسط 3 أشهر
                        </MudChip>
                    </MudStack>

                    @if (_dashboard.VarianceAnalysis.Any())
                    {
                        <MudTable Items="@_dashboard.VarianceAnalysis"
                                  Dense Hover Elevation="0">
                            <HeaderContent>
                                <MudTh>المجموعة</MudTh>
                                <MudTh Style="text-align:center;">الشهر الحالي</MudTh>
                                <MudTh Style="text-align:center;">المتوسط</MudTh>
                                <MudTh Style="text-align:center;">الانحراف</MudTh>
                                <MudTh Style="text-align:center;">الحالة</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudText Typo="Typo.body2">@context.GroupName</MudText>
                                </MudTd>
                                <MudTd Style="text-align:center;">
                                    <MudText Typo="Typo.body2">
                                        @context.CurrentMonth.ToString("N0")
                                    </MudText>
                                </MudTd>
                                <MudTd Style="text-align:center;">
                                    <MudText Typo="Typo.body2">
                                        @context.PreviousMonthsAverage.ToString("N0")
                                    </MudText>
                                </MudTd>
                                <MudTd Style="text-align:center;">
                                    <MudText Typo="Typo.body2" Class="fw-bold"
                                             Color="@GetVarianceColor(context.VariancePercentage)">
                                        @(context.VariancePercentage > 0 ? "+" : "")@context.VariancePercentage%
                                    </MudText>
                                </MudTd>
                                <MudTd Style="text-align:center;">
                                    @if (context.IsOverspending)
                                    {
                                        <MudChip T="string"
                                                 Color="MudBlazor.Color.Error"
                                                 Size="MudBlazor.Size.Small"
                                                 Variant="Variant.Filled">
                                            <MudIcon Icon="@Icons.Material.Filled.Warning"
                                                     Size="MudBlazor.Size.Small"
                                                     Class="me-1" />
                                            إنفاق زائد
                                        </MudChip>
                                    }
                                    else if (context.VariancePercentage < -10)
                                    {
                                        <MudChip T="string"
                                                 Color="MudBlazor.Color.Success"
                                                 Size="MudBlazor.Size.Small"
                                                 Variant="Variant.Filled">
                                            <MudIcon Icon="@Icons.Material.Filled.ThumbUp"
                                                     Size="MudBlazor.Size.Small"
                                                     Class="me-1" />
                                            وفّر
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string"
                                                 Color="MudBlazor.Color.Default"
                                                 Size="MudBlazor.Size.Small"
                                                 Variant="Variant.Outlined">
                                            طبيعي
                                        </MudChip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Color="MudBlazor.Color.Secondary"
                                 Align="MudBlazor.Align.Center" Class="mt-10">
                            لا توجد بيانات كافية للتحليل
                        </MudText>
                    }
                </MudPaper>
            </MudItem>

            @* Pareto Analysis *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="min-height:400px;">
                    <MudStack Row
                              AlignItems="MudBlazor.AlignItems.Center"
                              Justify="Justify.SpaceBetween"
                              Class="mb-3">
                        <MudText Typo="Typo.h6" Class="fw-bold" Style="color:#1a237e;">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="me-1" />
                            تحليل باريتو (80/20)
                        </MudText>
                        <MudChip T="string"
                                 Color="MudBlazor.Color.Info"
                                 Size="MudBlazor.Size.Small"
                                 Variant="Variant.Outlined">
                            منذ بداية السنة
                        </MudChip>
                    </MudStack>

                    @if (_dashboard.ParetoAnalysis.Any())
                    {
                        <ApexChart TItem="ExpenseParetoDto"
                                   Height="320"
                                   Options="_paretoOptions">
                            <ApexPointSeries TItem="ExpenseParetoDto"
                                             Items="_dashboard.ParetoAnalysis"
                                             SeriesType="SeriesType.Bar"
                                             Name="المبلغ"
                                             XValue="e => e.ItemName"
                                             YValue="e => e.Amount"
                                             OrderByDescending="e => e.Y" />
                            <ApexPointSeries TItem="ExpenseParetoDto"
                                             Items="_dashboard.ParetoAnalysis"
                                             SeriesType="SeriesType.Line"
                                             Name="التراكمي %"
                                             XValue="e => e.ItemName"
                                             YValue="e => e.CumulativePercentage"
                                             OrderByDescending="e => e.Y" />
                        </ApexChart>
                    }
                    else
                    {
                        <MudText Color="MudBlazor.Color.Secondary"
                                 Align="MudBlazor.Align.Center" Class="mt-10">
                            لا توجد بيانات
                        </MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ═══════════════════════════════════════════════════════
           ROW 5: مؤشر الإنفاق + توزيع المجموعات بالتفصيل
           ═══════════════════════════════════════════════════════ *@
        <MudGrid Spacing="3" Class="mb-4">

            @* مؤشر الإنفاق المتوقع *@
            <MudItem xs="12" md="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                    <MudText Typo="Typo.h6" Class="fw-bold mb-3" Style="color:#1a237e;">
                        <MudIcon Icon="@Icons.Material.Filled.Speed" Class="me-1" />
                        مؤشر الإنفاق
                    </MudText>

                    @{
                        var projected = GetProjectedAmount();
                        var projectedVsPrev = _dashboard.PreviousMonthAmount > 0
                            ? ((projected - _dashboard.PreviousMonthAmount)
                               / _dashboard.PreviousMonthAmount) * 100 : 0;

                        var gaugeColor = projectedVsPrev > 20
                            ? MudBlazor.Color.Error
                            : projectedVsPrev > 5
                                ? MudBlazor.Color.Warning
                                : MudBlazor.Color.Success;

                        var progressPct = _dashboard.PreviousMonthAmount > 0
                            ? Math.Min(
                                (double)(_dashboard.CurrentMonthAmount
                                         / _dashboard.PreviousMonthAmount) * 100, 150)
                            : 0;
                    }

                    <MudStack AlignItems="MudBlazor.AlignItems.Center" Spacing="2">
                        <MudProgressLinear Color="@gaugeColor"
                                           Value="@progressPct"
                                           Max="150"
                                           Rounded
                                           Size="MudBlazor.Size.Large"
                                           Style="height:20px;"
                                           Class="my-2" />

                        <MudStack Row Justify="Justify.SpaceBetween" Style="width:100%;">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                                    الحالي
                                </MudText>
                                <MudText Typo="Typo.body1" Class="fw-bold">
                                    @_dashboard.CurrentMonthAmount.ToString("N0") ج
                                </MudText>
                            </MudStack>
                            <MudStack Spacing="0" AlignItems="MudBlazor.AlignItems.End">
                                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                                    المتوقع نهاية الشهر
                                </MudText>
                                <MudText Typo="Typo.body1" Class="fw-bold"
                                         Color="@gaugeColor">
                                    @projected.ToString("N0") ج
                                </MudText>
                            </MudStack>
                        </MudStack>

                        <MudDivider />

                        <MudStack Row Justify="Justify.SpaceBetween" Style="width:100%;">
                            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                                الشهر السابق
                            </MudText>
                            <MudText Typo="Typo.caption" Class="fw-bold">
                                @_dashboard.PreviousMonthAmount.ToString("N0") ج
                            </MudText>
                        </MudStack>

                        <MudStack Row Justify="Justify.SpaceBetween" Style="width:100%;">
                            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                                نسبة التغيير المتوقع
                            </MudText>
                            <MudText Typo="Typo.caption" Class="fw-bold"
                                     Color="@gaugeColor">
                                @(projectedVsPrev > 0 ? "+" : "")@projectedVsPrev.ToString("N1")%
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @* Group Distribution Details *@
            <MudItem xs="12" md="8">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                    <MudText Typo="Typo.h6" Class="fw-bold mb-3" Style="color:#1a237e;">
                        <MudIcon Icon="@Icons.Material.Filled.ViewList" Class="me-1" />
                        تفاصيل التوزيع حسب المجموعات
                    </MudText>

                    <MudStack Spacing="3">
                        @foreach (var g in _dashboard.GroupDistribution)
                        {
                            <MudStack Spacing="1">
                                <MudStack Row
                                          AlignItems="MudBlazor.AlignItems.Center"
                                          Justify="Justify.SpaceBetween">
                                    <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord"
                                                 Size="MudBlazor.Size.Small"
                                                 Style="@($"color:{GetGroupHexColor(_groupColorIndex++)};")"/>
                                        <MudText Typo="Typo.body2" Class="fw-bold">
                                            @g.GroupName
                                        </MudText>
                                        <MudChip T="string"
                                                 Size="MudBlazor.Size.Small"
                                                 Variant="Variant.Text"
                                                 Color="MudBlazor.Color.Default">
                                            @g.Count مصروف
                                        </MudChip>
                                    </MudStack>
                                    <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.body2" Class="fw-bold">
                                            @g.Total.ToString("N0") ج
                                        </MudText>
                                        <MudChip T="string"
                                                 Size="MudBlazor.Size.Small"
                                                 Color="MudBlazor.Color.Primary"
                                                 Variant="Variant.Outlined">
                                            @g.Percentage%
                                        </MudChip>
                                    </MudStack>
                                </MudStack>
                                <MudProgressLinear Value="@((double)g.Percentage)"
                                                   Max="100"
                                                   Color="MudBlazor.Color.Primary"
                                                   Rounded
                                                   Size="MudBlazor.Size.Medium" />
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    // ── State ──
    private bool _loading = true;
    private ExpenseDashboardDto? _dashboard;
    private int _groupColorIndex = 0;

    // ── Chart Options ──
    private ApexChartOptions<ExpenseMonthlyTrendDto> _monthlyTrendOptions = new();
    private ApexChartOptions<ExpenseGroupStatsDto>   _donutOptions        = new();
    private ApexChartOptions<ExpenseDailyTrendDto>   _dailyTrendOptions   = new();
    private ApexChartOptions<ExpenseParetoDto>        _paretoOptions       = new();

    // ── Lifecycle ──
    protected override async Task OnInitializedAsync()
    {
        InitializeChartOptions();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        _groupColorIndex = 0;
        StateHasChanged();
        try
        {
            _dashboard = await ExpenseService.GetDashboardDataAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Dashboard Error: {ex.Message}");
            _dashboard = null;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    // ═══════════════════════════════════════════════════════
    // Chart Options
    // ═══════════════════════════════════════════════════════
    private void InitializeChartOptions()
    {
        // ── Monthly Trend (Area) ──
        _monthlyTrendOptions = new ApexChartOptions<ExpenseMonthlyTrendDto>
        {
            Chart = new Chart
            {
                Toolbar  = new Toolbar { Show = false },
                FontFamily = "inherit",
                Animations = new Animations { Enabled = true }
            },
            Colors = new List<string> { "#667eea" },
            Stroke = new Stroke { Curve = Curve.Smooth, Width = 3 },
            Fill = new Fill
            {
                Type = new List<FillType> { FillType.Gradient },
                Gradient = new FillGradient
                {
                    ShadeIntensity = 1,
                    OpacityFrom    = 0.45,
                    OpacityTo      = 0.05,
                    Stops          = new List<double> { 0, 100 }
                }
            },
            Xaxis = new XAxis
            {
                Labels = new XAxisLabels
                {
                    RotateAlways = false,
                    Rotate       = 0,
                    Style        = new AxisLabelStyle { FontSize = "11px" }
                }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Formatter = @"function(val){
                            if(val>=1000000) return (val/1000000).toFixed(1)+'M';
                            if(val>=1000)    return (val/1000).toFixed(0)+'K';
                            return val.toFixed(0);
                        }"
                    }
                }
            },
            Tooltip = new Tooltip
            {
                Y = new TooltipY
                {
                    Formatter = @"function(val){
                        return val.toLocaleString('ar-EG')+' ج';
                    }"
                }
            },
            DataLabels = new DataLabels { Enabled = false },
            Grid = new Grid
            {
                BorderColor = "#f0f0f0",
                StrokeDashArray = 4
            }
        };

        // ── Donut Chart ──
        _donutOptions = new ApexChartOptions<ExpenseGroupStatsDto>
        {
            Chart = new Chart
            {
                Toolbar    = new Toolbar { Show = false },
                FontFamily = "inherit",
                Animations = new Animations { Enabled = true }
            },
            Colors = new List<string>
            {
                "#667eea","#f5576c","#4facfe","#43e97b",
                "#fa709a","#fee140","#a18cd1","#84fab0","#f093fb","#fbc2eb"
            },
            Legend     = new Legend { Show = false },
            PlotOptions = new PlotOptions
            {
                Pie = new PlotOptionsPie
                {
                    Donut = new PlotOptionsDonut
                    {
                        Size   = "70%",
                        Labels = new DonutLabels
                        {
                            Show  = true,
                            Total = new DonutLabelTotal
                            {
                                Show      = true,
                                Label     = "الإجمالي",
                                Formatter = @"function(w){
                                    var t=w.globals.seriesTotals.reduce((a,b)=>a+b,0);
                                    return t.toLocaleString('ar-EG');
                                }"
                            }
                        }
                    }
                }
            },
            DataLabels = new DataLabels { Enabled = false },
            Tooltip = new Tooltip
            {
                Y = new TooltipY
                {
                    Formatter = @"function(val){
                        return val.toLocaleString('ar-EG')+' ج';
                    }"
                }
            }
        };

        // ── Daily Trend (Bar) ──
        _dailyTrendOptions = new ApexChartOptions<ExpenseDailyTrendDto>
        {
            Chart = new Chart
            {
                Toolbar    = new Toolbar { Show = false },
                FontFamily = "inherit",
                Animations = new Animations { Enabled = true }
            },
            Colors = new List<string> { "#4facfe" },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar
                {
                    BorderRadius = 4,
                    ColumnWidth  = "60%"
                }
            },
            Xaxis = new XAxis
            {
                Labels = new XAxisLabels
                {
                    Style = new AxisLabelStyle { FontSize = "10px" }
                }
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Formatter = @"function(val){
                            if(val>=1000) return (val/1000).toFixed(0)+'K';
                            return val.toFixed(0);
                        }"
                    }
                }
            },
            Tooltip = new Tooltip
            {
                Y = new TooltipY
                {
                    Formatter = @"function(val){
                        return val.toLocaleString('ar-EG')+' ج';
                    }"
                }
            },
            DataLabels = new DataLabels { Enabled = false },
            Grid = new Grid
            {
                BorderColor    = "#f0f0f0",
                StrokeDashArray = 4
            }
        };

        // ── Pareto Chart (Bar + Line) ──
        _paretoOptions = new ApexChartOptions<ExpenseParetoDto>
        {
            Chart = new Chart
            {
                Toolbar    = new Toolbar { Show = false },
                FontFamily = "inherit",
                Animations = new Animations { Enabled = true }
            },
            Colors = new List<string> { "#764ba2", "#f5576c" },
            PlotOptions = new PlotOptions
            {
                Bar = new PlotOptionsBar
                {
                    BorderRadius = 4,
