@page "/expenses/dashboard"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using ApexCharts
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@inject IExpenseService ExpenseService
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>مؤشرات أداء المصروفات</PageTitle>

<style>
    .expense-dashboard-page {
        background:
            radial-gradient(circle at top right, rgba(37, 99, 235, 0.07), transparent 22%),
            radial-gradient(circle at top left, rgba(14, 165, 233, 0.05), transparent 18%),
            linear-gradient(180deg, #f8fbff 0%, #f4f7fb 100%);
        min-height: 100%;
    }

    .expense-dashboard-page * {
        box-sizing: border-box;
    }

    .expense-dashboard-page .page-title,
    .expense-dashboard-page .section-title,
    .expense-dashboard-page .kpi-value,
    .expense-dashboard-page .hero-main-value,
    .expense-dashboard-page .hero-title {
        font-weight: 800 !important;
    }

    .expense-dashboard-page .section-subtitle,
    .expense-dashboard-page .kpi-label,
    .expense-dashboard-page .muted-label,
    .expense-dashboard-page .hero-subtitle,
    .expense-dashboard-page .hero-mini-label {
        font-weight: 700 !important;
    }

    .hero-shell {
        position: relative;
        overflow: hidden;
        border-radius: 30px;
        background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 55%, #2563eb 100%);
        box-shadow: 0 24px 55px rgba(15, 23, 42, 0.18);
        border: 1px solid rgba(255,255,255,0.06);
    }

    .hero-shell::before {
        content: "";
        position: absolute;
        width: 320px;
        height: 320px;
        border-radius: 50%;
        top: -120px;
        left: -80px;
        background: rgba(255,255,255,0.07);
    }

    .hero-shell::after {
        content: "";
        position: absolute;
        width: 240px;
        height: 240px;
        border-radius: 50%;
        bottom: -100px;
        right: -60px;
        background: rgba(255,255,255,0.08);
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-chip {
        border-radius: 14px !important;
        font-weight: 800 !important;
        letter-spacing: .2px;
    }

    .hero-chip-light {
        color: #fff !important;
        background: rgba(255,255,255,0.10) !important;
        border: 1px solid rgba(255,255,255,0.16) !important;
    }

    .hero-title {
        color: #fff;
        line-height: 1.12;
        letter-spacing: -.5px;
        margin-top: 6px;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.84);
        line-height: 1.9;
        max-width: 780px;
        font-size: 1rem;
    }

    .hero-action-btn {
        border-radius: 16px !important;
        font-weight: 800 !important;
        min-width: 150px;
    }

    .hero-action-btn.secondary {
        color: #fff !important;
        border-color: rgba(255,255,255,0.18) !important;
        background: rgba(255,255,255,0.06) !important;
    }

    .hero-summary-panel {
        position: relative;
        z-index: 2;
        border-radius: 24px;
        background: rgba(255,255,255,0.10);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.14);
        color: white;
        height: 100%;
    }

    .hero-mini-label {
        color: rgba(255,255,255,0.74);
        font-size: .82rem;
    }

    .hero-main-value {
        color: #fff;
        line-height: 1.1;
        margin-top: 4px;
    }

    .hero-main-sub {
        color: rgba(255,255,255,0.84);
        font-weight: 700;
    }

    .hero-meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .hero-meta-row .key {
        color: rgba(255,255,255,0.82);
        font-weight: 700;
    }

    .hero-meta-row .val {
        color: #fff;
        font-weight: 800;
    }

    .dashboard-card {
        border-radius: 24px;
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        border: 1px solid rgba(148, 163, 184, 0.16);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
    }

    .section-card {
        border-radius: 24px;
        background: linear-gradient(180deg, #ffffff 0%, #fcfdff 100%);
        border: 1px solid rgba(148, 163, 184, 0.16);
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
    }

    .section-title {
        color: #0f172a;
        letter-spacing: -.3px;
    }

    .section-subtitle {
        color: #64748b;
        font-size: .88rem;
        margin-top: 2px;
    }

    .kpi-card {
        position: relative;
        overflow: hidden;
        min-height: 156px;
        transition: all .24s ease;
    }

    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 18px 36px rgba(15, 23, 42, 0.10);
    }

    .kpi-top-strip {
        position: absolute;
        top: 0;
        right: 0;
        left: 0;
        height: 5px;
    }

    .kpi-label {
        color: #64748b;
        font-size: .92rem;
    }

    .kpi-value {
        color: #0f172a;
        letter-spacing: -.4px;
        line-height: 1.1;
    }

    .kpi-note {
        font-weight: 700;
        font-size: .82rem;
        color: #475569;
    }

    .kpi-avatar {
        width: 58px !important;
        height: 58px !important;
        border-radius: 18px !important;
    }

    .kpi-current .kpi-top-strip {
        background: linear-gradient(90deg, #2563eb, #60a5fa);
    }

    .kpi-current .kpi-avatar {
        background: rgba(37, 99, 235, 0.10) !important;
        color: #1d4ed8 !important;
    }

    .kpi-previous .kpi-top-strip {
        background: linear-gradient(90deg, #7c3aed, #a78bfa);
    }

    .kpi-previous .kpi-avatar {
        background: rgba(124, 58, 237, 0.10) !important;
        color: #7c3aed !important;
    }

    .kpi-daily .kpi-top-strip {
        background: linear-gradient(90deg, #0f766e, #2dd4bf);
    }

    .kpi-daily .kpi-avatar {
        background: rgba(15, 118, 110, 0.10) !important;
        color: #0f766e !important;
    }

    .kpi-advance .kpi-top-strip {
        background: linear-gradient(90deg, #b45309, #f59e0b);
    }

    .kpi-advance .kpi-avatar {
        background: rgba(180, 83, 9, 0.10) !important;
        color: #b45309 !important;
    }

    .trend-up {
        color: #dc2626 !important;
        font-weight: 800 !important;
    }

    .trend-down {
        color: #059669 !important;
        font-weight: 800 !important;
    }

    .trend-flat {
        color: #64748b !important;
        font-weight: 800 !important;
    }

    .panel-badge {
        border-radius: 14px !important;
        font-weight: 800 !important;
    }

    .metric-soft-box {
        border-radius: 18px;
        background: linear-gradient(180deg, #f8fbff 0%, #f3f7ff 100%);
        border: 1px solid rgba(96, 165, 250, 0.18);
    }

    .top-expense-item {
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.14);
    }

    .top-expense-item.rank-1 {
        background: linear-gradient(180deg, #fff9e7 0%, #fffdf5 100%);
    }

    .top-expense-item.rank-2 {
        background: linear-gradient(180deg, #f7efff 0%, #fcf8ff 100%);
    }

    .top-expense-item.rank-3 {
        background: linear-gradient(180deg, #eef7ff 0%, #f9fcff 100%);
    }

    .top-expense-item.rank-x {
        background: linear-gradient(180deg, #fafafa 0%, #ffffff 100%);
    }

    .rank-avatar {
        font-weight: 800 !important;
        color: white !important;
    }

    .rank-1-color { background: #ca8a04 !important; }
    .rank-2-color { background: #7c3aed !important; }
    .rank-3-color { background: #2563eb !important; }
    .rank-x-color { background: #64748b !important; }

    .legend-dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        display: inline-block;
        margin-left: 8px;
        flex-shrink: 0;
    }

    .distribution-row,
    .pareto-row {
        border-radius: 16px;
        padding: 10px 12px;
        background: #fbfdff;
        border: 1px solid rgba(148, 163, 184, 0.12);
    }

    .table-head-strong th {
        font-weight: 800 !important;
        color: #334155;
        background: #f8fafc;
    }

    .insight-box {
        border-radius: 18px;
        background: linear-gradient(180deg, #f8fbff 0%, #f4f8ff 100%);
        border: 1px solid rgba(59, 130, 246, 0.14);
    }

    .insight-status {
        font-weight: 800;
        font-size: .95rem;
    }

    .empty-soft {
        color: #64748b;
        font-weight: 700;
        text-align: center;
        padding: 40px 0;
    }

    .loading-box {
        min-height: 420px;
    }

    @@media (max-width: 960px) {
        .hero-title {
            font-size: 2rem !important;
        }

        .hero-subtitle {
            font-size: .95rem;
        }
    }
</style>

<div class="expense-dashboard-page">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">

        @if (_loading)
        {
            <MudPaper Class="section-card pa-6 loading-box" Elevation="0">
                <MudStack AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.Center" Style="min-height:340px;">
                    <MudProgressCircular Indeterminate Size="MudBlazor.Size.Large" Color="MudBlazor.Color.Primary" />
                    <MudText Typo="Typo.h6" Class="mt-4 page-title">جارٍ تحميل مؤشرات أداء المصروفات...</MudText>
                </MudStack>
            </MudPaper>
        }
        else if (_dashboard is null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mt-4">
                حدث خطأ أثناء تحميل بيانات لوحة مؤشرات المصروفات.
            </MudAlert>
        }
        else
        {
            var projectedAmount = GetProjectedAmount();
            var projectedVsPrev = GetProjectedVsPrevious();
            var spendColor = GetProjectionColor(projectedVsPrev);

            <MudPaper Elevation="0" Class="hero-shell pa-5 mb-4">
                <div class="hero-content">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="8">
                            <MudStack Spacing="2">
                                <MudStack Row Spacing="1">
                                    <MudChip T="string"
                                             Class="hero-chip"
                                             Color="MudBlazor.Color.Primary"
                                             Variant="Variant.Filled">
                                        Expense Intelligence
                                    </MudChip>

                                    <MudChip T="string"
                                             Class="hero-chip hero-chip-light"
                                             Variant="Variant.Outlined">
                                        @DateTime.Today.ToString("dd MMMM yyyy", _arCulture)
                                    </MudChip>
                                </MudStack>

                                <MudText Typo="Typo.h3" Class="hero-title">
                                    مؤشرات أداء المصروفات
                                </MudText>

                                <MudText Typo="Typo.body1" Class="hero-subtitle">
                                    لوحة تنفيذية متقدمة لتحليل المصروفات، متابعة الاتجاهات الشهرية واليومية،
                                    قياس الانحرافات، وتحديد البنود الأعلى تأثيرًا على الإنفاق.
                                </MudText>

                                <MudStack Row Spacing="2" Class="mt-2">
                                    <MudButton Variant="Variant.Filled"
                                               Color="MudBlazor.Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Refresh"
                                               OnClick="LoadDataAsync"
                                               Disabled="_loading"
                                               Class="hero-action-btn">
                                        تحديث البيانات
                                    </MudButton>

                                    <MudButton Variant="Variant.Outlined"
                                               StartIcon="@Icons.Material.Filled.ListAlt"
                                               Href="/expenses"
                                               Class="hero-action-btn secondary">
                                        قائمة المصروفات
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Elevation="0" Class="hero-summary-panel pa-4">
                                <MudText Typo="Typo.caption" Class="hero-mini-label">
                                    الملخص التنفيذي للشهر الحالي
                                </MudText>

                                <MudText Typo="Typo.h4" Class="hero-main-value">
                                    @_dashboard.CurrentMonthAmount.ToString("N0") ج
                                </MudText>

                                <MudText Typo="Typo.body2" Class="hero-main-sub">
                                    إجمالي المصروفات المسجلة خلال الشهر
                                </MudText>

                                <MudDivider Class="my-3" />

                                <MudStack Spacing="2">
                                    <div class="hero-meta-row">
                                        <span class="key">النمو الشهري</span>
                                        <span class="@GetGrowthClass(_dashboard.MonthOverMonthGrowth)">
                                            @GetGrowthText(_dashboard.MonthOverMonthGrowth)
                                        </span>
                                    </div>

                                    <div class="hero-meta-row">
                                        <span class="key">المتوسط اليومي</span>
                                        <span class="val">@_dashboard.DailyAverage.ToString("N0") ج</span>
                                    </div>

                                    <div class="hero-meta-row">
                                        <span class="key">المصروف المتوقع</span>
                                        <span class="val">@projectedAmount.ToString("N0") ج</span>
                                    </div>

                                    <div class="hero-meta-row">
                                        <span class="key">المصروفات المقدمة</span>
                                        <span class="val">@_dashboard.ActiveAdvanceExpensesCount</span>
                                    </div>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </div>
            </MudPaper>

            <MudGrid Spacing="3" Class="mb-4">

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="dashboard-card kpi-card kpi-current pa-4">
                        <div class="kpi-top-strip"></div>
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Class="kpi-label">مصروفات الشهر الحالي</MudText>
                                <MudText Typo="Typo.h4" Class="kpi-value">@_dashboard.CurrentMonthAmount.ToString("N0") ج</MudText>
                                <MudText Typo="Typo.caption" Class="@GetGrowthClass(_dashboard.MonthOverMonthGrowth)">
                                    @GetGrowthText(_dashboard.MonthOverMonthGrowth) عن الشهر السابق
                                </MudText>
                            </MudStack>

                            <MudAvatar Size="MudBlazor.Size.Large" Class="kpi-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="dashboard-card kpi-card kpi-previous pa-4">
                        <div class="kpi-top-strip"></div>
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Class="kpi-label">مصروفات الشهر السابق</MudText>
                                <MudText Typo="Typo.h4" Class="kpi-value">@_dashboard.PreviousMonthAmount.ToString("N0") ج</MudText>
                                <MudText Typo="Typo.caption" Class="kpi-note">
                                    @DateTime.Today.AddMonths(-1).ToString("MMMM yyyy", _arCulture)
                                </MudText>
                            </MudStack>

                            <MudAvatar Size="MudBlazor.Size.Large" Class="kpi-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.History" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="dashboard-card kpi-card kpi-daily pa-4">
                        <div class="kpi-top-strip"></div>
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Class="kpi-label">المتوسط اليومي</MudText>
                                <MudText Typo="Typo.h4" Class="kpi-value">@_dashboard.DailyAverage.ToString("N0") ج</MudText>
                                <MudText Typo="Typo.caption" Class="kpi-note">
                                    المتوقع نهاية الشهر: @projectedAmount.ToString("N0") ج
                                </MudText>
                            </MudStack>

                            <MudAvatar Size="MudBlazor.Size.Large" Class="kpi-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="dashboard-card kpi-card kpi-advance pa-4">
                        <div class="kpi-top-strip"></div>
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Class="kpi-label">مصروفات مقدمة نشطة</MudText>
                                <MudText Typo="Typo.h4" Class="kpi-value">@_dashboard.ActiveAdvanceExpensesCount</MudText>
                                <MudText Typo="Typo.caption" Class="kpi-note">
                                    بإجمالي: @_dashboard.ActiveAdvanceExpensesAmount.ToString("N0") ج
                                </MudText>
                            </MudStack>

                            <MudAvatar Size="MudBlazor.Size.Large" Class="kpi-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" />
                            </MudAvatar>
                        </MudStack>
                    </MudPaper>
                </MudItem>

            </MudGrid>

            <MudGrid Spacing="3" Class="mb-4">

                <MudItem xs="12" lg="8">
                    <MudPaper Elevation="0" Class="section-card pa-4" Style="min-height:430px;">
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6" Class="section-title">
                                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="me-1" />
                                    الاتجاه الشهري للمصروفات
                                </MudText>
                                <MudText Typo="Typo.body2" Class="section-subtitle">
                                    نظرة على حركة الإنفاق خلال آخر 12 شهر
                                </MudText>
                            </MudStack>

                            <MudChip T="string" Class="panel-badge" Color="MudBlazor.Color.Info" Variant="Variant.Outlined">
                                آخر 12 شهر
                            </MudChip>
                        </MudStack>

                        @if (_dashboard.MonthlyTrends.Any())
                        {
                            <ApexChart TItem="ExpenseMonthlyTrendDto" Height="330" Options="_monthlyTrendOptions">
                                <ApexPointSeries TItem="ExpenseMonthlyTrendDto"
                                                 Items="_dashboard.MonthlyTrends"
                                                 SeriesType="SeriesType.Area"
                                                 Name="المصروفات"
                                                 XValue="e => e.MonthName"
                                                 YValue="e => e.TotalAmount" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="empty-soft">لا توجد بيانات للاتجاه الشهري</div>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="4">
                    <MudPaper Elevation="0" Class="section-card pa-4" Style="min-height:430px;">
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6" Class="section-title">
                                    <MudIcon Icon="@Icons.Material.Filled.DonutLarge" Class="me-1" />
                                    توزيع المصروفات
                                </MudText>
                                <MudText Typo="Typo.body2" Class="section-subtitle">
                                    أعلى المجموعات مساهمة في الإنفاق
                                </MudText>
                            </MudStack>
                        </MudStack>

                        @if (_dashboard.GroupDistribution.Any())
                        {
                            <ApexChart TItem="ExpenseGroupStatsDto" Height="260" Options="_donutOptions">
                                <ApexPointSeries TItem="ExpenseGroupStatsDto"
                                                 Items="_dashboard.GroupDistribution"
                                                 SeriesType="SeriesType.Donut"
                                                 Name="المبلغ"
                                                 XValue="e => e.GroupName"
                                                 YValue="e => e.Total" />
                            </ApexChart>

                            <MudDivider Class="my-3" />

                            <MudStack Spacing="1">
                                @for (int i = 0; i < _dashboard.GroupDistribution.Count; i++)
                                {
                                    var item = _dashboard.GroupDistribution[i];
                                    <div class="distribution-row">
                                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Spacing="1">
                                                <span class="legend-dot" style="background:@GetPaletteColor(i)"></span>
                                                <MudText Typo="Typo.body2" Class="muted-label">@item.GroupName</MudText>
                                            </MudStack>

                                            <MudChip T="string" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Primary" Variant="Variant.Text">
                                                @item.Percentage%
                                            </MudChip>
                                        </MudStack>
                                    </div>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <div class="empty-soft">لا توجد بيانات للتوزيع</div>
                        }
                    </MudPaper>
                </MudItem>

            </MudGrid>

            <MudGrid Spacing="3" Class="mb-4">

                <MudItem xs="12" lg="7">
                    <MudPaper Elevation="0" Class="section-card pa-4" Style="min-height:390px;">
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6" Class="section-title">
                                    <MudIcon Icon="@Icons.Material.Filled.CalendarViewDay" Class="me-1" />
                                    الاتجاه اليومي للمصروفات
                                </MudText>
                                <MudText Typo="Typo.body2" Class="section-subtitle">
                                    توزيع المصروفات على أيام الشهر الحالي
                                </MudText>
                            </MudStack>

                            <MudChip T="string" Class="panel-badge" Color="MudBlazor.Color.Warning" Variant="Variant.Outlined">
                                المتوسط: @_dashboard.DailyAverage.ToString("N0") ج
                            </MudChip>
                        </MudStack>

                        @if (_dashboard.DailyTrend.Any())
                        {
                            <ApexChart TItem="ExpenseDailyTrendDto" Height="290" Options="_dailyTrendOptions">
                                <ApexPointSeries TItem="ExpenseDailyTrendDto"
                                                 Items="_dashboard.DailyTrend"
                                                 SeriesType="SeriesType.Bar"
                                                 Name="المصروفات اليومية"
                                                 XValue="e => e.Day.ToString()"
                                                 YValue="e => e.Amount" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="empty-soft">لا توجد بيانات يومية خلال الشهر الحالي</div>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" lg="5">
                    <MudPaper Elevation="0" Class="section-card pa-4" Style="min-height:390px;">
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6" Class="section-title">
                                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Class="me-1" />
                                    أعلى 5 مصروفات هذا الشهر
                                </MudText>
                                <MudText Typo="Typo.body2" Class="section-subtitle">
                                    البنود الأعلى استنزافًا للسيولة
                                </MudText>
                            </MudStack>
                        </MudStack>

                        @if (_dashboard.TopExpenses.Any())
                        {
                            <MudStack Spacing="2">
                                @for (int i = 0; i < _dashboard.TopExpenses.Count; i++)
                                {
                                    var exp = _dashboard.TopExpenses[i];
                                    var rank = i + 1;
                                    var pct = _dashboard.CurrentMonthAmount > 0
                                        ? (exp.Amount / _dashboard.CurrentMonthAmount) * 100
                                        : 0m;

                                    <MudPaper Elevation="0" Class="@($"{GetTopExpenseClass(rank)} top-expense-item pa-3")">
                                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Spacing="2">
                                                <MudAvatar Size="MudBlazor.Size.Medium" Class="@GetRankAvatarClass(rank)">
                                                    @rank
                                                </MudAvatar>

                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2" Class="page-title">@exp.ExpenseName</MudText>
                                                    <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                                                        @exp.ExpenseGroupName • @exp.ExpenseDate.ToString("dd/MM")
                                                    </MudText>
                                                </MudStack>
                                            </MudStack>

                                            <MudStack Spacing="0" AlignItems="MudBlazor.AlignItems.End">
                                                <MudText Typo="Typo.body2" Class="page-title" Color="MudBlazor.Color.Error">
                                                    @exp.Amount.ToString("N0") ج
                                                </MudText>
                                                <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                                                    @pct.ToString("N1")%
                                                </MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <div class="empty-soft">لا توجد مصروفات مسجلة خلال الشهر الحالي</div>
                        }
                    </MudPaper>
                </MudItem>

            </MudGrid>

            <MudGrid Spacing="3" Class="mb-4">

                <MudItem xs="12" lg="6">
                    <MudPaper Elevation="0" Class="section-card pa-4" Style="min-height:430px;">
                        <MudStack Row AlignItems="MudBlazor.AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.h6" Class="section-title">
                                    <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Class="me-1" />
                                    تحليل الانحراف
                                </MudText>
                                <MudText Typo="Typo.body2" Class="section-subtitle">
                                    مقارنة الشهر الحالي بمتوسط آخر 3 أشهر لكل مجموعة
                                </MudText>
                            </MudStack>

                            <MudChip T="string" Class="panel-badge" Color="MudBlazor.Color.Secondary" Variant="Variant.Outlined">
                                Variance Analysis
                            </MudChip>
                        </MudStack>

                        @if (_dashboard.VarianceAnalysis.Any())
                        {
                            <MudTable Items="_dashboard.VarianceAnalysis.Take(8)" Dense Hover Elevation="0" Breakpoint="Breakpoint.Sm" Class="table-head-strong">
                                <HeaderContent>
                                    <MudTh>المجموعة</MudTh>
                                    <MudTh Style="text-align:center;">الحالي</MudTh>
                                    <MudTh Style="text-align:center;">المتوسط</MudTh>
                                    <MudTh Style="text-align:center;">الانحراف</MudTh>
                                    <MudTh Style="text-align:center;">الحالة</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>
                                        <MudText Typo="Typo.body2" Class="muted-label">@context.GroupName</MudText>
                                    </MudTd>
                                    <MudTd Style="text-align:center;">
                                        <MudText Typo="Typo.body2" Class="page-title">@context.CurrentMonth.ToString("N0")</MudText>
                                    </MudTd>
                                    <MudTd Style="text-align:center;">
                                        <MudText Typo="Typo.body2" Class="muted-label">@context.PreviousMonthsAverage.ToString("N0")</MudText>
                                    </MudTd>
                                    <MudTd Style="text-align:center;">
                                        <MudText Typo="Typo.body2"
                                                 Class="page-title"
                                                 Color="@GetVarianceColor(context.VariancePercentage)">
                                            @(context.VariancePercentage > 0 ? "+" : "")@context.VariancePercentage%
                                        </MudText>
                                    </MudTd>
                                    <MudTd Style="text-align:center;">
                                        @if (context.VariancePercentage > 10)
                                        {
                                            <MudChip T="string" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Error" Variant="Variant.Filled">
                                                إنفاق زائد
                                            </MudChip>
                                        }
                                        else if (context.VariancePercentage < -10)
                                        {
                                            <MudChip T="string" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Success" Variant="Variant.Filled">
                                                وفر
                                            </MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Default" Variant="Variant.Outlined">
                                                طبيعي
                                            </MudChip>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
