    // ═══════════════════════════════════════════════════════
    // Helper Methods
    // ═══════════════════════════════════════════════════════

    private decimal GetProjectedAmount()
    {
        if (_dashboard == null) return 0;
        var today       = DateTime.Today;
        var daysInMonth = DateTime.DaysInMonth(today.Year, today.Month);
        return _dashboard.DailyAverage * daysInMonth;
    }

    private string GetGrowthIcon(decimal growth) =>
        growth > 0 ? Icons.Material.Filled.TrendingUp
      : growth < 0 ? Icons.Material.Filled.TrendingDown
      : Icons.Material.Filled.TrendingFlat;

    private string GetGrowthText(decimal growth)
    {
        var abs = Math.Abs(growth);
        if (growth > 0) return $"↑ {abs:N1}%";
        if (growth < 0) return $"↓ {abs:N1}%";
        return "بدون تغيير";
    }

    private string GetGrowthStyle(decimal growth)
    {
        // في المصروفات: الزيادة = سيء (أحمر فاتح)، النقصان = جيد (أخضر فاتح)
        if (growth > 0) return "color:rgba(255,200,200,0.95); font-weight:bold;";
        if (growth < 0) return "color:rgba(200,255,200,0.95); font-weight:bold;";
        return "opacity:0.8;";
    }

    private MudBlazor.Color GetVarianceColor(decimal variance) =>
        variance > 10  ? MudBlazor.Color.Error
      : variance < -10 ? MudBlazor.Color.Success
      : MudBlazor.Color.Default;

    private string GetRankBg(int rank) => rank switch
    {
        1 => "#fff8e1",
        2 => "#f3e5f5",
        3 => "#e3f2fd",
        _ => "#f5f5f5"
    };

    private string GetRankColor(int rank) => rank switch
    {
        1 => "#f57f17",
        2 => "#7b1fa2",
        3 => "#1565c0",
        _ => "#616161"
    };

    private static readonly string[] GroupHexColors =
    {
        "#667eea","#f5576c","#4facfe","#43e97b",
        "#fa709a","#fee140","#a18cd1","#84fab0","#f093fb","#fbc2eb"
    };

    private string GetGroupHexColor(int index) =>
        GroupHexColors[index % GroupHexColors.Length];
}