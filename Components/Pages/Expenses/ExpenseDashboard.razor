                            return val.toFixed(0);
                        }"
                    }
                }
            },
            Tooltip = new Tooltip
            {
                Y = new TooltipY
                {
                    Formatter = @"function(val){
                        return val.toLocaleString('ar-EG') + ' ج';
                    }"
                }
            }
        };
    }

    private decimal GetProjectedAmount()
    {
        if (_dashboard is null) return 0;
        var today = DateTime.Today;
        var daysInMonth = DateTime.DaysInMonth(today.Year, today.Month);
        return Math.Round(_dashboard.DailyAverage * daysInMonth, 2);
    }

    private decimal GetProjectedVsPrevious()
    {
        if (_dashboard is null) return 0;
        var projected = GetProjectedAmount();

        if (_dashboard.PreviousMonthAmount > 0)
            return Math.Round(((projected - _dashboard.PreviousMonthAmount) / _dashboard.PreviousMonthAmount) * 100, 1);

        return projected > 0 ? 100 : 0;
    }

    private double GetProgressPercent()
    {
        if (_dashboard is null || _dashboard.PreviousMonthAmount <= 0) return 0;
        var value = (double)(_dashboard.CurrentMonthAmount / _dashboard.PreviousMonthAmount) * 100;
        return Math.Min(value, 150);
    }

    private string GetGrowthText(decimal growth)
    {
        var abs = Math.Abs(growth);
        if (growth > 0) return $"↑ {abs:N1}%";
        if (growth < 0) return $"↓ {abs:N1}%";
        return "بدون تغيير";
    }

    private string GetGrowthClass(decimal growth)
    {
        if (growth > 0) return "trend-up";
        if (growth < 0) return "trend-down";
        return "trend-flat";
    }

    private MudBlazor.Color GetVarianceColor(decimal variance)
    {
        if (variance > 10) return MudBlazor.Color.Error;
        if (variance < -10) return MudBlazor.Color.Success;
        return MudBlazor.Color.Default;
    }

    private MudBlazor.Color GetProjectionColor(decimal projectedVsPrev)
    {
        if (projectedVsPrev > 20) return MudBlazor.Color.Error;
        if (projectedVsPrev > 5) return MudBlazor.Color.Warning;
        return MudBlazor.Color.Success;
    }

    private string GetSpendingStatusText(decimal projectedVsPrev)
    {
        if (projectedVsPrev > 20) return "مستوى الإنفاق مرتفع";
        if (projectedVsPrev > 5) return "الإنفاق أعلى من المعتاد";
        if (projectedVsPrev < -10) return "الإنفاق تحت السيطرة";
        return "الإنفاق في الحدود الطبيعية";
    }

    private string GetSpendingStatusDescription(decimal projectedVsPrev)
    {
        if (projectedVsPrev > 20)
            return "المؤشرات الحالية توضح أن إجمالي الشهر قد يتجاوز الشهر السابق بشكل ملحوظ، ويفضل مراجعة البنود الأعلى تكلفة.";
        if (projectedVsPrev > 5)
            return "هناك ارتفاع متوقع في إجمالي الإنفاق مقارنة بالشهر السابق، لكن ما زال ضمن نطاق يحتاج متابعة.";
        if (projectedVsPrev < -10)
            return "الأداء الحالي يشير إلى تحسن في مستوى المصروفات مقارنة بالشهر السابق، وهو مؤشر جيد.";
        return "الإنفاق الحالي يسير بمعدل قريب من النمط المعتاد دون تغيّر حاد.";
    }

    private string GetPaletteColor(int index)
    {
        string[] palette =
        {
            "#2563eb", "#7c3aed", "#0f766e", "#f59e0b", "#ef4444",
            "#06b6d4", "#8b5cf6", "#10b981", "#f97316", "#64748b"
        };

        return palette[index % palette.Length];
    }

    private string GetTopExpenseClass(int rank)
    {
        return rank switch
        {
            1 => "rank-1",
            2 => "rank-2",
            3 => "rank-3",
            _ => "rank-x"
        };
    }

    private string GetRankAvatarClass(int rank)
    {
        return rank switch
        {
            1 => "rank-avatar rank-1-color",
            2 => "rank-avatar rank-2-color",
            3 => "rank-avatar rank-3-color",
            _ => "rank-avatar rank-x-color"
        };
    }
}