@page "/expenses/dashboard"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IExpenseService ExpenseService
@inject NavigationManager Navigation

<div class="exp-dashboard" dir="rtl">
    <div class="dash-header mb-4">
        <div>
            <h1 class="dash-title">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
                لوحة تحكم المصروفات
            </h1>
            <p class="dash-subtitle">نظرة عامة على حركة المصروفات، المؤشرات والتحليلات</p>
        </div>
        <div class="dash-actions">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => Navigation.NavigateTo("/expenses/new"))" Class="me-2">
                مصروف جديد
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.ListAlt"
                       OnClick="@(() => Navigation.NavigateTo("/expenses/report"))">
                التقرير التفصيلي
            </MudButton>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="loading-overlay">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <p>جاري تحميل المؤشرات...</p>
        </div>
    }
    else if (_data != null)
    {
        <!-- KPI Cards -->
        <div class="kpi-grid">
            <div class="kpi-card">
                <div class="kpi-icon box-primary">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" />
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">مصروفات هذا الشهر</span>
                    <strong class="kpi-value">@_data.CurrentMonthAmount.ToString("N2", CultureInfo.InvariantCulture) <small>ج</small></strong>
                    
                    @if (_data.MonthOverMonthGrowth > 0)
                    {
                        <span class="kpi-trend trend-up">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                            +@Math.Round(_data.MonthOverMonthGrowth, 1)% عن الشهر السابق
                        </span>
                    }
                    else if (_data.MonthOverMonthGrowth < 0)
                    {
                        <span class="kpi-trend trend-down">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Size="Size.Small" />
                            @Math.Round(_data.MonthOverMonthGrowth, 1)% عن الشهر السابق
                        </span>
                    }
                    else
                    {
                        <span class="kpi-trend trend-neutral">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingFlat" Size="Size.Small" />
                            لا تغيير عن الشهر السابق
                        </span>
                    }
                </div>
            </div>

            <div class="kpi-card">
                <div class="kpi-icon box-info">
                    <MudIcon Icon="@Icons.Material.Filled.Event" />
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">متوسط الصرف اليومي (للحالي)</span>
                    <strong class="kpi-value">@_data.DailyAverage.ToString("N2", CultureInfo.InvariantCulture) <small>ج</small></strong>
                    <span class="kpi-trend trend-neutral">
                        <MudIcon Icon="@Icons.Material.Filled.Insights" Size="Size.Small" />
                        معدل الإنفاق اليومي
                    </span>
                </div>
            </div>

            <div class="kpi-card">
                <div class="kpi-icon box-warning">
                    <MudIcon Icon="@Icons.Material.Filled.Schedule" />
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">المصروفات المقدمة النشطة</span>
                    <strong class="kpi-value">@_data.ActiveAdvanceExpensesAmount.ToString("N2", CultureInfo.InvariantCulture) <small>ج</small></strong>
                    <span class="kpi-trend trend-warning">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                        موزعة على @_data.ActiveAdvanceExpensesCount عقود/مصروفات
                    </span>
                </div>
            </div>
        </div>

        <div class="charts-grid mt-4">
            <!-- Line Chart (Trend) -->
            <MudPaper Class="chart-card p-4" Elevation="0">
                <h3 class="chart-title">حركة المصروفات (آخر 6 أشهر)</h3>
                <div class="chart-container">
                    <MudChart T="double" 
                              ChartType="ChartType.Line" 
                              ChartSeries="@_trendSeries" 
                              XAxisLabels="@_trendLabels" 
                              Width="100%" 
                              Height="300px" />
                </div>
            </MudPaper>

            <!-- Donut Chart (Distribution) -->
            <MudPaper Class="chart-card p-4" Elevation="0">
                <h3 class="chart-title">توزيع المصروفات (السنة الحالية)</h3>
                <div class="chart-container donut-container">
                    <MudChart T="double"
                              ChartType="ChartType.Donut" 
                              InputData="@_donutData" 
                              InputLabels="@_donutLabels" 
                              Width="100%" 
                              Height="300px" />
                </div>
            </MudPaper>
        </div>

        <!-- Top Expenses Table -->
        <MudPaper Class="mt-4 p-4" Elevation="0" Style="border-radius:16px; border:1px solid var(--mud-palette-divider);">
            <h3 class="chart-title mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Star" Class="mr-2" Style="color:#f59e0b;" />
                أعلى 5 مصروفات (هذا الشهر)
            </h3>
            
            <div class="table-responsive">
                <table class="simple-table">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>المصروف</th>
                            <th>المجموعة</th>
                            <th class="text-left">المبلغ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_data.TopExpenses == null || !_data.TopExpenses.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">لا توجد مصروفات هذا الشهر حتى الآن</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var exp in _data.TopExpenses)
                            {
                                <tr>
                                    <td>@exp.ExpenseDate.ToString("yyyy/MM/dd")</td>
                                    <td><strong>@exp.ExpenseName</strong></td>
                                    <td>
                                        <span class="group-badge">@exp.ExpenseGroupName</span>
                                    </td>
                                    <td class="text-left amount-cell">@exp.Amount.ToString("N2", CultureInfo.InvariantCulture) ج</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </MudPaper>
    }
</div>

<style>
    .exp-dashboard { max-width: 1400px; margin: 0 auto; padding: 1rem; }
    
    .dash-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .dash-title { font-size: 1.75rem; font-weight: 800; margin: 0; display: flex; align-items: center; color: var(--mud-palette-text-primary); }
    .dash-subtitle { margin: 0.25rem 0 0 0; color: var(--mud-palette-text-secondary); font-size: 0.95rem; }
    .dash-actions { display: flex; gap: 0.5rem; }

    .loading-overlay { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 400px; gap: 1rem; color: var(--mud-palette-text-secondary); }

    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.25rem; }
    
    .kpi-card { 
        background: var(--mud-palette-surface); 
        border: 1px solid var(--mud-palette-divider); 
        border-radius: 16px; 
        padding: 1.5rem; 
        display: flex; 
        align-items: flex-start; 
        gap: 1.25rem;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.06); }
    
    .kpi-icon { width: 56px; height: 56px; border-radius: 14px; display: flex; align-items: center; justify-content: center; }
    .kpi-icon .mud-icon-root { font-size: 2rem !important; }
    
    .box-primary { background: rgba(99, 102, 241, 0.1); color: #4f46e5; }
    .box-info { background: rgba(14, 165, 233, 0.1); color: #0ea5e9; }
    .box-warning { background: rgba(245, 158, 11, 0.1); color: #d97706; }

    .kpi-info { display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }
    .kpi-label { font-size: 0.85rem; color: var(--mud-palette-text-secondary); font-weight: 600; }
    .kpi-value { font-size: 1.6rem; font-weight: 800; color: var(--mud-palette-text-primary); line-height: 1.2; }
    .kpi-value small { font-size: 0.9rem; color: var(--mud-palette-text-disabled); font-weight: 600; }
    
    .kpi-trend { font-size: 0.75rem; display: inline-flex; align-items: center; gap: 0.25rem; font-weight: 600; padding: 0.2rem 0.5rem; border-radius: 6px; width: fit-content; margin-top: 0.25rem; }
    .trend-up { background: rgba(239, 68, 68, 0.1); color: #dc2626; } /* Spending up is generally red/warning in expenses */
    .trend-down { background: rgba(34, 197, 94, 0.1); color: #16a34a; } /* Spending down is green/good */
    .trend-neutral { background: var(--mud-palette-background-grey); color: var(--mud-palette-text-secondary); }
    .trend-warning { background: rgba(245, 158, 11, 0.1); color: #d97706; }

    .charts-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 1.25rem; }
    @@media (max-width: 992px) { .charts-grid { grid-template-columns: 1fr; } }
    
    .chart-card { border-radius: 16px; border: 1px solid var(--mud-palette-divider); box-shadow: 0 4px 20px rgba(0,0,0,0.03); }
    .chart-title { font-size: 1.1rem; font-weight: 700; margin: 0 0 1.5rem 0; color: var(--mud-palette-text-primary); }
    
    .chart-container { position: relative; width: 100%; height: 300px; }
    .donut-container { display: flex; justify-content: center; }

    .simple-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .simple-table th { padding: 0.75rem 1rem; font-size: 0.85rem; font-weight: 600; color: var(--mud-palette-text-secondary); border-bottom: 1px solid var(--mud-palette-divider); }
    .simple-table td { padding: 1rem; border-bottom: 1px solid var(--mud-palette-divider); vertical-align: middle; }
    .simple-table tr:last-child td { border-bottom: none; }
    
    .group-badge { background: var(--mud-palette-background-grey); padding: 0.25rem 0.75rem; border-radius: 8px; font-size: 0.75rem; font-weight: 600; color: var(--mud-palette-text-primary); }
    .amount-cell { font-weight: 800; color: #ef4444; font-size: 1rem; }
</style>

@code {
    private bool _isLoading = true;
    private ExpenseDashboardDto? _data;

    // Charts Data - تم إضافة <double> لنوع البيانات
    private List<MudBlazor.ChartSeries<double>> _trendSeries = new List<MudBlazor.ChartSeries<double>>();
    private string[] _trendLabels = Array.Empty<string>();

    private double[] _donutData = Array.Empty<double>();
    private string[] _donutLabels = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        _data = await ExpenseService.GetDashboardDataAsync();

        if (_data != null)
        {
            // Build Line Chart (Trend)
            _trendLabels = _data.MonthlyTrends.Select(m => m.MonthName).ToArray();
            _trendSeries = new List<MudBlazor.ChartSeries<double>>
            {
                new MudBlazor.ChartSeries<double>
                {
                    Name = "المصروفات",
                    Data = _data.MonthlyTrends.Select(m => (double)m.TotalAmount).ToArray()
                }
            };

            // Build Donut Chart
            var topGroups = _data.GroupDistribution.Take(4).ToList();
            var othersAmount = _data.GroupDistribution.Skip(4).Sum(g => g.Total);
            
            var chartDataList = topGroups.Select(g => (double)g.Total).ToList();
            var chartLabelsList = topGroups.Select(g => $"{g.GroupName} ({g.Percentage}%)").ToList();

            if (othersAmount > 0)
            {
                chartDataList.Add((double)othersAmount);
                var total = _data.GroupDistribution.Sum(g => g.Total);
                var pct = Math.Round((othersAmount / (total == 0 ? 1 : total)) * 100, 1);
                chartLabelsList.Add($"أخرى ({pct}%)");
            }

            _donutData = chartDataList.ToArray();
            _donutLabels = chartLabelsList.ToArray();
        }

        _isLoading = false;
    }
}