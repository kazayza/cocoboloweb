@page "/company-info"
@using Microsoft.AspNetCore.Authorization
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor

@attribute [Authorize]
@inject ICompanyInfoService CompanyService
@inject IAuditService AuditService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@inject db24804Context Db
@inject IJSRuntime JS 

<PageTitle>بيانات الشركة</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4 px-2 px-md-6">

    @* ═══════════════════ Header ═══════════════════ *@
    <MudPaper Class="pa-6 mb-4" Elevation="2" Style="border-radius: 16px; background: linear-gradient(135deg, #0A1628 0%, #1E293B 100%);">
        <MudGrid Spacing="3" AlignItems="AlignItems.Center">
            <MudItem xs="12" md="8">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Style="width: 56px; height: 56px; font-size: 1.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Business" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h5" Color="Color.Secondary" Style="font-weight: 700;">
                            بيانات الشركة
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Surface" Style="opacity: 0.7;">
                            إدارة وتعديل البيانات الأساسية للشركة والفروع
                        </MudText>
                    </div>
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudStack Row Justify="Justify.FlexEnd" Spacing="2">
                    @if (_canEdit && !_isEditing && _companyInfo != null)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Edit" OnClick="ToggleEdit">
                            تعديل البيانات
                        </MudButton>
                    }
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* ═══════════════════ Stats Cards ═══════════════════ *@
    @if (_companyInfo != null)
    {
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="6" md="3">
                <MudPaper Class="pa-4" Elevation="1" Style="border-radius: 12px; border-right: 4px solid #D4AF37;">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-weight: 600;">اسم الشركة</MudText>
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@_companyInfo.CompanyName</MudText>
                        </div>
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Filled.Apartment" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="pa-4" Elevation="1" Style="border-radius: 12px; border-right: 4px solid #10B981;">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Success" Style="font-weight: 600;">عدد الفروع</MudText>
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@_companyInfo.LocationsCount</MudText>
                        </div>
                        <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="pa-4" Elevation="1" Style="border-radius: 12px; border-right: 4px solid #3B82F6;">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Info" Style="font-weight: 600;">البريد الإلكتروني</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600; font-size: 0.85rem;">@_companyInfo.SalesEmail</MudText>
                        </div>
                        <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Filled.Email" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudPaper Class="pa-4" Elevation="1" Style="border-radius: 12px; border-right: 4px solid #F59E0B;">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.body2" Color="Color.Warning" Style="font-weight: 600;">الهاتف</MudText>
                            <MudText Typo="Typo.body1" Style="font-weight: 600;">@_companyInfo.Phone1</MudText>
                        </div>
                        <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Filled.Phone" />
                        </MudAvatar>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    @* ═══════════════════ Loading State ═══════════════════ *@
    @if (_isLoading)
    {
        <MudPaper Class="pa-8 text-center" Elevation="1" Style="border-radius: 16px;">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.h6" Class="mt-4" Color="Color.Primary">جاري تحميل بيانات الشركة...</MudText>
        </MudPaper>
    }
    else if (_companyInfo == null && !_isEditing)
    {
        @* ═══════════════════ No Data - Create New ═══════════════════ *@
        <MudPaper Class="pa-8 text-center" Elevation="1" Style="border-radius: 16px;">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Style="width: 80px; height: 80px; margin: 0 auto; font-size: 2rem;">
                <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" />
            </MudAvatar>
            <MudText Typo="Typo.h5" Class="mt-4" Style="font-weight: 700;">لا توجد بيانات للشركة</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">قم بإدخال بيانات الشركة الأساسية لبدء استخدام النظام</MudText>
            @if (_canAdd)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Add" Class="mt-4" OnClick="OpenCreateMode">
                    إدخال بيانات الشركة
                </MudButton>
            }
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="4">
            @* ═══════════════════ Company Info Card ═══════════════════ *@
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-6" Elevation="2" Style="border-radius: 16px;">
                    <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight: 700;">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                            المعلومات الأساسية
                        </MudText>
                        @if (_isEditing)
                        {
                            <MudStack Row Spacing="2">
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelEdit">
                                    إلغاء
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Save" OnClick="SaveCompanyInfo"
                                           Disabled="@_isSaving">
                                    @if (_isSaving)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    }
                                    حفظ التعديلات
                                </MudButton>
                            </MudStack>
                        }
                    </MudStack>

                    @if (_isEditing)
                    {
                        @* ═══════════════════ Edit Form ═══════════════════ *@
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="اسم الشركة" @bind-Value="_formData.CompanyName"
                                              Variant="Variant.Outlined" Required="true" RequiredError="اسم الشركة مطلوب"
                                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Business" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="الموقع الإلكتروني" @bind-Value="_formData.Website"
                                              Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Language" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField T="string" Label="العنوان" @bind-Value="_formData.Address"
                                              Variant="Variant.Outlined" Required="true" RequiredError="العنوان مطلوب"
                                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.LocationOn" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="هاتف 1" @bind-Value="_formData.Phone1"
                                              Variant="Variant.Outlined" Required="true" RequiredError="رقم الهاتف مطلوب"
                                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Phone" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="هاتف 2" @bind-Value="_formData.Phone2"
                                              Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ContactPhone" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="بريد المبيعات" @bind-Value="_formData.SalesEmail"
                                              Variant="Variant.Outlined" Required="true" RequiredError="بريد المبيعات مطلوب"
                                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ShoppingCart" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="بريد الاستفسارات" @bind-Value="_formData.InfoEmail"
                                              Variant="Variant.Outlined" Required="true" RequiredError="بريد الاستفسارات مطلوب"
                                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.ContactMail" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="رابط Dropbox (الشروط)" @bind-Value="_formData.TocDropBox"
                                              Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CloudUpload" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="إصدار النظام" @bind-Value="_formData.CurrentVersion"
                                              Variant="Variant.Outlined" ReadOnly="true"
                                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Build" />
                            </MudItem>

                            @* Logo Upload *@
                            <MudItem xs="12">
                                <MudPaper Class="pa-4" Elevation="0" Style="border: 2px dashed #D4AF37; border-radius: 12px; background: rgba(212,175,55,0.05);">
                                    <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
                                        @if (_logoPreview != null)
                                        {
                                            <MudAvatar Image="@_logoPreview" Size="Size.Large" Style="width: 80px; height: 80px; border-radius: 12px;" />
                                        }
                                        else if (_companyInfo?.LogoBase64 != null)
                                        {
                                            <MudAvatar Image="@($"data:image/png;base64,{_companyInfo.LogoBase64}")" Size="Size.Large" Style="width: 80px; height: 80px; border-radius: 12px;" />
                                        }
                                        else
                                        {
                                            <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large" Style="width: 80px; height: 80px;">
                                                <MudIcon Icon="@Icons.Material.Filled.AddPhotoAlternate" />
                                            </MudAvatar>
                                        }
                                        <div>
                                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">شعار الشركة</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">اضغط لاختيار صورة الشعار (PNG, JPG)</MudText>
                                            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="TriggerLogoUpload">
                                                <MudIcon Icon="@Icons.Material.Filled.Upload" Class="mr-1" /> اختيار صورة
                                            </MudButton>
                                            <InputFile OnChange="OnLogoSelected" accept="image/*" style="display:none" @ref="_logoInputRef" id="logoUploadInput" />
                                        </div>
                                        @if (_logoPreview != null)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small" OnClick="RemoveLogo" />
                                        }
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    }
                    else
                    {
                        @* ═══════════════════ View Mode ═══════════════════ *@
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="6">
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">اسم الشركة</MudText>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@_companyInfo?.CompanyName</MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">الموقع الإلكتروني</MudText>
                                    @if (!string.IsNullOrEmpty(_companyInfo?.Website))
                                    {
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                            <MudIcon Icon="@Icons.Material.Filled.Language" Size="Size.Small" Class="mr-1" />
                                            @_companyInfo.Website
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                                    }
                                </div>
                            </MudItem>
                            <MudItem xs="12">
                                <MudDivider Class="my-2" />
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">العنوان</MudText>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" />
                                        @_companyInfo?.Address
                                    </MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">هاتف 1</MudText>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600; direction: ltr; display: inline-block;">
                                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-1" />
                                        @_companyInfo?.Phone1
                                    </MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">هاتف 2</MudText>
                                    @if (!string.IsNullOrEmpty(_companyInfo?.Phone2))
                                    {
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600; direction: ltr; display: inline-block;">
                                            <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Size="Size.Small" Class="mr-1" />
                                            @_companyInfo.Phone2
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                                    }
                                </div>
                            </MudItem>
                            <MudItem xs="12">
                                <MudDivider Class="my-2" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">بريد المبيعات</MudText>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600; direction: ltr; display: inline-block;">
                                        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" Class="mr-1" />
                                        @_companyInfo?.SalesEmail
                                    </MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">بريد الاستفسارات</MudText>
                                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600; direction: ltr; display: inline-block;">
                                        <MudIcon Icon="@Icons.Material.Filled.ContactMail" Size="Size.Small" Class="mr-1" />
                                        @_companyInfo?.InfoEmail
                                    </MudText>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">إصدار النظام</MudText>
                                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                        <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" Class="mr-1" />
                                        @_companyInfo?.CurrentVersion ?? "—"
                                    </MudChip>
                                </div>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="mb-3">
                                    <MudText Typo="Typo.overline" Color="Color.Secondary">رابط الشروط (Dropbox)</MudText>
                                    @if (!string.IsNullOrEmpty(_companyInfo?.TocDropBox))
                                    {
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" Class="mr-1" />
                                            @_companyInfo.TocDropBox
                                        </MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                                    }
                                </div>
                            </MudItem>
                        </MudGrid>
                    }
                </MudPaper>
            </MudItem>

            @* ═══════════════════ Logo Card ═══════════════════ *@
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-6 text-center" Elevation="2" Style="border-radius: 16px;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 700;" Class="mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Image" Class="mr-1" />
                        شعار الشركة
                    </MudText>
                    @if (_companyInfo?.LogoBase64 != null || _logoPreview != null)
                    {
                        var imgSrc = _logoPreview ?? (_companyInfo?.LogoBase64 != null ? $"data:image/png;base64,{_companyInfo.LogoBase64}" : "");
                        <MudAvatar Image="@imgSrc" Style="width: 160px; height: 160px; margin: 0 auto; border-radius: 16px; border: 3px solid #D4AF37;" />
                    }
                    else if (_companyInfo?.LogoPath != null)
                    {
                        <MudAvatar Image="@_companyInfo.LogoPath" Style="width: 160px; height: 160px; margin: 0 auto; border-radius: 16px; border: 3px solid #D4AF37;" />
                    }
                    else
                    {
                        <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Style="width: 160px; height: 160px; margin: 0 auto; border-radius: 16px;">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Style="font-size: 3rem;" />
                        </MudAvatar>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-4">
                            لم يتم رفع شعار بعد
                        </MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ═══════════════════ Locations Section ═══════════════════ *@
        <MudPaper Class="pa-6 mt-4" Elevation="2" Style="border-radius: 16px;">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: 700;">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Class="mr-2" Color="Color.Success" />
                    فروع الشركة
                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text" Class="ml-2">
                        @(_locations?.Count ?? 0) فرع
                    </MudChip>
                </MudText>
                @if (_canAdd)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.AddLocation" OnClick="OpenLocationDialog">
                        إضافة فرع
                    </MudButton>
                }
            </MudStack>

            @if (_locations == null || !_locations.Any())
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                    لا توجد فروع مسجلة. قم بإضافة فرع جديد لتفعيل نظام الحضور بالبصمة.
                </MudAlert>
            }
            else
            {
                <MudTable Items="@_locations" Hover="true" Elevation="0" Style="border-radius: 12px; overflow: hidden;">
                    <HeaderContent>
                        <MudTh>اسم الفرع</MudTh>
                        <MudTh>خط العرض</MudTh>
                        <MudTh>خط الطول</MudTh>
                        <MudTh>نطاق السماح (متر)</MudTh>
                        <MudTh>الحالة</MudTh>
                        <MudTh>الإجراءات</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="اسم الفرع">
                            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">
                                    <MudIcon Icon="@Icons.Material.Filled.Store" />
                                </MudAvatar>
                                <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.LocationName</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="خط العرض">
                            <MudText Typo="Typo.body2" Style="direction: ltr;">@context.Latitude</MudText>
                        </MudTd>
                        <MudTd DataLabel="خط الطول">
                            <MudText Typo="Typo.body2" Style="direction: ltr;">@context.Longitude</MudText>
                        </MudTd>
                        <MudTd DataLabel="نطاق السماح">
                            @if (context.AllowedRadius.HasValue)
                            {
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">
                                    @context.AllowedRadius متر
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="الحالة">
                            @if (context.IsActive == true)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">
                                    نشط
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Outlined">
                                    غير نشط
                                </MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="الإجراءات">
                            <MudStack Row Spacing="1">
                                @if (_canEdit)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="() => OpenEditLocationDialog(context)" />
                                }
                                @if (_canDelete)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="() => ConfirmDeleteLocation(context)" />
                                }
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }
</MudContainer>

@* ═══════════════════ Location Dialog ═══════════════════ *@
<MudDialog @bind-IsOpen="_showLocationDialog">
    <DialogContent>
        <MudText Typo="Typo.h6" Style="font-weight: 700;" Class="mb-4">
            @if (_locationForm?.LocationId != null)
            {
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" Color="Color.Primary" />
                <span>تعديل فرع</span>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.AddLocation" Class="mr-2" Color="Color.Success" />
                <span>إضافة فرع جديد</span>
            }
        </MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12">
                <MudTextField T="string" Label="اسم الفرع" @bind-Value="_locationForm!.LocationName"
                              Variant="Variant.Outlined" Required="true" RequiredError="اسم الفرع مطلوب"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Store" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField T="decimal" Label="خط العرض (Latitude)" @bind-Value="_locationForm.Latitude"
                                 Variant="Variant.Outlined" Required="true" Min="-90" Max="90"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Explore" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField T="decimal" Label="خط الطول (Longitude)" @bind-Value="_locationForm.Longitude"
                                 Variant="Variant.Outlined" Required="true" Min="-180" Max="180"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Explore" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField T="int" Label="نطاق السماح (متر)" @bind-Value="_allowedRadius"
                                 Variant="Variant.Outlined" Min="10" Max="10000"
                                 Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Radar" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSwitch T="bool" Label="فرع نشط" @bind-Value="_locationForm.IsActive"
                           Color="Color.Success" Class="mt-4" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="CloseLocationDialog">إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveLocation" Disabled="@_isSavingLocation">
            @if (_isSavingLocation)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            حفظ
        </MudButton>
    </DialogActions>
</MudDialog>

@* ═══════════════════ Delete Confirmation Dialog ═══════════════════ *@
<MudDialog @bind-IsOpen="_showDeleteDialog">
    <DialogContent>
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="py-4">
            <MudAvatar Color="Color.Error" Variant="Variant.Filled" Style="width: 64px; height: 64px;">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Style="font-size: 2rem;" />
            </MudAvatar>
            <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight: 700;">تأكيد الحذف</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
                هل أنت متأكد من حذف فرع <strong>@_locationToDelete?.LocationName</strong>؟
                <br />لا يمكن التراجع عن هذا الإجراء.
            </MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="CloseDeleteDialog">إلغاء</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteLocation" Disabled="@_isDeletingLocation">
            @if (_isDeletingLocation)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            حذف
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    // ═══════════════════ STATE ═══════════════════
    private CompanyInfoDto? _companyInfo;
    private List<CompanyLocationDto> _locations = new();
    private bool _isLoading = true;
    private bool _isEditing = false;
    private bool _isSaving = false;
    private bool _isSavingLocation = false;
    private bool _isDeletingLocation = false;

    // Permissions
    private bool _canView = false;
    private bool _canAdd = false;
    private bool _canEdit = false;
    private bool _canDelete = false;

    // Form Data
    private CompanyInfoUpdateDto _formData = new();
    private CompanyLocationFormDto _locationForm = new();
    private CompanyLocationDto? _locationToDelete;

    // Helper for nullable int in NumericField
    private int _allowedRadius = 100;

    // Dialogs
    private bool _showLocationDialog = false;
    private bool _showDeleteDialog = false;

    // Logo
    private string? _logoPreview;
    private InputFile? _logoInputRef;

    // ═══════════════════ LIFECYCLE ═══════════════════
    protected override async Task OnInitializedAsync()
    {
        await LoadPermissions();
        await LoadData();
    }

    // ═══════════════════ PERMISSIONS ═══════════════════
    private async Task LoadPermissions()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var claims = auth.User.Claims.ToList();

        _canView = claims.Any(c => c.Type == "Permission" && c.Value == "frm_CompanyInfo:View");
        _canAdd = claims.Any(c => c.Type == "Permission" && c.Value == "frm_CompanyInfo:Add");
        _canEdit = claims.Any(c => c.Type == "Permission" && c.Value == "frm_CompanyInfo:Edit");
        _canDelete = claims.Any(c => c.Type == "Permission" && c.Value == "frm_CompanyInfo:Delete");

        // Admin always has access
        var role = auth.User.FindFirst(ClaimTypes.Role)?.Value;
        if (role == "Admin")
        {
            _canView = _canAdd = _canEdit = _canDelete = true;
        }
    }

    // ═══════════════════ DATA ═══════════════════
    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _companyInfo = await CompanyService.GetCompanyInfoAsync();
            _locations = await CompanyService.GetLocationsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // ═══════════════════ EDIT MODE ═══════════════════
    private void ToggleEdit()
    {
        _isEditing = true;
        _logoPreview = null;

        if (_companyInfo != null)
        {
            _formData = new CompanyInfoUpdateDto
            {
                CompanyId = _companyInfo.CompanyId,
                CompanyName = _companyInfo.CompanyName,
                Address = _companyInfo.Address,
                Phone1 = _companyInfo.Phone1,
                Phone2 = _companyInfo.Phone2,
                SalesEmail = _companyInfo.SalesEmail,
                InfoEmail = _companyInfo.InfoEmail,
                Website = _companyInfo.Website,
                TocDropBox = _companyInfo.TocDropBox,
                CurrentVersion = _companyInfo.CurrentVersion
            };
        }
    }

    private void OpenCreateMode()
    {
        _isEditing = true;
        _logoPreview = null;
        _formData = new CompanyInfoUpdateDto
        {
            CompanyName = "",
            Address = "",
            Phone1 = "",
            SalesEmail = "",
            InfoEmail = "",
            Website = ""
        };
    }

    private void CancelEdit()
    {
        _isEditing = false;
        _logoPreview = null;
    }

    // ═══════════════════ SAVE COMPANY INFO ═══════════════════
    private async Task SaveCompanyInfo()
    {
        if (string.IsNullOrWhiteSpace(_formData.CompanyName))
        {
            Snackbar.Add("اسم الشركة مطلوب", Severity.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(_formData.Address))
        {
            Snackbar.Add("العنوان مطلوب", Severity.Warning);
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            // Set logo base64 if preview exists
            _formData.LogoBase64 = _logoPreview?.Replace("data:image/png;base64,", "")
                                                ?.Replace("data:image/jpeg;base64,", "")
                                                ?.Replace("data:image/jpg;base64,", "");

            _companyInfo = await CompanyService.UpdateCompanyInfoAsync(_formData);
            _isEditing = false;
            _logoPreview = null;

            Snackbar.Add("تم حفظ بيانات الشركة بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في حفظ البيانات: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    // ═══════════════════ LOGO UPLOAD ═══════════════════
    private async Task TriggerLogoUpload()
{
    await JS.InvokeVoidAsync("eval", "document.getElementById('logoUploadInput').click()");
}

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null || file.Size == 0) return;

        // Max 2MB
        if (file.Size > 2 * 1024 * 1024)
        {
            Snackbar.Add("حجم الصورة يجب ألا يتجاوز 2 ميجابايت", Severity.Warning);
            return;
        }

        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024).ReadAsync(buffer);

        var base64 = Convert.ToBase64String(buffer);
        var contentType = file.ContentType ?? "image/png";
        _logoPreview = $"data:{contentType};base64,{base64}";

        StateHasChanged();
    }

    private void RemoveLogo()
    {
        _logoPreview = null;
        _formData.LogoBase64 = null;
    }

    // ═══════════════════ LOCATION DIALOG ═══════════════════
    private void OpenLocationDialog()
    {
        _locationForm = new CompanyLocationFormDto { IsActive = true, AllowedRadius = 100 };
        _allowedRadius = 100;
        _showLocationDialog = true;
    }

    private void OpenEditLocationDialog(CompanyLocationDto location)
    {
        _locationForm = new CompanyLocationFormDto
        {
            LocationId = location.LocationId,
            LocationName = location.LocationName,
            Latitude = location.Latitude,
            Longitude = location.Longitude,
            AllowedRadius = location.AllowedRadius,
            IsActive = location.IsActive ?? true
        };
        _allowedRadius = location.AllowedRadius ?? 100;
        _showLocationDialog = true;
    }

    private void CloseLocationDialog()
    {
        _showLocationDialog = false;
    }

    private async Task SaveLocation()
    {
        if (string.IsNullOrWhiteSpace(_locationForm.LocationName))
        {
            Snackbar.Add("اسم الفرع مطلوب", Severity.Warning);
            return;
        }

        _isSavingLocation = true;
        StateHasChanged();

        try
        {
            // Sync the non-nullable field
            _locationForm.AllowedRadius = _allowedRadius;

            if (_locationForm.LocationId.HasValue)
            {
                await CompanyService.UpdateLocationAsync(_locationForm);
                Snackbar.Add("تم تعديل الفرع بنجاح", Severity.Success);
            }
            else
            {
                await CompanyService.AddLocationAsync(_locationForm);
                Snackbar.Add("تم إضافة الفرع بنجاح", Severity.Success);
            }

            _locations = await CompanyService.GetLocationsAsync();
            _showLocationDialog = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSavingLocation = false;
            StateHasChanged();
        }
    }

    // ═══════════════════ DELETE LOCATION ═══════════════════
    private void ConfirmDeleteLocation(CompanyLocationDto location)
    {
        _locationToDelete = location;
        _showDeleteDialog = true;
    }

    private void CloseDeleteDialog()
    {
        _showDeleteDialog = false;
        _locationToDelete = null;
    }

    private async Task DeleteLocation()
    {
        if (_locationToDelete == null) return;

        _isDeletingLocation = true;
        StateHasChanged();

        try
        {
            var success = await CompanyService.DeleteLocationAsync(_locationToDelete.LocationId);
            if (success)
            {
                Snackbar.Add("تم حذف الفرع بنجاح", Severity.Success);
                _locations = await CompanyService.GetLocationsAsync();
            }
            else
            {
                Snackbar.Add("لم يتم العثور على الفرع", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في الحذف: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isDeletingLocation = false;
            _showDeleteDialog = false;
            _locationToDelete = null;
            StateHasChanged();
        }
    }
}