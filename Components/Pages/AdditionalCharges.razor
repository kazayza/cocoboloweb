@code {
    /* ═══════════════════════════════════════════════════════════════════════════
       STATE VARIABLES
       ═══════════════════════════════════════════════════════════════════════════ */
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _filterExpanded = true;
    private bool _fabExpanded = false;
    private int _hoveredStat = 0;
    private bool _selectAll = false;
    private HashSet<int> _selectedRows = new();
    private AdditionalChargeFilterDto _filter = new();
    private AdditionalChargeStatsDto? _stats;
    private PagedResult<AdditionalChargeListDto>? _result;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    // Dialogs
    private bool _showFormDialog = false;
    private bool _showApplyDialog = false;
    private bool _showNonRefundDialog = false;
    private bool _showDeleteDialog = false;
    private bool _isEditing = false;

    // Form
    private AdditionalChargeFormDto _formData = new();
    private AdditionalChargeListDto? _selectedCharge;
    private PartyLookupDto? _selectedParty;
    private InvoiceLookupDto? _selectedInvoice;
    private string _nonRefundReason = "";
    private string _currentUserName = "System";

    /* ═══════════════════════════════════════════════════════════════════════════
       LIFECYCLE
       ═══════════════════════════════════════════════════════════════════════════ */
    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserName = auth.User.Identity?.Name ?? "System";
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        _filter.DateFrom = _dateFrom;
        _filter.DateTo = _dateTo;
        _result = await ChargeService.GetChargesAsync(_filter);
        _stats = await ChargeService.GetStatsAsync();
        _isLoading = false;
        StateHasChanged();
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       TABLE HELPERS
       ═══════════════════════════════════════════════════════════════════════════ */
    private string GetRowClass(AdditionalChargeListDto item, int index) =>
        _selectedRows.Contains(item.ChargeId) ? "row-selected" : "";

    private void ToggleSelectAll(bool value)
    {
        _selectAll = value;
        if (value && _result?.Items != null)
            _selectedRows = new HashSet<int>(_result.Items.Select(x => x.ChargeId));
        else
            _selectedRows.Clear();
    }

    private void ToggleRowSelection(int id, bool selected)
    {
        if (selected)
            _selectedRows.Add(id);
        else
            _selectedRows.Remove(id);
        _selectAll = _result?.Items != null && _selectedRows.Count == _result.Items.Count;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       FILTER HANDLERS
       ═══════════════════════════════════════════════════════════════════════════ */
    private bool HasActiveFilters() =>
        !string.IsNullOrEmpty(_filter.SearchText) ||
        !string.IsNullOrEmpty(_filter.ChargeType) ||
        !string.IsNullOrEmpty(_filter.Status) ||
        _dateFrom.HasValue ||
        _dateTo.HasValue;

    private async Task OnFilterChanged()
    {
        _filter.PageNumber = 1;
        await LoadData();
    }

    private async Task OnPageChanged(int page)
    {
        _filter.PageNumber = page;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _filter = new() { PageNumber = 1 };
        _dateFrom = null;
        _dateTo = null;
        await LoadData();
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       HELPERS
       ═══════════════════════════════════════════════════════════════════════════ */
    private string GetChargeTypeIcon(string? type) => type switch
    {
        ChargeTypes.Inspection => "🔍",
        ChargeTypes.Shipping => "🚚",
        ChargeTypes.Installation => "🔧",
        _ => "📦"
    };

    private string GetChargeTypeName(string? type) =>
        ChargeTypes.All.TryGetValue(type ?? "", out var name) ? name : "رسوم";

    private string FormatMoney(decimal v) => $"{v:N2}";

    /* ═══════════════════════════════════════════════════════════════════════════
       NOTIFICATIONS
       ═══════════════════════════════════════════════════════════════════════════ */
    private async Task SendNotification(string msg)
    {
        try
        {
            await Notify.NotifyRoleAsync("💰 رسوم إضافية", msg, SystemRoles.Admin,
                _currentUserName, "additional-charges", "AdditionalCharges", 0);
            await Notify.NotifyRoleAsync("💰 رسوم إضافية", msg, SystemRoles.AccountManager,
                _currentUserName, "additional-charges", "AdditionalCharges", 0);
            await Notify.NotifyRoleAsync("💰 رسوم إضافية", msg, SystemRoles.Account,
                _currentUserName, "additional-charges", "AdditionalCharges", 0);
        }
        catch { }
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       CREATE / EDIT
       ═══════════════════════════════════════════════════════════════════════════ */
    private void OpenCreateDialog()
    {
        _isEditing = false;
        _formData = new() { Status = ChargeStatuses.Paid, ChargeType = _formData.ChargeType ?? ChargeTypes.Inspection };
        _selectedParty = null;
        _fabExpanded = false;
        _showFormDialog = true;
    }

    private async Task OpenEditDialog(AdditionalChargeListDto charge)
    {
        _isEditing = true;
        var data = await ChargeService.GetChargeForEditAsync(charge.ChargeId);
        if (data != null)
        {
            _formData = data;
            _selectedParty = new PartyLookupDto
            {
                PartyId = charge.PartyId ?? 0,
                PartyName = charge.PartyName ?? "",
                Phone = charge.PartyPhone
            };
            _showFormDialog = true;
        }
    }

    private async Task SaveCharge()
    {
        if (_formData.ChargeAmount <= 0)
        {
            Snackbar.Add("المبلغ مطلوب", Severity.Warning);
            return;
        }
        if (_selectedParty == null && !_isEditing)
        {
            Snackbar.Add("يرجى اختيار العميل", Severity.Warning);
            return;
        }

        _isSaving = true;
        _formData.PartyId = _selectedParty?.PartyId;

        var (ok, msg) = _isEditing
            ? await ChargeService.UpdateChargeAsync(_formData.ChargeId, _formData, _currentUserName)
            : await ChargeService.CreateChargeAsync(_formData, _currentUserName);

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            var actionWord = _isEditing ? "تعديل" : "إضافة";
            await SendNotification($"{actionWord} رسوم {_formData.ChargeAmount:N2} ج - {GetChargeTypeName(_formData.ChargeType)} - {_selectedParty?.PartyName ?? ""} بواسطة {_currentUserName}");
        }

        _isSaving = false;
        _showFormDialog = false;
        await LoadData();
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       PARTY SEARCH
       ═══════════════════════════════════════════════════════════════════════════ */
    private void OnPartySelected(PartyLookupDto? party)
    {
        _selectedParty = party;
        _formData.PartyId = party?.PartyId;
    }

    private async Task<IEnumerable<PartyLookupDto>> SearchParties(string search, CancellationToken token)
    {
        return await PaymentService.SearchPartiesAsync(search);
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       APPLY TO INVOICE
       ═══════════════════════════════════════════════════════════════════════════ */
    private void OpenApplyDialog(AdditionalChargeListDto charge)
    {
        _selectedCharge = charge;
        _selectedInvoice = null;
        _showApplyDialog = true;
    }

    private void OnInvoiceSelected(InvoiceLookupDto? inv)
    {
        _selectedInvoice = inv;
    }

    private async Task<IEnumerable<InvoiceLookupDto>> SearchInvoices(string search, CancellationToken token)
    {
        if (_selectedCharge?.PartyId == null) return Enumerable.Empty<InvoiceLookupDto>();
        return await PaymentService.SearchInvoicesAsync(TransactionTypes.Sale, search, true, 10);
    }

    private async Task ApplyToInvoice()
    {
        if (_selectedInvoice == null || _selectedCharge == null)
        {
            Snackbar.Add("يرجى اختيار الفاتورة", Severity.Warning);
            return;
        }

        _isSaving = true;
        var (ok, msg) = await ChargeService.ApplyToInvoiceAsync(
            _selectedCharge.ChargeId, _selectedInvoice.TransactionId, _currentUserName);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            await SendNotification($"تطبيق رسوم {FormatMoney(_selectedCharge.ChargeAmount)} ج على فاتورة {_selectedInvoice.ReferenceNumber} - {_selectedCharge.PartyName} بواسطة {_currentUserName}");
        }

        _isSaving = false;
        _showApplyDialog = false;
        await LoadData();
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       NON REFUNDABLE
       ═══════════════════════════════════════════════════════════════════════════ */
    private void OpenNonRefundDialog(AdditionalChargeListDto charge)
    {
        _selectedCharge = charge;
        _nonRefundReason = "";
        _showNonRefundDialog = true;
    }

    private async Task MarkNonRefundable()
    {
        if (_selectedCharge == null) return;

        _isSaving = true;
        var (ok, msg) = await ChargeService.MarkAsNonRefundableAsync(
            _selectedCharge.ChargeId, _nonRefundReason, _currentUserName);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            await SendNotification($"تحديد رسوم {FormatMoney(_selectedCharge.ChargeAmount)} ج كغير مستردة - {_selectedCharge.PartyName} بواسطة {_currentUserName}");
        }

        _isSaving = false;
        _showNonRefundDialog = false;
        await LoadData();
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       DELETE
       ═══════════════════════════════════════════════════════════════════════════ */
    private void ConfirmDelete(AdditionalChargeListDto charge)
    {
        _selectedCharge = charge;
        _showDeleteDialog = true;
    }

    private async Task DeleteCharge()
    {
        if (_selectedCharge == null) return;

        _isSaving = true;
        var (ok, msg) = await ChargeService.DeleteChargeAsync(_selectedCharge.ChargeId, _currentUserName);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok)
        {
            await SendNotification($"حذف رسوم {FormatMoney(_selectedCharge.ChargeAmount)} ج - {_selectedCharge.PartyName} بواسطة {_currentUserName}");
        }

        _isSaving = false;
        _showDeleteDialog = false;
        await LoadData();
    }
}
