@page "/additional-charges"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudBlazor

@inject IAdditionalChargeService ChargeService
@inject IPaymentService PaymentService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState
@inject NotificationService Notify

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ BACKGROUND DECORATIONS                                                   -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="page-bg-decorations">
    <div class="bg-orb bg-orb-1"></div>
    <div class="bg-orb bg-orb-2"></div>
    <div class="bg-orb bg-orb-3"></div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ TOP ACCENT BAR (Animated)                                                -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="top-accent-bar">
    <div class="accent-shimmer"></div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ PREMIUM HEADER                                                      -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="charges-header">
    <div class="header-bg">
        <div class="header-gradient"></div>
        <div class="header-orbs">
            <div class="header-orb orb-1"></div>
            <div class="header-orb orb-2"></div>
            <div class="header-orb orb-3"></div>
        </div>
        <div class="header-grid"></div>
    </div>
    <div class="header-content">
        <div class="header-info">
            <div class="header-icon-wrapper">
                <div class="header-icon-glow"></div>
                <div class="header-icon">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" />
                </div>
                <div class="header-icon-badge">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                </div>
                <div class="header-icon-badge-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" />
                </div>
            </div>
            <div class="header-text">
                <div class="header-title-row">
                    <h1>الرسوم الإضافية</h1>
                    <span class="premium-badge">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                        Premium
                    </span>
                </div>
                <p>
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Class="subtitle-icon" />
                    إدارة وتتبع رسوم المعاينة، الشحن، التركيب وغيرها
                </p>
            </div>
        </div>
        <div class="header-actions">
            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateDialog"
                       Class="btn-add-new">
                <span class="btn-shine"></span>
                إضافة رسوم جديدة
            </MudButton>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ PREMIUM STATS GRID                                                       -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_stats != null)
{
    <div class="stats-grid">
        <div class="stat-card stat-total animate-card" style="--delay: 0.05s" @onmouseover="() => _hoveredStat = 1" @onmouseout="() => _hoveredStat = 0">
            <div class="stat-glow"></div>
            <div class="stat-accent"></div>
            <div class="stat-content">
                <div class="stat-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
                    <div class="stat-icon-ring"></div>
                </div>
                <div class="stat-data">
                    <div class="stat-value-row">
                        <span class="stat-value">@FormatMoney(_stats.TotalAmount)</span>
                        <span class="stat-trend trend-up">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                            12%
                        </span>
                    </div>
                    <div class="stat-label">إجمالي الرسوم</div>
                </div>
            </div>
            <div class="stat-hover-indicator"></div>
        </div>

        <div class="stat-card stat-collected animate-card" style="--delay: 0.1s">
            <div class="stat-glow"></div>
            <div class="stat-accent"></div>
            <div class="stat-content">
                <div class="stat-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                </div>
                <div class="stat-data">
                    <div class="stat-value-row">
                        <span class="stat-value">@FormatMoney(_stats.PaidAmount + _stats.AppliedAmount)</span>
                        <span class="stat-trend trend-up">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" />
                            8%
                        </span>
                    </div>
                    <div class="stat-label">إجمالي محصّل</div>
                </div>
            </div>
        </div>

        <div class="stat-card stat-paid animate-card" style="--delay: 0.15s">
            <div class="stat-glow"></div>
            <div class="stat-accent"></div>
            <div class="stat-content">
                <div class="stat-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.Payments" />
                </div>
                <div class="stat-data">
                    <span class="stat-value">@FormatMoney(_stats.PaidAmount)</span>
                    <div class="stat-label">مدفوعة (غير مطبقة)</div>
                </div>
            </div>
        </div>

        <div class="stat-card stat-applied animate-card" style="--delay: 0.2s">
            <div class="stat-glow"></div>
            <div class="stat-accent"></div>
            <div class="stat-content">
                <div class="stat-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.Link" />
                </div>
                <div class="stat-data">
                    <span class="stat-value">@FormatMoney(_stats.AppliedAmount)</span>
                    <div class="stat-label">مطبقة على فواتير</div>
                </div>
            </div>
        </div>

        <div class="stat-card stat-nonrefund animate-card" style="--delay: 0.25s">
            <div class="stat-glow"></div>
            <div class="stat-accent"></div>
            <div class="stat-content">
                <div class="stat-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.Block" />
                </div>
                <div class="stat-data">
                    <div class="stat-value-row">
                        <span class="stat-value">@FormatMoney(_stats.NonRefundableAmount)</span>
                        <span class="stat-trend trend-down">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Size="Size.Small" />
                            3%
                        </span>
                    </div>
                    <div class="stat-label">غير مستردة</div>
                </div>
            </div>
        </div>

        <div class="stat-card stat-count animate-card" style="--delay: 0.3s">
            <div class="stat-glow"></div>
            <div class="stat-accent"></div>
            <div class="stat-content">
                <div class="stat-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.BarChart" />
                </div>
                <div class="stat-data">
                    <span class="stat-value">@_stats.TotalCount</span>
                    <div class="stat-label">عدد الرسوم</div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ QUICK ACTIONS BAR                                                        -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="quick-actions-bar">
    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="LoadData" Class="quick-action-btn">
        تحديث
    </MudButton>
    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.FileDownload"
               Class="quick-action-btn">
        تصدير
    </MudButton>
    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.FileUpload"
               Class="quick-action-btn">
        استيراد
    </MudButton>
    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Print"
               Class="quick-action-btn">
        طباعة
    </MudButton>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ PREMIUM FILTER BAR                                                       -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="filter-container animate-card" style="--delay: 0.35s">
    <div class="filter-header" @onclick="() => _filterExpanded = !_filterExpanded">
        <div class="filter-header-right">
            <div class="filter-icon-box">
                <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" />
            </div>
            <span class="filter-title">بحث وتصفية</span>
            @if (HasActiveFilters())
            {
                <span class="filter-active-badge">
                    <span class="badge-pulse"></span>
                    فلتر نشط
                </span>
            }
        </div>
        <div class="filter-header-left">
            @if (HasActiveFilters())
            {
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Close"
                           OnClick="ResetFilters" Class="btn-reset-filter">
                    مسح الفلاتر
                </MudButton>
            }
            <div class="filter-expand-icon @(_filterExpanded ? "expanded" : "")">
                <MudIcon Icon="@Icons.Material.Filled.ExpandMore" Size="Size.Small" />
            </div>
        </div>
    </div>
    @if (_filterExpanded)
    {
        <div class="filter-content">
            <div class="filter-grid">
                <MudTextField T="string" @bind-Value="_filter.SearchText"
                              Placeholder="بحث باسم العميل، الهاتف، الوصف..."
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="400"
                              OnDebounceIntervalElapsed="OnFilterChanged"
                              Class="filter-search" />
                <MudSelect T="string" Value="@_filter.ChargeType"
                           ValueChanged="@((string? v) => { _filter.ChargeType = v; _ = OnFilterChanged(); })"
                           Label="نوع الرسوم" Variant="Variant.Outlined" Clearable="true"
                           AnchorOrigin="Origin.BottomCenter" Class="filter-select">
                    @foreach (var ct in ChargeTypes.All)
                    {
                        <MudSelectItem T="string" Value="@ct.Key">
                            <div class="select-item-content">
                                <span class="select-item-icon">@GetChargeTypeIcon(ct.Key)</span>
                                <span>@ct.Value</span>
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="string" Value="@_filter.Status"
                           ValueChanged="@((string? v) => { _filter.Status = v; _ = OnFilterChanged(); })"
                           Label="الحالة" Variant="Variant.Outlined" Clearable="true"
                           AnchorOrigin="Origin.BottomCenter" Class="filter-select">
                    @foreach (var st in ChargeStatuses.All)
                    {
                        <MudSelectItem T="string" Value="@st.Key">@st.Value</MudSelectItem>
                    }
                </MudSelect>
                <div class="filter-dates">
                    <MudDatePicker T="DateTime?" @bind-Value="_dateFrom"
                                   Label="من تاريخ" Variant="Variant.Outlined"
                                   Adornment="Adornment.Start"
                                   AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                                   DateChanged="@((DateTime? d) => { _dateFrom = d; _ = OnFilterChanged(); })"
                                   Class="filter-date" />
                    <span class="date-separator">←</span>
                    <MudDatePicker T="DateTime?" @bind-Value="_dateTo"
                                   Label="إلى تاريخ" Variant="Variant.Outlined"
                                   DateChanged="@((DateTime? d) => { _dateTo = d; _ = OnFilterChanged(); })"
                                   Class="filter-date" />
                </div>
            </div>
        </div>
    }
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ PREMIUM TABLE                                                            -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="table-container animate-card" style="--delay: 0.4s">
    <div class="table-header-bar">
        <div class="table-header-right">
            <div class="table-dot-wrapper">
                <span class="table-dot"></span>
                <span class="table-dot-ping"></span>
            </div>
            <span class="table-title">قائمة الرسوم</span>
            <span class="table-count">@(_result?.TotalCount ?? 0) رسوم</span>
        </div>
        @if (_selectedRows.Count > 0)
        {
            <div class="table-selection-info">
                <span>تم تحديد @_selectedRows.Count</span>
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                           OnClick="() => _selectedRows.Clear()">
                    إلغاء التحديد
                </MudButton>
            </div>
        }
    </div>
    <MudTable T="AdditionalChargeListDto"
              Items="@(_result?.Items ?? new())"
              Loading="@_isLoading"
              Hover="true"
              Breakpoint="Breakpoint.Sm"
              Class="charges-table"
              RowClassFunc="GetRowClass">
        <HeaderContent>
            <MudTh Style="width:50px;">
                <MudCheckBox T="bool" Value="_selectAll" ValueChanged="ToggleSelectAll" Size="Size.Small" />
            </MudTh>
            <MudTh>العميل</MudTh>
            <MudTh>نوع الرسوم</MudTh>
            <MudTh>الوصف</MudTh>
            <MudTh>المبلغ</MudTh>
            <MudTh>الحالة</MudTh>
            <MudTh>الفاتورة</MudTh>
            <MudTh>التاريخ</MudTh>
            <MudTh Style="width:60px;"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudCheckBox T="bool" Value="@_selectedRows.Contains(context.ChargeId)"
                             ValueChanged="@((bool v) => ToggleRowSelection(context.ChargeId, v))"
                             Size="Size.Small" />
            </MudTd>
            <MudTd DataLabel="العميل">
                <div class="customer-cell">
                    <div class="customer-avatar-wrapper">
                        <div class="customer-avatar">
                            @(context.PartyName?.Substring(0, Math.Min(2, context.PartyName?.Length ?? 0)))
                        </div>
                        <span class="customer-online-dot"></span>
                    </div>
                    <div class="customer-info">
                        <div class="customer-name">@context.PartyName</div>
                        @if (!string.IsNullOrEmpty(context.PartyPhone))
                        {
                            <div class="customer-phone">
                                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" />
                                <span dir="ltr">@context.PartyPhone</span>
                            </div>
                        }
                    </div>
                </div>
            </MudTd>
            <MudTd DataLabel="نوع الرسوم">
                <div class="charge-type-cell">
                    <span class="type-icon">@GetChargeTypeIcon(context.ChargeType)</span>
                    <span class="type-badge type-@(context.ChargeType?.ToLower())">
                        @context.ChargeTypeName
                    </span>
                </div>
            </MudTd>
            <MudTd DataLabel="الوصف">
                <span class="desc-text">@(context.ChargeDescription ?? "—")</span>
            </MudTd>
            <MudTd DataLabel="المبلغ">
                <div class="amount-cell">
                    <span class="amount-value">@FormatMoney(context.ChargeAmount)</span>
                    <span class="amount-currency">ج.م</span>
                </div>
            </MudTd>
            <MudTd DataLabel="الحالة">
                <span class="status-pill status-@(context.Status?.ToLower())">
                    <span class="status-dot"></span>
                    @context.StatusName
                </span>
            </MudTd>
            <MudTd DataLabel="الفاتورة">
                @if (context.AppliedToTransactionRef != null)
                {
                    <span class="invoice-ref ref-applied">
                        <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" />
                        @context.AppliedToTransactionRef
                    </span>
                }
                else if (context.TransactionRef != null)
                {
                    <span class="invoice-ref ref-linked">
                        @context.TransactionRef
                    </span>
                }
                else
                {
                    <span class="invoice-empty">—</span>
                }
            </MudTd>
            <MudTd DataLabel="التاريخ">
                <div class="date-cell">
                    <span class="date-main">@(context.CreatedAt?.ToString("yyyy/MM/dd") ?? "-")</span>
                    <span class="date-time">@(context.CreatedAt?.ToString("HH:mm") ?? "")</span>
                </div>
            </MudTd>
            <MudTd>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                         AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopRight"
                         Class="row-menu">
                    @if (context.Status == ChargeStatuses.Paid)
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.Link"
                                     OnClick="@(() => OpenApplyDialog(context))"
                                     Class="menu-item-apply">
                            تطبيق على فاتورة
                        </MudMenuItem>
                    }
                    @if (context.Status != ChargeStatuses.NonRefundable && context.Status != ChargeStatuses.Applied)
                    {
                        <MudMenuItem Icon="@Icons.Material.Filled.Block"
                                     OnClick="@(() => OpenNonRefundDialog(context))"
                                     Class="menu-item-warning">
                            تحديد كغير مستردة
                        </MudMenuItem>
                    }
                    <MudMenuItem Icon="@Icons.Material.Filled.Visibility">
                        عرض التفاصيل
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.ContentCopy">
                        نسخ
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                 OnClick="@(() => OpenEditDialog(context))"
                                 Disabled="@(context.Status == ChargeStatuses.Applied || context.Status == ChargeStatuses.NonRefundable)">
                        تعديل
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                 OnClick="@(() => ConfirmDelete(context))"
                                 Disabled="@(context.Status == ChargeStatuses.Applied || context.Status == ChargeStatuses.NonRefundable)"
                                 Class="menu-item-danger">
                        حذف
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="empty-state">
                <div class="empty-illustration">
                    <div class="empty-icon-box">
                        <MudIcon Icon="@Icons.Material.Filled.Inbox" Size="Size.Large" />
                    </div>
                    <div class="empty-particles">
                        <span class="particle particle-1"></span>
                        <span class="particle particle-2"></span>
                        <span class="particle particle-3"></span>
                    </div>
                </div>
                <h3>لا توجد رسوم مسجلة</h3>
                <p>قم بإضافة رسوم جديدة مثل رسوم معاينة أو شحن أو تركيب لتظهر هنا وتبدأ في تتبعها</p>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreateDialog" Class="empty-btn">
                    إضافة رسوم جديدة
                </MudButton>
            </div>
        </NoRecordsContent>
        <LoadingContent>
            <div class="loading-state">
                <div class="loading-spinner">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                </div>
                <span>جاري تحميل البيانات...</span>
            </div>
        </LoadingContent>
    </MudTable>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ PREMIUM PAGINATION                                                       -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
@if (_result != null && _result.TotalCount > _filter.PageSize)
{
    <div class="pagination-bar">
        <span class="pagination-info">
            عرض @(((_filter.PageNumber - 1) * _filter.PageSize) + 1) - @Math.Min(_filter.PageNumber * _filter.PageSize, _result.TotalCount) من @_result.TotalCount
        </span>
        <div class="pagination-controls">
            <MudIconButton Icon="@Icons.Material.Filled.FirstPage" Size="Size.Small"
                           Disabled="@(_filter.PageNumber == 1)"
                           OnClick="@(() => OnPageChanged(1))"
                           Class="pagination-btn" />
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                           Disabled="@(_filter.PageNumber == 1)"
                           OnClick="@(() => OnPageChanged(_filter.PageNumber - 1))"
                           Class="pagination-btn" />
            @{
                var totalPages = (int)Math.Ceiling((double)_result.TotalCount / _filter.PageSize);
                for (int i = 1; i <= totalPages; i++)
                {
                    var page = i;
                    <MudButton Variant="@(page == _filter.PageNumber ? Variant.Filled : Variant.Text)"
                               Color="@(page == _filter.PageNumber ? Color.Primary : Color.Default)"
                               Size="Size.Small"
                               OnClick="@(() => OnPageChanged(page))"
                               Class="@(page == _filter.PageNumber ? "pagination-btn active" : "pagination-btn")">
                        @(page)
                    </MudButton>
                }
            }
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                           Disabled="@(_filter.PageNumber == totalPages)"
                           OnClick="@(() => OnPageChanged(_filter.PageNumber + 1))"
                           Class="pagination-btn" />
            <MudIconButton Icon="@Icons.Material.Filled.LastPage" Size="Size.Small"
                           Disabled="@(_filter.PageNumber == totalPages)"
                           OnClick="@(() => OnPageChanged(totalPages))"
                           Class="pagination-btn" />
        </div>
    </div>
}

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ FLOATING ACTION BUTTON                                                   -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="fab-container @(_fabExpanded ? "expanded" : "")">
    @if (_fabExpanded)
    {
        <div class="fab-actions">
            <div class="fab-action fab-inspection" @onclick="() => { _formData.ChargeType = ChargeTypes.Inspection; OpenCreateDialog(); }">
                <span class="fab-action-icon">🔍</span>
                <span class="fab-action-label">رسوم معاينة</span>
            </div>
            <div class="fab-action fab-shipping" @onclick="() => { _formData.ChargeType = ChargeTypes.Shipping; OpenCreateDialog(); }">
                <span class="fab-action-icon">🚚</span>
                <span class="fab-action-label">رسوم شحن</span>
            </div>
            <div class="fab-action fab-installation" @onclick="() => { _formData.ChargeType = ChargeTypes.Installation; OpenCreateDialog(); }">
                <span class="fab-action-icon">🔧</span>
                <span class="fab-action-label">رسوم تركيب</span>
            </div>
            <div class="fab-action fab-other" @onclick="() => { _formData.ChargeType = ChargeTypes.Other; OpenCreateDialog(); }">
                <span class="fab-action-icon">📦</span>
                <span class="fab-action-label">رسوم أخرى</span>
            </div>
        </div>
    }
    <div class="fab-main @(_fabExpanded ? "rotated" : "")" @onclick="() => _fabExpanded = !_fabExpanded">
        <div class="fab-pulse"></div>
        <MudIcon Icon="@(_fabExpanded ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)" Size="Size.Medium" />
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ FOOTER                                                                   -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="page-footer">
    <div class="footer-content">
        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" Class="footer-icon" />
        <span>COCOBOLO ERP — نظام إدارة الرسوم الإضافية</span>
        <span class="footer-premium">Premium Edition</span>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DIALOG: CREATE / EDIT (Premium)                                          -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showFormDialog" Class="premium-dialog dialog-form">
    <TitleContent>
        <div class="dialog-header @(_isEditing ? "dialog-header-edit" : "dialog-header-add")">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@(_isEditing ? Icons.Material.Filled.Edit : Icons.Material.Filled.AddCircle)" />
                </div>
                <span class="dialog-title">@(_isEditing ? "تعديل الرسوم" : "إضافة رسوم جديدة")</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showFormDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body">
            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    العميل *
                </label>
                <MudAutocomplete T="PartyLookupDto"
                                 Value="_selectedParty"
                                 ValueChanged="OnPartySelected"
                                 SearchFunc="SearchParties"
                                 ToStringFunc="@(p => p == null ? "" : $"{p.PartyName} - {p.Phone}")"
                                 Placeholder="ابحث عن اسم العميل..."
                                 Variant="Variant.Outlined"
                                 Disabled="@_isEditing"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 ResetValueOnEmptyText="true"
                                 Class="form-input" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                    نوع الرسوم *
                </label>
                <div class="charge-type-grid">
                    @foreach (var ct in ChargeTypes.All)
                    {
                        <div class="charge-type-option @(_formData.ChargeType == ct.Key ? "selected" : "")"
                             @onclick="() => _formData.ChargeType = ct.Key">
                            <span class="charge-type-icon">@GetChargeTypeIcon(ct.Key)</span>
                            <span class="charge-type-name">@ct.Value</span>
                            @if (_formData.ChargeType == ct.Key)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="charge-type-check" />
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                    وصف الرسوم
                </label>
                <MudTextField T="string" @bind-Value="_formData.ChargeDescription"
                              Placeholder="مثال: معاينة شقة المعادي"
                              Variant="Variant.Outlined"
                              Class="form-input" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" />
                    المبلغ * (جنيه مصري)
                </label>
                <MudNumericField T="decimal" @bind-Value="_formData.ChargeAmount"
                                 Placeholder="0.00"
                                 Variant="Variant.Outlined"
                                 Min="0.01m" Step="100m"
                                 Adornment="Adornment.End"
                                 AdornmentText="ج.م"
                                 Class="form-input form-input-amount" />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.StickyNote2" Size="Size.Small" />
                    ملاحظات
                </label>
                <MudTextField T="string" @bind-Value="_formData.Notes"
                              Placeholder="أضف ملاحظات إضافية..."
                              Variant="Variant.Outlined" Lines="2"
                              Class="form-input" />
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions">
            <MudButton OnClick="@(() => _showFormDialog = false)" Variant="Variant.Text" Class="btn-cancel">
                إلغاء
            </MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="SaveCharge" Disabled="@_isSaving" Class="btn-save">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                }
                <span>@(_isEditing ? "حفظ التعديلات" : "إضافة الرسوم")</span>
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DIALOG: APPLY TO INVOICE (Premium)                                       -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showApplyDialog" Class="premium-dialog dialog-apply">
    <TitleContent>
        <div class="dialog-header dialog-header-apply">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.Link" />
                </div>
                <span class="dialog-title">تطبيق الرسوم على فاتورة</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showApplyDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body">
            <div class="info-card">
                <div class="info-row">
                    <span class="info-label">العميل</span>
                    <span class="info-value">@_selectedCharge?.PartyName</span>
                </div>
                <div class="info-row">
                    <span class="info-label">المبلغ</span>
                    <span class="info-value info-amount">@FormatMoney(_selectedCharge?.ChargeAmount ?? 0) ج.م</span>
                </div>
            </div>

            @if (_selectedCharge?.ChargeType == ChargeTypes.Inspection)
            {
                <div class="alert-box alert-info">
                    <div class="alert-icon">
                        <MudIcon Icon="@Icons.Material.Filled.Info" />
                    </div>
                    <span><strong>رسوم معاينة</strong> → ستُضاف للمبلغ المدفوع (تخصم من المتبقي)</span>
                </div>
            }
            else
            {
                <div class="alert-box alert-warning">
                    <div class="alert-icon">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" />
                    </div>
                    <span><strong>رسوم @(ChargeTypes.All.GetValueOrDefault(_selectedCharge?.ChargeType ?? "", "أخرى"))</strong> → ستُضاف للإجمالي</span>
                </div>
            }

            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" />
                    اختر الفاتورة *
                </label>
                <MudAutocomplete T="InvoiceLookupDto"
                                 Value="_selectedInvoice"
                                 ValueChanged="OnInvoiceSelected"
                                 SearchFunc="SearchInvoices"
                                 ToStringFunc="@(i => i == null ? "" : $"{i.ReferenceNumber} - {i.PartyName}")"
                                 Placeholder="ابحث عن رقم الفاتورة..."
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 Class="form-input" />
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions">
            <MudButton OnClick="@(() => _showApplyDialog = false)" Variant="Variant.Text" Class="btn-cancel">
                إلغاء
            </MudButton>
            <MudButton Color="Color.Success" Variant="Variant.Filled"
                       OnClick="ApplyToInvoice" Disabled="@_isSaving"
                       StartIcon="@Icons.Material.Filled.Check" Class="btn-success">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                }
                تطبيق
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DIALOG: NON REFUNDABLE (Premium)                                         -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showNonRefundDialog" Class="premium-dialog dialog-warning">
    <TitleContent>
        <div class="dialog-header dialog-header-warning">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.Block" />
                </div>
                <span class="dialog-title">تحديد كغير مستردة</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showNonRefundDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body">
            <div class="alert-box alert-warning">
                <div class="alert-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" />
                </div>
                <span>
                    سيتم تحديد رسوم <strong>@FormatMoney(_selectedCharge?.ChargeAmount ?? 0) ج.م</strong>
                    لعميل <strong>@(_selectedCharge?.PartyName ?? "-")</strong> كغير مستردة.
                    <br /><small>هذا الإجراء لا يمكن التراجع عنه.</small>
                </span>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <MudIcon Icon="@Icons.Material.Filled.Message" Size="Size.Small" />
                    سبب عدم الاسترداد
                </label>
                <MudTextField T="string" @bind-Value="_nonRefundReason"
                              Placeholder="اكتب سبب عدم الاسترداد..."
                              Variant="Variant.Outlined" Lines="3"
                              Class="form-input" />
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions">
            <MudButton OnClick="@(() => _showNonRefundDialog = false)" Variant="Variant.Text" Class="btn-cancel">
                إلغاء
            </MudButton>
            <MudButton Color="Color.Warning" Variant="Variant.Filled"
                       OnClick="MarkNonRefundable" Disabled="@_isSaving"
                       StartIcon="@Icons.Material.Filled.Block" Class="btn-warning">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                }
                تأكيد
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐ DIALOG: DELETE (Premium)                                                 -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<MudDialog @bind-Visible="_showDeleteDialog" Class="premium-dialog dialog-danger">
    <TitleContent>
        <div class="dialog-header dialog-header-danger">
            <div class="dialog-header-bg"></div>
            <div class="dialog-header-content">
                <div class="dialog-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" />
                </div>
                <span class="dialog-title">تأكيد الحذف</span>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _showDeleteDialog = false)" Class="dialog-close-btn" />
        </div>
    </TitleContent>
    <DialogContent>
        <div class="dialog-body dialog-body-centered">
            <div class="delete-illustration">
                <div class="delete-icon-box">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Large" />
                </div>
            </div>
            <h3 class="delete-title">هل أنت متأكد من الحذف؟</h3>
            <p class="delete-message">
                سيتم حذف رسوم <strong>@FormatMoney(_selectedCharge?.ChargeAmount ?? 0) ج.م</strong>
                لعميل <strong>@(_selectedCharge?.PartyName ?? "-")</strong>
            </p>
            <span class="delete-note">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" />
                سيتم إلغاء حركة الخزينة المرتبطة
            </span>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="dialog-actions dialog-actions-centered">
            <MudButton OnClick="@(() => _showDeleteDialog = false)" Variant="Variant.Text" Class="btn-cancel">
                إلغاء
            </MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       OnClick="DeleteCharge" Disabled="@_isSaving"
                       StartIcon="@Icons.Material.Filled.Delete" Class="btn-danger">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="btn-loader" />
                }
                حذف
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════════ -->
<!-- ⭐⭐⭐ PREMIUM STYLES ⭐⭐⭐                                                                              -->
<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════════ -->
<style>
    /* ═══════════════════════════════════════════════════════════════════════════
       CSS VARIABLES - LIGHT & DARK MODE SUPPORT
       ═══════════════════════════════════════════════════════════════════════════ */
    :root {
        --gold: #D4A853;
        --gold-dark: #B8912A;
        --gold-light: #F0DBA8;
        --gold-bg: #FEFBF3;
        --navy: #1B2A4A;
        --navy-dark: #0F1D36;
        --navy-light: #2D4A7A;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       ANIMATIONS
       ═══════════════════════════════════════════════════════════════════════════ */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(5deg); }
    }
    @@keyframes floatDelayed {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-15px) rotate(-3deg); }
    }
    @@keyframes pulseSlow {
        0%, 100% { opacity: 0.5; transform: scale(1); }
        50% { opacity: 0.3; transform: scale(1.1); }
    }
    @@keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 0 0 rgba(212, 168, 83, 0.4); }
        50% { box-shadow: 0 0 30px 10px rgba(212, 168, 83, 0.15); }
    }
    @@keyframes shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
    @@keyframes bounceSoft {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }
    @@keyframes ping {
        75%, 100% { transform: scale(2); opacity: 0; }
    }
    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.9); }
        to { opacity: 1; transform: scale(1); }
    }
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-card {
        animation: fadeInUp 0.6s ease-out forwards;
        animation-delay: var(--delay, 0s);
        opacity: 0;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       BACKGROUND DECORATIONS
       ═══════════════════════════════════════════════════════════════════════════ */
    .page-bg-decorations {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: 0;
    }
    .bg-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
    }
    .bg-orb-1 {
        width: 400px; height: 400px;
        top: -200px; right: -200px;
        background: radial-gradient(circle, rgba(212,168,83,0.15), transparent 70%);
        animation: float 10s ease-in-out infinite;
    }
    .bg-orb-2 {
        width: 500px; height: 500px;
        bottom: -250px; left: -250px;
        background: radial-gradient(circle, rgba(59,130,246,0.08), transparent 70%);
        animation: floatDelayed 12s ease-in-out infinite;
    }
    .bg-orb-3 {
        width: 600px; height: 600px;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        background: radial-gradient(circle, rgba(139,92,246,0.05), transparent 60%);
        animation: pulseSlow 8s ease-in-out infinite;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       TOP ACCENT BAR
       ═══════════════════════════════════════════════════════════════════════════ */
    .top-accent-bar {
        height: 5px;
        background: linear-gradient(90deg, var(--gold), var(--gold-dark), var(--gold));
        position: relative;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .accent-shimmer {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
        animation: shimmer 3s ease-in-out infinite;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       PREMIUM HEADER
       ═══════════════════════════════════════════════════════════════════════════ */
    .charges-header {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        margin-bottom: 1.5rem;
        min-height: 140px;
    }
    .header-bg {
        position: absolute;
        inset: 0;
    }
    .header-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 40%, var(--navy-light) 100%);
    }
    .header-orbs {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }
    .header-orb {
        position: absolute;
        border-radius: 50%;
    }
    .header-orb.orb-1 {
        width: 350px; height: 350px;
        top: -150px; right: -100px;
        background: radial-gradient(circle, rgba(212,168,83,0.25), transparent 60%);
        animation: float 8s ease-in-out infinite;
    }
    .header-orb.orb-2 {
        width: 250px; height: 250px;
        bottom: -100px; left: 20%;
        background: radial-gradient(circle, rgba(212,168,83,0.15), transparent 60%);
        animation: floatDelayed 10s ease-in-out infinite;
    }
    .header-orb.orb-3 {
        width: 150px; height: 150px;
        top: 30%; left: 10%;
        background: radial-gradient(circle, rgba(255,255,255,0.05), transparent 60%);
        animation: pulseSlow 6s ease-in-out infinite;
    }
    .header-grid {
        position: absolute;
        inset: 0;
        background-image: 
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 40px 40px;
    }
    .header-content {
        position: relative;
        z-index: 2;
        padding: 2rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.5rem;
    }
    .header-info {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }
    .header-icon-wrapper {
        position: relative;
    }
    .header-icon-glow {
        position: absolute;
        inset: -10px;
        background: var(--gold);
        border-radius: 20px;
        filter: blur(20px);
        opacity: 0.3;
        animation: pulseGlow 4s ease-in-out infinite;
    }
    .header-icon {
        position: relative;
        width: 64px; height: 64px;
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold);
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }
    .header-icon::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent 50%);
        pointer-events: none;
    }
    .header-icon-badge {
        position: absolute;
        top: -6px; right: -6px;
        width: 24px; height: 24px;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 4px 12px rgba(212,168,83,0.4);
        animation: bounceSoft 2s ease-in-out infinite;
    }
    .header-icon-badge .mud-icon-root { font-size: 12px !important; }
    .header-icon-badge-secondary {
        position: absolute;
        bottom: -4px; left: -4px;
        width: 20px; height: 20px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 4px 12px rgba(16,185,129,0.4);
        opacity: 0;
        transform: scale(0.8);
        transition: all 0.3s ease;
    }
    .header-icon-wrapper:hover .header-icon-badge-secondary {
        opacity: 1;
        transform: scale(1);
    }
    .header-icon-badge-secondary .mud-icon-root { font-size: 10px !important; }
    .header-text h1 {
        margin: 0;
        font-size: 1.75rem;
        font-weight: 900;
        color: white;
        letter-spacing: -0.5px;
    }
    .header-title-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .premium-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(212,168,83,0.3);
        color: var(--gold);
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.3rem 0.6rem;
        border-radius: 20px;
    }
    .premium-badge .mud-icon-root { font-size: 10px !important; }
    .header-text p {
        margin: 0.5rem 0 0 0;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.6);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .subtitle-icon { color: #10b981 !important; font-size: 16px !important; }
    .btn-add-new {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%) !important;
        color: white !important;
        font-weight: 700 !important;
        padding: 0.875rem 1.75rem !important;
        border-radius: 16px !important;
        box-shadow: 0 8px 25px rgba(212, 168, 83, 0.35) !important;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
    }
    .btn-add-new:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 12px 35px rgba(212, 168, 83, 0.45) !important;
    }
    .btn-add-new:active {
        transform: translateY(0) scale(0.98);
    }
    .btn-shine {
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
        transition: left 0.6s ease;
    }
    .btn-add-new:hover .btn-shine { left: 100%; }

    /* ═══════════════════════════════════════════════════════════════════════════
       PREMIUM STATS GRID
       ═══════════════════════════════════════════════════════════════════════════ */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 1rem;
        margin-bottom: 1.25rem;
    }
    .stat-card {
        position: relative;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        padding: 1.25rem;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
    }
    .stat-card:hover {
        transform: translateY(-8px) scale(1.02);
        border-color: transparent;
    }
    .stat-glow {
        position: absolute;
        inset: -50%;
        opacity: 0;
        transition: opacity 0.5s ease;
        pointer-events: none;
    }
    .stat-card:hover .stat-glow {
        opacity: 1;
    }
    .stat-accent {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        transform: scaleX(0.5);
        transform-origin: center;
        transition: transform 0.5s ease;
    }
    .stat-card:hover .stat-accent {
        transform: scaleX(1);
    }
    .stat-content {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 0.875rem;
    }
    .stat-icon-box {
        position: relative;
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: all 0.4s ease;
    }
    .stat-card:hover .stat-icon-box {
        transform: scale(1.15) rotate(-5deg);
    }
    .stat-icon-ring {
        position: absolute;
        inset: 0;
        border-radius: 14px;
        border: 2px solid transparent;
        transition: all 0.4s ease;
    }
    .stat-card:hover .stat-icon-ring {
        transform: scale(1.3);
        opacity: 0;
    }
    .stat-data { min-width: 0; flex: 1; }
    .stat-value-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .stat-value {
        font-size: 1.2rem;
        font-weight: 900;
        line-height: 1.2;
        transition: color 0.3s ease;
    }
    .stat-trend {
        display: inline-flex;
        align-items: center;
        gap: 0.15rem;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.2rem 0.4rem;
        border-radius: 8px;
    }
    .stat-trend .mud-icon-root { font-size: 10px !important; }
    .stat-trend.trend-up { background: #ecfdf5; color: #059669; }
    .stat-trend.trend-down { background: #fef2f2; color: #dc2626; }
    .stat-label {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        margin-top: 0.2rem;
    }
    .stat-hover-indicator {
        position: absolute;
        bottom: 8px; left: 50%;
        transform: translateX(-50%) translateY(10px);
        width: 30px; height: 4px;
        border-radius: 2px;
        opacity: 0;
        transition: all 0.4s ease;
    }
    .stat-card:hover .stat-hover-indicator {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
    /* Stat card colors */
    .stat-total .stat-glow { background: radial-gradient(circle at center, rgba(212,168,83,0.2), transparent 70%); }
    .stat-total .stat-accent { background: linear-gradient(90deg, var(--gold), var(--gold-dark)); }
    .stat-total .stat-icon-box { background: linear-gradient(135deg, rgba(212,168,83,0.15), rgba(212,168,83,0.05)); color: var(--gold); }
    .stat-total .stat-value { color: var(--gold); }
    .stat-total .stat-icon-ring { border-color: var(--gold); }
    .stat-total .stat-hover-indicator { background: linear-gradient(90deg, var(--gold), var(--gold-dark)); }
    .stat-total:hover { box-shadow: 0 20px 50px -10px rgba(212,168,83,0.3); }

    .stat-collected .stat-glow { background: radial-gradient(circle at center, rgba(16,185,129,0.2), transparent 70%); }
    .stat-collected .stat-accent { background: linear-gradient(90deg, #10b981, #059669); }
    .stat-collected .stat-icon-box { background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(16,185,129,0.05)); color: #10b981; }
    .stat-collected .stat-value { color: #10b981; }
    .stat-collected:hover { box-shadow: 0 20px 50px -10px rgba(16,185,129,0.3); }

    .stat-paid .stat-glow { background: radial-gradient(circle at center, rgba(59,130,246,0.2), transparent 70%); }
    .stat-paid .stat-accent { background: linear-gradient(90deg, #3b82f6, #2563eb); }
    .stat-paid .stat-icon-box { background: linear-gradient(135deg, rgba(59,130,246,0.15), rgba(59,130,246,0.05)); color: #3b82f6; }
    .stat-paid .stat-value { color: #3b82f6; }
    .stat-paid:hover { box-shadow: 0 20px 50px -10px rgba(59,130,246,0.3); }

    .stat-applied .stat-glow { background: radial-gradient(circle at center, rgba(139,92,246,0.2), transparent 70%); }
    .stat-applied .stat-accent { background: linear-gradient(90deg, #8b5cf6, #7c3aed); }
    .stat-applied .stat-icon-box { background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(139,92,246,0.05)); color: #8b5cf6; }
    .stat-applied .stat-value { color: #8b5cf6; }
    .stat-applied:hover { box-shadow: 0 20px 50px -10px rgba(139,92,246,0.3); }

    .stat-nonrefund .stat-glow { background: radial-gradient(circle at center, rgba(239,68,68,0.2), transparent 70%); }
    .stat-nonrefund .stat-accent { background: linear-gradient(90deg, #ef4444, #dc2626); }
    .stat-nonrefund .stat-icon-box { background: linear-gradient(135deg, rgba(239,68,68,0.15), rgba(239,68,68,0.05)); color: #ef4444; }
    .stat-nonrefund .stat-value { color: #ef4444; }
    .stat-nonrefund:hover { box-shadow: 0 20px 50px -10px rgba(239,68,68,0.3); }

    .stat-count .stat-glow { background: radial-gradient(circle at center, rgba(100,116,139,0.2), transparent 70%); }
    .stat-count .stat-accent { background: linear-gradient(90deg, #64748b, #475569); }
    .stat-count .stat-icon-box { background: linear-gradient(135deg, rgba(100,116,139,0.15), rgba(100,116,139,0.05)); color: #64748b; }
    .stat-count .stat-value { color: var(--mud-palette-text-primary); }
    .stat-count:hover { box-shadow: 0 20px 50px -10px rgba(100,116,139,0.3); }

    /* ═══════════════════════════════════════════════════════════════════════════
       QUICK ACTIONS BAR
       ═══════════════════════════════════════════════════════════════════════════ */
    .quick-actions-bar {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }
    .quick-action-btn {
        border-radius: 12px !important;
        border-color: var(--mud-palette-divider) !important;
        transition: all 0.3s ease !important;
    }
    .quick-action-btn:hover {
        border-color: var(--gold) !important;
        color: var(--gold) !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(212,168,83,0.15) !important;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       FILTER BAR
       ═══════════════════════════════════════════════════════════════════════════ */
    .filter-container {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        margin-bottom: 1rem;
        overflow: hidden;
        transition: box-shadow 0.3s ease;
    }
    .filter-container:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }
    .filter-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        cursor: pointer;
        transition: background 0.2s ease;
    }
    .filter-header:hover { background: var(--mud-palette-background-gray); }
    .filter-header-right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .filter-icon-box {
        width: 36px; height: 36px;
        background: var(--mud-palette-background-gray);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--mud-palette-text-secondary);
        transition: all 0.3s ease;
    }
    .filter-header:hover .filter-icon-box {
        background: var(--gold);
        color: white;
    }
    .filter-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
    }
    .filter-active-badge {
        position: relative;
        background: var(--gold);
        color: white;
        font-size: 0.68rem;
        font-weight: 700;
        padding: 0.25rem 0.6rem;
        border-radius: 12px;
        overflow: hidden;
    }
    .badge-pulse {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 100%; height: 100%;
        background: white;
        border-radius: 12px;
        opacity: 0;
        animation: ping 1.5s ease-in-out infinite;
    }
    .filter-header-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-reset-filter {
        font-size: 0.75rem !important;
        border-radius: 8px !important;
    }
    .filter-expand-icon {
        width: 28px; height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--mud-palette-text-secondary);
        transition: transform 0.3s ease;
    }
    .filter-expand-icon.expanded { transform: rotate(180deg); }
    .filter-content {
        padding: 0 1.5rem 1.25rem 1.5rem;
        border-top: 1px solid var(--mud-palette-divider);
        animation: slideUp 0.3s ease-out;
    }
    .filter-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1.5fr;
        gap: 0.875rem;
        padding-top: 1rem;
    }
    .filter-search .mud-input-outlined-border,
    .filter-select .mud-input-outlined-border,
    .filter-date .mud-input-outlined-border {
        border-radius: 12px !important;
    }
    .filter-dates {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .filter-date { flex: 1; }
    .date-separator {
        color: var(--mud-palette-text-disabled);
        font-size: 0.8rem;
    }
    .select-item-content {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .select-item-icon { font-size: 1.1rem; }

    /* ═══════════════════════════════════════════════════════════════════════════
       PREMIUM TABLE
       ═══════════════════════════════════════════════════════════════════════════ */
    .table-container {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        overflow: hidden;
        transition: box-shadow 0.5s ease;
    }
    .table-container:hover {
        box-shadow: 0 10px 40px rgba(0,0,0,0.06);
    }
    .table-header-bar {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--mud-palette-divider);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(90deg, var(--mud-palette-background-gray), var(--mud-palette-surface));
    }
    .table-header-right {
        display: flex;
        align-items: center;
        gap: 0.625rem;
    }
    .table-dot-wrapper {
        position: relative;
        width: 12px; height: 12px;
    }
    .table-dot {
        position: absolute;
        inset: 2px;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        border-radius: 50%;
    }
    .table-dot-ping {
        position: absolute;
        inset: 0;
        background: var(--gold);
        border-radius: 50%;
        animation: ping 2s ease-in-out infinite;
    }
    .table-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
    }
    .table-count {
        font-size: 0.72rem;
        color: var(--mud-palette-text-secondary);
        background: var(--mud-palette-background-gray);
        padding: 0.25rem 0.6rem;
        border-radius: 12px;
        font-weight: 600;
    }
    .table-selection-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.8rem;
        color: var(--mud-palette-text-secondary);
        animation: fadeInUp 0.3s ease-out;
    }
    .charges-table .mud-table-head th {
        background: var(--mud-palette-background-gray) !important;
        font-size: 0.78rem !important;
        font-weight: 700 !important;
        color: var(--mud-palette-text-secondary) !important;
        padding: 0.875rem 1rem !important;
    }
    .charges-table .mud-table-body tr {
        transition: all 0.3s ease;
    }
    .charges-table .mud-table-body tr:hover {
        background: var(--gold-bg) !important;
    }
    .charges-table .mud-table-body tr.row-selected {
        background: rgba(59,130,246,0.08) !important;
    }
    .charges-table .mud-table-body td {
        padding: 1rem !important;
        vertical-align: middle !important;
    }
    /* Customer Cell */
    .customer-cell {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .customer-avatar-wrapper {
        position: relative;
    }
    .customer-avatar {
        width: 42px; height: 42px;
        background: linear-gradient(135deg, var(--gold), var(--gold-dark));
        color: white;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.8rem;
        box-shadow: 0 4px 15px rgba(212, 168, 83, 0.3);
        transition: all 0.3s ease;
    }
    tr:hover .customer-avatar {
        transform: scale(1.1) rotate(3deg);
    }
    .customer-online-dot {
        position: absolute;
        bottom: -2px; right: -2px;
        width: 12px; height: 12px;
        background: #10b981;
        border: 2px solid var(--mud-palette-surface);
        border-radius: 50%;
    }
    .customer-name {
        font-weight: 700;
        font-size: 0.88rem;
        color: var(--mud-palette-text-primary);
        white-space: nowrap;
        transition: color 0.3s ease;
    }
    tr:hover .customer-name { color: var(--gold-dark); }
    .customer-phone {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.72rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 0.2rem;
    }
    .customer-phone .mud-icon-root { font-size: 12px !important; }
    /* Charge Type Cell */
    .charge-type-cell {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .type-icon { font-size: 1.15rem; }
    .type-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.35rem 0.7rem;
        border-radius: 10px;
        font-size: 0.75rem;
        font-weight: 700;
        border: 1px solid;
        transition: all 0.3s ease;
    }
    tr:hover .type-badge {
        transform: scale(1.05);
    }
    .type-inspection { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
    tr:hover .type-inspection { box-shadow: 0 4px 15px rgba(29,78,216,0.2); }
    .type-shipping { background: #fffbeb; color: #b45309; border-color: #fde68a; }
    tr:hover .type-shipping { box-shadow: 0 4px 15px rgba(180,83,9,0.2); }
    .type-installation { background: #ecfdf5; color: #047857; border-color: #a7f3d0; }
    tr:hover .type-installation { box-shadow: 0 4px 15px rgba(4,120,87,0.2); }
    .type-other { background: #faf5ff; color: #7c3aed; border-color: #ddd6fe; }
    tr:hover .type-other { box-shadow: 0 4px 15px rgba(124,58,237,0.2); }
    /* Description */
    .desc-text {
        font-size: 0.85rem;
        color: var(--mud-palette-text-secondary);
        max-width: 180px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    /* Amount Cell */
    .amount-cell {
        display: flex;
        align-items: baseline;
        gap: 0.3rem;
    }
    .amount-value {
        font-size: 0.95rem;
        font-weight: 900;
        color: var(--gold-dark);
    }
    .amount-currency {
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--mud-palette-text-disabled);
        background: var(--mud-palette-background-gray);
        padding: 0.15rem 0.35rem;
        border-radius: 4px;
    }
    /* Status Pill */
    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        border: 1px solid;
        transition: all 0.3s ease;
    }
    .status-dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        animation: pulseSlow 2s ease-in-out infinite;
    }
    .status-paid { background: #ecfdf5; color: #047857; border-color: #a7f3d0; }
    .status-paid .status-dot { background: #10b981; }
    .status-applied { background: #ecfeff; color: #0e7490; border-color: #a5f3fc; }
    .status-applied .status-dot { background: #06b6d4; }
    .status-nonrefundable { background: #fef2f2; color: #b91c1c; border-color: #fecaca; }
    .status-nonrefundable .status-dot { background: #ef4444; }
    /* Invoice Ref */
    .invoice-ref {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.7rem;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 700;
        border: 1px solid;
    }
    .invoice-ref .mud-icon-root { font-size: 14px !important; }
    .ref-applied { background: #ecfdf5; color: #047857; border-color: #a7f3d0; }
    .ref-linked { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
    .invoice-empty { color: var(--mud-palette-text-disabled); }
    /* Date Cell */
    .date-cell {
        display: flex;
        flex-direction: column;
    }
    .date-main {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
    }
    .date-time {
        font-size: 0.68rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 0.1rem;
    }
    /* Row Menu */
    .row-menu .mud-icon-button {
        opacity: 0.4;
        transition: all 0.3s ease !important;
    }
    tr:hover .row-menu .mud-icon-button {
        opacity: 1;
    }
    .menu-item-apply { color: #10b981 !important; }
    .menu-item-warning { color: #f59e0b !important; }
    .menu-item-danger { color: #ef4444 !important; }
    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 4rem 1.5rem;
    }
    .empty-illustration {
        position: relative;
        width: 120px; height: 120px;
        margin: 0 auto 1.5rem auto;
    }
    .empty-icon-box {
        position: absolute;
        inset: 10px;
        background: linear-gradient(135deg, var(--mud-palette-background-gray), var(--mud-palette-surface));
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--mud-palette-text-disabled);
        z-index: 2;
    }
    .empty-particles {
        position: absolute;
        inset: 0;
    }
    .particle {
        position: absolute;
        border-radius: 50%;
        animation: bounceSoft 2s ease-in-out infinite;
    }
    .particle-1 {
        width: 16px; height: 16px;
        top: -5px; right: -5px;
        background: var(--gold);
        animation-delay: 0s;
    }
    .particle-2 {
        width: 12px; height: 12px;
        bottom: 0; left: -5px;
        background: #3b82f6;
        animation-delay: 0.3s;
    }
    .particle-3 {
        width: 10px; height: 10px;
        top: 50%; right: -10px;
        background: #10b981;
        animation-delay: 0.6s;
    }
    .empty-state h3 {
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--mud-palette-text-primary);
        margin: 0 0 0.5rem 0;
    }
    .empty-state p {
        font-size: 0.9rem;
        color: var(--mud-palette-text-secondary);
        margin: 0 0 1.75rem 0;
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
    }
    .empty-btn {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark)) !important;
        color: white !important;
        border-radius: 14px !important;
        padding: 0.875rem 1.75rem !important;
        font-weight: 700 !important;
        box-shadow: 0 8px 25px rgba(212,168,83,0.3) !important;
    }
    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        padding: 4rem;
        color: var(--mud-palette-text-secondary);
    }
    .loading-spinner {
        animation: rotate 1.5s linear infinite;
    }

    /* ═══════════════════════════════════════════════════════════════════════════
       PAGINATION
       ═══════════════════════════════════════════════════════════════════════════ */
    .pagination-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1.25rem;
        padding: 0 0.5rem;
    }
    .pagination-info {
        font-size: 0.78rem;
        color: var(--mud-palette-text-secondary);
    }
    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }
    .pagination-btn {
        min-width: 36px !important;
        height: 36px !important;
        border-radius: 10px !important;
        transition: all 0.3s ease !important;
    }
    .pagination-btn.active {
        background: linear-gradient(135deg, var(--gold), var(--gold-dark)) !important;
