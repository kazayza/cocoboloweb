@code {
    private bool _isLoading = true;
    private bool _isReloading = false;
    private IncomeStatementDto? _report;
    private IncomeStatementFilterDto _filter = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frmIncomeStatement:View")
                   || user.HasClaim("Permission", "frmCashBoxDashboard:View")
                   || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        await SetPeriod("Month");
        _isLoading = false;
    }

    private async Task LoadReport()
    {
        _isReloading = true;
        try
        {
            _report = await FinancialService.GetIncomeStatementAsync(_filter);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isReloading = false;
            StateHasChanged();
        }
    }

    private async Task SetPeriod(string period)
    {
        _filter.PeriodType = period;
        var today = DateTime.Today;

        switch (period)
        {
            case "Today":
                _filter.FromDate = today; _filter.ToDate = today; break;
            case "Week":
                _filter.FromDate = today.AddDays(-(int)today.DayOfWeek); _filter.ToDate = today; break;
            case "Month":
                _filter.FromDate = new DateTime(today.Year, today.Month, 1); _filter.ToDate = today; break;
            case "Quarter":
                var qStart = new DateTime(today.Year, ((today.Month - 1) / 3) * 3 + 1, 1);
                _filter.FromDate = qStart; _filter.ToDate = today; break;
            case "Year":
                _filter.FromDate = new DateTime(today.Year, 1, 1); _filter.ToDate = today; break;
        }

        await LoadReport();
    }

    private async Task Print() => await JS.InvokeVoidAsync("window.print");

    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);

    private string GetTargetStatusClass()
    {
        if (_report?.ProfitTarget.Status.Contains("متجاوز") == true) return "success";
        if (_report?.ProfitTarget.Status.Contains("محقق") == true) return "success";
        if (_report?.ProfitTarget.Status.Contains("قريب") == true) return "warning";
        return "danger";
    }

    private string GetBreakEvenStatusClass()
    {
        if (_report?.BreakEvenAnalysis.Status.Contains("آمن") == true) return "success";
        if (_report?.BreakEvenAnalysis.Status == "حرج") return "warning";
        return "danger";
    }

    private string GetProgressColor(decimal pct)
    {
        if (pct >= 100) return "linear-gradient(90deg, #10b981, #059669)";
        if (pct >= 70) return "linear-gradient(90deg, #3b82f6, #1d4ed8)";
        if (pct >= 40) return "linear-gradient(90deg, #f59e0b, #d97706)";
        return "linear-gradient(90deg, #ef4444, #dc2626)";
    }

    private string GetChangeClass(decimal change) =>
        change > 0 ? "pos" : change < 0 ? "neg" : "neutral";
}
