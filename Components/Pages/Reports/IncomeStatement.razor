@page "/reports/income-statement"
@page "/financial/income-statement"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IFinancialReportsService FinancialService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS

@if (_isLoading)
{
    <div class="loading-screen">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        <p>جاري تحليل البيانات المالية...</p>
    </div>
}
else if (_report != null)
{
    <div class="income-page" dir="rtl">

        <!-- Background Decorations -->
        <div class="bg-decorations no-print">
            <div class="bg-orb bg-orb-1"></div>
            <div class="bg-orb bg-orb-2"></div>
        </div>

        <!-- ⭐ HEADER -->
        <div class="income-header">
            <div class="header-bg">
                <div class="header-gradient"></div>
                <div class="header-orbs">
                    <div class="header-orb orb-1"></div>
                    <div class="header-orb orb-2"></div>
                </div>
            </div>
            <div class="header-content">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Analytics" />
                        </div>
                    </div>
                    <div>
                        <h1>قائمة الدخل + التحليل المالي</h1>
                        <p>
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Style="vertical-align:middle;" />
                            <strong>@_report.PeriodLabel</strong>
                        </p>
                    </div>
                </div>
                <div class="header-actions no-print">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Print"
                               OnClick="Print">
                        طباعة
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                               StartIcon="@Icons.Material.Filled.Dashboard"
                               OnClick="@(() => Navigation.NavigateTo("/cashbox/dashboard"))">
                        العودة
                    </MudButton>
                </div>
            </div>
        </div>

        <!-- ⭐ FILTERS -->
        <div class="filters-bar no-print">
            <span class="filter-label">📅 الفترة:</span>
            @foreach (var period in IncomePeriodTypes.All.Where(p => p.Key != "Custom"))
            {
                <button class="period-btn @(_filter.PeriodType == period.Key ? "active" : "")"
                        @onclick="@(() => SetPeriod(period.Key))">
                    @period.Value
                </button>
            }

            <div class="custom-period">
                <MudDatePicker Date="_filter.FromDate"
                               DateChanged="@(d => { _filter.FromDate = d ?? _filter.FromDate; _filter.PeriodType = "Custom"; _ = LoadReport(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Label="من" Class="date-pick" />
                <MudDatePicker Date="_filter.ToDate"
                               DateChanged="@(d => { _filter.ToDate = d ?? _filter.ToDate; _filter.PeriodType = "Custom"; _ = LoadReport(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Label="إلى" Class="date-pick" />
            </div>
        </div>

        @if (_isReloading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
        }

        <!-- ⭐ HERO STATS - الأرقام الرئيسية -->
        <div class="hero-stats">
            <!-- الإيرادات -->
            <div class="hero-card revenue">
                <div class="hero-icon"><MudIcon Icon="@Icons.Material.Filled.TrendingUp" /></div>
                <div class="hero-info">
                    <span class="hero-label">إجمالي الإيرادات</span>
                    <span class="hero-value">@FormatMoney(_report.NetRevenue)</span>
                    <span class="hero-meta">@_report.InvoicesCount فاتورة • متوسط: @FormatMoney(_report.AverageInvoiceValue) ج</span>
                </div>
            </div>

            <!-- COGS -->
            <div class="hero-card cogs">
                <div class="hero-icon"><MudIcon Icon="@Icons.Material.Filled.LocalShipping" /></div>
                <div class="hero-info">
                    <span class="hero-label">تكلفة المبيعات</span>
                    <span class="hero-value">-@FormatMoney(_report.CostOfGoodsSold)</span>
                    <span class="hero-meta">سعر الشراء للأصناف المباعة</span>
                </div>
            </div>

            <!-- Gross Profit -->
            <div class="hero-card gross">
                <div class="hero-icon"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
                <div class="hero-info">
                    <span class="hero-label">الربح الإجمالي</span>
                    <span class="hero-value">@FormatMoney(_report.GrossProfit)</span>
                    <span class="hero-meta">هامش: @_report.GrossProfitMargin%</span>
                </div>
            </div>

            <!-- Operating Expenses -->
            <div class="hero-card expenses">
                <div class="hero-icon"><MudIcon Icon="@Icons.Material.Filled.MoneyOff" /></div>
                <div class="hero-info">
                    <span class="hero-label">المصروفات التشغيلية</span>
                    <span class="hero-value">-@FormatMoney(_report.TotalOperatingExpenses)</span>
                    <span class="hero-meta">@_report.ExpensesByGroup.Count مجموعة</span>
                </div>
            </div>

            <!-- ⭐ NET PROFIT - الأهم -->
            <div class="hero-card net @(_report.NetProfit >= 0 ? "profit" : "loss")">
                <div class="hero-icon">
                    <MudIcon Icon="@(_report.NetProfit >= 0 ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Warning)" />
                </div>
                <div class="hero-info">
                    <span class="hero-label">⭐ صافي الربح</span>
                    <span class="hero-value-big">@FormatMoney(_report.NetProfit)</span>
                    <span class="hero-margin">@_report.NetProfitMargin% هامش • @_report.ProfitStatus</span>
                </div>
            </div>
        </div>

        <!-- ⭐ TARGET + BREAK-EVEN -->
        <div class="analysis-grid">
            <!-- Profit Target -->
            <div class="analysis-card target-card">
                <div class="card-header">
                    <h3>
                        <span class="card-icon">@_report.ProfitTarget.Icon</span>
                        الهدف الذكي للربح
                    </h3>
                    <span class="status-badge @GetTargetStatusClass()">@_report.ProfitTarget.Status</span>
                </div>
                <div class="card-body">
                    <div class="target-progress">
                        <div class="target-info">
                            <div>
                                <span class="t-label">الهدف الحالي</span>
                                <span class="t-value">@_report.ProfitTarget.CurrentTargetPercentage%</span>
                            </div>
                            <div>
                                <span class="t-label">المحقق</span>
                                <span class="t-value @(_report.NetProfitMargin >= _report.ProfitTarget.CurrentTargetPercentage ? "achieved" : "")">
                                    @_report.ProfitTarget.CurrentMargin.ToString("N1")%
                                </span>
                            </div>
                            <div>
                                <span class="t-label">الهدف القادم</span>
                                <span class="t-value next">@_report.ProfitTarget.NextTargetPercentage%</span>
                            </div>
                        </div>

                        <!-- Progress Bar -->
                        <div class="progress-container">
                            <div class="progress-bar" style="width:@(Math.Min(100, _report.ProfitTarget.AchievementPercentage))%;
                                background: @(GetProgressColor(_report.ProfitTarget.AchievementPercentage));"></div>
                            <div class="progress-marker" style="right: @(_report.ProfitTarget.AchievementPercentage)%;">
                                @_report.ProfitTarget.AchievementPercentage%
                            </div>
                        </div>

                        <p class="target-message">@_report.ProfitTarget.Message</p>

                        @if (_report.ProfitTarget.GapToNextTarget > 0)
                        {
                            <div class="next-target-tips">
                                <strong>للوصول لـ @_report.ProfitTarget.NextTargetPercentage%:</strong>
                                <div class="tip-row">
                                    <span>📈 زيادة الإيرادات بـ:</span>
                                    <strong>@FormatMoney(_report.ProfitTarget.RevenueIncreaseNeeded) ج</strong>
                                </div>
                                <div class="tip-row">
                                    <span>📉 أو تقليل المصروفات بـ:</span>
                                    <strong>@FormatMoney(_report.ProfitTarget.ExpensesReductionNeeded) ج</strong>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Break Even -->
            <div class="analysis-card breakeven-card">
                <div class="card-header">
                    <h3>
                        <span class="card-icon">@_report.BreakEvenAnalysis.StatusIcon</span>
                        نقطة التعادل
                    </h3>
                    <span class="status-badge @GetBreakEvenStatusClass()">@_report.BreakEvenAnalysis.Status</span>
                </div>
                <div class="card-body">
                    <div class="be-rows">
                        <div class="be-row">
                            <span>المصروفات الثابتة:</span>
                            <strong>@FormatMoney(_report.BreakEvenAnalysis.FixedExpenses) ج</strong>
                        </div>
                        <div class="be-row">
                            <span>هامش الربح الإجمالي:</span>
                            <strong>@_report.BreakEvenAnalysis.GrossProfitMargin%</strong>
                        </div>
                        <div class="be-row highlight">
                            <span>🎯 نقطة التعادل:</span>
                            <strong class="be-value">@FormatMoney(_report.BreakEvenAnalysis.BreakEvenRevenue) ج</strong>
                        </div>
                        <div class="be-row">
                            <span>الإيراد الفعلي:</span>
                            <strong>@FormatMoney(_report.BreakEvenAnalysis.CurrentRevenue) ج</strong>
                        </div>
                        <div class="be-row @(_report.BreakEvenAnalysis.AboveBreakEven ? "positive" : "negative")">
                            <span>الفرق:</span>
                            <strong>
                                @(_report.BreakEvenAnalysis.RevenueGap >= 0 ? "+" : "")@FormatMoney(_report.BreakEvenAnalysis.RevenueGap) ج
                            </strong>
                        </div>
                        @if (_report.BreakEvenAnalysis.AboveBreakEven)
                        {
                            <div class="be-row positive">
                                <span>هامش الأمان:</span>
                                <strong>+@_report.BreakEvenAnalysis.SafetyMargin%</strong>
                            </div>
                        }
                    </div>
                    <p class="be-description">@_report.BreakEvenAnalysis.Description</p>
                </div>
            </div>
        </div>

        <!-- ⭐ SMART RECOMMENDATIONS -->
        @if (_report.Recommendations.Any())
        {
            <div class="recommendations-section">
                <h3 class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" />
                    التوصيات الذكية (@_report.Recommendations.Count)
                </h3>
                <div class="recommendations-grid">
                    @foreach (var rec in _report.Recommendations)
                    {
                        <div class="rec-card" style="border-right-color: @rec.Color;">
                            <div class="rec-icon" style="background: @(rec.Color)22; color: @rec.Color;">
                                <span>@rec.Icon</span>
                            </div>
                            <div class="rec-body">
                                <h4 style="color: @rec.Color;">@rec.Title</h4>
                                <p>@rec.Description</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ⭐ INCOME STATEMENT TABLE -->
        <div class="statement-card">
            <h3 class="section-title">
                <MudIcon Icon="@Icons.Material.Filled.TableChart" />
                قائمة الدخل التفصيلية
            </h3>

            <table class="income-table">
                <tbody>
                    <!-- الإيرادات -->
                    <tr class="section-header-row">
                        <td colspan="2">📥 الإيرادات</td>
                    </tr>
                    <tr>
                        <td>إجمالي المبيعات</td>
                        <td class="num">@FormatMoney(_report.TotalRevenue) ج</td>
                    </tr>
                    <tr class="subtotal">
                        <td><strong>صافي الإيرادات</strong></td>
                        <td class="num"><strong>@FormatMoney(_report.NetRevenue) ج</strong></td>
                    </tr>

                    <!-- COGS -->
                    <tr class="section-header-row">
                        <td colspan="2">📦 تكلفة المبيعات</td>
                    </tr>
                    <tr>
                        <td>تكلفة الأصناف المباعة</td>
                        <td class="num negative">-@FormatMoney(_report.CostOfGoodsSold) ج</td>
                    </tr>

                    <!-- Gross Profit -->
                    <tr class="gross-profit-row">
                        <td><strong>= الربح الإجمالي (@_report.GrossProfitMargin%)</strong></td>
                        <td class="num"><strong>@FormatMoney(_report.GrossProfit) ج</strong></td>
                    </tr>

                    <!-- Operating Expenses by Group -->
                    <tr class="section-header-row">
                        <td colspan="2">💸 المصروفات التشغيلية</td>
                    </tr>
                    @foreach (var grp in _report.ExpensesByGroup)
                    {
                        <tr>
                            <td>
                                <span class="grp-color" style="background: @grp.Color;"></span>
                                @grp.GroupName
                                <small>(@grp.Percentage%)</small>
                            </td>
                            <td class="num negative">-@FormatMoney(grp.Amount) ج</td>
                        </tr>
                    }
                    <tr class="subtotal">
                        <td><strong>إجمالي المصروفات التشغيلية</strong></td>
                        <td class="num"><strong>-@FormatMoney(_report.TotalOperatingExpenses) ج</strong></td>
                    </tr>

                    <!-- Net Profit -->
                    <tr class="net-profit-row @(_report.NetProfit >= 0 ? "profit" : "loss")">
                        <td>
                            <strong>@(_report.NetProfit >= 0 ? "🌟 صافي الربح" : "🔴 صافي الخسارة") (@_report.NetProfitMargin%)</strong>
                        </td>
                        <td class="num"><strong>@FormatMoney(_report.NetProfit) ج</strong></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- ⭐ COMPARISONS -->
        @if (_report.PreviousPeriod != null || _report.PreviousYear != null)
        {
            <div class="comparisons-section">
                <h3 class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.CompareArrows" />
                    مقارنات
                </h3>
                <div class="comp-grid">
                    @if (_report.PreviousPeriod != null)
                    {
                        @RenderComparison(_report.PreviousPeriod)
                    }
                    @if (_report.PreviousYear != null)
                    {
                        @RenderComparison(_report.PreviousYear)
                    }
                </div>
            </div>
        }

        <!-- ⭐ MONTHLY TREND CHART -->
        @if (_report.MonthlyTrend.Any())
        {
            <div class="trend-card">
                <h3 class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" />
                    ترند آخر 12 شهر
                </h3>
                <div class="trend-chart-wrap">
                    <svg viewBox="0 0 1000 300" class="trend-chart" preserveAspectRatio="xMidYMid meet">
                        @{
                            var maxRev = _report.MonthlyTrend.Max(m => Math.Max(m.Revenue, m.Expenses));
                            if (maxRev == 0) maxRev = 1;
                            var barWidth = 1000.0 / _report.MonthlyTrend.Count / 3.5;
                            var gap = 1000.0 / _report.MonthlyTrend.Count;
                        }
                        <!-- Grid -->
                        @for (int i = 0; i <= 4; i++)
                        {
                            var y = 30 + (200 * i / 4.0);
                            <line x1="0" y1="@y" x2="1000" y2="@y" stroke="#e5e7eb" stroke-width="1" stroke-dasharray="3,3" />
                        }

                        @for (int i = 0; i < _report.MonthlyTrend.Count; i++)
                        {
                            var m = _report.MonthlyTrend[i];
                            var x = i * gap + gap / 5;
                            var revH = (double)m.Revenue / (double)maxRev * 200;
                            var expH = (double)m.Expenses / (double)maxRev * 200;
                            var profitH = Math.Abs((double)m.NetProfit) / (double)maxRev * 200;

                            <!-- Revenue -->
                            <rect x="@(x.ToString("F1", CultureInfo.InvariantCulture))" 
                                  y="@((230 - revH).ToString("F1", CultureInfo.InvariantCulture))" 
                                  width="@(barWidth.ToString("F1", CultureInfo.InvariantCulture))" 
                                  height="@(revH.ToString("F1", CultureInfo.InvariantCulture))" 
                                  fill="#10b981" rx="2">
                                <title>@m.MonthLabel - إيرادات: @FormatMoney(m.Revenue)</title>
                            </rect>
                            <!-- Expenses -->
                            <rect x="@((x + barWidth + 1).ToString("F1", CultureInfo.InvariantCulture))" 
                                  y="@((230 - expH).ToString("F1", CultureInfo.InvariantCulture))" 
                                  width="@(barWidth.ToString("F1", CultureInfo.InvariantCulture))" 
                                  height="@(expH.ToString("F1", CultureInfo.InvariantCulture))" 
                                  fill="#ef4444" rx="2">
                                <title>@m.MonthLabel - مصروفات: @FormatMoney(m.Expenses)</title>
                            </rect>
                            <!-- Profit -->
                            <rect x="@((x + 2*barWidth + 2).ToString("F1", CultureInfo.InvariantCulture))" 
                                  y="@((230 - profitH).ToString("F1", CultureInfo.InvariantCulture))" 
                                  width="@(barWidth.ToString("F1", CultureInfo.InvariantCulture))" 
                                  height="@(profitH.ToString("F1", CultureInfo.InvariantCulture))" 
                                  fill="@(m.NetProfit >= 0 ? "#3b82f6" : "#dc2626")" rx="2">
                                <title>@m.MonthLabel - ربح: @FormatMoney(m.NetProfit)</title>
                            </rect>

                            <!-- Month label -->
                            <svg:text x="@((x + barWidth * 1.5).ToString("F1", CultureInfo.InvariantCulture))" 
          y="255" 
          text-anchor="middle" font-size="10" fill="#6b7280">
    @m.Month.ToString("MM/yy")
</svg:text>
                        }
                        <line x1="0" y1="230" x2="1000" y2="230" stroke="#374151" stroke-width="1.5" />
                    </svg>
                </div>
                <div class="chart-legend">
                    <span><span class="dot" style="background:#10b981;"></span> إيرادات</span>
                    <span><span class="dot" style="background:#ef4444;"></span> مصروفات</span>
                    <span><span class="dot" style="background:#3b82f6;"></span> صافي ربح</span>
                </div>
            </div>
        }

        <!-- ⭐ TOP EXPENSES -->
        @if (_report.TopExpenses.Any())
        {
            <div class="top-expenses-card">
                <h3 class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" />
                    أعلى 10 مصروفات
                </h3>
                <table class="top-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>المصروف</th>
                            <th>المجموعة</th>
                            <th>التاريخ</th>
                            <th>المبلغ</th>
                            <th>%</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var exp in _report.TopExpenses)
                        {
                            <tr>
                                <td><span class="rank-badge">@rank</span></td>
                                <td><strong>@exp.ExpenseName</strong></td>
                                <td>@(exp.GroupName ?? "-")</td>
                                <td>@exp.Date.ToString("yyyy/MM/dd")</td>
                                <td class="num"><strong>@FormatMoney(exp.Amount) ج</strong></td>
                                <td><span class="pct-pill">@exp.PercentageOfTotal%</span></td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Print Footer -->
        <div class="print-footer print-only">
            <p>تم إصدار هذا التقرير في @DateTime.Now.ToString("yyyy/MM/dd HH:mm") • COCOBOLO ERP</p>
        </div>
    </div>
}

@* Render comparison helper *@
@code {
    private RenderFragment RenderComparison(IncomeComparisonDto comp) => __builder =>
    {
        var trendIcon = comp.NetProfitChange > 5 ? "📈" : comp.NetProfitChange < -5 ? "📉" : "➡️";
        var trendColor = comp.NetProfitChange > 5 ? "#10b981" : comp.NetProfitChange < -5 ? "#ef4444" : "#94a3b8";

        <div class="comp-card">
            <div class="comp-header">
                <span>@comp.Label</span>
                <span class="comp-trend" style="color: @trendColor;">@trendIcon @comp.Trend</span>
            </div>
            <div class="comp-rows">
                <div class="cr">
                    <span>الإيرادات</span>
                    <div class="cr-vals">
                        <strong>@FormatMoney(comp.Revenue) ج</strong>
                        <span class="@GetChangeClass(comp.RevenueChange)">
                            @(comp.RevenueChange >= 0 ? "+" : "")@comp.RevenueChange.ToString("N1")%
                        </span>
                    </div>
                </div>
                <div class="cr">
                    <span>المصروفات</span>
                    <div class="cr-vals">
                        <strong>@FormatMoney(comp.Expenses) ج</strong>
                        <span class="@GetChangeClass(-comp.ExpensesChange)">
                            @(comp.ExpensesChange >= 0 ? "+" : "")@comp.ExpensesChange.ToString("N1")%
                        </span>
                    </div>
                </div>
                <div class="cr highlight">
                    <span>صافي الربح</span>
                    <div class="cr-vals">
                        <strong>@FormatMoney(comp.NetProfit) ج</strong>
                        <span class="@GetChangeClass(comp.NetProfitChange)">
                            @(comp.NetProfitChange >= 0 ? "+" : "")@comp.NetProfitChange.ToString("N1")%
                        </span>
                    </div>
                </div>
            </div>
        </div>
    };
}

<style>
    .income-page {
        max-width: 1800px;
        margin: 0 auto;
        padding: 0 1.25rem 2rem;
        position: relative;
        direction: rtl;
    }

    .loading-screen {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        min-height: 60vh;
    }

    .bg-decorations { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
    .bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); }
    .bg-orb-1 { width: 450px; height: 450px; top: -200px; right: -150px;
                background: radial-gradient(circle, rgba(59,130,246,0.1), transparent 70%); }
    .bg-orb-2 { width: 400px; height: 400px; bottom: -180px; left: -120px;
                background: radial-gradient(circle, rgba(16,185,129,0.08), transparent 70%); }

    /* ═══════ HEADER ═══════ */
    .income-header {
        position: relative;
        border-radius: 24px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .header-bg { position: absolute; inset: 0; }
    .header-gradient {
        position: absolute; inset: 0;
        background: linear-gradient(135deg, #0F1D36 0%, #1B2A4A 50%, #2D4A7A 100%);
    }
    .header-orbs { position: absolute; inset: 0; overflow: hidden; }
    .header-orb { position: absolute; border-radius: 50%; }
    .orb-1 { width: 380px; height: 380px; top: -160px; right: -100px;
             background: radial-gradient(circle, rgba(212,168,83,0.3), transparent 60%); }
    .orb-2 { width: 280px; height: 280px; bottom: -100px; left: 30%;
             background: radial-gradient(circle, rgba(59,130,246,0.2), transparent 60%); }

    .header-content {
        position: relative; z-index: 1;
        padding: 2rem;
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 1.5rem;
    }
    .header-info { display: flex; align-items: center; gap: 1.25rem; }
    .header-icon-wrapper { position: relative; }
    .header-icon {
        background: rgba(255,255,255,0.15); backdrop-filter: blur(20px);
        border-radius: 16px; width: 64px; height: 64px;
        display: flex; align-items: center; justify-content: center;
        color: white; border: 1px solid rgba(255,255,255,0.3);
    }
    .header-icon ::deep .mud-icon-root { font-size: 32px !important; color: white !important; }
    .header-info h1 { color: white; font-size: 1.75rem; font-weight: 800; margin: 0; }
    .header-info p { color: rgba(255,255,255,0.85); margin: 0.4rem 0 0; }
    .header-actions { display: flex; gap: 0.5rem; }

