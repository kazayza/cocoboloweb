@page "/reports/financial-dashboard"
@page "/financial/dashboard"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using ApexCharts
@using System.Globalization
@using Microsoft.AspNetCore.Authorization

@inject IFinancialDashboardService DashboardService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject ILogger<FinancialDashboard> Logger

@attribute [Authorize]

<PageTitle>لوحة القيادة المالية</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="MudBlazor.Color.Secondary" Size="MudBlazor.Size.Large" Indeterminate="true" />
            </div>
            <MudText Typo="Typo.h6" Class="loading-text">جاري إعداد لوحة القيادة المالية...</MudText>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else if (_dashboard != null)
{
<div dir="rtl" class="fd-page">

    <!-- ⭐ BG DECORATIONS -->
    <div class="page-bg-decorations">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>

    <!-- ⭐ TOP ACCENT -->
    <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

    <!-- ═════════════ HERO HEADER ═════════════ -->
    <div class="fd-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-orbs">
                <div class="header-orb orb-1"></div>
                <div class="header-orb orb-2"></div>
                <div class="header-orb orb-3"></div>
            </div>
            <div class="header-grid"></div>
        </div>

        <div class="header-content">
            <div class="header-top">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Insights" Size="MudBlazor.Size.Large" />
                        </div>
                        <div class="header-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" />
                        </div>
                    </div>
                    <div class="header-text">
                        <div class="header-title-row">
                            <MudText Typo="Typo.h4" Class="header-title">لوحة القيادة المالية</MudText>
                            <div class="header-badge">@_dashboard.PeriodLabel</div>
                        </div>
                        <MudText Typo="Typo.body2" Class="header-subtitle">
                            تحليل شامل للأداء المالي للمؤسسة مع توصيات استراتيجية
                        </MudText>
                    </div>
                </div>

                <div class="header-actions">
                    <MudDatePicker @bind-Date="_fromDate"
                                   @bind-Date:after="LoadDashboardAsync"
                                   Label="من"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="header-input" />
                    <MudDatePicker @bind-Date="_toDate"
                                   @bind-Date:after="LoadDashboardAsync"
                                   Label="إلى"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="header-input" />
                    <MudButton Variant="Variant.Outlined"
                               Class="btn-refresh"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="LoadDashboardAsync"
                               Disabled="_isRefreshing">
                        تحديث
                    </MudButton>
                </div>
            </div>
        </div>
    </div>

    <!-- ═════════════ KPIs CARDS ═════════════ -->
    @if (_dashboard.MainKpis?.Any() == true)
    {
        <div class="kpis-grid">
            @{ int kpiIdx = 0; }
            @foreach (var kpi in _dashboard.MainKpis)
            {
                kpiIdx++;
                <div class="kpi-card animate-card" style="--delay: @(0.05 * kpiIdx)s; border-top-color: @kpi.Color;">
                    <div class="kpi-glow" style="background: radial-gradient(circle, @(kpi.Color)33, transparent);"></div>
                    <div class="kpi-header">
                        <div class="kpi-icon" style="background: @(kpi.Color)22; color: @kpi.Color;">
                            <MudIcon Icon="@GetIcon(kpi.Icon)" />
                        </div>
                        @if (kpi.ChangePercentage.HasValue)
                        {
                            <span class="kpi-change @GetChangeClass(kpi.ChangePercentage.Value)">
                                @kpi.TrendIcon @(kpi.ChangePercentage >= 0 ? "+" : "")@kpi.ChangePercentage.Value.ToString("N1")%
                            </span>
                        }
                    </div>
                    <div class="kpi-body">
                        <span class="kpi-title">@kpi.Title</span>
                        <span class="kpi-value" style="color: @kpi.Color;">@kpi.FormattedValue</span>
                        <span class="kpi-subtitle">@kpi.Subtitle</span>
                        @if (!string.IsNullOrEmpty(kpi.ChangeLabel))
                        {
                            <small class="kpi-change-label">@kpi.ChangeLabel</small>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(kpi.Url))
                    {
                        <button class="kpi-link" @onclick="@(() => Navigation.NavigateTo(kpi.Url))">
                            عرض التفاصيل
                            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="MudBlazor.Size.Small" />
                        </button>
                    }
                </div>
            }
        </div>
    }

    <!-- ═════════════ ALERTS (لو في) ═════════════ -->
    @if (_dashboard.Alerts?.Any() == true)
    {
        <div class="alerts-section animate-card" style="--delay: 0.4s">
            <div class="section-card-header">
                <div class="section-icon section-icon-warning">
                    <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" />
                </div>
                <div class="section-titles">
                    <div class="section-title">التنبيهات والملاحظات</div>
                    <div class="section-subtitle">@_dashboard.Alerts.Count تنبيه يحتاج للمراجعة</div>
                </div>
            </div>
            <div class="alerts-grid">
                @foreach (var alert in _dashboard.Alerts.Take(6))
                {
                    <div class="alert-card alert-@alert.Type.ToLower()" style="border-right-color: @alert.Color;">
                        <div class="alert-icon" style="background: @(alert.Color)22; color: @alert.Color;">
                            <MudIcon Icon="@GetIcon(alert.Icon)" />
                        </div>
                        <div class="alert-content">
                            <h4 style="color: @alert.Color;">@alert.Title</h4>
                            <p>@alert.Description</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ═════════════ MAIN GRID — 2 COLUMNS ═════════════ -->
    <div class="main-grid">

        <!-- ═══ العمود الأيسر: Charts كبيرة ═══ -->
        <div class="col-main">

            <!-- 📊 CHART 1: الترند الشهري الموحّد -->
            <div class="chart-card animate-card" style="--delay: 0.45s">
                <div class="chart-card-header">
                    <div class="section-icon section-icon-blue">
                        <MudIcon Icon="@Icons.Material.Filled.ShowChart" />
                    </div>
                    <div class="section-titles">
                        <div class="section-title">الترند المالي الشامل</div>
                        <div class="section-subtitle">آخر 12 شهر — إيرادات / مصروفات / صافي الربح</div>
                    </div>
                </div>
                <div class="chart-card-body">
                    @if (_dashboard.Last12Months?.Any() == true)
                    {
                        <ApexChart TItem="UnifiedMonthlyDto"
                                   Options="_trendOptions"
                                   Height="380">
                            <ApexPointSeries TItem="UnifiedMonthlyDto"
                                             Items="_dashboard.Last12Months"
                                             Name="الإيرادات"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(e => e.MonthLabel)"
                                             YValue="@(e => (decimal?)e.Revenue)" />

                            <ApexPointSeries TItem="UnifiedMonthlyDto"
                                             Items="_dashboard.Last12Months"
                                             Name="المصروفات"
                                             SeriesType="SeriesType.Bar"
                                             XValue="@(e => e.MonthLabel)"
                                             YValue="@(e => (decimal?)e.Expenses)" />

                            <ApexPointSeries TItem="UnifiedMonthlyDto"
                                             Items="_dashboard.Last12Months"
                                             Name="صافي الربح"
                                             SeriesType="SeriesType.Line"
                                             XValue="@(e => e.MonthLabel)"
                                             YValue="@(e => (decimal?)e.NetProfit)" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="empty-chart">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="MudBlazor.Size.Large" />
                            <span>لا توجد بيانات شهرية</span>
                        </div>
                    }
                </div>
            </div>

            <!-- 📊 CHART 2: التدفقات النقدية الشهرية -->
            <div class="chart-card animate-card" style="--delay: 0.5s">
                <div class="chart-card-header">
                    <div class="section-icon section-icon-green">
                        <MudIcon Icon="@Icons.Material.Filled.WaterfallChart" />
                    </div>
                    <div class="section-titles">
                        <div class="section-title">التدفق النقدي والرصيد</div>
                        <div class="section-subtitle">داخل / خارج / صافي + الرصيد التراكمي</div>
                    </div>
                </div>
                <div class="chart-card-body">
                    @if (_dashboard.Last12Months?.Any() == true)
                    {
                        <ApexChart TItem="UnifiedMonthlyDto"
                                   Options="_cashFlowOptions"
                                   Height="320">
                            <ApexPointSeries TItem="UnifiedMonthlyDto"
                                             Items="_dashboard.Last12Months"
                                             Name="الداخل"
                                             SeriesType="SeriesType.Area"
                                             XValue="@(e => e.MonthLabel)"
                                             YValue="@(e => (decimal?)e.CashInflows)" />

                            <ApexPointSeries TItem="UnifiedMonthlyDto"
                                             Items="_dashboard.Last12Months"
                                             Name="الخارج"
                                             SeriesType="SeriesType.Area"
                                             XValue="@(e => e.MonthLabel)"
                                             YValue="@(e => (decimal?)e.CashOutflows)" />

                            <ApexPointSeries TItem="UnifiedMonthlyDto"
                                             Items="_dashboard.Last12Months"
                                             Name="الرصيد"
                                             SeriesType="SeriesType.Line"
                                             XValue="@(e => e.MonthLabel)"
                                             YValue="@(e => (decimal?)e.CashBalance)" />
                        </ApexChart>
                    }
                </div>
            </div>

            <!-- 📊 GRID: المنتجات والعملاء -->
            <div class="dual-charts">
                <!-- Top Products -->
                <div class="chart-card animate-card" style="--delay: 0.55s">
                    <div class="chart-card-header">
                        <div class="section-icon section-icon-gold">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                        </div>
                        <div class="section-titles">
                            <div class="section-title">الأعلى مبيعاً</div>
                            <div class="section-subtitle">أفضل @(_dashboard.TopProducts?.Count ?? 0) منتج</div>
                        </div>
                    </div>
                    <div class="chart-card-body">
                        @if (_dashboard.TopProducts?.Any() == true)
                        {
                            <ApexChart TItem="TopProductDto"
                                       Options="_topProductsOptions"
                                       Height="320">
                                <ApexPointSeries TItem="TopProductDto"
                                                 Items="_dashboard.TopProducts.Take(7)"
                                                 Name="الإيرادات"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="@(e => Truncate(e.ProductName, 18))"
                                                 YValue="@(e => (decimal?)e.Revenue)" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="empty-chart">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="MudBlazor.Size.Large" />
                                <span>لا توجد بيانات منتجات</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Top Customers -->
                <div class="chart-card animate-card" style="--delay: 0.6s">
                    <div class="chart-card-header">
                        <div class="section-icon section-icon-purple">
                            <MudIcon Icon="@Icons.Material.Filled.Groups" />
                        </div>
                        <div class="section-titles">
                            <div class="section-title">أكبر العملاء</div>
                            <div class="section-subtitle">أعلى @(_dashboard.TopCustomers?.Count ?? 0) عميل</div>
                        </div>
                    </div>
                    <div class="chart-card-body">
                        @if (_dashboard.TopCustomers?.Any() == true)
                        {
                            <ApexChart TItem="TopCustomerDto"
                                       Options="_topCustomersOptions"
                                       Height="320">
                                <ApexPointSeries TItem="TopCustomerDto"
                                                 Items="_dashboard.TopCustomers.Take(7)"
                                                 Name="الإيرادات"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="@(e => Truncate(e.CustomerName, 18))"
                                                 YValue="@(e => (decimal?)e.TotalRevenue)" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="empty-chart">
                                <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="MudBlazor.Size.Large" />
                                <span>لا توجد بيانات عملاء</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- 📊 STRATEGIC RECOMMENDATIONS -->
            @if (_dashboard.StrategicRecommendations?.Any() == true)
            {
                <div class="chart-card animate-card" style="--delay: 0.65s">
                    <div class="chart-card-header">
                        <div class="section-icon section-icon-purple">
                            <MudIcon Icon="@Icons.Material.Filled.TipsAndUpdates" />
                        </div>
                        <div class="section-titles">
                            <div class="section-title">التوصيات الاستراتيجية</div>
                            <div class="section-subtitle">@_dashboard.StrategicRecommendations.Count توصية</div>
                        </div>
                    </div>
                    <div class="chart-card-body">
                        <div class="recommendations-list">
                            @foreach (var rec in _dashboard.StrategicRecommendations.Take(5))
                            {
                                <div class="rec-item">
                                    <div class="rec-priority" style="background: @GetPriorityColor(rec.Impact);">
                                        @rec.Impact
                                    </div>
                                    <div class="rec-body">
                                        <h5>@rec.Title</h5>
                                        <p>@rec.Description</p>
                                        @if (!string.IsNullOrWhiteSpace(rec.ExpectedOutcome))
                                        {
                                            <span class="rec-action">
                                                <MudIcon Icon="@Icons.Material.Filled.PlayCircleFilled" Size="MudBlazor.Size.Small" />
                                                @rec.ExpectedOutcome
                                            </span>
                                        }
                                    </div>
                                    <div class="rec-meta">
                                        <span class="rec-impact">@GetImpactLabel(rec.Impact)</span>
                                        <span class="rec-difficulty">@GetDifficultyLabel(rec.Difficulty)</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ═══ العمود الأيمن: Sidebar Cards ═══ -->
        <div class="col-sidebar">

            <!-- 📊 CHART 3: الصحة المالية (RadialBar) -->
            <div class="chart-card animate-card" style="--delay: 0.45s">
                <div class="chart-card-header">
                    <div class="section-icon section-icon-red"
                         style="background: linear-gradient(135deg, @(_dashboard.HealthScore.Color), @(_dashboard.HealthScore.Color)cc);">
                        <MudIcon Icon="@Icons.Material.Filled.Favorite" />
                    </div>
                    <div class="section-titles">
                        <div class="section-title">الصحة المالية</div>
                        <div class="section-subtitle">@_dashboard.HealthScore.Status</div>
                    </div>
                    <div class="health-grade-pill" style="background: @_dashboard.HealthScore.Color;">
                        @_dashboard.HealthScore.Grade
                    </div>
                </div>
                <div class="chart-card-body">
                    <ApexChart TItem="HealthChartItem"
                               Options="_healthOptions"
                               Height="240">
                        <ApexPointSeries TItem="HealthChartItem"
                                         Items="_healthItems"
                                         Name="الصحة"
                                         SeriesType="SeriesType.RadialBar"
                                         XValue="@(e => e.Label)"
                                         YValue="@(e => (decimal?)(decimal)e.Value)" />
                    </ApexChart>

                    <div class="health-description">
                        @_dashboard.HealthScore.Description
                    </div>

                    @if (_dashboard.HealthScore.Factors?.Any() == true)
                    {
                        <div class="health-factors-mini">
                            @foreach (var factor in _dashboard.HealthScore.Factors.Take(4))
                            {
                                <div class="factor-mini">
                                    <div class="factor-mini-head">
                                        <span class="factor-mini-name">@factor.Name</span>
                                        <span class="factor-mini-score" style="color: @factor.Color;">
                                            @factor.Score/@factor.MaxScore
                                        </span>
                                    </div>
                                    <div class="factor-mini-bar">
                                        <div class="factor-mini-fill"
                                             style="width: @((double)factor.Score / factor.MaxScore * 100)%;
                                                    background: @factor.Color;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- 📊 CHART 4: توزيع المصروفات (Donut) -->
            <div class="chart-card animate-card" style="--delay: 0.5s">
                <div class="chart-card-header">
                    <div class="section-icon section-icon-warning">
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" />
                    </div>
                    <div class="section-titles">
                        <div class="section-title">توزيع المصروفات</div>
                        <div class="section-subtitle">حسب الفئات</div>
                    </div>
                </div>
                <div class="chart-card-body">
                    @if (_dashboard.TopExpenseCategories?.Any() == true)
                    {
                        <ApexChart TItem="ExpenseCategoryDto"
                                   Options="_expensesOptions"
                                   Height="300">
                            <ApexPointSeries TItem="ExpenseCategoryDto"
                                             Items="_dashboard.TopExpenseCategories.Take(6)"
                                             Name="المصروفات"
                                             SeriesType="SeriesType.Donut"
                                             XValue="@(e => e.GroupName)"
                                             YValue="@(e => (decimal?)e.Amount)" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="empty-chart">
                            <MudIcon Icon="@Icons.Material.Filled.PieChart" Size="MudBlazor.Size.Large" />
                            <span>لا توجد مصروفات</span>
                        </div>
                    }
                </div>
            </div>

            <!-- 📊 CHART 5: المؤشرات النسبية (Gauges) -->
            <div class="chart-card animate-card" style="--delay: 0.55s">
                <div class="chart-card-header">
                    <div class="section-icon section-icon-blue">
                        <MudIcon Icon="@Icons.Material.Filled.Speed" />
                    </div>
                    <div class="section-titles">
                        <div class="section-title">المؤشرات النسبية</div>
                        <div class="section-subtitle">ربحية وكفاءة</div>
                    </div>
                </div>
                <div class="chart-card-body">
                    <ApexChart TItem="RatioItem"
                               Options="_ratiosOptions"
                               Height="280">
                        <ApexPointSeries TItem="RatioItem"
                                         Items="_ratioItems"
                                         Name="النسب"
                                         SeriesType="SeriesType.RadialBar"
                                         XValue="@(e => e.Label)"
                                         YValue="@(e => (decimal?)(decimal)e.Value)" />
                    </ApexChart>
                </div>
            </div>

            <!-- 💰 RECEIVABLES SUMMARY -->
            <div class="chart-card animate-card" style="--delay: 0.6s">
                <div class="chart-card-header">
                    <div class="section-icon section-icon-purple">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" />
                    </div>
                    <div class="section-titles">
                        <div class="section-title">ملخص الذمم</div>
                        <div class="section-subtitle">العملاء والموردين</div>
                    </div>
                </div>
                <div class="chart-card-body">
                    <div class="receivables-list">
                        <div class="rec-row">
                            <span class="rec-label">مستحقات على العملاء</span>
                            <span class="rec-value rec-value-green">
                                @FormatMoney(_dashboard.Receivables.CustomerReceivables)
                            </span>
                        </div>
                        <div class="rec-row">
                            <span class="rec-label">مستحقات للموردين</span>
                            <span class="rec-value rec-value-red">
                                @FormatMoney(_dashboard.Receivables.SupplierPayables)
                            </span>
                        </div>
                        <div class="rec-row rec-row-divider">
                            <span class="rec-label">الصافي</span>
                            <span class="rec-value @(_dashboard.Receivables.NetReceivables >= 0 ? "rec-value-green" : "rec-value-red")">
                                @FormatMoney(_dashboard.Receivables.NetReceivables)
                            </span>
                        </div>
                        @if (_dashboard.Receivables.OverdueInvoicesCount > 0)
                        {
                            <div class="rec-warning">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="MudBlazor.Color.Warning" Size="MudBlazor.Size.Small" />
                                <span>@_dashboard.Receivables.OverdueInvoicesCount فاتورة متأخرة</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
}

<style>
    /* ════════════ LOADING ════════════ */
    .loading-screen { position: fixed; inset: 0; background: linear-gradient(135deg, #0f1a2e 0%, #1a2842 100%); display: flex; align-items: center; justify-content: center; z-index: 9999; }
    .loading-content { text-align: center; }
    .loading-spinner-box { background: rgba(212,175,55,0.1); padding: 24px; border-radius: 50%; border: 2px solid rgba(212,175,55,0.3); margin-bottom: 16px; display: inline-block; }
    .loading-text { color: #d4af37 !important; margin-bottom: 8px; }
    .loading-dots { display: inline-flex; gap: 6px; justify-content: center; }
    .loading-dots span { width: 8px; height: 8px; border-radius: 50%; background: #d4af37; animation: bounce 1.4s infinite ease-in-out both; }
    .loading-dots span:nth-child(2) { animation-delay: 0.16s; }
    .loading-dots span:nth-child(3) { animation-delay: 0.32s; }
    @@keyframes bounce { 0%,80%,100% { transform: scale(0); opacity: 0.5; } 40% { transform: scale(1); opacity: 1; } }

    /* ════════════ PAGE ════════════ */
    .fd-page {
        position: relative;
        min-height: 100vh;
        padding: 12px;
        background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
    }
    .page-bg-decorations { position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 0; }
    .bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.2; }
    .bg-orb-1 { width: 300px; height: 300px; background: radial-gradient(circle, #d4af37, transparent); top: -100px; right: -50px; }
    .bg-orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, #3b82f6, transparent); top: 30%; left: -100px; }
    .bg-orb-3 { width: 250px; height: 250px; background: radial-gradient(circle, #10b981, transparent); bottom: 20%; right: 30%; }
    .top-accent-bar { position: relative; height: 4px; background: linear-gradient(90deg, #d4af37, #e8c855, #d4af37); border-radius: 2px; margin-bottom: 12px; overflow: hidden; }
    .accent-shimmer { position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent); animation: shimmer 3s infinite; }
    @@keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

