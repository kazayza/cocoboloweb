@code {
    private bool _isLoading = true;
    private bool _isReloading = false;
    private FinancialDashboardDto? _dashboard;
    private FinancialDashboardFilterDto _filter = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frmFinancialDashboard:View")
                   || user.HasClaim("Permission", "frmCashBoxDashboard:View")
                   || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        await SetPeriod("Month");
        _isLoading = false;
    }

    private async Task LoadDashboard()
    {
        _isReloading = true;
        try
        {
            _dashboard = await DashboardService.GetDashboardAsync(_filter);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isReloading = false;
            StateHasChanged();
        }
    }

    private async Task SetPeriod(string period)
    {
        _filter.PeriodType = period;
        var today = DateTime.Today;

        switch (period)
        {
            case "Today": _filter.FromDate = today; _filter.ToDate = today; break;
            case "Week": _filter.FromDate = today.AddDays(-(int)today.DayOfWeek); _filter.ToDate = today; break;
            case "Month": _filter.FromDate = new DateTime(today.Year, today.Month, 1); _filter.ToDate = today; break;
            case "Quarter":
                var qStart = new DateTime(today.Year, ((today.Month - 1) / 3) * 3 + 1, 1);
                _filter.FromDate = qStart; _filter.ToDate = today; break;
            case "Year": _filter.FromDate = new DateTime(today.Year, 1, 1); _filter.ToDate = today; break;
        }

        await LoadDashboard();
    }

    private async Task Print() => await JS.InvokeVoidAsync("window.print");

    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);

    private string GetChangeClass(decimal change) => change > 0 ? "pos" : change < 0 ? "neg" : "neutral";

    private string GetRatioClass(decimal value, decimal goodMin, decimal excellentMin)
    {
        if (value >= excellentMin) return "good";
        if (value >= goodMin) return "fair";
        return "bad";
    }

