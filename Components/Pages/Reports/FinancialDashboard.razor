@page "/reports/financial-dashboard"
@page "/financial/dashboard"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Globalization

@inject IFinancialDashboardService DashboardService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS

@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <h3>جاري إعداد لوحة القيادة المالية</h3>
            <p>تحليل جميع البيانات المالية...</p>
        </div>
    </div>
}
else if (_dashboard != null)
{
    <div class="fd-page" dir="rtl">

        <!-- Background -->
        <div class="bg-deco no-print">
            <div class="bg-orb orb-1"></div>
            <div class="bg-orb orb-2"></div>
            <div class="bg-orb orb-3"></div>
        </div>

        <!-- ⭐ HERO HEADER -->
        <div class="fd-header">
            <div class="header-bg">
                <div class="hb-gradient"></div>
                <div class="hb-grid"></div>
            </div>
            <div class="header-content">
                <div class="header-left">
                    <div class="header-icon-wrap">
                        <div class="header-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Insights" />
                        </div>
                        <span class="premium-badge">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                            Premium Analytics
                        </span>
                    </div>
                    <div>
                        <h1>لوحة القيادة المالية</h1>
                        <p>تحليل شامل وذكي لأداء الشركة المالي • <strong>@_dashboard.PeriodLabel</strong></p>
                    </div>
                </div>
                <div class="header-actions no-print">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Print" OnClick="Print">
                        طباعة
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                               StartIcon="@Icons.Material.Filled.Analytics"
                               OnClick="@(() => Navigation.NavigateTo("/reports/income-statement"))">
                        قائمة الدخل
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                               StartIcon="@Icons.Material.Filled.WaterDrop"
                               OnClick="@(() => Navigation.NavigateTo("/reports/cash-flow"))">
                        التدفقات
                    </MudButton>
                </div>
            </div>
        </div>

        <!-- ⭐ FILTERS -->
        <div class="filters-bar no-print">
            <span class="filter-label">📅 الفترة:</span>
            <button class="period-btn @(_filter.PeriodType == "Today" ? "active" : "")" @onclick="@(() => SetPeriod("Today"))">اليوم</button>
            <button class="period-btn @(_filter.PeriodType == "Week" ? "active" : "")" @onclick="@(() => SetPeriod("Week"))">أسبوع</button>
            <button class="period-btn @(_filter.PeriodType == "Month" ? "active" : "")" @onclick="@(() => SetPeriod("Month"))">شهر</button>
            <button class="period-btn @(_filter.PeriodType == "Quarter" ? "active" : "")" @onclick="@(() => SetPeriod("Quarter"))">ربع</button>
            <button class="period-btn @(_filter.PeriodType == "Year" ? "active" : "")" @onclick="@(() => SetPeriod("Year"))">سنة</button>

            <div class="custom-period">
                <MudDatePicker Date="_filter.FromDate"
                               DateChanged="@(d => { _filter.FromDate = d ?? _filter.FromDate; _filter.PeriodType = "Custom"; _ = LoadDashboard(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Label="من" Class="date-pick" />
                <MudDatePicker Date="_filter.ToDate"
                               DateChanged="@(d => { _filter.ToDate = d ?? _filter.ToDate; _filter.PeriodType = "Custom"; _ = LoadDashboard(); })"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Label="إلى" Class="date-pick" />
            </div>
        </div>

        @if (_isReloading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-2" />
        }

        <!-- ⭐ HEALTH SCORE - الصحة المالية -->
        <div class="health-section">
            <div class="health-main">
                <div class="health-circle-wrap">
                    <svg viewBox="0 0 200 200" class="health-circle">
                        <circle cx="100" cy="100" r="85" stroke="#e5e7eb" stroke-width="14" fill="none" />
                        <circle cx="100" cy="100" r="85"
                                stroke="@_dashboard.HealthScore.Color" stroke-width="14"
                                fill="none" stroke-linecap="round"
                                stroke-dasharray="@(534 * _dashboard.HealthScore.OverallScore / 100), 534"
                                transform="rotate(-90 100 100)"
                                style="transition: stroke-dasharray 1s ease;" />
                        <text x="100" y="95" text-anchor="middle" font-size="48" font-weight="900" fill="@_dashboard.HealthScore.Color">
                            @_dashboard.HealthScore.OverallScore
                        </text>
                        <text x="100" y="125" text-anchor="middle" font-size="14" fill="#6b7280">
                            من 100
                        </text>
                    </svg>
                </div>
                <div class="health-info">
                    <div class="grade-badge" style="background: @_dashboard.HealthScore.Color;">
                        @_dashboard.HealthScore.Grade
                    </div>
                    <h2>الصحة المالية: @_dashboard.HealthScore.Status</h2>
                    <p>@_dashboard.HealthScore.Description</p>
                </div>
            </div>
            <div class="health-factors">
                @foreach (var factor in _dashboard.HealthScore.Factors)
                {
                    <div class="factor-card">
                        <div class="factor-header">
                            <span class="factor-name">@factor.Name</span>
                            <span class="factor-score" style="color: @factor.Color;">@factor.Score / @factor.MaxScore</span>
                        </div>
                        <div class="factor-bar">
                            <div class="factor-fill" style="width: @((double)factor.Score / factor.MaxScore * 100)%; background: @factor.Color;"></div>
                        </div>
                        <small class="factor-desc">@factor.Description</small>
                    </div>
                }
            </div>
        </div>

        <!-- ⭐ MAIN KPIs -->
        <div class="kpis-grid">
            @foreach (var kpi in _dashboard.MainKpis)
            {
                <div class="kpi-card" style="border-top-color: @kpi.Color;">
                    <div class="kpi-header">
                        <div class="kpi-icon" style="background: @(kpi.Color)22; color: @kpi.Color;">
                            <MudIcon Icon="@GetIcon(kpi.Icon)" />
                        </div>
                        @if (kpi.ChangePercentage.HasValue)
                        {
                            <span class="kpi-change @GetChangeClass(kpi.ChangePercentage.Value)">
                                @kpi.TrendIcon @(kpi.ChangePercentage >= 0 ? "+" : "")@kpi.ChangePercentage.Value.ToString("N1")%
                            </span>
                        }
                    </div>
                    <div class="kpi-body">
                        <span class="kpi-title">@kpi.Title</span>
                        <span class="kpi-value">@kpi.FormattedValue</span>
                        <span class="kpi-subtitle">@kpi.Subtitle</span>
                        @if (!string.IsNullOrEmpty(kpi.ChangeLabel))
                        {
                            <small class="kpi-change-label">@kpi.ChangeLabel</small>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(kpi.Url))
                    {
                        <button class="kpi-link" @onclick="@(() => Navigation.NavigateTo(kpi.Url))">
                            عرض التفاصيل →
                        </button>
                    }
                </div>
            }
        </div>

        <!-- ⭐ FINANCIAL RATIOS -->
        <div class="ratios-section">
            <h3 class="section-title">
                <MudIcon Icon="@Icons.Material.Filled.PieChart" />
                المؤشرات المالية النسبية
            </h3>
            <div class="ratios-grid">
                <div class="ratio-card">
                    <div class="r-icon">📈</div>
                    <span class="r-name">هامش الربح الإجمالي</span>
                    <strong class="r-value @GetRatioClass(_dashboard.Ratios.GrossProfitMargin, 30, 50)">
                        @_dashboard.Ratios.GrossProfitMargin.ToString("N1")%
                    </strong>
                </div>
                <div class="ratio-card">
                    <div class="r-icon">💰</div>
                    <span class="r-name">صافي الربح</span>
                    <strong class="r-value @GetRatioClass(_dashboard.Ratios.NetProfitMargin, 10, 20)">
                        @_dashboard.Ratios.NetProfitMargin.ToString("N1")%
                    </strong>
                </div>
                <div class="ratio-card">
                    <div class="r-icon">💧</div>
                    <span class="r-name">السيولة (شهور)</span>
                    <strong class="r-value @GetRatioClass(_dashboard.Ratios.CashRatio, 1, 3)">
                        @_dashboard.Ratios.CashRatio.ToString("N1")
                    </strong>
                </div>
                <div class="ratio-card">
                    <div class="r-icon">⚡</div>
                    <span class="r-name">السيولة السريعة</span>
                    <strong class="r-value @GetRatioClass(_dashboard.Ratios.QuickRatio, 1, 3)">
                        @_dashboard.Ratios.QuickRatio.ToString("N1")
                    </strong>
                </div>
                <div class="ratio-card">
                    <div class="r-icon">📊</div>
                    <span class="r-name">نسبة المصروفات</span>
                    <strong class="r-value @GetRatioClass(100 - _dashboard.Ratios.OperatingExpenseRatio, 50, 70)">
                        @_dashboard.Ratios.OperatingExpenseRatio.ToString("N1")%
                    </strong>
                </div>
                <div class="ratio-card">
                    <div class="r-icon">💸</div>
                    <span class="r-name">معدل التحصيل</span>
                    <strong class="r-value @GetRatioClass(_dashboard.Ratios.CollectionRate, 60, 90)">
                        @_dashboard.Ratios.CollectionRate.ToString("N1")%
                    </strong>
                </div>
                <div class="ratio-card">
                    <div class="r-icon">🚀</div>
                    <span class="r-name">نمو الإيرادات</span>
                    <strong class="r-value @GetRatioClass(_dashboard.Ratios.RevenueGrowthRate, 0, 10)">
                        @(_dashboard.Ratios.RevenueGrowthRate >= 0 ? "+" : "")@_dashboard.Ratios.RevenueGrowthRate.ToString("N1")%
                    </strong>
                </div>
                <div class="ratio-card">
                    <div class="r-icon">🧾</div>
                    <span class="r-name">متوسط الفاتورة</span>
                    <strong class="r-value">@FormatMoney(_dashboard.Ratios.RevenuePerInvoice) ج</strong>
                </div>
            </div>
        </div>

        <!-- ⭐ COMPARISONS -->
        @if (_dashboard.VsPreviousPeriod != null || _dashboard.VsLastYear != null)
        {
            <div class="comparisons-section">
                <h3 class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.CompareArrows" />
                    المقارنات الزمنية
                </h3>
                <div class="comp-grid">
                    @if (_dashboard.VsPreviousPeriod != null)
                    {
                        @RenderComparisonCard(_dashboard.VsPreviousPeriod)
                    }
                    @if (_dashboard.VsLastYear != null)
                    {
                        @RenderComparisonCard(_dashboard.VsLastYear)
                    }
                </div>
            </div>
        }

        <!-- ⭐ UNIFIED MONTHLY TREND -->
        @if (_dashboard.Last12Months.Any())
        {
            <div class="trend-section">
                <h3 class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" />
                    الترند المالي الشامل - 12 شهر
                </h3>
                <div class="chart-wrap">
                    <svg viewBox="0 0 1200 320" class="unified-chart" preserveAspectRatio="xMidYMid meet">
                        @{
                            var maxVal = _dashboard.Last12Months.Max(m => Math.Max(m.Revenue, Math.Max(m.Expenses, Math.Abs(m.NetProfit))));
                            if (maxVal == 0) maxVal = 1;
                            var sectionWidth = 1200.0 / _dashboard.Last12Months.Count;
                            var barWidth = sectionWidth / 4;
                        }

                        @for (int i = 0; i <= 4; i++)
                        {
                            var y = 30 + (220 * i / 4.0);
                            <line x1="0" y1="@y" x2="1200" y2="@y" stroke="#e5e7eb" stroke-width="1" stroke-dasharray="3,3" />
                        }

                        @for (int i = 0; i < _dashboard.Last12Months.Count; i++)
                        {
                            var m = _dashboard.Last12Months[i];
                            var baseX = i * sectionWidth + sectionWidth / 8;
                            var revH = (double)m.Revenue / (double)maxVal * 220;
                            var expH = (double)m.Expenses / (double)maxVal * 220;
                            var profitH = Math.Abs((double)m.NetProfit) / (double)maxVal * 220;

                            <rect x="@(baseX.ToString("F1", CultureInfo.InvariantCulture))" 
                                  y="@((250 - revH).ToString("F1", CultureInfo.InvariantCulture))" 
                                  width="@(barWidth.ToString("F1", CultureInfo.InvariantCulture))" 
                                  height="@(revH.ToString("F1", CultureInfo.InvariantCulture))" 
                                  fill="#10b981" rx="2">
                                <title>@m.MonthLabel - إيرادات: @FormatMoney(m.Revenue)</title>
                            </rect>
                            <rect x="@((baseX + barWidth + 1).ToString("F1", CultureInfo.InvariantCulture))" 
                                  y="@((250 - expH).ToString("F1", CultureInfo.InvariantCulture))" 
                                  width="@(barWidth.ToString("F1", CultureInfo.InvariantCulture))" 
                                  height="@(expH.ToString("F1", CultureInfo.InvariantCulture))" 
                                  fill="#ef4444" rx="2">
                                <title>@m.MonthLabel - مصروفات: @FormatMoney(m.Expenses)</title>
                            </rect>
                            <rect x="@((baseX + 2 * barWidth + 2).ToString("F1", CultureInfo.InvariantCulture))" 
                                  y="@((250 - profitH).ToString("F1", CultureInfo.InvariantCulture))" 
                                  width="@(barWidth.ToString("F1", CultureInfo.InvariantCulture))" 
                                  height="@(profitH.ToString("F1", CultureInfo.InvariantCulture))" 
                                  fill="@(m.NetProfit >= 0 ? "#3b82f6" : "#dc2626")" rx="2">
                                <title>@m.MonthLabel - ربح: @FormatMoney(m.NetProfit)</title>
                            </rect>

                            <svg:text x="@((baseX + barWidth * 1.5).ToString("F1", CultureInfo.InvariantCulture))" 
          y="280" text-anchor="middle" font-size="11" fill="#6b7280" font-weight="600">
    @m.Month.ToString("MM/yy")
</svg:text>

                            @if (m.Revenue > 0)
{
    <svg:text x="@((baseX + barWidth * 1.5).ToString("F1", CultureInfo.InvariantCulture))" 
              y="@((250 - profitH - 5).ToString("F1", CultureInfo.InvariantCulture))" 
              text-anchor="middle" font-size="10" fill="@(m.NetProfit >= 0 ? "#3b82f6" : "#dc2626")" font-weight="700">
        @m.NetProfitMargin.ToString("N0")%
    </svg:text>
}
                        }
                        <line x1="0" y1="250" x2="1200" y2="250" stroke="#374151" stroke-width="1.5" />
                    </svg>
                </div>
                <div class="chart-legend">
                    <span><span class="dot" style="background:#10b981;"></span> إيرادات</span>
                    <span><span class="dot" style="background:#ef4444;"></span> مصروفات</span>
                    <span><span class="dot" style="background:#3b82f6;"></span> صافي الربح</span>
                </div>
            </div>
        }

        <!-- ⭐ ALERTS -->
        @if (_dashboard.Alerts.Any())
        {
            <div class="alerts-section">
                <h3 class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" />
                    التنبيهات والتوصيات (@_dashboard.Alerts.Count)
                </h3>
                <div class="alerts-grid">
                    @foreach (var alert in _dashboard.Alerts)
                    {
                        <div class="alert-card" style="border-right-color: @alert.Color;">
                            <div class="alert-icon" style="background: @(alert.Color)22; color: @alert.Color;">@alert.Icon</div>
                            <div class="alert-body">
                                <div class="alert-cat" style="color: @alert.Color;">@GetCategoryLabel(alert.Category)</div>
                                <h4 style="color: @alert.Color;">@alert.Title</h4>
                                <p>@alert.Description</p>
                                @if (!string.IsNullOrEmpty(alert.ActionUrl))
                                {
                                    <button class="alert-btn" style="color: @alert.Color; border-color: @alert.Color;"
                                            @onclick="@(() => Navigation.NavigateTo(alert.ActionUrl!))">
                                        @alert.ActionLabel ←
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ⭐ TOP PRODUCTS + CUSTOMERS -->
        <div class="top-grid">
            @if (_dashboard.TopProducts.Any())
            {
                <div class="top-section">
                    <h3 class="section-title small">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                        أعلى 10 منتجات مبيعاً
                    </h3>
                    <table class="top-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>المنتج</th>
                                <th>كمية</th>
                                <th>الإيرادات</th>
                                <th>الربح</th>
                                <th>%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rank = 1; }
                            @foreach (var p in _dashboard.TopProducts)
                            {
                                <tr>
                                    <td><span class="rank">@rank</span></td>
                                    <td><strong>@p.ProductName</strong></td>
                                    <td>@p.QuantitySold</td>
                                    <td class="num">@FormatMoney(p.Revenue)</td>
                                    <td class="num pos">@FormatMoney(p.Profit)</td>
                                    <td><span class="margin-pill">@p.ProfitMargin.ToString("N1")%</span></td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (_dashboard.TopCustomers.Any())
            {
                <div class="top-section">
                    <h3 class="section-title small">
                        <MudIcon Icon="@Icons.Material.Filled.Stars" />
                        أعلى 10 عملاء
                    </h3>
                    <table class="top-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>العميل</th>
                                <th>فواتير</th>
                                <th>إيرادات</th>
                                <th>متبقي</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int crank = 1; }
                            @foreach (var c in _dashboard.TopCustomers)
                            {
                                <tr>
                                    <td><span class="rank">@crank</span></td>
                                    <td>
                                        <strong>@c.CustomerName</strong>
                                        @if (!string.IsNullOrEmpty(c.Phone))
                                        {
                                            <small>@c.Phone</small>
                                        }
                                    </td>
                                    <td>@c.InvoicesCount</td>
                                    <td class="num">@FormatMoney(c.TotalRevenue)</td>
                                    <td class="num @(c.Remaining > 0 ? "warn" : "")">@FormatMoney(c.Remaining)</td>
                                </tr>
                                crank++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- ⭐ EXPENSE CATEGORIES + RECEIVABLES -->
        <div class="bottom-grid">
            @if (_dashboard.TopExpenseCategories.Any())
            {
                <div class="bottom-card">
                    <h3 class="section-title small">
                        <MudIcon Icon="@Icons.Material.Filled.MoneyOff" />
                        تصنيفات المصروفات
                    </h3>
                    <div class="cat-list">
                        @foreach (var c in _dashboard.TopExpenseCategories)
                        {
                            <div class="cat-row">
                                <div class="cat-info">
                                    <span class="cat-color" style="background: @c.Color;"></span>
                                    <span>@c.GroupName</span>
                                </div>
                                <div class="cat-bar-wrap">
                                    <div class="cat-bar" style="width: @c.Percentage%; background: @c.Color;"></div>
                                </div>
                                <div class="cat-vals">
                                    <strong>@FormatMoney(c.Amount)</strong>
                                    <small>@c.Percentage%</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="bottom-card">
                <h3 class="section-title small">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" />
                    ملخص الذمم
                </h3>
                <div class="receivables-grid">
                    <div class="rec-item credit">
                        <span class="rec-label">📥 على العملاء</span>
                        <strong>@FormatMoney(_dashboard.Receivables.CustomerReceivables) ج</strong>
                        <small>@_dashboard.Receivables.CustomersWithDebtCount عميل</small>
                    </div>
                    <div class="rec-item debit">
                        <span class="rec-label">📤 للموردين</span>
                        <strong>@FormatMoney(_dashboard.Receivables.SupplierPayables) ج</strong>
                    </div>
                    <div class="rec-item credit">
                        <span class="rec-label">💼 ذمم شخصية (عليكم)</span>
                        <strong>@FormatMoney(_dashboard.Receivables.PersonalAccountsCredit) ج</strong>
                    </div>
                    <div class="rec-item debit">
                        <span class="rec-label">💼 ذمم شخصية (لكم)</span>
                        <strong>@FormatMoney(_dashboard.Receivables.PersonalAccountsDebit) ج</strong>
                    </div>
                    @if (_dashboard.Receivables.OverdueInvoicesCount > 0)
                    {
                        <div class="rec-item warn">
                            <span class="rec-label">🚨 فواتير متأخرة</span>
                            <strong>@_dashboard.Receivables.OverdueInvoicesCount فاتورة</strong>
                        </div>
                    }
                    <div class="rec-item net">
                        <span class="rec-label">💰 الصافي</span>
                        <strong style="color: @(_dashboard.Receivables.NetReceivables >= 0 ? "#10b981" : "#ef4444");">
                            @FormatMoney(_dashboard.Receivables.NetReceivables) ج
                        </strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- ⭐ STRATEGIC RECOMMENDATIONS -->
        @if (_dashboard.StrategicRecommendations.Any())
        {
            <div class="strategy-section">
                <h3 class="section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" />
                    التوصيات الاستراتيجية للنمو
                </h3>
                <div class="strategy-grid">
                    @foreach (var rec in _dashboard.StrategicRecommendations)
                    {
                        <div class="strategy-card" style="border-color: @(rec.Color)55;">
                            <div class="s-header" style="background: linear-gradient(135deg, @rec.Color, @(rec.Color)cc);">
                                <span class="s-icon">@rec.Icon</span>
                                <span class="s-title">@rec.Title</span>
                                <div class="s-tags">
                                    <span class="s-tag impact-@rec.Impact.ToLower()">@GetImpactLabel(rec.Impact)</span>
                                    <span class="s-tag diff-@rec.Difficulty.ToLower()">@GetDifficultyLabel(rec.Difficulty)</span>
                                </div>
                            </div>
                            <div class="s-body">
                                <p class="s-desc">@rec.Description</p>
                                <div class="s-outcome">
                                    <strong>🎯 النتيجة المتوقعة:</strong> @rec.ExpectedOutcome
                                </div>
                                <div class="s-steps">
                                    <strong>📋 خطوات التنفيذ:</strong>
                                    <ol>
                                        @foreach (var step in rec.ActionSteps)
                                        {
                                            <li>@step</li>
                                        }
                                    </ol>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="print-footer print-only">
            <p>تم إصدار هذا التقرير في @DateTime.Now.ToString("yyyy/MM/dd HH:mm") • COCOBOLO ERP</p>
        </div>
    </div>
}

@* Render comparison helper *@
@code {
    private RenderFragment RenderComparisonCard(PeriodComparisonDto comp) => __builder =>
    {
        var trendColor = comp.NetProfitChange > 5 ? "#10b981" : comp.NetProfitChange < -5 ? "#ef4444" : "#94a3b8";

        <div class="comp-card" style="border-top-color: @trendColor;">
            <div class="comp-head">
                <strong>@comp.Label</strong>
                <span class="comp-trend" style="color: @trendColor;">@comp.TrendIcon @comp.OverallTrend</span>
            </div>
            <div class="comp-body">
                <div class="comp-metric">
                    <span>الإيرادات</span>
                    <div class="comp-vals">
                        <strong>@FormatMoney(comp.Revenue) ج</strong>
                        <span class="@GetChangeClass(comp.RevenueChange)">
                            @(comp.RevenueChange >= 0 ? "+" : "")@comp.RevenueChange.ToString("N1")%
                        </span>
                    </div>
                </div>
                <div class="comp-metric">
                    <span>المصروفات</span>
                    <div class="comp-vals">
                        <strong>@FormatMoney(comp.Expenses) ج</strong>
                        <span class="@GetChangeClass(-comp.ExpensesChange)">
                            @(comp.ExpensesChange >= 0 ? "+" : "")@comp.ExpensesChange.ToString("N1")%
                        </span>
                    </div>
                </div>
                <div class="comp-metric highlight">
                    <span>صافي الربح</span>
                    <div class="comp-vals">
                        <strong>@FormatMoney(comp.NetProfit) ج</strong>
                        <span class="@GetChangeClass(comp.NetProfitChange)">
                            @(comp.NetProfitChange >= 0 ? "+" : "")@comp.NetProfitChange.ToString("N1")%
                        </span>
                    </div>
                </div>
            </div>
        </div>
    };
}

