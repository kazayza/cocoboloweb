    // ═══════════════ HELPERS ═══════════════
    private string FormatMoney(decimal val) => val.ToString("N0", CultureInfo.GetCultureInfo("ar-EG")) + " ج";

    private string Truncate(string str, int maxLen) =>
        string.IsNullOrEmpty(str) ? "" : (str.Length <= maxLen ? str : str.Substring(0, maxLen) + "...");

    private string GetChangeClass(decimal pct) => pct switch
    {
        > 0 => "change-up",
        < 0 => "change-down",
        _   => "change-neutral"
    };

    private string GetPriorityColor(string priority) => priority?.ToLower() switch
    {
        "high" or "عالي" or "عالية"       => "#ef4444",
        "medium" or "متوسط" or "متوسطة"  => "#f59e0b",
        "low" or "منخفض" or "منخفضة"      => "#10b981",
        _                                  => "#6b7280"
    };

    private string GetImpactLabel(string imp) => imp switch
    {
        "High" => "تأثير عالي",
        "Medium" => "تأثير متوسط",
        "Low" => "تأثير منخفض",
        _ => imp ?? ""
    };

    private string GetDifficultyLabel(string diff) => diff switch
    {
        "Easy" => "سهل",
        "Medium" => "متوسط",
        "Hard" => "صعب",
        _ => diff ?? ""
    };

    private string GetIcon(string iconName) => iconName switch
    {
        "TrendingUp"             => Icons.Material.Filled.TrendingUp,
        "TrendingDown"           => Icons.Material.Filled.TrendingDown,
        "AccountBalance"         => Icons.Material.Filled.AccountBalance,
        "Warning"                => Icons.Material.Filled.Warning,
        "MoneyOff"               => Icons.Material.Filled.MoneyOff,
        "AccountBalanceWallet"   => Icons.Material.Filled.AccountBalanceWallet,
        "PieChart"               => Icons.Material.Filled.PieChart,
        "AttachMoney"            => Icons.Material.Filled.AttachMoney,
        "Insights"               => Icons.Material.Filled.Insights,
        "Receipt"                => Icons.Material.Filled.Receipt,
        "ShoppingCart"           => Icons.Material.Filled.ShoppingCart,
        "Groups"                 => Icons.Material.Filled.Groups,
        _ => Icons.Material.Filled.Insights
    };
