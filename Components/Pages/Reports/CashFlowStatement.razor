</style>

@code {
    private bool _isLoading = true;
    private bool _isReloading = false;
    private CashFlowStatementDto? _report;
    private CashFlowFilterDto _filter = new();
    private List<CashBoxListDto> _boxes = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        var canView = user.HasClaim("Permission", "frm_CashFlowNew:View")
                   || user.HasClaim("Permission", "frmCashBoxDashboard:View")
                   || user.IsInRole("Admin");
        if (!canView) { Navigation.NavigateTo("/"); return; }

        _boxes = await CashBoxService.GetCashBoxesAsync();
        await SetPeriod("Month");
        _isLoading = false;
    }

    private async Task LoadReport()
    {
        _isReloading = true;
        try
        {
            _report = await CashFlowService.GetCashFlowStatementAsync(_filter);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isReloading = false;
            StateHasChanged();
        }
    }

    private async Task SetPeriod(string period)
    {
        _filter.PeriodType = period;
        var today = DateTime.Today;

        switch (period)
        {
            case "Today":
                _filter.FromDate = today; _filter.ToDate = today; break;
            case "Week":
                _filter.FromDate = today.AddDays(-(int)today.DayOfWeek); _filter.ToDate = today; break;
            case "Month":
                _filter.FromDate = new DateTime(today.Year, today.Month, 1); _filter.ToDate = today; break;
            case "Quarter":
                var qStart = new DateTime(today.Year, ((today.Month - 1) / 3) * 3 + 1, 1);
                _filter.FromDate = qStart; _filter.ToDate = today; break;
            case "Year":
                _filter.FromDate = new DateTime(today.Year, 1, 1); _filter.ToDate = today; break;
        }

        await LoadReport();
    }

    private async Task Print() => await JS.InvokeVoidAsync("window.print");

    private string FormatMoney(decimal v) => v.ToString("N2", CultureInfo.InvariantCulture);

    private string GetLiquidityStatusClass()
    {
        return _report?.LiquidityAnalysis.Status switch
        {
            "ممتاز" or "جيد" => "success",
            "متوسط" => "warning",
            _ => "danger"
        };
    }

    private string GetLiquidityColor()
    {
        var ratio = _report?.LiquidityAnalysis.LiquidityRatio ?? 0;
        if (ratio >= 6) return "#10b981";
        if (ratio >= 3) return "#22c55e";
        if (ratio >= 1) return "#f59e0b";
        if (ratio > 0) return "#fb923c";
        return "#ef4444";
    }

    private string GetTrendClass()
    {
        return _report?.Forecast.Trend switch
        {
            "نمو" => "success",
            "تراجع" => "danger",
            _ => "info"
        };
    }
}
