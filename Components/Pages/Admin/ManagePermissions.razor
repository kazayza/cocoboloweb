@page "/admin/permissions/manage"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using Microsoft.EntityFrameworkCore
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject db24804Context Db
@inject AuthenticationStateProvider AuthStateProvider

<div class="manage-permissions-page">

    <!-- Header Section -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-left">
                <div class="page-icon">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" />
                </div>
                <div class="header-text">
                    <h1>ربط الصلاحيات بالمستخدمين</h1>
                    <p class="subtitle">تخصيص صلاحيات المستخدمين للوصول إلى شاشات النظام</p>
                </div>
            </div>
        </div>
    </div>

    <!-- User Selection Bar -->
    <div class="selection-bar">
        <div class="selection-content">
            <div class="user-select-group">
                <div class="select-label">
                    <MudIcon Icon="@Icons.Material.Rounded.Person" />
                    <span>اختر المستخدم</span>
                </div>
                <MudSelect T="int"
                           Value="_selectedUser"
                           ValueChanged="OnUserSelected"
                           Variant="Variant.Outlined"
                           Placeholder="-- اختر مستخدم --"
                           Class="user-select">
                    <MudSelectItem Value="@(0)">-- اختر مستخدم --</MudSelectItem>
                    @foreach (var user in _users)
                    {
                        <MudSelectItem Value="@(user.UserId)">
                            <div class="user-option">
                                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" />
                                <div>
                                    <div class="user-name">@user.FullName</div>
                                    <div class="user-username">@@@user.Username</div>
                                </div>
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>
            </div>

            @if (_selectedUser > 0)
            {
                var selectedUserData = _users.FirstOrDefault(u => u.UserId == _selectedUser);
                var activePermissionsCount = _permissionList.Sum(p => (p.CanView ? 1 : 0) + (p.CanAdd ? 1 : 0) + (p.CanEdit ? 1 : 0) + (p.CanDelete ? 1 : 0));
                
                <div class="user-info-badges">
                    <div class="info-badge role-badge">
                        <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" />
                        <span>@selectedUserData?.Role</span>
                    </div>
                    <div class="info-badge permissions-badge">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                        <span>@activePermissionsCount صلاحية مفعلة</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Permissions Table -->
    @if (_selectedUser > 0)
    {
        <div class="permissions-container">
            <div class="container-header">
                <div class="header-title">
                    <MudIcon Icon="@Icons.Material.Filled.Security" />
                    <h2>الصلاحيات المتاحة</h2>
                </div>
                <div class="bulk-actions">
                    <MudButton OnClick="SelectAll" 
                               Variant="Variant.Outlined" 
                               Size="Size.Small" 
                               StartIcon="@Icons.Material.Rounded.SelectAll"
                               Color="Color.Success"
                               Class="bulk-btn">
                        تحديد الكل
                    </MudButton>
                    <MudButton OnClick="DeselectAll" 
                               Variant="Variant.Outlined" 
                               Size="Size.Small" 
                               StartIcon="@Icons.Material.Rounded.Deselect"
                               Color="Color.Error"
                               Class="bulk-btn">
                        إلغاء الكل
                    </MudButton>
                </div>
            </div>

            <div class="table-wrapper">
                <MudTable Items="_permissionList" 
                          Hover="true" 
                          Breakpoint="Breakpoint.Sm"
                          Elevation="0"
                          Class="permissions-table">

                    <HeaderContent>
                        <MudTh Class="table-header">
                            <div class="header-cell">
                                <MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" />
                                <span>اسم الصلاحية</span>
                            </div>
                        </MudTh>
                        <MudTh Class="table-header">
                            <div class="header-cell">
                                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
                                <span>Form Name</span>
                            </div>
                        </MudTh>
                        <MudTh Class="table-header">
                            <div class="header-cell">
                                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                                <span>الفئة</span>
                            </div>
                        </MudTh>
                        <MudTh Class="table-header permission-col">
                            <div class="permission-header view">
                                <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                                <span>عرض</span>
                            </div>
                        </MudTh>
                        <MudTh Class="table-header permission-col">
                            <div class="permission-header add">
                                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                                <span>إضافة</span>
                            </div>
                        </MudTh>
                        <MudTh Class="table-header permission-col">
                            <div class="permission-header edit">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                                <span>تعديل</span>
                            </div>
                        </MudTh>
                        <MudTh Class="table-header permission-col">
                            <div class="permission-header delete">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                                <span>حذف</span>
                            </div>
                        </MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="اسم الصلاحية">
                            <div class="permission-name-cell">
                                <strong>@context.Permission.PermissionName</strong>
                                @if (!string.IsNullOrEmpty(context.Permission.Description))
                                {
                                    <span class="permission-desc">@context.Permission.Description</span>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Form Name">
                            <span class="form-name-badge">@context.Permission.FormName</span>
                        </MudTd>
                        <MudTd DataLabel="الفئة">
                            <span class="category-badge" style="background: @GetCategoryColor(context.Permission.Category)">
                                @GetCategoryIcon(context.Permission.Category)
                                @context.Permission.Category
                            </span>
                        </MudTd>
                        <MudTd DataLabel="عرض" Class="checkbox-cell">
                            <label class="custom-checkbox view">
                                <input type="checkbox" 
                                       checked="@context.CanView"
                                       @onchange="(e) => { context.CanView = (bool)(e.Value ?? false); OnPermissionChanged(context); }" />
                                <span class="checkmark"></span>
                            </label>
                        </MudTd>
                        <MudTd DataLabel="إضافة" Class="checkbox-cell">
                            <label class="custom-checkbox add">
                                <input type="checkbox" 
                                       checked="@context.CanAdd"
                                       @onchange="(e) => { context.CanAdd = (bool)(e.Value ?? false); OnPermissionChanged(context); }" />
                                <span class="checkmark"></span>
                            </label>
                        </MudTd>
                        <MudTd DataLabel="تعديل" Class="checkbox-cell">
                            <label class="custom-checkbox edit">
                                <input type="checkbox" 
                                       checked="@context.CanEdit"
                                       @onchange="(e) => { context.CanEdit = (bool)(e.Value ?? false); OnPermissionChanged(context); }" />
                                <span class="checkmark"></span>
                            </label>
                        </MudTd>
                        <MudTd DataLabel="حذف" Class="checkbox-cell">
                            <label class="custom-checkbox delete">
                                <input type="checkbox" 
                                       checked="@context.CanDelete"
                                       @onchange="(e) => { context.CanDelete = (bool)(e.Value ?? false); OnPermissionChanged(context); }" />
                                <span class="checkmark"></span>
                            </label>
                        </MudTd>
                    </RowTemplate>

                </MudTable>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Rounded.ManageAccounts" Size="Size.Large" />
            <h3>إدارة صلاحيات المستخدمين</h3>
            <p>اختر مستخدم من القائمة أعلاه لعرض وتعديل صلاحياته</p>
        </div>
    }

</div>

<style>
    .manage-permissions-page {
        padding: 2rem;
        max-width: 1800px;
        margin: 0 auto;
        direction: rtl;
    }

    /* Header */
