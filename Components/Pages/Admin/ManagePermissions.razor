        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .page-icon {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .page-icon .mud-icon-root {
        font-size: 2rem;
    }

    .header-text h1 {
        color: white;
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
    }

    .header-text .subtitle {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
        font-size: 1rem;
    }

    /* Selection Bar */
    .selection-bar {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
    }

    .selection-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .user-select-group {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex: 1;
        min-width: 300px;
    }

    .select-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        color: #2d3748;
    }

    .select-label .mud-icon-root {
        color: #667eea;
    }

    .user-select {
        flex: 1;
        max-width: 400px;
    }

    .user-option {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .user-option .mud-icon-root {
        color: #667eea;
    }

    .user-name {
        font-weight: 600;
        color: #1a202c;
    }

    .user-username {
        font-size: 0.85rem;
        color: #718096;
        font-family: 'Courier New', monospace;
    }

    .user-info-badges {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .info-badge {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .role-badge {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(240, 147, 251, 0.3);
    }

    .permissions-badge {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }

    /* Permissions Container */
    .permissions-container {
        background: white;
        border-radius: 20px;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .container-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, #f8f9fc 0%, #eef1f7 100%);
        border-bottom: 2px solid #e2e8f0;
    }

    .header-title {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-title .mud-icon-root {
        color: #667eea;
        font-size: 1.75rem;
    }

    .header-title h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1a202c;
        margin: 0;
    }

    .bulk-actions {
        display: flex;
        gap: 0.75rem;
    }

    .bulk-btn {
        font-weight: 600 !important;
    }

    /* Table */
    .table-wrapper {
        overflow-x: auto;
    }

    .permissions-table {
        background: transparent !important;
    }

    .permissions-table .mud-table-head {
        background: linear-gradient(135deg, #f8f9fc 0%, #eef1f7 100%);
    }

    .table-header {
        font-weight: 700 !important;
        color: #1a202c !important;
        padding: 1.25rem 1rem !important;
    }

    .header-cell {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .header-cell .mud-icon-root {
        color: #667eea;
        font-size: 1.1rem;
    }

    .permission-col {
        text-align: center !important;
        width: 100px;
    }

    .permission-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
    }

    .permission-header.view .mud-icon-root { color: #3b82f6; }
    .permission-header.add .mud-icon-root { color: #10b981; }
    .permission-header.edit .mud-icon-root { color: #f59e0b; }
    .permission-header.delete .mud-icon-root { color: #ef4444; }

    .permissions-table .mud-table-row {
        transition: all 0.3s ease;
    }

    .permissions-table .mud-table-row:hover {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%) !important;
    }

    .permissions-table .mud-table-cell {
        padding: 1rem !important;
        vertical-align: middle !important;
    }

    /* Table Cells */
    .permission-name-cell {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .permission-name-cell strong {
        color: #1a202c;
        font-size: 1rem;
    }

    .permission-desc {
        color: #718096;
        font-size: 0.85rem;
    }

    .form-name-badge {
        display: inline-block;
        background: rgba(102, 126, 234, 0.1);
        color: #667eea;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-family: 'Courier New', monospace;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .category-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        color: white;
    }

    /* Custom Checkboxes */
    .checkbox-cell {
        text-align: center !important;
    }

    .custom-checkbox {
        position: relative;
        display: inline-block;
        width: 44px;
        height: 44px;
        cursor: pointer;
    }

    .custom-checkbox input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }

    .checkmark {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        height: 28px;
        width: 28px;
        background-color: #f1f5f9;
        border: 2px solid #cbd5e0;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .custom-checkbox:hover .checkmark {
        border-color: #667eea;
        background-color: #eef2ff;
    }

    .custom-checkbox input:checked ~ .checkmark {
        background-color: #667eea;
        border-color: #667eea;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .custom-checkbox.view input:checked ~ .checkmark {
        background-color: #3b82f6;
        border-color: #3b82f6;
    }

    .custom-checkbox.add input:checked ~ .checkmark {
        background-color: #10b981;
        border-color: #10b981;
    }

    .custom-checkbox.edit input:checked ~ .checkmark {
        background-color: #f59e0b;
        border-color: #f59e0b;
    }

    .custom-checkbox.delete input:checked ~ .checkmark {
        background-color: #ef4444;
        border-color: #ef4444;
    }

    .checkmark:after {
        content: "";
        position: absolute;
        display: none;
        left: 9px;
        top: 5px;
        width: 6px;
        height: 11px;
        border: solid white;
        border-width: 0 2.5px 2.5px 0;
        transform: rotate(45deg);
    }

    .custom-checkbox input:checked ~ .checkmark:after {
        display: block;
    }

    /* Empty State */
    .empty-state {
        background: white;
        border-radius: 20px;
        padding: 5rem 2rem;
        text-align: center;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
        border: 2px dashed #e2e8f0;
    }

    .empty-state .mud-icon-root {
        font-size: 6rem;
        color: #e2e8f0;
        margin-bottom: 2rem;
    }

    .empty-state h3 {
        color: #2d3748;
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0 0 0.75rem 0;
    }

    .empty-state p {
        color: #718096;
        font-size: 1.1rem;
        margin: 0;
    }

    /* Responsive */
    @@media (max-width: 960px) {
        .manage-permissions-page {
            padding: 1rem;
        }

        .page-header {
            padding: 1.5rem;
        }

        .header-text h1 {
            font-size: 1.5rem;
        }

        .page-icon {
            width: 48px;
            height: 48px;
        }

        .page-icon .mud-icon-root {
            font-size: 1.5rem;
        }

        .selection-content {
            flex-direction: column;
            align-items: stretch;
        }

        .user-select-group {
            flex-direction: column;
            align-items: stretch;
            width: 100%;
            min-width: 100%;
        }

        .user-select {
            max-width: 100%;
        }

        .container-header {
            flex-direction: column;
            align-items: stretch;
            gap: 1rem;
        }

        .bulk-actions {
            justify-content: stretch;
        }

        .bulk-btn {
            flex: 1;
        }
    }
</style>

@code {
    private List<User> _users = new();
    private int _selectedUser = 0;
    private List<UserPermissionItem> _permissionList = new();
    private ClaimsPrincipal? _currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User;
        _users = await Db.Users.OrderBy(u => u.FullName).ToListAsync();
    }

    private async Task OnUserSelected(int UserId)
    {
        _selectedUser = UserId;
        if (_selectedUser > 0)
        {
            await LoadUserPermissions();
        }
        else
        {
            _permissionList.Clear();
        }
        StateHasChanged();
    }

    private async Task LoadUserPermissions()
    {
        var allPermissions = await Db.Permissions.OrderBy(p => p.Category).ThenBy(p => p.PermissionName).ToListAsync();
        var userPermissions = await Db.UserPermissions.Where(up => up.UserId == _selectedUser).ToListAsync();

        _permissionList = allPermissions.Select(p =>
        {
            var existing = userPermissions.FirstOrDefault(up => up.PermissionId == p.PermissionId);
            return new UserPermissionItem
            {
                PermissionId = p.PermissionId,
                Permission = p,
                CanView = existing?.CanView ?? false,
                CanAdd = existing?.CanAdd ?? false,
                CanEdit = existing?.CanEdit ?? false,
                CanDelete = existing?.CanDelete ?? false
            };
        }).ToList();

        StateHasChanged();
    }

    private async Task OnPermissionChanged(UserPermissionItem item)
    {
        var existing = await Db.UserPermissions.FirstOrDefaultAsync(up => up.UserId == _selectedUser && up.PermissionId == item.PermissionId);

        if (!item.CanView && !item.CanAdd && !item.CanEdit && !item.CanDelete)
        {
            if (existing != null)
            {
                Db.UserPermissions.Remove(existing);
                await Db.SaveChangesAsync();
            }
            return;
        }

        if (existing == null)
        {
            existing = new UserPermission
            {
                UserId = _selectedUser,
                PermissionId = item.PermissionId,
                CanView = item.CanView,
                CanAdd = item.CanAdd,
                CanEdit = item.CanEdit,
                CanDelete = item.CanDelete,
                AssignedBy = _currentUser?.Identity?.Name,
                AssignedDate = DateTime.Now
            };
            Db.UserPermissions.Add(existing);
        }
        else
        {
            existing.CanView = item.CanView;
            existing.CanAdd = item.CanAdd;
            existing.CanEdit = item.CanEdit;
            existing.CanDelete = item.CanDelete;
            existing.AssignedBy = _currentUser?.Identity?.Name;
            existing.AssignedDate = DateTime.Now;
        }

        await Db.SaveChangesAsync();
    }

    private async Task SelectAll()
    {
        foreach (var item in _permissionList)
        {
            item.CanView = true;
            item.CanAdd = true;
            item.CanEdit = true;
            item.CanDelete = true;
        }
        await SaveAll();
        StateHasChanged();
    }

    private async Task DeselectAll()
    {
        foreach (var item in _permissionList)
        {
            item.CanView = false;
            item.CanAdd = false;
            item.CanEdit = false;
            item.CanDelete = false;
        }
        await SaveAll();
        StateHasChanged();
    }

    private async Task SaveAll()
    {
        var existing = await Db.UserPermissions.Where(up => up.UserId == _selectedUser).ToListAsync();
        Db.UserPermissions.RemoveRange(existing);

        foreach (var item in _permissionList.Where(p => p.CanView || p.CanAdd || p.CanEdit || p.CanDelete))
        {
            Db.UserPermissions.Add(new UserPermission
            {
                UserId = _selectedUser,
                PermissionId = item.PermissionId,
                CanView = item.CanView,
                CanAdd = item.CanAdd,
                CanEdit = item.CanEdit,
                CanDelete = item.CanDelete,
                AssignedBy = _currentUser?.Identity?.Name,
                AssignedDate = DateTime.Now
            });
        }

        await Db.SaveChangesAsync();
    }

    private string GetCategoryColor(string? category)
    {
        return category switch
        {
            "Administration" => "linear-gradient(135deg, #ef4444 0%, #dc2626 100%)",
            "Forms" => "linear-gradient(135deg, #3b82f6 0%, #2563eb 100%)",
            "Reports" => "linear-gradient(135deg, #10b981 0%, #059669 100%)",
            "Settings" => "linear-gradient(135deg, #f59e0b 0%, #d97706 100%)",
            _ => "linear-gradient(135deg, #6b7280 0%, #4b5563 100%)"
        };
    }

    private string GetCategoryIcon(string? category)
    {
        return category switch
        {
            "Administration" => "🔐",
            "Forms" => "📋",
            "Reports" => "📊",
            "Settings" => "⚙️",
            _ => "📌"
        };
    }

    private class UserPermissionItem
    {
        public int PermissionId { get; set; }
        public Permission Permission { get; set; } = new();
        public bool CanView { get; set; }
        public bool CanAdd { get; set; }
        public bool CanEdit { get; set; }
        public bool CanDelete { get; set; }
    }
}
