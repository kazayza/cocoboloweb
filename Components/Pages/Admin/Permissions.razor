@page "/admin/permissions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using Microsoft.EntityFrameworkCore
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject db24804Context Db
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="permissions-page">

    <!-- Header Section -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-left">
                <div class="page-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Security" />
                </div>
                <div class="header-text">
                    <h1>إدارة الصلاحيات</h1>
                    <p class="subtitle">تحديد وإدارة صلاحيات الوصول للنظام</p>
                </div>
            </div>
            @if (HasPermission("frm_AddPermission", "Add"))
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Rounded.Add"
                           Class="add-btn"
                           OnClick="() => OpenForm(null)">
                    إضافة صلاحية جديدة
                </MudButton>
            }
        </div>
    </div>

    <!-- Controls Bar -->
    <div class="controls-bar">
        <div class="search-section">
            <MudTextField @bind-Value="_searchText"
                          Placeholder="ابحث باسم الصلاحية أو Form Name..."
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search"
                          Immediate="true"
                          OnKeyUp="OnSearchChanged"
                          Class="search-field" />
        </div>

        <div class="filters-section">
            <div class="filter-group">
                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" Class="filter-icon" />
                <MudSelect T="string"
                           @bind-Value="_filterCategory"
                           Variant="Variant.Outlined"
                           Label="الفئة"
                           Clearable="true"
                           Class="category-select">
                    <MudSelectItem Value="@("all")">الكل</MudSelectItem>
                    <MudSelectItem Value="@("Administration")">Administration</MudSelectItem>
                    <MudSelectItem Value="@("Forms")">Forms</MudSelectItem>
                    <MudSelectItem Value="@("Reports")">Reports</MudSelectItem>
                    <MudSelectItem Value="@("Settings")">Settings</MudSelectItem>
                </MudSelect>
            </div>

            @if (!string.IsNullOrWhiteSpace(_searchText) || (_filterCategory != "all" && !string.IsNullOrWhiteSpace(_filterCategory)))
            {
                <MudButton OnClick="ClearFilters"
                           Variant="Variant.Text"
                           StartIcon="@Icons.Material.Rounded.Clear"
                           Size="Size.Small"
                           Class="clear-btn">
                    مسح الفلاتر
                </MudButton>
            }
        </div>

        <div class="stats-chip">
            <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" />
            <span class="stat-label">عدد الصلاحيات</span>
            <span class="stat-value">@_filteredPermissions.Count</span>
        </div>
    </div>

    <!-- Permissions Table -->
    <div class="table-container">
        @if (!_filteredPermissions.Any())
        {
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.SecurityUpdateWarning" Size="Size.Large" />
                <h3>لا توجد صلاحيات</h3>
                <p>@(string.IsNullOrWhiteSpace(_searchText) && _filterCategory == "all" ? "لم يتم إضافة أي صلاحيات بعد" : "لم يتم العثور على صلاحيات مطابقة للبحث")</p>
            </div>
        }
        else
        {
            <MudTable Items="_filteredPermissions"
                      Hover="true"
                      Breakpoint="Breakpoint.Sm"
                      RowsPerPage="20"
                      Elevation="0"
                      Class="permissions-table">

                <HeaderContent>
                    <MudTh Class="table-header">
                        <div class="header-cell">
                            <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" />
                            <span>الكود</span>
                        </div>
                    </MudTh>
                    <MudTh Class="table-header">
                        <div class="header-cell">
                            <MudIcon Icon="@Icons.Material.Filled.Label" Size="Size.Small" />
                            <span>اسم الصلاحية</span>
                        </div>
                    </MudTh>
                    <MudTh Class="table-header">
                        <div class="header-cell">
                            <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
                            <span>Form Name</span>
                        </div>
                    </MudTh>
                    <MudTh Class="table-header">
                        <div class="header-cell">
                            <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                            <span>الفئة</span>
                        </div>
                    </MudTh>
                    <MudTh Class="table-header">
                        <div class="header-cell">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
                            <span>الوصف</span>
                        </div>
                    </MudTh>
                    <MudTh Class="table-header actions-header">
                        <span>الإجراءات</span>
                    </MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="الكود">
                        <span class="permission-id">@context.PermissionId</span>
                    </MudTd>
                    <MudTd DataLabel="اسم الصلاحية">
                        <strong class="permission-name">@context.PermissionName</strong>
                    </MudTd>
                    <MudTd DataLabel="Form Name">
                        <span class="form-name">@context.FormName</span>
                    </MudTd>
                    <MudTd DataLabel="الفئة">
                        <span class="category-badge @GetCategoryClass(context.Category)">
                            @GetCategoryIcon(context.Category)
                            @context.Category
                        </span>
                    </MudTd>
                    <MudTd DataLabel="الوصف">
                        <span class="description-text">@(string.IsNullOrWhiteSpace(context.Description) ? "-" : context.Description)</span>
                    </MudTd>
                    <MudTd DataLabel="الإجراءات">
                        <div class="action-buttons">
                            @if (HasPermission("frm_AddPermission", "Edit"))
                            {
                                <MudTooltip Text="تعديل">
                                    <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                                   Color="Color.Warning"
                                                   Size="Size.Small"
                                                   Class="action-btn edit-btn"
                                                   OnClick="() => OpenForm(context)" />
                                </MudTooltip>
                            }
                            @if (HasPermission("frm_AddPermission", "Delete"))
                            {
                                <MudTooltip Text="حذف">
                                    <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   Class="action-btn delete-btn"
                                                   OnClick="() => OpenDeleteDialog(context)" />
                                </MudTooltip>
                            }
                        </div>
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <div class="no-records">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" />
                        <p>لا يوجد صلاحيات مطابقة</p>
                    </div>
                </NoRecordsContent>

            </MudTable>
        }
    </div>

</div>

<!-- Add/Edit Permission Form -->
@if (_formOpen)
{
    <MudOverlay Visible="true" Class="form-overlay">
        <div class="permission-form">
            <div class="form-header">
                <div class="form-title">
                    <MudIcon Icon="@Icons.Material.Filled.Shield" />
                    <h2>@(_editingPermission != null ? "تعديل صلاحية" : "إضافة صلاحية جديدة")</h2>
                </div>
                <button class="close-btn" @onclick="CloseForm">
                    <MudIcon Icon="@Icons.Material.Filled.Close" />
                </button>
            </div>

            <div class="form-body">
                <div class="form-field">
                    <label>اسم الصلاحية <span class="required">*</span></label>
                    <MudTextField @bind-Value="_formModel.PermissionName"
                                  Variant="Variant.Outlined"
                                  Placeholder="أدخل اسم الصلاحية"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Label"
                                  FullWidth="true" />
                </div>

                <div class="form-field">
                    <label>Form Name <span class="required">*</span></label>
                    <MudTextField @bind-Value="_formModel.FormName"
                                  Variant="Variant.Outlined"
                                  Placeholder="frm_Example"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Code"
                                  FullWidth="true"
                                  Class="ltr-field" />
                    <span class="field-hint">مثال: frm_Users, frm_Products</span>
                </div>

                <div class="form-field">
                    <label>الفئة <span class="required">*</span></label>
                    <MudSelect @bind-Value="_formModel.Category"
                               Variant="Variant.Outlined"
                               Placeholder="اختر الفئة"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Category"
                               FullWidth="true">
                        <MudSelectItem Value="@("Administration")">
                            <div class="category-option">
                                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" />
                                <span>Administration</span>
                            </div>
                        </MudSelectItem>
                        <MudSelectItem Value="@("Forms")">
                            <div class="category-option">
                                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" />
                                <span>Forms</span>
                            </div>
                        </MudSelectItem>
                        <MudSelectItem Value="@("Reports")">
                            <div class="category-option">
                                <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" />
                                <span>Reports</span>
                            </div>
                        </MudSelectItem>
                        <MudSelectItem Value="@("Settings")">
                            <div class="category-option">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" />
                                <span>Settings</span>
                            </div>
                        </MudSelectItem>
                    </MudSelect>
                </div>

                <div class="form-field">
                    <label>الوصف</label>
                    <MudTextField @bind-Value="_formModel.Description"
                                  Variant="Variant.Outlined"
                                  Lines="3"
                                  Placeholder="أدخل وصف الصلاحية..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Description"
                                  FullWidth="true" />
                </div>
            </div>

            <div class="form-footer">
                <MudButton OnClick="CloseForm" 
                           Variant="Variant.Outlined" 
                           Size="Size.Large"
                           Class="cancel-btn">
                    إلغاء
                </MudButton>
                <MudButton OnClick="SavePermission" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           Size="Size.Large"
                           Class="save-btn">
                    @(_editingPermission != null ? "تحديث" : "حفظ")
                </MudButton>
            </div>
        </div>
    </MudOverlay>
}

<!-- Delete Confirmation Dialog -->
@if (_deleteDialogOpen)
{
    <MudOverlay Visible="true" Class="delete-overlay">
        <div class="delete-dialog">
            <div class="dialog-icon">
                <MudIcon Icon="@Icons.Material.Rounded.Warning" />
            </div>
            <h2>تأكيد الحذف</h2>
            <p>هل أنت متأكد من حذف هذه الصلاحية؟</p>
            <div class="permission-info">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" />
                <strong>@_permToDelete?.PermissionName</strong>
            </div>
            <p class="warning-text">لا يمكن التراجع عن هذا الإجراء</p>
            <div class="dialog-actions">
                <MudButton OnClick="CancelDelete" 
                           Variant="Variant.Outlined" 
                           Color="Color.Default"
                           Class="cancel-btn">
                    إلغاء
                </MudButton>
                <MudButton OnClick="ConfirmDelete" 
                           Variant="Variant.Filled" 
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           Class="confirm-btn">
                    نعم، احذف
                </MudButton>
            </div>
        </div>
    </MudOverlay>
}

<style>
    .permissions-page {
        padding: 2rem;
        max-width: 1600px;
        margin: 0 auto;
        direction: rtl;
    }

    /* Header */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .page-icon {
        width: 64px;
        height: 64px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .page-icon .mud-icon-root {
        font-size: 2rem;
    }

    .header-text h1 {
        color: white;
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
    }

    .header-text .subtitle {
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
        font-size: 1rem;
    }

    .add-btn {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2) !important;
        font-weight: 600 !important;
    }

    /* Controls Bar */
    .controls-bar {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .search-section {
        flex: 1;
        min-width: 300px;
    }

    .search-field {
        width: 100%;
    }

    .filters-section {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .filter-icon {
        color: #667eea;
    }

    .category-select {
        min-width: 180px;
    }

    .clear-btn {
        color: #ef4444 !important;
    }

    .stats-chip {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .stats-chip .mud-icon-root {
        font-size: 1.25rem;
    }

    .stat-label {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .stat-value {
        font-size: 1.25rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.2);
        padding: 0.25rem 0.75rem;
        border-radius: 8px;
    }

    /* Table Container */
    .table-container {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
    }

    .permissions-table {
        background: transparent !important;
    }

    .permissions-table .mud-table-head {
        background: linear-gradient(135deg, #f8f9fc 0%, #eef1f7 100%);
    }

    .table-header {
        font-weight: 700 !important;
        color: #1a202c !important;
        padding: 1.25rem 1rem !important;
    }

    .header-cell {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .header-cell .mud-icon-root {
        color: #667eea;
        font-size: 1.1rem;
    }

    .actions-header {
        text-align: center !important;
    }

    .permissions-table .mud-table-row {
        transition: all 0.3s ease;
    }

    .permissions-table .mud-table-row:hover {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%) !important;
    }

    .permissions-table .mud-table-cell {
        padding: 1rem !important;
        vertical-align: middle !important;
    }

    /* Table Cells */
    .permission-id {
        display: inline-block;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        font-family: 'Courier New', monospace;
        font-size: 0.9rem;
    }

    .permission-name {
        color: #1a202c;
        font-size: 1rem;
    }

    .form-name {
        font-family: 'Courier New', monospace;
        color: #667eea;
        font-weight: 600;
        direction: ltr;
        display: inline-block;
    }

    .category-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        color: white;
    }

    .category-badge.administration {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    }

    .category-badge.forms {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    }

    .category-badge.reports {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    }

    .category-badge.settings {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    }

    .description-text {
        color: #718096;
        font-size: 0.9rem;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
    }

    .action-btn {
        transition: all 0.3s ease !important;
    }

    .edit-btn:hover {
        transform: scale(1.15) !important;
        box-shadow: 0 4px 15px rgba(245, 158, 11, 0.4) !important;
    }

    .delete-btn:hover {
        transform: scale(1.15) !important;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4) !important;
    }

    /* Empty State */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        text-align: center;
    }

    .empty-state .mud-icon-root {
        font-size: 5rem;
        color: #e2e8f0;
        margin-bottom: 1.5rem;
    }

    .empty-state h3 {
        color: #2d3748;
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0 0 0.5rem 0;
    }

    .empty-state p {
        color: #718096;
        font-size: 1.1rem;
        margin: 0;
    }

    .no-records {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 3rem 2rem;
        text-align: center;
    }

    .no-records .mud-icon-root {
        font-size: 4rem;
        color: #e2e8f0;
        margin-bottom: 1rem;
    }

    .no-records p {
        color: #718096;
        font-size: 1rem;
        margin: 0;
    }

    /* Permission Form */
    .form-overlay {
        backdrop-filter: blur(8px);
    }

    .permission-form {
        background: white;
        border-radius: 24px;
        max-width: 600px;
        margin: 10vh auto;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }

    .form-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .form-title {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .form-title .mud-icon-root {
        font-size: 2rem;
    }

    .form-title h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
    }

    .close-btn {
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.2);
        border: none;
        border-radius: 10px;
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .close-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: rotate(90deg);
    }

    .form-body {
        padding: 2rem;
    }

    .form-field {
        margin-bottom: 1.5rem;
    }

    .form-field:last-child {
        margin-bottom: 0;
    }

    .form-field label {
        display: block;
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .required {
        color: #ef4444;
    }

    .field-hint {
        display: block;
        color: #718096;
        font-size: 0.85rem;
        margin-top: 0.5rem;
    }

    .ltr-field input {
        direction: ltr;
        text-align: left;
    }

    .category-option {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .form-footer {
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
        padding: 2rem;
        background: linear-gradient(135deg, #f8f9fc 0%, #eef1f7 100%);
    }

    .cancel-btn,
    .save-btn {
        padding: 0.875rem 2rem !important;
        font-weight: 600 !important;
    }

    .save-btn {
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4) !important;
    }

    /* Delete Dialog */
    .delete-overlay {
        backdrop-filter: blur(8px);
    }

    .delete-dialog {
        background: white;
        border-radius: 24px;
        padding: 2.5rem;
        max-width: 450px;
        margin: 20vh auto;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        text-align: center;
        border: 2px solid rgba(239, 68, 68, 0.2);
    }

    .dialog-icon {
        width: 80px;
        height: 80px;
        background: rgba(239, 68, 68, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
    }

    .dialog-icon .mud-icon-root {
        font-size: 3rem;
        color: #ef4444;
    }

    .delete-dialog h2 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1a202c;
        margin: 0 0 1rem 0;
    }

    .delete-dialog > p {
        color: #718096;
        font-size: 1rem;
        margin: 0 0 1.5rem 0;
    }

    .permission-info {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        background: linear-gradient(135deg, #f8f9fc 0%, #eef1f7 100%);
        padding: 1rem 1.5rem;
        border-radius: 12px;
        margin-bottom: 1rem;
    }

    .permission-info .mud-icon-root {
        color: #667eea;
    }

    .permission-info strong {
        color: #1a202c;
        font-size: 1.1rem;
    }

