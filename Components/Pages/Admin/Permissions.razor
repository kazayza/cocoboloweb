@code {
    private List<Permission> _allPermissions = new();
    private List<Permission> _filteredPermissions = new();
    private string _searchText = "";
    private string _filterCategory = "all";
    private ClaimsPrincipal? _currentUser;

    private bool _formOpen = false;
    private Permission? _editingPermission;
    private PermissionFormModel _formModel = new();

    private bool _deleteDialogOpen = false;
    private Permission? _permToDelete;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User;
        await LoadPermissions();
    }

    private async Task LoadPermissions()
    {
        _allPermissions = await Db.Permissions.OrderBy(p => p.PermissionId).ToListAsync();
        ApplyFilters();
    }

    private async void OnSearchChanged(KeyboardEventArgs e)
    {
        ApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    private void ApplyFilters()
    {
        var query = _allPermissions.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var search = _searchText.Trim();
            query = query.Where(p =>
                (p.PermissionName != null && p.PermissionName.ContainsArabic(search)) ||
                (p.FormName != null && p.FormName.ContainsArabic(search)) ||
                (p.Description != null && p.Description.ContainsArabic(search))
            );
        }

        if (!string.IsNullOrWhiteSpace(_filterCategory) && _filterCategory != "all")
        {
            query = query.Where(p => p.Category == _filterCategory);
        }

        _filteredPermissions = query.ToList();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        _searchText = "";
        _filterCategory = "all";
        ApplyFilters();
    }

    private void OpenForm(Permission? permission)
    {
        _editingPermission = permission;
        
        if (permission != null)
        {
            _formModel = new PermissionFormModel
            {
                PermissionName = permission.PermissionName,
                FormName = permission.FormName ?? "",
                Category = permission.Category ?? "",
                Description = permission.Description ?? ""
            };
        }
        else
        {
            _formModel = new PermissionFormModel();
        }
        
        _formOpen = true;
        StateHasChanged();
    }

    private void CloseForm()
    {
        _formOpen = false;
        _editingPermission = null;
        _formModel = new PermissionFormModel();
        StateHasChanged();
    }

    private async Task SavePermission()
    {
        if (string.IsNullOrWhiteSpace(_formModel.PermissionName) || 
            string.IsNullOrWhiteSpace(_formModel.FormName) ||
            string.IsNullOrWhiteSpace(_formModel.Category))
        {
            return;
        }

        if (_editingPermission != null)
        {
            _editingPermission.PermissionName = _formModel.PermissionName;
            _editingPermission.FormName = _formModel.FormName;
            _editingPermission.Category = _formModel.Category;
            _editingPermission.Description = _formModel.Description;
            Db.Permissions.Update(_editingPermission);
        }
        else
        {
            var newPermission = new Permission
            {
                PermissionName = _formModel.PermissionName,
                FormName = _formModel.FormName,
                Category = _formModel.Category,
                Description = _formModel.Description,
                CreatedBy = _currentUser?.Identity?.Name ?? "system",
                CreatedAt = DateTime.Now
            };
            Db.Permissions.Add(newPermission);
        }

        await Db.SaveChangesAsync();
        CloseForm();
        await LoadPermissions();
    }

    private void OpenDeleteDialog(Permission permission)
    {
        _permToDelete = permission;
        _deleteDialogOpen = true;
        StateHasChanged();
    }

    private async Task ConfirmDelete()
    {
        if (_permToDelete != null)
        {
            Db.Permissions.Remove(_permToDelete);
            await Db.SaveChangesAsync();
            await LoadPermissions();
        }
        _deleteDialogOpen = false;
        _permToDelete = null;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        _deleteDialogOpen = false;
        _permToDelete = null;
        StateHasChanged();
    }

    private bool HasPermission(string formName, string action)
    {
        if (_currentUser == null || !_currentUser.Identity!.IsAuthenticated)
            return false;

        return _currentUser.Claims.Any(c =>
            c.Type == "Permission" &&
            c.Value == $"{formName}:{action}");
    }

    private string GetCategoryClass(string? category)
    {
        return category?.ToLower() ?? "";
    }

    private string GetCategoryIcon(string? category)
    {
        return category switch
        {
            "Administration" => "🔐",
            "Forms" => "📋",
            "Reports" => "📊",
            "Settings" => "⚙️",
            _ => "📌"
        };
    }

    private class PermissionFormModel
    {
        public string PermissionName { get; set; } = "";
        public string FormName { get; set; } = "";
        public string Category { get; set; } = "Forms";
        public string Description { get; set; } = "";
    }
}
