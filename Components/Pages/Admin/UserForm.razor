@page "/admin/users/new"
@page "/admin/users/{UserId:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using Microsoft.EntityFrameworkCore
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.Services
@inject db24804Context Db
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="user-form-page">

    <!-- Header Section -->
    <div class="page-header">
        <div class="header-content">
            <button class="back-btn" @onclick="Cancel">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" />
            </button>
            
            <div class="header-info">
                <h1>@(_isEdit ? "تعديل مستخدم" : "إضافة مستخدم جديد")</h1>
                <p class="subtitle">@(_isEdit ? "تحديث بيانات المستخدم وصلاحياته" : "إنشاء حساب مستخدم جديد في النظام")</p>
            </div>

            @if (_isEdit && _model.LastLogin.HasValue)
            {
                <div class="last-login-badge">
                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" />
                    <div>
                        <span class="label">آخر دخول</span>
                        <span class="value">@_model.LastLogin.Value.ToString("yyyy/MM/dd HH:mm")</span>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-error" : "alert-success")">
            <MudIcon Icon="@(_isError ? Icons.Material.Filled.Error : Icons.Material.Filled.CheckCircle)" />
            <span>@_message</span>
        </div>
    }

    <!-- Form Container -->
    <div class="form-container">
        <MudForm @ref="_form">
            
            <!-- معلومات الحساب -->
            <div class="form-section">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" />
                    <h2>معلومات الحساب</h2>
                </div>
                <div class="section-body">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <div class="form-field">
                                <label>اسم المستخدم <span class="required">*</span></label>
                                <MudTextField @bind-Value="_model.Username"
                                              Variant="Variant.Outlined"
                                              Placeholder="أدخل اسم المستخدم"
                                              Required="true"
                                              ReadOnly="_isEdit"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Person"
                                              Class="@(_isEdit ? "readonly-field" : "")" />
                                @if (_isEdit)
                                {
                                    <span class="field-hint">لا يمكن تعديل اسم المستخدم</span>
                                }
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <div class="form-field">
                                <label>الاسم الكامل <span class="required">*</span></label>
                                <MudTextField @bind-Value="_model.FullName"
                                              Variant="Variant.Outlined"
                                              Placeholder="أدخل الاسم الكامل"
                                              Required="true"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Badge" />
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <div class="form-field">
                                <label>
                                    كلمة المرور 
                                    @if (_isEdit)
                                    {
                                        <span class="optional">(اتركها فارغة للإبقاء على القديمة)</span>
                                    }
                                    else
                                    {
                                        <span class="required">*</span>
                                    }
                                </label>
                                <MudTextField @bind-Value="_model.Password"
                                              Variant="Variant.Outlined"
                                              InputType="InputType.Password"
                                              Placeholder="••••••••"
                                              Required="@(!_isEdit)"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Lock" />
                                @if (!_isEdit)
                                {
                                    <span class="field-hint">يجب أن تكون 8 أحرف على الأقل</span>
                                }
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <div class="form-field">
                                <label>البريد الإلكتروني</label>
                                <MudTextField @bind-Value="_model.Email"
                                              Variant="Variant.Outlined"
                                              Placeholder="example@domain.com"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Email" />
                            </div>
                        </MudItem>
                    </MudGrid>
                </div>
            </div>

            <!-- الصلاحيات والحالة -->
            <div class="form-section">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.Shield" />
                    <h2>الصلاحيات والحالة</h2>
                </div>
                <div class="section-body">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <div class="form-field">
                                <label>الدور الوظيفي <span class="required">*</span></label>
                                <MudSelect @bind-Value="_model.Role"
                                           Variant="Variant.Outlined"
                                           Placeholder="اختر الدور"
                                           Required="true"
                                           Adornment="Adornment.Start"
                                           AdornmentIcon="@Icons.Material.Filled.WorkspacePremium">
                                    <MudSelectItem Value="@("Admin")">
                                        <div class="role-option">
                                            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" />
                                            <span>مدير النظام</span>
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Manager")">
                                        <div class="role-option">
                                            <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Size="Size.Small" />
                                            <span>مدير</span>
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Sales")">
                                        <div class="role-option">
                                            <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Size="Size.Small" />
                                            <span>مندوب مبيعات</span>
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("Accountant")">
                                        <div class="role-option">
                                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" />
                                            <span>محاسب</span>
                                        </div>
                                    </MudSelectItem>
                                    <MudSelectItem Value="@("User")">
                                        <div class="role-option">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                            <span>مستخدم</span>
                                        </div>
                                    </MudSelectItem>
                                </MudSelect>
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <div class="form-field">
                                <label>حالة الحساب</label>
                                <div class="status-toggle">
                                    <button type="button" 
                                            class="status-btn @(_model.IsActive ? "active" : "")"
                                            @onclick="() => _model.IsActive = true">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                        <span>نشط</span>
                                    </button>
                                    <button type="button" 
                                            class="status-btn @(!_model.IsActive ? "inactive" : "")"
                                            @onclick="() => _model.IsActive = false">
                                        <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" />
                                        <span>غير نشط</span>
                                    </button>
                                </div>
                                <span class="field-hint">
                                    @(_model.IsActive ? "المستخدم يمكنه تسجيل الدخول" : "المستخدم لا يمكنه تسجيل الدخول")
                                </span>
                            </div>
                        </MudItem>
                    </MudGrid>
                </div>
            </div>

            <!-- أزرار الحفظ والإلغاء -->
            <div class="form-actions">
                <MudButton Variant="Variant.Outlined"
                           OnClick="Cancel"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Close"
                           Class="cancel-btn"
                           Disabled="_isSaving">
                    إلغاء
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveUser"
                           Size="Size.Large"
                           StartIcon="@(_isSaving ? "" : Icons.Material.Filled.Save)"
                           Class="save-btn"
                           Disabled="_isSaving">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>جاري الحفظ...</span>
                    }
                    else
                    {
                        <span>@(_isEdit ? "تحديث البيانات" : "حفظ المستخدم")</span>
                    }
                </MudButton>
            </div>

        </MudForm>
    </div>

</div>

<style>
    .user-form-page {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        direction: rtl;
    }

    /* Header */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .back-btn {
        width: 48px;
        height: 48px;
        background: rgba(255, 255, 255, 0.2);
        border: none;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .back-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: translateX(5px);
    }

    .header-info {
        flex: 1;
    }

    .header-info h1 {
        color: white;
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 0.5rem 0;
    }

    .header-info .subtitle {
        color: rgba(255, 255, 255, 0.9);
        font-size: 1rem;
        margin: 0;
    }

    .last-login-badge {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(255, 255, 255, 0.2);
        padding: 0.75rem 1.25rem;
        border-radius: 12px;
        color: white;
    }

    .last-login-badge .label {
        display: block;
        font-size: 0.75rem;
        opacity: 0.9;
    }

    .last-login-badge .value {
        display: block;
        font-size: 0.95rem;
        font-weight: 600;
    }

    /* Alert */
    .alert {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.5rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .alert-error {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: 2px solid rgba(239, 68, 68, 0.3);
    }

    .alert-success {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        border: 2px solid rgba(16, 185, 129, 0.3);
    }

    /* Form Container */
    .form-container {
        background: white;
        border-radius: 20px;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    /* Form Sections */
    .form-section {
        border-bottom: 2px solid #f1f5f9;
    }

    .form-section:last-of-type {
        border-bottom: none;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 2rem;
        background: linear-gradient(135deg, #f8f9fc 0%, #eef1f7 100%);
    }

    .section-header .mud-icon-root {
        color: #667eea;
        font-size: 1.75rem;
    }

    .section-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1a202c;
        margin: 0;
    }

    .section-body {
        padding: 2rem;
    }

    /* Form Fields */
    .form-field {
        margin-bottom: 1.5rem;
    }

    .form-field:last-child {
        margin-bottom: 0;
    }

    .form-field label {
        display: block;
        color: #2d3748;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .required {
        color: #ef4444;
    }

    .optional {
        color: #718096;
        font-weight: 400;
        font-size: 0.85rem;
    }

    .field-hint {
        display: block;
        color: #718096;
        font-size: 0.85rem;
        margin-top: 0.5rem;
    }

    .readonly-field {
        background: #f8f9fc !important;
        opacity: 0.8;
    }

    /* Role Options */
    .role-option {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    /* Status Toggle */
    .status-toggle {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.5rem;
    }

    .status-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.875rem 1.5rem;
        border: 2px solid #e2e8f0;
        background: white;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        color: #718096;
        transition: all 0.3s ease;
    }

    .status-btn:hover {
        border-color: #cbd5e0;
        background: #f8f9fc;
    }

    .status-btn.active {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        border-color: #10b981;
        color: white;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }

    .status-btn.inactive {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        border-color: #ef4444;
        color: white;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
        padding: 2rem;
        background: linear-gradient(135deg, #f8f9fc 0%, #eef1f7 100%);
    }

    .cancel-btn,
    .save-btn {
        padding: 0.875rem 2.5rem !important;
        font-weight: 600 !important;
    }

    .save-btn {
        box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4) !important;
    }

    .save-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    /* Responsive */
    @@media (max-width: 960px) {
        .user-form-page {
            padding: 1rem;
        }

        .page-header {
            padding: 1.5rem;
        }

        .header-info h1 {
            font-size: 1.5rem;
        }

        .section-body {
            padding: 1.5rem;
        }

        .form-actions {
            flex-direction: column-reverse;
        }

        .cancel-btn,
        .save-btn {
            width: 100%;
        }

        .status-toggle {
            flex-direction: column;
        }
    }
</style>

@code {
    [Parameter]
    public int? UserId { get; set; }

    private MudForm? _form;
    private bool _isEdit = false;
    private bool _isSaving = false;
    private bool _isError = false;
    private string _message = "";
    private ClaimsPrincipal? _currentUser;

    private UserEditModel _model = new()
    {
        IsActive = true,
        Role = "User"
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User;

        if (UserId.HasValue)
        {
            _isEdit = true;
            await LoadUser(UserId.Value);
        }
    }

    private async Task LoadUser(int id)
    {
        var user = await Db.Users.FirstOrDefaultAsync(u => u.UserId == id);
        
        if (user != null)
        {
            _model = new UserEditModel
            {
                UserId = user.UserId,
                Username = user.Username,
                Password = "",
                FullName = user.FullName,
                Email = user.Email,
                Role = user.Role ?? "User",
                IsActive = user.IsActive ?? true,
                LastLogin = user.LastLogin
            };
        }
        else
        {
            _isError = true;
            _message = "المستخدم غير موجود";
        }
    }

    private async Task SaveUser()
    {
        _isSaving = true;
        _isError = false;
        _message = "";

        if (!HasPermission("frm_AddUser", _isEdit ? "Edit" : "Add"))
        {
            _isError = true;
            _message = "ليس لديك صلاحية للقيام بهذا الإجراء";
            _isSaving = false;
            StateHasChanged();
            return;
        }

        if (string.IsNullOrWhiteSpace(_model.Username) || string.IsNullOrWhiteSpace(_model.FullName))
        {
            _isError = true;
            _message = "اسم المستخدم والاسم الكامل مطلوبان";
            _isSaving = false;
            StateHasChanged();
            return;
        }

        if (!_isEdit && string.IsNullOrWhiteSpace(_model.Password))
        {
            _isError = true;
            _message = "كلمة المرور مطلوبة للمستخدم الجديد";
            _isSaving = false;
            StateHasChanged();
            return;
        }

        try
        {
            if (_isEdit)
            {
                var user = await Db.Users.FirstOrDefaultAsync(u => u.UserId == _model.UserId);
                if (user == null)
                {
                    _isError = true;
                    _message = "المستخدم غير موجود";
                    _isSaving = false;
                    StateHasChanged();
                    return;
                }

                user.FullName = _model.FullName;
                user.Email = _model.Email;
                user.Role = _model.Role;
                user.IsActive = _model.IsActive;

                if (!string.IsNullOrWhiteSpace(_model.Password))
                {
                    user.Password = _model.Password;
                }

                Db.Users.Update(user);
                await Db.SaveChangesAsync();
                
                _isError = false;
                _message = "تم تحديث المستخدم بنجاح";
            }
            else
            {
                var exists = await Db.Users.AnyAsync(u => u.Username == _model.Username);
                if (exists)
                {
                    _isError = true;
                    _message = "اسم المستخدم موجود بالفعل";
                    _isSaving = false;
                    StateHasChanged();
                    return;
                }

                var newUser = new COCOBOLOERPNEW.Models.User
                {
                    Username = _model.Username,
                    Password = _model.Password,
                    FullName = _model.FullName,
                    Email = _model.Email,
                    Role = _model.Role,
                    IsActive = _model.IsActive,
                    CreatedAt = DateTime.Now,
                    CreatedBy = _currentUser?.Identity?.Name ?? "System"
                };

                Db.Users.Add(newUser);
                await Db.SaveChangesAsync();

                _isError = false;
                _message = "تم إضافة المستخدم بنجاح";
            }

            await Task.Delay(1500);
            Navigation.NavigateTo("/admin/users");
        }
        catch (Exception ex)
        {
            _isError = true;
            _message = $"حدث خطأ: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/admin/users");
    }

    private bool HasPermission(string formName, string action)
    {
        if (_currentUser == null || !_currentUser.Identity!.IsAuthenticated)
            return false;

        return _currentUser.Claims.Any(c =>
            c.Type == "Permission" &&
            c.Value == $"{formName}:{action}");
    }

    public class UserEditModel
    {
        public int UserId { get; set; }
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string FullName { get; set; } = "";
        public string? Email { get; set; }
        public string Role { get; set; } = "User";
        public bool IsActive { get; set; } = true;
        public DateTime? LastLogin { get; set; }
    }
}
