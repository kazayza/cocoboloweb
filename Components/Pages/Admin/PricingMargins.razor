@code {
    private bool _authorized = false;
    private bool _isLoading = true;
    private bool _editDialogOpen = false;
    private bool _isSaving = false;
    private string? _dialogError;
    private string? _currentUserName;

    private PricingMargin? _activeMargin;
    private List<PricingMargin> _allMargins = new();

    // حقول الـ Dialog
    private decimal _newCClass;
    private decimal _newPremium;
    private decimal _newElite;
    private string _newReason = "";

    // حاسبة المعاينة
    private decimal _previewCost = 1000;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var role = auth.User.FindFirst(ClaimTypes.Role)?.Value;
        _currentUserName = auth.User.Identity?.Name;

        _authorized = role is "Admin" or "AccountManager";
        if (!_authorized) return;

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            _allMargins = await Db.PricingMargins
                .OrderByDescending(m => m.ChangedAt)
                .ToListAsync();

            _activeMargin = _allMargins.FirstOrDefault(m => m.IsActive);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void OpenEditDialog()
    {
        _newCClass  = _activeMargin?.CClassMargin  ?? 0;
        _newPremium = _activeMargin?.PremiumMargin ?? 0;
        _newElite   = _activeMargin?.EliteMargin   ?? 0;
        _newReason  = "";
        _dialogError = null;
        _editDialogOpen = true;
    }

    private void CloseDialog()
    {
        if (_isSaving) return;
        _editDialogOpen = false;
    }

    private async Task SaveMargin()
    {
        // Validation
        if (string.IsNullOrWhiteSpace(_newReason))
        {
            _dialogError = "سبب التغيير مطلوب";
            return;
        }
        if (_newCClass <= 0 || _newPremium <= 0 || _newElite <= 0)
        {
            _dialogError = "يجب أن تكون جميع النسب أكبر من صفر";
            return;
        }

        _isSaving = true;
        _dialogError = null;
        StateHasChanged();

        try
        {
            // 1. نعمل الـ records القديمة inactive
            var oldActive = await Db.PricingMargins.Where(m => m.IsActive).ToListAsync();
            foreach (var old in oldActive)
                old.IsActive = false;

            // 2. نضيف record جديد
            var newMargin = new PricingMargin
            {
                CClassMargin    = _newCClass,
                PremiumMargin   = _newPremium,
                EliteMargin     = _newElite,
                IsActive        = true,
                PreviousCClass  = _activeMargin?.CClassMargin,
                PreviousPremium = _activeMargin?.PremiumMargin,
                PreviousElite   = _activeMargin?.EliteMargin,
                ChangeReason    = _newReason.Trim(),
                ChangedBy       = _currentUserName ?? "System",
                ChangedAt       = DateTime.Now
            };
            Db.PricingMargins.Add(newMargin);
            await Db.SaveChangesAsync();

            // 3. Audit
            await AuditService.LogAsync(
                "PricingMargins",
                "تعديل نسب الأرباح",
                newMargin.MarginId.ToString(),
                _activeMargin,
                newMargin,
                _currentUserName ?? "System"
            );

            Snackbar.Add("✅ تم حفظ نسب الأرباح الجديدة وتفعيلها بنجاح", Severity.Success);
            _editDialogOpen = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            _dialogError = $"خطأ أثناء الحفظ: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }
}