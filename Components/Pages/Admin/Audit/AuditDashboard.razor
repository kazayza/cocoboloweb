@code {
    private bool _isInitialLoading = true;
    private bool _isLoadingDashboard = false;
    private bool _isLoadingList = false;
    private bool _isExporting = false;
    private int _activeTab = 0;

    private AuditDashboardDto? _dashboard;
    private List<AuditLogListItemDto> _items = new();
    private AuditLogFilterDto _filter = new() { PageSize = 50 };
    private AuditLookupsDto _lookups = new();

    private bool _canExport, _canPurge;
    private bool _initialListLoaded;

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_filter.SearchText) ||
        !string.IsNullOrWhiteSpace(_filter.TableName) ||
        !string.IsNullOrWhiteSpace(_filter.ActionType) ||
        !string.IsNullOrWhiteSpace(_filter.UserName) ||
        _filter.DateFrom.HasValue || _filter.DateTo.HasValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();
        await LoadDashboardAsync();
        _lookups = await AuditService.GetLookupsAsync();
        _isInitialLoading = false;
    }

    private async Task LoadPermissionsAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;

        if (!AuditPermissions.CanView(user))
        {
            Snackbar.Add("ليس لديك صلاحية", MudBlazor.Severity.Error);
            Navigation.NavigateTo("/");
            return;
        }
        _canExport = AuditPermissions.CanExport(user);
        _canPurge  = AuditPermissions.CanPurge(user);
    }

    private async Task LoadDashboardAsync()
    {
        _isLoadingDashboard = true;
        try
        {
            _dashboard = await AuditService.GetDashboardAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load audit dashboard failed");
            Snackbar.Add("تعذّر تحميل لوحة التحكم: " + ex.Message, MudBlazor.Severity.Error);
        }
        finally { _isLoadingDashboard = false; }
    }

    private async Task LoadListAsync()
    {
        _isLoadingList = true;
        try
        {
            var result = await AuditService.GetLogsAsync(_filter);
            _items = result.Items;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Load audit logs failed");
            Snackbar.Add("تعذّر تحميل السجلات: " + ex.Message, MudBlazor.Severity.Error);
        }
        finally { _isLoadingList = false; }
    }

    private async Task OnTabChanged(int idx)
    {
        _activeTab = idx;
        if (idx == 1 && !_initialListLoaded)
        {
            _initialListLoaded = true;
            await LoadListAsync();
        }
    }

    private async Task OnFilterChangedAsync()
    {
        _filter.Page = 1;
        await LoadListAsync();
    }

    private async Task ClearFilters()
    {
        _filter = new AuditLogFilterDto { PageSize = _filter.PageSize };
        await LoadListAsync();
    }

    private async Task RefreshAllAsync()
    {
        await LoadDashboardAsync();
        if (_initialListLoaded) await LoadListAsync();
        _lookups = await AuditService.GetLookupsAsync();
    }

    private async Task OpenDetailAsync(long auditId)
    {
        var parameters = new DialogParameters<AuditDetailDialog>
        {
            { x => x.AuditId, auditId }
        };
        await DialogService.ShowAsync<AuditDetailDialog>("تفاصيل السجل", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
    }

    private async Task ExportAsync()
    {
        _isExporting = true;
        try
        {
            var bytes = await AuditService.ExportToExcelAsync(_filter);
            var fileName = $"audit_log_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            await JS.InvokeVoidAsync("downloadFile", fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
            Snackbar.Add("تم تصدير الملف", MudBlazor.Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("فشل التصدير: " + ex.Message, MudBlazor.Severity.Error);
        }
        finally { _isExporting = false; }
    }

    private async Task OpenPurgeDialog()
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Title, "تنظيف السجلات القديمة" },
            { x => x.Message, "هل تريد حذف كل السجلات الأقدم من 6 شهور؟ هذه العملية لا يمكن التراجع عنها." },
            { x => x.YesText, "نعم، احذف" },
            { x => x.CancelText, "إلغاء" }
        };
        var dlg = await DialogService.ShowAsync<MudMessageBox>("تأكيد", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });
        var res = await dlg.Result;
        if (res is null || res.Canceled) return;

        var cutoff = DateTime.Today.AddMonths(-6);
        var (count, msg) = await AuditService.PurgeOldLogsAsync(cutoff);
        Snackbar.Add(msg, count > 0 ? MudBlazor.Severity.Success : MudBlazor.Severity.Warning);
        if (count > 0) await RefreshAllAsync();
    }

    // ApexCharts Options
    private ApexChartOptions<DailyActivityDto> _activityOptions => new()
    {
        Chart = new Chart { FontFamily = "Cairo, sans-serif", Toolbar = new Toolbar { Show = false }, Background = "transparent", Stacked = true },
        Colors = new List<string> { "#10b981", "#f59e0b", "#ef4444" },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { BorderRadius = 4, ColumnWidth = "60%" } },
        DataLabels = new DataLabels { Enabled = false },
        Legend = new Legend { Position = LegendPosition.Top, HorizontalAlign = ApexCharts.Align.Center, FontFamily = "Cairo, sans-serif" },
        Tooltip = new Tooltip { Shared = true, Intersect = false, Theme = Mode.Light },
        Grid = new Grid { BorderColor = "#e5e7eb", StrokeDashArray = 3 },
        Xaxis = new XAxis { Labels = new XAxisLabels { Style = new AxisLabelStyle { FontFamily = "Cairo, sans-serif", FontSize = "10px" } } }
    };

    private ApexChartOptions<TopTableDto> _topTablesOptions => new()
    {
        Chart = new Chart { FontFamily = "Cairo, sans-serif", Toolbar = new Toolbar { Show = false }, Background = "transparent" },
        Colors = new List<string> { "#d4af37" },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = true, BorderRadius = 6, BarHeight = "70%" } },
        DataLabels = new DataLabels { Enabled = true, Style = new DataLabelsStyle { Colors = new List<string> { "#1a2842" }, FontWeight = 700 } },
        Tooltip = new Tooltip { Y = new TooltipY { Formatter = "function(val) { return val + ' عملية'; }" } },
        Grid = new Grid { BorderColor = "#e5e7eb", StrokeDashArray = 3 }
    };

    // Helpers
    private string GetActionClass(string? action) => (action ?? "").ToLower() switch
    {
        "insert" => "action-insert",
        "update" => "action-update",
        "delete" => "action-delete",
        _        => "action-other"
    };

    private string GetActionBadgeClass(string? action)
    {
        var cls = (action ?? "").ToLower() switch
        {
            "insert" => "badge-insert",
            "update" => "badge-update",
            "delete" => "badge-delete",
            _        => "badge-other"
        };
        return $"action-badge {cls}";
    }

    private string GetActionIcon(string? action) => (action ?? "").ToLower() switch
    {
        "insert" => Icons.Material.Filled.AddCircle,
        "update" => Icons.Material.Filled.Edit,
        "delete" => Icons.Material.Filled.Delete,
        _        => Icons.Material.Filled.Info
    };

    private string GetActionLabel(string? action) => (action ?? "").ToLower() switch
    {
        "insert" => "إضافة",
        "update" => "تعديل",
        "delete" => "حذف",
        _        => action ?? "—"
    };
}