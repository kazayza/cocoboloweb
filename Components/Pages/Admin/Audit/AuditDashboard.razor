@page "/admin/audit"
@page "/admin/audit-log"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using ApexCharts
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using COCOBOLOERPNEW.Components.Pages.Admin.Audit
@using System.Globalization

@inject IAuditService AuditService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider
@inject IJSRuntime JS
@inject ILogger<AuditDashboard> Logger

@attribute [Authorize]

<PageTitle>سجل التدقيق</PageTitle>

@if (_isInitialLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="MudBlazor.Color.Secondary" Size="MudBlazor.Size.Large" Indeterminate="true" />
            </div>
            <MudText Typo="Typo.h6" Class="loading-text">جاري تحميل سجل التدقيق...</MudText>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else
{
<div dir="rtl" class="audit-page">

    <!-- BG -->
    <div class="page-bg-decorations">
        <div class="bg-orb bg-orb-1"></div>
        <div class="bg-orb bg-orb-2"></div>
        <div class="bg-orb bg-orb-3"></div>
    </div>
    <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

    <!-- HEADER -->
    <div class="audit-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-orbs">
                <div class="header-orb orb-1"></div>
                <div class="header-orb orb-2"></div>
                <div class="header-orb orb-3"></div>
            </div>
            <div class="header-grid"></div>
        </div>
        <div class="header-content">
            <div class="header-top">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Policy" Size="MudBlazor.Size.Large" />
                        </div>
                        <div class="header-icon-badge">
                            <MudIcon Icon="@Icons.Material.Filled.Visibility" />
                        </div>
                    </div>
                    <div class="header-text">
                        <div class="header-title-row">
                            <MudText Typo="Typo.h4" Class="header-title">سجل التدقيق</MudText>
                            <div class="header-badge">@(_dashboard?.TotalLogs ?? 0) سجل</div>
                        </div>
                        <MudText Typo="Typo.body2" Class="header-subtitle">
                            مراقبة وتتبع كل العمليات في النظام (للأدمن فقط)
                        </MudText>
                    </div>
                </div>
                <div class="header-actions">
                    @if (_canExport)
                    {
                        <MudButton Variant="Variant.Outlined" Class="btn-export"
                                   StartIcon="@Icons.Material.Filled.FileDownload"
                                   OnClick="ExportAsync"
                                   Disabled="_isExporting">
                            @if (_isExporting)
                            {
                                <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="me-1" />
                            }
                            تصدير Excel
                        </MudButton>
                    }
                    @if (_canPurge)
                    {
                        <MudButton Variant="Variant.Outlined" Class="btn-purge"
                                   StartIcon="@Icons.Material.Filled.DeleteSweep"
                                   OnClick="OpenPurgeDialog">
                            تنظيف القديم
                        </MudButton>
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Class="btn-refresh"
                                   OnClick="RefreshAllAsync"
                                   Disabled="_isLoadingList || _isLoadingDashboard" />
                </div>
            </div>
        </div>
    </div>

    <!-- TABS -->
    <MudTabs Elevation="0" Rounded="true" Class="audit-tabs"
             ActivePanelIndex="@_activeTab" ActivePanelIndexChanged="OnTabChanged">

        <!-- TAB 1: DASHBOARD -->
        <MudTabPanel Text=" لوحة التحكم" Icon="@Icons.Material.Filled.Dashboard">

            @if (_isLoadingDashboard)
            {
                <div class="tab-loading">
                    <MudProgressCircular Color="MudBlazor.Color.Primary" Indeterminate="true" />
                </div>
            }
            else if (_dashboard != null)
            {
                <div class="stats-grid">
                    <div class="stat-card stat-total animate-card" style="--delay: 0.05s">
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.History" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-label">إجمالي السجلات</div>
                                <div class="stat-value">@_dashboard.TotalLogs.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-today animate-card" style="--delay: 0.1s">
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.Today" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-label">اليوم</div>
                                <div class="stat-value">@_dashboard.TodayLogs.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-week animate-card" style="--delay: 0.15s">
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarViewWeek" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-label">آخر 7 أيام</div>
                                <div class="stat-value">@_dashboard.Last7DaysLogs.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-month animate-card" style="--delay: 0.2s">
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-label">آخر 30 يوم</div>
                                <div class="stat-value">@_dashboard.Last30DaysLogs.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-insert animate-card" style="--delay: 0.25s">
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.Add" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-label">إضافات</div>
                                <div class="stat-value">@_dashboard.InsertCount.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-update animate-card" style="--delay: 0.3s">
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-label">تعديلات</div>
                                <div class="stat-value">@_dashboard.UpdateCount.ToString("N0")</div>
                            </div>
                        </div>
                    </div>

                    <div class="stat-card stat-delete animate-card" style="--delay: 0.35s">
                        <div class="stat-accent"></div>
                        <div class="stat-content">
                            <div class="stat-icon-box">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" />
                            </div>
                            <div class="stat-data">
                                <div class="stat-label">حذف</div>
                                <div class="stat-value">@_dashboard.DeleteCount.ToString("N0")</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="charts-grid">
                    <!-- Daily Activity -->
                    <div class="chart-card animate-card" style="--delay: 0.4s">
                        <div class="chart-card-header">
                            <div class="section-icon section-icon-blue">
                                <MudIcon Icon="@Icons.Material.Filled.Timeline" />
                            </div>
                            <div>
                                <div class="section-title">النشاط اليومي</div>
                                <div class="section-subtitle">آخر 14 يوم — تفصيل العمليات</div>
                            </div>
                        </div>
                        <div class="chart-card-body">
                            <ApexChart TItem="DailyActivityDto" Options="_activityOptions" Height="300">
                                <ApexPointSeries TItem="DailyActivityDto" Items="_dashboard.DailyActivity"
                                                 Name="إضافات" SeriesType="SeriesType.Bar"
                                                 XValue="@(e => e.Label)"
                                                 YValue="@(e => (decimal?)e.Insert)" />
                                <ApexPointSeries TItem="DailyActivityDto" Items="_dashboard.DailyActivity"
                                                 Name="تعديلات" SeriesType="SeriesType.Bar"
                                                 XValue="@(e => e.Label)"
                                                 YValue="@(e => (decimal?)e.Update)" />
                                <ApexPointSeries TItem="DailyActivityDto" Items="_dashboard.DailyActivity"
                                                 Name="حذف" SeriesType="SeriesType.Bar"
                                                 XValue="@(e => e.Label)"
                                                 YValue="@(e => (decimal?)e.Delete)" />
                            </ApexChart>
                        </div>
                    </div>

                    <!-- Top Users -->
                    <div class="chart-card animate-card" style="--delay: 0.45s">
                        <div class="chart-card-header">
                            <div class="section-icon section-icon-purple">
                                <MudIcon Icon="@Icons.Material.Filled.PersonPin" />
                            </div>
                            <div>
                                <div class="section-title">أكثر المستخدمين نشاطاً</div>
                                <div class="section-subtitle">في آخر 30 يوم</div>
                            </div>
                        </div>
                        <div class="chart-card-body">
                            @if (_dashboard.TopUsers.Any())
                            {
                                <div class="top-list">
                                    @{ int idx = 0; var maxC = _dashboard.TopUsers.Max(x => x.Count); }
                                    @foreach (var u in _dashboard.TopUsers)
                                    {
                                        idx++;
                                        var pct = maxC > 0 ? (double)u.Count / maxC * 100 : 0;
                                        <div class="top-item">
                                            <div class="top-rank">@idx</div>
                                            <div class="top-body">
                                                <div class="top-head">
                                                    <span class="top-name">@u.UserName</span>
                                                    <span class="top-count">@u.Count</span>
                                                </div>
                                                <div class="top-bar">
                                                    <div class="top-bar-fill" style="width: @pct.ToString("F0", CultureInfo.InvariantCulture)%;"></div>
                                                </div>
                                                @if (u.LastActionAt.HasValue)
                                                {
                                                    <div class="top-meta">آخر نشاط: @u.LastActionAt.Value.ToString("yyyy/MM/dd HH:mm")</div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else { <div class="empty-state">لا توجد بيانات</div> }
                        </div>
                    </div>

                    <!-- Top Tables -->
                    <div class="chart-card animate-card" style="--delay: 0.5s">
                        <div class="chart-card-header">
                            <div class="section-icon section-icon-gold">
                                <MudIcon Icon="@Icons.Material.Filled.TableChart" />
                            </div>
                            <div>
                                <div class="section-title">أكثر الجداول نشاطاً</div>
                                <div class="section-subtitle">في آخر 30 يوم</div>
                            </div>
                        </div>
                        <div class="chart-card-body">
                            @if (_dashboard.TopTables.Any())
                            {
                                <ApexChart TItem="TopTableDto" Options="_topTablesOptions" Height="280">
                                    <ApexPointSeries TItem="TopTableDto" Items="_dashboard.TopTables"
                                                     Name="عمليات" SeriesType="SeriesType.Bar"
                                                     XValue="@(e => TableNameTranslator.Translate(e.TableName))"
                                                     YValue="@(e => (decimal?)e.Count)" />
                                </ApexChart>
                            }
                            else { <div class="empty-state">لا توجد بيانات</div> }
                        </div>
                    </div>

                    <!-- Recent Activity -->
                    <div class="chart-card animate-card" style="--delay: 0.55s">
                        <div class="chart-card-header">
                            <div class="section-icon section-icon-green">
                                <MudIcon Icon="@Icons.Material.Filled.AccessTime" />
                            </div>
                            <div>
                                <div class="section-title">آخر العمليات</div>
                                <div class="section-subtitle">آخر 10 عمليات</div>
                            </div>
                        </div>
                        <div class="chart-card-body recent-body">
                            @if (_dashboard.RecentLogs.Any())
                            {
                                <div class="recent-list">
                                    @foreach (var log in _dashboard.RecentLogs)
                                    {
                                        <div class="recent-item @GetActionClass(log.ActionType)" @onclick="@(() => OpenDetailAsync(log.AuditId))">
                                            <div class="recent-icon">
                                                <MudIcon Icon="@GetActionIcon(log.ActionType)" />
                                            </div>
                                            <div class="recent-body-inner">
                                                <div class="recent-head">
                                                    <span class="recent-user">@(log.LoginName ?? "—")</span>
                                                    <span class="recent-action">@GetActionLabel(log.ActionType)</span>
                                                    <span class="recent-table" title="@log.TableName">@TableNameTranslator.Translate(log.TableName)</span>
                                                </div>
                                                <div class="recent-meta">
                                                    @if (!string.IsNullOrWhiteSpace(log.PrimaryKeyValue))
                                                    {
                                                        <span>المعرّف: <strong>@log.PrimaryKeyValue</strong></span>
                                                    }
                                                    <span class="recent-time">@(log.ActionDate?.ToString("yyyy/MM/dd HH:mm:ss") ?? "—")</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </MudTabPanel>

        <!-- TAB 2: LIST -->
        <MudTabPanel Text=" السجلات الكاملة" Icon="@Icons.Material.Filled.ListAlt">

            <div class="filters-panel">
                <div class="filters-header">
                    <div class="filters-title">
                        <MudIcon Icon="@Icons.Material.Filled.FilterAlt" />
                        <span>الفلاتر والبحث</span>
                    </div>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Text" Size="MudBlazor.Size.Small"
                                   StartIcon="@Icons.Material.Filled.Clear"
                                   OnClick="ClearFilters">مسح الفلاتر</MudButton>
                    }
                </div>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" @bind-Value="_filter.SearchText"
                                      @bind-Value:after="OnFilterChangedAsync"
                                      Placeholder="بحث في المعرّف أو البيانات..."
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      DebounceInterval="400" Immediate="true" Clearable="true" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect T="string" @bind-Value="_filter.TableName"
                                   @bind-Value:after="OnFilterChangedAsync"
                                   Label="الجدول" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var t in _lookups.Tables)
                            {
                                <MudSelectItem T="string" Value="@t">@TableNameTranslator.Translate(t)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect T="string" @bind-Value="_filter.ActionType"
                                   @bind-Value:after="OnFilterChangedAsync"
                                   Label="نوع العملية" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var a in _lookups.Actions)
                            {
                                <MudSelectItem T="string" Value="@a">@a</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect T="string" @bind-Value="_filter.UserName"
                                   @bind-Value:after="OnFilterChangedAsync"
                                   Label="المستخدم" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                            @foreach (var u in _lookups.UserNames)
                            {
                                <MudSelectItem T="string" Value="@u">@u</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="1">
                        <MudDatePicker @bind-Date="_filter.DateFrom"
                                       @bind-Date:after="OnFilterChangedAsync"
                                       Label="من" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" Clearable="true" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudDatePicker @bind-Date="_filter.DateTo"
                                       @bind-Date:after="OnFilterChangedAsync"
                                       Label="إلى" Variant="Variant.Outlined"
                                       Margin="Margin.Dense" Clearable="true" />
                    </MudItem>
                </MudGrid>
            </div>

            <div class="table-card">
                <MudTable T="AuditLogListItemDto" Items="_items" Dense="true" Hover="true" Striped="true"
                          Loading="_isLoadingList" LoadingProgressColor="MudBlazor.Color.Secondary"
                          Class="audit-table" Elevation="0">
                    <NoRecordsContent>
                        <div class="empty-state-big">
                            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="MudBlazor.Size.Large" />
                            <MudText Typo="Typo.h6">لا توجد سجلات</MudText>
                        </div>
                    </NoRecordsContent>
                    <HeaderContent>
                        <MudTh>الرقم</MudTh>
                        <MudTh>التاريخ والوقت</MudTh>
                        <MudTh>المستخدم</MudTh>
                        <MudTh>الجدول</MudTh>
                        <MudTh>العملية</MudTh>
                        <MudTh>المعرّف</MudTh>
                        <MudTh>الجهاز</MudTh>
                        <MudTh Style="text-align:center">البيانات</MudTh>
                        <MudTh Style="text-align:center">عرض</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="ID">
                            <span class="cell-id">#@context.AuditId</span>
                        </MudTd>
                        <MudTd DataLabel="التاريخ">
                            <span class="cell-date">@(context.ActionDate?.ToString("yyyy/MM/dd HH:mm:ss") ?? "—")</span>
                        </MudTd>
                        <MudTd DataLabel="المستخدم">
                            <div class="cell-user">
                                <div class="user-avatar">@(context.LoginName?.Length > 0 ? context.LoginName.Substring(0, 1) : "؟")</div>
                                <span>@(context.LoginName ?? "—")</span>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="الجدول">
                            <div class="cell-table-stack">
                                <span class="cell-table">@TableNameTranslator.Translate(context.TableName)</span>
                                @if (TableNameTranslator.HasTranslation(context.TableName))
                                {
                                    <span class="cell-table-en">@context.TableName</span>
                                }
                            </div>
                        </MudTd>
                        <MudTd DataLabel="العملية">
                            <span class="@GetActionBadgeClass(context.ActionType)">
                                @GetActionLabel(context.ActionType)
                            </span>
                        </MudTd>
                        <MudTd DataLabel="المعرّف">
                            <code class="cell-pk">@(context.PrimaryKeyValue ?? "—")</code>
                        </MudTd>
                        <MudTd DataLabel="الجهاز">
                            <span class="cell-host">@(context.HostName ?? "—")</span>
                        </MudTd>
                        <MudTd DataLabel="بيانات" Style="text-align:center">
                            <div class="data-indicators">
                                @if (context.HasOldData)
                                {
                                    <span class="data-pill data-pill-red" title="بيانات قديمة">قديم</span>
                                }
                                @if (context.HasNewData)
                                {
                                    <span class="data-pill data-pill-green" title="بيانات جديدة">جديد</span>
                                }
                            </div>
                        </MudTd>
                        <MudTd Style="text-align:center">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Size="MudBlazor.Size.Small"
                                           Color="MudBlazor.Color.Info"
                                           OnClick="@(() => OpenDetailAsync(context.AuditId))" />
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="@(new int[] { 25, 50, 100, 200 })"
                                       RowsPerPageString="عدد الصفوف"
                                       InfoFormat="{first_item}-{last_item} من {all_items}" />
                    </PagerContent>
                </MudTable>
            </div>
        </MudTabPanel>
    </MudTabs>
</div>
}

<style>
    .loading-screen { position: fixed; inset: 0; background: linear-gradient(135deg, #0f1a2e 0%, #1a2842 100%); display: flex; align-items: center; justify-content: center; z-index: 9999; }
    .loading-content { text-align: center; }
    .loading-spinner-box { background: rgba(212,175,55,0.1); padding: 24px; border-radius: 50%; border: 2px solid rgba(212,175,55,0.3); margin-bottom: 16px; display: inline-block; }
    .loading-text { color: #d4af37 !important; margin-bottom: 8px; }
    .loading-dots { display: inline-flex; gap: 6px; justify-content: center; }
    .loading-dots span { width: 8px; height: 8px; border-radius: 50%; background: #d4af37; animation: bounce 1.4s infinite ease-in-out both; }
    .loading-dots span:nth-child(2) { animation-delay: 0.16s; }
    .loading-dots span:nth-child(3) { animation-delay: 0.32s; }
    @@keyframes bounce { 0%,80%,100% { transform: scale(0); opacity: 0.5; } 40% { transform: scale(1); opacity: 1; } }

    .audit-page { position: relative; min-height: 100vh; padding: 12px; background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%); }
    .page-bg-decorations { position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 0; }
    .bg-orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.2; }
    .bg-orb-1 { width: 300px; height: 300px; background: radial-gradient(circle, #6366f1, transparent); top: -100px; right: -50px; }
    .bg-orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, #ec4899, transparent); top: 30%; left: -100px; }
    .bg-orb-3 { width: 250px; height: 250px; background: radial-gradient(circle, #06b6d4, transparent); bottom: 20%; right: 30%; }
    .top-accent-bar { position: relative; height: 4px; background: linear-gradient(90deg, #6366f1, #ec4899, #6366f1); border-radius: 2px; margin-bottom: 12px; overflow: hidden; }
    .accent-shimmer { position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent); animation: shimmer 3s infinite; }
    @@keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }

    .audit-header { position: relative; background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%); border-radius: 16px; overflow: hidden; margin-bottom: 14px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
    .header-bg { position: absolute; inset: 0; overflow: hidden; }
    .header-gradient { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(168,85,247,0.1) 0%, transparent 50%); }
    .header-orbs { position: absolute; inset: 0; }
    .header-orb { position: absolute; border-radius: 50%; filter: blur(40px); opacity: 0.4; }
    .header-orb.orb-1 { width: 200px; height: 200px; background: #a855f7; top: -50px; right: 10%; }
