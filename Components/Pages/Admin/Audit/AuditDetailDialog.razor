@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Text.Json
@using MudBlazor

@inject IAuditService AuditService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog Style="min-width: 800px;">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Visibility" Color="MudBlazor.Color.Primary" />
            <MudText Typo="Typo.h6">تفاصيل السجل #@AuditId</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:200px;">
                <MudProgressCircular Indeterminate="true" Color="MudBlazor.Color.Primary" />
            </MudStack>
        }
        else if (_detail is null)
        {
            <MudAlert Severity="MudBlazor.Severity.Error">السجل غير موجود</MudAlert>
        }
        else
        {
            <div class="audit-detail">
                <!-- Meta info -->
                <div class="meta-grid">
                    <div class="meta-item">
                        <div class="meta-label">رقم السجل</div>
                        <div class="meta-value">#@_detail.AuditId</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">التاريخ والوقت</div>
                        <div class="meta-value">@(_detail.ActionDate?.ToString("yyyy/MM/dd HH:mm:ss") ?? "—")</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">المستخدم</div>
                        <div class="meta-value">
                            <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="MudBlazor.Size.Small" />
                            @(_detail.LoginName ?? "—")
                        </div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">الجدول</div>
                        <div class="meta-value">
                            <span class="table-pill">@_detail.TableName</span>
                        </div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">نوع العملية</div>
                        <div class="meta-value">
                            <span class="@GetActionBadgeClass(_detail.ActionType)">@GetActionLabel(_detail.ActionType)</span>
                        </div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">المعرّف</div>
                        <div class="meta-value"><code>@(_detail.PrimaryKeyValue ?? "—")</code></div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_detail.HostName))
                    {
                        <div class="meta-item">
                            <div class="meta-label">الجهاز</div>
                            <div class="meta-value">@_detail.HostName</div>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_detail.AppName))
                    {
                        <div class="meta-item">
                            <div class="meta-label">التطبيق</div>
                            <div class="meta-value">@_detail.AppName</div>
                        </div>
                    }
                </div>

                <!-- Old/New data -->
                @if (!string.IsNullOrWhiteSpace(_detail.OldData) || !string.IsNullOrWhiteSpace(_detail.NewData))
                {
                    <MudTabs Elevation="0" Rounded="true" Class="data-tabs">
                        @if (!string.IsNullOrWhiteSpace(_detail.OldData))
                        {
                            <MudTabPanel Text="🔴 البيانات القديمة" Icon="@Icons.Material.Filled.History">
                                <div class="json-wrapper">
                                    <div class="json-toolbar">
                                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                                   OnClick="@(() => CopyAsync(_detail.OldData))">نسخ</MudButton>
                                    </div>
                                    <pre class="json-viewer json-old">@FormatJson(_detail.OldData)</pre>
                                </div>
                            </MudTabPanel>
                        }
                        @if (!string.IsNullOrWhiteSpace(_detail.NewData))
                        {
                            <MudTabPanel Text="🟢 البيانات الجديدة" Icon="@Icons.Material.Filled.NewReleases">
                                <div class="json-wrapper">
                                    <div class="json-toolbar">
                                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                                   OnClick="@(() => CopyAsync(_detail.NewData))">نسخ</MudButton>
                                    </div>
                                    <pre class="json-viewer json-new">@FormatJson(_detail.NewData)</pre>
                                </div>
                            </MudTabPanel>
                        }
                        @if (!string.IsNullOrWhiteSpace(_detail.OldData) && !string.IsNullOrWhiteSpace(_detail.NewData))
                        {
                            <MudTabPanel Text="🔄 المقارنة" Icon="@Icons.Material.Filled.Compare">
                                <div class="compare-wrapper">
                                    <div class="compare-side">
                                        <h5>🔴 القديم</h5>
                                        <pre class="json-viewer json-old">@FormatJson(_detail.OldData)</pre>
                                    </div>
                                    <div class="compare-side">
                                        <h5>🟢 الجديد</h5>
                                        <pre class="json-viewer json-new">@FormatJson(_detail.NewData)</pre>
                                    </div>
                                </div>
                            </MudTabPanel>
                        }
                    </MudTabs>
                }
                else
                {
                    <div class="no-data-block">
                        <MudIcon Icon="@Icons.Material.Filled.DataObject" Size="MudBlazor.Size.Large" />
                        <span>لا توجد بيانات إضافية لهذا السجل</span>
                    </div>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">إغلاق</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .audit-detail { padding: 8px; }
    .meta-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 10px; margin-bottom: 16px;
        padding: 14px;
        background: #f8fafc;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
    }
    .meta-item { display: flex; flex-direction: column; }
    .meta-label { font-size: 11px; color: #94a3b8; margin-bottom: 4px; font-weight: 600; }
    .meta-value { font-size: 13px; color: #1a2842; font-weight: 600; display: inline-flex; gap: 4px; align-items: center; }
    .meta-value code { background: white; padding: 2px 6px; border-radius: 4px; font-size: 11px; }

    .table-pill { background: #e0e7ff; color: #3730a3; padding: 3px 10px; border-radius: 8px; font-size: 12px; font-weight: 700; }
    .action-badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 700; }
    .badge-insert { background: #d1fae5; color: #047857; }
    .badge-update { background: #fef3c7; color: #92400e; }
    .badge-delete { background: #fee2e2; color: #b91c1c; }
    .badge-other  { background: #f1f5f9; color: #475569; }

    .data-tabs { margin-top: 16px; }
    .json-wrapper { position: relative; }
    .json-toolbar { display: flex; justify-content: flex-end; padding: 6px 8px; }
    .json-viewer {
        max-height: 400px; overflow: auto;
        background: #0f172a;
        color: #e2e8f0;
        padding: 16px;
        border-radius: 10px;
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 13px;
        line-height: 1.7;
        direction: ltr;
        text-align: left;
        white-space: pre-wrap;
        word-break: break-word;
        unicode-bidi: plaintext;
    }
    .json-old { background: #1e1b1b; border-left: 3px solid #ef4444; }
    .json-new { background: #14271e; border-left: 3px solid #10b981; }

    .compare-wrapper { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    @@media (max-width: 768px) { .compare-wrapper { grid-template-columns: 1fr; } }
    .compare-side h5 { margin: 0 0 6px 0; font-size: 13px; font-weight: 700; color: #1a2842; }

    .no-data-block {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 50px; color: #cbd5e1; gap: 8px;
    }
    .no-data-block .mud-icon-root { font-size: 64px !important; }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired]
    public long AuditId { get; set; }

    private AuditLogDetailDto? _detail;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _detail = await AuditService.GetByIdAsync(AuditId);
        }
        catch (Exception ex)
        {
            Snackbar.Add("تعذّر تحميل التفاصيل: " + ex.Message, MudBlazor.Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Close() => MudDialog.Close();

    private async Task CopyAsync(string? data)
    {
        if (string.IsNullOrEmpty(data)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", FormatJson(data));
            Snackbar.Add("تم النسخ", MudBlazor.Severity.Info);
        }
        catch { }
    }

    private static string FormatJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return "";
        try
        {
            var parsed = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(parsed, new JsonSerializerOptions
            {
                WriteIndented = true,
                Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
            });
        }
        catch
        {
            return json;
        }
    }

    private string GetActionBadgeClass(string? action)
    {
        var cls = (action ?? "").ToLower() switch
        {
            "insert" => "badge-insert",
            "update" => "badge-update",
            "delete" => "badge-delete",
            _        => "badge-other"
        };
        return $"action-badge {cls}";
    }

    private string GetActionLabel(string? action) => (action ?? "").ToLower() switch
    {
        "insert" => "إضافة",
        "update" => "تعديل",
        "delete" => "حذف",
        _        => action ?? "—"
    };
}