    /* ═══ TEMPERATURE BADGES ═══ */
    .temp-hot { background: rgba(239,68,68,.7); color: #fff; border: 1px solid rgba(255,255,255,.3); }
    .temp-warm { background: rgba(245,158,11,.7); color: #fff; border: 1px solid rgba(255,255,255,.3); }
    .temp-cold { background: rgba(59,130,246,.6); color: #fff; border: 1px solid rgba(255,255,255,.3); }
    .temp-responded { background: rgba(34,197,94,.6); color: #fff; border: 1px solid rgba(255,255,255,.3); }

    /* ═══ QUICK ACTIONS ═══ */
    .ld2-action-strip {
        display: flex;
