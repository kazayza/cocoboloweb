@page "/crm/leads/{LeadId:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@attribute [Authorize]

@inject ILeadsCrmService LeadsService
@inject IInteractionService InteractionService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS


<PageTitle>تفاصيل Lead — CRM</PageTitle>

@if (_isLoading)
{
    <div class="ld-loading-screen">
        <div class="ld-loading-card">
            <MudProgressCircular Color="MudColor.Primary" Size="MudSize.Large" Indeterminate="true" />
            <MudText Typo="Typo.h6" Class="mt-3">جاري تحميل بيانات الـ Lead...</MudText>
        </div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="ld2-page" dir="rtl">
        <MudAlert Severity="Severity.Error" Variant="MudVariant.Filled" Class="mb-3">
            @_loadError
        </MudAlert>
        <div class="ld2-error-actions">
            <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary" OnClick="LoadLeadAsync">
                إعادة المحاولة
            </MudButton>
            <MudButton Variant="MudVariant.Text" Color="MudColor.Default" OnClick="GoBack">
                رجوع
            </MudButton>
        </div>
    </div>
}
else if (_lead is null)
{
    <div class="ld2-page" dir="rtl">
        <MudAlert Severity="Severity.Warning" Variant="MudVariant.Filled">
            لم يتم العثور على الـ Lead.
        </MudAlert>
        <MudButton Variant="MudVariant.Text" Color="MudColor.Default" OnClick="GoBack" Class="mt-3">
            رجوع
        </MudButton>
    </div>
}
else
{
    <div class="ld2-page" dir="rtl">

        @* ════════════════════════════════════════
           DUPLICATE ALERT
           ════════════════════════════════════════ *@
        @if (_lead.IsDuplicate)
        {
            <div class="ld2-duplicate-alert">
                <MudIcon Icon="@Icons.Material.Rounded.WarningAmber" />
                <span>هذا Lead مكرر — الرقم مطابق لعميل موجود: <strong>@_lead.DuplicateOfPhone</strong></span>
                <MudButton Variant="MudVariant.Text" Color="MudColor.Error" Size="MudSize.Small"
                           OnClick='@(() => Navigation.NavigateTo("/crm/leads"))'>
                    عرض الليدز
                </MudButton>
            </div>
        }

        @* ════════════════════════════════════════
           HERO
           ════════════════════════════════════════ *@
        <section class="ld2-hero">
            <div class="ld2-hero-bg"></div>
            <div class="ld2-hero-dots"></div>
            <div class="ld2-hero-orb orb-1"></div>
            <div class="ld2-hero-orb orb-2"></div>

            <div class="ld2-hero-content">
                <div class="ld2-person-block">
                    <div class="ld2-avatar" style="background:@GetTemperatureBg()">
                        @GetInitials(_lead.FullName)
                    </div>

                    <div class="ld2-person-text">
                        <div class="ld2-title-line">
                            <h1>@_lead.FullName</h1>
                            <span class="@GetStatusClass(_lead.LeadStatus)">@(_lead.LeadStatus ?? "غير محدد")</span>
                            <span class="@GetFollowClass()">@GetFollowText()</span>
                            @if (GetTemperatureBadge() is { } tempBadge)
                            {
                                <span class="@tempBadge.Class">@tempBadge.Icon @tempBadge.Text</span>
                            }
                        </div>

                        <div class="ld2-meta-line">
                            @if (!string.IsNullOrWhiteSpace(_lead.Phone))
                            {
                                <span class="ltr">
                                    @_lead.Phone
                                    <MudIconButton Icon="@Icons.Material.Rounded.ContentCopy" Size="MudSize.Small"
                                                   Color="MudColor.Inherit" Class="ld2-copy-btn"
                                                   OnClick='@(() => CopyToClipboard(_lead.Phone))'
                                                   Title="نسخ الرقم" />
                                </span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_lead.City))
                            {
                                <span>• @_lead.City</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_lead.CampaignName))
                            {
                                <span>• @_lead.CampaignName</span>
                            }
                            <span>• وصل @FormatElapsed(_lead.CreatedAt)</span>
                            @if (_leadInteractions.Any())
                            {
                                <span>• @_leadInteractions.Count تواصلات</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="ld2-hero-actions">
                    @if (!string.IsNullOrWhiteSpace(_lead.Phone))
                    {
                        <MudButton Variant="MudVariant.Filled" Color="MudColor.Success" Size="MudSize.Small"
                                   StartIcon="@Icons.Custom.Brands.WhatsApp"
                                   OnClick="@(() => OpenWhatsApp(_lead.Phone))">
                            واتساب
                        </MudButton>
                        <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary" Size="MudSize.Small"
                                   StartIcon="@Icons.Material.Rounded.Phone"
                                   OnClick="@(() => CallPhone(_lead.Phone))">
                            اتصال
                        </MudButton>
                    }
                    <MudButton Variant="MudVariant.Outlined" Color="MudColor.Inherit" Size="MudSize.Small"
                               StartIcon="@Icons.Material.Rounded.ArrowBack"
                               OnClick="GoBack">
                        رجوع
                    </MudButton>
                </div>
            </div>
        </section>

        @* ════════════════════════════════════════
           QUICK ACTIONS
           ════════════════════════════════════════ *@
        <section class="ld2-action-strip">
            <div class="ld2-action-title">
                <MudIcon Icon="@Icons.Material.Rounded.Bolt" Size="MudSize.Small" />
                إجراءات سريعة
            </div>

            <div class="ld2-action-buttons">
                @if (_canEdit && _lead.LeadStatus != "محول" && _lead.LeadStatus != "مرفوض")
                {
                    <MudButton Variant="MudVariant.Filled"
                               Color="MudColor.Primary"
                               Size="MudSize.Small"
                               StartIcon="@Icons.Material.Rounded.AddComment"
                               OnClick="OpenInteractionDialog">
                        تسجيل تواصل
                    </MudButton>
                }
                @if (_canEdit && CanConvertLead())
                {
                    <MudButton Variant="MudVariant.Filled"
                               Color="MudColor.Success"
                               Size="MudSize.Small"
                               StartIcon="@Icons.Material.Rounded.PersonAdd"
                               OnClick="OpenConvertDialog">
                        تحويل لفرصة
                    </MudButton>
                }

                @if (_lead.IsConverted && _lead.ConvertedOpportunityId.HasValue)
                {
                    <MudButton Variant="MudVariant.Filled"
                               Color="MudColor.Success"
                               Size="MudSize.Small"
                               StartIcon="@Icons.Material.Rounded.OpenInNew"
                               OnClick="@(() => Navigation.NavigateTo($"/crm/opportunities/{_lead.ConvertedOpportunityId.Value}"))">
                        فتح الفرصة
                    </MudButton>
                }

                @if (_lead.IsConverted && _lead.ConvertedPartyId.HasValue)
                {
                    <MudButton Variant="MudVariant.Outlined"
                               Color="MudColor.Primary"
                               Size="MudSize.Small"
                               StartIcon="@Icons.Material.Rounded.ContactPage"
                               OnClick="@(() => Navigation.NavigateTo($"/crm/customers/{_lead.ConvertedPartyId.Value}"))">
                        بطاقة العميل
                    </MudButton>
                }
                @if (_canEdit && _lead.LeadStatus != "تم التواصل" && _lead.LeadStatus != "محول" && _lead.LeadStatus != "مرفوض")
                {
                    <MudButton Variant="MudVariant.Outlined" Color="MudColor.Info" Size="MudSize.Small"
                               StartIcon="@Icons.Material.Rounded.PhoneCallback"
                               OnClick='@(() => ChangeStatusAsync("تم التواصل"))'>
                        تم التواصل
                    </MudButton>
                }

                @if (_canEdit && _lead.LeadStatus != "مرفوض" && _lead.LeadStatus != "محول")
                {
                    <MudButton Variant="MudVariant.Outlined" Color="MudColor.Error" Size="MudSize.Small"
                               StartIcon="@Icons.Material.Rounded.Cancel"
                               OnClick='@(() => ChangeStatusAsync("مرفوض"))'>
                        مرفوض
                    </MudButton>
                }

                <MudButton Variant="MudVariant.Text" Color="MudColor.Primary" Size="MudSize.Small"
                           StartIcon="@Icons.Material.Rounded.ListAlt"
                           OnClick='@(() => Navigation.NavigateTo("/crm/leads"))'>
                    قائمة Leads
                </MudButton>

                <MudButton Variant="MudVariant.Text" Color="MudColor.Primary" Size="MudSize.Small"
                           StartIcon="@Icons.Material.Rounded.AssignmentInd"
                           OnClick='@(() => Navigation.NavigateTo("/crm/leads/my"))'>
                    My Leads
                </MudButton>
            </div>
        </section>

        @* ════════════════════════════════════════
           SUMMARY CARDS
           ════════════════════════════════════════ *@
        <section class="ld2-summary-grid">
            <div class="ld2-summary-card">
                <div class="sum-icon blue"><MudIcon Icon="@Icons.Material.Rounded.Source" /></div>
                <div>
                    <span>المصدر</span>
                    <strong>@GetPlatformText(_lead.Platform)</strong>
                </div>
            </div>
            <div class="ld2-summary-card">
                <div class="sum-icon purple"><MudIcon Icon="@Icons.Material.Rounded.Campaign" /></div>
                <div>
                    <span>الحملة</span>
                    <strong title="@_lead.CampaignName">@Safe(_lead.CampaignName)</strong>
                </div>
            </div>
            <div class="ld2-summary-card">
                <div class="sum-icon green"><MudIcon Icon="@Icons.Material.Rounded.HomeWork" /></div>
                <div>
                    <span>نوع المشروع</span>
                    <strong>@Safe(_lead.ProjectType)</strong>
                </div>
            </div>
            <div class="ld2-summary-card">
                <div class="sum-icon amber"><MudIcon Icon="@Icons.Material.Rounded.Payments" /></div>
                <div>
                    <span>الميزانية</span>
                    <strong>@Safe(_lead.Budget)</strong>
                </div>
            </div>
            <div class="ld2-summary-card">
                <div class="sum-icon rose"><MudIcon Icon="@Icons.Material.Rounded.PersonPin" /></div>
                <div>
                    <span>الموظف المسؤول</span>
                    <strong>@Safe(_lead.AssignedEmployeeName)</strong>
                </div>
            </div>
        </section>

        @* ════════════════════════════════════════
           MAIN CONTENT — COLLAPSIBLE SECTIONS
           ════════════════════════════════════════ *@
        <section class="ld2-content-grid">

            @* ─── بيانات العميل ─── *@
            <MudPaper Class="ld2-section" Elevation="0">
                <div class="ld2-section-header" @onclick="@(() => _customerExpanded = !_customerExpanded)">
                    <div class="sec-icon customer"><MudIcon Icon="@Icons.Material.Rounded.ContactPhone" /></div>
                    <div class="ld2-section-title">
                        <h3>بيانات العميل</h3>
                        <p>معلومات التواصل الأساسية (@CountCustomerFields())</p>
                    </div>
                    <MudIcon Icon="@(_customerExpanded ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)"
                             Class="ld2-collapse-icon" />
                </div>
                @if (_customerExpanded)
                {
                    <div class="ld2-info-grid ld2-section-body">
                        @InfoTile("الاسم", _lead.FullName)
                        @InfoTile("الهاتف", _lead.Phone, ltr: true)
                        @InfoTile("هاتف إضافي", _lead.Phone2, ltr: true)
                        @InfoTile("البريد", _lead.Email)
                        @InfoTile("المدينة", _lead.City)
                        @InfoTile("المنطقة", _lead.Area)
                        @InfoTile("العنوان", _lead.Address, wide: true)
                    </div>
                }
            </MudPaper>

            @* ─── بيانات الإعلان ─── *@
            <MudPaper Class="ld2-section" Elevation="0">
                <div class="ld2-section-header" @onclick="@(() => _adsExpanded = !_adsExpanded)">
                    <div class="sec-icon ads"><MudIcon Icon="@Icons.Material.Rounded.Campaign" /></div>
                    <div class="ld2-section-title">
                        <h3>بيانات الإعلان</h3>
                        <p>@(HasAdData() ? $"مصدر الـ Lead من Meta ({CountAdFields()})" : "لا توجد بيانات إعلان")</p>
                    </div>
                    <MudIcon Icon="@(_adsExpanded ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)"
                             Class="ld2-collapse-icon" />
                </div>
                @if (_adsExpanded)
                {
                    <div class="ld2-section-body">
                        @if (HasAdData())
                        {
                            <div class="ld2-info-grid">
                                @InfoTile("المنصة", GetPlatformText(_lead.Platform))
                                @InfoTile("الحملة", _lead.CampaignName)
                                @InfoTile("الإعلان", _lead.AdName)
                                @InfoTile("مجموعة الإعلان", _lead.AdSetName)
                                @InfoTile("النموذج", _lead.FormName)
                                @InfoTile("Meta Lead Id", _lead.MetaLeadId)
                            </div>
                        }
                        else
                        {
                            <div class="ld2-empty-section">
                                <MudIcon Icon="@Icons.Material.Rounded.NaturePeople" />
                                <span>Lead عضوي — لا توجد بيانات إعلان من Meta</span>
                            </div>
                        }
                    </div>
                }
            </MudPaper>

            @* ─── بيانات المشروع ─── *@
            <MudPaper Class="ld2-section" Elevation="0">
                <div class="ld2-section-header" @onclick="@(() => _projectExpanded = !_projectExpanded)">
                    <div class="sec-icon project"><MudIcon Icon="@Icons.Material.Rounded.HomeWork" /></div>
                    <div class="ld2-section-title">
                        <h3>بيانات المشروع</h3>
                        <p>تفاصيل احتياج العميل المحتمل (@CountProjectFields())</p>
                    </div>
                    <MudIcon Icon="@(_projectExpanded ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)"
                             Class="ld2-collapse-icon" />
                </div>
                @if (_projectExpanded)
                {
                    <div class="ld2-info-grid ld2-section-body">
                        @InfoTile("نوع المشروع", _lead.ProjectType)
                        @InfoTile("مرحلة المشروع", _lead.ProjectStage)
                        @InfoTile("الميزانية", _lead.Budget)
                        @InfoTile("صاحب القرار", _lead.DecisionMaker)
                        @InfoTile("الإجراء المطلوب", _lead.NextAction)
                        @InfoTile("أفضل وقت للتواصل", _lead.BestTimeToReach)
                    </div>
                }
            </MudPaper>

            @* ─── المتابعة والتحويل ─── *@
            <MudPaper Class="ld2-section" Elevation="0">
                <div class="ld2-section-header" @onclick="@(() => _followExpanded = !_followExpanded)">
                    <div class="sec-icon follow"><MudIcon Icon="@Icons.Material.Rounded.TrackChanges" /></div>
                    <div class="ld2-section-title">
                        <h3>المتابعة والتحويل</h3>
                        <p>حالة المعالجة داخل CRM</p>
                    </div>
                    <MudIcon Icon="@(_followExpanded ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)"
                             Class="ld2-collapse-icon" />
                </div>
                @if (_followExpanded)
                {
                    <div class="ld2-info-grid ld2-section-body">
                        @InfoTile("تاريخ الوصول", FormatDateTime(_lead.CreatedAt))
                        @InfoTile("آخر تواصل", FormatDateTime(_lead.LastContactDate))
                        @InfoTile("تاريخ التحويل", FormatDateTime(_lead.QualifiedDate))
                        @InfoTile("الموظف المسؤول", _lead.AssignedEmployeeName)

                        @if (_lead.IsConverted)
                        {
                            @InfoTile("تم التحويل", GetConversionText(), wide: true)
                            @InfoTile("تاريخ التحويل", FormatDateTime(_lead.ConvertedDate))
                            @InfoTile("بواسطة", _lead.ConvertedBy)
                        }

                        @if (!string.IsNullOrWhiteSpace(_lead.RejectedReason))
                        {
                            @InfoTile("سبب الرفض", _lead.RejectedReason, wide: true)
                        }
                    </div>

                    @* روابط سريعة للفرصة/العميل داخل القسم *@
                    @if (_lead.IsConverted)
                    {
                        <div class="ld2-quick-links">
                            @if (_lead.ConvertedOpportunityId.HasValue)
                            {
                                <button type="button" class="ld2-quick-link opp"
                                        @onclick="@(() => Navigation.NavigateTo($"/crm/opportunities/{_lead.ConvertedOpportunityId.Value}"))">
                                    <MudIcon Icon="@Icons.Material.Rounded.OpenInNew" Size="MudSize.Small" />
                                    <span>فتح الفرصة #@_lead.ConvertedOpportunityId</span>
                                </button>
                            }
                            @if (_lead.ConvertedPartyId.HasValue)
                            {
                                <button type="button" class="ld2-quick-link cust"
                                        @onclick="@(() => Navigation.NavigateTo($"/crm/customers/{_lead.ConvertedPartyId.Value}"))">
                                    <MudIcon Icon="@Icons.Material.Rounded.ContactPage" Size="MudSize.Small" />
                                    <span>بطاقة العميل #@_lead.ConvertedPartyId</span>
                                </button>
                            }
                        </div>
                    }
                }
            </MudPaper>

            @* ─── ملاحظات و Feedback ─── *@
            <MudPaper Class="ld2-section ld2-wide" Elevation="0">
                <div class="ld2-section-header" @onclick="@(() => _notesExpanded = !_notesExpanded)">
                    <div class="sec-icon notes"><MudIcon Icon="@Icons.Material.Rounded.Notes" /></div>
                    <div class="ld2-section-title">
                        <h3>ملاحظات و Feedback</h3>
                        <p>ملخص بيانات الفورم وملاحظات فريق المبيعات</p>
                    </div>
                    <div class="ld2-header-actions">
                        @if (_canEdit && _notesExpanded && !_isEditingNotes)
                        {
                            <div @onclick:stopPropagation>
                                <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="MudSize.Small"
                                               Color="MudColor.Primary" OnClick="StartEditNotes"
                                               Title="تعديل الملاحظات" />
                            </div>
                        }
                        <MudIcon Icon="@(_notesExpanded ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)"
                                 Class="ld2-collapse-icon" />
                    </div>
                </div>
                @if (_notesExpanded)
                {
                    <div class="ld2-section-body">
                        @if (_isEditingNotes)
                        {
                            <div class="ld2-notes-edit">
                                <MudTextField T="string"
                                              Label="الملاحظات"
                                              Variant="MudVariant.Outlined"
                                              @bind-Value="_editingNotes"
                                              Lines="4" />
                                <div class="ld2-notes-edit-actions">
                                    <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary"
                                               Size="MudSize.Small" Disabled="_isSavingNotes"
                                               OnClick="SaveNotesAsync">
                                        @if (_isSavingNotes)
                                        {
                                            <MudProgressCircular Size="MudSize.Small" Indeterminate="true" Class="me-2" />
                                        }
                                        حفظ
                                    </MudButton>
                                    <MudButton Variant="MudVariant.Text" Color="MudColor.Default"
                                               Size="MudSize.Small" OnClick="CancelEditNotes"
                                               Disabled="_isSavingNotes">
                                        إلغاء
                                    </MudButton>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="ld2-notes-box">
                                @if (!string.IsNullOrWhiteSpace(_lead.Notes))
                                {
                                    <p>@_lead.Notes</p>
                                }
                                else
                                {
                                    <span class="muted">لا توجد ملاحظات.</span>
                                }

                                @if (!string.IsNullOrWhiteSpace(_lead.Feedback))
                                {
                                    <div class="feedback-box">
                                        <strong>Feedback</strong>
                                        <p>@_lead.Feedback</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </MudPaper>

            @* ─── سجل التواصلات ─── *@
            <MudPaper Class="ld2-section ld2-wide" Elevation="0">
                <div class="ld2-section-header" @onclick="@(() => _timelineExpanded = !_timelineExpanded)">
                    <div class="sec-icon timeline">
                        <MudIcon Icon="@Icons.Material.Rounded.Timeline" />
                    </div>
                    <div class="ld2-section-title">
                        <h3>سجل التواصلات الكامل</h3>
                        <p>تواصلات الـ Lead قبل التحويل + تواصلات فرصة البيع بعد التحويل
                           @if (_leadInteractions.Any() || _opportunityInteractions.Any())
                           {
                               <span class="ld2-count-badge">@(_leadInteractions.Count + _opportunityInteractions.Count)</span>
                           }
                        </p>
                    </div>
                    <MudIcon Icon="@(_timelineExpanded ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)"
                             Class="ld2-collapse-icon" />
                </div>
                @if (_timelineExpanded)
                {
                    <div class="ld2-section-body">
                        @if (_leadInteractions.Any() || _opportunityInteractions.Any())
                        {
                            <div class="lead-interactions-list">

                                @if (_leadInteractions.Any())
                                {
                                    <div class="timeline-group-title">
                                        <MudIcon Icon="@Icons.Material.Rounded.FiberNew" Size="MudSize.Small" />
                                        قبل التحويل — تواصلات الـ Lead
                                    </div>

                                    @foreach (var item in _leadInteractions)
                                    {
                                        <div class="lead-interaction-item" style="--tl-color:@GetInteractionColor(item.InteractionType)">
                                            <div class="li-icon @GetInteractionClass(item.InteractionType)">
                                                <MudIcon Icon="@GetInteractionIcon(item.InteractionType)" Size="MudSize.Small" />
                                            </div>

                                            <div class="li-content">
                                                <div class="li-head">
                                                    <strong>@item.InteractionType</strong>
                                                    <span>@item.InteractionDate.ToString("yyyy/MM/dd HH:mm")</span>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(item.Summary))
                                                {
                                                    <p>@item.Summary</p>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(item.Notes))
                                                {
                                                    <small>@item.Notes</small>
                                                }

                                                <div class="li-meta">
                                                    <span>قبل التحويل</span>

                                                    @if (!string.IsNullOrWhiteSpace(item.EmployeeName))
                                                    {
                                                        <span>الموظف: @item.EmployeeName</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(item.CreatedBy))
                                                    {
                                                        <span>بواسطة: @item.CreatedBy</span>
                                                    }

                                                    @if (item.NextFollowUpDate.HasValue)
                                                    {
                                                        <span>متابعة: @item.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(item.OldLeadStatus) ||
                                                         !string.IsNullOrWhiteSpace(item.NewLeadStatus))
                                                    {
                                                        <span>
                                                            الحالة:
                                                            @(item.OldLeadStatus ?? "—")
                                                            ←
                                                            @(item.NewLeadStatus ?? "—")
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }

                                @if (_opportunityInteractions.Any())
                                {
                                    <div class="timeline-group-title after-convert">
                                        <MudIcon Icon="@Icons.Material.Rounded.TrackChanges" Size="MudSize.Small" />
                                        بعد التحويل — تواصلات فرصة البيع
                                    </div>

                                    @foreach (var item in _opportunityInteractions.OrderByDescending(i => i.InteractionDate))
                                    {
                                        <div class="lead-interaction-item" style="--tl-color:#047857">
                                            <div class="li-icon li-opportunity">
                                                <MudIcon Icon="@Icons.Material.Rounded.Forum" Size="MudSize.Small" />
                                            </div>

                                            <div class="li-content">
                                                <div class="li-head">
                                                    <strong>@(item.StatusNameAr ?? item.StatusName ?? "تواصل مع فرصة البيع")</strong>
                                                    <span>@item.InteractionDate.ToString("yyyy/MM/dd HH:mm")</span>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(item.Summary))
                                                {
                                                    <p>@item.Summary</p>
                                                }
                                                else
                                                {
                                                    <p>تم تسجيل تواصل على فرصة البيع بعد تحويل الـ Lead.</p>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(item.Notes))
                                                {
                                                    <small>@item.Notes</small>
                                                }

                                                <div class="li-meta">
                                                    <span>بعد التحويل</span>

                                                    @if (!string.IsNullOrWhiteSpace(item.EmployeeName))
                                                    {
                                                        <span>الموظف: @item.EmployeeName</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(item.CreatedBy))
                                                    {
                                                        <span>بواسطة: @item.CreatedBy</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(item.StageBeforeNameAr) ||
                                                         !string.IsNullOrWhiteSpace(item.StageAfterNameAr))
                                                    {
                                                        <span>
                                                            المرحلة:
                                                            @(item.StageBeforeNameAr ?? item.StageBeforeName ?? "—")
                                                            ←
                                                            @(item.StageAfterNameAr ?? item.StageAfterName ?? "—")
                                                        </span>
                                                    }

                                                    @if (item.NextFollowUpDate.HasValue)
                                                    {
                                                        <span>متابعة: @item.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <div class="timeline-empty">
                                <MudIcon Icon="@Icons.Material.Rounded.ChatBubbleOutline" />
                                <span>لم يتم تسجيل أي تواصل مع هذا الـ Lead أو فرصته بعد.</span>
                            </div>
                        }
                    </div>
                }
            </MudPaper>
        </section>
    </div>
}

@* ════════════════════════════════════════
   DIALOG: تسجيل تواصل
   ════════════════════════════════════════ *@
<MudDialog @bind-Visible="_showInteractionDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <div style="display:flex;align-items:center;gap:.5rem;">
            <MudIcon Icon="@Icons.Material.Rounded.AddComment" Color="MudColor.Primary" />
            <MudText Typo="Typo.h6">تسجيل تواصل مع Lead</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <div dir="rtl" style="display:flex;flex-direction:column;gap:1rem;">

            <MudSelect T="string"
                       Label="نوع التواصل"
                       Variant="MudVariant.Outlined"
                       @bind-Value="_interactionModel.InteractionType"
                       Dense="true">
                @foreach (var t in LeadInteractionTypes.All)
                {
                    <MudSelectItem T="string" Value="@t.Key">@t.Value</MudSelectItem>
                }
            </MudSelect>

            <MudTextField T="string"
                          Label="ملخص التواصل *"
                          Variant="MudVariant.Outlined"
                          @bind-Value="_interactionModel.Summary"
                          Dense="true"
                          Lines="2"
                          Placeholder="مثال: تم الاتصال والعميل مهتم بالتفاصيل" />

            <MudTextField T="string"
                          Label="ملاحظات"
                          Variant="MudVariant.Outlined"
                          @bind-Value="_interactionModel.Notes"
                          Dense="true"
                          Lines="3" />

            <MudDatePicker Label="تاريخ متابعة قادم"
                           Variant="MudVariant.Outlined"
                           @bind-Date="_interactionModel.NextFollowUpDate"
                           Dense="true"
                           Clearable="true" />

            <MudSelect T="string"
                       Label="تحديث الحالة بعد التواصل"
                       Variant="MudVariant.Outlined"
                       @bind-Value="_interactionModel.NewLeadStatus"
                       Dense="true"
                       Clearable="true">
                <MudSelectItem T="string" Value="@("تم التواصل")">تم التواصل</MudSelectItem>
                <MudSelectItem T="string" Value="@("مرفوض")">مرفوض</MudSelectItem>
            </MudSelect>

            @if (_interactionModel.NewLeadStatus == "مرفوض")
            {
                <MudTextField T="string"
                              Label="سبب الرفض"
                              Variant="MudVariant.Outlined"
                              @bind-Value="_interactionModel.RejectedReason"
                              Dense="true"
                              Lines="2" />
            }

            <MudAlert Severity="Severity.Info" Dense="true">
                إذا لم تختار حالة، سيتم اعتبار التواصل كـ "تم التواصل" تلقائيًا عند الاتصال أو واتساب أو متابعة.
            </MudAlert>
        </div>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="MudVariant.Text"
                   Color="MudColor.Default"
                   OnClick="@(() => _showInteractionDialog = false)">
            إلغاء
        </MudButton>

        <MudButton Variant="MudVariant.Filled"
                   Color="MudColor.Primary"
                   Disabled="_isSavingInteraction"
                   OnClick="SaveInteractionAsync">
            @if (_isSavingInteraction)
            {
                <MudProgressCircular Size="MudSize.Small" Indeterminate="true" Class="me-2" />
            }
            حفظ التواصل
        </MudButton>
    </DialogActions>
</MudDialog>

@* ════════════════════════════════════════
   DIALOG: تحويل لفرصة
   ════════════════════════════════════════ *@
<MudDialog @bind-Visible="_showConvertDialog"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <div style="display:flex;align-items:center;gap:.5rem;">
            <MudIcon Icon="@Icons.Material.Rounded.PersonAdd" Color="MudColor.Success" />
            <MudText Typo="Typo.h6">تحويل Lead إلى فرصة بيع</MudText>
        </div>
    </TitleContent>

    <DialogContent>
        <div dir="rtl" style="display:flex;flex-direction:column;gap:1rem;">

            <MudAlert Severity="Severity.Info" Dense="true">
                سيتم إنشاء عميل + فرصة بيع على مرحلة <strong>مهتم</strong>، وسيتم إسناد الفرصة مباشرةً للموظف الذي ستختاره هنا.
            </MudAlert>

            <MudSelect T="int?"
                       Label="الموظف المسؤول عن الفرصة *"
                       Variant="MudVariant.Outlined"
                       @bind-Value="_convertEmployeeId"
                       Dense="true"
                       Clearable="false">
                @foreach (var emp in _assignableEmployees)
                {
                    <MudSelectItem T="int?" Value="@((int?)emp.EmployeeId)">@emp.FullName (@(emp.Department ?? "—"))</MudSelectItem>
                }
            </MudSelect>

            <MudNumericField T="decimal"
                             Label="قيمة الفرصة المتوقعة"
                             Variant="MudVariant.Outlined"
                             @bind-Value="_convertExpectedValue"
                             Min="0m"
                             Dense="true"
                             Adornment="Adornment.End"
                             AdornmentText="ج" />

            <MudTextField T="string"
                          Label="ملاحظات التحويل"
                          Variant="MudVariant.Outlined"
                          @bind-Value="_convertNotes"
                          Dense="true"
                          Lines="3" />

        </div>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="MudVariant.Text"
                   Color="MudColor.Default"
                   OnClick="@(() => _showConvertDialog = false)">
            إلغاء
        </MudButton>

        <MudButton Variant="MudVariant.Filled"
                   Color="MudColor.Success"
                   Disabled="_isConverting"
                   OnClick="ConvertLeadAsync">
            @if (_isConverting)
            {
                <MudProgressCircular Size="MudSize.Small" Indeterminate="true" Class="me-2" />
            }
            تحويل
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .ld2-page {
        padding: 1rem 1.5rem 3rem;
        max-width: 1800px;
        margin: 0 auto;
        direction: rtl;
    }

    .ld-loading-screen {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .ld-loading-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 18px;
        padding: 2rem 3rem;
        box-shadow: 0 10px 30px rgba(15,23,42,.08);
    }
    .ld2-error-actions { display: flex; gap: .5rem; flex-wrap: wrap; }

    /* ═══ DUPLICATE ALERT ═══ */
    .ld2-duplicate-alert {
        display: flex;
