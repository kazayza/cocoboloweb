    .ld2-action-buttons { display: flex; align-items: center; gap: .45rem; flex-wrap: wrap; }

    /* ═══ SUMMARY ═══ */
    .ld2-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: .65rem;
        margin-bottom: .85rem;
    }
