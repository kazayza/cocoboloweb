@code {
    [Parameter] public int LeadId { get; set; }

    // ─── State ───
    private bool _isLoading = true;
    private bool _canEdit;
    private string _currentUserName = "system";
    private string? _loadError;
    private LeadsCrmDetailDto? _lead;
    private bool _showConvertDialog = false;
    private bool _isConverting = false;
    private int? _convertEmployeeId;
    private decimal _convertExpectedValue = 0;
    private string? _convertNotes;
    private List<Employee> _assignableEmployees = new();
    private List<LeadInteractionDto> _leadInteractions = new();
    private List<InteractionListDto> _opportunityInteractions = new();

    private bool _showInteractionDialog = false;
    private bool _isSavingInteraction = false;
    private LeadInteractionCreateDto _interactionModel = new();

    // ─── Collapsible Section State ───
    private bool _customerExpanded = true;
    private bool _adsExpanded = false;       // مطوي افتراضياً
    private bool _projectExpanded = true;
    private bool _followExpanded = true;
    private bool _notesExpanded = true;
    private bool _timelineExpanded = true;

    // ─── Inline Notes Edit ───
    private bool _isEditingNotes = false;
    private bool _isSavingNotes = false;
    private string _editingNotes = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "system";
            _canEdit = LeadsCrmPermissions.CanEdit(user);

            await LoadAssignableEmployeesAsync();
            await LoadLeadAsync();
        }
        catch (Exception ex)
        {
            _loadError = ex.GetBaseException().Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadAssignableEmployeesAsync()
    {
        try
        {
            _assignableEmployees = await LeadsService.GetAssignableEmployeesAsync();
        }
        catch
        {
            _assignableEmployees = new();
        }
    }

    private async Task LoadLeadAsync()
    {
        _isLoading = true;
        _loadError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _lead = await LeadsService.GetLeadByIdAsync(LeadId);

            _leadInteractions = _lead != null
                ? await LeadsService.GetLeadInteractionsAsync(LeadId)
                : new List<LeadInteractionDto>();

            if (_lead?.ConvertedOpportunityId.HasValue == true)
            {
                _opportunityInteractions = await InteractionService
                    .GetByOpportunityAsync(_lead.ConvertedOpportunityId.Value);
            }
            else
            {
                _opportunityInteractions = new();
            }

            if (_lead == null)
                _loadError = "لم يتم العثور على الـ Lead المطلوب.";
        }
        catch (Exception ex)
        {
            _loadError = ex.GetBaseException().Message;
            Snackbar.Add("تعذّر تحميل تفاصيل الـ Lead: " + _loadError, Severity.Error);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ═══════════════════════════════════════════
    //  تغيير الحالة
    // ═══════════════════════════════════════════
    private async Task ChangeStatusAsync(string status)
    {
        if (_lead is null) return;

        try
        {
            var dto = new LeadsCrmUpdateDto
            {
                LeadId = _lead.LeadId,
                LeadStatus = status,
                AssignedEmployeeId = _lead.AssignedEmployeeId,
                Feedback = status == "تم التواصل" ? "تم التواصل من صفحة تفاصيل Lead" : null,
                RejectedReason = status == "مرفوض" ? "تم الرفض من صفحة تفاصيل Lead" : null
            };

            var (ok, msg) = await LeadsService.UpdateLeadAsync(dto, _currentUserName);
            Snackbar.Add(ok ? "تم تحديث الحالة" : msg, ok ? Severity.Success : Severity.Error);
            if (ok) await LoadLeadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("تعذّر تحديث الحالة: " + ex.Message, Severity.Error);
        }
    }

    // ═══════════════════════════════════════════
    //  تسجيل تواصل
    // ═══════════════════════════════════════════
    private void OpenInteractionDialog()
    {
        if (_lead == null) return;

        _interactionModel = new LeadInteractionCreateDto
        {
            LeadId = _lead.LeadId,
            EmployeeId = _lead.AssignedEmployeeId,
            InteractionType = LeadInteractionTypes.Call,
            NewLeadStatus = "تم التواصل"
        };

        _showInteractionDialog = true;
    }

    private async Task SaveInteractionAsync()
    {
        if (_lead == null) return;

        if (string.IsNullOrWhiteSpace(_interactionModel.Summary))
        {
            Snackbar.Add("يرجى كتابة ملخص التواصل", Severity.Warning);
            return;
        }

        _isSavingInteraction = true;

        try
        {
            _interactionModel.LeadId = _lead.LeadId;

            var (success, message) = await LeadsService.AddLeadInteractionAsync(
                _interactionModel,
                _currentUserName);

            if (success)
            {
                Snackbar.Add("تم تسجيل التواصل بنجاح", Severity.Success);
                _showInteractionDialog = false;
                await LoadLeadAsync();
            }
            else
            {
                Snackbar.Add(message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("تعذّر تسجيل التواصل: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isSavingInteraction = false;
        }
    }

    // ═══════════════════════════════════════════
    //  تحويل لفرصة
    // ═══════════════════════════════════════════
    private bool CanConvertLead()
    {
        if (_lead == null) return false;
        if (_lead.IsConverted || _lead.LeadStatus == "محول" || _lead.LeadStatus == "مرفوض")
            return false;

        return _lead.LeadStatus == "تم التواصل" || _lead.LastContactDate.HasValue;
    }

    private void OpenConvertDialog()
    {
        if (_lead == null) return;

        _convertEmployeeId = _lead.AssignedEmployeeId;
        _convertExpectedValue = 0;
        _convertNotes = _lead.Notes;

        if (_convertEmployeeId.HasValue && !_assignableEmployees.Any(e => e.EmployeeId == _convertEmployeeId.Value))
            _convertEmployeeId = null;

        _showConvertDialog = true;
    }

    private async Task ConvertLeadAsync()
    {
        if (_lead == null || _isConverting) return;

        if (!_convertEmployeeId.HasValue)
        {
            Snackbar.Add("يجب اختيار الموظف الذي ستُسند إليه الفرصة قبل التحويل", Severity.Warning);
            return;
        }

        if (!_assignableEmployees.Any(e => e.EmployeeId == _convertEmployeeId.Value))
        {
            Snackbar.Add("الموظف المختار غير متاح حاليًا للإسناد", Severity.Warning);
            return;
        }

        _isConverting = true;

        try
        {
            var dto = new LeadConvertDto
            {
                LeadId = _lead.LeadId,
                EmployeeId = _convertEmployeeId,
                ExpectedValue = _convertExpectedValue,
                Notes = _convertNotes
            };

            var result = await LeadsService.ConvertLeadToClientAsync(dto, _currentUserName);

            if (result.Success)
            {
                Snackbar.Add("تم تحويل الـ Lead إلى فرصة بيع بنجاح", Severity.Success);
                _showConvertDialog = false;

                if (result.OpportunityId > 0)
                    Navigation.NavigateTo($"/crm/opportunities/{result.OpportunityId}");
                else
                    await LoadLeadAsync();
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("تعذّر التحويل: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isConverting = false;
        }
    }

    // ═══════════════════════════════════════════
    //  تعديل الملاحظات Inline
    // ═══════════════════════════════════════════
    private void StartEditNotes()
    {
        _editingNotes = _lead?.Notes ?? "";
        _isEditingNotes = true;
    }

    private void CancelEditNotes()
    {
        _isEditingNotes = false;
        _editingNotes = "";
    }

    private async Task SaveNotesAsync()
    {
        if (_lead == null) return;

        _isSavingNotes = true;

        try
        {
            var dto = new LeadsCrmUpdateDto
            {
                LeadId = _lead.LeadId,
                LeadStatus = _lead.LeadStatus,
                AssignedEmployeeId = _lead.AssignedEmployeeId,
                Notes = _editingNotes
            };

            var (ok, msg) = await LeadsService.UpdateLeadAsync(dto, _currentUserName);

            if (ok)
            {
                Snackbar.Add("تم حفظ الملاحظات", Severity.Success);
                _isEditingNotes = false;
                await LoadLeadAsync();
            }
            else
            {
                Snackbar.Add(msg, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("تعذّر حفظ الملاحظات: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isSavingNotes = false;
        }
    }

    // ═══════════════════════════════════════════
    //  نسخ رقم التليفون
    // ═══════════════════════════════════════════
    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            Snackbar.Add("تم نسخ الرقم ✅", Severity.Success);
        }
        catch
        {
            Snackbar.Add("تعذّر النسخ", Severity.Warning);
        }
    }

    // ═══════════════════════════════════════════
    //  بيانات الإعلان - هل فيها بيانات؟
    // ═══════════════════════════════════════════
    private bool HasAdData()
    {
        if (_lead == null) return false;
        return !string.IsNullOrWhiteSpace(_lead.CampaignName)
            || !string.IsNullOrWhiteSpace(_lead.AdName)
            || !string.IsNullOrWhiteSpace(_lead.AdSetName)
            || !string.IsNullOrWhiteSpace(_lead.FormName)
            || !string.IsNullOrWhiteSpace(_lead.MetaLeadId)
            || !string.IsNullOrWhiteSpace(_lead.Platform);
    }

    private int CountAdFields()
    {
        if (_lead == null) return 0;
        int count = 0;
        if (!string.IsNullOrWhiteSpace(_lead.Platform)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.CampaignName)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.AdName)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.AdSetName)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.FormName)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.MetaLeadId)) count++;
        return count;
    }

    private int CountCustomerFields()
    {
        if (_lead == null) return 0;
        int count = 0;
        if (!string.IsNullOrWhiteSpace(_lead.FullName)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.Phone)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.Phone2)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.Email)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.City)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.Area)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.Address)) count++;
        return count;
    }

    private int CountProjectFields()
    {
        if (_lead == null) return 0;
        int count = 0;
        if (!string.IsNullOrWhiteSpace(_lead.ProjectType)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.ProjectStage)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.Budget)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.DecisionMaker)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.NextAction)) count++;
        if (!string.IsNullOrWhiteSpace(_lead.BestTimeToReach)) count++;
        return count;
    }

    // ═══════════════════════════════════════════
    //  مؤشر سرعة الاستجابة (Response Time Badge)
    // ═══════════════════════════════════════════
    private record TemperatureBadge(string Class, string Icon, string Text);

    private TemperatureBadge? GetTemperatureBadge()
    {
        if (_lead is null) return null;

        // لو محول أو مرفوض → مفيش badge
        if (_lead.IsConverted || _lead.LeadStatus == "محول" || _lead.LeadStatus == "مرفوض")
            return null;

        // لو تم التواصل → "تم الرد"
        if (_lead.LeadStatus == "تم التواصل" || _lead.LastContactDate.HasValue)
            return new("follow-badge temp-responded", "✓", "تم الرد");

        // لو لسه جديد → نحسب الوقت
        var age = DateTime.Now - _lead.CreatedAt;
        if (age.TotalMinutes < 15)
            return new("follow-badge temp-hot", "🔥", "حار");
        if (age.TotalHours < 1)
            return new("follow-badge temp-warm", "🟡", "يحتاج متابعة");

        return new("follow-badge temp-cold", "❄️", "متأخر");
    }

    private string GetTemperatureBg()
    {
        if (_lead is null) return "rgba(255,255,255,.16)";
        if (_lead.IsConverted || _lead.LeadStatus == "محول") return "rgba(34,197,94,.4)";
        if (_lead.LeadStatus == "مرفوض") return "rgba(239,68,68,.4)";
        if (_lead.LeadStatus == "تم التواصل" || _lead.LastContactDate.HasValue) return "rgba(34,197,94,.35)";

        var age = DateTime.Now - _lead.CreatedAt;
        if (age.TotalMinutes < 15) return "rgba(239,68,68,.5)";     // حار
        if (age.TotalHours < 1) return "rgba(245,158,11,.5)";       // دافئ
        return "rgba(59,130,246,.5)";                                 // بارد
    }

    // ═══════════════════════════════════════════
    //  Helpers
    // ═══════════════════════════════════════════
    private RenderFragment InfoTile(string label, string? value, bool wide = false, bool ltr = false) => @<div class="info-tile @(wide ? "wide" : "")">
        <span class="info-label">@label</span>
        <span class="info-value @(ltr ? "ltr" : "")">@(string.IsNullOrWhiteSpace(value) ? "—" : value)</span>
    </div>;

    private static string Safe(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string? FormatDateTime(DateTime? value)
        => value.HasValue ? value.Value.ToString("yyyy/MM/dd HH:mm") : null;

    private string GetConversionText()
    {
        if (_lead is null) return "—";
        return $"عميل #{_lead.ConvertedPartyId} — فرصة #{_lead.ConvertedOpportunityId}";
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "؟";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString();
        return $"{parts[0][0]}{parts[1][0]}";
    }

    private string GetStatusClass(string? status) => status switch
    {
        "جديد" => "status-new",
        "تم التواصل" => "status-contacted",
        "مؤهل" => "status-qualified",
        "محول" => "status-converted",
        "مرفوض" => "status-rejected",
        _ => "status-default"
    };

    private string GetPlatformText(string? platform) => platform switch
    {
        "fb" => "Facebook",
        "ig" => "Instagram",
        _ => platform ?? "—"
    };

    private static string GetInteractionClass(string? type) => type switch
    {
        LeadInteractionTypes.Call => "li-call",
        LeadInteractionTypes.WhatsApp => "li-whatsapp",
        LeadInteractionTypes.Assigned => "li-assigned",
        LeadInteractionTypes.Rejected => "li-rejected",
        _ => "li-note"
    };

    private static string GetInteractionIcon(string? type) => type switch
    {
        LeadInteractionTypes.Call => Icons.Material.Rounded.Phone,
        LeadInteractionTypes.WhatsApp => Icons.Custom.Brands.WhatsApp,
        LeadInteractionTypes.Assigned => Icons.Material.Rounded.AssignmentInd,
        LeadInteractionTypes.FollowUp => Icons.Material.Rounded.EventRepeat,
        LeadInteractionTypes.Rejected => Icons.Material.Rounded.Cancel,
        _ => Icons.Material.Rounded.Notes
    };

    private static string GetInteractionColor(string? type) => type switch
    {
        LeadInteractionTypes.Assigned => "#0ea5e9",
        LeadInteractionTypes.Call => "#2563eb",
        LeadInteractionTypes.WhatsApp => "#16a34a",
        LeadInteractionTypes.FollowUp => "#f59e0b",
        LeadInteractionTypes.Converted => "#7c3aed",
        LeadInteractionTypes.Rejected => "#dc2626",
        _ => "#64748b"
    };

    private string GetFollowText()
    {
        if (_lead is null) return "—";
        if (_lead.IsConverted || _lead.LeadStatus == "محول") return "تم التحويل";
        if (_lead.LeadStatus == "مرفوض") return "مرفوض";
        if (_lead.LastContactDate.HasValue) return $"آخر تواصل {FormatElapsed(_lead.LastContactDate.Value)}";
        return $"وصل {FormatElapsed(_lead.CreatedAt)}";
    }

    private string GetFollowClass()
    {
        if (_lead is null) return "follow-badge follow-new";
        if (_lead.IsConverted || _lead.LeadStatus == "محول") return "follow-badge follow-done";
        if (_lead.LeadStatus == "مرفوض") return "follow-badge follow-rejected";
        if (_lead.LastContactDate.HasValue) return "follow-badge follow-contact";

        var age = DateTime.Now - _lead.CreatedAt;
        if (age.TotalHours >= 1) return "follow-badge follow-late";
        if (age.TotalMinutes >= 15) return "follow-badge follow-warn";
        return "follow-badge follow-new";
    }

    private static string FormatElapsed(DateTime date)
    {
        var span = DateTime.Now - date;
        if (span.TotalMinutes < 1) return "الآن";
        if (span.TotalMinutes < 60) return $"منذ {(int)span.TotalMinutes} د";
        if (span.TotalHours < 24) return $"منذ {(int)span.TotalHours} س";
        if (span.TotalDays < 30) return $"منذ {(int)span.TotalDays} يوم";
        return date.ToString("yyyy/MM/dd");
    }

    private void OpenWhatsApp(string phone)
    {
        var clean = phone.Replace(" ", "").Replace("-", "");
        if (!clean.StartsWith("+") && !clean.StartsWith("2")) clean = "2" + clean;
        if (!clean.StartsWith("+")) clean = "+" + clean;
        Navigation.NavigateTo($"https://wa.me/{clean[1..]}", forceLoad: true);
    }

    private void CallPhone(string phone)
    {
        Navigation.NavigateTo($"tel:{phone}", forceLoad: true);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/crm/leads");
    }
}
