    private List<TaskType> _taskTypes = new();
    private List<LostReason> _lostReasons = new();

    private List<SalesStage> _pipelineStages => _stages.OrderBy(s => s.StageOrder).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync(); var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";
            _canView = user.HasClaim("Permission","frmNewInteraction:View")||user.IsInRole("Admin");
            _canAdd = user.HasClaim("Permission","frmNewInteraction:Add")||user.IsInRole("Admin");
            _canEdit = user.HasClaim("Permission","frmNewInteraction:Edit")||user.IsInRole("Admin");
            if(!_canView){ Navigation.NavigateTo("/"); return; }
            if(Id==0&&!_canAdd){ Snackbar.Add("غير مصرح بإضافة فرصة",Severity.Error); Navigation.NavigateTo("/crm/opportunities"); return; }
            if(Id>0&&!_canEdit){ Snackbar.Add("غير مصرح بتعديل الفرصة",Severity.Error); Navigation.NavigateTo("/crm/opportunities"); return; }
            _isEdit = Id>0;
            _stages = await OppService.GetStagesAsync(); _sources = await OppService.GetSourcesAsync();
            _adTypes = await OppService.GetAdTypesAsync(); _statuses = await OppService.GetContactStatusesAsync();
            _categories = await OppService.GetCategoriesAsync(); _employees = await OppService.GetActiveEmployeesAsync();
            _taskTypes = await OppService.GetTaskTypesAsync(); _lostReasons = await OppService.GetLostReasonsAsync();
            if(IsEdit) await LoadForEdit();
            else if(PartyIdFromQuery.HasValue) await PreselectPartyFromQueryAsync(PartyIdFromQuery.Value);
        }
        catch(Exception ex){ Snackbar.Add($"خطأ: {ex.Message}",Severity.Error); }
        finally{ _isLoading = false; }
    }

    private static string PartyToString(PartySearchDto? p) => p?.PartyName ?? string.Empty;

    private async Task<IEnumerable<PartySearchDto>> SearchPartiesWrapper(string search, CancellationToken ct)
    {
        if(string.IsNullOrWhiteSpace(search)||search.Length<2) return new List<PartySearchDto>();
        _isSearching = true; StateHasChanged();
        try { return await OppService.SearchPartiesAsync(search); }
        catch { return new List<PartySearchDto>(); }
        finally { _isSearching = false; StateHasChanged(); }
    }

    private async Task PreselectPartyFromQueryAsync(int partyId)
    {
        try
        {
            var parties = await OppService.SearchPartiesAsync("");
            var party = parties.FirstOrDefault(p => p.PartyId == partyId);
            if(party==null){ Snackbar.Add("تعذر اختيار العميل تلقائياً",Severity.Warning); return; }
            _selectedParty = party; _model.IsNewClient = false; _model.ExistingPartyId = party.PartyId;
            _clientName = party.PartyName; _clientPhone = party.Phone;
        }
        catch{ Snackbar.Add("تعذر تحميل بيانات العميل",Severity.Warning); }
    }

    private async Task LoadForEdit()
    {
        var form = await OppService.GetOpportunityForEditAsync(Id);
        if(form==null){ Snackbar.Add("الفرصة غير موجودة",Severity.Error); Navigation.NavigateTo("/crm/opportunities"); return; }
        _model = new OpportunityWorkflowDto{
            OpportunityId = form.OpportunityId, IsNewClient = false, ExistingPartyId = form.PartyId,
            EmployeeId = form.EmployeeId, SourceId = form.SourceId, AdTypeId = form.AdTypeId,
            StageId = form.StageId, StatusId = form.StatusId, CategoryId = form.CategoryId,
            InterestedProduct = form.InterestedProduct, ExpectedValue = form.ExpectedValue,
            FirstContactDate = form.FirstContactDate, NextFollowUpDate = form.NextFollowUpDate,
            Location = form.Location, LostReasonId = form.LostReasonId, LostNotes = form.LostNotes,
            Summary = form.Notes, Guidance = form.Guidance, StageBeforeId = form.StageId
        };
        _editPartyName = form.PartyName; _editPartyPhone = form.Phone;
        _clientName = form.PartyName; _clientPhone = form.Phone;
    }

    private void OnClientTypeChanged()
    {
        _model.ExistingPartyId = null; _model.NewClientName = null; _model.NewPhone = null;
        _model.NewAddress = null; _model.OpportunityId = null; _model.HasActiveOpportunity = false;
        _selectedParty = null; _clientName = null; _clientPhone = null;
    }

    private async Task OnPartySelected(PartySearchDto? party)
    {
        if(party==null) return;
        _model.ExistingPartyId = party.PartyId; _model.ExistingPartyPhone = party.Phone;
        _clientName = party.PartyName; _clientPhone = party.Phone;
        try
        {
            var existing = await OppService.GetActiveOpportunityByPartyAsync(party.PartyId);
            if(existing!=null)
            {
                _model.OpportunityId = existing.OpportunityId; _model.StageBeforeId = existing.StageId??0;
                _model.EmployeeId = existing.EmployeeId??_model.EmployeeId; _model.SourceId = existing.SourceId??_model.SourceId;
                _model.AdTypeId = existing.AdTypeId??_model.AdTypeId; _model.StageId = existing.StageId;
                _model.StatusId = existing.StatusId??_model.StatusId; _model.CategoryId = existing.CategoryId??_model.CategoryId;
                _model.InterestedProduct = existing.InterestedProduct??_model.InterestedProduct;
                _model.FirstContactDate = existing.FirstContactDate??_model.FirstContactDate;
                _model.NextFollowUpDate = existing.NextFollowUpDate??_model.NextFollowUpDate;
                _model.LostReasonId = existing.LostReasonId; _model.LostNotes = existing.LostNotes;
                _model.HasActiveOpportunity = true;
            }
            else { _model.OpportunityId = null; _model.HasActiveOpportunity = false; }
        }
        catch { }
    }

    private void ClearClient()
    {
        _selectedParty = null; _model.ExistingPartyId = null; _model.ExistingPartyPhone = null;
        _model.OpportunityId = null; _model.HasActiveOpportunity = false;
        _clientName = null; _clientPhone = null;
    }

    private async Task CheckPhoneDuplicate()
    {
        if(string.IsNullOrWhiteSpace(_model.NewPhone)) return;
        try { var exists = await OppService.CheckPhoneExistsAsync(_model.NewPhone); if(exists){ Snackbar.Add("رقم الهاتف مسجل مسبقاً",Severity.Warning); _model.NewPhone = ""; } }
        catch { }
    }

    private void OnStageChanged(int? stageId)
    {
        _model.StageId = stageId;
        if(stageId==4||stageId==5){ _model.NextFollowUpDate = null; _model.TaskTypeId = null; }
        else
        {
            _model.LostReasonId = null; _model.LostNotes = null;
            if(_model.NextFollowUpDate==null||_model.NextFollowUpDate<=DateTime.Today)
                _model.NextFollowUpDate = DateTime.Today.AddDays(1);
        }
    }

    private void OnValueInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        var cleaned = new string(raw.Where(c => char.IsDigit(c) || c == '.').ToArray());
        if (decimal.TryParse(cleaned, out var val))
            _model.ExpectedValue = val;
        else if (string.IsNullOrWhiteSpace(cleaned))
            _model.ExpectedValue = null;
        StateHasChanged();
    }

    private void OnSliderInput(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var val))
            _model.ExpectedValue = val;
    }

    private bool ValidateForm()
    {
        if(!_isEdit)
        {
            if(_model.IsNewClient){
                if(string.IsNullOrWhiteSpace(_model.NewClientName)){ Snackbar.Add("برجاء إدخال اسم العميل",Severity.Warning); return false; }
                if(string.IsNullOrWhiteSpace(_model.NewPhone)){ Snackbar.Add("برجاء إدخال رقم الهاتف",Severity.Warning); return false; }
            }
            else if(!_model.ExistingPartyId.HasValue){ Snackbar.Add("برجاء اختيار العميل",Severity.Warning); return false; }
        }
        if(!_model.SourceId.HasValue){ Snackbar.Add("اختر مصدر التواصل",Severity.Warning); return false; }
        if(!_model.StatusId.HasValue){ Snackbar.Add("اختر حالة التواصل",Severity.Warning); return false; }
        if(!_model.FirstContactDate.HasValue){ Snackbar.Add("أدخل تاريخ أول تواصل",Severity.Warning); return false; }
        if(!_model.StageId.HasValue){ Snackbar.Add("اختر المرحلة",Severity.Warning); return false; }
        if((_model.StageId==1||_model.StageId==2||_model.StageId==7)&&!_model.TaskTypeId.HasValue)
        { Snackbar.Add("اختر نوع المتابعة لهذه المرحلة",Severity.Warning); return false; }
        if(_showLostFields&&!_model.LostReasonId.HasValue){ Snackbar.Add("اختر سبب الخسارة",Severity.Warning); return false; }
        if(string.IsNullOrWhiteSpace(_model.Summary)){ Snackbar.Add("اكتب ملخص التواصل",Severity.Warning); return false; }
        return true;
    }

    private async Task SaveAndClose(){ if(!ValidateForm()) return; await DoSave(false); }
    private async Task SaveAndNew(){ if(!ValidateForm()) return; await DoSave(true); }

    private async Task DoSave(bool andNew)
    {
        _isSaving = true; StateHasChanged();
        try
        {
            var (ok,msg,oppId) = await OppService.SaveWorkflowAsync(_model,_currentUserName!);
            if(ok){
                _savedOpportunityId = oppId;
                _savedClientName = _clientName??_model.NewClientName;
                _savedExpectedValue = _model.ExpectedValue ?? 0;
                if(andNew){ Snackbar.Add(msg,Severity.Success); ResetForm(); }
                else _saveSuccess = true;
            }
            else Snackbar.Add(msg,Severity.Error);
        }
        catch(Exception ex){ Snackbar.Add($"خطأ: {ex.Message}",Severity.Error); }
        finally{ _isSaving = false; StateHasChanged(); }
    }

    private void ResetForm()
    {
        _model = new OpportunityWorkflowDto{ IsNewClient = false, FirstContactDate = DateTime.Today, NextFollowUpDate = DateTime.Today.AddDays(1) };
        _selectedParty = null; _clientName = null; _clientPhone = null;
    }

    private string GetClientName()
    {
        if(!string.IsNullOrWhiteSpace(_model.NewClientName)) return _model.NewClientName;
        return _clientName ?? "—";
    }

    private string FormatInputValue(decimal? v) => v?.ToString("N0") ?? "";
    private static string FormatMoney(decimal v) => v switch
    {
        >= 1_000_000 => $"{v / 1_000_000:N1}M ج.م",
        >= 1_000 => $"{v / 1_000:N1}K ج.م",
        _ => $"{v:N0} ج.م"
    };
    private static string FormatLargeMoney(decimal v) => v switch
    {
        >= 1_000_000 => $"{v / 1_000_000:N1}M",
        >= 1_000 => $"{v / 1_000:N1}K",
        _ => $"{v:N0}"
    };
    private static string FormatMoneyFull(decimal v) => $"{v:N0} ج.م";

