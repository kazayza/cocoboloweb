@code {
    [Parameter] public int Id { get; set; }
    [SupplyParameterFromQuery(Name = "partyId")] public int? PartyIdFromQuery { get; set; }

    private bool _isLoading = true, _isSaving, _isEdit, _saveSuccess, _isSearching;
    private int _savedOpportunityId;
    private decimal _savedExpectedValue;
    private string? _savedClientName, _currentUserName, _editPartyName, _editPartyPhone, _clientName, _clientPhone;
    private bool _canView, _canAdd, _canEdit;
    private OpportunityWorkflowDto _model = new();
    private PartySearchDto? _selectedParty;
    private bool IsEdit => Id > 0;
    private bool _showLostFields => _model.StageId == 4 || _model.StageId == 5;

    private List<SalesStage> _stages = new();
