@code {
    [Parameter] public int Id { get; set; }
    [SupplyParameterFromQuery(Name = "partyId")]
public int? PartyIdFromQuery { get; set; }

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _isEdit = false;
    private bool _saveSuccess = false;
    private bool _isSearching = false;
    private bool _copyLostToSummary = false;
    private int _step = 1;
    private int _savedOpportunityId;
    private string? _savedClientName;
    private string? _currentUserName;
    private string? _editPartyName;
    private string? _editPartyPhone;
    private string? _clientName;
    private string? _clientPhone;

    // Permissions
    private bool _canView, _canAdd, _canEdit;

    private OpportunityWorkflowDto _model = new();
    private PartySearchDto? _selectedParty;

    private bool _showLostFields => _model.StageId == 4 || _model.StageId == 5;
    private bool _showFollowUp => !_showLostFields;

    // Lookup data
    private List<SalesStage> _stages = new();
    private List<ContactSource> _sources = new();
    private List<AdType> _adTypes = new();
    private List<ContactStatus> _statuses = new();
    private List<InterestCategory> _categories = new();
    private List<Employee> _employees = new();
    private List<TaskType> _taskTypes = new();
    private List<LostReason> _lostReasons = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canView  = user.HasClaim("Permission", "frmNewInteraction:View")   || user.IsInRole("Admin");
            _canAdd   = user.HasClaim("Permission", "frmNewInteraction:Add")    || user.IsInRole("Admin");
            _canEdit  = user.HasClaim("Permission", "frmNewInteraction:Edit")   || user.IsInRole("Admin");

            if (!_canView)
            {
                Navigation.NavigateTo("/");
                return;
            }

            if (Id == 0 && !_canAdd)
            {
                Snackbar.Add("غير مصرح لك بإضافة فرصة جديدة", Severity.Error);
                Navigation.NavigateTo("/crm/opportunities");
                return;
            }

            if (Id > 0 && !_canEdit)
            {
                Snackbar.Add("غير مصرح لك بتعديل الفرصة", Severity.Error);
                Navigation.NavigateTo("/crm/opportunities");
                return;
            }

            _stages = await OppService.GetStagesAsync();
            _sources = await OppService.GetSourcesAsync();
            _adTypes = await OppService.GetAdTypesAsync();
            _statuses = await OppService.GetContactStatusesAsync();
            _categories = await OppService.GetCategoriesAsync();
            _employees = await OppService.GetActiveEmployeesAsync();
            _taskTypes = await OppService.GetTaskTypesAsync();
            _lostReasons = await OppService.GetLostReasonsAsync();

            if (Id > 0)
            {
                _isEdit = true;
                await LoadForEdit();
            }
            else if (PartyIdFromQuery.HasValue)
{
    await PreselectPartyFromQueryAsync(PartyIdFromQuery.Value);
}
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ═══ ToString Helper ═══
    private static string PartyToString(PartySearchDto? p) => p?.PartyName ?? string.Empty;

    // ═══ Search Wrapper ═══
    private async Task<IEnumerable<PartySearchDto>> SearchPartiesWrapper(string search, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(search) || search.Length < 2)
            return new List<PartySearchDto>();

        _isSearching = true;
        StateHasChanged();
        try
        {
            return await OppService.SearchPartiesAsync(search);
        }
        catch
        {
            return new List<PartySearchDto>();
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }
    private async Task PreselectPartyFromQueryAsync(int partyId)
{
    try
    {
        var parties = await OppService.SearchPartiesAsync("");

        var party = parties.FirstOrDefault(p => p.PartyId == partyId);

        if (party == null)
        {
            Snackbar.Add("تعذر اختيار العميل تلقائيًا، برجاء اختياره يدويًا.", Severity.Warning);
            return;
        }

        _selectedParty = party;
        _model.IsNewClient = false;
        _model.ExistingPartyId = party.PartyId;
        _clientName = party.PartyName;
        _clientPhone = party.Phone;
    }
    catch
    {
        Snackbar.Add("تعذر تحميل بيانات العميل تلقائيًا.", Severity.Warning);
    }
}

    // ═══ تحميل للتعديل ═══
    private async Task LoadForEdit()
    {
        var form = await OppService.GetOpportunityForEditAsync(Id);
        if (form == null)
        {
            Snackbar.Add("الفرصة غير موجودة", Severity.Error);
            Navigation.NavigateTo("/crm/opportunities");
            return;
        }

        _model = new OpportunityWorkflowDto
        {
            OpportunityId = form.OpportunityId,
            IsNewClient = false,
            ExistingPartyId = form.PartyId,
            EmployeeId = form.EmployeeId,
            SourceId = form.SourceId,
            AdTypeId = form.AdTypeId,
            StageId = form.StageId,
            StatusId = form.StatusId,
            CategoryId = form.CategoryId,
            InterestedProduct = form.InterestedProduct,
            FirstContactDate = form.FirstContactDate,
            NextFollowUpDate = form.NextFollowUpDate,
            Location = form.Location,
            LostReasonId = form.LostReasonId,
            LostNotes = form.LostNotes,
            Summary = form.Notes,
            Guidance = form.Guidance,
            StageBeforeId = form.StageId
        };

        _editPartyName = form.PartyName;
        _editPartyPhone = form.Phone;
        _clientName = form.PartyName;
        _clientPhone = form.Phone;
        _step = 2;
    }

    // ═══ Step Navigation ═══
    private void NextStep()
    {
        if (_step == 1 && !ValidateStep1()) return;
        if (_step == 2 && !ValidateStep2()) return;
        if (_step < 3) _step++;
    }

    private void PrevStep()
    {
        if (_step > 1) _step--;
    }

    private bool ValidateStep1()
    {
        if (_isEdit) return true;

        if (_model.IsNewClient)
        {
            if (string.IsNullOrWhiteSpace(_model.NewClientName))
            { Snackbar.Add("برجاء إدخال اسم العميل", Severity.Warning); return false; }
            if (string.IsNullOrWhiteSpace(_model.NewPhone))
            { Snackbar.Add("برجاء إدخال رقم الهاتف", Severity.Warning); return false; }
        }
        else
        {
            if (!_model.ExistingPartyId.HasValue)
            { Snackbar.Add("برجاء اختيار العميل", Severity.Warning); return false; }
        }
        return true;
    }

    private bool ValidateStep2()
    {
        if (!_model.SourceId.HasValue)
        { Snackbar.Add("برجاء اختيار مصدر التواصل", Severity.Warning); return false; }
        if (!_model.StatusId.HasValue)
        { Snackbar.Add("برجاء اختيار حالة التواصل", Severity.Warning); return false; }
        if (!_model.FirstContactDate.HasValue)
        { Snackbar.Add("برجاء إدخال تاريخ أول تواصل", Severity.Warning); return false; }
        return true;
    }

    private bool ValidateStep3()
    {
        if (!_model.StageId.HasValue)
        { Snackbar.Add("برجاء اختيار المرحلة", Severity.Warning); return false; }
        if (_showLostFields && !_model.LostReasonId.HasValue)
        { Snackbar.Add("برجاء اختيار سبب الخسارة", Severity.Warning); return false; }
        if (string.IsNullOrWhiteSpace(_model.Summary))
        { Snackbar.Add("برجاء إدخال ملخص التواصل", Severity.Warning); return false; }
        return true;
    }

    // ═══ Client Type Changed ═══
    private void OnClientTypeChanged()
    {
        _model.ExistingPartyId = null;
        _model.NewClientName = null;
        _model.NewPhone = null;
        _model.NewAddress = null;
        _model.OpportunityId = null;
        _model.HasActiveOpportunity = false;
        _selectedParty = null;
        _clientName = null;
        _clientPhone = null;
    }

    // ═══ Party Selected ═══
    private async Task OnPartySelected(PartySearchDto? party)
    {
        if (party == null) return;

        _model.ExistingPartyId = party.PartyId;
        _model.ExistingPartyPhone = party.Phone;
        _clientName = party.PartyName;
        _clientPhone = party.Phone;

        try
        {
            var existing = await OppService.GetActiveOpportunityByPartyAsync(party.PartyId);
            if (existing != null)
            {
                _model.OpportunityId = existing.OpportunityId;
                _model.StageBeforeId = existing.StageId ?? 0;
                _model.EmployeeId = existing.EmployeeId ?? _model.EmployeeId;
                _model.SourceId = existing.SourceId ?? _model.SourceId;
                _model.AdTypeId = existing.AdTypeId ?? _model.AdTypeId;
                _model.StageId = existing.StageId;
                _model.StatusId = existing.StatusId ?? _model.StatusId;
                _model.CategoryId = existing.CategoryId ?? _model.CategoryId;
                _model.InterestedProduct = existing.InterestedProduct ?? _model.InterestedProduct;
                _model.FirstContactDate = existing.FirstContactDate ?? _model.FirstContactDate;
                _model.NextFollowUpDate = existing.NextFollowUpDate ?? _model.NextFollowUpDate;
                _model.LostReasonId = existing.LostReasonId;
                _model.LostNotes = existing.LostNotes;
                _model.HasActiveOpportunity = true;
            }
            else
            {
                _model.OpportunityId = null;
                _model.HasActiveOpportunity = false;
            }
        }
        catch { }
    }

    private void ClearClient()
    {
        _selectedParty = null;
        _model.ExistingPartyId = null;
        _model.ExistingPartyPhone = null;
        _model.OpportunityId = null;
        _model.HasActiveOpportunity = false;
        _clientName = null;
        _clientPhone = null;
    }

    // ═══ Phone Duplicate Check ═══
    private async Task CheckPhoneDuplicate()
    {
        if (string.IsNullOrWhiteSpace(_model.NewPhone)) return;
        try
        {
            var exists = await OppService.CheckPhoneExistsAsync(_model.NewPhone);
            if (exists)
            {
                Snackbar.Add("رقم الهاتف مسجل مسبقاً — ابحث عن العميل أولاً", Severity.Warning);
                _model.NewPhone = "";
            }
        }
        catch { }
    }

    // ═══ Source Changed ═══
    private void OnSourceChanged(int? sourceId)
    {
        _model.SourceId = sourceId;
    }

    // ═══ Stage Changed ═══
    private void OnStageChanged(int? stageId)
    {
        _model.StageId = stageId;

        if (stageId == 4 || stageId == 5)
        {
            _model.NextFollowUpDate = null;
            _model.TaskTypeId = null;
        }
        else
        {
            _model.LostReasonId = null;
            _model.LostNotes = null;
            if (_model.NextFollowUpDate == null || _model.NextFollowUpDate <= DateTime.Today)
                _model.NextFollowUpDate = DateTime.Today.AddDays(1);
        }
    }

    // ═══ Save ═══
    private async Task SaveAndClose()
    {
        if (!ValidateStep3()) return;
        await DoSave(false);
    }

    private async Task SaveAndNew()
    {
        if (!ValidateStep3()) return;
        await DoSave(true);
    }

    private async Task DoSave(bool andNew)
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            if (_copyLostToSummary && !string.IsNullOrWhiteSpace(_model.LostNotes))
                _model.Summary = _model.LostNotes;

            var (ok, msg, oppId) = await OppService.SaveWorkflowAsync(_model, _currentUserName!);

            if (ok)
            {
                _savedOpportunityId = oppId;
                _savedClientName = _clientName ?? _model.NewClientName;

                if (andNew)
                {
                    Snackbar.Add(msg, Severity.Success);
                    ResetForm();
                }
                else
                {
                    _saveSuccess = true;
                }
            }
            else
            {
                Snackbar.Add(msg, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void ResetForm()
    {
        _model = new OpportunityWorkflowDto
        {
            IsNewClient = false,
            FirstContactDate = DateTime.Today,
            NextFollowUpDate = DateTime.Today.AddDays(1)
        };
        _selectedParty = null;
        _clientName = null;
        _clientPhone = null;
        _step = 1;
        _copyLostToSummary = false;
    }

    // ═══ Navigation ═══
    private void GoToNew() => Navigation.NavigateTo("/crm/opportunities/new", forceLoad: true);
    private void GoToDetail(int id) => Navigation.NavigateTo($"/crm/opportunities/{id}");
    private void GoToKanban() => Navigation.NavigateTo("/crm/opportunities");
    private void Cancel() => Navigation.NavigateTo("/crm/opportunities");

    private async Task OpenWhatsApp(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return;
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        if (digits.StartsWith("0")) digits = "20" + digits[1..];
        else if (!digits.StartsWith("20")) digits = "20" + digits;
        await JS.InvokeVoidAsync("open", $"https://wa.me/{digits}", "_blank");
    }

    private async Task CallPhone(string? phone)
    {
        if (!string.IsNullOrWhiteSpace(phone))
            await JS.InvokeVoidAsync("open", $"tel:{phone}", "_self");
    }
}