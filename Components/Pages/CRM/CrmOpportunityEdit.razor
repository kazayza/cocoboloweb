@page "/crm/opportunities/new"
@page "/crm/opportunities/{Id:int}/edit"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@inject IOpportunityService OppService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<PageTitle>@(_isNew ? "فرصة جديدة" : "تعديل الفرصة") — CRM</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <MudProgressCircular Color="MudColor.Secondary" Size="MudSize.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Class="loading-text">جاري التحميل...</MudText>
    </div>
}
else
{
<div dir="rtl" class="edit-page">
    <MudPaper Class="form-card" Elevation="0">
        <div class="form-header">
            <MudIcon Icon="@Icons.Material.Rounded.TrackChanges" Size="MudSize.Large" />
            <h2>@(_isNew ? "إنشاء فرصة بيع جديدة" : "تعديل الفرصة")</h2>
        </div>

        <div class="form-fields">
            <MudTextField T="string" Label="اسم العميل" Variant="MudVariant.Outlined"
                          @bind-Value="_form.PartyName" Immediate="true" />
            
            <MudSelect T="int" Label="المرحلة" Variant="MudVariant.Outlined" 
                       @bind-Value="_form.StageId" Dense="true">
                @foreach (var s in _stages)
                {
                    <MudSelectItem Value="@s.StageId">@(s.StageNameAr ?? s.StageName)</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" Label="الموظف" Variant="MudVariant.Outlined" 
                       @bind-Value="_form.EmployeeId" Dense="true" Clearable="true">
                @foreach (var e in _employees)
                {
                    <MudSelectItem Value="@((int?)e.EmployeeId)">@e.FullName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int?" Label="المصدر" Variant="MudVariant.Outlined" 
                       @bind-Value="_form.SourceId" Dense="true" Clearable="true">
                @foreach (var s in _sources)
                {
                    <MudSelectItem Value="@((int?)s.SourceId)">@(s.SourceNameAr ?? s.SourceName)</MudSelectItem>
                }
            </MudSelect>

            <MudTextField T="string" Label="المنتج المهتم به" Variant="MudVariant.Outlined"
                          @bind-Value="_form.InterestedProduct" Immediate="true" />

            <MudTextField T="decimal?" Label="القيمة المتوقعة" Variant="MudVariant.Outlined"
                          @bind-Value="_form.ExpectedValue" />

            <MudDatePicker Label="تاريخ أول تواصل" Variant="MudVariant.Outlined"
                           Date="_form.FirstContactDate"
                           DateChanged="OnFirstContactDateChanged" />

            <MudDatePicker Label="موعد المتابعة القادمة" Variant="MudVariant.Outlined"
                           Date="_form.NextFollowUpDate"
                           DateChanged="OnNextFollowUpDateChanged" />

            <MudTextField T="string" Label="الملاحظات" Variant="MudVariant.Outlined"
                          @bind-Value="_form.Notes" Lines="3" Immediate="true" />

            <MudTextField T="string" Label="التوجيه" Variant="MudVariant.Outlined"
                          @bind-Value="_form.Guidance" Lines="2" Immediate="true" />
        </div>

        <div class="form-actions">
            <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary"
                       OnClick="Save" Disabled="_isSaving">
                @(_isSaving ? "جاري الحفظ..." : (_isNew ? "إنشاء الفرصة" : "حفظ التعديل"))
            </MudButton>
            <MudButton Variant="MudVariant.Text" OnClick="GoBack">إلغاء</MudButton>
        </div>
    </MudPaper>
</div>
}

<style>
    .edit-page { padding: 1rem 1.5rem 3rem; }
    .form-card { padding: 2rem; border-radius: 16px; border: 1px solid var(--mud-palette-lines-default); }
    .form-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--mud-palette-lines-inputs); }
    .form-header h2 { margin: 0; font-size: 1.25rem; font-weight: 700; }
    .form-fields { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .form-actions { display: flex; gap: 1rem; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--mud-palette-lines-inputs); }
    
    @@media (max-width: 900px) {
        .edit-page { padding: 0.5rem; }
        .form-card { padding: 1rem; }
        .form-fields { grid-template-columns: 1fr; }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private bool _isLoading = true, _isSaving, _isNew = true;
    private OpportunityFormDto _form = new() { FirstContactDate = DateTime.Today };
    private List<SalesStage> _stages = new();
    private List<ContactSource> _sources = new();
    private List<Employee> _employees = new();
    private string? _currentUserName;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            _currentUserName = auth.User.Identity?.Name ?? "System";

            _stages = await OppService.GetStagesAsync();
            _sources = await OppService.GetSourcesAsync();
            _employees = await OppService.GetEmployeesAsync();

            if (Id > 0)
            {
                _isNew = false;
                var editDto = await OppService.GetOpportunityForEditAsync(Id);
                if (editDto == null) { Snackbar.Add("الفرصة غير موجودة", Severity.Error); Navigation.NavigateTo("/crm/opportunities"); return; }
                _form = editDto;
            }
        }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _isLoading = false; }
    }

    private void OnFirstContactDateChanged(DateTime? d) => _form.FirstContactDate = d ?? DateTime.Today;
    private void OnNextFollowUpDateChanged(DateTime? d) => _form.NextFollowUpDate = d;

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.PartyName)) { Snackbar.Add("أدخل اسم العميل", Severity.Warning); return; }
        
        _isSaving = true;
        var (ok, msg, oppId) = await OppService.SaveOpportunityAsync(_form, _currentUserName!);
        _isSaving = false;

        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) { Navigation.NavigateTo("/crm/opportunities"); }
    }

    private void GoBack() => Navigation.NavigateTo("/crm/opportunities");
}