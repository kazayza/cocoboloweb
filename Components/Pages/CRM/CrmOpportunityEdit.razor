@page "/crm/opportunities/new"
@page "/crm/opportunities/{Id:int}/edit"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant
@inject IOpportunityService OppService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

<PageTitle>@(IsEdit ? "تعديل الفرصة" : "فرصة بيع جديدة") — CRM</PageTitle>

<div dir="rtl" class="opp-page">

    @* ═══════════════════════════════════════════════════════
       LOADING STATE
       ═══════════════════════════════════════════════════════ *@
    @if (_isLoading)
    {
        <div class="opp-loading">
            <div class="opp-loader">
                <div class="opp-loader-ring"></div>
                <span>جاري التحميل...</span>
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════════════
       SUCCESS STATE
       ═══════════════════════════════════════════════════════ *@
    else if (_saveSuccess)
    {
        <div class="opp-success">
            <div class="opp-success-card">
                <div class="opp-success-glow"></div>
                <div class="opp-success-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                </div>
                <h2 class="opp-success-title">تم الحفظ بنجاح! 🎉</h2>
                <p class="opp-success-sub">فرصة #@_savedOpportunityId — @_savedClientName</p>
                <div class="opp-success-value">@FormatMoney(_savedExpectedValue)</div>
                <div class="opp-success-actions">
                    <button class="opp-btn opp-btn-primary" @onclick="GoToNew">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                        إضافة فرصة جديدة
                    </button>
                    <button class="opp-btn opp-btn-outline" @onclick="() => GoToDetail(_savedOpportunityId)">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        عرض الفرصة
                    </button>
                    <button class="opp-btn opp-btn-ghost" @onclick="GoToKanban">
                        العودة للقائمة
                    </button>
                </div>
            </div>
        </div>
    }

    @* ═══════════════════════════════════════════════════════
       MAIN FORM
       ═══════════════════════════════════════════════════════ *@
    else
    {
        @* ──────────────────────────────────────────────────────
           HEADER — Green gradient + value hero (compact)
           ────────────────────────────────────────────────────── *@
        <div class="opp-header">
            <div class="opp-header-bg">
                <div class="opp-header-gradient"></div>
                <div class="opp-header-pattern"></div>
                <div class="opp-header-glow opp-header-glow-1"></div>
                <div class="opp-header-glow opp-header-glow-2"></div>
            </div>
            <div class="opp-header-content">
                <div class="opp-header-top">
                    <button class="opp-back-btn" @onclick="Cancel" title="رجوع">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                    </button>
                    <div class="opp-header-info">
                        <div class="opp-header-badge">@(IsEdit ? "تعديل" : "جديد")</div>
                        <h1 class="opp-header-title">@(IsEdit ? $"تعديل فرصة #{Id}" : "فرصة بيع جديدة")</h1>
                        <p class="opp-header-sub">CRM — COCO BOLO</p>
                    </div>
                    <div class="opp-header-spacer"></div>
                    @if (_clientPhone != null)
                    {
                        <button class="opp-header-action" @onclick="() => CallPhone(_clientPhone)" title="اتصال">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        </button>
                        <button class="opp-header-action opp-header-action-wa" @onclick="() => OpenWhatsApp(_clientPhone)" title="واتساب">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        </button>
                    }
                </div>

                @* ── Hero Value Display (compact) ── *@
                <div class="opp-hero">
                    <div class="opp-hero-value-area">
                        <div class="opp-hero-label">القيمة المتوقعة</div>
                        <div class="opp-hero-value">
                            <span class="opp-hero-currency">ج.م</span>
                            <span class="opp-hero-amount">@FormatLargeMoney(_model.ExpectedValue ?? 0)</span>
                        </div>
                        <div class="opp-hero-sub">
                            @if (_model.ExpectedValue.HasValue && _model.ExpectedValue > 0)
                            {
                                <div class="opp-hero-indicator">
                                    <div class="opp-hero-bar">
                                        <div class="opp-hero-bar-fill" style="width: @Math.Min(100, (int)(_model.ExpectedValue.Value / 1000000 * 100))%"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="opp-hero-meta">
                        <div class="opp-hero-chip">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            @(_stages.FirstOrDefault(s => s.StageId == _model.StageId)?.StageNameAr ?? "غير محدد")
                        </div>
                        <div class="opp-hero-chip">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            @(_model.NextFollowUpDate?.ToString("dd MMM, yyyy") ?? "لا يوجد متابعة")
                        </div>
                        <div class="opp-hero-chip">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            @(_employees.FirstOrDefault(e => e.EmployeeId == _model.EmployeeId)?.FullName ?? "غير معين")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ──────────────────────────────────────────────────────
           LAYOUT: Main Form + Sidebar Preview
           ────────────────────────────────────────────────────── *@
        <div class="opp-layout">

            @* ─── MAIN FORM COLUMN ─── *@
            <div class="opp-main">

                @* ▸ CLIENT CARD ──────────────────── *@
                <div class="opp-card">
                    <div class="opp-card-head">
                        <div class="opp-card-icon opp-card-icon-client">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <div>
                            <div class="opp-card-title">العميل</div>
                            <div class="opp-card-sub">اختر عميل موجود أو أضف عميل جديد</div>
                        </div>
                        <div class="opp-card-spacer"></div>
                        @if (!IsEdit)
                        {
                            <div class="opp-client-switch">
                                <button class="opp-csw-btn @(!_model.IsNewClient ? "opp-csw-on" : "")" @onclick="() => { _model.IsNewClient = false; OnClientTypeChanged(); }">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    موجود
                                </button>
                                <button class="opp-csw-btn @(_model.IsNewClient ? "opp-csw-on" : "")" @onclick="() => { _model.IsNewClient = true; OnClientTypeChanged(); }">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                                    جديد
                                </button>
                            </div>
                        }
                    </div>
                    <div class="opp-card-body">

                        @if (!_model.IsNewClient && !IsEdit)
                        {
                            <MudAutocomplete T="PartySearchDto"
                                Label="ابحث باسم أو رقم هاتف"
                                Variant="MudVariant.Outlined"
                                SearchFunc="SearchPartiesWrapper"
                                ToStringFunc="PartyToString"
                                Value="_selectedParty"
                                ValueChanged="OnPartySelected"
                                Class="opp-ac"
                                Clearable="true"
                                DebounceInterval="300"
                                AdornmentIcon="@Icons.Material.Rounded.Search"
                                AdornmentColor="MudColor.Primary" />

                            @if (_selectedParty != null)
                            {
                                <div class="opp-client-selected">
                                    <div class="opp-client-avatar">
                                        <span>@(_selectedParty.PartyName.Length > 0 ? _selectedParty.PartyName[0].ToString() : "?")</span>
                                    </div>
                                    <div class="opp-client-info">
                                        <div class="opp-client-name">@_selectedParty.PartyName</div>
                                        <div class="opp-client-phone">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                            @_selectedParty.Phone
                                        </div>
                                    </div>
                                    <button class="opp-client-clear" @onclick="ClearClient" title="إزالة">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                </div>
                            }

                            @if (_model.HasActiveOpportunity)
                            {
                                <div class="opp-warning">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                                    <div>
                                        <strong>يوجد فرصة مفتوحة</strong> لهذا العميل — سيتم الإضافة على نفس الفرصة
                                    </div>
                                </div>
                            }
                        }

                        @if (_model.IsNewClient && !IsEdit)
                        {
                            <div class="opp-grid-3">
                                <MudTextField T="string" Label="اسم العميل *" @bind-Value="_model.NewClientName" Variant="MudVariant.Outlined" Dense="true" />
                                <MudTextField T="string" Label="رقم الهاتف *" @bind-Value="_model.NewPhone" Variant="MudVariant.Outlined" Dense="true" OnBlur="CheckPhoneDuplicate" />
                                <MudTextField T="string" Label="العنوان" @bind-Value="_model.NewAddress" Variant="MudVariant.Outlined" Dense="true" />
                            </div>
                        }

                        @if (IsEdit && _editPartyName != null)
                        {
                            <div class="opp-client-selected opp-client-edit">
                                <div class="opp-client-avatar">
                                    <span>@(_editPartyName.Length > 0 ? _editPartyName[0].ToString() : "?")</span>
                                </div>
                                <div class="opp-client-info">
                                    <div class="opp-client-name">@_editPartyName</div>
                                    <div class="opp-client-phone">📞 @_editPartyPhone</div>
                                </div>
                                <div class="opp-client-edit-badge">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    تعديل
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @* ▸ PIPELINE & VALUE CARD ──────────── *@
                <div class="opp-card opp-card-accent">
                    <div class="opp-card-head">
                        <div class="opp-card-icon opp-card-icon-value">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                        </div>
                        <div>
                            <div class="opp-card-title">القيمة والمرحلة البيعية</div>
                            <div class="opp-card-sub">حدد القيمة المتوقعة والمرحلة في دورة البيع</div>
                        </div>
                    </div>
                    <div class="opp-card-body">

                        @* ── Value Input with Range Slider ── *@
                        <div class="opp-value-row">
                            <div class="opp-value-input-wrap">
                                <label class="opp-value-label">القيمة المتوقعة (ج.م)</label>
                                <div class="opp-value-input-group">
                                    <span class="opp-value-currency">ج.م</span>
                                    <input type="text"
                                           class="opp-value-input"
                                           value="@FormatInputValue(_model.ExpectedValue)"
                                           @oninput="OnValueInput" />
                                </div>
                            </div>
                        </div>
                        <div class="opp-slider-row">
                            <span class="opp-slider-min">0</span>
                            <div class="opp-slider-wrap">
                                <div class="opp-slider-track">
                                    <div class="opp-slider-fill" style="width: @(_model.ExpectedValue.HasValue ? Math.Min(100, (double)_model.ExpectedValue.Value / 5000000 * 100) : 0)%"></div>
                                </div>
                                <input type="range"
                                       class="opp-value-slider"
                                       min="0" max="5000000" step="5000"
                                       value="@(_model.ExpectedValue ?? 0)"
                                       @oninput="OnSliderInput" />
                            </div>
                            <span class="opp-slider-max">5,000,000</span>
                        </div>
                        <div class="opp-slider-labels">
                            <button class="opp-slider-label @(_model.ExpectedValue >= 5000 && _model.ExpectedValue < 25000 ? "opp-sl-lbl-on" : "")" @onclick="() => { _model.ExpectedValue = 5000; StateHasChanged(); }">5K</button>
                            <button class="opp-slider-label @(_model.ExpectedValue >= 25000 && _model.ExpectedValue < 100000 ? "opp-sl-lbl-on" : "")" @onclick="() => { _model.ExpectedValue = 25000; StateHasChanged(); }">25K</button>
                            <button class="opp-slider-label @(_model.ExpectedValue >= 100000 && _model.ExpectedValue < 500000 ? "opp-sl-lbl-on" : "")" @onclick="() => { _model.ExpectedValue = 100000; StateHasChanged(); }">100K</button>
                            <button class="opp-slider-label @(_model.ExpectedValue >= 500000 && _model.ExpectedValue < 1000000 ? "opp-sl-lbl-on" : "")" @onclick="() => { _model.ExpectedValue = 500000; StateHasChanged(); }">500K</button>
                            <button class="opp-slider-label @(_model.ExpectedValue >= 1000000 && _model.ExpectedValue < 2000000 ? "opp-sl-lbl-on" : "")" @onclick="() => { _model.ExpectedValue = 1000000; StateHasChanged(); }">1M</button>
                            <button class="opp-slider-label @(_model.ExpectedValue >= 2000000 && _model.ExpectedValue < 5000000 ? "opp-sl-lbl-on" : "")" @onclick="() => { _model.ExpectedValue = 2000000; StateHasChanged(); }">2M</button>
                            <button class="opp-slider-label @(_model.ExpectedValue >= 5000000 ? "opp-sl-lbl-on" : "")" @onclick="() => { _model.ExpectedValue = 5000000; StateHasChanged(); }">5M</button>
                        </div>


                        @* ── Pipeline Timeline (all stages including lost/not-interested) ── *@
                        <div class="opp-pipeline">
                            @{
                                var currentStageOrder = _stages.FirstOrDefault(s => s.StageId == _model.StageId)?.StageOrder ?? 0;
                                var maxOrder = _pipelineStages.Any() ? _pipelineStages.Max(s => s.StageOrder) : 1;
                                var progressPct = maxOrder > 0 ? (double)currentStageOrder / maxOrder * 100 : 0;
                            }
                            <div class="opp-pipeline-progress">
                                <div class="opp-pipeline-progress-bar" style="width: @progressPct%"></div>
                            </div>
                            <div class="opp-pipeline-stages">
                                @foreach (var st in _pipelineStages)
                                {
                                    var isActive = st.StageId == _model.StageId;
                                    var isPast = st.StageOrder < currentStageOrder;
                                    var col = st.StageColor ?? "#94a3b8";
                                    <div class="opp-pipe-node @(isActive ? "opp-pipe-active" : "") @(isPast ? "opp-pipe-past" : "")"
                                         @onclick="() => OnStageChanged(st.StageId)">
                                        <div class="opp-pipe-dot" style="background:@col;@(isActive ? $"box-shadow:0 0 0 6px {col}30" : "")">
                                            @if (isPast)
                                            {
                                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                            }
                                        </div>
                                        <span class="opp-pipe-label">@(st.StageNameAr ?? st.StageName)</span>
                                    </div>
                                }
                            </div>
                        </div>

                        @* ── Stage Meta ── *@
                        <div class="opp-grid-3 mt-3">
                            <MudDatePicker Label="📅 تاريخ المتابعة القادمة" @bind-Date="_model.NextFollowUpDate" Variant="MudVariant.Outlined" Dense="true" />
                            <MudSelect T="int?" Label="نوع المهمة" @bind-Value="_model.TaskTypeId" Clearable="true" Dense="true"
                                       Variant="MudVariant.Outlined">
                                @foreach (var t in _taskTypes) { <MudSelectItem Value="@((int?)t.TaskTypeId)">@(t.TaskTypeNameAr ?? t.TaskTypeName)</MudSelectItem> }
                            </MudSelect>
                            <MudSelect T="int?" Label="حالة التواصل *" @bind-Value="_model.StatusId" Clearable="true" Dense="true"
                                       Variant="MudVariant.Outlined">
                                @foreach (var s in _statuses) { <MudSelectItem Value="@((int?)s.StatusId)">@(s.StatusNameAr ?? s.StatusName)</MudSelectItem> }
                            </MudSelect>
                        </div>

                        @* ── Lost Fields ── *@
                        @if (_showLostFields)
                        {
                            <div class="opp-lost-section">
                                <div class="opp-lost-header">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                    <span>سيتم إلغاء جميع المهام المعلقة تلقائياً</span>
                                </div>
                                <div class="opp-grid-2">
                                    <MudSelect T="int?" Label="⚠️ سبب الخسارة *" @bind-Value="_model.LostReasonId" Clearable="true" Dense="true"
                                               Variant="MudVariant.Outlined">
                                        @foreach (var r in _lostReasons) { <MudSelectItem Value="@((int?)r.LostReasonId)">@(r.ReasonNameAr ?? r.ReasonName)</MudSelectItem> }
                                    </MudSelect>
                                    <MudTextField T="string" Label="تفاصيل سبب الخسارة" @bind-Value="_model.LostNotes" Variant="MudVariant.Outlined" Lines="2" Dense="true" />
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @* ▸ DETAILS CARD ────────────────── *@
                <div class="opp-card">
                    <div class="opp-card-head">
                        <div class="opp-card-icon opp-card-icon-details">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                        </div>
                        <div>
                            <div class="opp-card-title">تفاصيل الفرصة</div>
                            <div class="opp-card-sub">مصدر التواصل والمنتج المهتم به</div>
                        </div>
                    </div>
                    <div class="opp-card-body">
                        <div class="opp-grid-3">
                            <MudSelect T="int?" Label="مصدر التواصل *" @bind-Value="_model.SourceId" Clearable="true"
                                       Variant="MudVariant.Outlined" Dense="true">
                                @foreach (var s in _sources) { <MudSelectItem Value="@((int?)s.SourceId)">@(s.SourceIcon) @(s.SourceNameAr ?? s.SourceName)</MudSelectItem> }
                            </MudSelect>
                            <MudSelect T="int?" Label="الموظف المسؤول" @bind-Value="_model.EmployeeId" Clearable="true"
                                       Variant="MudVariant.Outlined" Dense="true">
                                @foreach (var e in _employees) { <MudSelectItem Value="@((int?)e.EmployeeId)">@e.FullName</MudSelectItem> }
                            </MudSelect>
                            <MudDatePicker Label="📅 تاريخ أول تواصل *" @bind-Date="_model.FirstContactDate" Variant="MudVariant.Outlined" Dense="true" />
                        </div>
                        <div class="opp-grid-3 mt-2">
                            <MudSelect T="int?" Label="الحملة الإعلانية" @bind-Value="_model.AdTypeId" Clearable="true"
                                       Variant="MudVariant.Outlined" Dense="true" Visible="@(_model.SourceId.HasValue)">
                                @foreach (var a in _adTypes) { <MudSelectItem Value="@((int?)a.AdTypeId)">@(a.AdTypeNameAr ?? a.AdTypeName)</MudSelectItem> }
                            </MudSelect>
                            <MudSelect T="int?" Label="فئة المنتج" @bind-Value="_model.CategoryId" Clearable="true"
                                       Variant="MudVariant.Outlined" Dense="true">
                                @foreach (var c in _categories) { <MudSelectItem Value="@((int?)c.CategoryId)">@(c.CategoryNameAr ?? c.CategoryName)</MudSelectItem> }
                            </MudSelect>
                            <MudTextField T="string" Label="المنتج المهتم به" @bind-Value="_model.InterestedProduct"
                                          Variant="MudVariant.Outlined" Dense="true" />
                        </div>
                        <div class="opp-grid-2 mt-2">
                            <MudTextField T="string" Label="📍 الموقع" @bind-Value="_model.Location" Variant="MudVariant.Outlined" Dense="true" />
                        </div>
                    </div>
                </div>

                @* ▸ NOTES CARD ────────────────── *@
                <div class="opp-card">
                    <div class="opp-card-head">
                        <div class="opp-card-icon opp-card-icon-notes">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                        </div>
                        <div>
                            <div class="opp-card-title">ملاحظات التواصل</div>
                            <div class="opp-card-sub">سجل ملخص التواصل وتوجيهات المتابعة</div>
                        </div>
                    </div>
                    <div class="opp-card-body">
                        <MudTextField T="string" Label="📝 ملخص التواصل *" @bind-Value="_model.Summary"
                                      Variant="MudVariant.Outlined" Lines="4" Dense="true"
                                      Placeholder="مثال: العميل استفسر عن غرفة النوم، طلب كتالوج..." />
                        <div class="mt-2">
                            <MudTextField T="string" Label="📋 توجيهات المتابعة" @bind-Value="_model.Guidance"
                                          Variant="MudVariant.Outlined" Lines="3" Dense="true" />
                        </div>
                    </div>
                </div>

                @* ▸ ACTIONS ────────────────── *@
                <div class="opp-actions-bar">
                    <button class="opp-action-btn opp-action-cancel" @onclick="Cancel">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        إلغاء
                    </button>
                    <div class="opp-actions-right">
                        <button class="opp-action-btn opp-action-sn" @onclick="SaveAndNew" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="opp-spinner"></span>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                            }
                            حفظ وجديد
                        </button>
                        <button class="opp-action-btn opp-action-save" @onclick="SaveAndClose" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="opp-spinner"></span>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            }
                            حفظ
                        </button>
                    </div>
                </div>
            </div>

            @* ─── SIDEBAR PREVIEW ─── *@
            <div class="opp-sidebar">
                <div class="opp-preview-card">
                    <div class="opp-preview-header">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        معاينة الفرصة
                    </div>
                    <div class="opp-preview-body">
                        @* ── Preview Value ── *@
                        <div class="opp-pv-value">
                            <div class="opp-pv-value-label">القيمة المتوقعة</div>
                            <div class="opp-pv-value-amount">@FormatMoneyFull(_model.ExpectedValue ?? 0)</div>
                        </div>

                        @* ── Preview Info Rows ── *@
                        <div class="opp-pv-row">
                            <div class="opp-pv-item">
                                <div class="opp-pv-icon" style="background:#e0f2fe;color:#0284c7">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                </div>
                                <div class="opp-pv-info">
                                    <span class="opp-pv-lbl">العميل</span>
                                    <span class="opp-pv-val">@GetClientName()</span>
                                </div>
                            </div>
                            <div class="opp-pv-divider"></div>
                            <div class="opp-pv-item">
                                <div class="opp-pv-icon" style="background:#dcfce7;color:#16a34a">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                                </div>
                                <div class="opp-pv-info">
                                    <span class="opp-pv-lbl">المنتج</span>
                                    <span class="opp-pv-val">@(_model.InterestedProduct ?? "—")</span>
                                </div>
                            </div>
                            <div class="opp-pv-divider"></div>
                            <div class="opp-pv-item">
                                <div class="opp-pv-icon" style="background:#fef3c7;color:#d97706">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                </div>
                                <div class="opp-pv-info">
                                    <span class="opp-pv-lbl">المرحلة</span>
                                    <span class="opp-pv-val">@(_stages.FirstOrDefault(s => s.StageId == _model.StageId)?.StageNameAr ?? "—")</span>
                                </div>
                            </div>
                            <div class="opp-pv-divider"></div>
                            <div class="opp-pv-item">
                                <div class="opp-pv-icon" style="background:#e0e7ff;color:#4338ca">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </div>
                                <div class="opp-pv-info">
                                    <span class="opp-pv-lbl">المتابعة</span>
                                    <span class="opp-pv-val">@(_model.NextFollowUpDate?.ToString("dd/MM/yyyy") ?? "—")</span>
                                </div>
                            </div>
                            <div class="opp-pv-divider"></div>
                            <div class="opp-pv-item">
                                <div class="opp-pv-icon" style="background:#fce7f3;color:#db2777">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                </div>
                                <div class="opp-pv-info">
                                    <span class="opp-pv-lbl">الموظف</span>
                                    <span class="opp-pv-val">@(_employees.FirstOrDefault(e => e.EmployeeId == _model.EmployeeId)?.FullName ?? "—")</span>
                                </div>
                            </div>
                            <div class="opp-pv-divider"></div>
                            <div class="opp-pv-item">
                                <div class="opp-pv-icon" style="background:#f3e8ff;color:#9333ea">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
                                </div>
                                <div class="opp-pv-info">
                                    <span class="opp-pv-lbl">المصدر</span>
                                    <span class="opp-pv-val">@(_sources.FirstOrDefault(s => s.SourceId == _model.SourceId)?.SourceNameAr ?? "—")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── Quick Info ── *@
                <div class="opp-preview-card opp-preview-card-mini">
                    <div class="opp-preview-header">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        إجراءات سريعة
                    </div>
                    <div class="opp-preview-body">
                        <button class="opp-pv-action" @onclick="GoToInteractions">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            سجل التواصلات
                        </button>
                        <button class="opp-pv-action" @onclick="GoToTasks">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                            مهام المتابعة
                        </button>
                        <button class="opp-pv-action" @onclick="GoToNewInteraction">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            إضافة تواصل
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* ═══════════════════════════════════════════════════════
   STYLES — Modern 2026 Design (Arial, Green Header, Slider)
   ═══════════════════════════════════════════════════════ *@
<style>
    /* ── Base ── */
    .opp-page { padding: 0 1.25rem 2.5rem; max-width: 1440px; margin: 0 auto; font-family: Arial, Helvetica, sans-serif; min-height: 100vh; }

    /* ── Loading ── */
    .opp-loading { display: flex; align-items: center; justify-content: center; min-height: 60vh; }
    .opp-loader { display: flex; flex-direction: column; align-items: center; gap: 1rem; font-size: 0.95rem; color: #64748b; font-weight: 600; font-family: Arial, Helvetica, sans-serif; }
    .opp-loader-ring { width: 44px; height: 44px; border: 3px solid #e2e8f0; border-top-color: #059669; border-radius: 50%; animation: opp-spin 0.8s linear infinite; }
    @@keyframes opp-spin { to { transform: rotate(360deg); } }

    /* ── Success ── */
    .opp-success { display: flex; align-items: center; justify-content: center; min-height: 70vh; padding: 2rem; }
    .opp-success-card { position: relative; background: rgba(255,255,255,0.85); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.3); border-radius: 28px; padding: 3rem 4rem; text-align: center; max-width: 520px; width: 100%; box-shadow: 0 8px 40px rgba(0,0,0,0.06), 0 0 0 1px rgba(5,150,105,0.08); overflow: hidden; }
    .opp-success-glow { position: absolute; top: -60px; left: 50%; transform: translateX(-50%); width: 200px; height: 200px; background: radial-gradient(circle, rgba(5,150,105,0.15) 0%, transparent 70%); border-radius: 50%; pointer-events: none; }
    .opp-success-icon { width: 64px; height: 64px; margin: 0 auto 1.25rem; background: linear-gradient(135deg, #059669, #10b981); border-radius: 20px; display: flex; align-items: center; justify-content: center; color: #fff; padding: 14px; box-shadow: 0 8px 24px rgba(5,150,105,0.25); }
    .opp-success-title { font-size: 1.6rem; font-weight: 800; margin: 0 0 .4rem; color: #0f172a; font-family: Arial, Helvetica, sans-serif; }
    .opp-success-sub { color: #64748b; font-size: 0.95rem; margin-bottom: 1.25rem; font-family: Arial, Helvetica, sans-serif; }
    .opp-success-value { font-size: 2rem; font-weight: 900; color: #059669; margin-bottom: 1.75rem; letter-spacing: -0.5px; }
    .opp-success-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
    .opp-btn { display: inline-flex; align-items: center; gap: .5rem; padding: .65rem 1.35rem; border-radius: 12px; font-size: .88rem; font-weight: 700; cursor: pointer; transition: all .2s; font-family: Arial, Helvetica, sans-serif; border: none; text-decoration: none; }
    .opp-btn-primary { background: linear-gradient(135deg, #059669, #10b981); color: #fff; box-shadow: 0 4px 14px rgba(5,150,105,0.25); }
    .opp-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(5,150,105,0.35); }
    .opp-btn-outline { background: transparent; color: #059669; border: 2px solid rgba(5,150,105,0.25); }
    .opp-btn-outline:hover { background: rgba(5,150,105,0.06); border-color: #059669; }
    .opp-btn-ghost { background: transparent; color: #64748b; }
    .opp-btn-ghost:hover { background: #f1f5f9; color: #0f172a; }

    /* ── HEADER — Green Emerald Gradient ── */
    .opp-header { position: relative; border-radius: 18px; overflow: hidden; margin-bottom: 1rem; }
    .opp-header-bg { position: absolute; inset: 0; }
    .opp-header-gradient { position: absolute; inset: 0; background: linear-gradient(135deg, #047857 0%, #059669 45%, #10b981 75%, #047857 100%); }
    .opp-header-pattern { position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 20px 20px; }
    .opp-header-glow { position: absolute; border-radius: 50%; filter: blur(60px); pointer-events: none; }
    .opp-header-glow-1 { width: 160px; height: 160px; background: rgba(255,255,255,0.06); top: -40px; right: -20px; }
    .opp-header-glow-2 { width: 120px; height: 120px; background: rgba(255,255,255,0.04); bottom: -40px; left: 10%; }

    .opp-header-content { position: relative; z-index: 1; color: #fff; padding: .75rem 1.35rem 1rem; }
    .opp-header-top { display: flex; align-items: center; gap: .6rem; margin-bottom: .7rem; }
    .opp-back-btn { width: 30px; height: 30px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.12); border-radius: 9px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: rgba(255,255,255,0.8); transition: all .2s; flex-shrink: 0; }
    .opp-back-btn:hover { background: rgba(255,255,255,0.2); color: #fff; }
    .opp-header-info { display: flex; flex-direction: column; }
    .opp-header-badge { display: inline-block; align-self: flex-start; padding: 1px 7px; border-radius: 999px; font-size: .6rem; font-weight: 700; background: rgba(255,255,255,0.15); color: #fff; margin-bottom: 1px; border: 1px solid rgba(255,255,255,0.2); letter-spacing: 0.3px; }
    .opp-header-title { margin: 0; font-size: .95rem; font-weight: 700; letter-spacing: -0.2px; font-family: Arial, Helvetica, sans-serif; }
    .opp-header-sub { margin: 0; font-size: .68rem; opacity: 0.5; font-weight: 500; font-family: Arial, Helvetica, sans-serif; }
    .opp-header-spacer { flex: 1; }
    .opp-header-action { width: 30px; height: 30px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.12); border-radius: 9px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: rgba(255,255,255,0.8); transition: all .2s; }
    .opp-header-action:hover { background: rgba(255,255,255,0.2); color: #fff; }
    .opp-header-action-wa:hover { background: rgba(37,211,102,0.25); color: #25d366; }

    /* ── Hero Value ── */
    .opp-hero { display: flex; align-items: center; justify-content: space-between; gap: .7rem; flex-wrap: wrap; }
    .opp-hero-value-area { }
    .opp-hero-label { font-size: .62rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; opacity: 0.45; margin-bottom: 1px; font-family: Arial, Helvetica, sans-serif; }
    .opp-hero-value { display: flex; align-items: baseline; gap: .25rem; }
    .opp-hero-currency { font-size: .8rem; font-weight: 700; opacity: 0.6; }
    .opp-hero-amount { font-size: 1.5rem; font-weight: 900; letter-spacing: -0.5px; line-height: 1.1; background: linear-gradient(135deg, #a7f3d0, #6ee7b7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .opp-hero-sub { margin-top: .25rem; }
    .opp-hero-indicator { width: 140px; }
    .opp-hero-bar { height: 2px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden; }
    .opp-hero-bar-fill { height: 100%; background: linear-gradient(90deg, #6ee7b7, #a7f3d0); border-radius: 2px; transition: width .5s ease; }
    .opp-hero-meta { display: flex; gap: .35rem; flex-wrap: wrap; }
    .opp-hero-chip { display: inline-flex; align-items: center; gap: .25rem; padding: .2rem .5rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); border-radius: 999px; font-size: .65rem; font-weight: 600; color: rgba(255,255,255,0.85); font-family: Arial, Helvetica, sans-serif; }

    /* ── Layout ── */
    .opp-layout { display: grid; grid-template-columns: 1fr 280px; gap: 1.15rem; align-items: start; }
    .opp-main { display: flex; flex-direction: column; gap: 1rem; }

    /* ── Cards ── */
    .opp-card { background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default); border-radius: 16px; overflow: hidden; transition: all .25s; }
    .opp-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.04); }
    .opp-card-accent { border-top: 3px solid #059669; }
    .opp-card-head { display: flex; align-items: center; gap: .65rem; padding: .75rem 1rem .6rem; background: var(--mud-palette-background); border-bottom: 1px solid var(--mud-palette-lines-inputs); }
    .opp-card-icon { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .opp-card-icon-client { background: #e0f2fe; color: #0284c7; }
    .opp-card-icon-value { background: #f0fdf4; color: #16a34a; }
    .opp-card-icon-details { background: #fef3c7; color: #d97706; }
    .opp-card-icon-notes { background: #f3e8ff; color: #9333ea; }
    .opp-card-spacer { flex: 1; }
    .opp-card-title { font-size: .88rem; font-weight: 700; font-family: Arial, Helvetica, sans-serif; }
    .opp-card-sub { font-size: .72rem; color: #64748b; margin-top: 1px; font-family: Arial, Helvetica, sans-serif; }
    .opp-card-body { padding: .85rem 1rem; }

    /* ── Client Switch ── */
    .opp-client-switch { display: flex; gap: .25rem; background: #f1f5f9; border-radius: 9px; padding: 2px; }
