@page "/crm/my-calendar"
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims
@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudBlazor

@inject AuthenticationStateProvider AuthProvider
@inject IDbContextFactory<db24804Context> DbFactory
@inject ITaskService TaskService
@inject IOpportunityService OppService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>مهامي وجدولي اليومي — COCOBOLO ERP</PageTitle>

<div class="calendar-page-v2" dir="rtl">
    @* ═══ PREMIUM HEADER (Arial Font & Dynamic Palette & Progress Tracker) ═══ *@
    <div class="premium-header-v2">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-pattern"></div>
            <div class="header-orb orb-1"></div>
            <div class="header-orb orb-2"></div>
        </div>
        <div class="header-content">
            <div class="header-top">
                <div class="header-title">
                    <div class="title-icon-box">
                        <MudIcon Icon="@Icons.Material.Rounded.CalendarMonth" Size="Size.Large" Color="Color.Inherit" />
                        <div class="icon-pulse-ring"></div>
                    </div>
                    <div class="title-text">
                        <div class="title-badge-row">
                            <span class="live-dot"></span>
                            <span class="badge-text">تقويم مبيعات متقدم</span>
                        </div>
                        <h1 class="arial-title">مهامي وجدولي اليومي</h1>
                        <p>إدارة المهام، ومتابعات العملاء، والليدز في واجهة تقويم تفاعلية متطورة</p>
                    </div>
                </div>
                <div class="header-actions">
                    @if (_isAdmin)
                    {
                        <div class="admin-filter-box">
                            <MudSelect T="int?" Value="_selectedEmployeeId" ValueChanged="OnEmployeeFilterChanged" Label="تقويم الموظف" Variant="Variant.Outlined" Dense="true" Clearable="true" Class="emp-select">
                                <MudSelectItem T="int?" Value="@((int?)null)">الجميع (كل الموظفين)</MudSelectItem>
                                @foreach (var emp in _employees)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)emp.EmployeeId)">@emp.FullName</MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                    }
                    <div class="cal-nav-group">
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="GoToTodayMonth" Class="today-nav-btn">الشهر الحالي</MudButton>
                        <MudIconButton Icon="@Icons.Material.Rounded.ChevronRight" Color="Color.Inherit" OnClick="PreviousMonth" Tooltip="الشهر السابق" Class="nav-arrow" />
                        <MudIconButton Icon="@Icons.Material.Rounded.ChevronLeft" Color="Color.Inherit" OnClick="NextMonth" Tooltip="الشهر التالي" Class="nav-arrow" />
                    </div>
                </div>
            </div>

            @* ═══ MONTHLY ACHIEVEMENT TRACKER ═══ *@
            @if (_totalMonthTasks > 0)
            {
                <div class="month-progress-box">
                    <div class="prog-labels">
                        <span class="prog-title">إنجاز شهر @_currentMonth.ToString("MMMM", new CultureInfo("ar-EG")):</span>
                        <span class="prog-nums">@_completedMonthTasks / @_totalMonthTasks (@_monthProgressPercent%)</span>
                    </div>
                    <div class="prog-track">
                        <div class="prog-fill @(_monthProgressPercent >= 100 ? "prog-done" : "")" style="width:@Math.Min(_monthProgressPercent, 100)%"></div>
                    </div>
                </div>
            }

            @* ═══ SMART DYNAMIC FILTER BAR ═══ *@
            <div class="month-banner">
                <div class="month-title">
                    <MudIcon Icon="@Icons.Material.Rounded.EventNote" Size="Size.Medium" Class="month-icon" />
                    <h2 class="arial-title">@_currentMonth.ToString("MMMM yyyy", new CultureInfo("ar-EG"))</h2>
                </div>
                <div class="smart-toggle-bar">
                    <button class="smart-toggle-btn @(_activeFilterMode == "All" ? "active" : "")" @onclick='() => ToggleFilterMode("All")'>
                        <span class="tb-emoji">🌐</span>
                        <span class="tb-text">عرض الكل (@(_clientTasksCount + _leadTasksCount))</span>
                    </button>
                    <button class="smart-toggle-btn @(_activeFilterMode == "Client" ? "active" : "")" @onclick='() => ToggleFilterMode("Client")'>
                        <span class="tb-emoji">👤</span>
                        <span class="tb-text">مهام العملاء (@_clientTasksCount)</span>
                    </button>
                    <button class="smart-toggle-btn @(_activeFilterMode == "Lead" ? "active" : "")" @onclick='() => ToggleFilterMode("Lead")'>
                        <span class="tb-emoji">📣</span>
                        <span class="tb-text">متابعات الليدز (@_leadTasksCount)</span>
                    </button>
                    <button class="smart-toggle-btn tb-today @(_activeFilterMode == "Today" ? "active" : "")" @onclick='() => ToggleFilterMode("Today")'>
                        <span class="tb-emoji">⏰</span>
                        <span class="tb-text">مهام اليوم فقط (@_todayTasksCount)</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="loading-box">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Typo="Typo.h6" Class="mt-4">جاري تحميل التقويم والمهام...</MudText>
        </div>
    }
    else
    {
        @* ═══ DESKTOP GRID CALENDAR (PIXEL-PERFECT ALIGNED TABLE) ═══ *@
        <div class="cal-desktop-view">
            <div class="cal-month-table">
                @* HEADER ROW *@
                @foreach (var d in _dayNames)
                {
                    <div class="cal-col-header">@d</div>
                }

                @* BODY CELLS *@
                @foreach (var cell in _calendarCells)
                {
                    var isToday = cell.Date.Date == DateTime.Today;
                    var isOtherMonth = cell.Date.Month != _currentMonth.Month;
                    var cellEvents = GetCellEvents(cell);

                    <div class="cal-day-cell @(isToday ? "cell-today" : "") @(isOtherMonth ? "cell-other-month" : "")">
                        <div class="cell-top-bar">
                            <span class="cell-num @(isToday ? "num-today" : "")">@cell.Date.Day</span>
                            @if (cellEvents.Any())
                            {
                                <span class="cell-count-pill">@cellEvents.Count</span>
                            }
                        </div>
                        <div class="cell-events-container">
                            @foreach (var ev in cellEvents)
                            {
                                <div class="event-card-v2 @GetEventClass(ev)" @onclick="@(() => OpenEvent(ev))">
                                    <div class="ev-header">
                                        <span class="ev-badge">@ev.Emoji @ev.Title</span>
                                        @if (ev.Time.HasValue)
                                        {
                                            <span class="ev-time-pill">@ev.Time.Value.ToString(@"HH\:mm")</span>
                                        }
                                    </div>
                                    <div class="ev-subtitle">@ev.Subtitle</div>
                                    <div class="ev-emp-pill">👤 @ev.AssignedToName</div>
                                    @if (!string.IsNullOrWhiteSpace(ev.Phone))
                                    {
                                        <div class="ev-wa-box" @onclick:stopPropagation="true">
                                            <a href="https://wa.me/@(CleanPhoneForWhatsApp(ev.Phone))" target="_blank" class="cal-wa-btn">
                                                <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Size="Size.Small" Color="Color.Success" />
                                                <span>@ev.Phone</span>
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ═══ MOBILE AGENDA VIEW (MAX-WIDTH 991px - APPLE STICKY HEADERS) ═══ *@
        <div class="cal-mobile-view">
            @if (!_mobileAgendaDays.Any())
            {
                <div class="cal-empty-mobile">
                    <MudIcon Icon="@Icons.Material.Rounded.InsertInvitation" Size="Size.Large" />
                    <h3>لا توجد مهام مطابقة للفلتر المحدد</h3>
                    <p>جرب تغيير خيارات الفلترة العلوية</p>
                </div>
            }
            else
            {
                <div class="mobile-agenda-container">
                    @foreach (var dayGroup in _mobileAgendaDays)
                    {
                        var isToday = dayGroup.Date.Date == DateTime.Today;
                        <div class="agenda-card-v2 @(isToday ? "agenda-today-v2" : "")">
                            <div class="agenda-sticky-header">
                                <div class="agenda-header-left">
                                    <span class="agenda-day-val">@dayGroup.Date.Day</span>
                                    <div class="agenda-day-details">
                                        <span class="agenda-day-lbl">@dayGroup.Date.ToString("dddd", new CultureInfo("ar-EG"))</span>
                                        <span class="agenda-month-lbl">@dayGroup.Date.ToString("MMMM yyyy", new CultureInfo("ar-EG"))</span>
                                    </div>
                                </div>
                                @if (isToday)
                                {
                                    <span class="agenda-today-pill">اليوم</span>
                                }
                            </div>
                            <div class="agenda-events-body">
                                @foreach (var ev in dayGroup.Events)
                                {
                                    <div class="mobile-ev-row @GetEventClass(ev)" @onclick="@(() => OpenEvent(ev))">
                                        <div class="mer-accent"></div>
                                        <div class="mer-body">
                                            <div class="mer-top">
                                                <span class="mer-title">@ev.Emoji @ev.Title</span>
                                                @if (ev.Time.HasValue)
                                                {
                                                    <span class="mer-time">@ev.Time.Value.ToString(@"HH\:mm")</span>
                                                }
                                            </div>
                                            <div class="mer-desc">@ev.Subtitle</div>
                                            <div class="mer-emp">👤 @ev.AssignedToName</div>
                                            @if (!string.IsNullOrWhiteSpace(ev.Phone))
                                            {
                                                <div class="mer-footer" @onclick:stopPropagation="true">
                                                    <a href="https://wa.me/@(CleanPhoneForWhatsApp(ev.Phone))" target="_blank" class="cal-wa-btn">
                                                        <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Size="Size.Small" Color="Color.Success" />
                                                        <span>@ev.Phone</span>
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _isLoading = true;
    private bool _isAdmin = false;
    private string? _currentUserName;
    private int? _myEmployeeId;
    private int? _selectedEmployeeId;
    private DateTime _currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private string _activeFilterMode = "All"; // "All", "Client", "Lead", "Today"

    private List<Employee> _employees = new();
    private List<CalendarEventItem> _allRawEvents = new();
    private List<CalendarCell> _calendarCells = new();
    private List<CalendarDayGroup> _mobileAgendaDays = new();

    private int _clientTasksCount = 0;
    private int _leadTasksCount = 0;
    private int _todayTasksCount = 0;
    private int _completedMonthTasks = 0;
    private int _totalMonthTasks = 0;
    private int _monthProgressPercent => _totalMonthTasks > 0 ? (int)Math.Round((double)_completedMonthTasks / _totalMonthTasks * 100) : 0;

    private readonly string[] _dayNames = new[] { "الأحد", "الإثنين", "الثلاثاء", "الأربعاء", "الخميس", "الجمعة", "السبت" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name;
            _isAdmin = user.IsInRole("Admin") || user.IsInRole("SalesManager");

            await using var db = await DbFactory.CreateDbContextAsync();

            _myEmployeeId = await db.Users.AsNoTracking()
                .Where(u => u.Username == _currentUserName && u.EmployeeId != null)
                .Select(u => u.EmployeeId)
                .FirstOrDefaultAsync();

            if (_isAdmin)
            {
                _employees = await db.Employees.AsNoTracking()
                    .Where(e => e.Status == "نشط")
                    .OrderBy(e => e.FullName)
                    .ToListAsync();
            }
            else
            {
                _selectedEmployeeId = _myEmployeeId;
            }

            await LoadCalendarData();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ في تحميل التقويم: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadCalendarData()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            var startDate = _currentMonth;
            var endDate = _currentMonth.AddMonths(1).AddDays(-1);

            var filter = new TaskFilterDto
            {
                PageSize = 50000,
                AssignedTo = _selectedEmployeeId
            };

            var pagedResult = await TaskService.GetTasksAsync(filter);
            
            // حساب إنجاز الشهر
            _completedMonthTasks = pagedResult.Items.Count(t => t.Status == "Completed" && t.DueDate.Date >= startDate.Date && t.DueDate.Date <= endDate.Date);
            var activeMonthTasks = pagedResult.Items.Where(t => t.Status != "Completed" && t.Status != "Cancelled" && t.DueDate.Date >= startDate.Date && t.DueDate.Date <= endDate.Date).ToList();
            _totalMonthTasks = _completedMonthTasks + activeMonthTasks.Count;

            _clientTasksCount = activeMonthTasks.Count(t => !t.IsLeadTask);
            _leadTasksCount = activeMonthTasks.Count(t => t.IsLeadTask);
            _todayTasksCount = activeMonthTasks.Count(t => t.DueDate.Date == DateTime.Today);

            _allRawEvents = activeMonthTasks.Select(t => new CalendarEventItem
            {
                Id = t.TaskId.ToString(),
                Title = t.IsLeadTask ? "متابعة Lead" : "متابعة عميل",
                Subtitle = t.IsLeadTask ? (t.ClientName ?? "—") : $"{t.ClientName} - {t.TaskDescription}",
                Date = t.DueDate,
                Time = t.DueTime,
                EventType = t.IsLeadTask ? "LeadTask" : "Task",
                Priority = t.Priority,
                Status = t.Status,
                Emoji = t.IsLeadTask ? "📣" : "👤",
                Phone = t.Phone,
                AssignedToName = t.AssignedToName ?? "غير محدد",
                ReferenceId = t.IsLeadTask ? t.LeadId : t.OpportunityId
            }).ToList();

            BuildGrid();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void BuildGrid()
    {
        var filteredEvents = _activeFilterMode switch
        {
            "Client" => _allRawEvents.Where(e => e.EventType == "Task").ToList(),
            "Lead"   => _allRawEvents.Where(e => e.EventType == "LeadTask").ToList(),
            "Today"  => _allRawEvents.Where(e => e.Date.Date == DateTime.Today).ToList(),
            _        => _allRawEvents
        };

        // 1. Desktop Grid
        _calendarCells.Clear();
        var firstDayOfMonth = _currentMonth;
        var startOffset = (int)firstDayOfMonth.DayOfWeek;
        var firstGridDate = firstDayOfMonth.AddDays(-startOffset);

        for (int i = 0; i < 42; i++)
        {
            var curDate = firstGridDate.AddDays(i);
            var cellEvents = filteredEvents.Where(e => e.Date.Date == curDate.Date).OrderBy(e => e.Time).ToList();
            _calendarCells.Add(new CalendarCell(curDate, cellEvents));
        }

        // 2. Mobile Agenda (فلترة الأيام الفارغة لعرض الأجندة بوضوح)
        _mobileAgendaDays = filteredEvents
            .GroupBy(e => e.Date.Date)
            .OrderBy(g => g.Key)
            .Select(g => new CalendarDayGroup(g.Key, g.OrderBy(e => e.Time).ToList()))
            .ToList();
    }

    private List<CalendarEventItem> GetCellEvents(CalendarCell cell)
    {
        if (_activeFilterMode == "Today" && cell.Date.Date != DateTime.Today)
            return new List<CalendarEventItem>(); // إخفاء أحداث الأيام الأخرى في وضع اليوم فقط
        return cell.Events;
    }

    private void ToggleFilterMode(string mode)
    {
        _activeFilterMode = mode;
        BuildGrid();
        StateHasChanged();
    }

    private async Task OnEmployeeFilterChanged(int? empId)
    {
        _selectedEmployeeId = empId;
        await LoadCalendarData();
    }

    private async Task PreviousMonth()
    {
        _currentMonth = _currentMonth.AddMonths(-1);
        await LoadCalendarData();
    }

    private async Task NextMonth()
    {
        _currentMonth = _currentMonth.AddMonths(1);
        await LoadCalendarData();
    }

    private async Task GoToTodayMonth()
    {
        _currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        _activeFilterMode = "Today";
        await LoadCalendarData();
    }

    private void OpenEvent(CalendarEventItem ev)
    {
        if (ev.EventType == "LeadTask" && ev.ReferenceId.HasValue)
        {
            Nav.NavigateTo($"/crm/leads/{ev.ReferenceId.Value}");
        }
        else if (ev.EventType == "Task" && ev.ReferenceId.HasValue)
        {
            Nav.NavigateTo($"/crm/opportunities/{ev.ReferenceId.Value}");
        }
    }

    private static string CleanPhoneForWhatsApp(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return "";
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        if (digits.StartsWith("01") && digits.Length == 11) return "2" + digits;
        return digits;
    }

    private static string GetEventClass(CalendarEventItem ev) => ev.EventType switch
    {
        "LeadTask" => "ev-lead-v2",
        "Shift"    => "ev-shift-v2",
        _          => "ev-client-v2"
    };

    // ── DATA MODELS ────────────────────────────────────────────────
    private class CalendarEventItem
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public DateTime Date { get; set; }
        public TimeOnly? Time { get; set; }
        public string EventType { get; set; } = "Task";
        public string Priority { get; set; } = "Medium";
        public string Status { get; set; } = "Pending";
        public string Emoji { get; set; } = "👤";
        public string? Phone { get; set; }
        public string AssignedToName { get; set; } = "";
        public int? ReferenceId { get; set; }
    }

    private record CalendarCell(DateTime Date, List<CalendarEventItem> Events);
    private record CalendarDayGroup(DateTime Date, List<CalendarEventItem> Events);
}

<style>
    /* ═══ ARIAL FONT & APPLE WEBKIT OPTIMIZATIONS ═══ */
    .calendar-page-v2 { 
        font-family: Arial, Helvetica, sans-serif !important; 
        padding: 1rem; 
        -webkit-font-smoothing: antialiased; 
        -moz-osx-font-smoothing: grayscale; 
    }
    .arial-title { font-family: Arial, Helvetica, sans-serif !important; font-weight: 700; }
    .loading-box { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 50vh; }
    
    /* ═══ PREMIUM HEADER ═══ */
    .premium-header-v2 { position: relative; border-radius: 24px; overflow: hidden; margin-bottom: 2rem; box-shadow: 0 12px 40px rgba(37, 99, 235, 0.22); background: linear-gradient(135deg, #1e3a5f 0%, #1e40af 30%, #2563eb 60%, #3b82f6 85%, #60a5fa 100%); color: #fff; }
    .header-bg { position: absolute; inset: 0; pointer-events: none; }
    .header-pattern { position: absolute; inset: 0; opacity: 0.06; background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.5) 1px, transparent 0); background-size: 28px 28px; }
    .header-orb { position: absolute; border-radius: 50%; filter: blur(70px); }
    .orb-1 { width: 260px; height: 260px; background: rgba(147, 197, 253, 0.2); top: -80px; right: -40px; }
    .orb-2 { width: 180px; height: 180px; background: rgba(99, 102, 241, 0.18); bottom: -50px; left: 8%; }
    .header-content { position: relative; z-index: 2; padding: 2rem 2.4rem; }
    .header-top { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1.5rem; }
    .header-title { display: flex; gap: 1.25rem; align-items: center; }
    .title-icon-box { position: relative; width: 62px; height: 62px; background: rgba(255,255,255,0.15); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 18px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255,255,255,0.2); flex-shrink: 0; }
    .title-text h1 { margin: 0; font-size: 2.1rem; line-height: 1.2; }
    .title-text p { margin: 0.25rem 0 0; opacity: 0.85; font-size: 0.95rem; }
    .title-badge-row { display: flex; align-items: center; gap: 6px; margin-bottom: 0.4rem; }
    .live-dot { width: 8px; height: 8px; border-radius: 50%; background: #34d399; box-shadow: 0 0 10px #34d399; }
    .badge-text { font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; opacity: 0.9; }
    
    .header-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .admin-filter-box { background: rgba(255,255,255,0.15); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); padding: 0.25rem 1rem; border-radius: 14px; border: 1px solid rgba(255,255,255,0.2); width: 250px; }
    .cal-nav-group { display: flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.15); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); padding: 0.35rem 0.75rem; border-radius: 14px; border: 1px solid rgba(255,255,255,0.2); }
    .today-nav-btn { font-weight: 800 !important; border-radius: 10px !important; padding: 6px 18px !important; }
    .nav-arrow { padding: 8px !important; transition: all 0.2s; }
    .nav-arrow:hover { background: rgba(255,255,255,0.2) !important; transform: scale(1.1); }

    /* ═══ MONTHLY ACHIEVEMENT TRACKER ═══ */
    .month-progress-box { margin-top: 1.5rem; background: rgba(255,255,255,0.1); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.15); border-radius: 16px; padding: 1rem 1.4rem; }
    .prog-labels { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; font-size: 0.9rem; font-weight: 700; }
    .prog-nums { font-weight: 800; color: #34d399; }
    .prog-track { height: 8px; background: rgba(255,255,255,0.15); border-radius: 4px; overflow: hidden; }
    .prog-fill { height: 100%; background: linear-gradient(90deg, #34d399, #10b981); border-radius: 4px; transition: width 0.8s ease; }
    .prog-done { background: linear-gradient(90deg, #34d399, #059669); box-shadow: 0 0 12px rgba(52,211,153,0.5); }

    /* ═══ SMART DYNAMIC FILTER BAR ═══ */
    .month-banner { display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.2); flex-wrap: wrap; gap: 1.25rem; }
    .month-title { display: flex; align-items: center; gap: 0.75rem; }
    .month-title h2 { margin: 0; font-size: 1.7rem; color: #fff; }
