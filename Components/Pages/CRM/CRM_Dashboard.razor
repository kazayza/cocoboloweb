@code {
    private bool _isLoading = true;
    private bool _canView;
    private CrmDashboardDto _d = new();
    private CrmDashboardFilterDto _filter = CrmDashboardFilterDto.FromPeriod("all");
    private string? _currentUserName;
    private string? _currentUserRole;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";
            _currentUserRole = user.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value;

            // Permission check
            _canView = user.HasClaim("Permission", "frmCrmDashboard:View") || user.IsInRole("Admin");
            if (!_canView) { Navigation.NavigateTo("/"); return; }

            await LoadDashboard();
        }
        catch { }
        finally { _isLoading = false; }
    }

    private async Task LoadDashboard()
    {
        _isLoading = true; StateHasChanged();
        _d = await CrmDashboard.GetDashboardAsync(_currentUserName!, _currentUserRole, _filter);
        _isLoading = false; StateHasChanged();
    }

    private async Task ChangePeriod(string period)
    {
        _filter = CrmDashboardFilterDto.FromPeriod(period);
        await LoadDashboard();
    }

    private string GetFilterDescription()
    {
        if (_filter.Period == "all") return "متابعة الفرص البيعية والعملاء والمهام — كل الفترات";
        var label = CrmDashboardFilterDto.PeriodLabels[_filter.Period];
        return $"متابعة الفرص البيعية والعملاء والمهام — {label}";
    }

    private void GoToOpportunities() => Navigation.NavigateTo("/crm/opportunities");
    private void GoToNewOpportunity() => Navigation.NavigateTo("/crm/opportunities/new");
    private void GoToOpportunityDetail(int id) => Navigation.NavigateTo($"/crm/opportunities/{id}");

    private static string Trunc(string? s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "—";
        return s.Length <= max ? s : s[..max] + "...";
    }

    private static string FormatMoney(decimal v) => v switch
    {
        >= 1_000_000 => $"{v / 1_000_000:N1}M",
        >= 1_000     => $"{v / 1_000:N1}K",
        _            => $"{v:N0}"
    };

    private static string GetActivityIcon(string? icon) => icon switch
    {
        "Chat"        => @Icons.Material.Rounded.Chat,
        "Lightbulb"   => @Icons.Material.Rounded.Lightbulb,
        "CheckCircle" => @Icons.Material.Rounded.CheckCircle,
        _             => @Icons.Material.Rounded.Circle
    };
}