@page "/crm/dashboard"

@using ApexCharts
@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudTypo = MudBlazor.Typo
@using MudVariant = MudBlazor.Variant

@inject ICrmDashboardService CrmDashboard
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider

<PageTitle>لوحة CRM — COCOBOLO ERP</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-spinner-box">
                <MudProgressCircular Color="MudColor.Secondary" Size="MudSize.Large" Indeterminate="true" />
            </div>
            <MudText Typo="MudTypo.h6" Class="loading-text">جاري تحميل لوحة CRM...</MudText>
            <div class="loading-dots"><span></span><span></span><span></span></div>
        </div>
    </div>
}
else
{
<div dir="rtl" class="crm-dash-page">

    <div class="page-bg-decorations">
        <div class="bg-orb bg-orb-1"></div><div class="bg-orb bg-orb-2"></div>
    </div>
    <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

    @* ═════════ HEADER ═════════ *@
    <div class="crm-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-orbs">
                <div class="header-orb orb-1"></div><div class="header-orb orb-2"></div>
            </div>
            <div class="header-grid"></div>
        </div>
        <div class="header-content">
            <div class="header-top">
                <div class="header-info">
                    <div class="header-icon-wrapper">
                        <div class="header-icon-glow"></div>
                        <div class="header-icon"><MudIcon Icon="@Icons.Material.Rounded.Hub" Size="MudSize.Large" /></div>
                        <div class="header-icon-badge"><MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="MudSize.Small" /></div>
                    </div>
                    <div class="header-text">
                        <div class="header-title-row">
                            <h1>لوحة إدارة علاقات العملاء</h1>
                            <span class="premium-badge"><MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="MudSize.Small" /> CRM</span>
                        </div>
                        <p><MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="MudSize.Small" Class="subtitle-icon" /> @GetFilterDescription()</p>
                    </div>
                </div>
                <div class="header-actions">
                    <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary"
                               StartIcon="@Icons.Material.Rounded.Add" OnClick="GoToNewOpportunity">
                        <span class="btn-shine"></span>فرصة جديدة
                    </MudButton>
                </div>
            </div>
        </div>
    </div>

    @* ═════════ PERIOD FILTER ═════════ *@
    <div class="period-bar">
        @foreach (var kv in CrmDashboardFilterDto.PeriodLabels)
        {
            <MudChip T="string"
                     Variant="@(_filter.Period == kv.Key ? MudVariant.Filled : MudVariant.Outlined)"
                     Color="@(_filter.Period == kv.Key ? MudColor.Primary : MudColor.Default)"
                     Size="MudSize.Small"
                     OnClick="() => ChangePeriod(kv.Key)">
                @kv.Value
            </MudChip>
        }
    </div>

    @* ═════════ KPI CARDS ═════════ *@
    <div class="kpi-grid">
        <div class="kpi-card kpi-total" @onclick="GoToOpportunities">
            <div class="kpi-accent"></div>
            <div class="kpi-content">
                <div class="kpi-icon-box"><MudIcon Icon="@Icons.Material.Rounded.TrackChanges" /></div>
                <div class="kpi-data">
                    <span class="kpi-value">@_d.TotalOpportunities</span>
                    <span class="kpi-label">إجمالي الفرص</span>
                </div>
            </div>
        </div>
        <div class="kpi-card kpi-open" @onclick="GoToOpportunities">
            <div class="kpi-accent"></div>
            <div class="kpi-content">
                <div class="kpi-icon-box"><MudIcon Icon="@Icons.Material.Rounded.Pending" /></div>
                <div class="kpi-data">
                    <span class="kpi-value">@_d.OpenOpportunities</span>
                    <span class="kpi-label">فرص مفتوحة</span>
                </div>
            </div>
        </div>
        <div class="kpi-card kpi-won">
            <div class="kpi-accent"></div>
            <div class="kpi-content">
                <div class="kpi-icon-box"><MudIcon Icon="@Icons.Material.Rounded.EmojiEvents" /></div>
                <div class="kpi-data">
                    <span class="kpi-value">@_d.WonOpportunities</span>
                    <span class="kpi-label">فرص مربوحة</span>
                </div>
            </div>
        </div>
        <div class="kpi-card kpi-lost">
            <div class="kpi-accent"></div>
            <div class="kpi-content">
                <div class="kpi-icon-box"><MudIcon Icon="@Icons.Material.Rounded.Cancel" /></div>
                <div class="kpi-data">
                    <span class="kpi-value">@_d.LostOpportunities</span>
                    <span class="kpi-label">فرص مفقودة</span>
                </div>
            </div>
        </div>
        <div class="kpi-card kpi-value-card">
            <div class="kpi-accent"></div>
            <div class="kpi-content">
                <div class="kpi-icon-box"><MudIcon Icon="@Icons.Material.Rounded.AttachMoney" /></div>
                <div class="kpi-data">
                    <span class="kpi-value val-md">@FormatMoney(_d.PipelineValue)</span>
                    <span class="kpi-label">قيمة الـ Pipeline</span>
                </div>
            </div>
        </div>
        <div class="kpi-card kpi-rate">
            <div class="kpi-accent"></div>
            <div class="kpi-content">
                <div class="kpi-icon-box"><MudIcon Icon="@Icons.Material.Rounded.TrendingUp" /></div>
                <div class="kpi-data">
                    <span class="kpi-value">@_d.ConversionRate%</span>
                    <span class="kpi-label">نسبة التحويل</span>
                </div>
            </div>
        </div>
    </div>

    @* ═════════ CHARTS ═════════ *@
    <div class="charts-row">
        <MudPaper Class="chart-card" Elevation="0">
            <div class="chart-header">
                <h3><MudIcon Icon="@Icons.Material.Rounded.PieChart" Size="MudSize.Small" /> توزيع الفرص حسب المرحلة</h3>
            </div>
            <div class="chart-body-full">
                @if (_d.OpportunitiesByStage.Any(s => s.Count > 0))
                {
                    <ApexChart TItem="StageDistributionDto" Title="" Height="310">
                        <ApexPointSeries TItem="StageDistributionDto"
                                         Items="_d.OpportunitiesByStage.Where(s => s.Count > 0)"
                                         Name="الفرص" SeriesType="SeriesType.Donut"
                                         XValue="s => s.StageNameAr" YValue="s => (decimal)s.Count" />
                    </ApexChart>
                }
                else
                {
                    <div class="empty-chart"><MudIcon Icon="@Icons.Material.Rounded.PieChartOutline" Size="MudSize.Large" /><span>لا توجد بيانات</span></div>
                }
            </div>
        </MudPaper>

        <MudPaper Class="chart-card" Elevation="0">
            <div class="chart-header">
                <h3><MudIcon Icon="@Icons.Material.Rounded.BarChart" Size="MudSize.Small" /> الاتجاه الشهري</h3>
                <div class="chart-legend-inline">
                    <span class="legend-dot" style="background:#818cf8"></span> فرص جديدة
                    <span class="legend-dot" style="background:#34d399"></span> مربوحة
                    <span class="legend-dot" style="background:#f87171"></span> مفقودة
                </div>
            </div>
            <div class="chart-body-full">
                @if (_d.MonthlyTrend.Any())
                {
                    <ApexChart TItem="CrmMonthlyTrendDto" Title="" Height="310">
                        <ApexPointSeries TItem="CrmMonthlyTrendDto"
                                         Items="_d.MonthlyTrend" Name="فرص جديدة"
                                         SeriesType="SeriesType.Bar"
                                         XValue="m => m.MonthAr" YValue="m => (decimal)m.NewOpportunities" />
                        <ApexPointSeries TItem="CrmMonthlyTrendDto"
                                         Items="_d.MonthlyTrend" Name="مربوحة"
                                         SeriesType="SeriesType.Bar"
                                         XValue="m => m.MonthAr" YValue="m => (decimal)m.WonOpportunities" />
                        <ApexPointSeries TItem="CrmMonthlyTrendDto"
                                         Items="_d.MonthlyTrend" Name="مفقودة"
                                         SeriesType="SeriesType.Bar"
                                         XValue="m => m.MonthAr" YValue="m => (decimal)m.LostOpportunities" />
                    </ApexChart>
                }
                else
                {
                    <div class="empty-chart"><MudIcon Icon="@Icons.Material.Rounded.BarChart" Size="MudSize.Large" /><span>لا توجد بيانات</span></div>
                }
            </div>
            @* جدول نسبة التحويل الشهرية *@
            @if (_d.MonthlyTrend.Any(m => m.ConversionRate > 0))
            {
                <div class="conv-table">
                    @foreach (var m in _d.MonthlyTrend)
                    {
                        var rateClass = m.ConversionRate switch { >= 50 => "rate-high", >= 25 => "rate-mid", > 0 => "rate-low", _ => "" };
                        <div class="conv-cell">
                            <span class="conv-month">@m.MonthAr</span>
                            <span class="conv-rate @rateClass">@(m.ConversionRate > 0 ? $"{m.ConversionRate}%" : "—")</span>
                        </div>
                    }
                </div>
            }
        </MudPaper>
    </div>

    @* ═════════ PERFORMERS + TASKS ═════════ *@
    <div class="bottom-row">
        <MudPaper Class="data-card" Elevation="0">
            <div class="chart-header">
                <h3><MudIcon Icon="@Icons.Material.Rounded.Leaderboard" Size="MudSize.Small" /> أفضل الموظفين أداءً</h3>
                @if (_filter.Period != "all")
                {
                    <MudChip T="string" Color="MudColor.Primary" Size="MudSize.Small" Variant="MudVariant.Outlined">
                        @CrmDashboardFilterDto.PeriodLabels[_filter.Period]
                    </MudChip>
                }
            </div>
            <div class="card-body-scroll">
                @if (_d.TopPerformers.Any())
                {
                    <div class="perf-list">
                        @{ int rank = 0; }
                        @foreach (var emp in _d.TopPerformers)
                        {
                            rank++;
                            var medal = rank switch { 1 => "🥇", 2 => "🥈", 3 => "🥉", _ => $"#{rank}" };
                            <div class="perf-row @(rank <= 3 ? "top-three" : "")">
                                <span class="perf-rank">@medal</span>
                                <div class="perf-info">
                                    <span class="perf-name">@emp.EmployeeName</span>
                                    <span class="perf-sub">
                                        @emp.TotalOpportunities فرصة •
                                        @emp.WonCount مكسب (@emp.ConversionRate%) •
                                        @FormatMoney(emp.WonValue) قيمة
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-chart"><span>لا توجد بيانات موظفين</span></div>
                }
            </div>
        </MudPaper>

        <MudPaper Class="data-card" Elevation="0">
            <div class="chart-header">
                <h3><MudIcon Icon="@Icons.Material.Rounded.AssignmentLate" Size="MudSize.Small" /> مهام متأخرة</h3>
                @if (_d.OverdueTasksList.Any())
                {
                    <MudChip T="string" Color="MudColor.Error" Size="MudSize.Small" Variant="MudVariant.Outlined">@_d.OverdueTasksList.Count</MudChip>
                }
            </div>
            <div class="card-body-scroll">
                @if (_d.OverdueTasksList.Any())
                {
                    <div class="task-list">
                        @foreach (var t in _d.OverdueTasksList)
                        {
                            var priorityColor = t.Priority switch { "High" => "#ef4444", "Medium" => "#f59e0b", _ => "#3b82f6" };
                            <div class="task-row @(t.Priority == "High" ? "task-high" : "")">
                                <div class="task-priority" style="background:@priorityColor"></div>
                                <div class="task-info">
                                    <span class="task-desc">@Trunc(t.TaskDescription, 40)</span>
                                    <span class="task-meta">@t.ClientName · @t.AssignedToName · متأخر @t.DaysOverdue يوم</span>
                                </div>
                                <span class="task-date">@t.DueDate.ToString("dd/MM")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-chart green"><MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Size="MudSize.Large" /><span>لا توجد مهام متأخرة 👏</span></div>
                }
            </div>
        </MudPaper>
    </div>

    @* ═════════ FOLLOW-UPS + ACTIVITY ═════════ *@
    <div class="bottom-row">
        <MudPaper Class="data-card" Elevation="0">
            <div class="chart-header">
                <h3><MudIcon Icon="@Icons.Material.Rounded.EventAvailable" Size="MudSize.Small" /> متابعات قادمة</h3>
                @if (_d.UpcomingFollowUps.Any(f => f.IsOverdue))
                {
                    var od = _d.UpcomingFollowUps.Count(f => f.IsOverdue);
                    <MudChip T="string" Color="MudColor.Warning" Size="MudSize.Small" Variant="MudVariant.Outlined">@od متأخر</MudChip>
                }
            </div>
            <div class="card-body-scroll">
                @if (_d.UpcomingFollowUps.Any())
                {
                    <div class="followup-list">
                        @foreach (var f in _d.UpcomingFollowUps)
                        {
                            var oppId = f.OpportunityId;
                            <div class="followup-row @(f.IsOverdue ? "fu-overdue" : "")"
                                 @onclick="() => GoToOpportunityDetail(oppId)">
                                <div class="fu-indicator" style="background:@(f.StageColor ?? "#94a3b8")"></div>
                                <div class="fu-info">
                                    <span class="fu-name">@f.ClientName</span>
                                    <span class="fu-meta">@(f.StageNameAr ?? "—") · @(f.EmployeeName ?? "—")</span>
                                </div>
                                <div class="fu-date @(f.IsOverdue ? "fu-date-overdue" : "")">
                                    @if (f.IsOverdue) { <MudIcon Icon="@Icons.Material.Rounded.Warning" Size="MudSize.Small" Class="fu-warn" /> }
                                    @f.FollowUpDate.ToString("dd/MM")
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-chart"><span>لا توجد متابعات قادمة</span></div>
                }
            </div>
        </MudPaper>

        <MudPaper Class="data-card" Elevation="0">
            <div class="chart-header">
                <h3><MudIcon Icon="@Icons.Material.Rounded.History" Size="MudSize.Small" /> آخر النشاطات</h3>
            </div>
            <div class="card-body-scroll">
                @if (_d.RecentActivities.Any())
                {
                    <div class="activity-list">
                        @foreach (var a in _d.RecentActivities)
                        {
                            <div class="activity-row">
                                <div class="act-icon" style="background:@(a.Color ?? "#94a3b8")20;color:@(a.Color ?? "#94a3b8")">
                                    <MudIcon Icon="@GetActivityIcon(a.Icon)" Size="MudSize.Small" />
                                </div>
                                <div class="act-info">
                                    <span class="act-title">@a.Title</span>
                                    <span class="act-desc">@a.Description</span>
                                </div>
                                <span class="act-time">@a.Elapsed</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-chart"><span>لا توجد نشاطات حديثة</span></div>
                }
            </div>
        </MudPaper>
    </div>

</div>
}

<style>
    .crm-dash-page { padding: 0 1.5rem 3rem; position: relative; }
    .period-bar { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem; justify-content: center; }
    .kpi-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
    .charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
    .bottom-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }

    .kpi-card { position: relative; border-radius: 14px; padding: 1rem; cursor: pointer; overflow: hidden; transition: transform .2s, box-shadow .2s; background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default); }
    .kpi-card:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,.12); }
    .kpi-accent { position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 14px 14px 0 0; }
    .kpi-total .kpi-accent { background: linear-gradient(90deg, #6366f1, #818cf8); }
    .kpi-open .kpi-accent { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
    .kpi-won .kpi-accent { background: linear-gradient(90deg, #10b981, #34d399); }
    .kpi-lost .kpi-accent { background: linear-gradient(90deg, #ef4444, #f87171); }
    .kpi-value-card .kpi-accent { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .kpi-rate .kpi-accent { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }
    .kpi-content { display: flex; align-items: center; gap: 0.7rem; position: relative; z-index: 1; }
    .kpi-icon-box { width: 42px; height: 42px; border-radius: 11px; display: flex; align-items: center; justify-content: center; }
    .kpi-total .kpi-icon-box { background: #6366f115; color: #6366f1; }
    .kpi-open .kpi-icon-box { background: #3b82f615; color: #3b82f6; }
    .kpi-won .kpi-icon-box { background: #10b98115; color: #10b981; }
    .kpi-lost .kpi-icon-box { background: #ef444415; color: #ef4444; }
    .kpi-value-card .kpi-icon-box { background: #f59e0b15; color: #f59e0b; }
    .kpi-rate .kpi-icon-box { background: #8b5cf615; color: #8b5cf6; }
    .kpi-data { display: flex; flex-direction: column; }
    .kpi-value { font-weight: 800; font-size: 1.3rem; letter-spacing: -0.5px; }
    .val-md { font-size: 1.05rem; }
    .kpi-label { font-size: 0.72rem; color: var(--mud-palette-text-secondary); }

    .chart-card { border-radius: 16px; border: 1px solid var(--mud-palette-lines-default); overflow: hidden; }
    .chart-header { padding: 0.85rem 1.25rem; border-bottom: 1px solid var(--mud-palette-lines-inputs); display: flex; align-items: center; gap: 0.5rem; justify-content: space-between; flex-wrap: wrap; }
    .chart-header h3 { margin: 0; font-size: 0.9rem; font-weight: 700; display: flex; align-items: center; gap: 0.4rem; }
    .chart-body-full { padding: 0.5rem; }
    .chart-body-full ::deep > * { width: 100% !important; }
    .empty-chart { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; color: var(--mud-palette-text-disabled); gap: 0.5rem; }
    .empty-chart.green { color: #10b981; }

    .chart-legend-inline { display: flex; gap: 0.75rem; font-size: 0.7rem; align-items: center; color: var(--mud-palette-text-secondary); }
    .legend-dot { width: 10px; height: 10px; border-radius: 3px; display: inline-block; }

    .conv-table { display: flex; padding: 0.5rem 1rem 1rem; gap: 0; border-top: 1px solid var(--mud-palette-lines-inputs); justify-content: space-around; flex-wrap: wrap; }
    .conv-cell { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; min-width: 48px; }
    .conv-month { font-size: 0.65rem; color: var(--mud-palette-text-secondary); }
    .conv-rate { font-size: 0.78rem; font-weight: 700; }
    .rate-high { color: #10b981; }
    .rate-mid { color: #f59e0b; }
    .rate-low { color: #ef4444; }

    .data-card { border-radius: 16px; border: 1px solid var(--mud-palette-lines-default); overflow: hidden; }
    .card-body-scroll { max-height: 340px; overflow-y: auto; }

    .perf-row { display: flex; align-items: center; gap: 0.6rem; padding: 0.7rem 1.25rem; cursor: pointer; border-bottom: 1px solid var(--mud-palette-lines-inputs); }
    .perf-row:last-child { border-bottom: none; }
    .perf-row:hover { background: var(--mud-palette-action-hover); }
    .perf-rank { font-size: 1.1rem; min-width: 28px; text-align: center; }
    .perf-info { flex: 1; display: flex; flex-direction: column; }
    .perf-name { font-weight: 600; font-size: 0.82rem; }
    .perf-sub { font-size: 0.68rem; color: var(--mud-palette-text-secondary); }
    .top-three { background: linear-gradient(135deg, #ffd70005, #ffd70002); }

    .task-row { display: flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1.25rem; border-bottom: 1px solid var(--mud-palette-lines-inputs); }
    .task-row:last-child { border-bottom: none; }
    .task-priority { width: 4px; align-self: stretch; border-radius: 2px; flex-shrink: 0; }
    .task-info { flex: 1; display: flex; flex-direction: column; }
    .task-desc { font-size: 0.8rem; font-weight: 500; }
    .task-meta { font-size: 0.68rem; color: var(--mud-palette-text-secondary); }
    .task-date { font-size: 0.7rem; font-weight: 600; color: #ef4444; }
    .task-high { background: #ef444405; }

    .followup-row { display: flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1.25rem; cursor: pointer; border-bottom: 1px solid var(--mud-palette-lines-inputs); }
    .followup-row:last-child { border-bottom: none; }
    .followup-row:hover { background: var(--mud-palette-action-hover); }
    .fu-indicator { width: 4px; align-self: stretch; border-radius: 2px; flex-shrink: 0; }
    .fu-info { flex: 1; display: flex; flex-direction: column; }
    .fu-name { font-size: 0.8rem; font-weight: 600; }
    .fu-meta { font-size: 0.68rem; color: var(--mud-palette-text-secondary); }
    .fu-date { font-size: 0.7rem; font-weight: 600; display: flex; align-items: center; gap: 0.2rem; }
    .fu-date-overdue { color: #ef4444; }
    .fu-warn { color: #ef4444; animation: pulse-warn 1.5s infinite; }
    .fu-overdue { background: #ef444405; }
    @@keyframes pulse-warn { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

    .activity-row { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.65rem 1.25rem; border-bottom: 1px solid var(--mud-palette-lines-inputs); }
    .activity-row:last-child { border-bottom: none; }
    .act-icon { width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .act-info { flex: 1; display: flex; flex-direction: column; }
    .act-title { font-size: 0.78rem; font-weight: 600; }
    .act-desc { font-size: 0.68rem; color: var(--mud-palette-text-secondary); }
    .act-time { font-size: 0.68rem; color: var(--mud-palette-text-disabled); white-space: nowrap; margin-top: 2px; }

