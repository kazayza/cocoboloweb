    .dlg-step-text { font-size: 0.75rem; font-weight: 600; color: #64748b; }
    .dlg-step-line { width: 50px; height: 3px; background: linear-gradient(90deg, #10b981, #3b82f6); border-radius: 3px; margin: 0 8px; margin-bottom: 20px; }

    /* ─── Dialog Actions Footer ─── */
    .dlg-actions-footer { display: flex; gap: 8px; padding: 4px 0; width: 100%; align-items: center; }

    /* ═══ STATUS BADGES ═══ */
    .status-new { background: #dbeafe; color: #1e40af; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
    .status-contacted { background: #fef3c7; color: #92400e; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
