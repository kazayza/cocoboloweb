    /* ═══ PLATFORM BADGES ═══ */
    .platform-fb { background: #dbeafe; color: #1e40af; padding: 2px 8px; border-radius: 8px; font-size: 11px; font-weight: 700; }
    .platform-ig { background: #fce7f3; color: #9d174d; padding: 2px 8px; border-radius: 8px; font-size: 11px; font-weight: 700; }
