@page "/crm/leads"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@attribute [Authorize]

@inject ILeadsCrmService LeadsService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

@implements IDisposable

<PageTitle>إدارة Leads — CRM</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <MudProgressCircular Color="MudColor.Secondary" Size="MudSize.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Style="color:var(--mud-palette-text-secondary);margin-top:1rem">جاري تحميل الـ Leads...</MudText>
    </div>
}
else
{
<div dir="rtl" class="leads-page">

    @* ═══ HEADER ═══ *@
    <div class="leads-header">
        <div class="hdr-bg">
            <div class="hdr-gradient"></div>
            <div class="hdr-dots"></div>
            <div class="hdr-glow hdr-glow1"></div>
            <div class="hdr-glow hdr-glow2"></div>
        </div>
        <div class="hdr-body">
            <div class="hdr-top">
                <div class="hdr-title-area">
                    <div class="hdr-icon">
                        <MudIcon Icon="@Icons.Material.Rounded.ContactPhone" Style="font-size:1.6rem" />
                    </div>
                    <div>
                        <h1 class="hdr-h1">إدارة Leads</h1>
                        <p class="hdr-sub">عملاء محتملين من Meta Ads — <strong>@_stats.TotalLeads</strong> Lead</p>
                    </div>
                </div>
                <div class="hdr-actions">
                    <button class="btn-sync" @onclick="SyncFromSheet">
                        <MudIcon Icon="@Icons.Material.Rounded.Sync" Size="MudSize.Small" />
                        مزامنة من الشيت
                    </button>
                </div>
            </div>

            @* ═══ KPI ROW ═══ *@
            <div class="kpi-row">
                <div class="kpi" @onclick="@(() => QuickFilter(null))">
                    <div class="kpi-ico" style="background:rgba(99,102,241,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.Layers" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.TotalLeads</span>
                        <span class="kpi-lbl">إجمالي</span>
                    </div>
                </div>
                <div class="kpi" @onclick="@(() => QuickFilter("جديد"))">
                    <div class="kpi-ico" style="background:rgba(59,130,246,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.FiberNew" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.NewLeads</span>
                        <span class="kpi-lbl">جديد</span>
                    </div>
                </div>
                <div class="kpi" @onclick="@(() => QuickFilter("تم التواصل"))">
                    <div class="kpi-ico" style="background:rgba(245,158,11,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.PhoneCallback" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.ContactedLeads</span>
                        <span class="kpi-lbl">تم التواصل</span>
                    </div>
                </div>
                <div class="kpi" @onclick="@(() => QuickFilter("مؤهل"))">
                    <div class="kpi-ico" style="background:rgba(16,185,129,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.Verified" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.QualifiedLeads</span>
                        <span class="kpi-lbl">مؤهل</span>
                    </div>
                </div>
                <div class="kpi" @onclick="@(() => QuickFilter("محوّل"))">
                    <div class="kpi-ico" style="background:rgba(139,92,246,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.ConvertedLeads</span>
                        <span class="kpi-lbl">محوّل</span>
                    </div>
                </div>
                <div class="kpi" @onclick="@(() => QuickFilter("مرفوض"))">
                    <div class="kpi-ico" style="background:rgba(239,68,68,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.Cancel" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.RejectedLeads</span>
                        <span class="kpi-lbl">مرفوض</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ═══ SEARCH ═══ *@
    <div class="search-bar">
        <MudTextField T="string" Placeholder="ابحث بالاسم أو الهاتف أو الحملة..."
                      Variant="MudVariant.Outlined" Dense="true"
                      @bind-Value="_searchText"
                      OnKeyDown="OnSearchKeyDown"
                      Class="search-input" />
        <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary"
                   OnClick="ApplySearch" Size="MudSize.Small"
                   StartIcon="@Icons.Material.Rounded.Search">بحث</MudButton>
        <div class="search-chips">
            <button class="chip-btn @(_filter.LeadStatus=="جديد"?"chip-on":"")" @onclick="@(() => QuickFilter("جديد"))">جديد</button>
            <button class="chip-btn @(_filter.LeadStatus=="تم التواصل"?"chip-on":"")" @onclick="@(() => QuickFilter("تم التواصل"))">تم التواصل</button>
            <button class="chip-btn @(_filter.LeadStatus=="مؤهل"?"chip-on":"")" @onclick="@(() => QuickFilter("مؤهل"))">مؤهل</button>
            @if (_hasFilters)
            {
                <button class="chip-btn chip-clear" @onclick="ResetFilters">✕ مسح الكل</button>
            }
        </div>
    </div>

    @* ═══ FILTERS ═══ *@
    <div class="filter-bar">
        <div class="filter-row">
            <MudSelect T="string" Label="الحالة" Variant="MudVariant.Outlined"
                       @bind-Value="_filter.LeadStatus" Dense="true" Class="f-item"
                       Clearable="true" AnchorOrigin="Origin.BottomCenter">
                <MudSelectItem Value="@("جديد")">جديد</MudSelectItem>
                <MudSelectItem Value="@("تم التواصل")">تم التواصل</MudSelectItem>
                <MudSelectItem Value="@("مؤهل")">مؤهل</MudSelectItem>
                <MudSelectItem Value="@("محوّل")">محوّل</MudSelectItem>
                <MudSelectItem Value="@("مرفوض")">مرفوض</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" Label="المنصة" Variant="MudVariant.Outlined"
                       @bind-Value="_filter.Platform" Dense="true" Class="f-item"
                       Clearable="true" AnchorOrigin="Origin.BottomCenter">
                <MudSelectItem Value="@("fb")">Facebook</MudSelectItem>
                <MudSelectItem Value="@("ig")">Instagram</MudSelectItem>
            </MudSelect>
            <MudSelect T="int?" Label="الموظف المسؤول" Variant="MudVariant.Outlined"
                       @bind-Value="_filter.AssignedEmployeeId" Dense="true" Class="f-item"
                       Clearable="true" AnchorOrigin="Origin.BottomCenter">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem Value="@((int?)emp.EmployeeId)">@emp.FullName</MudSelectItem>
                }
            </MudSelect>
            <MudDatePicker Label="من" Variant="MudVariant.Outlined"
                           @bind-Date="_filter.DateFrom"
                           Dense="true" Class="f-date" />
            <MudDatePicker Label="إلى" Variant="MudVariant.Outlined"
                           @bind-Date="_filter.DateTo"
                           Dense="true" Class="f-date" />
            <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary"
                       OnClick="ApplyFilters" Size="MudSize.Small"
                       StartIcon="@Icons.Material.Rounded.FilterList">تصفية</MudButton>
        </div>
    </div>

    @* ═══ DATA TABLE ═══ *@
    @if (_isLoadingData) { <MudProgressLinear Color="MudColor.Primary" Indeterminate="true" Class="mb-2" /> }

    <div class="tbl-wrap">
        <MudTable Items="_pagedResult.Items"
                  T="LeadsCrmListDto"
                  Hover="true"
                  Striped="true"
                  Loading="_isLoadingData"
                  Dense="true"
                  Class="leads-table"
                  Breakpoint="Breakpoint.Sm"
                  Elevation="0">
            <NoRecordsContent>
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Rounded.SearchOff" Size="MudSize.Large" />
                    <MudText Typo="Typo.h6">لا توجد Leads مطابقة</MudText>
                    <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary)">
                        جرّب تعديل الفلاتر أو انتظر مزامنة بيانات جديدة
                    </MudText>
                </div>
            </NoRecordsContent>
            <HeaderContent>
                <MudTh>الاسم</MudTh>
                <MudTh>الهاتف</MudTh>
                <MudTh>الحالة</MudTh>
                <MudTh>المشروع</MudTh>
                <MudTh>المنصة</MudTh>
                <MudTh>الحملة</MudTh>
                <MudTh>الموظف</MudTh>
                <MudTh>التاريخ</MudTh>
                <MudTh Style="text-align:center">إجراءات</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="الاسم">
                    <strong>@context.FullName</strong>
                </MudTd>
                <MudTd DataLabel="الهاتف" Style="direction:ltr;text-align:right">
                    @context.Phone
                </MudTd>
                <MudTd DataLabel="الحالة">
                    <span class="@GetStatusClass(context.LeadStatus)">@context.LeadStatus</span>
                </MudTd>
                <MudTd DataLabel="المشروع">
                    <span style="font-size:0.82rem">@(context.ProjectType ?? "—")</span>
                </MudTd>
                <MudTd DataLabel="المنصة">
                    <span class="@GetPlatformClass(context.Platform)">@(context.Platform == "fb" ? "FB" : context.Platform == "ig" ? "IG" : "—")</span>
                </MudTd>
                <MudTd DataLabel="الحملة" Style="max-width:150px">
                    <span class="cell-truncate" title="@context.CampaignName">@(context.CampaignName ?? "—")</span>
                </MudTd>
                <MudTd DataLabel="الموظف">@(context.AssignedEmployeeName ?? "—")</MudTd>
                <MudTd DataLabel="التاريخ">
                    <span style="font-size:0.82rem;color:#64748b">@(context.CreatedAt.ToString("yyyy/MM/dd"))</span>
                </MudTd>
                <MudTd DataLabel="إجراءات" Style="text-align:center">
    <div class="actions-cell">
        <MudIconButton Icon="@Icons.Material.Rounded.Visibility"
               Title="عرض التفاصيل"
               OnClick="@(() => ShowDetail(context))" />
        @if (!string.IsNullOrEmpty(context.Phone))
        {
            <MudIconButton Icon="@Icons.Custom.Brands.WhatsApp"
                           Size="MudSize.Small" Color="MudColor.Success"
                           Title="واتساب"
                           OnClick="@(() => OpenWhatsApp(context.Phone))" />
            <MudIconButton Icon="@Icons.Material.Rounded.Phone"
                           Size="MudSize.Small" Color="MudColor.Primary"
                           Title="اتصال"
                           OnClick="@(() => CallPhone(context.Phone))" />
        }
        @if (_canEdit)
        {
            <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                           Size="MudSize.Small" Color="MudColor.Warning"
                           Title="تعديل"
                           OnClick="@(() => ShowEdit(context))" />
        }
        @if (_canConvert && context.LeadStatus != "محوّل")
        {
            <MudIconButton Icon="@Icons.Material.Rounded.PersonAdd"
                           Size="MudSize.Small" Color="MudColor.Success"
                           Title="تحويل لعميل"
                           OnClick="@(() => ShowConvert(context))" />
        }
        @if (_canDelete)
        {
            <MudIconButton Icon="@Icons.Material.Rounded.Delete"
                           Size="MudSize.Small" Color="MudColor.Error"
                           Title="حذف"
                           OnClick="@(() => DeleteLead(context))" />
        }
    </div>
</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="@(new int[] { 10, 25, 50, 100 })"
                               RowsPerPageString="عدد الصفوف"
                               InfoFormat="{first_item}-{last_item} من {all_items}" />
            </PagerContent>
        </MudTable>
    </div>

    @* ═══ PAGINATION INFO ═══ *@
    @if (_pagedResult.TotalPages > 1)
    {
        <div class="pager">
            <MudIconButton Icon="@Icons.Material.Rounded.ChevronRight"
                           OnClick="() => GoToPage(_filter.PageNumber - 1)"
                           Disabled="@(!_pagedResult.HasPrevious)" />
            <span>صفحة @_pagedResult.PageNumber من @_pagedResult.TotalPages — @_pagedResult.TotalCount Lead</span>
            <MudIconButton Icon="@Icons.Material.Rounded.ChevronLeft"
                           OnClick="() => GoToPage(_filter.PageNumber + 1)"
                           Disabled="@(!_pagedResult.HasNext)" />
        </div>
    }

</div>
}

@* ═══════════════════════════════════════════════════════════════════════════════════════════ *@
@* ═══ DETAIL DIALOG ═══ *@
@* ═══════════════════════════════════════════════════════════════════════════════════════════ *@
<MudDialog @bind-IsOpen="_showDetailDialog" MaxWidth="MaxWidth.Medium" FullWidth="true">
    <DialogContent>
        @if (_leadDetail != null)
        {
            <div dir="rtl" class="detail-dialog">

                @* ─── Hero Header ─── *@
                <div class="detail-hero">
                    <div class="detail-hero-info">
                        <div class="detail-avatar">
                            <MudIcon Icon="@Icons.Material.Rounded.Person" Size="MudSize.Large" />
                        </div>
                        <div>
                            <h3 class="detail-name">@_leadDetail.FullName</h3>
                            <span class="detail-phone-lbl" style="direction:ltr">@_leadDetail.Phone</span>
                        </div>
                    </div>
                    <span class="@GetStatusClass(_leadDetail.LeadStatus)" style="font-size:14px;padding:6px 16px">@_leadDetail.LeadStatus</span>
                </div>

                @* ─── Quick Actions ─── *@
                <div class="detail-actions-row">
                    @if (!string.IsNullOrEmpty(_leadDetail.Phone))
                    {
                        <MudButton Color="MudColor.Success" Variant="MudVariant.Outlined" Size="MudSize.Small"
                                   StartIcon="@Icons.Custom.Brands.WhatsApp"
                                   OnClick="@(() => OpenWhatsApp(_leadDetail.Phone))">واتساب</MudButton>
                        <MudButton Color="MudColor.Primary" Variant="MudVariant.Outlined" Size="MudSize.Small"
                                   StartIcon="@Icons.Material.Rounded.Phone"
                                   OnClick="@(() => CallPhone(_leadDetail.Phone))">اتصال</MudButton>
                    }
                    @if (!string.IsNullOrEmpty(_leadDetail.Phone2))
                    {
                        <MudButton Color="MudColor.Success" Variant="MudVariant.Text" Size="MudSize.Small"
                                   StartIcon="@Icons.Custom.Brands.WhatsApp"
                                   OnClick="@(() => OpenWhatsApp(_leadDetail.Phone2))">واتساب 2</MudButton>
                    }
                    @if (!string.IsNullOrEmpty(_leadDetail.Email))
                    {
                        <MudButton Color="MudColor.Info" Variant="MudVariant.Text" Size="MudSize.Small"
                                   StartIcon="@Icons.Material.Rounded.Email"
                                   OnClick="@(() => Navigation.NavigateTo($"mailto:{_leadDetail.Email}", forceLoad: true))">بريد</MudButton>
                    }
                    @if (_canEdit)
                    {
                        <MudButton Color="MudColor.Warning" Variant="MudVariant.Text" Size="MudSize.Small"
                                   StartIcon="@Icons.Material.Rounded.Edit"
                                   OnClick="@(() => { _showDetailDialog = false; ShowEdit(_selectedLead!); })">تعديل</MudButton>
                    }
                </div>

                @* ─── Section: بيانات العميل ─── *@
                <div class="detail-section">
                    <div class="section-title">
                        <MudIcon Icon="@Icons.Material.Rounded.Badge" Size="MudSize.Small" />
                        <span>بيانات العميل</span>
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <span class="detail-label">الهاتف</span>
                            <span class="detail-value" style="direction:ltr">@_leadDetail.Phone</span>
                        </div>
                        @if (!string.IsNullOrEmpty(_leadDetail.Phone2))
                        {
                            <div class="detail-item">
                                <span class="detail-label">هاتف 2</span>
                                <span class="detail-value" style="direction:ltr">@_leadDetail.Phone2</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_leadDetail.Email))
                        {
                            <div class="detail-item">
                                <span class="detail-label">البريد الإلكتروني</span>
                                <span class="detail-value">@_leadDetail.Email</span>
                            </div>
                        }
                        <div class="detail-item">
                            <span class="detail-label">المدينة</span>
                            <span class="detail-value">@(_leadDetail.City ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">العنوان</span>
                            <span class="detail-value">@(_leadDetail.Address ?? "—")</span>
                        </div>
                    </div>
                </div>

                @* ─── Section: معلومات المشروع ─── *@
                <div class="detail-section">
                    <div class="section-title">
                        <MudIcon Icon="@Icons.Material.Rounded.HomeWork" Size="MudSize.Small" />
                        <span>معلومات المشروع</span>
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <span class="detail-label">نوع المشروع</span>
                            <span class="detail-value">@(_leadDetail.ProjectType ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">مرحلة المشروع</span>
                            <span class="detail-value">@(_leadDetail.ProjectStage ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">الميزانية</span>
                            <span class="detail-value">@(_leadDetail.Budget ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">صانع القرار</span>
                            <span class="detail-value">@(_leadDetail.DecisionMaker ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">الإجراء التالي</span>
                            <span class="detail-value">@(_leadDetail.NextAction ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">أفضل وقت للتواصل</span>
                            <span class="detail-value">@(_leadDetail.BestTimeToReach ?? "—")</span>
                        </div>
                    </div>
                </div>

                @* ─── Section: مصدر الإعلان ─── *@
                <div class="detail-section">
                    <div class="section-title">
                        <MudIcon Icon="@Icons.Material.Rounded.Campaign" Size="MudSize.Small" />
                        <span>مصدر الإعلان</span>
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <span class="detail-label">المنصة</span>
                            <span class="detail-value">
                                <span class="@GetPlatformClass(_leadDetail.Platform)">@(_leadDetail.Platform == "fb" ? "Facebook" : _leadDetail.Platform == "ig" ? "Instagram" : _leadDetail.Platform ?? "—")</span>
                            </span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">الحملة</span>
                            <span class="detail-value">@(_leadDetail.CampaignName ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">الإعلان</span>
                            <span class="detail-value">@(_leadDetail.AdName ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">مجموعة الإعلان</span>
                            <span class="detail-value">@(_leadDetail.AdSetName ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">النموذج</span>
                            <span class="detail-value">@(_leadDetail.FormName ?? "—")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">لغة النموذج</span>
                            <span class="detail-value">@(_leadDetail.FormLanguage ?? "—")</span>
                        </div>
                    </div>
                </div>

                @* ─── Section: حالة التحويل ─── *@
                @if (_leadDetail.IsConverted || _leadDetail.IsDuplicate)
                {
                    <div class="detail-section">
                        <div class="section-title">
                            <MudIcon Icon="@Icons.Material.Rounded.Info" Size="MudSize.Small" />
                            <span>حالة التحويل</span>
                        </div>
                        <div class="detail-grid">
                            @if (_leadDetail.IsConverted)
                            {
                                <div class="detail-item" style="grid-column:1/-1">
                                    <span class="detail-label">تم التحويل لعميل</span>
                                    <span class="detail-value" style="color:#6d28d9;font-weight:700">
                                        عميل #@_leadDetail.ConvertedPartyId
                                        — فرصة #@_leadDetail.ConvertedOpportunityId
                                        — @_leadDetail.ConvertedDate?.ToString("yyyy/MM/dd")
                                        — بواسطة: @(_leadDetail.ConvertedBy ?? "—")
                                    </span>
                                </div>
                            }
                            @if (_leadDetail.IsDuplicate)
                            {
                                <div class="detail-item" style="grid-column:1/-1">
                                    <span class="detail-label">مكرر</span>
                                    <span class="detail-value" style="color:#b45309">نعم — نفس رقم: @(_leadDetail.DuplicateOfPhone ?? "—")</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* ─── Section: ملاحظات ─── *@
                @if (!string.IsNullOrEmpty(_leadDetail.Feedback) || !string.IsNullOrEmpty(_leadDetail.Notes))
                {
                    <div class="detail-section">
                        <div class="section-title">
                            <MudIcon Icon="@Icons.Material.Rounded.Notes" Size="MudSize.Small" />
                            <span>ملاحظات</span>
                        </div>
                        @if (!string.IsNullOrEmpty(_leadDetail.Feedback))
                        {
                            <div class="detail-note">
                                <span class="detail-label">Feedback</span>
                                <p class="detail-note-text">@_leadDetail.Feedback</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_leadDetail.Notes))
                        {
                            <div class="detail-note">
                                <span class="detail-label">ملاحظات داخلية</span>
                                <p class="detail-note-text">@_leadDetail.Notes</p>
                            </div>
                        }
                    </div>
                }

                @* ─── Footer ─── *@
                <div class="detail-footer">
                    <span>الموظف: <strong>@(_leadDetail.AssignedEmployeeName ?? "غير محدد")</strong></span>
                    <span>تاريخ الإنشاء: <strong>@_leadDetail.CreatedAt.ToString("yyyy/MM/dd HH:mm")</strong></span>
                    <span>بواسطة: <strong>@(_leadDetail.CreatedBy ?? "—")</strong></span>
                </div>
            </div>
        }
        else if (_showDetailDialog)
        {
            <div style="display:flex;justify-content:center;padding:2rem">
                <MudProgressCircular Color="MudColor.Primary" Indeterminate="true" />
            </div>
        }
    </DialogContent>
    <DialogActions>
        @if (_leadDetail != null && !string.IsNullOrEmpty(_leadDetail.Phone))
        {
            <MudButton Color="MudColor.Success" Variant="MudVariant.Text" StartIcon="@Icons.Custom.Brands.WhatsApp"
                       OnClick="@(() => OpenWhatsApp(_leadDetail.Phone))">واتساب</MudButton>
        }
        <MudButton Color="MudColor.Default" Variant="MudVariant.Text" OnClick="@(() => _showDetailDialog = false)">إغلاق</MudButton>
    </DialogActions>
</MudDialog>

@* ═══════════════════════════════════════════════════════════════════════════════════════════ *@
@* ═══ EDIT DIALOG ═══ *@
@* ═══════════════════════════════════════════════════════════════════════════════════════════ *@
<MudDialog @bind-IsOpen="_showEditDialog" MaxWidth="MaxWidth.Small" FullWidth="true">
    <DialogContent>
        <div dir="rtl">
            @if (_selectedLead != null)
            {
                <div class="edit-lead-header">
                    <strong>@_selectedLead.FullName</strong>
                    <span style="direction:ltr;color:var(--mud-palette-text-secondary);font-size:0.85rem">@_selectedLead.Phone</span>
                </div>
            }

            @* ─── تغيير الحالة (Quick Buttons) ─── *@
            <MudText Typo="Typo.subtitle2" Style="margin-bottom:0.5rem;font-weight:700">الحالة</MudText>
            <div class="status-btns">
                <button class="status-btn @(_editStatus == "جديد" ? "sb-new sb-active" : "sb-new")"
                        @onclick="@(() => _editStatus = "جديد")">جديد</button>
                <button class="status-btn @(_editStatus == "تم التواصل" ? "sb-contacted sb-active" : "sb-contacted")"
                        @onclick="@(() => _editStatus = "تم التواصل")">تم التواصل</button>
                <button class="status-btn @(_editStatus == "مؤهل" ? "sb-qualified sb-active" : "sb-qualified")"
                        @onclick="@(() => _editStatus = "مؤهل")">مؤهل</button>
                <button class="status-btn @(_editStatus == "مرفوض" ? "sb-rejected sb-active" : "sb-rejected")"
                        @onclick="@(() => _editStatus = "مرفوض")">مرفوض</button>
            </div>

            @* ─── الموظف المسؤول ─── *@
            <MudSelect T="int?" Label="الموظف المسؤول" Variant="MudVariant.Outlined"
                       @bind-Value="_editEmployeeId" Dense="true" Class="mb-3 mt-3" Clearable="true">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem Value="@((int?)emp.EmployeeId)">@emp.FullName</MudSelectItem>
                }
            </MudSelect>

            @* ─── سبب الرفض (يظهر بس لو الحالة مرفوض) ─── *@
            @if (_editStatus == "مرفوض")
            {
                <MudTextField T="string" Label="سبب الرفض" Variant="MudVariant.Outlined"
                              @bind-Value="_editRejectedReason" Dense="true" Class="mb-3" Lines="2" />
            }

            @* ─── Feedback ─── *@
            <MudTextField T="string" Label="ملاحظات / Feedback" Variant="MudVariant.Outlined"
                          @bind-Value="_editFeedback" Dense="true" Lines="3" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Color="MudColor.Primary" Variant="MudVariant.Filled" OnClick="SaveEdit" Disabled="_isSaving">
            @if (_isSaving) { <MudProgressCircular Size="MudSize.Small" Indeterminate="true" /> }
            حفظ
        </MudButton>
        <MudButton Color="MudColor.Default" Variant="MudVariant.Text" OnClick="@(() => _showEditDialog = false)">إلغاء</MudButton>
    </DialogActions>
</MudDialog>

@* ═══════════════════════════════════════════════════════════════════════════════════════════ *@
@* ═══ CONVERT DIALOG ═══ *@
@* ═══════════════════════════════════════════════════════════════════════════════════════════ *@
<MudDialog @bind-IsOpen="_showConvertDialog" MaxWidth="MaxWidth.Small" FullWidth="true">
    <DialogContent>
        <div dir="rtl">
            @if (_selectedLead != null)
            {
                <div class="edit-lead-header">
                    <strong>@_selectedLead.FullName</strong>
                    <span class="@GetStatusClass(_selectedLead.LeadStatus)">@_selectedLead.LeadStatus</span>
                </div>
            }

            <MudText Typo="Typo.h6" Style="margin-bottom:0.75rem;font-weight:700">تحويل Lead لعميل</MudText>
            <MudAlert Severity="Severity.Info" Style="margin-bottom:1rem">
                سيتم إنشاء: عميل (Party) + فرصة بيعية (Opportunity) + مهمة متابعة (Task)
            </MudAlert>

            <MudSelect T="int?" Label="الموظف المسؤول عن العميل" Variant="MudVariant.Outlined"
                       @bind-Value="_convertEmployeeId" Dense="true" Class="mb-3" Clearable="true">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem Value="@((int?)emp.EmployeeId)">@emp.FullName</MudSelectItem>
                }
            </MudSelect>

            <MudTextField T="string" Label="قيمة الفرصة المتوقعة" Variant="MudVariant.Outlined"
                          @bind-Value="_convertExpectedValue" Dense="true" Class="mb-3" />

            <MudTextField T="string" Label="ملاحظات التحويل" Variant="MudVariant.Outlined"
                          @bind-Value="_convertNotes" Dense="true" Lines="2" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Color="MudColor.Success" Variant="MudVariant.Filled" OnClick="ConvertLead" Disabled="_isSaving">
            @if (_isSaving) { <MudProgressCircular Size="MudSize.Small" Indeterminate="true" /> }
            تحويل لعميل
        </MudButton>
        <MudButton Color="MudColor.Default" Variant="MudVariant.Text" OnClick="@(() => _showConvertDialog = false)">إلغاء</MudButton>
    </DialogActions>
</MudDialog>


