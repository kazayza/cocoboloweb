    .dlg-field-label { display: flex; align-items: center; gap: 2px; font-size: 0.8rem; font-weight: 700; color: #475569; margin-bottom: 6px; }
    .dlg-input { width: 100%; }

    /* ─── Status Chips ─── */
    .dlg-status-chips { display: flex; gap: 6px; flex-wrap: wrap; }
