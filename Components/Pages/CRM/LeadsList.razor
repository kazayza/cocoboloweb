@code {
    // ───── State ─────
    private bool _isLoading = true;
    private bool _isLoadingData = false;
    private bool _isSaving = false;
    private string _searchText = "";

    private LeadsCrmFilterDto _filter = new() { PageSize = 25 };
    private PagedResult<LeadsCrmListDto> _pagedResult = new();
    private LeadsCrmStatsDto _stats = new();
    private List<Employee> _employees = new();

    // ───── Permissions ─────
    private bool _canEdit = false;
    private bool _canDelete = false;
    private bool _canConvert = false;
    private string _currentUserName = "system";

    // ───── Dialogs ─────
    private bool _showDetailDialog = false;
    private bool _showEditDialog = false;
    private bool _showConvertDialog = false;
    private LeadsCrmListDto? _selectedLead = null;
    private LeadsCrmDetailDto? _leadDetail = null;

    // ───── Edit State ─────
    private string _editStatus = "";
    private int? _editEmployeeId = null;
    private string _editFeedback = "";
    private string _editRejectedReason = "";

    // ───── Convert State ─────
    private string _convertExpectedValue = "";
    private string _convertNotes = "";
    private int? _convertEmployeeId = null;

    // ───── Helpers ─────
    private bool _hasFilters =>
        !string.IsNullOrWhiteSpace(_filter.SearchText)
        || !string.IsNullOrWhiteSpace(_filter.LeadStatus)
        || !string.IsNullOrWhiteSpace(_filter.Platform)
        || _filter.AssignedEmployeeId.HasValue
        || _filter.DateFrom.HasValue
        || _filter.DateTo.HasValue;

    // ═══════════════════════════════════════
    //              LIFECYCLE
    // ═══════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissionsAsync();
        await LoadEmployeesAsync();
        await LoadDataAsync();
        _isLoading = false;
    }

    public void Dispose() { }

    // ═══════════════════════════════════════
    //            PERMISSIONS
    // ═══════════════════════════════════════

    private async Task LoadPermissionsAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _currentUserName = user.Identity?.Name ?? "system";
        _canEdit = LeadsCrmPermissions.CanEdit(user);
        _canDelete = LeadsCrmPermissions.CanDelete(user);
        _canConvert = LeadsCrmPermissions.CanConvert(user);
    }

    // ═══════════════════════════════════════
    //              DATA
    // ═══════════════════════════════════════

    private async Task LoadEmployeesAsync()
    {
        try { _employees = await LeadsService.GetEmployeesAsync(); }
        catch { _employees = new(); }
    }

    private async Task LoadDataAsync()
    {
        _isLoadingData = true;

        try
        {
            _stats = await LeadsService.GetStatsAsync();
            _pagedResult = await LeadsService.GetLeadsAsync(_filter);
        }
        catch (Exception ex)
        {
            Snackbar.Add("تعذّر تحميل البيانات: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isLoadingData = false;
        }
    }

    // ═══════════════════════════════════════
    //             SEARCH
    // ═══════════════════════════════════════

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _filter.SearchText = _searchText;
            _filter.PageNumber = 1;
            await LoadDataAsync();
        }
    }

    private async Task ApplySearch()
    {
        _filter.SearchText = _searchText;
        _filter.PageNumber = 1;
        await LoadDataAsync();
    }

    // ═══════════════════════════════════════
    //             FILTERS
    // ═══════════════════════════════════════

    private async Task ApplyFilters()
    {
        _filter.SearchText = _searchText;
        _filter.PageNumber = 1;
        await LoadDataAsync();
    }

    private async Task ResetFilters()
    {
        _searchText = "";
        _filter = new LeadsCrmFilterDto { PageSize = _filter.PageSize };
        await LoadDataAsync();
    }

    private async Task QuickFilter(string? status)
    {
        if (_filter.LeadStatus == status)
            _filter.LeadStatus = null;
        else
            _filter.LeadStatus = status;

        _filter.SearchText = _searchText;
        _filter.PageNumber = 1;
        await LoadDataAsync();
    }

    private async Task GoToPage(int page)
    {
        _filter.PageNumber = page;
        await LoadDataAsync();
    }

    // ═══════════════════════════════════════
    //            ACTIONS
    // ═══════════════════════════════════════

    private async Task ShowDetail(LeadsCrmListDto lead)
    {
        _selectedLead = lead;
        _leadDetail = null;
        _showDetailDialog = true;

        try
        {
            _leadDetail = await LeadsService.GetLeadByIdAsync(lead.LeadId);
        }
        catch (Exception ex)
        {
            Snackbar.Add("تعذّر تحميل التفاصيل: " + ex.Message, Severity.Error);
        }
    }

    private void ShowEdit(LeadsCrmListDto lead)
    {
        _selectedLead = lead;
        _editStatus = lead.LeadStatus ?? "جديد";
        _editEmployeeId = lead.AssignedEmployeeId;
        _editFeedback = lead.Feedback ?? "";
        _editRejectedReason = "";
        _showEditDialog = true;
    }

    private void ShowConvert(LeadsCrmListDto lead)
    {
        _selectedLead = lead;
        _convertExpectedValue = "";
        _convertNotes = "";
        _convertEmployeeId = lead.AssignedEmployeeId;
        _showConvertDialog = true;
    }

    private async Task SaveEdit()
    {
        if (_selectedLead == null) return;
        _isSaving = true;

        try
        {
            var dto = new LeadsCrmUpdateDto
            {
                LeadId = _selectedLead.LeadId,
                LeadStatus = _editStatus,
                AssignedEmployeeId = _editEmployeeId,
                Feedback = _editFeedback,
                RejectedReason = _editStatus == "مرفوض" ? _editRejectedReason : null
            };

            var (success, message) = await LeadsService.UpdateLeadAsync(dto, _currentUserName);
            if (success)
            {
                Snackbar.Add("تم تحديث الـ Lead بنجاح", Severity.Success);
                _showEditDialog = false;
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add(message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("خطأ: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ConvertLead()
    {
        if (_selectedLead == null) return;
        _isSaving = true;

        try
        {
            var dto = new LeadConvertDto
            {
                LeadId = _selectedLead.LeadId,
                EmployeeId = _convertEmployeeId,
                ExpectedValue = decimal.TryParse(_convertExpectedValue, out var v) ? v : 0,
                Notes = _convertNotes
            };

            var result = await LeadsService.ConvertLeadToClientAsync(dto, _currentUserName);
            if (result.Success)
            {
                Snackbar.Add($"تم التحويل بنجاح — عميل #{result.PartyId}", Severity.Success);
                _showConvertDialog = false;
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add(result.Message ?? "فشل التحويل", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("خطأ: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteLead(LeadsCrmListDto lead)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Title, "تأكيد الحذف" },
            { x => x.Message, $"هل تريد حذف الـ Lead للعميل {lead.FullName}؟" },
            { x => x.YesText, "نعم، احذف" },
            { x => x.CancelText, "إلغاء" }
        };

        var dialog = await DialogService.ShowAsync<MudMessageBox>(
            "تأكيد الحذف", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });

        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        try
        {
            var (success, msg) = await LeadsService.DeleteLeadAsync(lead.LeadId, _currentUserName);
            Snackbar.Add(success ? "تم الحذف بنجاح" : msg, success ? Severity.Success : Severity.Error);
            if (success) await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("خطأ: " + ex.Message, Severity.Error);
        }
    }

    private async Task SyncFromSheet()
    {
        Snackbar.Add("جاري المزامنة من Google Sheet...", Severity.Info);
        await Task.Delay(1000);
        await LoadDataAsync();
        Snackbar.Add("تم تحديث البيانات", Severity.Success);
    }

