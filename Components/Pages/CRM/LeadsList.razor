    .dlg-chip:hover { border-color: #cbd5e1; background: #f8fafc; }
    .dlg-chip-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .dlg-chip-active { border-color: currentColor; background: #f0f9ff; }
    .dlg-chip-new.dlg-chip-active { color: #2563eb; background: #eff6ff; border-color: #3b82f6; }
    .dlg-chip-contacted.dlg-chip-active { color: #d97706; background: #fffbeb; border-color: #f59e0b; }
    .dlg-chip-qualified.dlg-chip-active { color: #059669; background: #ecfdf5; border-color: #10b981; }
    .dlg-chip-rejected.dlg-chip-active { color: #dc2626; background: #fef2f2; border-color: #ef4444; }

    /* ─── Convert: Header ─── */
