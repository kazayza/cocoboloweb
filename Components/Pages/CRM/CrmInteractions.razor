@page "/crm/interactions"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@inject IInteractionService InteractionService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>المتابعات — CRM</PageTitle>

@if (_isLoading)
{ <div class="loading-screen"><div class="loading-content"><MudProgressCircular Color="MudColor.Secondary" Size="MudSize.Large" Indeterminate="true" /><MudText Class="loading-text">جاري تحميل المتابعات...</MudText></div></div> }
else
{
<div dir="rtl" class="list-page">
    <div class="page-bg-decorations"><div class="bg-orb bg-orb-1"></div><div class="bg-orb bg-orb-2"></div></div>
    <div class="top-accent-bar"><div class="accent-shimmer"></div></div>

    <div class="list-header">
        <div class="header-bg"><div class="header-gradient"></div><div class="header-orbs"><div class="header-orb orb-1"></div><div class="header-orb orb-2"></div></div><div class="header-grid"></div></div>
        <div class="header-content">
            <div class="header-info">
                <div class="header-icon-wrapper"><div class="header-icon-glow"></div><div class="header-icon"><MudIcon Icon="@Icons.Material.Rounded.Chat" Size="MudSize.Large" /></div></div>
                <div class="header-text"><h1>سجل المتابعات</h1><p>سجل التفاعلات والتواصل مع العملاء</p></div>
            </div>
        </div>
    </div>

    @* Filters *@
    <div class="filter-bar">
        <div class="search-box"><MudIcon Icon="@Icons.Material.Rounded.Search" Class="search-icon" /><input type="text" @bind="_searchText" @bind:event="oninput" placeholder="بحث..." class="search-input" /></div>
        <MudDatePicker T="DateTime?" Label="من تاريخ" Variant="MudVariant.Outlined" @bind-Date="_filter.DateFrom" Dense="true" Class="filter-pick" />
        <MudDatePicker T="DateTime?" Label="إلى تاريخ" Variant="MudVariant.Outlined" @bind-Date="_filter.DateTo" Dense="true" Class="filter-pick" />
        <MudButton Variant="MudVariant.Outlined" OnClick="ApplyFilter" StartIcon="@Icons.Material.Rounded.FilterList">تصفية</MudButton>
    </div>

    @if (_isTableLoading) { <MudLinearProgress Color="MudColor.Primary" Indeterminate="true" Class="load-bar" /> }

    <div class="table-wrap">
        <table class="data-table">
            <thead><tr><th>العميل</th><th>التفاعل</th><th>المرحلة</th><th>الموظف</th><th>التاريخ</th><th>المتابعة</th></tr></thead>
            <tbody>
                @foreach (var i in _pagedResult.Items)
                {
                    <tr class="clickable" @onclick="() => GoToOpportunity(i.OpportunityId)">
                        <td><strong>@i.ClientName</strong></td>
                        <td>@(i.Summary ?? "—").Truncate(50)</td>
                        <td>
                            @if (i.StageBeforeId != i.StageAfterId)
                            { <span>@(i.StageBeforeName ?? "—") → <strong>@(i.StageAfterName ?? "—")</strong></span> }
                            else { <span>@(i.StageAfterName ?? "—")</span> }
                        </td>
                        <td>@(i.EmployeeName ?? "—")</td>
                        <td>@i.InteractionDate.ToString("yyyy/MM/dd")</td>
                        <td>@(i.NextFollowUpDate?.ToString("yyyy/MM/dd") ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!_pagedResult.Items.Any()) { <div class="empty-state"><MudIcon Icon="@Icons.Material.Rounded.SearchOff" Size="MudSize.Large" /><span>لا توجد تفاعلات</span></div> }

    @if (_pagedResult.TotalPages > 1)
    {
        <div class="pagination-bar">
            <MudIconButton Icon="@Icons.Material.Rounded.ChevronRight" OnClick="() => GoToPage(_filter.PageNumber - 1)" Disabled="@(!_pagedResult.HasPrevious)" />
            <span>صفحة @_pagedResult.PageNumber من @_pagedResult.TotalPages — @_pagedResult.TotalCount تفاعل</span>
            <MudIconButton Icon="@Icons.Material.Rounded.ChevronLeft" OnClick="() => GoToPage(_filter.PageNumber + 1)" Disabled="@(!_pagedResult.HasNext)" />
        </div>
    }
</div>
}

<style>
    .list-page { padding: 0 1.5rem 3rem; }
    .filter-bar { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-bottom: 1rem; padding: 0.6rem 1rem; background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default); border-radius: 12px; }
    .search-box { position: relative; flex: 1; min-width: 140px; }
    .search-icon { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); }
    .search-input { width: 100%; padding: 7px 30px 7px 10px; border: 1px solid var(--mud-palette-lines-inputs); border-radius: 8px; background: var(--mud-palette-background); }
    .filter-pick { min-width: 130px; }
    .load-bar { margin-bottom: 0.5rem; border-radius: 4px; }
    .table-wrap { overflow-x: auto; border: 1px solid var(--mud-palette-lines-default); border-radius: 12px; background: var(--mud-palette-surface); }
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .data-table th { padding: 0.6rem 0.8rem; text-align: right; font-weight: 700; border-bottom: 2px solid var(--mud-palette-lines-inputs); }
    .data-table td { padding: 0.5rem 0.8rem; border-bottom: 1px solid var(--mud-palette-lines-inputs); }
    .data-table tr:last-child td { border-bottom: none; }
    .clickable { cursor: pointer; }
    .clickable:hover { background: var(--mud-palette-action-hover); }
    .empty-state { display: flex; flex-direction: column; align-items: center; padding: 3rem; color: var(--mud-palette-text-disabled); gap: 0.5rem; }
    .pagination-bar { display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-top: 1.5rem; font-size: 0.85rem; color: var(--mud-palette-text-secondary); }

    .list-header { position: relative; border-radius: 20px; overflow: hidden; margin-bottom: 0.75rem; }
    .header-bg { position: absolute; inset: 0; }
    .header-gradient { position: absolute; inset: 0; background: linear-gradient(135deg, #0891b2 0%, #06b6d4 40%, #22d3ee 100%); }
    .header-orbs { position: absolute; inset: 0; overflow: hidden; }
    .header-orb { position: absolute; border-radius: 50%; filter: blur(60px); }
    .orb-1 { width: 140px; height: 140px; background: rgba(255,255,255,.1); top: -20px; right: -20px; }
    .orb-2 { width: 100px; height: 100px; background: rgba(255,255,255,.05); bottom: -20px; left: 10%; }
    .header-grid { position: absolute; inset: 0; background: repeating-linear-gradient(0deg, transparent, transparent 1px, rgba(255,255,255,.02) 1px, rgba(255,255,255,.02) 2px), repeating-linear-gradient(90deg, transparent, transparent 1px, rgba(255,255,255,.02) 1px, rgba(255,255,255,.02) 2px); background-size: 40px 40px; }
    .header-content { position: relative; z-index: 1; padding: 1.25rem 1.5rem; color: #fff; }
    .header-info { display: flex; align-items: center; gap: 0.75rem; }
    .header-icon-wrapper { position: relative; }
    .header-icon-glow { position: absolute; inset: -6px; background: rgba(255,255,255,.12); border-radius: 50%; filter: blur(10px); }
    .header-icon { width: 44px; height: 44px; background: rgba(255,255,255,.12); border-radius: 12px; display: flex; align-items: center; justify-content: center; }
    .header-text h1 { margin: 0; font-size: 1.15rem; }
    .header-text p { margin: 2px 0 0; font-size: 0.75rem; opacity: 0.75; }

    @@media (max-width: 900px) { .filter-bar { flex-direction: column; } .filter-pick { width: 100%; } }
</style>

@code {
    private bool _isLoading = true, _isTableLoading, _canView;
    private string _searchText = "";
    private InteractionFilterDto _filter = new();
    private PagedResult<InteractionListDto> _pagedResult = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _canView = user.HasClaim("Permission", "frmNewInteraction:View") || user.IsInRole("Admin");
        if (!_canView) { Navigation.NavigateTo("/"); return; }
        
        _isTableLoading = true; 
        _pagedResult = await InteractionService.GetInteractionsAsync(_filter); 
        _isTableLoading = _isLoading = false; 
    }

    private async Task ApplyFilter()
    { _filter.SearchText = _searchText; _filter.PageNumber = 1; _isTableLoading = true; StateHasChanged(); _pagedResult = await InteractionService.GetInteractionsAsync(_filter); _isTableLoading = false; }

    private async Task GoToPage(int page) { _filter.PageNumber = page; _isTableLoading = true; StateHasChanged(); _pagedResult = await InteractionService.GetInteractionsAsync(_filter); _isTableLoading = false; }

    private void GoToOpportunity(int id) => Navigation.NavigateTo($"/crm/opportunities/{id}");
}