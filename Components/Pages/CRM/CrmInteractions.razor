@page "/crm/interactions"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@inject IInteractionService InteractionService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>سجل التواصلات — CRM</PageTitle>

@if (_loading)
{ <div class="loading-screen"><MudProgressCircular Color="MudColor.Secondary" Size="MudSize.Large" Indeterminate="true" /><MudText Typo="Typo.h6" Class="load-txt">جاري تحميل التواصلات...</MudText></div> }
else
{
<div dir="rtl" class="ipg">

    @* ═══ HEADER ═══ *@
    <div class="ihdr">
        <div class="ihdr-bg"><div class="ihdr-grad"></div></div>
        <div class="ihdr-inr">
            <div class="ihdr-icn"><MudIcon Icon="@Icons.Material.Rounded.Chat" Style="font-size:1.5rem" /></div>
            <div class="ihdr-txt"><h1>سجل التواصلات</h1><p>سجل كامل للتفاعلات والتواصل مع العملاء — <strong>@_paged.TotalCount</strong> تفاعل</p></div>
        </div>
    </div>

    @* ═══ FILTERS ═══ *@
    <div class="iflt">
        <MudTextField T="string" Label="🔍 بحث عن عميل أو تفاعل" Variant="MudVariant.Outlined" @bind-Value="_s" Dense="true" Class="iflt-big" Immediate="true" />
        <MudDatePicker Label="📅 من" Variant="MudVariant.Outlined" Date="_f.DateFrom" DateChanged="d=>_f.DateFrom=d" Dense="true" Class="iflt-sm" />
        <MudDatePicker Label="📅 إلى" Variant="MudVariant.Outlined" Date="_f.DateTo" DateChanged="d=>_f.DateTo=d" Dense="true" Class="iflt-sm" />
        <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary" OnClick="DoFilter" Size="MudSize.Small">تصفية</MudButton>
        @if (_hasF) { <MudButton Variant="MudVariant.Text" Color="MudColor.Error" OnClick="DoReset" Size="MudSize.Small">مسح</MudButton> }
    </div>

    @if (_busy) { <div class="busy-bar"></div> }

    @* ═══ TIMELINE ═══ *@
    @if (_paged.Items.Any())
    {
        <div class="itl">
            @foreach (var i in _paged.Items)
            {
                <div class="itl-item" @onclick="()=>OpenOpp(i.OpportunityId)">
                    <div class="itl-line"></div>
                    <div class="itl-dot" style="background:@(GetStageColor(i))"></div>
                    <div class="itl-body">
                        <div class="itl-h">
                            <strong>@i.ClientName</strong>
                            <span class="itl-date">@i.InteractionDate.ToString("yyyy/MM/dd") @(i.InteractionTime?.ToString("HH:mm")??"")</span>
                        </div>
                        @if (i.StageBeforeId != i.StageAfterId && i.StageBeforeName != null)
                        {
                            <div class="itl-stage">🔄 <span>@i.StageBeforeName</span> → <strong>@(i.StageAfterName??"—")</strong></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(i.Summary))
                        { <div class="itl-sum">@i.Summary</div> }
                        <div class="itl-meta">
                            <span>👤 @(i.EmployeeName??i.CreatedBy??"—")</span>
                            @if (i.SourceName!=null) { <span>📡 @i.SourceName</span> }
                            @if (i.NextFollowUpDate.HasValue) { <span>📅 المتابعة: @i.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span> }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(i.Notes)) { <div class="itl-notes">📌 @i.Notes</div> }
                    </div>
                </div>
            }
        </div>
    }
    else { <div class="empty"><MudIcon Icon="@Icons.Material.Rounded.Inbox" Size="MudSize.Large" /><span>لا توجد تواصلات</span></div> }

    @if (_paged.TotalPages > 1)
    { <div class="pag"><MudIconButton Icon="@Icons.Material.Rounded.ChevronRight" OnClick="()=>Pg(_f.PageNumber-1)" Disabled="!_paged.HasPrevious" /><span>@_paged.PageNumber / @_paged.TotalPages · @_paged.TotalCount</span><MudIconButton Icon="@Icons.Material.Rounded.ChevronLeft" OnClick="()=>Pg(_f.PageNumber+1)" Disabled="!_paged.HasNext" /></div> }

</div>
}

<style>
    .ipg{padding:0 1.5rem 3rem;max-width:900px;margin:0 auto}
    .load-txt{margin-top:.75rem}

    .ihdr{position:relative;border-radius:18px;overflow:hidden;margin-bottom:1rem;box-shadow:0 10px 30px rgba(8,145,178,.2)}
    .ihdr-bg{position:absolute;inset:0}
    .ihdr-grad{position:absolute;inset:0;background:linear-gradient(135deg,#0891b2,#06b6d4,#22d3ee)}
    .ihdr-inr{position:relative;z-index:1;padding:1.1rem 1.5rem;color:#fff;display:flex;align-items:center;gap:.75rem}
    .ihdr-icn{width:44px;height:44px;background:rgba(255,255,255,.15);border-radius:12px;display:flex;align-items:center;justify-content:center}
    .ihdr-txt h1{margin:0;font-size:1.2rem;font-weight:800}
    .ihdr-txt p{margin:3px 0 0;font-size:.78rem;opacity:.85}
    .ihdr-txt strong{color:#fde68a}

    .iflt{display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;padding:.65rem .9rem;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-lines-default);border-radius:12px;margin-bottom:.85rem}
    .iflt-big{flex:2;min-width:200px}.iflt-sm{min-width:130px}

    .busy-bar{height:3px;background:linear-gradient(90deg,var(--mud-palette-primary),#06b6d4);border-radius:3px;margin-bottom:.5rem;animation:busy 1.5s ease-in-out infinite;width:100%}
    @@keyframes busy{0%,100%{opacity:.4}50%{opacity:1}}

    .itl{position:relative;padding-right:2rem}
    .itl-item{position:relative;padding-bottom:1.5rem;cursor:pointer}
    .itl-item:last-child{padding-bottom:0}
    .itl-line{position:absolute;right:.55rem;top:1.4rem;bottom:0;width:2px;background:var(--mud-palette-lines-inputs)}
    .itl-item:last-child .itl-line{display:none}
    .itl-dot{position:absolute;right:.05rem;top:.35rem;width:12px;height:12px;border-radius:50%;border:2px solid var(--mud-palette-surface);box-shadow:0 0 0 2px currentColor;opacity:.8}
    .itl-body{background:var(--mud-palette-surface);border:1px solid var(--mud-palette-lines-default);border-radius:12px;padding:.9rem 1rem}
    .itl-body:hover{box-shadow:0 4px 16px rgba(0,0,0,.08)}
    .itl-h{display:flex;justify-content:space-between;margin-bottom:.3rem;font-size:.85rem}
    .itl-date{font-size:.72rem;color:var(--mud-palette-text-secondary)}
    .itl-stage{font-size:.78rem;margin-bottom:.25rem;color:var(--mud-palette-primary)}
    .itl-stage span{text-decoration:line-through;color:var(--mud-palette-text-disabled)}
    .itl-sum{font-size:.88rem;margin-bottom:.3rem;line-height:1.4}
    .itl-meta{display:flex;gap:.8rem;font-size:.7rem;color:var(--mud-palette-text-secondary)}
    .itl-notes{font-size:.72rem;color:var(--mud-palette-text-disabled);margin-top:.2rem;border-top:1px solid var(--mud-palette-lines-inputs);padding-top:.2rem}
    .empty{display:flex;flex-direction:column;align-items:center;padding:3rem;color:var(--mud-palette-text-disabled);gap:.5rem}
    .pag{display:flex;align-items:center;justify-content:center;gap:.75rem;margin-top:1.25rem;font-size:.85rem;color:var(--mud-palette-text-secondary)}

    @@media(max-width:768px){.ipg{padding:0 .4rem 2rem}.iflt{flex-direction:column}.iflt-big,.iflt-sm{width:100%!important}.itl-body{padding:.7rem}}
</style>

@code {
    private bool _loading=true,_busy;
    private string _s="";
    private InteractionFilterDto _f=new();
    private PagedResult<InteractionListDto> _paged=new();
    private bool _hasF=>!string.IsNullOrWhiteSpace(_s)||_f.DateFrom.HasValue||_f.DateTo.HasValue;

    protected override async Task OnInitializedAsync(){_paged=await InteractionService.GetInteractionsAsync(_f);_loading=false;}

    async Task DoFilter(){_f.SearchText=_s?.Trim();_f.PageNumber=1;_busy=true;StateHasChanged();_paged=await InteractionService.GetInteractionsAsync(_f);_busy=false;StateHasChanged();}
    async Task DoReset(){_s="";_f=new();await DoFilter();}
    async Task Pg(int p){_f.PageNumber=p;_busy=true;StateHasChanged();_paged=await InteractionService.GetInteractionsAsync(_f);_busy=false;StateHasChanged();}

    private void OpenOpp(int id) => Nav.NavigateTo($"/crm/opportunities/{id}");
    private void GoToCust(int pid) => Nav.NavigateTo($"/crm/customers/{pid}");
    private static string GetStageColor(InteractionListDto i){
        if(i.StageAfterId.HasValue)return i.StageAfterName switch{"تم البيع"=>"#27ae60","خسارة"=>"#e74c3c","غير مهتم"=>"#95a5a6",_=>"#3b82f6"};
        return "#94a3b8";
    }
}