@page "/crm/customers"
@page "/crm/customers/{PartyId:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using Microsoft.EntityFrameworkCore
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@inject IDbContextFactory<db24804Context> DbFactory
@inject IOpportunityService OppService
@inject IInteractionService InteractionService
@inject ITaskService TaskService
@inject IComplaintService ComplaintService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<PageTitle>@(PartyId.HasValue ? "بطاقة العميل" : "بحث العملاء") — CRM</PageTitle>

@if (_loading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-logo">
                <MudIcon Icon="@(PartyId.HasValue ? Icons.Material.Rounded.Person : Icons.Material.Rounded.Search)" Size="MudSize.Large" />
                <div class="loading-ring"></div>
                <div class="loading-ring ring-2"></div>
                <div class="loading-ring ring-3"></div>
            </div>
            <MudText Typo="Typo.h6" Style="font-weight:700;margin-top:1.2rem">جاري التحميل...</MudText>
            <MudProgressLinear Color="MudColor.Secondary" Indeterminate="true" Class="mt-3" Style="max-width:280px;border-radius:8px" />
        </div>
    </div>
}
else if (PartyId.HasValue && PartyId.Value > 0 && _party != null)
{
    @* ════════════════════════════════════════════════════════ *@
    @* ═══ MODE: CUSTOMER PROFILE — PREMIUM 2026 ═══ *@
    @* ════════════════════════════════════════════════════════ *@
    <div dir="rtl" class="cp-page">

        @* SEARCH OVERLAY *@
        @if (_showSearch)
        {
            <div class="cp-search-overlay" @onclick="ToggleSearch">
                <div class="cp-search-box" @onclick:stopPropagation>
                    <div class="cp-search-header">
                        <MudIcon Icon="@Icons.Material.Rounded.Search" Style="color:var(--mud-palette-primary)" />
                        <input type="text" class="cp-search-input" placeholder="ابحث بالاسم أو رقم التليفون..."
                               @bind="_searchQuery" @bind:event="oninput" @onkeyup="OnSearchKey" />
                        @if (_searching)
                        { <div class="cp-search-spinner"></div> }
                        <button class="cp-search-close" @onclick="ToggleSearch">
                            <MudIcon Icon="@Icons.Material.Rounded.Close" Size="MudSize.Small" />
                        </button>
                    </div>
                    @if (_searchResults.Any())
                    {
                        <div class="cp-search-results">
                            @foreach (var c in _searchResults)
                            {
                                <div class="cp-search-item @(c.PartyId == PartyId ? "current" : "")"
                                     @onclick="@(() => GoToCustomer(c.PartyId))">
                                    <div class="cp-si-avatar" style="background:linear-gradient(135deg,#7c3aed,#a78bfa)">
                                        @GetInitials(c.PartyName)
                                    </div>
                                    <div class="cp-si-info">
                                        <span class="cp-si-name">@c.PartyName</span>
                                        <span class="cp-si-meta">
                                            @if (!string.IsNullOrWhiteSpace(c.Phone))
                                            { <span>📞 @c.Phone</span> }
                                            @if (!string.IsNullOrWhiteSpace(c.City))
                                            { <span>📍 @c.City</span> }
                                        </span>
                                    </div>
                                    @if (c.PartyId == PartyId)
                                    { <span class="cp-si-badge">الحالي</span> }
                                </div>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_searchQuery) && _searchQuery.Length >= 2 && !_searching)
                    {
                        <div class="cp-search-empty">لا توجد نتائج</div>
                    }
                    else
                    {
                        <div class="cp-search-hint">اكتب اسم العميل أو رقم التليفون (حرفين على الأقل)</div>
                    }
                </div>
            </div>
        }

        @* ─── HERO HEADER — Mesh Gradient + Animated Avatar ─── *@
        <div class="cp-hero">
            <div class="cp-hero-bg">
                <div class="cp-hero-grad"></div>
                <div class="cp-hero-pattern"></div>
                <div class="cp-hero-orb orb-1"></div>
                <div class="cp-hero-orb orb-2"></div>
                <div class="cp-hero-orb orb-3"></div>
                <div class="cp-hero-orb orb-4"></div>
            </div>
            <div class="cp-hero-content">
                <div class="cp-hero-top">
                    <button class="cp-back-btn" @onclick="GoBack">
                        <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="MudSize.Small" />
                        <span>العودة</span>
                    </button>
                    <div class="cp-hero-actions">
                        <button class="cp-action-btn" @onclick="ToggleSearch" title="بحث سريع">
                            <MudIcon Icon="@Icons.Material.Rounded.Search" Size="MudSize.Small" />
                        </button>
                        @if (!string.IsNullOrWhiteSpace(_party.Phone))
                        {
                            <button class="cp-action-btn" @onclick="@(() => Call(_party.Phone))" title="اتصال">
                                <MudIcon Icon="@Icons.Material.Rounded.Phone" Size="MudSize.Small" />
                            </button>
                            <button class="cp-action-btn wa-btn" @onclick="@(() => WA(_party.Phone))" title="واتساب سريع">
                                <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Size="MudSize.Small" />
                            </button>
                        }
                        @if (!string.IsNullOrWhiteSpace(_party.Email))
                        {
                            <button class="cp-action-btn" @onclick="@(() => Email(_party.Email))" title="إرسال إيميل">
                                <MudIcon Icon="@Icons.Material.Rounded.Email" Size="MudSize.Small" />
                            </button>
                        }
                        <button class="cp-action-btn edit" @onclick="EditCustomer">
                            <MudIcon Icon="@Icons.Material.Rounded.Edit" Size="MudSize.Small" />
                            <span>تعديل</span>
                        </button>
                    </div>
                </div>

                <div class="cp-hero-profile">
                    <div class="cp-avatar-wrap">
                        <div class="cp-avatar-conic-ring"></div>
                        <div class="cp-avatar">
                            <span>@GetInitials(_party.PartyName)</span>
                        </div>
                        <div class="cp-avatar-pulse"></div>
                    </div>
                    <div class="cp-hero-info">
                        <h1>@_party.PartyName</h1>
                        <div class="cp-hero-meta">
                            @if (!string.IsNullOrWhiteSpace(_party.Phone))
                            {
                                <a class="cp-meta-link" href="tel:@_party.Phone" @onclick:stopPropagation @onclick="@(() => Call(_party.Phone))">
                                    <MudIcon Icon="@Icons.Material.Rounded.Phone" Size="MudSize.Small" />
                                    <span>@_party.Phone</span>
                                    <MudIcon Icon="@Icons.Material.Rounded.ContentCopy" Size="MudSize.Small" Class="cp-copy-icon" title="نسخ" />
                                </a>
                            }
                            @if (!string.IsNullOrWhiteSpace(_party.Email))
                            {
                                <a class="cp-meta-link" href="mailto:@_party.Email" @onclick:stopPropagation @onclick="@(() => Email(_party.Email))">
                                    <MudIcon Icon="@Icons.Material.Rounded.Email" Size="MudSize.Small" />
                                    <span>@_party.Email</span>
                                    <MudIcon Icon="@Icons.Material.Rounded.ContentCopy" Size="MudSize.Small" Class="cp-copy-icon" title="نسخ" />
                                </a>
                            }
                            @if (!string.IsNullOrWhiteSpace(_party.City))
                            {
                                <span class="cp-meta-item">
                                    <MudIcon Icon="@Icons.Material.Rounded.LocationOn" Size="MudSize.Small" />
                                    <span>@_party.City</span>
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_party.CustomerStage))
                        {
                            <div class="cp-stage-badge">
                                <span class="cp-stage-dot"></span>
                                <span>@_party.CustomerStage</span>
                            </div>
                        }
                    </div>
                </div>

                @* ─── STATS ROW — Enhanced Visual Weight (مدمج مع Insights) ─── *@
                <div class="cp-hero-stats">
                    <div class="cp-stat" @onclick="@(() => _tab = 0)" style="--stat-color:#818cf8">
                        <div class="cp-stat-accent"></div>
                        <div class="cp-stat-icon" style="background:rgba(99,102,241,.18);color:#818cf8">
                            <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_opportunities.Count</span>
                            <span class="cp-stat-lbl">فرصة</span>
                        </div>
                    </div>
                    <div class="cp-stat" @onclick="@(() => _tab = 0)" style="--stat-color:#22c55e">
                        <div class="cp-stat-accent"></div>
                        <div class="cp-stat-icon" style="background:rgba(34,197,94,.18);color:#22c55e">
                            <MudIcon Icon="@Icons.Material.Rounded.EmojiEvents" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_wonCount</span>
                            <span class="cp-stat-lbl">مربوحة</span>
                        </div>
                    </div>
                    <div class="cp-stat" style="--stat-color:#f59e0b">
                        <div class="cp-stat-accent"></div>
                        <div class="cp-stat-icon" style="background:rgba(245,158,11,.18);color:#f59e0b">
                            <MudIcon Icon="@Icons.Material.Rounded.AttachMoney" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val"><span class="cp-stat-currency">ج</span> @_pipelineValue.ToString("N0")</span>
                            <span class="cp-stat-lbl">Pipeline</span>
                        </div>
                    </div>
                    <div class="cp-stat" @onclick="@(() => _tab = 1)" style="--stat-color:#7c3aed">
                        <div class="cp-stat-accent"></div>
                        <div class="cp-stat-icon" style="background:rgba(124,58,237,.18);color:#7c3aed">
                            <MudIcon Icon="@Icons.Material.Rounded.Schedule" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@(_lastContactDate.HasValue ? _lastContactDate.Value.ToString("yyyy/MM/dd") : "—")</span>
                            <span class="cp-stat-lbl">آخر تواصل</span>
                        </div>
                    </div>
                    <div class="cp-stat" style="--stat-color:#3b82f6">
                        <div class="cp-stat-accent"></div>
                        <div class="cp-stat-icon" style="background:rgba(59,130,246,.18);color:#3b82f6">
                            <MudIcon Icon="@Icons.Material.Rounded.Event" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@(_nextFollowUp.HasValue ? _nextFollowUp.Value.ToString("yyyy/MM/dd") : "—")</span>
                            <span class="cp-stat-lbl">متابعة قادمة</span>
                        </div>
                    </div>
                    <div class="cp-stat" style="--stat-color:#22c55e">
                        <div class="cp-stat-accent"></div>
                        <div class="cp-stat-icon" style="background:rgba(34,197,94,.18);color:#22c55e">
                            <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_winRate%</span>
                            <span class="cp-stat-lbl">نسبة الفوز</span>
                        </div>
                    </div>
                    <div class="cp-stat" @onclick="@(() => _tab = 2)" style="--stat-color:#ef4444">
                        <div class="cp-stat-accent"></div>
                        <div class="cp-stat-icon" style="background:rgba(239,68,68,.18);color:#ef4444">
                            <MudIcon Icon="@Icons.Material.Rounded.TaskAlt" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_activeTaskCount</span>
                            <span class="cp-stat-lbl">مهمة نشطة</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ─── QUICK ADD — Integrated Action Bar ─── *@
        <div class="cp-quick-add">
            <span class="cp-qa-label"><MudIcon Icon="@Icons.Material.Rounded.Bolt" Size="MudSize.Small" /> إضافة سريعة</span>
            <button class="cp-qa-btn" @onclick="AddOpportunity">
                <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="MudSize.Small" /> فرصة جديدة
            </button>
            <button class="cp-qa-btn info" @onclick="AddInteraction">
                <MudIcon Icon="@Icons.Material.Rounded.Forum" Size="MudSize.Small" /> تواصل جديد
            </button>
            <button class="cp-qa-btn warn" @onclick="AddTask">
                <MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Size="MudSize.Small" /> مهمة جديدة
            </button>
        </div>

        @* ─── PREMIUM PILL TABS ─── *@
        <div class="cp-tabs-container">
            <div class="cp-tabs">
                <button class="@(_tab==0?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=0)">
                    <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="MudSize.Small" />
                    <span>الفرص</span>
                    <span class="cp-tab-count">@_opportunities.Count</span>
                </button>
                <button class="@(_tab==1?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=1)">
                    <MudIcon Icon="@Icons.Material.Rounded.Forum" Size="MudSize.Small" />
                    <span>التواصلات</span>
                    <span class="cp-tab-count">@_interactions.Count</span>
                </button>
                <button class="@(_tab==2?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=2)">
                    <MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Size="MudSize.Small" />
                    <span>المهام</span>
                    <span class="cp-tab-count">@_tasks.Count</span>
                </button>
                @if (_canViewInvoices)
                {
                    <button class="@(_tab==3?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=3)">
                        <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="MudSize.Small" />
                        <span>المالية والفواتير</span>
                        <span class="cp-tab-count">@_invoices.Count</span>
                    </button>
                }
                @if (_canViewQuotations)
                {
                    <button class="@(_tab==5?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=5)">
                        <MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="MudSize.Small" />
                        <span>عروض الأسعار</span>
                        <span class="cp-tab-count">@_clientQuotations.Count</span>
                    </button>
                }
                @if (_canViewComplaints)
                {
                    <button class="@(_tab==6?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=6)">
                        <MudIcon Icon="@Icons.Material.Rounded.ReportProblem" Size="MudSize.Small" />
                        <span>الشكاوى</span>
                        <span class="cp-tab-count">@_complaints.Count</span>
                    </button>
                }
                <button class="@(_tab==4?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=4)">
                    <MudIcon Icon="@Icons.Material.Rounded.History" Size="MudSize.Small" />
                    <span>النشاط الموحد</span>
                    <span class="cp-tab-count">@_activities.Count</span>
                </button>
                <div class="cp-tabs-indicator" style="transform:translateX(@(_tabIndex * 100)%);width:@(100.0 / _tabCount)%"></div>
            </div>
        </div>

        @* ─── TAB: OPPORTUNITIES ─── *@
        @if (_tab == 0)
        {
            @if (_opportunities.Any())
            {
                @if (_stageGroups.Any())
                {
                    <div class="cp-pipeline-bar">
                        @foreach (var stage in _stageGroups)
                        {
                            <div class="cp-pipeline-seg" style="flex:@stage.Count;background:@stage.Color" title="@stage.Name: @stage.Count">
                                @if (stage.Count > 0) { <span class="cp-pipeline-label">@stage.Count</span> }
                            </div>
                        }
                    </div>
                }
                <div class="cp-opp-grid">
                    @foreach (var o in _opportunities.OrderByDescending(o => o.CreatedAt))
                    {
                        <div class="cp-opp-card" @onclick="() => OpenOpp(o.OpportunityId)" style="--opp-color:@(o.StageColor ?? "#94a3b8")">
                            <div class="cp-opp-color" style="background:linear-gradient(180deg, @(o.StageColor ?? "#94a3b8"), transparent)"></div>
                            <div class="cp-opp-tint" style="background:@(o.StageColor ?? "#94a3b8")"></div>
                            <div class="cp-opp-body">
                                <div class="cp-opp-head">
                                    <span class="cp-opp-stage" style="color:@(o.StageColor ?? "#94a3b8");background:@(o.StageColor ?? "#94a3b8")18">
                                        @(o.StageNameAr ?? o.StageName ?? "—")
                                    </span>
                                    <span class="cp-opp-value">💰 @((o.ExpectedValue ?? 0).ToString("N0")) ج</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(o.InterestedProduct))
                                {
                                    <div class="cp-opp-product">🏷️ @o.InterestedProduct</div>
                                }
                                <div class="cp-opp-meta">
                                    <span class="cp-opp-emp">👤 @(o.EmployeeName ?? "—")</span>
                                    <span class="cp-opp-source">📡 @(o.SourceName ?? "—")</span>
                                </div>
                                <div class="cp-opp-footer">
                                    <span>📅 @o.CreatedAt.ToString("yyyy/MM/dd")</span>
                                    @if (o.NextFollowUpDate.HasValue)
                                    {
                                        <span class="cp-opp-next">🔔 @o.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cp-empty">
                    <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="MudSize.Large" /></div>
                    <h3>لا توجد فرص بعد</h3>
                    <p>ابدأ بإضافة أول فرصة لهذا العميل</p>
                    <MudButton Variant="Variant.Filled" Color="MudColor.Primary" OnClick="AddOpportunity" StartIcon="@Icons.Material.Rounded.Add">إضافة فرصة</MudButton>
                </div>
            }
        }

        @* ─── TAB: INTERACTIONS TIMELINE ─── *@
        @if (_tab == 1)
        {
            @if (_interactions.Any())
            {
                <div class="cp-timeline">
                    <div class="cp-tl-rail"></div>
                    @foreach (var i in _interactions.OrderByDescending(i => i.InteractionDate))
                    {
                        <div class="cp-tl-item">
                            <div class="cp-tl-line">
                                <div class="cp-tl-dot" style="--dot-color:#3b82f6">
                                    <MudIcon Icon="@Icons.Material.Rounded.Chat" Size="MudSize.Small" />
                                </div>
                            </div>
                            <div class="cp-tl-card">
                                <div class="cp-tl-head">
                                    <div class="cp-tl-user">
                                        <div class="cp-tl-avatar" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">@GetInitials(i.EmployeeName ?? i.CreatedBy)</div>
                                        <strong>@(i.EmployeeName ?? i.CreatedBy ?? "—")</strong>
                                    </div>
                                    <span class="cp-tl-date">@i.InteractionDate.ToString("yyyy/MM/dd hh:mm tt")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(i.Summary))
                                {
                                    <div class="cp-tl-text">@i.Summary</div>
                                }
                                <div class="cp-tl-foot">
                                    @if (i.NextFollowUpDate.HasValue)
                                    {
                                        <span class="cp-tl-follow">📅 متابعة: @i.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cp-empty">
                    <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.Forum" Size="MudSize.Large" /></div>
                    <h3>لا توجد تواصلات</h3>
                    <p>سجّل أول تفاعل مع هذا العميل</p>
                    <MudButton Variant="Variant.Filled" Color="MudColor.Info" OnClick="AddInteraction" StartIcon="@Icons.Material.Rounded.Add">إضافة تفاعل</MudButton>
                </div>
            }
        }

        @* ─── TAB: TASKS ─── *@
        @if (_tab == 2)
        {
            @if (_tasks.Any())
            {
                <div class="cp-tasks-list">
                    @foreach (var t in _tasks.OrderByDescending(t => t.DueDate))
                    {
                        var isDone = t.Status == "Completed";
                        var isOverdue = t.DueDate.Date < DateTime.Today && !isDone;
                        var priColor = t.Priority == "High" ? "#ef4444" : (t.Priority == "Medium" || t.Priority == "Normal") ? "#f59e0b" : "#22c55e";
                        <div class="cp-task-card @(isDone ? "done" : "") @(isOverdue ? "overdue" : "")" style="--pri-color:@priColor">
                            <div class="cp-task-pri" style="background:@priColor"></div>
                            <div class="cp-task-body">
                                <div class="cp-task-top">
                                    <span class="cp-task-desc">@(t.TaskDescription ?? "بدون وصف")</span>
                                    @if (!isDone)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Rounded.CheckCircleOutline" Size="MudSize.Small" Color="MudColor.Success" OnClick="@(() => CompleteTask(t.TaskId))" Tooltip="إكمال" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Style="color:#22c55e" Size="MudSize.Small" />
                                    }
                                </div>
                                <div class="cp-task-meta">
                                    <span class="cp-task-assignee">👤 @(t.AssignedToName ?? "—")</span>
                                    <span class="cp-task-due">📅 @t.DueDate.ToString("yyyy/MM/dd")</span>
                                    @if (isOverdue)
                                    { <span class="cp-task-overdue-badge">⚠️ متأخرة</span> }
                                    else if (isDone)
                                    { <span class="cp-task-done-badge">✅ مكتملة</span> }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cp-empty">
                    <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Size="MudSize.Large" /></div>
                    <h3>لا توجد مهام</h3>
                    <p>أنشئ مهمة متابعة لهذا العميل</p>
                    <MudButton Variant="Variant.Filled" Color="MudColor.Warning" OnClick="AddTask" StartIcon="@Icons.Material.Rounded.Add">إضافة مهمة</MudButton>
                </div>
            }
        }

        @* ─── TAB: FINANCIAL & INVOICES ─── *@
        @if (_tab == 3 && _canViewInvoices)
        {
            <div class="cp-financial-panel animate-card">
                <div class="cp-fin-grid">
                    <div class="cp-fin-card total-sales">
                        <div class="cp-fin-card-border"></div>
                        <div class="cp-fc-icon" style="background:rgba(16,185,129,.15);color:#10b981">
                            <MudIcon Icon="@Icons.Material.Rounded.AttachMoney" />
                        </div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_totalSales.ToString("N2") ج</span>
                            <span class="cp-fc-lbl">إجمالي مبيعات العميل</span>
                        </div>
                    </div>
                    <div class="cp-fin-card total-paid">
                        <div class="cp-fin-card-border"></div>
                        <div class="cp-fc-icon" style="background:rgba(59,130,246,.15);color:#3b82f6">
                            <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" />
                        </div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_totalPaid.ToString("N2") ج</span>
                            <span class="cp-fc-lbl">إجمالي المبالغ المسددة</span>
                        </div>
                    </div>
                    <div class="cp-fin-card total-remaining">
                        <div class="cp-fin-card-border"></div>
                        <div class="cp-fc-icon" style="background:rgba(239,68,68,.15);color:#ef4444">
                            <MudIcon Icon="@Icons.Material.Rounded.Warning" />
                        </div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_totalRemaining.ToString("N2") ج</span>
                            <span class="cp-fc-lbl">المديونية (المتبقي للتحصيل)</span>
                        </div>
                    </div>
                </div>

                <h3 class="cp-section-title">
                    <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="MudSize.Small" style="color:var(--mud-palette-primary)" />
                    سجل فواتير المبيعات
                </h3>
                @if (_invoices.Any())
                {
                    <div class="cp-invoice-list">
                        @foreach (var inv in _invoices)
                        {
                            var statusClass = inv.InvoiceStatus?.ToLower() switch
                            {
                                "paid" => "paid",
                                "partiallypaid" => "partial",
                                _ => "unpaid"
                            };

                            var statusText = inv.InvoiceStatus?.ToLower() switch
                            {
                                "paid" => "مدفوعة بالكامل",
                                "partiallypaid" => "مدفوعة جزئياً",
                                _ => "مفتوحة / غير مدفوعة"
                            };

                            <div class="cp-invoice-card" @onclick="@(() => Nav.NavigateTo($"/sales/invoices/{inv.TransactionId}"))">
                                <div class="cp-inv-head">
                                    <span class="cp-inv-num">#@inv.TransactionId</span>
                                    <span class="cp-inv-status @statusClass">@statusText</span>
                                </div>
                                <div class="cp-inv-row">
                                    <div class="cp-inv-item">
                                        <span class="lbl">إجمالي الفاتورة:</span>
                                        <span class="val font-bold">@inv.GrandTotal.ToString("N2") ج</span>
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">المسدد:</span>
                                        <span class="val text-success font-bold">@inv.PaidAmount.ToString("N2") ج</span>
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">المتبقي:</span>
                                        <span class="val text-error font-bold">@((inv.GrandTotal - inv.PaidAmount).ToString("N2")) ج</span>
                                    </div>
                                </div>
                                <div class="cp-inv-footer">
                                    <span class="cp-inv-date">📅 تاريخ الفاتورة: @inv.TransactionDate.ToString("yyyy/MM/dd")</span>
                                    @if (!string.IsNullOrWhiteSpace(inv.CreatedBy))
                                    {
                                        <span class="cp-inv-seller">👤 البائع: @inv.CreatedBy</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="cp-empty">
                        <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="MudSize.Large" /></div>
                        <h3>لا توجد فواتير بعد</h3>
                        <p>لا توجد أي فواتير مبيعات مسجلة لهذا العميل في النظام المالي.</p>
                    </div>
                }
            </div>
        }

        @* ─── TAB: QUOTATIONS ─── *@
        @if (_tab == 5 && _canViewQuotations)
        {
            <div class="cp-financial-panel animate-card">
                <div class="cp-fin-grid">
                    <div class="cp-fin-card total-quotes">
                        <div class="cp-fin-card-border"></div>
                        <div class="cp-fc-icon" style="background:rgba(124,58,237,.15);color:#7c3aed">
                            <MudIcon Icon="@Icons.Material.Rounded.Description" />
                        </div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_clientQuotations.Count</span>
                            <span class="cp-fc-lbl">إجمالي العروض المستخرجة</span>
                        </div>
                    </div>
                    <div class="cp-fin-card accepted-quotes">
                        <div class="cp-fin-card-border"></div>
                        <div class="cp-fc-icon" style="background:rgba(16,185,129,.15);color:#10b981">
                            <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" />
                        </div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_clientQuotations.Count(q => q.Status == "Accepted" || q.Status == "Converted")</span>
                            <span class="cp-fc-lbl">عروض مقبولة / مؤكدة</span>
                        </div>
                    </div>
                    <div class="cp-fin-card total-value">
                        <div class="cp-fin-card-border"></div>
                        <div class="cp-fc-icon" style="background:rgba(245,158,11,.15);color:#f59e0b">
                            <MudIcon Icon="@Icons.Material.Rounded.AttachMoney" />
                        </div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_clientQuotations.Sum(q => q.GrandTotal ?? q.TotalAmount).ToString("N0") ج</span>
                            <span class="cp-fc-lbl">إجمالي القيمة المعروضة</span>
                        </div>
                    </div>
                </div>

                <h3 class="cp-section-title">
                    <MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="MudSize.Small" style="color:var(--mud-palette-primary)" />
                    عروض الأسعار المقدمة
                </h3>
                @if (_clientQuotations.Any())
                {
                    <div class="cp-invoice-list">
                        @foreach (var q in _clientQuotations)
                        {
                            var statusClass = q.Status?.ToLower() switch
                            {
                                "accepted" => "paid",
                                "converted" => "paid",
                                "rejected" => "unpaid",
                                "expired" => "partial",
                                _ => "unpaid"
                            };

                            var statusText = q.Status switch
                            {
                                "Draft" => "مسودة",
                                "Sent" => "تم الإرسال للعميل",
                                "Accepted" => "مقبول من العميل",
                                "Rejected" => "مرفوض من العميل",
                                "Converted" => "محوّل لفاتورة",
                                "Expired" => "منتهي الصلاحية",
                                _ => q.Status
                            };

                            var qProfit = GetQuotationGrossProfit(q);
                            var qMargin = GetQuotationProfitMargin(q);
                            var marginColor = qMargin.HasValue ? (qMargin.Value >= 30 ? "#10b981" : qMargin.Value >= 15 ? "#f59e0b" : "#ef4444") : "#94a3b8";

                            <div class="cp-invoice-card" @onclick="@(() => Nav.NavigateTo($"/quotations/{q.QuotationId}"))">
                                <div class="cp-inv-head">
                                    <span class="cp-inv-num">📄 عرض رقم: @(q.ReferenceNumber ?? q.QuotationId.ToString())</span>
                                    <span class="cp-inv-status @statusClass">@statusText</span>
                                </div>
                                <div class="cp-inv-row">
                                    <div class="cp-inv-item">
                                        <span class="lbl">قيمة العرض:</span>
                                        <span class="val font-bold text-primary">@((q.GrandTotal ?? q.TotalAmount).ToString("N2")) ج</span>
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">الربح:</span>
                                        @if (qProfit.HasValue)
                                        {
                                            <span class="val font-bold" style="color:#10b981">@qProfit.Value.ToString("N2") ج</span>
                                        }
                                        else
                                        {
                                            <span class="val" style="color:var(--mud-palette-text-disabled)">غير متاح</span>
                                        }
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">نسبة الربح:</span>
                                        @if (qMargin.HasValue)
                                        {
                                            <span class="val font-bold" style="color:@marginColor">@qMargin.Value.ToString("N1")%</span>
                                        }
                                        else
                                        {
                                            <span class="val" style="color:var(--mud-palette-text-disabled)">—</span>
                                        }
                                    </div>
                                </div>
                                <div class="cp-inv-row cp-inv-row-2col">
                                    <div class="cp-inv-item">
                                        <span class="lbl">تاريخ الإصدار:</span>
                                        <span class="val">@q.QuotationDate.ToString("yyyy/MM/dd")</span>
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">صالح لغاية:</span>
                                        <span class="val @(q.ValidUntil.HasValue && q.ValidUntil.Value < DateTime.Today ? "text-error font-bold" : "")">
                                            @(q.ValidUntil.HasValue ? q.ValidUntil.Value.ToString("yyyy/MM/dd") : "—")
                                        </span>
                                    </div>
                                </div>
                                <div class="cp-inv-footer">
                                    <span>📅 أنشئ في: @q.CreatedAt.ToString("yyyy/MM/dd")</span>
                                    @if (!string.IsNullOrWhiteSpace(q.CreatedBy))
                                    {
                                        <span>👤 المسؤول: @q.CreatedBy</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="cp-empty">
                        <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="MudSize.Large" /></div>
                        <h3>لا توجد عروض أسعار</h3>
                        <p>لم يتم إنشاء أي عروض أسعار رسمية لهذا العميل من قبل.</p>
                        <MudButton Variant="Variant.Filled" Color="MudColor.Primary" OnClick="AddQuotation" StartIcon="@Icons.Material.Rounded.Add">إنشاء عرض سعر</MudButton>
                    </div>
                }
            </div>
        }

        @* ─── TAB: UNIFIED TIMELINE FEED ─── *@
        @if (_tab == 4)
        {
            <div class="cp-unified-feed animate-card">
                <h3 class="cp-section-title">
                    <MudIcon Icon="@Icons.Material.Rounded.History" Size="MudSize.Small" style="color:var(--mud-palette-primary)" />
                    سجل الأنشطة والفعاليات اللحظي الموحد
                </h3>
                @if (_activities.Any())
                {
                    <div class="cp-feed-timeline">
                        @foreach (var act in _activities)
                        {
                            var badgeClass = act.Type.ToLower();
                            <div class="cp-feed-item">
                                <div class="cp-feed-left">
                                    <div class="cp-feed-icon" style="background:@(act.Color + "15");color:@act.Color;border-color:@act.Color">
                                        <MudIcon Icon="@act.Icon" Size="MudSize.Medium" />
                                    </div>
                                    <div class="cp-feed-line" style="background: linear-gradient(180deg, @act.Color, var(--mud-palette-lines-default))"></div>
                                </div>
                                <div class="cp-feed-card" @onclick="@(() => Nav.NavigateTo(act.Link))">
                                    <div class="cp-feed-head">
                                        <span class="cp-feed-badge @badgeClass">@act.BadgeText</span>
                                        <span class="cp-feed-date">@act.Date.ToString("yyyy/MM/dd hh:mm tt")</span>
                                    </div>
                                    <div class="cp-feed-body">
                                        <h4 class="cp-feed-title">@act.Title</h4>
                                        <p class="cp-feed-desc">@act.Description</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="cp-empty">
                        <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.History" Size="MudSize.Large" /></div>
                        <h3>السجل فارغ</h3>
                        <p>لا توجد أي أنشطة أو أحداث مسجلة لهذا العميل حتى الآن.</p>
                    </div>
                }
            </div>
        }

        @* ─── TAB: COMPLAINTS ─── *@
        @if (_tab == 6 && _canViewComplaints)
        {
            <div class="cp-financial-panel animate-card">
                <h3 class="cp-section-title">
                    <MudIcon Icon="@Icons.Material.Rounded.ReportProblem" Size="MudSize.Small" style="color:var(--mud-palette-primary)" />
                    سجل الشكاوى
                </h3>
                @if (_complaints.Any())
                {
                    <div class="cp-complaint-list">
                        @foreach (var c in _complaints)
                        {
                            var (priBg, priFg) = ComplaintPriority.ToColors(c.Priority);
                            <div class="cp-complaint-card" @onclick="@(() => Nav.NavigateTo($"/complaints/{c.ComplaintId}"))">
                                <div class="cp-comp-head">
                                    <span class="cp-comp-subject">@c.Subject</span>
                                    <span class="cp-comp-status" style="background:@(ComplaintStatus.IsClosed(c.Status) ? "#10b981" : c.Status == 6 ? "#ef4444" : "#f59e0b");color:#fff">
                                        @ComplaintStatus.ToText(c.Status)
                                    </span>
                                </div>
                                <div class="cp-comp-row">
                                    <div class="cp-comp-item">
                                        <span class="lbl">النوع:</span>
                                        <span class="val">@c.ComplaintType</span>
                                    </div>
                                    <div class="cp-comp-item">
                                        <span class="lbl">الأولوية:</span>
                                        <span class="val" style="background:@priBg;color:@priFg;padding:2px 8px;border-radius:8px;font-size:.75rem;font-weight:700">
                                            @ComplaintPriority.ToText(c.Priority)
                                        </span>
                                    </div>
                                    @if (c.EmployeeName != null)
                                    {
                                        <div class="cp-comp-item">
                                            <span class="lbl">المسؤول:</span>
                                            <span class="val">@c.EmployeeName</span>
                                        </div>
                                    }
                                </div>
                                <div class="cp-comp-footer">
                                    <span class="cp-comp-date">📅 @(c.ComplaintDate?.ToString("yyyy/MM/dd"))</span>
                                    @if (c.DaysOpen.HasValue)
                                    {
                                        <span class="cp-comp-days">⏱️ @c.DaysOpen يوم</span>
                                    }
                                    @if (c.Escalated == true)
                                    {
                                        <span class="cp-comp-escalated">⚠️ مصعدة</span>
                                    }
                                    @if (c.FollowUpsCount > 0)
                                    {
                                        <span class="cp-comp-followups">💬 @c.FollowUpsCount متابعة</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="cp-empty">
                        <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.ReportProblem" Size="MudSize.Large" /></div>
                        <h3>لا توجد شكاوى</h3>
                        <p>لا توجد شكاوى مسجلة لهذا العميل في النظام.</p>
                    </div>
                }
            </div>
        }

        @* ─── FAB BUTTON ─── *@
        <button class="cp-fab" @onclick="AddInteraction" title="إضافة تفاعل">
            <MudIcon Icon="@Icons.Material.Rounded.AddComment" />
        </button>

    </div>
}
else
{
    @* ════════════════════════════════════════════════════════ *@
    @* ═══ MODE: SEARCH — PREMIUM 2026 ═══ *@
    @* ════════════════════════════════════════════════════════ *@
    <div dir="rtl" class="cs-page animate-card">

        @* SEARCH HEADER (Wide & Immersive) *@
        <div class="cs-header">
            <div class="cs-header-bg">
                <div class="cs-grad"></div>
                <div class="cs-orb cs-orb-1"></div>
                <div class="cs-orb cs-orb-2"></div>
                <div class="cs-orb cs-orb-3"></div>
                <div class="cs-pattern"></div>
            </div>
            <div class="cs-header-content">
                <div class="cs-header-icon">
                    <MudIcon Icon="@Icons.Material.Rounded.PersonSearch" Size="MudSize.Large" />
                    <div class="cs-icon-ring"></div>
                    <div class="cs-icon-ring ring-2"></div>
                </div>
                <h1>مركز بحث ومتابعة العملاء</h1>
                <p>ابحث عن أي عميل بالاسم أو رقم التليفون للوصول الفوري لملفه وبطاقته البيعية والمالية</p>
            </div>
        </div>

        @* SEARCH BOX *@
        <div class="cs-search-wrap">
            <div class="cs-search-input-group">
                <span class="cs-search-icon">🔍</span>
                <input type="search" dir="rtl"
                       class="cs-search-input-field"
                       placeholder="اكتب اسم العميل أو رقم التليفون هنا للبحث الفوري..."
                       @bind="_searchQuery"
                       @bind:event="oninput"
                       @onkeyup="OnSearchKeyV1" />
                @if (_searching)
                {
                    <div class="cs-search-spinner-inline"></div>
                }
            </div>
            @if (_searching)
            {
                <div class="cs-loading">
                    <div class="cs-search-spinner-simple"></div>
                    <span>جاري البحث عن العميل...</span>
                </div>
            }
        </div>

        @* RESULTS COUNT *@
        @if (!_searching && _searchResults.Any())
        {
            <div class="cs-count">🎯 تم العثور على <strong>@_searchResults.Count</strong> عميل في قاعدة البيانات</div>
        }

        @* RESULTS (Premium Responsive Grid) *@
        <div class="cs-results">
            @foreach (var c in _searchResults)
            {
                <div class="cs-card animate-card" style="--delay: 0.05s">
                    <div class="cs-card-top-accent"></div>
                    <div class="cs-card-main-row" @onclick="@(() => GoToCustomer(c.PartyId))">
                        <div class="cs-card-avatar">
                            <span>@GetInitials(c.PartyName)</span>
                        </div>
                        <div class="cs-card-info">
                            <span class="cs-card-name">@c.PartyName</span>
                            @if (!string.IsNullOrWhiteSpace(c.City))
                            {
                                <span class="cs-card-city">📍 @c.City</span>
                            }
                        </div>
                    </div>

                    <div class="cs-card-footer">
                        @if (!string.IsNullOrWhiteSpace(c.Phone))
                        {
                            <span class="cs-card-phone font-bold">📞 @c.Phone</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.CustomerStage))
                        {
                            <span class="cs-stage">🏷️ @c.CustomerStage</span>
                        }
                    </div>

                    @* Premium Card Quick Actions *@
                    <div class="cs-card-actions">
                        @if (!string.IsNullOrWhiteSpace(c.Phone))
                        {
                            <button class="cs-card-act-btn wa" @onclick="@(() => WA(c.Phone))" title="شات واتساب سريع">
                                <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Size="MudSize.Small" />
                                <span>واتساب</span>
                            </button>
                            <button class="cs-card-act-btn call" @onclick="@(() => Call(c.Phone))" title="اتصال هاتفي">
                                <MudIcon Icon="@Icons.Material.Rounded.Phone" Size="MudSize.Small" />
                                <span>اتصال</span>
                            </button>
                        }
                        <button class="cs-card-act-btn profile" @onclick="@(() => GoToCustomer(c.PartyId))" title="فتح الملف">
                            <MudIcon Icon="@Icons.Material.Rounded.AccountBox" Size="MudSize.Small" />
                            <span>الملف</span>
                        </button>
                    </div>
                </div>
            }
        </div>

        @* EMPTY STATES *@
        @if (!_searching && !string.IsNullOrWhiteSpace(_searchQuery) && _searchQuery.Length >= 2 && !_searchResults.Any())
        {
            <div class="cs-empty animate-card">
                <div class="cs-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.SearchOff" Size="MudSize.Large" /></div>
                <h3>لا توجد نتائج مطابقة</h3>
                <p>لم نعثر على عميل بهذا الاسم أو الرقم، تأكد من صحة الحروف أو جرب رقم هاتف آخر.</p>
            </div>
        }
        else if (string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Length < 2)
        {
            <div class="cs-empty animate-card">
                <div class="cs-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.PersonSearch" Size="MudSize.Large" /></div>
                <h3>أدخل بيانات البحث لبدء المتابعة</h3>
                <p>اكتب حرفين أو أكثر من اسم العميل أو رقم هاتفه لعرض سجله البيعي فوراً.</p>
            </div>
        }
    </div>
}

<style>
    :root {
        --cp-max: 1140px;
        --cp-radius: 24px;
        --cp-radius-sm: 14px;
        --cp-radius-xs: 8px;
        --cp-hero-h: auto;
        --cp-gradient-1: #5b21b6;
        --cp-gradient-2: #6d28d9;
        --cp-gradient-3: #7c3aed;
        --cp-gradient-4: #8b5cf6;
        --cp-gradient-5: #a78bfa;
    }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ LOADING — PREMIUM ═══ */
    /* ═══════════════════════════════════════════════════ */
    .loading-screen { display: flex; align-items: center; justify-content: center; min-height: 85vh; }
    .loading-content { display: flex; flex-direction: column; align-items: center; text-align: center; }
    .loading-logo { position: relative; width: 76px; height: 76px; display: flex; align-items: center; justify-content: center; color: var(--mud-palette-secondary); }
    .loading-ring { position: absolute; inset: -10px; border: 3px solid transparent; border-top-color: var(--mud-palette-secondary); border-radius: 50%; animation: cp-spin 1.2s linear infinite; }
    .loading-ring.ring-2 { inset: -20px; border-top-color: var(--mud-palette-primary); animation-duration: 1.8s; animation-direction: reverse; }
    .loading-ring.ring-3 { inset: -30px; border-top-color: #a78bfa; animation-duration: 2.4s; animation-direction: reverse; }
    @@keyframes cp-spin { to { transform: rotate(360deg); } }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ PROFILE PAGE ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-page { padding: 0 1.5rem 4rem; max-width: var(--cp-max); margin: 0 auto; font-size: .9rem; line-height: 1.6; }

    /* ── Search Overlay ── */
    .cp-search-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); backdrop-filter: blur(8px); z-index: 9999; display: flex; justify-content: center; padding-top: 90px; animation: cp-fadeIn .2s; }
    @@keyframes cp-fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .cp-search-box { width: 95%; max-width: 620px; background: var(--mud-palette-surface); border-radius: 20px; box-shadow: 0 25px 70px rgba(0,0,0,.25); overflow: hidden; max-height: 72vh; display: flex; flex-direction: column; animation: cp-slideUp .3s cubic-bezier(.4,0,.2,1); }
    @@keyframes cp-slideUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
    .cp-search-header { display: flex; align-items: center; gap: .75rem; padding: 1.1rem 1.5rem; border-bottom: 1px solid var(--mud-palette-lines-default); }
    .cp-search-input { flex: 1; border: none; outline: none; font-size: 1rem; background: transparent; color: var(--mud-palette-text-primary); font-family: inherit; }
    .cp-search-input::placeholder { color: var(--mud-palette-text-disabled); }
    .cp-search-spinner { width: 22px; height: 22px; border: 2.5px solid var(--mud-palette-lines-default); border-top-color: var(--mud-palette-primary); border-radius: 50%; animation: cp-spin .8s linear infinite; flex-shrink: 0; }
    .cp-search-close { width: 34px; height: 34px; border-radius: 10px; border: 1px solid var(--mud-palette-lines-default); background: transparent; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--mud-palette-text-secondary); transition: all .2s; }
    .cp-search-close:hover { background: var(--mud-palette-action-hover); transform: scale(.92); }
    .cp-search-close:active { transform: scale(.88); }
    .cp-search-results { overflow-y: auto; max-height: 56vh; }
    .cp-search-item { display: flex; align-items: center; gap: .85rem; padding: .85rem 1.5rem; cursor: pointer; transition: background .15s; border-bottom: 1px solid var(--mud-palette-lines-inputs); }
    .cp-search-item:hover { background: var(--mud-palette-action-hover); }
    .cp-search-item.current { background: rgba(124,58,237,.06); border-right: 3px solid #7c3aed; }
    .cp-si-avatar { width: 40px; height: 40px; border-radius: 12px; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: .82rem; flex-shrink: 0; }
    .cp-si-info { flex: 1; min-width: 0; }
    .cp-si-name { display: block; font-weight: 700; font-size: .9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cp-si-meta { display: flex; gap: .5rem; font-size: .74rem; color: var(--mud-palette-text-secondary); }
    .cp-si-badge { font-size: .66rem; font-weight: 700; padding: 3px 9px; border-radius: 6px; background: rgba(124,58,237,.1); color: #7c3aed; }
    .cp-search-empty { padding: 2.5rem; text-align: center; color: var(--mud-palette-text-disabled); font-size: .88rem; }
    .cp-search-hint { padding: 2rem; text-align: center; color: var(--mud-palette-text-disabled); font-size: .82rem; }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ HERO — Mesh Gradient + Animated Avatar ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-hero { position: relative; border-radius: var(--cp-radius); overflow: hidden; margin-bottom: 1rem; box-shadow: 0 16px 50px rgba(124,58,237,.25), 0 0 0 1px rgba(255,255,255,.08) inset; }
    .cp-hero-bg { position: absolute; inset: 0; }
    .cp-hero-grad { position: absolute; inset: 0; background: linear-gradient(135deg, var(--cp-gradient-1) 0%, var(--cp-gradient-2) 25%, var(--cp-gradient-3) 50%, var(--cp-gradient-4) 75%, var(--cp-gradient-5) 100%); }
    .cp-hero-pattern { position: absolute; inset: 0; opacity: .04; background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,.5) 1px, transparent 0); background-size: 28px 28px; }
    .cp-hero-orb { position: absolute; border-radius: 50%; filter: blur(80px); animation: cp-orb-float 12s ease-in-out infinite; }
    .orb-1 { width: 300px; height: 300px; background: rgba(196,181,253,.18); top: -100px; right: -60px; }
    .orb-2 { width: 220px; height: 220px; background: rgba(167,139,250,.14); bottom: -60px; left: 8%; animation-delay: -4s; }
    .orb-3 { width: 180px; height: 180px; background: rgba(251,191,36,.1); top: 20%; left: 50%; animation-delay: -7s; }
    .orb-4 { width: 140px; height: 140px; background: rgba(52,211,153,.1); bottom: 10%; right: 30%; animation-delay: -2s; }
    @@keyframes cp-orb-float {
        0%, 100% { transform: translate(0,0) scale(1); }
        25% { transform: translate(15px,-12px) scale(1.08); }
        50% { transform: translate(-8px, 18px) scale(1.04); }
        75% { transform: translate(12px, 6px) scale(1.1); }
    }
    .cp-hero-content { position: relative; z-index: 2; padding: 1.75rem 2rem 0; color: #fff; }
    .cp-hero-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .cp-back-btn { display: inline-flex; align-items: center; gap: 7px; padding: 8px 16px; background: rgba(255,255,255,.1); backdrop-filter: blur(14px); border: 1px solid rgba(255,255,255,.15); border-radius: 12px; color: #fff; font-size: .84rem; font-weight: 600; cursor: pointer; transition: all .25s; font-family: inherit; }
    .cp-back-btn:hover { background: rgba(255,255,255,.2); transform: translateY(-1px); }
    .cp-back-btn:active { transform: scale(.95); }
    .cp-hero-actions { display: flex; align-items: center; gap: .4rem; }
    .cp-action-btn { display: inline-flex; align-items: center; gap: 5px; padding: 8px 14px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.12); border-radius: 10px; color: rgba(255,255,255,.8); font-size: .78rem; font-weight: 600; cursor: pointer; transition: all .25s; font-family: inherit; backdrop-filter: blur(8px); }
    .cp-action-btn:hover { background: rgba(255,255,255,.2); color: #fff; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,0,0,.15); }
    .cp-action-btn:active { transform: scale(.95); }
    .cp-action-btn.edit { background: rgba(255,255,255,.16); border-color: rgba(255,255,255,.22); }
    .cp-action-btn.wa-btn { background: rgba(37,211,102,.16); border-color: rgba(37,211,102,.3); color: #25d366; }
    .cp-action-btn.wa-btn:hover { background: #25d366; color: #fff; box-shadow: 0 4px 18px rgba(37,211,102,.35); }

    /* Avatar with Conic Ring + Pulse Dot */
    .cp-hero-profile { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.75rem; flex-wrap: wrap; }
    .cp-avatar-wrap { position: relative; width: 80px; height: 80px; flex-shrink: 0; }
    .cp-avatar-conic-ring { position: absolute; inset: -6px; border-radius: 24px; background: conic-gradient(from 0deg, #a78bfa, #7c3aed, #f59e0b, #10b981, #3b82f6, #a78bfa); animation: cp-conic-spin 6s linear infinite; opacity: .7; }
    @@keyframes cp-conic-spin { to { transform: rotate(360deg); } }
    .cp-avatar { position: relative; width: 80px; height: 80px; background: rgba(255,255,255,.12); backdrop-filter: blur(14px); border-radius: 20px; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.7rem; z-index: 1; border: 2px solid rgba(255,255,255,.15); }
    .cp-avatar-pulse { position: absolute; bottom: -2px; left: -2px; width: 18px; height: 18px; background: #34d399; border-radius: 50%; border: 3px solid var(--cp-gradient-2); z-index: 2; animation: cp-pulse-dot 2s ease-in-out infinite; box-shadow: 0 0 8px #34d399; }
    @@keyframes cp-pulse-dot { 0%, 100% { transform: scale(1); box-shadow: 0 0 8px #34d399; } 50% { transform: scale(1.2); box-shadow: 0 0 16px #34d399; } }

    .cp-hero-info h1 { margin: 0; font-size: 1.65rem; font-weight: 900; line-height: 1.2; letter-spacing: -.3px; }
    .cp-hero-meta { display: flex; gap: .85rem; flex-wrap: wrap; font-size: .84rem; margin-top: .4rem; opacity: .92; }
    .cp-meta-link { display: inline-flex; align-items: center; gap: 5px; color: rgba(255,255,255,.9); text-decoration: none; cursor: pointer; transition: all .2s; padding: 3px 8px; border-radius: 6px; }
    .cp-meta-link:hover { background: rgba(255,255,255,.12); color: #fff; }
    .cp-meta-link:active { transform: scale(.95); }
    .cp-copy-icon { opacity: 0; transition: opacity .2s; font-size: 14px !important; }
    .cp-meta-link:hover .cp-copy-icon { opacity: .7; }
    .cp-meta-item { display: inline-flex; align-items: center; gap: 4px; }
    .cp-stage-badge { display: inline-flex; align-items: center; gap: 7px; margin-top: .5rem; padding: 5px 14px; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15); border-radius: 10px; font-size: .78rem; font-weight: 600; backdrop-filter: blur(8px); }
    .cp-stage-dot { width: 9px; height: 9px; border-radius: 50%; background: #34d399; box-shadow: 0 0 10px #34d399; animation: cp-blink 2s infinite; }
    @@keyframes cp-blink { 0%, 100% { opacity: 1; } 50% { opacity: .3; } }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ STATS ROW — Enhanced Visual Weight ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-hero-stats { display: grid; grid-template-columns: repeat(7,1fr); gap: 0; border-top: 1px solid rgba(255,255,255,.08); margin-top: -.25rem; }
    .cp-stat { display: flex; align-items: center; gap: .7rem; padding: .9rem .85rem; cursor: pointer; transition: all .25s; position: relative; }
    .cp-stat:hover { background: rgba(255,255,255,.08); transform: translateY(-2px); }
    .cp-stat:active { transform: scale(.97); }
    .cp-stat-accent { position: absolute; top: 0; right: 0; width: 3px; height: 100%; background: var(--stat-color); border-radius: 0 0 3px 0; opacity: 0; transition: opacity .25s; }
    .cp-stat:hover .cp-stat-accent { opacity: 1; }
    .cp-stat-icon { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform .25s; }
    .cp-stat:hover .cp-stat-icon { transform: scale(1.1); }
    .cp-stat-data { display: flex; flex-direction: column; }
    .cp-stat-val { font-size: 1.15rem; font-weight: 900; line-height: 1; }
    .cp-stat-currency { font-size: .75rem; font-weight: 700; opacity: .7; margin-left: 2px; }
    .cp-stat-lbl { font-size: .66rem; opacity: .65; margin-top: 3px; font-weight: 500; }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ QUICK ADD BAR ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-quick-add { display: flex; align-items: center; gap: .5rem; margin-bottom: 1rem; flex-wrap: wrap; }
    .cp-qa-label { font-size: .84rem; font-weight: 700; color: var(--mud-palette-text-secondary); display: inline-flex; align-items: center; gap: 4px; }
    .cp-qa-btn { display: inline-flex; align-items: center; gap: 5px; padding: 7px 16px; background: rgba(99,102,241,.08); color: #6366f1; border: 1px solid rgba(99,102,241,.15); border-radius: var(--cp-radius-xs); font-size: .82rem; font-weight: 600; cursor: pointer; transition: all .25s; font-family: inherit; }
    .cp-qa-btn:hover { background: rgba(99,102,241,.15); transform: translateY(-2px); box-shadow: 0 4px 12px rgba(99,102,241,.12); }
    .cp-qa-btn:active { transform: scale(.95); }
    .cp-qa-btn.info { background: rgba(59,130,246,.08); color: #3b82f6; border-color: rgba(59,130,246,.15); }
    .cp-qa-btn.info:hover { background: rgba(59,130,246,.15); box-shadow: 0 4px 12px rgba(59,130,246,.12); }
    .cp-qa-btn.warn { background: rgba(245,158,11,.08); color: #f59e0b; border-color: rgba(245,158,11,.15); }
    .cp-qa-btn.warn:hover { background: rgba(245,158,11,.15); box-shadow: 0 4px 12px rgba(245,158,11,.12); }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ PREMIUM PILL TABS ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-tabs-container { position: relative; margin-bottom: 1.25rem; }
    .cp-tabs { display: flex; gap: 4px; background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default); border-radius: 14px; padding: 5px; overflow-x: auto; position: relative; }
    .cp-tab { display: flex; align-items: center; gap: 7px; padding: 10px 18px; border: none; background: transparent; border-radius: 10px; font-size: .87rem; font-weight: 600; cursor: pointer; color: var(--mud-palette-text-secondary); transition: all .25s; font-family: inherit; flex: 1; justify-content: center; white-space: nowrap; position: relative; z-index: 1; }
    .cp-tab:hover { color: var(--mud-palette-text-primary); background: var(--mud-palette-action-hover); }
    .cp-tab:active { transform: scale(.95); }
    .cp-tab.active { background: linear-gradient(135deg, var(--cp-gradient-2), var(--cp-gradient-4)); color: #fff; box-shadow: 0 4px 14px rgba(124,58,237,.3); }
    .cp-tab-count { font-size: .66rem; font-weight: 700; padding: 2px 8px; border-radius: 10px; background: rgba(0,0,0,.06); }
    .cp-tab.active .cp-tab-count { background: rgba(255,255,255,.2); color: #fff; }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ PIPELINE BAR ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-pipeline-bar { display: flex; height: 10px; border-radius: 5px; overflow: hidden; margin-bottom: 1.1rem; background: var(--mud-palette-lines-default); box-shadow: inset 0 1px 3px rgba(0,0,0,.06); }
    .cp-pipeline-seg { position: relative; transition: flex .6s cubic-bezier(.4,0,.2,1); min-width: 3px; }
    .cp-pipeline-seg:hover { opacity: .85; filter: brightness(1.1); }
    .cp-pipeline-label { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: .55rem; color: #fff; font-weight: 700; }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ OPP CARDS — Glassmorphism + Stagger ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-opp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px,1fr)); gap: 1rem; }
    .cp-opp-card { position: relative; background: var(--mud-palette-surface); border: 1.5px solid var(--mud-palette-lines-default); border-radius: 18px; overflow: hidden; cursor: pointer; transition: all .35s cubic-bezier(.4,0,.2,1); display: flex; box-shadow: 0 4px 14px rgba(0,0,0,.02); animation: cp-fadeSlideIn .5s ease-out backwards; }
    .cp-opp-card:hover { box-shadow: 0 16px 40px rgba(124,58,237,.14), 0 0 0 1px var(--opp-color) inset; transform: translateY(-5px); border-color: var(--opp-color); background: color-mix(in srgb, var(--opp-color) 4%, var(--mud-palette-surface)); backdrop-filter: blur(12px); }
    .cp-opp-card:active { transform: scale(.97); }
    .cp-opp-color { width: 6px; flex-shrink: 0; }
    .cp-opp-tint { position: absolute; top: 0; right: 0; width: 80px; height: 80px; opacity: .06; border-radius: 0 0 0 100%; pointer-events: none; }
    .cp-opp-body { flex: 1; padding: 1.3rem; display: flex; flex-direction: column; gap: 8px; }
    .cp-opp-head { display: flex; justify-content: space-between; align-items: center; }
    .cp-opp-stage { font-size: .78rem; font-weight: 800; padding: 4px 14px; border-radius: 10px; }
    .cp-opp-value { font-size: 1.1rem; font-weight: 900; color: var(--mud-palette-text-primary); }
    .cp-opp-product { font-size: .92rem; color: var(--mud-palette-primary); font-weight: 700; }
    .cp-opp-meta { display: flex; gap: .85rem; font-size: .88rem; color: var(--mud-palette-text-secondary); margin-top: 2px; align-items: center; }
    .cp-opp-emp { font-weight: 800; color: var(--mud-palette-text-primary); font-size: .92rem; background: rgba(124,58,237,.06); padding: 3px 10px; border-radius: 8px; display: inline-flex; align-items: center; gap: 4px; }
    .cp-opp-source { font-weight: 600; color: var(--mud-palette-text-secondary); }
    .cp-opp-footer { display: flex; justify-content: space-between; font-size: .76rem; color: var(--mud-palette-text-secondary); padding-top: .65rem; border-top: 1px dashed var(--mud-palette-lines-default); margin-top: 6px; }
    .cp-opp-next { color: var(--mud-palette-primary); font-weight: 700; }
    @@keyframes cp-fadeSlideIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ INTERACTIONS TIMELINE — Color-Coded ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-timeline { position: relative; padding-right: 28px; }
    .cp-tl-rail { position: absolute; right: 17px; top: 0; bottom: 0; width: 3px; background: linear-gradient(180deg, #7c3aed, #3b82f6, #10b981, var(--mud-palette-lines-default)); border-radius: 2px; opacity: .4; }
    .cp-tl-item { display: flex; gap: 1.1rem; padding: .6rem 0; position: relative; animation: cp-fadeSlideIn .4s ease-out backwards; }
    .cp-tl-line { display: flex; flex-direction: column; align-items: center; width: 36px; flex-shrink: 0; }
    .cp-tl-dot { width: 36px; height: 36px; border-radius: 50%; background: var(--mud-palette-surface); border: 3px solid var(--dot-color, var(--mud-palette-lines-default)); display: flex; align-items: center; justify-content: center; z-index: 1; box-shadow: 0 3px 10px rgba(0,0,0,.05); color: var(--dot-color, var(--mud-palette-text-secondary)); transition: transform .2s; }
    .cp-tl-item:hover .cp-tl-dot { transform: scale(1.12); }
    .cp-tl-card { flex: 1; background: var(--mud-palette-surface); border: 1.5px solid var(--mud-palette-lines-default); border-radius: 16px; padding: 1.3rem; transition: all .25s; box-shadow: 0 4px 16px rgba(0,0,0,.02); }
    .cp-tl-card:hover { box-shadow: 0 8px 24px rgba(124,58,237,.1); border-color: var(--mud-palette-primary); transform: translateX(-3px); }
    .cp-tl-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: .65rem; flex-wrap: wrap; gap: 6px; }
    .cp-tl-user { display: flex; align-items: center; gap: .65rem; }
    .cp-tl-avatar { width: 32px; height: 32px; border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; font-size: .72rem; font-weight: 700; box-shadow: 0 2px 6px rgba(99,102,241,.2); }
    .cp-tl-date { font-size: .78rem; color: var(--mud-palette-text-secondary); font-weight: 600; }
    .cp-tl-text { font-size: .92rem; line-height: 1.75; color: var(--mud-palette-text-primary); font-weight: 500; margin-bottom: .45rem; word-break: break-word; }
    .cp-tl-foot { display: flex; align-items: center; gap: .5rem; }
    .cp-tl-follow { font-size: .82rem; color: var(--mud-palette-primary); font-weight: 700; }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ TASKS — Priority Visual ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-tasks-list { display: flex; flex-direction: column; gap: .65rem; }
    .cp-task-card { display: flex; gap: 0; background: var(--mud-palette-surface); border: 1.5px solid var(--mud-palette-lines-default); border-radius: 16px; overflow: hidden; transition: all .25s; box-shadow: 0 4px 14px rgba(0,0,0,.02); animation: cp-fadeSlideIn .4s ease-out backwards; }
    .cp-task-card:hover { box-shadow: 0 8px 22px rgba(124,58,237,.08); border-color: var(--pri-color); transform: translateY(-2px); }
    .cp-task-card:active { transform: scale(.98); }
    .cp-task-pri { width: 6px; flex-shrink: 0; }
    .cp-task-body { flex: 1; padding: 1.05rem 1.3rem; display: flex; flex-direction: column; gap: 7px; }
    .cp-task-top { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .cp-task-desc { font-weight: 800; font-size: 1.05rem; color: var(--mud-palette-text-primary); line-height: 1.5; }
    .cp-task-meta { display: flex; gap: .85rem; font-size: .88rem; color: var(--mud-palette-text-secondary); flex-wrap: wrap; align-items: center; }
    .cp-task-assignee { font-weight: 800; color: var(--mud-palette-text-primary); background: rgba(124,58,237,.06); padding: 3px 10px; border-radius: 8px; display: inline-flex; align-items: center; gap: 4px; }
    .cp-task-due { font-weight: 600; }
    .cp-task-overdue-badge { color: #ef4444; font-weight: 800; background: rgba(239,68,68,.08); padding: 3px 10px; border-radius: 8px; display: inline-flex; align-items: center; gap: 4px; }
    .cp-task-done-badge { color: #22c55e; font-weight: 700; background: rgba(34,197,94,.08); padding: 3px 10px; border-radius: 8px; display: inline-flex; align-items: center; gap: 4px; }
    .cp-task-card.done { opacity: .55; }
    .cp-task-card.done .cp-task-desc { text-decoration: line-through; text-decoration-thickness: 2px; }
    .cp-task-card.overdue { border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.02); box-shadow: 0 0 20px rgba(239,68,68,.1), 0 0 40px rgba(239,68,68,.05); animation: cp-red-glow 2s ease-in-out infinite; }
    @@keyframes cp-red-glow {
        0%, 100% { box-shadow: 0 0 20px rgba(239,68,68,.1), 0 0 40px rgba(239,68,68,.05); }
        50% { box-shadow: 0 0 25px rgba(239,68,68,.2), 0 0 50px rgba(239,68,68,.08); }
    }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ EMPTY STATE ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-empty { text-align: center; padding: 4.5rem 2rem; color: var(--mud-palette-text-disabled); animation: cp-fadeSlideIn .5s ease-out; }
    .cp-empty-icon { width: 76px; height: 76px; border-radius: 50%; background: var(--mud-palette-action-hover); display: flex; align-items: center; justify-content: center; margin: 0 auto .9rem; color: var(--mud-palette-text-disabled); }
    .cp-empty h3 { margin: .35rem 0 .25rem; color: var(--mud-palette-text-secondary); font-size: 1.12rem; font-weight: 700; }
    .cp-empty p { font-size: .88rem; margin-bottom: 1.1rem; }

    /* ═══════════════════════════════════════════════════ */
    /* ═══ FINANCIAL, QUOTATIONS & TIMELINE ═══ */
    /* ═══════════════════════════════════════════════════ */
    .cp-section-title { font-size: 1.1rem; font-weight: 800; margin: 1.5rem 0 .85rem; color: var(--mud-palette-text-primary); display: flex; align-items: center; gap: 8px; }
    .font-bold { font-weight: 700; }

