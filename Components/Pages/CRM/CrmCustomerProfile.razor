    private async Task CompleteTask(int taskId)
    {
        var (success, msg) = await TaskService.CompleteAsync(taskId, "تم الإكمال من صفحة العميل", _currentUser ?? "System");
        if (success)
        {
            Snackbar.Add("تم إكمال المهمة ✓", Severity.Success);
            var taskFilter = new TaskFilterDto { PageSize = 200 };
            var taskResult = await TaskService.GetTasksAsync(taskFilter);
            _tasks = taskResult.Items.Where(t => t.PartyId == PartyId).ToList();
            _activeTaskCount = _tasks.Count(t => t.Status != "Completed" && t.Status != "Cancelled");
            StateHasChanged();
        }
        else Snackbar.Add(msg, Severity.Error);
    }
