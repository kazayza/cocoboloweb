@page "/crm/customers"
@page "/crm/customers/{PartyId:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using Microsoft.EntityFrameworkCore
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@inject IDbContextFactory<db24804Context> DbFactory
@inject IOpportunityService OppService
@inject IInteractionService InteractionService
@inject ITaskService TaskService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider

<PageTitle>@(PartyId.HasValue ? "بطاقة العميل" : "بحث العملاء") — CRM</PageTitle>

@if (_loading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-logo">
                <MudIcon Icon="@(PartyId.HasValue ? Icons.Material.Rounded.Person : Icons.Material.Rounded.Search)" Size="MudSize.Large" />
                <div class="loading-ring"></div>
                <div class="loading-ring ring-2"></div>
            </div>
            <MudText Typo="Typo.h6" Style="font-weight:700;margin-top:1rem">جاري التحميل...</MudText>
            <MudProgressLinear Color="MudColor.Secondary" Indeterminate="true" Class="mt-3" Style="max-width:250px;border-radius:8px" />
        </div>
    </div>
}
else if (PartyId.HasValue && PartyId.Value > 0 && _party != null)
{
    @* ════════════════════════════════════════════════════════ *@
    @* ═══ MODE: CUSTOMER PROFILE ═══ *@
    @* ════════════════════════════════════════════════════════ *@
    <div dir="rtl" class="cp-page">

        @* SEARCH OVERLAY *@
        @if (_showSearch)
        {
            <div class="cp-search-overlay" @onclick="ToggleSearch">
                <div class="cp-search-box" @onclick:stopPropagation>
                    <div class="cp-search-header">
                        <MudIcon Icon="@Icons.Material.Rounded.Search" Style="color:var(--mud-palette-primary)" />
                        <input type="text" class="cp-search-input" placeholder="ابحث بالاسم أو رقم التليفون..."
                               @bind="_searchQuery" @bind:event="oninput" @onkeyup="OnSearchKey" />
                        @if (_searching)
                        { <div class="cp-search-spinner"></div> }
                        <button class="cp-search-close" @onclick="ToggleSearch">
                            <MudIcon Icon="@Icons.Material.Rounded.Close" Size="MudSize.Small" />
                        </button>
                    </div>
                    @if (_searchResults.Any())
                    {
                        <div class="cp-search-results">
                            @foreach (var c in _searchResults)
                            {
                                <div class="cp-search-item @(c.PartyId == PartyId ? "current" : "")"
                                     @onclick="@(() => GoToCustomer(c.PartyId))">
                                    <div class="cp-si-avatar" style="background:linear-gradient(135deg,#6d28d9,#8b5cf6)">
                                        @GetInitials(c.PartyName)
                                    </div>
                                    <div class="cp-si-info">
                                        <span class="cp-si-name">@c.PartyName</span>
                                        <span class="cp-si-meta">
                                            @if (!string.IsNullOrWhiteSpace(c.Phone))
                                            { <span>📞 @c.Phone</span> }
                                            @if (!string.IsNullOrWhiteSpace(c.City))
                                            { <span>📍 @c.City</span> }
                                        </span>
                                    </div>
                                    @if (c.PartyId == PartyId)
                                    { <span class="cp-si-badge">الحالي</span> }
                                </div>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_searchQuery) && _searchQuery.Length >= 2 && !_searching)
                    {
                        <div class="cp-search-empty">لا توجد نتائج</div>
                    }
                    else
                    {
                        <div class="cp-search-hint">اكتب اسم العميل أو رقم التليفون (حرفين على الأقل)</div>
                    }
                </div>
            </div>
        }

        @* HERO HEADER *@
        <div class="cp-hero">
            <div class="cp-hero-bg">
                <div class="cp-hero-grad"></div>
                <div class="cp-hero-pattern"></div>
                <div class="cp-hero-orb orb-1"></div>
                <div class="cp-hero-orb orb-2"></div>
            </div>
            <div class="cp-hero-content">
                <div class="cp-hero-top">
                    <button class="cp-back-btn" @onclick="GoBack">
                        <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="MudSize.Small" />
                        <span>العودة</span>
                    </button>
                    <div class="cp-hero-actions">
                        <button class="cp-action-btn" @onclick="ToggleSearch" title="بحث سريع">
                            <MudIcon Icon="@Icons.Material.Rounded.Search" Size="MudSize.Small" />
                        </button>
                        @if (!string.IsNullOrWhiteSpace(_party.Phone))
                        {
                            <button class="cp-action-btn" @onclick="@(() => Call(_party.Phone))" title="اتصال">
                                <MudIcon Icon="@Icons.Material.Rounded.Phone" Size="MudSize.Small" />
                            </button>
                            <button class="cp-action-btn wa-btn" @onclick="@(() => WA(_party.Phone))" title="واتساب سريع">
                                <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Size="MudSize.Small" />
                            </button>
                        }
                        @if (!string.IsNullOrWhiteSpace(_party.Email))
                        {
                            <button class="cp-action-btn" @onclick="@(() => Email(_party.Email))" title="إرسال إيميل">
                                <MudIcon Icon="@Icons.Material.Rounded.Email" Size="MudSize.Small" />
                            </button>
                        }
                        <button class="cp-action-btn edit" @onclick="EditCustomer">
                            <MudIcon Icon="@Icons.Material.Rounded.Edit" Size="MudSize.Small" />
                            <span>تعديل</span>
                        </button>
                    </div>
                </div>

                <div class="cp-hero-profile">
                    <div class="cp-avatar">
                        <span>@GetInitials(_party.PartyName)</span>
                        <div class="cp-avatar-ring"></div>
                    </div>
                    <div class="cp-hero-info">
                        <h1>@_party.PartyName</h1>
                        <div class="cp-hero-meta">
                            @if (!string.IsNullOrWhiteSpace(_party.Phone))
                            { <span class="cp-meta-item">📞 @_party.Phone</span> }
                            @if (!string.IsNullOrWhiteSpace(_party.Email))
                            { <span class="cp-meta-item">📧 @_party.Email</span> }
                            @if (!string.IsNullOrWhiteSpace(_party.City))
                            { <span class="cp-meta-item">📍 @_party.City</span> }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_party.CustomerStage))
                        {
                            <div class="cp-stage-badge">
                                <span class="cp-stage-dot"></span>
                                <span>@_party.CustomerStage</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="cp-hero-stats">
                    <div class="cp-stat" @onclick="@(() => _tab = 0)">
                        <div class="cp-stat-icon" style="background:rgba(99,102,241,.15);color:#818cf8">
                            <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="MudSize.Small" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_opportunities.Count</span>
                            <span class="cp-stat-lbl">فرصة</span>
                        </div>
                    </div>
                    <div class="cp-stat" @onclick="@(() => _tab = 0)">
                        <div class="cp-stat-icon" style="background:rgba(34,197,94,.15);color:#22c55e">
                            <MudIcon Icon="@Icons.Material.Rounded.EmojiEvents" Size="MudSize.Small" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_wonCount</span>
                            <span class="cp-stat-lbl">مربوحة</span>
                        </div>
                    </div>
                    <div class="cp-stat">
                        <div class="cp-stat-icon" style="background:rgba(245,158,11,.15);color:#f59e0b">
                            <MudIcon Icon="@Icons.Material.Rounded.AttachMoney" Size="MudSize.Small" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_pipelineValue.ToString("N0")</span>
                            <span class="cp-stat-lbl">Pipeline</span>
                        </div>
                    </div>
                    <div class="cp-stat" @onclick="@(() => _tab = 1)">
                        <div class="cp-stat-icon" style="background:rgba(59,130,246,.15);color:#3b82f6">
                            <MudIcon Icon="@Icons.Material.Rounded.Forum" Size="MudSize.Small" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_interactions.Count</span>
                            <span class="cp-stat-lbl">تفاعل</span>
                        </div>
                    </div>
                    <div class="cp-stat" @onclick="@(() => _tab = 2)">
                        <div class="cp-stat-icon" style="background:rgba(239,68,68,.15);color:#ef4444">
                            <MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Size="MudSize.Small" />
                        </div>
                        <div class="cp-stat-data">
                            <span class="cp-stat-val">@_activeTaskCount</span>
                            <span class="cp-stat-lbl">مهمة نشطة</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* INSIGHTS BAR *@
        <div class="cp-insights">
            <div class="cp-insight">
                <MudIcon Icon="@Icons.Material.Rounded.Schedule" Size="MudSize.Small" Style="color:var(--mud-palette-text-secondary)" />
                <span>آخر تواصل: <strong>@(_lastContactDate.HasValue ? _lastContactDate.Value.ToString("yyyy/MM/dd") : "—")</strong></span>
            </div>
            <div class="cp-insight-sep"></div>
            <div class="cp-insight">
                <MudIcon Icon="@Icons.Material.Rounded.Event" Size="MudSize.Small" Style="color:var(--mud-palette-primary)" />
                <span>متابعة قادمة: <strong>@(_nextFollowUp.HasValue ? _nextFollowUp.Value.ToString("yyyy/MM/dd") : "—")</strong></span>
            </div>
            <div class="cp-insight-sep"></div>
            <div class="cp-insight">
                <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" Size="MudSize.Small" Style="color:#22c55e" />
                <span>نسبة الفوز: <strong>@_winRate%</strong></span>
            </div>
        </div>

        @* QUICK ADD *@
        <div class="cp-quick-add">
            <span class="cp-qa-label">إضافة سريعة:</span>
            <button class="cp-qa-btn" @onclick="AddOpportunity">
                <MudIcon Icon="@Icons.Material.Rounded.Add" Size="MudSize.Small" /> فرصة جديدة
            </button>
            <button class="cp-qa-btn info" @onclick="AddInteraction">
                <MudIcon Icon="@Icons.Material.Rounded.Add" Size="MudSize.Small" /> تواصل جديد
            </button>
            <button class="cp-qa-btn warn" @onclick="AddTask">
                <MudIcon Icon="@Icons.Material.Rounded.Add" Size="MudSize.Small" /> مهمة جديدة
            </button>
        </div>

        @* TABS *@
        <div class="cp-tabs">
            <button class="@(_tab==0?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=0)">
                <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="MudSize.Small" />
                <span>الفرص</span>
                <span class="cp-tab-count">@_opportunities.Count</span>
            </button>
            <button class="@(_tab==1?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=1)">
                <MudIcon Icon="@Icons.Material.Rounded.Forum" Size="MudSize.Small" />
                <span>التواصلات</span>
                <span class="cp-tab-count">@_interactions.Count</span>
            </button>
            <button class="@(_tab==2?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=2)">
                <MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Size="MudSize.Small" />
                <span>المهام</span>
                <span class="cp-tab-count">@_tasks.Count</span>
            </button>
            @if (_canViewInvoices)
            {
                <button class="@(_tab==3?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=3)">
                    <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="MudSize.Small" />
                    <span>المالية والفواتير</span>
                    <span class="cp-tab-count">@_invoices.Count</span>
                </button>
            }
            @if (_canViewQuotations)
            {
                <button class="@(_tab==5?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=5)">
                    <MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="MudSize.Small" />
                    <span>عروض الأسعار</span>
                    <span class="cp-tab-count">@_clientQuotations.Count</span>
                </button>
            }
            <button class="@(_tab==4?"cp-tab active":"cp-tab")" @onclick="@(() => _tab=4)">
                <MudIcon Icon="@Icons.Material.Rounded.History" Size="MudSize.Small" />
                <span>النشاط الموحد</span>
                <span class="cp-tab-count">@_activities.Count</span>
            </button>
        </div>

        @* TAB: OPPORTUNITIES *@
        @if (_tab == 0)
        {
            @if (_opportunities.Any())
            {
                @if (_stageGroups.Any())
                {
                    <div class="cp-pipeline-bar">
                        @foreach (var stage in _stageGroups)
                        {
                            <div class="cp-pipeline-seg" style="flex:@stage.Count;background:@stage.Color" title="@stage.Name: @stage.Count">
                                @if (stage.Count > 0) { <span class="cp-pipeline-label">@stage.Count</span> }
                            </div>
                        }
                    </div>
                }
                <div class="cp-opp-grid">
                    @foreach (var o in _opportunities.OrderByDescending(o => o.CreatedAt))
                    {
                        <div class="cp-opp-card" @onclick="() => OpenOpp(o.OpportunityId)">
                            <div class="cp-opp-color" style="background:linear-gradient(180deg, @(o.StageColor ?? "#94a3b8"), rgba(255,255,255,0))"></div>
                            <div class="cp-opp-body">
                                <div class="cp-opp-head">
                                    <span class="cp-opp-stage" style="color:@(o.StageColor ?? "#94a3b8");background:@(o.StageColor ?? "#94a3b8")15">
                                        @(o.StageNameAr ?? o.StageName ?? "—")
                                    </span>
                                    <span class="cp-opp-value">💰 @((o.ExpectedValue ?? 0).ToString("N0")) ج</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(o.InterestedProduct))
                                {
                                    <div class="cp-opp-product">🏷️ @o.InterestedProduct</div>
                                }
                                <div class="cp-opp-meta">
                                    <span>👤 @(o.EmployeeName ?? "—")</span>
                                    <span>📡 @(o.SourceName ?? "—")</span>
                                </div>
                                <div class="cp-opp-footer">
                                    <span>📅 @o.CreatedAt.ToString("yyyy/MM/dd")</span>
                                    @if (o.NextFollowUpDate.HasValue)
                                    {
                                        <span class="cp-opp-next">🔔 @o.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cp-empty">
                    <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="MudSize.Large" /></div>
                    <h3>لا توجد فرص بعد</h3>
                    <p>ابدأ بإضافة أول فرصة لهذا العميل</p>
                    <MudButton Variant="Variant.Filled" Color="MudColor.Primary" OnClick="AddOpportunity" StartIcon="@Icons.Material.Rounded.Add">إضافة فرصة</MudButton>
                </div>
            }
        }

        @* TAB: INTERACTIONS *@
        @if (_tab == 1)
        {
            @if (_interactions.Any())
            {
                <div class="cp-timeline">
                    @foreach (var i in _interactions.OrderByDescending(i => i.InteractionDate))
                    {
                        <div class="cp-tl-item">
                            <div class="cp-tl-line">
                                <div class="cp-tl-dot">💬</div>
                            </div>
                            <div class="cp-tl-card">
                                <div class="cp-tl-head">
                                    <div class="cp-tl-user">
                                        <div class="cp-tl-avatar" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">@GetInitials(i.EmployeeName ?? i.CreatedBy)</div>
                                        <strong>@(i.EmployeeName ?? i.CreatedBy ?? "—")</strong>
                                    </div>
                                    <span class="cp-tl-date">@i.InteractionDate.ToString("yyyy/MM/dd hh:mm tt")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(i.Summary))
                                {
                                    <div class="cp-tl-text">@i.Summary</div>
                                }
                                <div class="cp-tl-foot">
                                    @if (i.NextFollowUpDate.HasValue)
                                    {
                                        <span class="cp-tl-follow">📅 متابعة: @i.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cp-empty">
                    <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.Forum" Size="MudSize.Large" /></div>
                    <h3>لا توجد تواصلات</h3>
                    <p>سجّل أول تفاعل مع هذا العميل</p>
                    <MudButton Variant="Variant.Filled" Color="MudColor.Info" OnClick="AddInteraction" StartIcon="@Icons.Material.Rounded.Add">إضافة تفاعل</MudButton>
                </div>
            }
        }

        @* TAB: TASKS *@
        @if (_tab == 2)
        {
            @if (_tasks.Any())
            {
                <div class="cp-tasks-list">
                    @foreach (var t in _tasks.OrderByDescending(t => t.DueDate))
                    {
                        var isDone = t.Status == "Completed";
                        var isOverdue = t.DueDate.Date < DateTime.Today && !isDone;
                        var priColor = t.Priority == "High" ? "#ef4444" : (t.Priority == "Medium" || t.Priority == "Normal") ? "#f59e0b" : "#22c55e";
                        <div class="cp-task-card @(isDone ? "done" : "") @(isOverdue ? "overdue" : "")">
                            <div class="cp-task-pri" style="background:@priColor"></div>
                            <div class="cp-task-body">
                                <div class="cp-task-top">
                                    <span class="cp-task-desc">@(t.TaskDescription ?? "بدون وصف")</span>
                                    @if (!isDone)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Rounded.CheckCircleOutline" Size="MudSize.Small" Color="MudColor.Success" OnClick="@(() => CompleteTask(t.TaskId))" Tooltip="إكمال" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Style="color:#22c55e" Size="MudSize.Small" />
                                    }
                                </div>
                                <div class="cp-task-meta">
                                    <span>👤 @(t.AssignedToName ?? "—")</span>
                                    <span>📅 @t.DueDate.ToString("yyyy/MM/dd")</span>
                                    @if (isOverdue)
                                    { <span style="color:#ef4444;font-weight:700">⚠️ متأخرة</span> }
                                    else if (isDone)
                                    { <span style="color:#22c55e">✅ مكتملة</span> }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cp-empty">
                    <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Size="MudSize.Large" /></div>
                    <h3>لا توجد مهام</h3>
                    <p>أنشئ مهمة متابعة لهذا العميل</p>
                    <MudButton Variant="Variant.Filled" Color="MudColor.Warning" OnClick="AddTask" StartIcon="@Icons.Material.Rounded.Add">إضافة مهمة</MudButton>
                </div>
            }
        }

        @* TAB: FINANCIAL & INVOICES *@
        @if (_tab == 3 && _canViewInvoices)
        {
            <div class="cp-financial-panel animate-card">
                <!-- KPI Stats Cards -->
                <div class="cp-fin-grid">
                    <div class="cp-fin-card total-sales">
                        <div class="cp-fc-icon">💰</div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_totalSales.ToString("N2") ج</span>
                            <span class="cp-fc-lbl">إجمالي مبيعات العميل</span>
                        </div>
                    </div>
                    <div class="cp-fin-card total-paid">
                        <div class="cp-fc-icon">✅</div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_totalPaid.ToString("N2") ج</span>
                            <span class="cp-fc-lbl">إجمالي المبالغ المسددة</span>
                        </div>
                    </div>
                    <div class="cp-fin-card total-remaining">
                        <div class="cp-fc-icon">⚠️</div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_totalRemaining.ToString("N2") ج</span>
                            <span class="cp-fc-lbl">المديونية (المتبقي للتحصيل)</span>
                        </div>
                    </div>
                </div>

                <!-- Invoices List -->
                <h3 class="cp-section-title">📄 سجل فواتير المبيعات</h3>
                @if (_invoices.Any())
                {
                    <div class="cp-invoice-list">
                        @foreach (var inv in _invoices)
                        {
                            var statusClass = inv.InvoiceStatus?.ToLower() switch
                            {
                                "paid" => "paid",
                                "partiallypaid" => "partial",
                                _ => "unpaid"
                            };

                            var statusText = inv.InvoiceStatus?.ToLower() switch
                            {
                                "paid" => "مدفوعة بالكامل",
                                "partiallypaid" => "مدفوعة جزئياً",
                                _ => "مفتوحة / غير مدفوعة"
                            };

                            <div class="cp-invoice-card" @onclick="@(() => Nav.NavigateTo($"/sales/invoices/{inv.TransactionId}"))">
                                <div class="cp-inv-head">
                                    <span class="cp-inv-num">#@inv.TransactionId</span>
                                    <span class="cp-inv-status @statusClass">@statusText</span>
                                </div>
                                <div class="cp-inv-row">
                                    <div class="cp-inv-item">
                                        <span class="lbl">إجمالي الفاتورة:</span>
                                        <span class="val font-bold">@inv.GrandTotal.ToString("N2") ج</span>
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">المسدد:</span>
                                        <span class="val text-success font-bold">@inv.PaidAmount.ToString("N2") ج</span>
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">المتبقي:</span>
                                        <span class="val text-error font-bold">@((inv.GrandTotal - inv.PaidAmount).ToString("N2")) ج</span>
                                    </div>
                                </div>
                                <div class="cp-inv-footer">
                                    <span>📅 تاريخ الفاتورة: @inv.TransactionDate.ToString("yyyy/MM/dd")</span>
                                    @if (!string.IsNullOrWhiteSpace(inv.CreatedBy))
                                    {
                                        <span>👤 البائع: @inv.CreatedBy</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="cp-empty">
                        <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="MudSize.Large" /></div>
                        <h3>لا توجد فواتير بعد</h3>
                        <p>لا توجد أي فواتير مبيعات مسجلة لهذا العميل في النظام المالي.</p>
                    </div>
                }
            </div>
        }

        @* TAB: QUOTATIONS *@
        @if (_tab == 5 && _canViewQuotations)
        {
            <div class="cp-financial-panel animate-card">
                <!-- Quotations KPI Stats -->
                <div class="cp-fin-grid">
                    <div class="cp-fin-card total-quotes">
                        <div class="cp-fc-icon">📄</div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_clientQuotations.Count</span>
                            <span class="cp-fc-lbl">إجمالي العروض المستخرجة</span>
                        </div>
                    </div>
                    <div class="cp-fin-card accepted-quotes">
                        <div class="cp-fc-icon">✅</div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_clientQuotations.Count(q => q.Status == "Accepted" || q.Status == "Converted")</span>
                            <span class="cp-fc-lbl">عروض مقبولة / مؤكدة</span>
                        </div>
                    </div>
                    <div class="cp-fin-card total-value">
                        <div class="cp-fc-icon">💰</div>
                        <div class="cp-fc-data">
                            <span class="cp-fc-val font-bold">@_clientQuotations.Sum(q => q.GrandTotal ?? q.TotalAmount).ToString("N0") ج</span>
                            <span class="cp-fc-lbl">إجمالي القيمة المعروضة</span>
                        </div>
                    </div>
                </div>

                <!-- Quotations List -->
                <h3 class="cp-section-title">📊 عروض الأسعار المقدمة</h3>
                @if (_clientQuotations.Any())
                {
                    <div class="cp-invoice-list">
                        @foreach (var q in _clientQuotations)
                        {
                            var statusClass = q.Status?.ToLower() switch
                            {
                                "accepted" => "paid",
                                "converted" => "paid",
                                "rejected" => "unpaid",
                                "expired" => "partial",
                                _ => "unpaid"
                            };

                            var statusText = q.Status switch
                            {
                                "Draft" => "مسودة",
                                "Sent" => "تم الإرسال للعميل",
                                "Accepted" => "مقبول من العميل",
                                "Rejected" => "مرفوض من العميل",
                                "Converted" => "محوّل لفاتورة",
                                "Expired" => "منتهي الصلاحية",
                                _ => q.Status
                            };

                            <div class="cp-invoice-card" @onclick="@(() => Nav.NavigateTo($"/quotations/{q.QuotationId}"))">
                                <div class="cp-inv-head">
                                    <span class="cp-inv-num">📄 عرض رقم: @(q.ReferenceNumber ?? q.QuotationId.ToString())</span>
                                    <span class="cp-inv-status @statusClass">@statusText</span>
                                </div>
                                <div class="cp-inv-row">
                                    <div class="cp-inv-item">
                                        <span class="lbl">قيمة العرض:</span>
                                        <span class="val font-bold text-primary">@((q.GrandTotal ?? q.TotalAmount).ToString("N2")) ج</span>
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">تاريخ الإصدار:</span>
                                        <span class="val">@q.QuotationDate.ToString("yyyy/MM/dd")</span>
                                    </div>
                                    <div class="cp-inv-item">
                                        <span class="lbl">صالح لغاية:</span>
                                        <span class="val @(q.ValidUntil.HasValue && q.ValidUntil.Value < DateTime.Today ? "text-error font-bold" : "")">
                                            @(q.ValidUntil.HasValue ? q.ValidUntil.Value.ToString("yyyy/MM/dd") : "—")
                                        </span>
                                    </div>
                                </div>
                                <div class="cp-inv-footer">
                                    <span>📅 أنشئ في: @q.CreatedAt.ToString("yyyy/MM/dd")</span>
                                    @if (!string.IsNullOrWhiteSpace(q.CreatedBy))
                                    {
                                        <span>👤 المسؤول: @q.CreatedBy</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="cp-empty">
                        <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="MudSize.Large" /></div>
                        <h3>لا توجد عروض أسعار</h3>
                        <p>لم يتم إنشاء أي عروض أسعار رسمية لهذا العميل من قبل.</p>
                        <MudButton Variant="Variant.Filled" Color="MudColor.Primary" OnClick="AddOpportunity" StartIcon="@Icons.Material.Rounded.Add">إنشاء عرض سعر</MudButton>
                    </div>
                }
            </div>
        }

        @* TAB: UNIFIED TIMELINE FEED *@
        @if (_tab == 4)
        {
            <div class="cp-unified-feed animate-card">
                <h3 class="cp-section-title">🕰️ سجل الأنشطة والفعاليات اللحظي الموحد</h3>
                @if (_activities.Any())
                {
                    <div class="cp-feed-timeline">
                        @foreach (var act in _activities)
                        {
                            var badgeClass = act.Type.ToLower();
                            <div class="cp-feed-item">
                                <div class="cp-feed-left">
                                    <div class="cp-feed-icon" style="background:@(act.Color + "15");color:@act.Color;border-color:@act.Color">
                                        <MudIcon Icon="@act.Icon" Size="MudSize.Medium" />
                                    </div>
                                    <div class="cp-feed-line" style="background: linear-gradient(180deg, @act.Color, var(--mud-palette-lines-default))"></div>
                                </div>
                                <div class="cp-feed-card" @onclick="@(() => Nav.NavigateTo(act.Link))">
                                    <div class="cp-feed-head">
                                        <span class="cp-feed-badge @badgeClass">@act.BadgeText</span>
                                        <span class="cp-feed-date">@act.Date.ToString("yyyy/MM/dd hh:mm tt")</span>
                                    </div>
                                    <div class="cp-feed-body">
                                        <h4 class="cp-feed-title">@act.Title</h4>
                                        <p class="cp-feed-desc">@act.Description</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="cp-empty">
                        <div class="cp-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.History" Size="MudSize.Large" /></div>
                        <h3>السجل فارغ</h3>
                        <p>لا توجد أي أنشطة أو أحداث مسجلة لهذا العميل حتى الآن.</p>
                    </div>
                }
            </div>
        }

    </div>
}
else
{
    @* ════════════════════════════════════════════════════════ *@
    @* ═══ MODE: SEARCH ═══ *@
    @* ════════════════════════════════════════════════════════ *@
    <div dir="rtl" class="cs-page animate-card">

        @* SEARCH HEADER (Wide & Immersive) *@
        <div class="cs-header">
            <div class="cs-header-bg">
                <div class="cs-grad"></div>
                <div class="cs-orb"></div>
                <div class="cs-pattern"></div>
            </div>
            <div class="cs-header-content">
                <div class="cs-header-icon">
                    <MudIcon Icon="@Icons.Material.Rounded.PersonSearch" Size="MudSize.Large" />
                    <div class="cs-icon-ring"></div>
                </div>
                <h1>مركز بحث ومتابعة العملاء</h1>
                <p>ابحث عن أي عميل بالاسم أو رقم التليفون للوصول الفوري لملفه وبطاقته البيعية والمالية</p>
            </div>
        </div>

        @* SEARCH BOX *@
        <div class="cs-search-wrap">
            <MudTextField T="string"
                          Placeholder="اكتب اسم العميل أو رقم التليفون هنا للبحث الفوري..."
                          Variant="Variant.Outlined"
                          @bind-Value="_searchQuery"
                          @bind:event="oninput"
                          Immediate="true"
                          DebounceInterval="300"
                          OnDebounceIntervalElapsed="SearchCustomers"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search"
                          FullWidth="true"
                          Class="cs-search-input-field" />
            @if (_searching)
            {
                <div class="cs-loading">
                    <MudProgressCircular Size="MudSize.Small" Indeterminate="true" Color="MudColor.Primary" />
                    <span>جاري البحث عن العميل الفائز...</span>
                </div>
            }
        </div>

        @* RESULTS COUNT *@
        @if (!_searching && _searchResults.Any())
        {
            <div class="cs-count">🎯 تم العثور على <strong>@_searchResults.Count</strong> عميل في قاعدة البيانات</div>
        }

        @* RESULTS (Spectacular Responsive Grid) *@
        <div class="cs-results">
            @foreach (var c in _searchResults)
            {
                <div class="cs-card animate-card" style="--delay: 0.05s">
                    <div class="cs-card-top-accent"></div>
                    <div class="cs-card-main-row" @onclick="@(() => GoToCustomer(c.PartyId))">
                        <div class="cs-card-avatar">
                            <span>@GetInitials(c.PartyName)</span>
                        </div>
                        <div class="cs-card-info">
                            <span class="cs-card-name">@c.PartyName</span>
                            @if (!string.IsNullOrWhiteSpace(c.City))
                            {
                                <span class="cs-card-city">📍 @c.City</span>
                            }
                        </div>
                    </div>
                    
                    <div class="cs-card-footer">
                        @if (!string.IsNullOrWhiteSpace(c.Phone))
                        {
                            <span class="cs-card-phone font-bold">📞 @c.Phone</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(c.CustomerStage))
                        {
                            <span class="cs-stage">🏷️ @c.CustomerStage</span>
                        }
                    </div>

                    <!-- Premium Card Quick Actions (WhatsApp & Direct Phone & Profile Link) -->
                    <div class="cs-card-actions">
                        @if (!string.IsNullOrWhiteSpace(c.Phone))
                        {
                            <button class="cs-card-act-btn wa" @onclick="@(() => WA(c.Phone))" title="شات واتساب سريع">
                                <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Size="MudSize.Small" />
                                <span>واتساب</span>
                            </button>
                            <button class="cs-card-act-btn call" @onclick="@(() => Call(c.Phone))" title="اتصال هاتفي">
                                <MudIcon Icon="@Icons.Material.Rounded.Phone" Size="MudSize.Small" />
                                <span>اتصال</span>
                            </button>
                        }
                        <button class="cs-card-act-btn profile" @onclick="@(() => GoToCustomer(c.PartyId))" title="فتح الملف">
                            <MudIcon Icon="@Icons.Material.Rounded.AccountBox" Size="MudSize.Small" />
                            <span>الملف</span>
                        </button>
                    </div>
                </div>
            }
        </div>

        @* EMPTY STATES *@
        @if (!_searching && !string.IsNullOrWhiteSpace(_searchQuery) && _searchQuery.Length >= 2 && !_searchResults.Any())
        {
            <div class="cs-empty animate-card">
                <div class="cs-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.SearchOff" Size="MudSize.Large" /></div>
                <h3>لا توجد نتائج مطابقة</h3>
                <p>لم نعثر على عميل بهذا الاسم أو الرقم، تأكد من صحة الحروف أو جرب رقم هاتف آخر.</p>
            </div>
        }
        else if (string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Length < 2)
        {
            <div class="cs-empty animate-card">
                <div class="cs-empty-icon"><MudIcon Icon="@Icons.Material.Rounded.PersonSearch" Size="MudSize.Large" /></div>
                <h3>أدخل بيانات البحث لبدء المتابعة</h3>
                <p>اكتب حرفين أو أكثر من اسم العميل أو رقم هاتفه لعرض سجله البيعي فوراً.</p>
            </div>
        }
    </div>
}

<style>
    :root{--cp-max:1100px;--cp-radius:20px;--cp-radius-sm:12px}

    /* ═══ LOADING ═══ */
    .loading-screen{display:flex;align-items:center;justify-content:center;min-height:80vh}
    .loading-content{display:flex;flex-direction:column;align-items:center;text-align:center}
    .loading-logo{position:relative;width:70px;height:70px;display:flex;align-items:center;justify-content:center;color:var(--mud-palette-secondary)}
    .loading-ring{position:absolute;inset:-8px;border:3px solid transparent;border-top-color:var(--mud-palette-secondary);border-radius:50%;animation:spin 1.2s linear infinite}
    .loading-ring.ring-2{inset:-16px;border-top-color:var(--mud-palette-primary);animation-duration:1.8s;animation-direction:reverse}
    @@keyframes spin{to{transform:rotate(360deg)}}

    /* ═══ PROFILE PAGE ═══ */
    .cp-page{padding:0 1.5rem 3rem;max-width:var(--cp-max);margin:0 auto;font-size:.9rem;line-height:1.6}

    /* Search Overlay */
    .cp-search-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);backdrop-filter:blur(4px);z-index:9999;display:flex;justify-content:center;padding-top:80px;animation:fadeIn .2s}
    @@keyframes fadeIn{from{opacity:0}to{opacity:1}}
    .cp-search-box{width:95%;max-width:600px;background:var(--mud-palette-surface);border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.2);overflow:hidden;max-height:70vh;display:flex;flex-direction:column;animation:slideUp .25s ease-out}
    @@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .cp-search-header{display:flex;align-items:center;gap:.75rem;padding:1rem 1.25rem;border-bottom:1px solid var(--mud-palette-lines-default)}
    .cp-search-input{flex:1;border:none;outline:none;font-size:1rem;background:transparent;color:var(--mud-palette-text-primary);font-family:inherit}
    .cp-search-input::placeholder{color:var(--mud-palette-text-disabled)}
    .cp-search-spinner{width:20px;height:20px;border:2px solid var(--mud-palette-lines-default);border-top-color:var(--mud-palette-primary);border-radius:50%;animation:spin .8s linear infinite;flex-shrink:0}
    .cp-search-close{width:32px;height:32px;border-radius:8px;border:1px solid var(--mud-palette-lines-default);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--mud-palette-text-secondary);transition:all .2s}
    .cp-search-close:hover{background:var(--mud-palette-action-hover)}
    .cp-search-results{overflow-y:auto;max-height:55vh}
    .cp-search-item{display:flex;align-items:center;gap:.75rem;padding:.75rem 1.25rem;cursor:pointer;transition:background .15s;border-bottom:1px solid var(--mud-palette-lines-inputs)}
    .cp-search-item:hover{background:var(--mud-palette-action-hover)}
    .cp-search-item.current{background:rgba(124,58,237,.05);border-right:3px solid #7c3aed}
    .cp-si-avatar{width:38px;height:38px;border-radius:10px;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;flex-shrink:0}
    .cp-si-info{flex:1;min-width:0}
    .cp-si-name{display:block;font-weight:600;font-size:.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .cp-si-meta{display:flex;gap:.5rem;font-size:.72rem;color:var(--mud-palette-text-secondary)}
    .cp-si-badge{font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:5px;background:rgba(124,58,237,.1);color:#7c3aed}
    .cp-search-empty{padding:2rem;text-align:center;color:var(--mud-palette-text-disabled);font-size:.86rem}
    .cp-search-hint{padding:1.5rem;text-align:center;color:var(--mud-palette-text-disabled);font-size:.8rem}

    /* Hero */
    .cp-hero{position:relative;border-radius:var(--cp-radius);overflow:hidden;margin-bottom:1rem;box-shadow:0 12px 40px rgba(124,58,237,.22)}
    .cp-hero-bg{position:absolute;inset:0}
    .cp-hero-grad{position:absolute;inset:0;background:linear-gradient(135deg,#5b21b6 0%,#6d28d9 25%,#7c3aed 50%,#8b5cf6 75%,#a78bfa 100%)}
    .cp-hero-pattern{position:absolute;inset:0;opacity:.04;background-image:radial-gradient(circle at 1px 1px,rgba(255,255,255,.5) 1px,transparent 0);background-size:24px 24px}
    .cp-hero-orb{position:absolute;border-radius:50%;filter:blur(70px);animation:orb-float 10s ease-in-out infinite}
    .orb-1{width:240px;height:240px;background:rgba(196,181,253,.15);top:-80px;right:-40px}
    .orb-2{width:160px;height:160px;background:rgba(167,139,250,.12);bottom:-50px;left:10%;animation-delay:-4s}
    @@keyframes orb-float{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(12px,-8px) scale(1.06)}}
    .cp-hero-content{position:relative;z-index:2;padding:1.5rem 2rem 0;color:#fff}
    .cp-hero-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem}
    .cp-back-btn{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;background:rgba(255,255,255,.12);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.18);border-radius:8px;color:#fff;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit}
    .cp-back-btn:hover{background:rgba(255,255,255,.22)}
    .cp-hero-actions{display:flex;align-items:center;gap:.35rem}
    .cp-action-btn{display:inline-flex;align-items:center;gap:5px;padding:7px 12px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:8px;color:rgba(255,255,255,.8);font-size:.78rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit}
    .cp-action-btn:hover{background:rgba(255,255,255,.22);color:#fff}
    .cp-action-btn.edit{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.25)}
    .cp-action-btn.wa-btn { background: rgba(37,211,102,0.18); border-color: rgba(37,211,102,0.3); color: #25d366; }
    .cp-action-btn.wa-btn:hover { background: #25d366; color: #fff; }

    .cp-hero-profile{display:flex;align-items:center;gap:1.25rem;margin-bottom:1.5rem;flex-wrap:wrap}
    .cp-avatar{position:relative;width:68px;height:68px;background:rgba(255,255,255,.15);backdrop-filter:blur(12px);border-radius:18px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:1.5rem;flex-shrink:0}
    .cp-avatar-ring{position:absolute;inset:-4px;border-radius:22px;border:2px solid rgba(255,255,255,.2);animation:pulse-ring 3s ease-out infinite}
    @@keyframes pulse-ring{0%{transform:scale(1);opacity:.5}100%{transform:scale(1.15);opacity:0}}
    .cp-hero-info h1{margin:0;font-size:1.5rem;font-weight:900;line-height:1.2}
    .cp-hero-meta{display:flex;gap:.75rem;flex-wrap:wrap;font-size:.82rem;margin-top:.3rem;opacity:.9}
    .cp-meta-item{display:inline-flex;align-items:center;gap:3px}
    .cp-stage-badge{display:inline-flex;align-items:center;gap:6px;margin-top:.4rem;padding:4px 12px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);border-radius:8px;font-size:.76rem;font-weight:600}
    .cp-stage-dot{width:8px;height:8px;border-radius:50%;background:#34d399;box-shadow:0 0 8px #34d399;animation:blink 2s infinite}
    @@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

    .cp-hero-stats{display:grid;grid-template-columns:repeat(5,1fr);gap:0;border-top:1px solid rgba(255,255,255,.1)}
    .cp-stat{display:flex;align-items:center;gap:.6rem;padding:.75rem .75rem;cursor:pointer;transition:background .2s}
    .cp-stat:hover{background:rgba(255,255,255,.08)}
    .cp-stat-icon{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .cp-stat-data{display:flex;flex-direction:column}
    .cp-stat-val{font-size:1.05rem;font-weight:900;line-height:1}
    .cp-stat-lbl{font-size:.65rem;opacity:.7;margin-top:2px}

    /* Insights */
    .cp-insights{display:flex;align-items:center;gap:.75rem;padding:.75rem 1.25rem;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-lines-default);border-radius:var(--cp-radius-sm);margin-bottom:.75rem;flex-wrap:wrap;font-size:.82rem}
    .cp-insight{display:flex;align-items:center;gap:6px;color:var(--mud-palette-text-secondary)}
    .cp-insight strong{color:var(--mud-palette-text-primary)}
    .cp-insight-sep{width:1px;height:18px;background:var(--mud-palette-lines-default)}

    /* Quick Add */
    .cp-quick-add{display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap}
    .cp-qa-label{font-size:.82rem;font-weight:700;color:var(--mud-palette-text-secondary)}
    .cp-qa-btn{display:inline-flex;align-items:center;gap:4px;padding:6px 14px;background:rgba(99,102,241,.08);color:#6366f1;border:1px solid rgba(99,102,241,.15);border-radius:8px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit}
    .cp-qa-btn:hover{background:rgba(99,102,241,.15);transform:translateY(-1px)}
    .cp-qa-btn.info{background:rgba(59,130,246,.08);color:#3b82f6;border-color:rgba(59,130,246,.15)}
    .cp-qa-btn.info:hover{background:rgba(59,130,246,.15)}
    .cp-qa-btn.warn{background:rgba(245,158,11,.08);color:#f59e0b;border-color:rgba(245,158,11,.15)}
    .cp-qa-btn.warn:hover{background:rgba(245,158,11,.15)}

    /* Tabs */
    .cp-tabs{display:flex;gap:4px;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-lines-default);border-radius:12px;padding:4px;margin-bottom:1rem;overflow-x:auto}
    .cp-tab{display:flex;align-items:center;gap:6px;padding:8px 16px;border:none;background:transparent;border-radius:8px;font-size:.86rem;font-weight:600;cursor:pointer;color:var(--mud-palette-text-secondary);transition:all .2s;font-family:inherit;flex:1;justify-content:center;white-space:nowrap}
    .cp-tab:hover{background:var(--mud-palette-action-hover)}
    .cp-tab.active{background:var(--mud-palette-primary);color:#fff;box-shadow:0 2px 8px rgba(37,99,235,.3)}
    .cp-tab-count{font-size:.68rem;font-weight:700;padding:1px 7px;border-radius:8px;background:rgba(0,0,0,.08)}
