private void AddInteraction()
{
    var activeOpp = _opportunities
        .Where(o => o.IsActive)
        .OrderByDescending(o => o.LastContactDate ?? o.CreatedAt)
        .FirstOrDefault();

    if (activeOpp != null)
    {
        // تفاصيل الفرصة فيها فورم إضافة تفاعل بالفعل
        Nav.NavigateTo($"/crm/opportunities/{activeOpp.OpportunityId}");
    }
    else if (PartyId.HasValue)
    {
        // مفيش فرصة، يبقى نعمل فرصة أولاً
        Snackbar.Add("لا توجد فرصة نشطة لهذا العميل. سيتم فتح شاشة إنشاء فرصة جديدة أولاً.", Severity.Info);
        Nav.NavigateTo($"/crm/opportunities/new?partyId={PartyId.Value}");
    }
    else
    {
        Nav.NavigateTo("/crm/opportunities/new");
    }
}

