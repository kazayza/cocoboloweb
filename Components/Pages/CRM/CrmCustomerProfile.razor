    // ═══ HELPERS ═══
    private static string GetInitials(string? n)
    {
        if (string.IsNullOrWhiteSpace(n)) return "?";
        var w = n.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return w.Length >= 2 ? $"{w[0][0]}{w[1][0]}" : n[..1];
    }

    private async Task WA(string? p)
    {
        if (string.IsNullOrWhiteSpace(p)) return;
        var c = new string(p.Where(char.IsDigit).ToArray());
        if (c.StartsWith("0")) c = "2" + c;
        if (!c.StartsWith("2")) c = "2" + c;
        await JS.InvokeVoidAsync("open", $"https://wa.me/{c}", "_blank");
    }

    private async Task Call(string? p)
    { if (!string.IsNullOrWhiteSpace(p)) await JS.InvokeVoidAsync("open", $"tel:{p}", "_self"); }

    private async Task Email(string? e)
    { if (!string.IsNullOrWhiteSpace(e)) await JS.InvokeVoidAsync("open", $"mailto:{e}", "_blank"); }

    // ═══════════════════════════════════════════
    //  PROFIT CALCULATION HELPERS
    // ═══════════════════════════════════════════

    private decimal? GetQuotationTotalCost(Quotation q)
    {
        if (q.QuotationDetails == null || !q.QuotationDetails.Any()) return null;
        decimal totalCost = 0;
        bool hasAnyCost = false;
        foreach (var d in q.QuotationDetails)
        {
            if (_productCostDict.TryGetValue(d.ProductId, out var cost) && cost.HasValue)
            {
                totalCost += cost.Value * d.Quantity;
                hasAnyCost = true;
            }
        }
        return hasAnyCost ? totalCost : null;
    }

    private decimal? GetQuotationGrossProfit(Quotation q)
    {
        var cost = GetQuotationTotalCost(q);
        if (!cost.HasValue) return null;
        return (q.GrandTotal ?? q.TotalAmount) - cost.Value;
    }

    private decimal? GetQuotationProfitMargin(Quotation q)
    {
        var profit = GetQuotationGrossProfit(q);
        var grandTotal = q.GrandTotal ?? q.TotalAmount;
        if (!profit.HasValue || grandTotal == 0) return null;
        return Math.Round((profit.Value / grandTotal) * 100m, 2);
    }

