        if (_crmAccessFromDate.HasValue)
        {
            oppQuery = oppQuery.Where(o => o.CreatedAt >= _crmAccessFromDate.Value);
        }

        _opportunities = await oppQuery.Select(o => new OpportunityListDto
        {
            OpportunityId = o.OpportunityId,
            PartyId = o.PartyId,
            ClientName = o.ClientName ?? "",
            Phone = o.Phone1,
            EmployeeId = o.EmployeeId,
            EmployeeName = o.EmployeeName,
            SourceId = o.SourceId,
            SourceName = o.SourceNameAr ?? o.SourceName,
            SourceIcon = o.SourceIcon,
            StageId = o.StageId,
            StageName = o.StageName ?? "",
            StageNameAr = o.StageNameAr,
            StageColor = o.StageColor,
            StageOrder = o.StageOrder ?? 0,
            StatusId = o.StatusId,
            StatusName = o.StatusName,
            CategoryId = o.CategoryId,
            CategoryName = o.CategoryNameAr ?? o.CategoryName,
