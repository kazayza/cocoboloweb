@code {
    [Parameter] public int? PartyId { get; set; }

    // Common
    private bool _loading = true;
    private string? _currentUser;

    // Profile
    private PartyListDto? _party;
    private List<OpportunityListDto> _opportunities = new();
    private List<InteractionListDto> _interactions = new();
    private List<TaskListDto> _tasks = new();
    private int _tab;
    private int _wonCount;
    private int _activeTaskCount;
    private decimal _pipelineValue;
    private int _winRate;
    private DateTime? _lastContactDate;
    private DateTime? _nextFollowUp;
    private List<StageGroup> _stageGroups = new();
    private record StageGroup(string Name, string Color, int Count);

    // Search (shared between both modes)
    private bool _showSearch;
    private string _searchQuery = "";
    private List<PartyListDto> _searchResults = new();
    private bool _searching;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _currentUser = (await AuthProvider.GetAuthenticationStateAsync()).User.Identity?.Name;

            if (PartyId.HasValue && PartyId.Value > 0)
            {
                await LoadProfileData();
            }
        }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task LoadProfileData()
{
    using var db = await DbFactory.CreateDbContextAsync();

    _party = await db.Parties.AsNoTracking()
        .Where(p => p.PartyId == PartyId.Value)
        .Select(p => new PartyListDto
        {
            PartyId = p.PartyId,
            PartyName = p.PartyName,
            Phone = p.Phone,
            Email = p.Email,
            City = p.City,
            CustomerStage = p.CustomerStage
        })
        .FirstOrDefaultAsync();

    if (_party == null)
    {
        Snackbar.Add("العميل غير موجود", Severity.Error);
        Nav.NavigateTo("/crm/customers");
        return;
    }

    // ★ فرص العميل مباشرة من DB
    _opportunities = await db.Opportunities.AsNoTracking()
        .Where(o => o.PartyId == PartyId.Value)
        .OrderByDescending(o => o.CreatedAt)
        .Select(o => new OpportunityListDto
        {
            OpportunityId = o.OpportunityId,
            PartyId = o.PartyId,
            StageName = o.Stage.StageName,
            StageNameAr = o.Stage.StageNameAr,
            StageColor = o.Stage.Color,
            ExpectedValue = o.ExpectedValue,
            InterestedProduct = o.InterestedProduct,
            EmployeeName = o.Employee.EmployeeName,
            SourceName = o.Source.SourceName,
            CreatedAt = o.CreatedAt,
            NextFollowUpDate = o.NextFollowUpDate
        })
        .ToListAsync();

    // ★ تواصلات العميل مباشرة من DB
    _interactions = await db.Interactions.AsNoTracking()
        .Where(i => i.PartyId == PartyId.Value)
        .OrderByDescending(i => i.InteractionDate)
        .Select(i => new InteractionListDto
        {
            InteractionId = i.InteractionId,
            PartyId = i.PartyId,
            EmployeeName = i.Employee.EmployeeName,
            CreatedBy = i.CreatedBy,
            Summary = i.Summary,
            InteractionDate = i.InteractionDate,
            NextFollowUpDate = i.NextFollowUpDate
        })
        .ToListAsync();

    // ★ مهام العميل مباشرة من DB
    _tasks = await db.CrmTasks.AsNoTracking()
        .Where(t => t.PartyId == PartyId.Value)
        .OrderByDescending(t => t.DueDate)
        .Select(t => new TaskListDto
        {
            TaskId = t.TaskId,
            PartyId = t.PartyId,
            TaskDescription = t.TaskDescription,
            Priority = t.Priority,
            Status = t.Status,
            DueDate = t.DueDate,
            DueTime = t.DueTime,
            AssignedToName = t.Employee.EmployeeName
        })
        .ToListAsync();

    CalcStats();
}

    private void CalcStats()
    {
        _wonCount = _opportunities.Count(o => o.StageName == "Won" || o.StageName == "تم البيع");
        _activeTaskCount = _tasks.Count(t => t.Status != "Completed" && t.Status != "Cancelled");
        _pipelineValue = _opportunities
            .Where(o => o.StageName != "Won" && o.StageName != "Lost" && o.StageName != "تم البيع" && o.StageName != "خسارة")
            .Sum(o => o.ExpectedValue ?? 0);
        _winRate = _opportunities.Count > 0 ? (int)Math.Round((double)_wonCount / _opportunities.Count * 100) : 0;

        if (_interactions.Any())
            _lastContactDate = _interactions.Max(i => i.InteractionDate);

        var next = _interactions
            .Where(i => i.NextFollowUpDate.HasValue && i.NextFollowUpDate.Value.Date >= DateTime.Today)
            .OrderBy(i => i.NextFollowUpDate)
            .FirstOrDefault();
        if (next != null && next.NextFollowUpDate.HasValue)
            _nextFollowUp = next.NextFollowUpDate.Value;

        _stageGroups = _opportunities
            .GroupBy(o => new { o.StageName, o.StageColor })
            .Select(g => new StageGroup(g.Key.StageName ?? "أخرى", g.Key.StageColor ?? "#94a3b8", g.Count()))
            .OrderByDescending(g => g.Count)
            .ToList();
    }

    // ═══ SEARCH ═══
    private void ToggleSearch()
    {
        _showSearch = !_showSearch;
        if (_showSearch) { _searchQuery = ""; _searchResults = new(); }
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { _showSearch = false; return; }
        if (e.Key == "Enter") { await SearchCustomers(); return; }
        await SearchCustomers();
    }

    private async Task SearchCustomers()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Trim().Length < 2)
        { _searchResults = new(); return; }

        _searching = true; StateHasChanged();
        try
        {
            var q = _searchQuery.Trim().ToLower();
            using var db = await DbFactory.CreateDbContextAsync();
            _searchResults = await db.Parties.AsNoTracking()
                .Where(p => p.PartyName != null &&
                            (p.PartyName.ToLower().Contains(q) ||
                             (p.Phone != null && p.Phone.Contains(q))))
                .OrderBy(p => p.PartyName)
                .Take(30)
                .Select(p => new PartyListDto
                {
                    PartyId = p.PartyId,
                    PartyName = p.PartyName,
                    Phone = p.Phone,
                    City = p.City,
                    CustomerStage = p.CustomerStage
                })
                .ToListAsync();
        }
        catch { _searchResults = new(); }
        finally { _searching = false; StateHasChanged(); }
    }

    private void GoToCustomer(int partyId)
    {
        _showSearch = false;
        Nav.NavigateTo($"/crm/customers/{partyId}", forceLoad: true);
    }

    // ═══ HELPERS ═══
    private static string GetInitials(string? n)
    {
        if (string.IsNullOrWhiteSpace(n)) return "?";
        var w = n.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return w.Length >= 2 ? $"{w[0][0]}{w[1][0]}" : n[..1];
    }

    private async Task WA(string? p)
    {
        if (string.IsNullOrWhiteSpace(p)) return;
        var c = new string(p.Where(char.IsDigit).ToArray());
        if (c.StartsWith("0")) c = "2" + c;
        if (!c.StartsWith("2")) c = "2" + c;
        await JS.InvokeVoidAsync("open", $"https://wa.me/{c}", "_blank");
    }

    private async Task Call(string? p)
    { if (!string.IsNullOrWhiteSpace(p)) await JS.InvokeVoidAsync("open", $"tel:{p}", "_self"); }

    private async Task Email(string? e)
    { if (!string.IsNullOrWhiteSpace(e)) await JS.InvokeVoidAsync("open", $"mailto:{e}", "_blank"); }

