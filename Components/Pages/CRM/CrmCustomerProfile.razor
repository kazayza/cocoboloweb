    // Permission and Scoping Controls
    private bool _canViewInvoices;
    private bool _canViewQuotations;
    private bool _canViewComplaints;
    private DateTime? _crmAccessFromDate;

    // Search (shared between both modes)
    private bool _showSearch;
    private string _searchQuery = "";
    private List<PartyListDto> _searchResults = new();
    private bool _searching;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _currentUser = user.Identity?.Name;

            // ── 🛡️ 1. Global Page Permission Enforcer ──
            bool hasPermission = user.IsInRole("Admin") || 
                                 user.HasClaim("Permission", "frmClientCard:View") || 
                                 user.HasClaim("Permission", "frm_PartiesList:View");

            if (!hasPermission)
            {
                Snackbar.Add("عذراً، لا تمتلك صلاحية للوصول لبيانات العملاء في الـ CRM.", Severity.Error);
                Nav.NavigateTo("/");
                return;
            }

            // ── 🛡️ 2. Load Permissions for Tabs ──
            _canViewInvoices = user.IsInRole("Admin") || user.HasClaim("Permission", "frm_PartiesInvoices:View");
            _canViewQuotations = user.IsInRole("Admin") || user.HasClaim("Permission", "frmQuotationsList:View");
            _canViewComplaints = user.IsInRole("Admin") || user.HasClaim("Permission", "frm_Complaints_Main:View");

            // ── 🛡️ 3. Load CRM Data Scoping (CrmAccessFrom) ──
            var crmAccessClaim = user.FindFirst("CrmAccessFrom")?.Value;
            if (DateTime.TryParse(crmAccessClaim, out var accessDate))
            {
                _crmAccessFromDate = accessDate;
            }

            if (PartyId.HasValue && PartyId.Value > 0)
            {
                await LoadProfileData();
            }
        }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task LoadProfileData()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        _party = await db.Parties.AsNoTracking()
            .Where(p => p.PartyId == PartyId.Value)
            .Select(p => new PartyListDto
            {
                PartyId = p.PartyId,
                PartyName = p.PartyName,
                Phone = p.Phone,
                Email = p.Email,
                City = p.City,
                CustomerStage = p.CustomerStage
            })
            .FirstOrDefaultAsync();

        if (_party == null)
        {
            Snackbar.Add("العميل غير موجود", Severity.Error);
            Nav.NavigateTo("/crm/customers");
            return;
        }

        // ── 1. Load ALL Opportunities directly from DB with CrmDataScoping ──
        var oppQuery = db.VwSalesOpportunities.AsNoTracking()
            .Where(o => o.PartyId == PartyId.Value && o.IsActive == true);

        if (_crmAccessFromDate.HasValue)
        {
            oppQuery = oppQuery.Where(o => o.CreatedAt >= _crmAccessFromDate.Value);
        }

        _opportunities = await oppQuery.Select(o => new OpportunityListDto
        {
            OpportunityId = o.OpportunityId,
            PartyId = o.PartyId,
            ClientName = o.ClientName ?? "",
            Phone = o.Phone1,
            EmployeeId = o.EmployeeId,
            EmployeeName = o.EmployeeName,
            SourceId = o.SourceId,
            SourceName = o.SourceNameAr ?? o.SourceName,
            SourceIcon = o.SourceIcon,
            StageId = o.StageId,
            StageName = o.StageName ?? "",
            StageNameAr = o.StageNameAr,
            StageColor = o.StageColor,
            StageOrder = o.StageOrder ?? 0,
            StatusId = o.StatusId,
            StatusName = o.StatusName,
            CategoryId = o.CategoryId,
            CategoryName = o.CategoryNameAr ?? o.CategoryName,
            InterestedProduct = o.InterestedProduct,
            ExpectedValue = o.ExpectedValue,
            Location = o.Location,
            FirstContactDate = o.FirstContactDate,
            NextFollowUpDate = o.NextFollowUpDate,
            LastContactDate = o.LastContactDate,
            Notes = o.Notes,
            Guidance = o.Guidance,
            QuotationId = o.QuotationId,
            TransactionId = o.TransactionId,
            IsActive = o.IsActive,
            CreatedBy = o.CreatedBy,
            CreatedAt = o.CreatedAt
        })
        .OrderByDescending(o => o.CreatedAt)
        .ToListAsync();

        // ── 2. Load ALL Interactions directly from DB with CrmDataScoping ──
        var intQuery = db.VwCustomerInteractions.AsNoTracking()
            .Where(i => i.PartyId == PartyId.Value);

        if (_crmAccessFromDate.HasValue)
        {
            intQuery = intQuery.Where(i => i.CreatedAt >= _crmAccessFromDate.Value);
        }

        _interactions = await intQuery.Select(i => new InteractionListDto
        {
            InteractionId = i.InteractionId,
            OpportunityId = i.OpportunityId,
            PartyId = i.PartyId,
            ClientName = i.ClientName,
            Phone = i.Phone,
            EmployeeId = i.EmployeeId,
            EmployeeName = i.EmployeeName,
            SourceId = i.SourceId,
            SourceName = i.SourceName,
            StatusId = i.StatusId,
            StatusName = i.StatusNameAr ?? i.StatusName,
            InteractionDate = i.InteractionDate,
            Summary = i.Summary,
            NextFollowUpDate = i.NextFollowUpDate,
            Notes = i.Notes,
            CreatedBy = i.CreatedBy,
            CreatedAt = i.CreatedAt
        })
        .OrderByDescending(i => i.InteractionDate)
        .ToListAsync();

        // ── 3. Load ALL Tasks directly from DB with CrmDataScoping ──
        var taskQuery = db.VwCrmTasks.AsNoTracking()
            .Where(t => t.PartyId == PartyId.Value && t.IsActive == true);

        if (_crmAccessFromDate.HasValue)
        {
            taskQuery = taskQuery.Where(t => t.CreatedAt >= _crmAccessFromDate.Value);
        }

        _tasks = await taskQuery.Select(t => new TaskListDto
        {
            TaskId = t.TaskId,
            OpportunityId = t.OpportunityId,
            PartyId = t.PartyId,
            ClientName = t.ClientName,
            Phone = t.Phone,
            AssignedTo = t.AssignedTo,
            AssignedToName = t.AssignedToName,
            TaskTypeId = t.TaskTypeId,
            TaskTypeName = t.TaskTypeNameAr ?? t.TaskTypeName,
            TaskDescription = t.TaskDescription,
            DueDate = t.DueDate,
            Priority = t.Priority,
            Status = t.Status,
            CompletedDate = t.CompletedDate,
            CompletedBy = t.CompletedBy,
            CompletionNotes = t.CompletionNotes,
            IsActive = t.IsActive,
            CreatedBy = t.CreatedBy,
            CreatedAt = t.CreatedAt
        })
        .OrderByDescending(t => t.DueDate)
        .ToListAsync();

        // ── 4. Load ALL Financial Invoices (If Permitted) ──
        if (_canViewInvoices)
        {
            _invoices = await db.Transactions.AsNoTracking()
                .Where(t => t.PartyId == PartyId.Value && t.TransactionType == "Sale")
                .OrderByDescending(t => t.TransactionDate)
                .ToListAsync();

            _totalSales = _invoices.Sum(t => t.GrandTotal);
            _totalPaid = _invoices.Sum(t => t.PaidAmount);
            _totalRemaining = _totalSales - _totalPaid;
        }

        // ── 5. Load ALL Quotations directly from DB (If Permitted) ──
        if (_canViewQuotations)
        {
            _clientQuotations = await db.Quotations.AsNoTracking()
                .Include(q => q.QuotationDetails)
                .Where(q => q.PartyId == PartyId.Value)
                .OrderByDescending(q => q.QuotationDate)
                .ToListAsync();

            // ⭐ تحميل أسعار شراء المنتجات لحساب الربح
            var allProductIds = _clientQuotations
                .SelectMany(q => q.QuotationDetails.Select(d => d.ProductId))
                .Distinct()
                .ToList();
            _productCostDict = await db.Products.AsNoTracking()
                .Where(p => allProductIds.Contains(p.ProductId))
                .ToDictionaryAsync(p => p.ProductId, p => p.PurchasePrice);
        }

        // ── 5b. Load Complaints ──
        if (_canViewComplaints)
        {
            var complaintFilter = new ComplaintFilterDto { PartyId = PartyId.Value, PageSize = 100 };
            var complaintResult = await ComplaintService.GetComplaintsAsync(complaintFilter);
            _complaints = complaintResult.Items.ToList();
        }

        // ── 6. Build Unified Timeline Activities ──
        _activities = new List<TimelineActivity>();

        foreach (var opp in _opportunities)
        {
            _activities.Add(new TimelineActivity
            {
                Date = opp.CreatedAt,
                Title = $"💡 فرصة بيعية جديدة: {(opp.InterestedProduct ?? "غير محدد")}",
                Description = $"القيمة المتوقعة: {opp.ExpectedValue?.ToString("N0") ?? "0"} ج.م — المرحلة الحالية: {opp.StageNameAr ?? opp.StageName}",
                Type = "Opportunity",
                Icon = Icons.Material.Rounded.Lightbulb,
                Color = opp.StageColor ?? "#7c3aed",
                BadgeText = "فرصة بيعية",
                Link = $"/crm/opportunities/{opp.OpportunityId}"
            });
        }

        foreach (var i in _interactions)
        {
            _activities.Add(new TimelineActivity
            {
                Date = i.InteractionDate,
                Title = $"📞 تسجيل تواصل بواسطة {i.EmployeeName ?? i.CreatedBy}",
                Description = i.Summary ?? "لا يوجد ملخص مكالمة",
                Type = "Interaction",
                Icon = Icons.Material.Rounded.Forum,
                Color = "#3b82f6",
                BadgeText = "تواصل ومتابعة",
                Link = $"/crm/customers/{PartyId}"
            });
        }

        foreach (var t in _tasks)
        {
            _activities.Add(new TimelineActivity
            {
                Date = t.DueDate,
                Title = $"📅 مهمة متابعة معلقة: {t.TaskDescription}",
                Description = $"مخصصة الى : {t.AssignedToName} — حالة المهمة: {(t.Status == "Completed" ? "مكتملة ✓" : "نشطة معلقة")}",
                Type = "Task",
                Icon = Icons.Material.Rounded.TaskAlt,
                Color = t.Status == "Completed" ? "#22c55e" : "#f59e0b",
                BadgeText = "مهمة عمل",
                Link = $"/crm/tasks"
            });
        }

        if (_canViewInvoices)
        {
            foreach (var inv in _invoices)
            {
                var pText = inv.InvoiceStatus?.ToLower() switch { "paid" => "مدفوعة بالكامل", "partiallypaid" => "مدفوعة جزئياً", _ => "غير مدفوعة" };
                _activities.Add(new TimelineActivity
                {
                    Date = inv.TransactionDate,
                    Title = $"📄 إصدار فاتورة مبيعات رقم #{inv.TransactionId}",
                    Description = $"القيمة الإجمالية: {inv.GrandTotal:N2} ج.م — المسدد: {inv.PaidAmount:N2} ج.م — حالة السداد: {pText}",
                    Type = "Invoice",
                    Icon = Icons.Material.Rounded.ReceiptLong,
                    Color = inv.InvoiceStatus?.ToLower() == "paid" ? "#10b981" : "#3b82f6",
                    BadgeText = "فاتورة مالية",
                    Link = $"/sales/invoices/{inv.TransactionId}"
                });
            }
        }

        if (_canViewQuotations)
        {
            foreach (var q in _clientQuotations)
            {
                var qStatusText = q.Status switch
                {
                    "Draft" => "مسودة تطلب مراجعة",
                    "Sent" => "تم الإرسال والانتظار للعميل",
                    "Accepted" => "مقبول من العميل ومرسل لتاكيد الحجز ✅",
                    "Rejected" => "مرفوض من العميل ❌",
                    "Converted" => "تم التأكيد وتحويله لفاتورة مبيعات محققة 🎉",
                    "Expired" => "منتهي صلاحية الحجز والطلب ⏰",
                    _ => q.Status
                };

                var qColor = q.Status switch
                {
                    "Accepted" => "#10b981",
                    "Converted" => "#10b981",
                    "Rejected" => "#ef4444",
                    "Expired" => "#f59e0b",
                    _ => "#d4af37"
                };

                _activities.Add(new TimelineActivity
                {
                    Date = q.QuotationDate,
                    Title = $"📄 عرض سعر جديد #{q.ReferenceNumber ?? q.QuotationId.ToString()}",
                    Description = $"القيمة المعروضة: {(q.GrandTotal ?? q.TotalAmount):N2} ج.م — حالة الطلب: {qStatusText} — صالح لغاية: {(q.ValidUntil.HasValue ? q.ValidUntil.Value.ToString("yyyy/MM/dd") : "غير محدد")}",
                    Type = "Quotation",
                    Icon = Icons.Material.Rounded.RequestQuote,
                    Color = qColor,
                    BadgeText = "عرض سعر رسمي",
                    Link = $"/quotations/{q.QuotationId}"
                });
            }
        }

        // Sort by date descending
        _activities = _activities.OrderByDescending(a => a.Date).ToList();

        CalcStats();
    }

    private void CalcStats()
    {
        _wonCount = _opportunities.Count(o => o.StageName == "Won" || o.StageName == "تم البيع");
        _activeTaskCount = _tasks.Count(t => t.Status != "Completed" && t.Status != "Cancelled");
        _pipelineValue = _opportunities
            .Where(o => o.StageName != "Won" && o.StageName != "Lost" && o.StageName != "تم البيع" && o.StageName != "خسارة")
            .Sum(o => o.ExpectedValue ?? 0);
        _winRate = _opportunities.Count > 0 ? (int)Math.Round((double)_wonCount / _opportunities.Count * 100) : 0;

        if (_interactions.Any())
            _lastContactDate = _interactions.Max(i => i.InteractionDate);

        var next = _interactions
            .Where(i => i.NextFollowUpDate.HasValue && i.NextFollowUpDate.Value.Date >= DateTime.Today)
            .OrderBy(i => i.NextFollowUpDate)
            .FirstOrDefault();
        if (next != null && next.NextFollowUpDate.HasValue)
            _nextFollowUp = next.NextFollowUpDate.Value;

        _stageGroups = _opportunities
            .GroupBy(o => new { o.StageName, o.StageColor })
            .Select(g => new StageGroup(g.Key.StageName ?? "أخرى", g.Key.StageColor ?? "#94a3b8", g.Count()))
            .OrderByDescending(g => g.Count)
            .ToList();
    }

    // ═══ SEARCH ═══
    private CancellationTokenSource? _searchCts;

    private async Task OnSearchKeyV1(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { _searchQuery = ""; _searchResults = new(); return; }

        _searchCts?.Cancel();
        if (string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Trim().Length < 2)
        {
            _searchResults = new();
            return;
        }

        _searchCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(300, _searchCts.Token);
            await SearchCustomers();
        }
        catch (TaskCanceledException) { }
    }

    private void ToggleSearch()
    {
        _showSearch = !_showSearch;
        if (_showSearch) { _searchQuery = ""; _searchResults = new(); }
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { _showSearch = false; return; }
        if (e.Key == "Enter") { await SearchCustomers(); return; }
        await SearchCustomers();
    }

    private async Task SearchCustomers()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Trim().Length < 2)
        { _searchResults = new(); return; }

        _searching = true; StateHasChanged();
        try
        {
            var q = _searchQuery.Trim().ToLower();
            using var db = await DbFactory.CreateDbContextAsync();
            _searchResults = await db.Parties.AsNoTracking()
                .Where(p => p.PartyName != null &&
                            (p.PartyName.ToLower().Contains(q) ||
                             (p.Phone != null && p.Phone.Contains(q))))
                .OrderBy(p => p.PartyName)
                .Take(30)
                .Select(p => new PartyListDto
                {
                    PartyId = p.PartyId,
                    PartyName = p.PartyName,
                    Phone = p.Phone,
                    City = p.City,
                    CustomerStage = p.CustomerStage
                })
                .ToListAsync();
        }
        catch { _searchResults = new(); }
        finally { _searching = false; StateHasChanged(); }
    }

