            bool hasPermission = user.IsInRole("Admin") || 
                                 user.HasClaim("Permission", "frmClientCard:View") || 
                                 user.HasClaim("Permission", "frm_PartiesList:View");

            if (!hasPermission)
            {
                Snackbar.Add("عذراً، لا تمتلك صلاحية للوصول لبيانات العملاء في الـ CRM.", Severity.Error);
