    // ──────────────────────────────────────────────────
    //  Sorting
    // ──────────────────────────────────────────────────
    private static readonly string[] _sortCycle = { "newest", "oldest", "value_high", "overdue_first" };

    private string GetColumnSort(int stageId) => _columnSort.GetValueOrDefault(stageId, "newest");

    private void CycleSort(int stageId)
    {
        var current = GetColumnSort(stageId);
        var idx = Array.IndexOf(_sortCycle, current);
        _columnSort[stageId] = _sortCycle[(idx + 1) % _sortCycle.Length];
        StateHasChanged();
    }

    private static string GetSortLabel(string sort) => sort switch
    {
        "oldest" => "الأقدم", "value_high" => "الأعلى قيمة", "overdue_first" => "المتأخرة أولاً", _ => "الأحدث"
    };

    private static string GetSortIcon(string sort) => sort switch
    {
        "oldest" => Icons.Material.Rounded.ArrowUpward,
        "value_high" => Icons.Material.Rounded.AttachMoney,
        "overdue_first" => Icons.Material.Rounded.NotificationImportant,
        _ => Icons.Material.Rounded.ArrowDownward
    };

    private List<KanbanCardDto> GetSortedCards(KanbanColumnDto col)
    {
        var cards = col.Cards?.ToList() ?? new();
        var sort = GetColumnSort(col.StageId);
        return sort switch
        {
            "oldest" => cards.OrderBy(c => c.OpportunityId).ToList(),
            "value_high" => cards.OrderByDescending(c => c.ExpectedValue ?? 0).ToList(),
            "overdue_first" => cards.OrderByDescending(c => c.IsOverdue).ThenBy(c => c.NextFollowUpDate).ToList(),
            _ => cards.OrderByDescending(c => c.OpportunityId).ToList()
        };
    }

