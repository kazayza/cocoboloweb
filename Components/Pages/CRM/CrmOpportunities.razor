@page "/crm/opportunities"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@inject IOpportunityService OppService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject AuthenticationStateProvider AuthProvider

@implements IDisposable

<PageTitle>الفرص البيعية — CRM</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <MudProgressCircular Color="MudColor.Secondary" Size="MudSize.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Class="loading-text">جاري تحميل الفرص...</MudText>
    </div>
}
else
{
<div dir="rtl" class="opp-page">

    @* ═══ HEADER ═══ *@
    <div class="opp-header">
        <div class="hdr-bg">
            <div class="hdr-gradient"></div>
            <div class="hdr-dots"></div>
            <div class="hdr-glow hdr-glow1"></div>
            <div class="hdr-glow hdr-glow2"></div>
        </div>
        <div class="hdr-body">
            <div class="hdr-top">
                <div class="hdr-title-area">
                    <div class="hdr-icon">
                        <MudIcon Icon="@Icons.Material.Rounded.TrackChanges" Style="font-size:1.6rem" />
                    </div>
                    <div>
                        <h1 class="hdr-h1">الفرص البيعية</h1>
                        <p class="hdr-sub">خط أنابيب المبيعات — <strong>@_stats.TotalCount</strong> فرصة</p>
                    </div>
                </div>
                <div class="hdr-actions">
                    <div class="view-sw">
                        <button class="sw-btn @(_viewMode==ViewMode.Kanban?"sw-on":"")"
                                @onclick="async () => await SetView(ViewMode.Kanban)">
                            <MudIcon Icon="@Icons.Material.Rounded.ViewKanban" Size="MudSize.Small" />
                            <span class="sw-label">كانبان</span>
                        </button>
                        <button class="sw-btn @(_viewMode==ViewMode.Grid?"sw-on":"")"
                                @onclick="() => SetView(ViewMode.Grid)">
                            <MudIcon Icon="@Icons.Material.Rounded.GridView" Size="MudSize.Small" />
                            <span class="sw-label">بطاقات</span>
                        </button>
                        <button class="sw-btn @(_viewMode==ViewMode.Table?"sw-on":"")"
                                @onclick="() => SetView(ViewMode.Table)">
                            <MudIcon Icon="@Icons.Material.Rounded.ViewList" Size="MudSize.Small" />
                            <span class="sw-label">جدول</span>
                        </button>
                    </div>
                    @if (_canAdd)
                    {
                        <button class="btn-add" @onclick="GoToNew">
                            <MudIcon Icon="@Icons.Material.Rounded.Add" Size="MudSize.Small" />
                            فرصة جديدة
                        </button>
                    }
                </div>
            </div>

            <div class="kpi-row">
                <div class="kpi" @onclick="() => QuickFilter(null)">
                    <div class="kpi-ico" style="background:rgba(99,102,241,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.Layers" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.TotalCount</span>
                        <span class="kpi-lbl">إجمالي</span>
                    </div>
                </div>
                <div class="kpi" @onclick='() => QuickFilter("open")'>
                    <div class="kpi-ico" style="background:rgba(59,130,246,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.FolderOpen" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.OpenCount</span>
                        <span class="kpi-lbl">مفتوحة</span>
                    </div>
                </div>
                <div class="kpi" @onclick='() => QuickFilter("won")'>
                    <div class="kpi-ico" style="background:rgba(16,185,129,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.EmojiEvents" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.WonCount</span>
                        <span class="kpi-lbl">مربوحة</span>
                    </div>
                </div>
                <div class="kpi" @onclick='() => QuickFilter("lost")'>
                    <div class="kpi-ico" style="background:rgba(239,68,68,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.HeartBroken" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.LostCount</span>
                        <span class="kpi-lbl">خسارة</span>
                    </div>
                </div>
                <div class="kpi @(_stats.OverdueFollowUpCount > 0 ? "kpi-alert" : "")" @onclick="TogO">
                    <div class="kpi-ico" style="background:rgba(245,158,11,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.NotificationImportant" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@_stats.OverdueFollowUpCount</span>
                        <span class="kpi-lbl">متأخرة</span>
                    </div>
                    @if (_stats.OverdueFollowUpCount > 0) { <span class="kpi-dot"></span> }
                </div>
                <div class="kpi">
                    <div class="kpi-ico" style="background:rgba(139,92,246,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.AccountBalanceWallet" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@FormatMoney(_stats.PipelineValue)</span>
                        <span class="kpi-lbl">Pipeline</span>
                    </div>
                </div>
                <div class="kpi">
                    <div class="kpi-ico" style="background:rgba(16,185,129,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@(_stats.TotalCount > 0 ? Math.Round((decimal)_stats.WonCount / _stats.TotalCount * 100, 0) : 0)%</span>
                        <span class="kpi-lbl">التحويل</span>
                    </div>
                </div>
                <div class="kpi">
                    <div class="kpi-ico" style="background:rgba(59,130,246,0.25)">
                        <MudIcon Icon="@Icons.Material.Rounded.AttachMoney" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-info">
                        <span class="kpi-num">@FormatMoney(_stats.OpenCount > 0 ? _stats.PipelineValue / _stats.OpenCount : 0)</span>
                        <span class="kpi-lbl">متوسط القيمة</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ═══ SEARCH ═══ *@
    <div class="search-bar">
        <MudTextField T="string" Placeholder="🔍 ابحث بالاسم أو الهاتف أو الموظف..."
                      Variant="MudVariant.Outlined" Dense="true"
                      Value="_filter.SearchText" ValueChanged="OnSearchChanged" Immediate="true"
                      Class="search-input" />
        <div class="search-chips">
            <button class="chip-btn @(_filter.IsOverdueFollowUp==true?"chip-on":"")" @onclick="TogO">⚠️ متأخرة</button>
            <button class="chip-btn @(_filter.HasFollowUp==true?"chip-on":"")" @onclick="TogF">📅 متابعة</button>
            <button class="chip-btn @(_filterIsNew==true?"chip-on":"")" @onclick="TogNew">🆕 جدد</button>
            @if (_hasFilters)
            {
                <button class="chip-btn chip-clear" @onclick="ResetFilters">✕ مسح الكل</button>
            }
        </div>
    </div>

    @* ═══ FILTERS ═══ *@
    <div class="filter-bar">
        <div class="filter-row">
            <MudSelect T="int?" Label="المرحلة" Variant="MudVariant.Outlined"
                       @bind-Value="_filter.StageId" Dense="true" Class="f-item"
                       Clearable="true" AnchorOrigin="Origin.BottomCenter">
                @foreach (var s in _stages)
                {
                    <MudSelectItem Value="@((int?)s.StageId)">
                        <span style="color:@(s.StageColor ?? "#666")">●</span> @(s.StageNameAr ?? s.StageName)
                    </MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" Label="الموظف" Variant="MudVariant.Outlined"
                       @bind-Value="_filter.EmployeeId" Dense="true" Class="f-item"
                       Clearable="true" AnchorOrigin="Origin.BottomCenter">
                @foreach (var e in _activeEmployees)
                {
                    <MudSelectItem Value="@((int?)e.EmployeeId)">@e.FullName</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" Label="المصدر" Variant="MudVariant.Outlined"
                       @bind-Value="_filter.SourceId" Dense="true" Class="f-item"
                       Clearable="true" AnchorOrigin="Origin.BottomCenter">
                @foreach (var s in _sources)
                {
                    <MudSelectItem Value="@((int?)s.SourceId)">@(s.SourceNameAr ?? s.SourceName)</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" Label="التواصل" Variant="MudVariant.Outlined"
                       @bind-Value="_filterStatusId" Dense="true" Class="f-item"
                       Clearable="true" AnchorOrigin="Origin.BottomCenter">
                @foreach (var s in _statuses)
                {
                    <MudSelectItem Value="@((int?)s.StatusId)">@(s.StatusNameAr ?? s.StatusName)</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" Label="الحملة" Variant="MudVariant.Outlined"
                       @bind-Value="_filterAdTypeId" Dense="true" Class="f-item"
                       Clearable="true" AnchorOrigin="Origin.BottomCenter">
                @foreach (var a in _adTypes)
                {
                    <MudSelectItem Value="@((int?)a.AdTypeId)">@(a.AdTypeNameAr ?? a.AdTypeName)</MudSelectItem>
                }
            </MudSelect>
            <MudDatePicker Label="من" Variant="MudVariant.Outlined"
                           Date="_filter.DateFrom" DateChanged="d => _filter.DateFrom = d"
                           Dense="true" Class="f-date" />
            <MudDatePicker Label="إلى" Variant="MudVariant.Outlined"
                           Date="_filter.DateTo" DateChanged="d => _filter.DateTo = d"
                           Dense="true" Class="f-date" />
            <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary"
                       OnClick="ApplyFilters" Size="MudSize.Small"
                       StartIcon="@Icons.Material.Rounded.FilterList">تصفية</MudButton>
        </div>
    </div>

    @* ═══ KANBAN ═══ *@
    @if (_viewMode == ViewMode.Kanban)
    {
        @if (_isLoadingData) { <div class="load-bar"></div> }

        <div class="kanban-board">
            @if (_filteredKanban.Columns.Any())
            {
                @foreach (var col in _filteredKanban.Columns)
                {
                    var sortedCards = GetSortedCards(col);
                    var isExpanded = _expandedColumns.Contains(col.StageId);
                    var isMerged = col.StageId == -1;

                    List<KanbanCardDto> displayCards;
                    if (isMerged)
                    {
                        if (_mergedFilter == "lost")
                            displayCards = sortedCards.Where(c => c.StageId == 4).ToList();
                        else if (_mergedFilter == "noint")
                            displayCards = sortedCards.Where(c => c.StageId == 5).ToList();
                        else
                            displayCards = sortedCards;
                    }
                    else
                    {
                        displayCards = sortedCards;
                    }

                    var visibleCards = isExpanded ? displayCards : displayCards.Take(20).ToList();
                    var hasMore = displayCards.Count > 20 && !isExpanded;

                    <div class="kanban-col @(_dragOverStageId == col.StageId ? "kcol-over" : "")"
                         style="@(isMerged ? "border-color:#94a3b840" : $"border-color:{col.StageColor}25")"
                         @ondrop="() => OnDrop(col.StageId)"
                         @ondragenter="() => _dragOverStageId = col.StageId">

                        <div class="kcol-head" style="border-bottom:3px solid @(isMerged ? "#94a3b8" : col.StageColor)">
                            <div class="kcol-left">
                                <span class="kcol-dot" style="background:@(isMerged ? "#94a3b8" : col.StageColor)"></span>
                                <span class="kcol-name">@(col.StageNameAr)</span>
                                <span class="kcol-badge">@displayCards.Count</span>
                            </div>
                            <div class="kcol-right">
                                <span class="kcol-val">@FormatMoney(displayCards.Sum(c => c.ExpectedValue ?? 0))</span>
                                <button class="kcol-sort" @onclick="() => CycleSort(col.StageId)"
                                        title="@GetSortLabel(GetColumnSort(col.StageId))">
                                    <MudIcon Icon="@GetSortIcon(GetColumnSort(col.StageId))" Style="font-size:0.9rem" />
                                </button>
                            </div>
                        </div>

                        @if (isMerged)
                        {
                            <div class="kcol-sub">
                                <button class="sub-btn @(_mergedFilter==null?"sub-on":"")"
                                        @onclick="SetMergedAll">الكل</button>
                                <button class="sub-btn @(_mergedFilter=="lost"?"sub-on-lost":"")"
                                        @onclick="SetMergedLost">خسارة</button>
                                <button class="sub-btn @(_mergedFilter=="noint"?"sub-on-ni":"")"
                                        @onclick="SetMergedNoint">غير مهتم</button>
                            </div>
                        }

                        <div class="kcol-body">
                            @foreach (var card in visibleCards)
                            {
                                var cardColor = _stages.FirstOrDefault(s => s.StageId == card.StageId)?.StageColor ?? "#94a3b8";
                                var isLost = card.StageId == 4;
                                var isNotInterested = card.StageId == 5;
                                var daysSince = DaysSince(card.CreatedAt);

                                <div class="kcard @(card.IsOverdue ? "kcard-overdue" : "") @(isLost ? "kcard-lost" : "") @(isNotInterested ? "kcard-notint" : "")"
                                     style="--cc:@(card.IsOverdue ? "#ef4444" : cardColor)"
                                     draggable="true"
                                     @ondragstart="() => OnDragStart(card)"
                                     @ondragend="OnDragEnd"
                                     @onclick="() => GoToDetail(card.OpportunityId)">

                                    @* ═══ TOOLTIP ═══ *@
                                    <div class="kcard-tip">
                                        <div class="tt-header">📋 ملخص @card.ClientName</div>
                                        <div class="tt-row">
                                            <span>📅 تاريخ الإنشاء</span>
                                            <span>@card.CreatedAt.ToString("yyyy/MM/dd")</span>
                                        </div>
                                        <div class="tt-row">
                                            <span>⏳ منذ</span>
                                            <span>@(daysSince >= 0 ? $"{daysSince} يوم" : "—")</span>
                                        </div>
                                        <div class="tt-row">
                                            <span>💬 التفاعلات</span>
                                            <span>@card.InteractionsCount</span>
                                        </div>
                                        <div class="tt-row">
                                            <span>📋 المهام</span>
                                            <span>@card.TasksCount</span>
                                        </div>
                                        <div class="tt-row">
                                            <span>💰 القيمة المتوقعة</span>
                                            <span>@FormatMoney(card.ExpectedValue ?? 0) ج.م</span>
                                        </div>
                                        @if (card.NextFollowUpDate.HasValue)
                                        {
                                            <div class="tt-row @(card.IsOverdue ? "tt-overdue" : "")">
                                                <span>📅 المتابعة القادمة</span>
                                                <span>@card.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                                            </div>
                                        }
                                        <div class="tt-row">
                                            <span>👤 المسؤول</span>
                                            <span>@(card.EmployeeName ?? "—")</span>
                                        </div>
                                    </div>

                                    <div class="kcard-top">
                                        <span class="kcard-name">@card.ClientName</span>
                                        <div class="kcard-badges">
                                            @if (card.IsOverdue)
                                            {
                                                <span class="kcard-badge-over">متأخر</span>
                                            }
                                            @if (isLost)
                                            {
                                                <span class="kcard-badge-lost">خسارة</span>
                                            }
                                            else if (isNotInterested)
                                            {
                                                <span class="kcard-badge-ni">غير مهتم</span>
                                            }
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(card.InterestedProduct))
                                    {
                                        <div class="kcard-product">🏷️ @card.InterestedProduct</div>
                                    }

                                    <div class="kcard-prog">
                                        @foreach (var ms in _mainStages)
                                        {
                                            var curOrder = _stages.FirstOrDefault(s => s.StageId == card.StageId)?.StageOrder ?? 0;
                                            var isPast = ms.StageOrder < curOrder;
                                            var isCurrent = ms.StageId == card.StageId;
                                            <span class="prog-dot @(isCurrent?"prog-cur":"") @(isPast?"prog-done":"")"
                                                  style="--pc:@(ms.StageColor ?? "#94a3b8")"></span>
                                        }
                                    </div>

                                    <div class="kcard-mid">
                                        <span class="kcard-money">@FormatMoney(card.ExpectedValue ?? 0) ج.م</span>
                                        @if (card.NextFollowUpDate.HasValue)
                                        {
                                            <span class="kcard-date @(card.IsOverdue?"text-danger":"")">
                                                📅 @card.NextFollowUpDate.Value.ToString("dd/MM")
                                            </span>
                                        }
                                    </div>

                                    <div class="kcard-foot">
                                        <span class="kcard-emp">👤 @(card.EmployeeName ?? "—")</span>
                                        <div class="kcard-foot-right">
                                            @if (daysSince >= 0)
                                            {
                                                <span class="kcard-days @(daysSince > 7 ? "text-danger" : "")">⏳ @daysSince يوم</span>
                                            }
                                            <span class="kcard-counts">💬@card.InteractionsCount · 📋@card.TasksCount</span>
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (hasMore)
                            {
                                <button class="kcol-more" @onclick="() => _expandedColumns.Add(col.StageId)">
                                    + @(displayCards.Count - 20) أخري
                                </button>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state" style="width:100%">
                    <MudIcon Icon="@Icons.Material.Rounded.ViewKanban" Size="MudSize.Large" />
                    <span>لا توجد فرص تطابق البحث</span>
                </div>
            }
        </div>
    }

    @* ═══ GRID ═══ *@
    @if (_viewMode == ViewMode.Grid)
    {
        @if (_isLoadingData) { <div class="load-bar"></div> }

        <div class="opp-grid">
            @foreach (var o in _pagedResult.Items)
            {
                var daysSince = DaysSince(o.CreatedAt);

                <div class="opp-card" @onclick="() => GoToDetail(o.OpportunityId)">
                    <div class="card-bar" style="background:@(o.StageColor ?? "#94a3b8")"></div>
                    <div class="card-body">
                        <div class="card-row-top">
                            <span class="card-name">@o.ClientName</span>
                            <span class="stage-chip"
                                  style="background:@(o.StageColor ?? "#94a3b8")14;color:@(o.StageColor ?? "#94a3b8");border:1px solid @(o.StageColor ?? "#94a3b8")35">
                                @(o.StageNameAr ?? o.StageName)
                            </span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(o.InterestedProduct))
                        {
                            <div class="card-product">🏷️ @o.InterestedProduct</div>
                        }
                        <div class="card-meta">
                            <span>👤 @(o.EmployeeName ?? "—")</span>
                            @if (o.SourceName != null)
                            {
                                <span>📡 @o.SourceName</span>
                            }
                        </div>
                        <div class="card-prog">
                            @foreach (var ms in _mainStages)
                            {
                                var curOrder = _stages.FirstOrDefault(s => s.StageId == o.StageId)?.StageOrder ?? 0;
                                var isPast = ms.StageOrder < curOrder;
                                var isCurrent = ms.StageId == o.StageId;
                                <span class="prog-dot @(isCurrent?"prog-cur":"") @(isPast?"prog-done":"")"
                                      style="--pc:@(ms.StageColor ?? "#94a3b8")"></span>
                            }
                        </div>
                        <div class="card-metrics">
                            <span class="cm-val">💰 @FormatMoney(o.ExpectedValue ?? 0)</span>
                            <span class="cm-date @(o.FollowUpStatus=="Overdue"?"text-danger":"")">
                                📅 @(o.NextFollowUpDate?.ToString("dd/MM") ?? "—")
                            </span>
                            @if (daysSince >= 0)
                            {
                                <span class="cm-days @(daysSince > 7 ? "text-danger" : "")">⏳@daysSince يوم</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer" @onclick:stopPropagation="true">
                        <span class="cf-date">@o.CreatedAt.ToString("yyyy/MM/dd")</span>
                        <div class="cf-btns">
                            <button class="action-btn action-contact" title="تواصل سريع"
                                    @onclick="() => QuickContact(o.OpportunityId, o.Phone)">
                                <MudIcon Icon="@Icons.Material.Rounded.Quickreply" Size="MudSize.Small" />
                            </button>
                            <MudIconButton Icon="@Icons.Material.Rounded.Phone"
                                           Size="MudSize.Small" OnClick="() => CallPhone(o.Phone)" />
                            <MudIconButton Icon="@Icons.Custom.Brands.WhatsApp"
                                           Size="MudSize.Small" OnClick="() => OpenWhatsApp(o.Phone)" />
                            @if (_canEdit)
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                               Size="MudSize.Small" OnClick="() => GoToEdit(o.OpportunityId)" />
                            }
                        </div>
                    </div>
                </div>
            }
            @if (!_pagedResult.Items.Any())
            {
                <div class="empty-state" style="grid-column:1/-1">
                    <MudIcon Icon="@Icons.Material.Rounded.SearchOff" Size="MudSize.Large" />
                    <span>لا توجد فرص تطابق البحث</span>
                </div>
            }
        </div>

        @if (_pagedResult.TotalPages > 1)
        {
            <div class="pager">
                <MudIconButton Icon="@Icons.Material.Rounded.ChevronRight"
                               OnClick="() => GoToPage(_filter.PageNumber - 1)"
                               Disabled="@(!_pagedResult.HasPrevious)" />
                <span>صفحة @_pagedResult.PageNumber من @_pagedResult.TotalPages · @_pagedResult.TotalCount فرصة</span>
                <MudIconButton Icon="@Icons.Material.Rounded.ChevronLeft"
                               OnClick="() => GoToPage(_filter.PageNumber + 1)"
                               Disabled="@(!_pagedResult.HasNext)" />
            </div>
        }
    }

    @* ═══ TABLE ═══ *@
    @if (_viewMode == ViewMode.Table)
    {
        @if (_isLoadingData) { <div class="load-bar"></div> }

        <div class="tbl-toolbar">
            <span class="tbl-info">@_pagedResult.TotalCount فرصة</span>
            <div class="tbl-col-toggle">
                <button class="col-toggle-btn" @onclick="() => _showColMenu = !_showColMenu">
                    <MudIcon Icon="@Icons.Material.Rounded.ViewColumn" Style="font-size:1.1rem" />
                    أعمدة
                </button>
                @if (_showColMenu)
                {
                    <div class="col-menu">
                        @foreach (var cd in _colDefs)
                        {
                            <label class="col-menu-item">
                                <input type="checkbox" checked="@_tableCols[cd.Key]"
                                       @onchange="e => { _tableCols[cd.Key] = (bool)(e.Value ?? false); StateHasChanged(); }" />
                                @cd.Label
                            </label>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="tbl-wrap">
            <table class="tbl">
                <thead>
                    <tr>
                        @if (_tableCols["client"])   { <th>العميل</th> }
                        @if (_tableCols["phone"])    { <th>الهاتف</th> }
                        @if (_tableCols["stage"])    { <th>المرحلة</th> }
                        @if (_tableCols["employee"]) { <th>الموظف</th> }
                        @if (_tableCols["source"])   { <th>المصدر</th> }
                        @if (_tableCols["product"])  { <th>المنتج</th> }
                        @if (_tableCols["value"])    { <th>القيمة</th> }
                        @if (_tableCols["followup"]) { <th>المتابعة</th> }
                        @if (_tableCols["activity"]) { <th>النشاط</th> }
                        @if (_tableCols["date"])     { <th>التاريخ</th> }
                        <th style="width:120px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in _pagedResult.Items)
                    {
                        <tr class="tbl-row" @onclick="() => GoToDetail(o.OpportunityId)">
                            @if (_tableCols["client"])   { <td><strong class="tbl-client">@o.ClientName</strong></td> }
                            @if (_tableCols["phone"])    { <td class="tbl-ltr">@o.Phone</td> }
                            @if (_tableCols["stage"])
                            {
                                <td>
                                    <span class="stage-chip"
                                          style="background:@(o.StageColor ?? "#94a3b8")14;color:@(o.StageColor ?? "#94a3b8");border:1px solid @(o.StageColor ?? "#94a3b8")35">
                                        @(o.StageNameAr ?? o.StageName)
                                    </span>
                                </td>
                            }
                            @if (_tableCols["employee"]) { <td>@(o.EmployeeName ?? "—")</td> }
                            @if (_tableCols["source"])   { <td>@(o.SourceName ?? "—")</td> }
                            @if (_tableCols["product"])  { <td>@(o.InterestedProduct ?? "—")</td> }
                            @if (_tableCols["value"])    { <td class="tbl-ltr tbl-money">@FormatMoney(o.ExpectedValue ?? 0)</td> }
                            @if (_tableCols["followup"])
                            {
                                <td class="@(o.FollowUpStatus=="Overdue"?"text-danger":"")">
                                    @(o.NextFollowUpDate?.ToString("dd/MM") ?? "—")
                                </td>
                            }
                            @if (_tableCols["activity"]) { <td>💬@o.InteractionsCount · 📋@o.TasksCount</td> }
                            @if (_tableCols["date"])     { <td>@o.CreatedAt.ToString("yyyy/MM/dd")</td> }
                            <td @onclick:stopPropagation="true">
                                <div class="tbl-actions">
                                    <button class="action-btn action-contact" title="تواصل سريع"
                                            @onclick="() => QuickContact(o.OpportunityId, o.Phone)">
                                        <MudIcon Icon="@Icons.Material.Rounded.Quickreply" Style="font-size:1rem" />
                                    </button>
                                    <MudIconButton Icon="@Icons.Custom.Brands.WhatsApp"
                                                   Size="MudSize.Small" OnClick="() => OpenWhatsApp(o.Phone)" />
                                    @if (_canEdit)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Rounded.Edit"
                                                       Size="MudSize.Small" OnClick="() => GoToEdit(o.OpportunityId)" />
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_pagedResult.TotalPages > 1)
        {
            <div class="pager">
                <MudIconButton Icon="@Icons.Material.Rounded.ChevronRight"
                               OnClick="() => GoToPage(_filter.PageNumber - 1)"
                               Disabled="@(!_pagedResult.HasPrevious)" />
                <span>صفحة @_pagedResult.PageNumber من @_pagedResult.TotalPages · @_pagedResult.TotalCount فرصة</span>
                <MudIconButton Icon="@Icons.Material.Rounded.ChevronLeft"
                               OnClick="() => GoToPage(_filter.PageNumber + 1)"
                               Disabled="@(!_pagedResult.HasNext)" />
            </div>
        }
    }

</div>
}

