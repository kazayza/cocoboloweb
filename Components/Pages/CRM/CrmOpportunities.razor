@code {
    private bool _isLoading = true, _isLoadingData, _canView, _canAdd, _canEdit, _canDelete;
    private string? _currentUserName;
    private OpportunityFilterDto _filter = new() { IsActive = true };
    private PagedResult<OpportunityListDto> _pagedResult = new();
    private KanbanBoardDto _kanban = new();
    private OpportunityStatsDto _stats = new();
    private List<SalesStage> _stages = new();
    private List<ContactSource> _sources = new();
    private List<InterestCategory> _categories = new();
    private List<AdType> _adTypes = new();
    private List<Employee> _activeEmployees = new();

    private KanbanCardDto? _dragCard;
    private enum ViewMode { Kanban, Grid, Table }
    private ViewMode _viewMode = ViewMode.Kanban;
    private bool _hasFilters => _filter.StageId.HasValue || _filter.EmployeeId.HasValue || _filter.SourceId.HasValue
        || _filter.CategoryId.HasValue || _filter.MinValue.HasValue || _filter.MaxValue.HasValue
        || _filter.DateFrom.HasValue || _filter.DateTo.HasValue || _filter.IsOverdueFollowUp == true
        || _filter.HasFollowUp == true || !string.IsNullOrWhiteSpace(_filter.SearchText);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync(); var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";
            _canView = user.HasClaim("Permission","frmOpportunities:View") || user.IsInRole("Admin");
            _canAdd = user.HasClaim("Permission","frmOpportunities:Add") || user.IsInRole("Admin");
            _canEdit = user.HasClaim("Permission","frmOpportunities:Edit") || user.IsInRole("Admin");
            _canDelete = user.HasClaim("Permission","frmOpportunities:Delete") || user.IsInRole("Admin");
            if (!_canView) { Navigation.NavigateTo("/"); return; }
            _stages = await OppService.GetStagesAsync();
            _sources = await OppService.GetSourcesAsync();
            _categories = await OppService.GetCategoriesAsync();
            _adTypes = await OppService.GetAdTypesAsync();
            _activeEmployees = await OppService.GetActiveEmployeesAsync();
            await RefreshAll();
        }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _isLoading = false; }
    }

    private async Task RefreshAll()
    {
        _isLoadingData = true; StateHasChanged();
        try { _kanban = await OppService.GetKanbanBoardAsync(_filter); _pagedResult = await OppService.GetOpportunitiesAsync(_filter); _stats = await OppService.GetStatsAsync(_filter); }
        catch { }
        _isLoadingData = false; StateHasChanged();
    }

    private async Task ApplyFilters() { _filter.PageNumber = 1; await RefreshAll(); }
    private async Task ResetFilters() { _filter = new() { IsActive = true }; await RefreshAll(); }
    private async Task TogO() { _filter.IsOverdueFollowUp = _filter.IsOverdueFollowUp == true ? null : true; await RefreshAll(); }
    private async Task TogF() { _filter.HasFollowUp = _filter.HasFollowUp == true ? null : true; await RefreshAll(); }
    private async Task GoToPage(int p) { _filter.PageNumber = p; _isLoadingData = true; StateHasChanged(); _pagedResult = await OppService.GetOpportunitiesAsync(_filter); _isLoadingData = false; StateHasChanged(); }
    private void SetView(ViewMode v) { _viewMode = v; if (v != ViewMode.Kanban) _ = RefreshAll(); else _ = RefreshKanban(); }
    private async Task RefreshKanban() { _kanban = await OppService.GetKanbanBoardAsync(_filter); }

    private async Task OnDrop(int newStageId)
    {
        if (_dragCard == null || _dragCard.StageId == newStageId) return;
        var card = _dragCard;
        var (ok, msg) = await OppService.MoveStageAsync(card.OpportunityId, newStageId, _currentUserName!);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) { _kanban = await OppService.GetKanbanBoardAsync(_filter); _stats = await OppService.GetStatsAsync(_filter); StateHasChanged(); }
    }

    private void HandleDragOver(DragEventArgs e) { e.DataTransfer.EffectAllowed = "move"; }

    // Navigation
    private void GoToNew() => Navigation.NavigateTo("/crm/opportunities/new");
    private void GoToEdit(int id) => Navigation.NavigateTo($"/crm/opportunities/{id}");
    private void GoToDetail(int id) => Navigation.NavigateTo($"/crm/opportunities/{id}");

    private async Task OpenWhatsApp(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return;
        var clean = new string(phone.Where(char.IsDigit).ToArray());
        if (clean.StartsWith("0")) clean = "2" + clean; if (!clean.StartsWith("2")) clean = "2" + clean;
        await JS.InvokeVoidAsync("open", $"https://wa.me/{clean}", "_blank");
    }
    private async Task CallPhone(string? phone) { if (!string.IsNullOrWhiteSpace(phone)) await JS.InvokeVoidAsync("open", $"tel:{phone}", "_self"); }

    private static string FormatMoney(decimal v) => v switch { >= 1_000_000 => $"{v/1_000_000:N1}M", >= 1_000 => $"{v/1_000:N1}K", _ => $"{v:N0}" };
}