        .search-bar { flex-wrap:wrap; }
        .search-chips { flex-wrap:wrap; }
        .filter-row { gap:0.4rem; }
        .f-item,.f-date { min-width:100%!important; width:100%!important; flex:100%; }
        .kanban-col { min-width:250px; flex:0 0 250px; }
    }
    @@media (max-width:500px) { .hdr-h1 { font-size:1.15rem; } .kpi-row { grid-template-columns:1fr 1fr; } }
</style>

@code {
    private bool _isLoading = true;
    private bool _isRefreshing;
    private bool _isLoadingData;
    private bool _canView, _canAdd, _canEdit, _canDelete;
    private string? _currentUserName;

    private OpportunityFilterDto _filter = new() { IsActive = true };
    private PagedResult<OpportunityListDto> _pagedResult = new();
    private KanbanBoardDto _kanbanRaw = new();
    private KanbanBoardDto _filteredKanban = new();
    private OpportunityStatsDto _stats = new();

    private List<SalesStage> _stages = new();
    private List<ContactSource> _sources = new();
    private List<ContactStatus> _statuses = new();
    private List<InterestCategory> _categories = new();
    private List<AdType> _adTypes = new();
    private List<Employee> _activeEmployees = new();

    private int? _filterStatusId;
    private int? _filterAdTypeId;
    private bool? _filterIsNew;
    private string? _mergedFilter;

    private KanbanCardDto? _dragCard;
    private int? _dragOverStageId;

    private Dictionary<int, string> _columnSort = new();
    private HashSet<int> _expandedColumns = new();

    private bool _showColMenu;
    private Dictionary<string, bool> _tableCols = new()
    {
        {"client",true},{"phone",true},{"stage",true},{"employee",true},
        {"source",true},{"product",false},{"value",true},{"followup",true},
        {"activity",false},{"date",true}
    };
    private readonly (string Key, string Label)[] _colDefs =
    {
        ("client","العميل"),("phone","الهاتف"),("stage","المرحلة"),("employee","الموظف"),
        ("source","المصدر"),("product","المنتج"),("value","القيمة"),("followup","المتابعة"),
        ("activity","النشاط"),("date","التاريخ")
    };

    private System.Timers.Timer? _searchTimer;

    private enum ViewMode { Kanban, Grid, Table }
    private ViewMode _viewMode = ViewMode.Kanban;

    private List<SalesStage> _mainStages => _stages.Where(s => s.StageId != 4 && s.StageId != 5).OrderBy(s => s.StageOrder).ToList();

    private bool _hasFilters =>
        _filter.StageId.HasValue || _filter.EmployeeId.HasValue ||
        _filter.SourceId.HasValue || _filterStatusId.HasValue || _filterAdTypeId.HasValue ||
        _filter.DateFrom.HasValue || _filter.DateTo.HasValue ||
        _filter.IsOverdueFollowUp == true || _filter.HasFollowUp == true ||
        _filterIsNew == true ||
        !string.IsNullOrWhiteSpace(_filter.SearchText);

    private static string NormalizeArabic(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return "";
        var s = input;
        var diacritics = "\u064B\u064C\u064D\u064E\u064F\u0650\u0651\u0652\u0653\u0654\u0655\u0656";
        s = new string(s.Where(c => !diacritics.Contains(c)).ToArray());
        s = s.Replace('أ', 'ا').Replace('إ', 'ا').Replace('آ', 'ا').Replace('ٱ', 'ا');
        s = s.Replace('ة', 'ه');
        s = s.Replace('ى', 'ي');
        s = s.Replace('\u0640', ' ');
        return s.ToLower().Trim();
    }

    private static bool SmartMatch(string? text, string search)
    {
        if (string.IsNullOrWhiteSpace(text)) return false;
        return NormalizeArabic(text).Contains(NormalizeArabic(search));
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";
            _canView   = user.HasClaim("Permission", "frmNewInteraction:View")   || user.IsInRole("Admin");
            _canAdd    = user.HasClaim("Permission", "frmNewInteraction:Add")    || user.IsInRole("Admin");
            _canEdit   = user.HasClaim("Permission", "frmNewInteraction:Edit")   || user.IsInRole("Admin");
            _canDelete = user.HasClaim("Permission", "frmNewInteraction:Delete") || user.IsInRole("Admin");

            if (!_canView) { Navigation.NavigateTo("/"); return; }

            _stages         = await OppService.GetStagesAsync();
            _sources        = await OppService.GetSourcesAsync();
            _statuses       = await OppService.GetContactStatusesAsync();
            _categories     = await OppService.GetCategoriesAsync();
            _adTypes        = await OppService.GetAdTypesAsync();
            _activeEmployees = await OppService.GetActiveEmployeesAsync();

            await RefreshAll();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("setupKanbanDnD");
            }
            catch { }
        }
    }

    private async Task RefreshAll()
    {
        if (_isRefreshing) return;
        _isRefreshing = true;
        _isLoadingData = true;
        StateHasChanged();

        try
        {
            _stats = await OppService.GetStatsAsync(_filter);

            if (_viewMode == ViewMode.Kanban)
            {
                _kanbanRaw = await OppService.GetKanbanBoardAsync(_filter);
                _filteredKanban = ApplyClientFilters(_kanbanRaw);
            }
            else
            {
                _pagedResult = await OppService.GetOpportunitiesAsync(_filter);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingData = false;
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    private KanbanBoardDto ApplyClientFilters(KanbanBoardDto raw)
    {
        var result = new KanbanBoardDto();
        var search = _filter.SearchText?.Trim() ?? "";

        foreach (var col in raw.Columns)
        {
            if (col.StageId == 5) continue;

            var cards = col.StageId == 4
                ? raw.Columns.Where(c => c.StageId == 4 || c.StageId == 5).SelectMany(c => c.Cards).AsEnumerable()
                : col.Cards.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(search))
                cards = cards.Where(c => SmartMatch(c.ClientName, search) || SmartMatch(c.Phone, search) || SmartMatch(c.EmployeeName, search) || SmartMatch(c.InterestedProduct, search));

            if (_filter.StageId.HasValue)
                cards = cards.Where(c => c.StageId == _filter.StageId.Value);

            if (_filter.EmployeeId.HasValue)
                cards = cards.Where(c => c.EmployeeId == _filter.EmployeeId.Value);

            if (_filter.SourceId.HasValue)
                cards = cards.Where(c => c.SourceId == _filter.SourceId.Value);

            if (_filter.IsOverdueFollowUp == true)
                cards = cards.Where(c => c.IsOverdue);

            if (_filter.HasFollowUp == true)
                cards = cards.Where(c => c.NextFollowUpDate.HasValue);

            if (_filter.DateFrom.HasValue)
{
    var from = _filter.DateFrom.Value.Date;
    cards = cards.Where(c => c.CreatedAt >= from);
}

if (_filter.DateTo.HasValue)
{
    var toExclusive = _filter.DateTo.Value.Date.AddDays(1);
    cards = cards.Where(c => c.CreatedAt < toExclusive);
}

            var filteredList = cards.ToList();

            var stageColor = col.StageColor ?? "#94a3b8";
            var stageNameAr = col.StageNameAr ?? col.StageName;

            if (col.StageId == 4)
            {
                stageColor = "#94a3b8";
                stageNameAr = "مغلق / خاسر";
            }

            result.Columns.Add(new KanbanColumnDto
            {
                StageId = col.StageId == 4 ? -1 : col.StageId,
                StageName = col.StageName,
                StageNameAr = stageNameAr,
                StageColor = stageColor,
                Cards = filteredList,
                Count = filteredList.Count,
                Value = filteredList.Sum(c => c.ExpectedValue ?? 0)
            });
        }

        return result;
    }

    private void OnSearchChanged(string value)
    {
        _filter.SearchText = value;
        _searchTimer?.Stop();
        _searchTimer?.Dispose();
        _searchTimer = new System.Timers.Timer(350);
        _searchTimer.Elapsed += async (_, _) =>
        {
            _searchTimer?.Dispose();
            _searchTimer = null;
            _filter.PageNumber = 1;
            await InvokeAsync(async () =>
            {
                if (_viewMode == ViewMode.Kanban)
                {
                    _filteredKanban = ApplyClientFilters(_kanbanRaw);
                    StateHasChanged();
                }
                else
                {
                    await RefreshAll();
                }
            });
        };
        _searchTimer.AutoReset = false;
        _searchTimer.Start();
    }

    private async Task ApplyFilters() { _filter.PageNumber = 1; await RefreshAll(); }

    private async Task ResetFilters()
    {
        _filter = new() { IsActive = true };
        _filterStatusId = null;
        _filterAdTypeId = null;
        _filterIsNew = null;
        _mergedFilter = null;
        await RefreshAll();
    }

    private async Task TogO()
    {
        _filter.IsOverdueFollowUp = _filter.IsOverdueFollowUp == true ? null : true;
        _filter.PageNumber = 1;
        await RefreshAll();
    }

    private async Task TogF()
    {
        _filter.HasFollowUp = _filter.HasFollowUp == true ? null : true;
        _filter.PageNumber = 1;
        await RefreshAll();
    }

    private async Task TogNew()
    {
        _filterIsNew = _filterIsNew == true ? null : true;
        if (_filterIsNew == true)
        {
            _filter.DateFrom = DateTime.Today.AddDays(-7);
            _filter.DateTo = DateTime.Today;
        }
        else
        {
            _filter.DateFrom = null;
            _filter.DateTo = null;
        }
        _filter.PageNumber = 1;
        await RefreshAll();
    }

    private void SetMergedAll()   { _mergedFilter = null;   StateHasChanged(); }
    private void SetMergedLost()  { _mergedFilter = "lost";  StateHasChanged(); }
    private void SetMergedNoint() { _mergedFilter = "noint"; StateHasChanged(); }

    private async Task QuickFilter(string? type)
    {
        _filter = new() { IsActive = true };
        _filterStatusId = null;
        _filterAdTypeId = null;
        _filterIsNew = null;
        _mergedFilter = null;
        switch (type)
        {
            case "won":  _filter.StageId = 3; break;
            case "lost": _filter.StageId = 4; break;
        }
        await RefreshAll();
    }

    private async Task SetView(ViewMode v) { _viewMode = v; await RefreshAll(); }

    private async Task GoToPage(int p)
    {
        _filter.PageNumber = p;
        _isLoadingData = true;
        StateHasChanged();
        _pagedResult = await OppService.GetOpportunitiesAsync(_filter);
        _isLoadingData = false;
        StateHasChanged();
    }

    private static readonly string[] _sortCycle = { "newest", "oldest", "value_high", "overdue_first" };

    private string GetColumnSort(int stageId) => _columnSort.GetValueOrDefault(stageId, "newest");

    private void CycleSort(int stageId)
    {
        var current = GetColumnSort(stageId);
        var idx = Array.IndexOf(_sortCycle, current);
        _columnSort[stageId] = _sortCycle[(idx + 1) % _sortCycle.Length];
        StateHasChanged();
    }

    private static string GetSortLabel(string sort) => sort switch
    {
        "oldest" => "الأقدم", "value_high" => "الأعلى قيمة", "overdue_first" => "المتأخرة أولاً", _ => "الأحدث"
    };

    private static string GetSortIcon(string sort) => sort switch
    {
        "oldest" => Icons.Material.Rounded.ArrowUpward,
        "value_high" => Icons.Material.Rounded.AttachMoney,
        "overdue_first" => Icons.Material.Rounded.NotificationImportant,
        _ => Icons.Material.Rounded.ArrowDownward
    };

    private List<KanbanCardDto> GetSortedCards(KanbanColumnDto col)
    {
        var cards = col.Cards?.ToList() ?? new();
        var sort = GetColumnSort(col.StageId);
        return sort switch
        {
            "oldest" => cards.OrderBy(c => c.OpportunityId).ToList(),
            "value_high" => cards.OrderByDescending(c => c.ExpectedValue ?? 0).ToList(),
            "overdue_first" => cards.OrderByDescending(c => c.IsOverdue).ThenBy(c => c.NextFollowUpDate).ToList(),
            _ => cards.OrderByDescending(c => c.OpportunityId).ToList()
        };
    }

    private void OnDragStart(KanbanCardDto card) { _dragCard = card; }
    private void OnDragEnd() { _dragCard = null; _dragOverStageId = null; }

    private async Task OnDrop(int colStageId)
    {
        _dragOverStageId = null;
        if (_dragCard == null) return;

        var isMerged = colStageId == -1;
        var targetStageId = isMerged
            ? (_dragCard.StageId == 5 ? 5 : 4)
            : colStageId;

        if (_dragCard.StageId == targetStageId)
        {
            _dragCard = null;
            return;
        }

        var card = _dragCard;
        _dragCard = null;

        var newStage = _stages.FirstOrDefault(s => s.StageId == targetStageId);
        var stageName = newStage?.StageNameAr ?? newStage?.StageName ?? "";

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"هل تريد نقل \"{card.ClientName}\" إلى \"{stageName}\"؟");
        if (!confirmed) return;

        var (ok, msg) = await OppService.MoveStageAsync(card.OpportunityId, targetStageId, _currentUserName!);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok) await RefreshAll();
    }

    private void QuickContact(int opportunityId, string? phone)
    {
        Snackbar.Add("سيتم تفعيل التواصل السريع قريبًا", Severity.Info);
    }

    private void GoToNew()    => Navigation.NavigateTo("/crm/opportunities/new");
    private void GoToEdit(int id)  => Navigation.NavigateTo($"/crm/opportunities/{id}/edit");
    private void GoToDetail(int id) => Navigation.NavigateTo($"/crm/opportunities/{id}");

    private async Task OpenWhatsApp(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return;
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        if (digits.StartsWith("0")) digits = "20" + digits[1..];
        else if (!digits.StartsWith("20")) digits = "20" + digits;
        await JS.InvokeVoidAsync("open", $"https://wa.me/{digits}", "_blank");
    }

    private async Task CallPhone(string? phone)
    {
        if (!string.IsNullOrWhiteSpace(phone))
            await JS.InvokeVoidAsync("open", $"tel:{phone}", "_self");
    }

    private static string FormatMoney(decimal v) => v switch
    {
        >= 1_000_000 => $"{v / 1_000_000:N1}M",
        >= 1_000 => $"{v / 1_000:N1}K",
        _ => $"{v:N0}"
    };

    private static int DaysSince(DateTime date)
    {
        if (date == default) return -1;
        return (int)(DateTime.Today - date.Date).TotalDays;
    }

    public void Dispose() { _searchTimer?.Dispose(); _dragCard = null; }
}