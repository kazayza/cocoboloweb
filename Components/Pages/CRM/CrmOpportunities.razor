    private void OnDragStart(KanbanCardDto card) { _dragCard = card; }
    private void OnDragEnd() { _dragCard = null; _dragOverStageId = null; }

    private async Task OnDrop(int colStageId)
    {
        _dragOverStageId = null;
        if (_dragCard == null) return;

        var isMerged = colStageId == -1;
        var targetStageId = isMerged
            ? (_dragCard.StageId == 5 ? 5 : 4)
            : colStageId;

        if (_dragCard.StageId == targetStageId)
        {
            _dragCard = null;
            return;
        }

        var card = _dragCard;
        _dragCard = null;

        var newStage = _stages.FirstOrDefault(s => s.StageId == targetStageId);
        var stageName = newStage?.StageNameAr ?? newStage?.StageName ?? "";

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"هل تريد نقل \"{card.ClientName}\" إلى \"{stageName}\"؟");
        if (!confirmed) return;

        var (ok, msg) = await OppService.MoveStageAsync(card.OpportunityId, targetStageId, _currentUserName!);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);

        if (ok) await RefreshAll();
    }

