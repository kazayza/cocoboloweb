    private void OnSearchChanged(string value)
    {
        _filter.SearchText = value;
        _searchTimer?.Stop();
        _searchTimer?.Dispose();
        _searchTimer = new System.Timers.Timer(350);
        _searchTimer.Elapsed += async (_, _) =>
        {
            _searchTimer?.Dispose();
            _searchTimer = null;
            _filter.PageNumber = 1;
            await InvokeAsync(async () =>
            {
                if (_viewMode == ViewMode.Kanban)
                {
                    _filteredKanban = ApplyClientFilters(_kanbanRaw);
                    StateHasChanged();
                }
                else
                {
                    await RefreshAll();
                }
            });
        };
        _searchTimer.AutoReset = false;
        _searchTimer.Start();
    }

