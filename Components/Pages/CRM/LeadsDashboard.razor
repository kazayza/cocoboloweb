    private string GetFunnelWidth(decimal pct) => Math.Max(pct, 15m).ToString("F0");

    private string GetPlatformClass(string? platform) => platform switch
    {
        "fb" => "platform-fb",
        "ig" => "platform-ig",
        _ => "platform-default"
    };

    private string GetConvRateClass(decimal rate) => rate switch
    {
        >= 20m => "conv-high",
        >= 10m => "conv-mid",
        _ => "conv-low"
    };

    private static string FormatMoney(decimal value)
    {
        if (value >= 1_000_000m) return $"{(value / 1_000_000m).ToString("F1")}M";
        if (value >= 1_000m) return $"{(value / 1_000m).ToString("F1")}K";
        return value.ToString("N0");
    }

    private static Chart MakeChart(string fontFamily, bool stacked = false)
    {
        return new Chart
        {
            FontFamily = fontFamily,
            Background = "transparent",
            Toolbar = new Toolbar { Show = false },
            Stacked = stacked,
            StackType = stacked ? StackType.Normal : null
        };
    }

