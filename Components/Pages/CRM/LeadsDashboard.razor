        catch { _employees = new(); }
    }

    private async Task LoadData()
{
    _isLoading = true;
    _loadError = null;
    await InvokeAsync(StateHasChanged);

    try
    {
        _data = await LeadsService
            .GetDashboardDataAsync(_filter)
            .WaitAsync(TimeSpan.FromSeconds(30));
    }
    catch (TimeoutException)
    {
        _loadError = "تحميل بيانات لوحة Leads استغرق أكثر من 30 ثانية. غالبًا يوجد استعلام بطيء في قاعدة البيانات.";
        Snackbar.Add(_loadError, Severity.Warning);
    }
    catch (Exception ex)
    {
        _loadError = ex.GetBaseException().Message;
        Snackbar.Add("تعذّر تحميل بيانات اللوحة: " + _loadError, Severity.Error);
    }
    finally
    {
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }
}

    // ═══════════════════════════════════════
    //           PERIOD & FILTERS
    // ═══════════════════════════════════════

    private async Task SelectPeriod(string period)
{
    _selectedPeriod = period;

    var today = DateTime.Today;

    switch (period)
    {
        case "today":
            _filter.DateFrom = today;
            _filter.DateTo = today;
            break;

        case "week":
            _filter.DateFrom = today.AddDays(-(int)today.DayOfWeek);
            _filter.DateTo = today;
            break;

        case "month":
            _filter.DateFrom = new DateTime(today.Year, today.Month, 1);
            _filter.DateTo = today;
            break;

        case "quarter":
            var qMonth = ((today.Month - 1) / 3) * 3 + 1;
            _filter.DateFrom = new DateTime(today.Year, qMonth, 1);
            _filter.DateTo = today;
            break;

        case "year":
            _filter.DateFrom = new DateTime(today.Year, 1, 1);
            _filter.DateTo = today;
            break;

        case "all":
            _filter.DateFrom = null;
            _filter.DateTo = null;
            break;

        case "custom":
            return;
    }

    await LoadData();
}

    private async Task ApplyCustomPeriod()
    {
        await LoadData();
    }

    private async Task SetPlatform(string? platform)
{
    _filter.Platform = platform;
    await LoadData();
}

    private async Task ResetAllFilters()
{
    _filter = new LeadsDashboardFilterDto();
    _showAdvanced = false;
    await SelectPeriod("month");
}

