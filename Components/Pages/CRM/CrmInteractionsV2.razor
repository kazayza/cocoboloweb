@page "/crm/interactions/V2"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using ClosedXML.Excel
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IInteractionService InteractionService
@inject IOpportunityService OppService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

<PageTitle>سجل التواصلات — CRM Premium</PageTitle>

@if (_loading)
{
    <div class="loading-screen">
        <MudProgressCircular Color="MudColor.Secondary" Size="MudSize.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Class="mt-3">جاري تحميل سجل التواصلات...</MudText>
    </div>
}
else
{
<div dir="rtl" class="interactions-page">

    @* ═══ PREMIUM HEADER ═══ *@
    <div class="premium-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-pattern"></div>
            <div class="header-orb orb-1"></div>
            <div class="header-orb orb-2"></div>
        </div>
        <div class="header-content">
            <div class="header-top">
                <div class="header-title">
                    <div class="title-icon">
                        <MudIcon Icon="@Icons.Material.Rounded.Forum" Size="MudSize.Large" />
                        <div class="icon-pulse"></div>
                    </div>
                    <div>
                        <h1>سجل التواصلات</h1>
                        <p>إدارة كاملة لتفاعلات العملاء مع بحث ذكي وفلاتر متقدمة</p>
                    </div>
                </div>
                <div class="header-actions">
                    <MudButton Variant="Variant.Filled" Color="MudColor.Primary" 
                               StartIcon="@Icons.Material.Rounded.FileDownload"
                               OnClick="ExportExcel" Disabled="!_canExport">
                        تصدير Excel
                    </MudButton>
                </div>
            </div>

            @* KPI CARDS *@
            <div class="kpi-grid">
                <div class="kpi-card">
                    <div class="kpi-icon" style="background:rgba(99,102,241,.15);color:#6366f1">
                        <MudIcon Icon="@Icons.Material.Rounded.ChatBubble" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.TotalInteractions.ToString("N0")</span>
                        <span class="kpi-label">إجمالي التفاعلات</span>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon" style="background:rgba(16,185,129,.15);color:#10b981">
                        <MudIcon Icon="@Icons.Material.Rounded.Today" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.TodayCount</span>
                        <span class="kpi-label">اليوم</span>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon" style="background:rgba(59,130,246,.15);color:#3b82f6">
                        <MudIcon Icon="@Icons.Material.Rounded.CalendarViewWeek" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.WeekCount</span>
                        <span class="kpi-label">هذا الأسبوع</span>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon" style="background:rgba(245,158,11,.15);color:#f59e0b">
                        <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.StageChanges%</span>
                        <span class="kpi-label">تغيير مرحلة</span>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon" style="background:rgba(239,68,68,.15);color:#ef4444">
                        <MudIcon Icon="@Icons.Material.Rounded.NotificationImportant" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.NoFollowUp</span>
                        <span class="kpi-label">بدون متابعة</span>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon" style="background:rgba(139,92,246,.15);color:#8b5cf6">
                        <MudIcon Icon="@Icons.Material.Rounded.Groups" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.UniqueClients</span>
                        <span class="kpi-label">عملاء مميزون</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ═══ SMART FILTERS ═══ *@
    <MudPaper Class="filter-paper" Elevation="0">
        <div class="filter-header" @onclick="() => _filtersExpanded = !_filtersExpanded">
            <div class="filter-title">
                <MudIcon Icon="@Icons.Material.Rounded.FilterAlt" />
                <span>فلاتر متقدمة</span>
                @if (_hasActiveFilters)
                {
                    <MudChip T="string" Size="MudSize.Small" Color="MudColor.Primary" Variant="Variant.Filled">@_activeFilterCount نشط</MudChip>
                }
            </div>
            <MudIconButton Icon="@(_filtersExpanded ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)" 
                           Size="MudSize.Small" />
        </div>

        <MudCollapse Expanded="_filtersExpanded">
            <div class="filter-body">
                @* البحث الذكي *@
                <div class="filter-row">
                    <div class="search-autocomplete">
                        <MudAutocomplete T="PartySearchDto" Label="🔍 بحث بالعميل أو الهاتف"
                                         @bind-Value="_selectedParty"
                                         SearchFunc="SearchParties"
                                         ToStringFunc="@(p => p == null ? "" : p.DisplayText)"
                                         Variant="Variant.Outlined" Dense="true"
                                         Clearable="true" Immediate="true"
                                         AdornmentIcon="@Icons.Material.Rounded.PersonSearch"
                                         OnClearButtonClick="ClearPartyFilter">
                            <ItemTemplate Context="party">
                                <div class="party-item">
                                    <div class="party-avatar">@party.NameInitial</div>
                                    <div class="party-info">
                                        <div class="party-name">@party.PartyName</div>
                                        <div class="party-phone">@party.PhoneDisplay</div>
                                    </div>
                                    <div class="party-meta">@party.LastInteractionDays يوم</div>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </div>
                    <MudTextField T="string" Label="بحث في المحتوى" Variant="Variant.Outlined"
                                  @bind-Value="_filter.SearchText" Dense="true"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                                  Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="ApplyFilters" />
                </div>

                <div class="filter-row">
                    <MudSelect T="int?" Label="المصدر" Variant="Variant.Outlined" @bind-Value="_filter.SourceId" Dense="true" Clearable="true">
                        @foreach (var s in _sources)
                        {
                            <MudSelectItem Value="@((int?)s.SourceId)">@s.SourceName</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" Label="الحملة الإعلانية" Variant="Variant.Outlined" @bind-Value="_filter.AdTypeId" Dense="true" Clearable="true">
                        @foreach (var a in _adTypes)
                        {
                            <MudSelectItem Value="@((int?)a.AdTypeId)">@(a.AdTypeNameAr ?? a.AdTypeName)</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" Label="طريقة التواصل" Variant="Variant.Outlined" @bind-Value="_filter.StatusId" Dense="true" Clearable="true">
                        @foreach (var st in _statuses)
                        {
                            <MudSelectItem Value="@((int?)st.StatusId)">@(st.StatusNameAr ?? st.StatusName)</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" Label="الموظف" Variant="Variant.Outlined" @bind-Value="_filter.EmployeeId" Dense="true" Clearable="true">
                        @foreach (var e in _employees)
                        {
                            <MudSelectItem Value="@((int?)e.EmployeeId)">@e.FullName</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <div class="filter-row">
                    <MudSelect T="int?" Label="المرحلة قبل" Variant="Variant.Outlined" @bind-Value="_filter.StageBeforeId" Dense="true" Clearable="true">
                        @foreach (var s in _stages)
                        {
                            <MudSelectItem Value="@((int?)s.StageId)">
                                <div style="display:flex;align-items:center;gap:6px">
                                    <span style="width:10px;height:10px;border-radius:50%;background:@(s.StageColor ?? "#999")"></span>
                                    @(s.StageNameAr ?? s.StageName)
                                </div>
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int?" Label="المرحلة بعد" Variant="Variant.Outlined" @bind-Value="_filter.StageAfterId" Dense="true" Clearable="true">
                        @foreach (var s in _stages)
                        {
                            <MudSelectItem Value="@((int?)s.StageId)">
                                <div style="display:flex;align-items:center;gap:6px">
                                    <span style="width:10px;height:10px;border-radius:50%;background:@(s.StageColor ?? "#999")"></span>
                                    @(s.StageNameAr ?? s.StageName)
                                </div>
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudDatePicker Label="من تاريخ" Variant="Variant.Outlined" @bind-Date="_filter.DateFrom" Dense="true" />
                    <MudDatePicker Label="إلى تاريخ" Variant="Variant.Outlined" @bind-Date="_filter.DateTo" Dense="true" />
                </div>

                <div class="filter-actions">
                    <div class="quick-filters">
                        <MudChip T="string" OnClick="() => SetQuickDate(0)" Variant="@(_quickDate==0?Variant.Filled:Variant.Outlined)" Color="MudColor.Primary" Size="MudSize.Small">اليوم</MudChip>
                        <MudChip T="string" OnClick="() => SetQuickDate(7)" Variant="@(_quickDate==7?Variant.Filled:Variant.Outlined)" Color="MudColor.Primary" Size="MudSize.Small">7 أيام</MudChip>
                        <MudChip T="string" OnClick="() => SetQuickDate(30)" Variant="@(_quickDate==30?Variant.Filled:Variant.Outlined)" Color="MudColor.Primary" Size="MudSize.Small">30 يوم</MudChip>
                        <MudChip T="string" OnClick="() => FilterStageChanges()" Variant="@(_filterStageChange?Variant.Filled:Variant.Outlined)" Color="MudColor.Secondary" Size="MudSize.Small">تغيير مرحلة فقط</MudChip>
                    </div>
                    <div>
                        <MudButton Variant="Variant.Filled" Color="MudColor.Primary" OnClick="ApplyFilters" StartIcon="@Icons.Material.Rounded.Search">بحث</MudButton>
                        <MudButton Variant="Variant.Text" Color="MudColor.Default" OnClick="ResetFilters" StartIcon="@Icons.Material.Rounded.Clear">مسح</MudButton>
                    </div>
                </div>
            </div>
        </MudCollapse>
    </MudPaper>

    @* ═══ VIEW TOGGLE ═══ *@
    <div class="view-toolbar">
        <div class="view-tabs">
            <button class="view-tab @(_viewMode==ViewMode.Timeline?"active":"")" @onclick="() => SetView(ViewMode.Timeline)">
                <MudIcon Icon="@Icons.Material.Rounded.Timeline" Size="MudSize.Small" /> تايملاين
            </button>
            <button class="view-tab @(_viewMode==ViewMode.Table?"active":"")" @onclick="() => SetView(ViewMode.Table)">
                <MudIcon Icon="@Icons.Material.Rounded.TableRows" Size="MudSize.Small" /> جدول
            </button>
            <button class="view-tab @(_viewMode==ViewMode.Cards?"active":"")" @onclick="() => SetView(ViewMode.Cards)">
                <MudIcon Icon="@Icons.Material.Rounded.GridView" Size="MudSize.Small" /> كروت
            </button>
        </div>
        <div class="view-info">
            <span>@_paged.TotalCount تفاعل</span>
            <MudSelect T="int" Value="_filter.PageSize" ValueChanged="ChangePageSize" Dense="true" Variant="Variant.Outlined" Class="page-size">
                <MudSelectItem Value="25">25</MudSelectItem>
                <MudSelectItem Value="50">50</MudSelectItem>
                <MudSelectItem Value="100">100</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    @if (_isLoadingData)
    {
        <MudProgressLinear Color="MudColor.Primary" Indeterminate="true" Class="mb-3" />
    }

    @* ═══ TIMELINE VIEW ═══ *@
    @if (_viewMode == ViewMode.Timeline)
    {
        <div class="timeline-view">
            @foreach (var group in _groupedInteractions)
            {
                <div class="timeline-date-group">
                    <div class="date-header">
                        <span class="date-label">@FormatGroupDate(group.Key)</span>
                        <span class="date-count">@group.Count() تفاعل</span>
                    </div>
                    @foreach (var item in group)
                    {
                        <div class="timeline-item" @onclick="() => OpenOpportunity(item.OpportunityId)">
                            <div class="timeline-dot" style="background:@(item.StageAfterColor ?? item.StageBeforeColor ?? "#94a3b8")"></div>
                            <MudPaper Class="timeline-card" Elevation="0">
                                <div class="card-header">
                                    <div class="client-info">
                                        <div class="client-avatar">@GetInitials(item.ClientName)</div>
                                        <div>
                                            <div class="client-name">@item.ClientName</div>
                                            <div class="client-phone">@item.Phone @if(!string.IsNullOrEmpty(item.AllPhones) && item.AllPhones != item.Phone){<span class="more-phones">+@(item.AllPhones.Split(',').Length-1)</span>}</div>
                                        </div>
                                    </div>
                                    <div class="card-time">
                                        @item.InteractionTime?.ToString(@"hh\:mm")
                                        <MudIcon Icon="@GetStatusIcon(item.StatusName)" Size="MudSize.Small" Title="@item.StatusNameAr" />
                                    </div>
                                </div>
                                
                                @if (!string.IsNullOrWhiteSpace(item.Summary))
                                {
                                    <div class="card-summary">@item.Summary</div>
                                }

                                @if (item.StageBeforeId != item.StageAfterId)
                                {
                                    <div class="stage-change">
                                        <span class="stage-before" style="--c:@(item.StageBeforeColor ?? "#999")">@(item.StageBeforeNameAr ?? item.StageBeforeName)</span>
                                        <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="MudSize.Small" />
                                        <span class="stage-after" style="--c:@(item.StageAfterColor ?? "#999")">@(item.StageAfterNameAr ?? item.StageAfterName)</span>
                                    </div>
                                }

                                <div class="card-footer">
                                    <div class="footer-tags">
                                        @if (item.SourceName != null)
                                        {
                                            <span class="tag tag-source">📡 @item.SourceName</span>
                                        }
                                        @if (item.AdTypeNameAr != null)
                                        {
                                            <span class="tag tag-campaign">🎯 @item.AdTypeNameAr</span>
                                        }
                                        @if (item.NextFollowUpDate.HasValue)
                                        {
                                            <span class="tag tag-followup">📅 @item.NextFollowUpDate.Value.ToString("dd/MM")</span>
                                        }
                                    </div>
                                    <div class="footer-user">👤 @item.EmployeeName</div>
                                </div>
                            </MudPaper>
                        </div>
                    }
                </div>
            }
            @if (!_paged.Items.Any())
            {
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Rounded.SearchOff" Size="MudSize.Large" />
                    <h3>لا توجد تفاعلات</h3>
                    <p>جرب تغيير الفلاتر أو البحث</p>
                </div>
            }
        </div>
    }

    @* ═══ TABLE VIEW ═══ *@
    @if (_viewMode == ViewMode.Table)
    {
        <MudPaper Class="table-paper" Elevation="0">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>التاريخ</th>
                        <th>العميل</th>
                        <th>الهاتف</th>
                        <th>الملخص</th>
                        <th>المرحلة</th>
                        <th>المصدر</th>
                        <th>الحملة</th>
                        <th>الموظف</th>
                        <th>المتابعة</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _paged.Items)
                    {
                        <tr @onclick="() => OpenOpportunity(item.OpportunityId)">
                            <td>
                                <div class="cell-date">
                                    <div>@item.InteractionDate.ToString("yyyy/MM/dd")</div>
                                    <div class="cell-time">@item.InteractionTime?.ToString(@"hh\:mm")</div>
                                </div>
                            </td>
                            <td><strong>@item.ClientName</strong></td>
                            <td class="ltr">@item.Phone</td>
                            <td><div class="cell-summary">@Truncate(item.Summary, 60)</div></td>
                            <td>
                                @if (item.StageBeforeId != item.StageAfterId)
                                {
                                    <div class="cell-stage-change">
                                        <span style="color:@(item.StageAfterColor)">@(item.StageAfterNameAr ?? item.StageAfterName)</span>
                                    </div>
                                }
                                else
                                {
                                    <span style="color:@(item.StageAfterColor)">@(item.StageAfterNameAr ?? "—")</span>
                                }
                            </td>
                            <td>@item.SourceName</td>
                            <td>@item.AdTypeNameAr</td>
                            <td>@item.EmployeeName</td>
                            <td>@(item.NextFollowUpDate?.ToString("dd/MM") ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </MudPaper>
    }

    @* ═══ CARDS VIEW ═══ *@
    @if (_viewMode == ViewMode.Cards)
    {
        <div class="cards-grid">
            @foreach (var item in _paged.Items)
            {
                <MudPaper Class="interaction-card" Elevation="0" @onclick="() => OpenOpportunity(item.OpportunityId)">
                    <div class="card-accent" style="background:@(item.StageAfterColor ?? "#6366f1")"></div>
                    <div class="card-top">
                        <div class="card-client">
                            <div class="client-avatar sm">@GetInitials(item.ClientName)</div>
                            <div>
                                <div class="name">@item.ClientName</div>
                                <div class="phone ltr">@item.Phone</div>
                            </div>
                        </div>
                        <MudIcon Icon="@GetStatusIcon(item.StatusName)" Size="MudSize.Small" />
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrWhiteSpace(item.Summary))
                        {
                            <p>@Truncate(item.Summary, 100)</p>
                        }
                        @if (item.StageBeforeId != item.StageAfterId)
                        {
                            <div class="mini-stage">
                                <span>@item.StageBeforeNameAr</span> → <strong style="color:@(item.StageAfterColor)">@item.StageAfterNameAr</strong>
                            </div>
                        }
                    </div>
                    <div class="card-bottom">
                        <span>@item.InteractionDate.ToString("dd/MM") @item.InteractionTime?.ToString(@"hh\:mm")</span>
                        <span>@item.EmployeeName</span>
                    </div>
                </MudPaper>
            }
        </div>
    }

    @* PAGINATION *@
    @if (_paged.TotalPages > 1)
    {
        <div class="pagination-bar">
            <MudPagination Count="_paged.TotalPages" Selected="_filter.PageNumber" SelectedChanged="GoToPage" 
                           Color="MudColor.Primary" Size="MudSize.Medium" ShowFirstButton="true" ShowLastButton="true" />
        </div>
    }

    @* زر العودة للأعلى *@
<div class="scroll-top-fab" @onclick="ScrollToTop">
    <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Rounded.KeyboardArrowUp" Size="Size.Medium" />
</div>

</div>
}

<style>
    .interactions-page { padding: 0 1.5rem 3rem; max-width: 1400px; margin: 0 auto; }
    .loading-screen { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:60vh; gap:1rem; }

    /* PREMIUM HEADER */
    .premium-header { position:relative; border-radius:24px; overflow:hidden; margin-bottom:1.5rem; box-shadow:0 10px 40px rgba(8,145,178,.2); }
    .header-bg { position:absolute; inset:0; }
    .header-gradient { position:absolute; inset:0; background:linear-gradient(135deg,#0891b2 0%,#06b6d4 50%,#22d3ee 100%); }
    .header-pattern { position:absolute; inset:0; opacity:.1; background-image:radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size:24px 24px; }
    .header-orb { position:absolute; border-radius:50%; filter:blur(60px); }
    .orb-1 { width:200px; height:200px; background:rgba(255,255,255,.2); top:-50px; right:-30px; }
    .orb-2 { width:150px; height:150px; background:rgba(255,255,255,.15); bottom:-40px; left:10%; }
    .header-content { position:relative; z-index:1; padding:2rem; color:white; }
    .header-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem; }
    .header-title { display:flex; gap:1rem; align-items:center; }
    .title-icon { position:relative; width:56px; height:56px; background:rgba(255,255,255,.15); backdrop-filter:blur(10px); border-radius:16px; display:flex; align-items:center; justify-content:center; border:1px solid rgba(255,255,255,.2); }
    .icon-pulse { position:absolute; inset:-4px; border-radius:18px; border:2px solid rgba(255,255,255,.3); animation:pulse 2s infinite; }
    @@keyframes pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.05);opacity:.7} }
    .header-title h1 { margin:0; font-size:1.75rem; font-weight:800; }
    .header-title p { margin:.25rem 0 0; opacity:.9; font-size:.95rem; }

    .kpi-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:.75rem; }
    .kpi-card { background:rgba(255,255,255,.12); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,.15); border-radius:14px; padding:1rem; display:flex; align-items:center; gap:.75rem; transition:all .2s; }
    .kpi-card:hover { background:rgba(255,255,255,.18); transform:translateY(-2px); }
    .kpi-icon { width:42px; height:42px; border-radius:10px; display:flex; align-items:center; justify-content:center; }
    .kpi-data { display:flex; flex-direction:column; }
    .kpi-value { font-size:1.4rem; font-weight:800; line-height:1; }
    .kpi-label { font-size:.75rem; opacity:.85; margin-top:.15rem; }

    /* FILTERS */
    .filter-paper { border-radius:16px; border:1px solid var(--mud-palette-lines-default); margin-bottom:1rem; overflow:hidden; }
    .filter-header { padding:.85rem 1.25rem; display:flex; justify-content:space-between; align-items:center; cursor:pointer; background:var(--mud-palette-background); border-bottom:1px solid var(--mud-palette-lines-default); }
    .filter-title { display:flex; align-items:center; gap:.5rem; font-weight:700; }
    .filter-body { padding:1.25rem; }
    .filter-row { display:grid; grid-template-columns:repeat(4,1fr); gap:.75rem; margin-bottom:.75rem; }
    .filter-row:first-child { grid-template-columns:2fr 1fr; }
    .search-autocomplete { grid-column:span 1; }
    .filter-actions { display:flex; justify-content:space-between; align-items:center; margin-top:1rem; padding-top:1rem; border-top:1px solid var(--mud-palette-lines-default); }
    .quick-filters { display:flex; gap:.4rem; }

    .party-item { display:flex; align-items:center; gap:.75rem; padding:.5rem 0; }
    .party-avatar { width:36px; height:36px; border-radius:50%; background:var(--mud-palette-primary); color:white; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.85rem; }
    .party-info { flex:1; }
    .party-name { font-weight:600; font-size:.9rem; }
    .party-phone { font-size:.75rem; color:var(--mud-palette-text-secondary); direction:ltr; text-align:right; }
    .party-meta { font-size:.7rem; color:var(--mud-palette-text-disabled); }

    /* VIEW TOOLBAR */
    .view-toolbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem; }
    .view-tabs { display:flex; background:var(--mud-palette-background); border:1px solid var(--mud-palette-lines-default); border-radius:10px; padding:3px; gap:3px; }
    .view-tab { display:flex; align-items:center; gap:5px; padding:6px 14px; border:none; background:transparent; border-radius:7px; font-size:.85rem; font-weight:600; cursor:pointer; color:var(--mud-palette-text-secondary); transition:all .15s; }
    .view-tab:hover { background:var(--mud-palette-action-hover); }
    .view-tab.active { background:var(--mud-palette-primary); color:white; }
    .view-info { display:flex; align-items:center; gap:1rem; font-size:.85rem; color:var(--mud-palette-text-secondary); }
    .page-size { width:80px; }

    /* TIMELINE */
    .timeline-view { position:relative; }
    .timeline-date-group { margin-bottom:2rem; }
    .date-header { display:flex; align-items:center; gap:1rem; margin-bottom:1rem; position:sticky; top:0; background:var(--mud-palette-background); z-index:2; padding:.5rem 0; }
    .date-label { font-weight:800; font-size:1rem; color:var(--mud-palette-primary); }
    .date-count { font-size:.75rem; background:var(--mud-palette-lines-default); padding:2px 8px; border-radius:12px; }
    .timeline-item { position:relative; padding-right:2.5rem; padding-bottom:1.25rem; }
    .timeline-dot { position:absolute; right:0; top:.5rem; width:14px; height:14px; border-radius:50%; border:3px solid var(--mud-palette-background); box-shadow:0 0 0 2px currentColor; z-index:1; }
    .timeline-item:not(:last-child)::before { content:''; position:absolute; right:6px; top:1.5rem; bottom:-.25rem; width:2px; background:var(--mud-palette-lines-default); }
    .timeline-card { border:1px solid var(--mud-palette-lines-default); border-radius:14px; padding:1rem; cursor:pointer; transition:all .2s; }
    .timeline-card:hover { box-shadow:0 4px 20px rgba(0,0,0,.08); border-color:var(--mud-palette-primary-lighten); transform:translateX(-2px); }
    .card-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:.6rem; }
    .client-info { display:flex; gap:.75rem; align-items:center; }
    .client-avatar { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,#6366f1,#8b5cf6); color:white; display:flex; align-items:center; justify-content:center; font-weight:700; }
    .client-avatar.sm { width:32px; height:32px; font-size:.8rem; }
    .client-name { font-weight:700; font-size:.95rem; }
    .client-phone { font-size:.8rem; color:var(--mud-palette-text-secondary); direction:ltr; }
    .more-phones { background:var(--mud-palette-info-lighten); color:var(--mud-palette-info-darken); padding:1px 5px; border-radius:4px; font-size:.7rem; margin-right:4px; }
    .card-time { display:flex; align-items:center; gap:.4rem; font-size:.8rem; color:var(--mud-palette-text-secondary); }
    .card-summary { font-size:.9rem; line-height:1.5; margin-bottom:.6rem; color:var(--mud-palette-text-primary); }
    .stage-change { display:flex; align-items:center; gap:.5rem; margin-bottom:.6rem; font-size:.85rem; }
    .stage-before, .stage-after { padding:3px 10px; border-radius:6px; font-weight:600; font-size:.8rem; }
    .stage-before { background:color-mix(in srgb, var(--c) 12%, transparent); color:var(--c); text-decoration:line-through; opacity:.7; }
    .stage-after { background:color-mix(in srgb, var(--c) 15%, transparent); color:var(--c); border:1px solid color-mix(in srgb, var(--c) 30%, transparent); }
    .card-footer { display:flex; justify-content:space-between; align-items:center; padding-top:.6rem; border-top:1px solid var(--mud-palette-lines-inputs); }
    .footer-tags { display:flex; gap:.4rem; flex-wrap:wrap; }
    .tag { font-size:.7rem; padding:2px 7px; border-radius:5px; font-weight:600; }
    .tag-source { background:rgba(59,130,246,.1); color:#3b82f6; }
    .tag-campaign { background:rgba(139,92,246,.1); color:#8b5cf6; }
    .tag-followup { background:rgba(245,158,11,.1); color:#f59e0b; }
    .footer-user { font-size:.75rem; color:var(--mud-palette-text-secondary); }

    /* TABLE */
    .table-paper { border-radius:14px; overflow:hidden; border:1px solid var(--mud-palette-lines-default); }
    .data-table { width:100%; border-collapse:collapse; font-size:.88rem; }
    .data-table thead { background:var(--mud-palette-background); }
    .data-table th { padding:.75rem .9rem; text-align:right; font-weight:700; color:var(--mud-palette-text-secondary); border-bottom:2px solid var(--mud-palette-lines-default); white-space:nowrap; }
    .data-table td { padding:.65rem .9rem; border-bottom:1px solid var(--mud-palette-lines-inputs); }
    .data-table tbody tr { cursor:pointer; transition:background .15s; }
    .data-table tbody tr:hover { background:var(--mud-palette-action-hover); }
    .cell-date { line-height:1.3; }
    .cell-time { font-size:.75rem; color:var(--mud-palette-text-secondary); }
    .cell-summary { max-width:300px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* CARDS */
    .cards-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1rem; }
    .interaction-card { position:relative; border:1px solid var(--mud-palette-lines-default); border-radius:14px; padding:1rem; cursor:pointer; transition:all .2s; overflow:hidden; }
    .interaction-card:hover { transform:translateY(-3px); box-shadow:0 8px 24px rgba(0,0,0,.1); }
    .card-accent { position:absolute; top:0; right:0; left:0; height:3px; }
    .card-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:.75rem; }
    .card-client { display:flex; gap:.6rem; align-items:center; }
    .card-client .name { font-weight:700; font-size:.9rem; }
    .card-client .phone { font-size:.75rem; color:var(--mud-palette-text-secondary); }
    .card-body p { font-size:.85rem; line-height:1.4; margin:0 0 .5rem; color:var(--mud-palette-text-secondary); }
    .mini-stage { font-size:.75rem; padding:.25rem 0; }
    .card-bottom { display:flex; justify-content:space-between; font-size:.7rem; color:var(--mud-palette-text-disabled); padding-top:.5rem; border-top:1px solid var(--mud-palette-lines-inputs); margin-top:.5rem; }

    .empty-state { text-align:center; padding:4rem 2rem; color:var(--mud-palette-text-disabled); }
    .empty-state h3 { margin:1rem 0 .5rem; color:var(--mud-palette-text-secondary); }
    .pagination-bar { display:flex; justify-content:center; margin-top:2rem; }
    .ltr { direction:ltr; text-align:left; }
    .scroll-top-fab {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 1000;
    opacity: 0.9;
    transition: all 0.3s;
}
.scroll-top-fab:hover {
    opacity: 1;
    transform: translateY(-2px);
}

    @@media (max-width:1200px) { .kpi-grid { grid-template-columns:repeat(3,1fr); } .filter-row { grid-template-columns:repeat(2,1fr); } }
    @@media (max-width:768px) { .interactions-page { padding:0 .75rem 2rem; } .header-content { padding:1.25rem; } .kpi-grid { grid-template-columns:repeat(2,1fr); } .filter-row { grid-template-columns:1fr; } .view-toolbar { flex-direction:column; gap:.75rem; align-items:stretch; } }
</style>

@code {
    private bool _loading = true;
    private bool _isLoadingData = false;
    private bool _filtersExpanded = true;
    private bool _canExport = false;
    private string? _currentUser;

    private InteractionFilterDto _filter = new() { PageSize = 25 };
    private PagedResult<InteractionListDto> _paged = new();
    private InteractionStats _stats = new();
    private PartySearchDto? _selectedParty;
    
    private List<ContactSource> _sources = new();
    private List<AdType> _adTypes = new();
    private List<ContactStatus> _statuses = new();
    private List<Employee> _employees = new();
    private List<SalesStage> _stages = new();

    private int _quickDate = 30;
    private bool _filterStageChange = false;

    private enum ViewMode { Timeline, Table, Cards }
    private ViewMode _viewMode = ViewMode.Timeline;

    private bool _hasActiveFilters => _filter.SourceId.HasValue || _filter.AdTypeId.HasValue || _filter.StatusId.HasValue || 
                                      _filter.EmployeeId.HasValue || _filter.StageBeforeId.HasValue || _filter.StageAfterId.HasValue ||
                                      _filter.DateFrom.HasValue || _filter.PartyId.HasValue || !string.IsNullOrWhiteSpace(_filter.SearchText);
    private int _activeFilterCount => new[] { _filter.SourceId, _filter.AdTypeId, _filter.StatusId, _filter.EmployeeId, 
                                               _filter.StageBeforeId, _filter.StageAfterId, _filter.PartyId }
                                               .Count(v => v.HasValue) + 
                                      (_filter.DateFrom.HasValue ? 1 : 0) + 
                                      (!string.IsNullOrWhiteSpace(_filter.SearchText) ? 1 : 0);

    private IEnumerable<IGrouping<DateTime, InteractionListDto>> _groupedInteractions => 
        _paged.Items.GroupBy(i => i.InteractionDate.Date).OrderByDescending(g => g.Key);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _currentUser = auth.User.Identity?.Name;
        _canExport = auth.User.HasClaim("Permission", "frmInteractions:Export") || auth.User.IsInRole("Admin");

        _sources = await OppService.GetSourcesAsync();
        _adTypes = await OppService.GetAdTypesAsync();
        _statuses = await OppService.GetContactStatusesAsync();
        _employees = await OppService.GetActiveEmployeesAsync();
        _stages = await OppService.GetStagesAsync();

        await SetQuickDate(30);
        _loading = false;
    }

    private async Task LoadData()
{
    _isLoadingData = true;
    StateHasChanged();
    
    _paged = await InteractionService.GetInteractionsAsync(_filter);
    
    // نحسب الإحصائيات مرة واحدة فقط أو كل 30 ثانية
    if (_stats.TotalInteractions == 0)
        await CalculateStats();
    
    _isLoadingData = false;
    StateHasChanged();
}

    private async Task CalculateStats()
{
    var today = DateTime.Today;
    var thirtyDaysAgo = today.AddDays(-30);
    
    // نجيب بيانات محدودة فقط للإحصائيات
    var statsData = await InteractionService.GetInteractionsAsync(new InteractionFilterDto 
    { 
        PageSize = 5000,  // بدل 10000
        DateFrom = thirtyDaysAgo 
    });
    
    _stats = new InteractionStats
    {
        TotalInteractions = _paged.TotalCount,
        TodayCount = statsData.Items.Count(i => i.InteractionDate.Date == today),
        WeekCount = statsData.Items.Count(i => i.InteractionDate >= today.AddDays(-7)),
        StageChanges = statsData.Items.Count(i => i.StageBeforeId != i.StageAfterId),
        NoFollowUp = statsData.Items.Count(i => !i.NextFollowUpDate.HasValue),
        UniqueClients = statsData.Items.Select(i => i.PartyId).Distinct().Count()
    };
}

    private async Task ApplyFilters()
    {
        _filter.PageNumber = 1;
        if (_selectedParty != null) _filter.PartyId = _selectedParty.PartyId;
        await LoadData();
    }

    private async Task ResetFilters()
    {
        _filter = new() { PageSize = _filter.PageSize };
        _selectedParty = null;
        _quickDate = 30;
        _filterStageChange = false;
        await SetQuickDate(30);
    }

    private async Task SetQuickDate(int days)
    {
        _quickDate = days;
        _filter.DateFrom = days == 0 ? DateTime.Today : DateTime.Today.AddDays(-days);
        _filter.DateTo = DateTime.Today;
        await ApplyFilters();
    }

    private async Task FilterStageChanges()
    {
        _filterStageChange = !_filterStageChange;
        // سيتم تطبيقه في UI فقط حاليا
        await ApplyFilters();
    }

    private async Task<IEnumerable<PartySearchDto>> SearchParties(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length < 2) return Array.Empty<PartySearchDto>();
        
        // بحث عربي ذكي
        var normalized = NormalizeArabic(value);
        var parties = await OppService.SearchPartiesAsync(value); // نفترض وجود هذه الدالة
        
        return parties.Where(p => 
            NormalizeArabic(p.PartyName).Contains(normalized) || 
            (p.Phone != null && p.Phone.Contains(value)) ||
            (p.Phone2 != null && p.Phone2.Contains(value))
        ).Take(10).Select(p => new PartySearchDto
        {
            PartyId = p.PartyId,
            PartyName = p.PartyName,
            Phone = p.Phone,
            Phone2 =p.Phone2,
            
            LastInteractionDays = (DateTime.Today - (p.LastContactDate ?? DateTime.Today)).Days
        });
    }

    private void ClearPartyFilter() { _selectedParty = null; _filter.PartyId = null; }

    private async Task ChangePageSize(int size) { _filter.PageSize = size; await ApplyFilters(); }
    private async Task GoToPage(int page) { _filter.PageNumber = page; await LoadData(); }
    private void SetView(ViewMode mode) => _viewMode = mode;
    private void OpenOpportunity(int id) => Nav.NavigateTo($"/crm/opportunities/{id}");

    private async Task ExportExcel()
    {
        var allData = await InteractionService.GetInteractionsAsync(new InteractionFilterDto { 
            PageSize = 10000, 
            SearchText = _filter.SearchText,
            SourceId = _filter.SourceId,
            AdTypeId = _filter.AdTypeId,
            // ... كل الفلاتر
        });

        using var wb = new XLWorkbook();
        var ws = wb.Worksheets.Add("التفاعلات");
        
        // Headers
        ws.Cell(1,1).Value = "التاريخ"; ws.Cell(1,2).Value = "العميل"; ws.Cell(1,3).Value = "الهاتف";
        ws.Cell(1,4).Value = "الملخص"; ws.Cell(1,5).Value = "المرحلة قبل"; ws.Cell(1,6).Value = "المرحلة بعد";
        ws.Cell(1,7).Value = "المصدر"; ws.Cell(1,8).Value = "الحملة"; ws.Cell(1,9).Value = "الموظف";
        
        int row = 2;
        foreach (var item in allData.Items)
        {
            ws.Cell(row,1).Value = item.InteractionDate.ToString("yyyy/MM/dd HH:mm");
            ws.Cell(row,2).Value = item.ClientName;
            ws.Cell(row,3).Value = item.Phone;
            ws.Cell(row,4).Value = item.Summary;
            ws.Cell(row,5).Value = item.StageBeforeNameAr;
            ws.Cell(row,6).Value = item.StageAfterNameAr;
            ws.Cell(row,7).Value = item.SourceName;
            ws.Cell(row,8).Value = item.AdTypeNameAr;
            ws.Cell(row,9).Value = item.EmployeeName;
            row++;
        }
        
        ws.Columns().AdjustToContents();
        ws.RightToLeft = true;
        
        using var stream = new MemoryStream();
        wb.SaveAs(stream);
        var bytes = stream.ToArray();
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", $"Interactions_{DateTime.Now:yyyyMMdd}.xlsx", base64);
        
        Snackbar.Add("تم تصدير Excel بنجاح", Severity.Success);
    }

    // Helpers
    private static string NormalizeArabic(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return "";
        var s = input.Trim();
        s = s.Replace('أ','ا').Replace('إ','ا').Replace('آ','ا').Replace('ٱ','ا');
        s = s.Replace('ة','ه').Replace('ى','ي').Replace('ئ','ي');
        s = new string(s.Where(c => !"\u064B\u064C\u064D\u064E\u064F\u0650\u0651\u0652".Contains(c)).ToArray());
        return s.ToLower();
    }
    private static string GetInitials(string name) => string.Join("", name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();
    private static string Truncate(string? s, int max) => string.IsNullOrEmpty(s) ? "" : s.Length <= max ? s : s[..max] + "...";
    private static string FormatGroupDate(DateTime date) => date.Date == DateTime.Today ? "اليوم" : date.Date == DateTime.Today.AddDays(-1) ? "أمس" : date.ToString("dddd، d MMMM");
    private static string GetStatusIcon(string? status) => status?.ToLower() switch { "call" or "مكالمة" => Icons.Material.Rounded.Phone, "whatsapp" or "واتساب" => Icons.Custom.Brands.WhatsApp, "visit" or "زيارة" => Icons.Material.Rounded.Place, _ => Icons.Material.Rounded.Chat };

    private class InteractionStats
    {
        public int TotalInteractions { get; set; }
        public int TodayCount { get; set; }
        public int WeekCount { get; set; }
        public int StageChanges { get; set; }
        public int NoFollowUp { get; set; }
        public int UniqueClients { get; set; }
    }

    public class PartySearchDto
    {
        public int PartyId { get; set; }
        public string PartyName { get; set; } = "";
        public string? Phone { get; set; }
        public string? Phone2 { get; set; }
        public int LastInteractionDays { get; set; }
        public string DisplayText => $"{PartyName} - {Phone ?? Phone2}";
        public string PhoneDisplay => Phone ?? Phone2 ?? "";
        public string NameInitial => GetInitials(PartyName);
    }
    private async Task ScrollToTop()
{
    await JS.InvokeVoidAsync("window.scrollTo", new { top = 0, behavior = "smooth" });
}
}
