    private async Task ResetFiltersAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);
        _toDate = DateTime.Today;
        _selectedEmployeeId = null;
        await LoadData();
    }

    private async Task SetLastMonthsAsync(int months)
    {
        if (months <= 0) months = 12;

        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-(months - 1));
        _toDate = DateTime.Today;
        _selectedEmployeeId = null;

        await LoadData();
    }

    private async Task SetCurrentYearAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _selectedEmployeeId = null;

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentRows = await LoadPeriodRowsAsync(db, _fromDate, _toDate);

            if (TryGetPreviousRange(out var prevFrom, out var prevTo))
            {
                _previousPeriodLabel = $"{prevFrom.ToString("dd MMM yyyy", _arCulture)} — {prevTo.ToString("dd MMM yyyy", _arCulture)}";
                var previousRows = await LoadPeriodRowsAsync(db, prevFrom, prevTo);
                CalculatePreviousMetrics(previousRows);
            }
            else
            {
                _previousPeriodLabel = "غير متاح";
                ResetPreviousMetrics();
            }

            CalculateCurrentMetrics(_currentRows);
            BuildEmployeeData(_currentRows);
            BuildTeamMonthlyData(_currentRows);
            ResolveSelectedEmployee();
            BuildSelectedEmployeeAnalytics(_currentRows);
            BuildInsights();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<List<OpportunitySourceRow>> LoadPeriodRowsAsync(db24804Context db, DateTime? from, DateTime? to)
    {
        var oppQuery = db.VwSalesOpportunities
            .AsNoTracking()
            .Where(o => o.IsActive == true);

        if (from.HasValue)
        {
            var fromDate = from.Value.Date;
            oppQuery = oppQuery.Where(o => o.CreatedAt >= fromDate);
        }

        if (to.HasValue)
        {
            var toExclusive = to.Value.Date.AddDays(1);
            oppQuery = oppQuery.Where(o => o.CreatedAt < toExclusive);
        }

        var opps = await oppQuery
            .Select(o => new OpportunitySourceRow
            {
                OpportunityId = o.OpportunityId,
                CreatedAt = o.CreatedAt,
                EmpId = o.EmployeeId ?? 0,
                EmployeeName = o.EmployeeName ?? "غير محدد",
                StageId = o.StageId,
                ExpectedValue = o.ExpectedValue ?? 0m,
                DaysSinceFirstContact = o.DaysSinceFirstContact ?? 0
            })
            .ToListAsync();

        if (!opps.Any())
            return opps;

        var oppIds = opps.Select(x => x.OpportunityId).Distinct().ToList();

        var interactionQuery = db.CustomerInteractions.AsNoTracking();

        if (from.HasValue)
        {
            var fromDate = from.Value.Date;
            interactionQuery = interactionQuery.Where(i => i.InteractionDate >= fromDate);
        }

        if (to.HasValue)
        {
            var toExclusive = to.Value.Date.AddDays(1);
            interactionQuery = interactionQuery.Where(i => i.InteractionDate < toExclusive);
        }

        var interactionOppIds = await interactionQuery
            .Where(i => oppIds.Contains(i.OpportunityId))
            .Select(i => i.OpportunityId)
            .ToListAsync();

        var counts = interactionOppIds
            .GroupBy(x => x)
            .ToDictionary(g => g.Key, g => g.Count());

        foreach (var opp in opps)
        {
            if (counts.TryGetValue(opp.OpportunityId, out var c))
                opp.InteractionCount = c;
        }

        return opps;
    }

    private void CalculateCurrentMetrics(List<OpportunitySourceRow> rows)
    {
        _activeEmpCount = rows
            .Where(x => x.EmpId != 0 || !string.IsNullOrWhiteSpace(x.EmployeeName))
            .GroupBy(x => new { x.EmpId, x.EmployeeName })
            .Count();

        _totalInteractions = rows.Sum(x => x.InteractionCount);

        var wonRows = rows.Where(x => IsWon(x.StageId)).ToList();
        _totalRevenue = wonRows.Sum(x => x.ExpectedValue);
        _avgSalesCycle = wonRows.Any() ? wonRows.Average(x => x.DaysSinceFirstContact) : 0d;
        _teamWinRate = rows.Count > 0 ? (double)wonRows.Count / rows.Count * 100d : 0d;

        var top = rows
            .Where(x => IsWon(x.StageId))
            .GroupBy(x => new { x.EmpId, x.EmployeeName })
            .Select(g => new
            {
                Name = g.Key.EmployeeName,
                Revenue = g.Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.Revenue)
            .FirstOrDefault();

        _topEarner = top?.Name ?? "—";
        _topEarnerRevenue = top?.Revenue ?? 0m;
    }

    private void CalculatePreviousMetrics(List<OpportunitySourceRow> rows)
    {
        _prevActiveEmpCount = rows
            .Where(x => x.EmpId != 0 || !string.IsNullOrWhiteSpace(x.EmployeeName))
            .GroupBy(x => new { x.EmpId, x.EmployeeName })
            .Count();

        _prevTotalInteractions = rows.Sum(x => x.InteractionCount);

        var wonRows = rows.Where(x => IsWon(x.StageId)).ToList();
        _prevTotalRevenue = wonRows.Sum(x => x.ExpectedValue);
        _prevAvgSalesCycle = wonRows.Any() ? wonRows.Average(x => x.DaysSinceFirstContact) : 0d;
        _prevTeamWinRate = rows.Count > 0 ? (double)wonRows.Count / rows.Count * 100d : 0d;
    }

    private void ResetPreviousMetrics()
    {
        _prevActiveEmpCount = 0;
        _prevTotalInteractions = 0;
        _prevTotalRevenue = 0m;
        _prevAvgSalesCycle = 0d;
        _prevTeamWinRate = 0d;
    }

    private void BuildEmployeeData(List<OpportunitySourceRow> rows)
    {
        var groups = rows
            .GroupBy(x => new { x.EmpId, x.EmployeeName })
            .Select(g =>
            {
                var won = g.Where(x => IsWon(x.StageId)).ToList();

                return new EmployeePerfRow
                {
                    EmpId = g.Key.EmpId,
                    Employee = g.Key.EmployeeName,
                    TotalOpps = g.Count(),
                    WonOpps = won.Count,
                    Revenue = won.Sum(x => x.ExpectedValue),
                    WinRate = g.Count() > 0 ? (double)won.Count / g.Count() * 100d : 0d,
                    AvgCycle = won.Any() ? won.Average(x => x.DaysSinceFirstContact) : 0d,
                    Interactions = g.Sum(x => x.InteractionCount),
                    IsTotal = false
                };
            })
            .OrderByDescending(x => x.Revenue)
            .ThenByDescending(x => x.WonOpps)
            .ThenByDescending(x => x.TotalOpps)
            .ToList();

        _employeeRows = groups.ToList();

        _employeeRows.Add(new EmployeePerfRow
        {
            EmpId = -1,
            Employee = "الإجمالي",
            TotalOpps = rows.Count,
            WonOpps = rows.Count(x => IsWon(x.StageId)),
            Revenue = rows.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue),
            WinRate = rows.Count > 0 ? (double)rows.Count(x => IsWon(x.StageId)) / rows.Count * 100d : 0d,
            AvgCycle = rows.Where(x => IsWon(x.StageId)).Any() ? rows.Where(x => IsWon(x.StageId)).Average(x => x.DaysSinceFirstContact) : 0d,
            Interactions = rows.Sum(x => x.InteractionCount),
            IsTotal = true
        });

        _employeeRevenueChartPoints = groups
            .OrderByDescending(x => x.Revenue)
            .ThenByDescending(x => x.WonOpps)
            .Take(8)
            .Select(x => new EmployeeRevenueChartPoint
            {
                Employee = x.Employee,
                Revenue = x.Revenue
            })
            .ToList();
    }

    private void BuildTeamMonthlyData(List<OpportunitySourceRow> rows)
    {
        var monthMap = new Dictionary<DateTime, MonthlyAggregate>();

        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        foreach (var row in rows)
        {
            var key = new DateTime(row.CreatedAt.Year, row.CreatedAt.Month, 1);

            if (!monthMap.TryGetValue(key, out var agg))
            {
                agg = new MonthlyAggregate();
                monthMap[key] = agg;
            }

            agg.TotalOpps++;
            agg.Interactions += row.InteractionCount;

            if (IsWon(row.StageId))
            {
                agg.WonOpps++;
                agg.Revenue += row.ExpectedValue;
            }
        }

        _teamMonthlyChartPoints = new();

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthMap.TryGetValue(month, out var agg);
            agg ??= new MonthlyAggregate();

            _teamMonthlyChartPoints.Add(new TeamMonthlyChartPoint
            {
                Month = month.ToString("MMM yyyy", _arCulture),
                TotalOpps = agg.TotalOpps,
                WonOpps = agg.WonOpps,
                Interactions = agg.Interactions
            });
        }
    }

    private void ResolveSelectedEmployee()
    {
        var employees = _employeeRows.Where(x => !x.IsTotal).ToList();
        if (!employees.Any())
        {
            _selectedEmployeeId = null;
            return;
        }

        if (_selectedEmployeeId.HasValue && employees.Any(x => x.EmpId == _selectedEmployeeId.Value))
            return;

        _selectedEmployeeId = employees
            .OrderByDescending(x => x.Revenue)
            .ThenByDescending(x => x.WonOpps)
            .Select(x => (int?)x.EmpId)
            .FirstOrDefault();
    }

    private void BuildSelectedEmployeeAnalytics(List<OpportunitySourceRow> rows)
    {
        _selectedEmployeeName = "—";
        _selectedEmployeeTotalOpps = 0;
        _selectedEmployeeWonOpps = 0;
        _selectedEmployeeRevenue = 0m;
        _selectedEmployeeWinRate = 0d;
        _selectedEmployeeAvgCycle = 0d;
        _selectedEmployeeInteractions = 0;
        _selectedEmployeeMonthlyPoints = new();
        _selectedEmployeeRevenuePoints = new();

        if (!_selectedEmployeeId.HasValue)
            return;

        var empRows = rows
            .Where(x => x.EmpId == _selectedEmployeeId.Value)
            .ToList();

        if (!empRows.Any())
            return;

        _selectedEmployeeName = empRows.First().EmployeeName;
        _selectedEmployeeTotalOpps = empRows.Count;
        _selectedEmployeeWonOpps = empRows.Count(x => IsWon(x.StageId));
        _selectedEmployeeRevenue = empRows.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
        _selectedEmployeeWinRate = _selectedEmployeeTotalOpps > 0 ? (double)_selectedEmployeeWonOpps / _selectedEmployeeTotalOpps * 100d : 0d;
        _selectedEmployeeAvgCycle = empRows.Where(x => IsWon(x.StageId)).Any() ? empRows.Where(x => IsWon(x.StageId)).Average(x => x.DaysSinceFirstContact) : 0d;
        _selectedEmployeeInteractions = empRows.Sum(x => x.InteractionCount);

        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var monthMap = new Dictionary<DateTime, MonthlyAggregate>();

        foreach (var row in empRows)
        {
            var key = new DateTime(row.CreatedAt.Year, row.CreatedAt.Month, 1);

            if (!monthMap.TryGetValue(key, out var agg))
            {
                agg = new MonthlyAggregate();
                monthMap[key] = agg;
            }

            agg.TotalOpps++;
            agg.Interactions += row.InteractionCount;

            if (IsWon(row.StageId))
            {
                agg.WonOpps++;
                agg.Revenue += row.ExpectedValue;
            }
        }

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthMap.TryGetValue(month, out var agg);
            agg ??= new MonthlyAggregate();

            _selectedEmployeeMonthlyPoints.Add(new EmployeeMonthlyChartPoint
            {
                Month = month.ToString("MMM yyyy", _arCulture),
                TotalOpps = agg.TotalOpps,
                WonOpps = agg.WonOpps,
                Interactions = agg.Interactions
            });

            _selectedEmployeeRevenuePoints.Add(new EmployeeRevenueMonthlyPoint
            {
                Month = month.ToString("MMM yyyy", _arCulture),
                Revenue = agg.Revenue
            });
        }
    }

    private void BuildInsights()
    {
        _insights = new();

        var employees = _employeeRows.Where(x => !x.IsTotal).ToList();

        if (employees.Any())
        {
            var topRevenue = employees
                .OrderByDescending(x => x.Revenue)
                .ThenByDescending(x => x.WonOpps)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.AttachMoney,
                Title = "أعلى إيراد",
                Value = topRevenue.Employee,
                Description = $"إيراد محقق {FormatMoney(topRevenue.Revenue)}",
                ToneClass = "tone-green"
            });

            var closerSource = employees.Where(x => x.TotalOpps >= 3).ToList();
            if (!closerSource.Any())
                closerSource = employees.Where(x => x.TotalOpps > 0).ToList();

            if (closerSource.Any())
            {
                var bestCloser = closerSource
                    .OrderByDescending(x => x.WinRate)
                    .ThenByDescending(x => x.WonOpps)
                    .First();

                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.EmojiEvents,
                    Title = "أفضل معدل إغلاق",
                    Value = bestCloser.Employee,
                    Description = $"{bestCloser.WinRate:F1}% من {bestCloser.TotalOpps} فرصة",
                    ToneClass = "tone-gold"
                });
            }

            var mostInteractive = employees
                .OrderByDescending(x => x.Interactions)
                .ThenByDescending(x => x.TotalOpps)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Forum,
                Title = "أعلى تفاعلات",
                Value = mostInteractive.Employee,
                Description = $"{mostInteractive.Interactions:N0} تفاعل",
                ToneClass = "tone-indigo"
            });

            var cycleSource = employees.Where(x => x.WonOpps > 0).ToList();
            if (cycleSource.Any())
            {
                var fastest = cycleSource
                    .OrderBy(x => x.AvgCycle)
                    .ThenByDescending(x => x.WonOpps)
                    .First();

                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.Speed,
                    Title = "أسرع دورة بيع",
                    Value = fastest.Employee,
                    Description = $"{fastest.AvgCycle:F1} يوم",
                    ToneClass = "tone-slate"
                });
            }
        }

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

