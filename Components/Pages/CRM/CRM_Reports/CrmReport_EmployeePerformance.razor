@page "/crm/reports/employee-performance"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير أداء الموظفين</PageTitle>

<div class="empx-page" dir="rtl">

    @* Background *@
    <div class="empx-bg">
        <div class="empx-orb orb-1"></div>
        <div class="empx-orb orb-2"></div>
        <div class="empx-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="empx-hero">
        <div class="empx-hero-grid"></div>

        <div class="empx-hero-content">
            <div class="empx-hero-top">
                <button class="empx-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="empx-badge">
                    <span class="badge-dot"></span>
                    <span>Employee Performance Intelligence</span>
                </div>
            </div>

            <div class="empx-hero-main">
                <div class="empx-hero-text">
                    <h1>تقرير <span>أداء</span> الموظفين</h1>
                    <p>
                        لوحة تنفيذية متقدمة لقياس أداء فريق المبيعات من حيث عدد الفرص،
                        الصفقات الرابحة، الإيرادات، معدل الإغلاق، التفاعلات، ومتوسط دورة البيع.
                    </p>

                    <div class="empx-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الموظف الأعلى إيرادًا</span>
                            <span class="chip-value">@_topEarner</span>
                        </div>
                    </div>
                </div>

                <div class="empx-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_teamWinRate.ToString("F1")%</div>
                            <div class="summary-caption">معدل إغلاق الفريق</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card empx-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية أو استخدم الفترات السريعة لتحليل أداء الفريق</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card empx-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل أداء الموظفين...</h3>
                <p>يتم تجهيز المؤشرات، الرسوم البيانية، والمقارنات الذكية</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="empx-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">👥</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الموظفون النشطون</div>
                        <span class="trend-badge @GetTrendClass(_activeEmpCount, _prevActiveEmpCount)">
                            @GetTrendText(_activeEmpCount, _prevActiveEmpCount)
                        </span>
                    </div>
                    <div class="kpi-value">@_activeEmpCount.ToString("N0")</div>
                    <div class="kpi-sub">عدد الموظفين الذين لديهم فرص خلال الفترة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon green">₪</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الإيرادات المحققة</div>
                        <span class="trend-badge @GetTrendClass(_totalRevenue, _prevTotalRevenue)">
                            @GetTrendText(_totalRevenue, _prevTotalRevenue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_totalRevenue)</div>
                    <div class="kpi-sub">قيمة الصفقات الرابحة خلال الفترة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">%</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">معدل إغلاق الفريق</div>
                        <span class="trend-badge @GetTrendClass(_teamWinRate, _prevTeamWinRate)">
                            @GetTrendText(_teamWinRate, _prevTeamWinRate)
                        </span>
                    </div>
                    <div class="kpi-value">@_teamWinRate.ToString("F1")%</div>
                    <div class="kpi-progress">
                        <div class="kpi-progress-bar" style="@GetProgressBarStyle()"></div>
                    </div>
                    <div class="kpi-sub">الصفقات الرابحة ÷ إجمالي الفرص × 100</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon slate">💬</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي التفاعلات</div>
                        <span class="trend-badge @GetTrendClass(_totalInteractions, _prevTotalInteractions)">
                            @GetTrendText(_totalInteractions, _prevTotalInteractions)
                        </span>
                    </div>
                    <div class="kpi-value">@_totalInteractions.ToString("N0")</div>
                    <div class="kpi-sub">عدد التفاعلات المرتبطة بالفرص داخل الفترة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon @GetCycleTrendBadgeClass()">@GetCycleTrendIcon()</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">متوسط دورة البيع</div>
                        <span class="trend-badge @GetCycleTrendClass(_avgSalesCycle, _prevAvgSalesCycle)">
                            @GetCycleTrendText(_avgSalesCycle, _prevAvgSalesCycle)
                        </span>
                    </div>
                    <div class="kpi-value">@_avgSalesCycle.ToString("F1") يوم</div>
                    <div class="kpi-sub">محسوب من الصفقات الرابحة فقط</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon purple">🏆</div>
                <div class="kpi-body">
                    <div class="kpi-head-row no-badge">
                        <div class="kpi-label">أعلى موظف مبيعات</div>
                    </div>
                    <div class="kpi-value kpi-name">@_topEarner</div>
                    <div class="kpi-sub">إيراد محقق: @FormatMoney(_topEarnerRevenue)</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="empx-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* DASHBOARD *@
        <section class="empx-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>الاتجاه الشهري للفريق</h3>
                        <p>إجمالي الفرص مقابل الصفقات الرابحة والتفاعلات على مستوى الشهور</p>
                    </div>
                </div>

                @if (_teamMonthlyChartPoints.Any())
                {
                    <ApexChart TItem="TeamMonthlyChartPoint"
                               Options="_teamMonthlyChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="TeamMonthlyChartPoint"
                                         Items="@_teamMonthlyChartPoints"
                                         Name="الفرص"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.TotalOpps" />

                        <ApexPointSeries TItem="TeamMonthlyChartPoint"
                                         Items="@_teamMonthlyChartPoints"
                                         Name="المبيعات"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.WonOpps" />

                        <ApexPointSeries TItem="TeamMonthlyChartPoint"
                                         Items="@_teamMonthlyChartPoints"
                                         Name="التفاعلات"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Month"
                                         YValue="x => x.Interactions" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>أعلى الموظفين في الإيراد</h3>
                            <p>الترتيب حسب الإيرادات المحققة من الصفقات الرابحة</p>
                        </div>
                    </div>

                    @if (_employeeRevenueChartPoints.Any())
                    {
                        <ApexChart TItem="EmployeeRevenueChartPoint"
                                   Options="_employeeRevenueChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="EmployeeRevenueChartPoint"
                                             Items="@_employeeRevenueChartPoints"
                                             Name="الإيراد"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Employee"
                                             YValue="x => x.Revenue" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض الإيرادات حسب الموظف</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">الموظفون النشطون</div>
                            <div class="compare-values">
                                <span>@_prevActiveEmpCount</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_activeEmpCount</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">الإيرادات</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevTotalRevenue)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_totalRevenue)</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">التفاعلات</div>
                            <div class="compare-values">
                                <span>@_prevTotalInteractions</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_totalInteractions</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">معدل الإغلاق</div>
                            <div class="compare-values">
                                <span>@_prevTeamWinRate.ToString("F1")%</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_teamWinRate.ToString("F1")%</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @(_teamWinRate >= _prevTeamWinRate ? "compare-good" : "compare-bad")">
                        @if (_teamWinRate >= _prevTeamWinRate)
                        {
                            <span>الأداء الحالي للفريق أفضل أو مساوي للفترة السابقة</span>
                        }
                        else
                        {
                            <span>الأداء الحالي للفريق أقل من الفترة السابقة ويحتاج متابعة</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* EMPLOYEE DRILL-DOWN *@
        <section class="glass-card empx-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down حسب الموظف</h3>
                    <p>اختر موظفًا لعرض تحليله التفصيلي داخل الفترة الحالية</p>
                </div>

                @if (_selectedEmployeeId.HasValue)
                {
                    <button class="clear-emp-btn" @onclick="ClearSelectedEmployee">
                        إلغاء اختيار الموظف
                    </button>
                }
            </div>

            <div class="employee-chip-row">
                @foreach (var emp in _employeeRows.Where(x => !x.IsTotal))
                {
                    <button class="employee-chip-btn @(IsSelectedEmployee(emp.EmpId) ? "employee-chip-active" : "")"
                            @onclick="() => SelectEmployee(emp.EmpId)">
                        <span>@emp.Employee</span>
                        <small>@emp.WinRate.ToString("F0")%</small>
                    </button>
                }
            </div>

            @if (_selectedEmployeeId.HasValue)
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">الموظف المحدد</span>
                        <strong>@_selectedEmployeeName</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الفرص</span>
                        <strong>@_selectedEmployeeTotalOpps.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">المبيعات</span>
                        <strong>@_selectedEmployeeWonOpps.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الإيرادات</span>
                        <strong>@FormatMoney(_selectedEmployeeRevenue)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">معدل الإغلاق</span>
                        <strong>@_selectedEmployeeWinRate.ToString("F1")%</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">التفاعلات</span>
                        <strong>@_selectedEmployeeInteractions.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">متوسط الدورة</span>
                        <strong>@_selectedEmployeeAvgCycle.ToString("F1") يوم</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>الاتجاه الشهري للموظف</h3>
                                <p>الفرص والمبيعات والتفاعلات للموظف المحدد</p>
                            </div>
                        </div>

                        @if (_selectedEmployeeMonthlyPoints.Any())
                        {
                            <ApexChart TItem="EmployeeMonthlyChartPoint"
                                       Options="_selectedEmployeeMonthlyChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="EmployeeMonthlyChartPoint"
                                                 Items="@_selectedEmployeeMonthlyPoints"
                                                 Name="الفرص"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.TotalOpps" />

                                <ApexPointSeries TItem="EmployeeMonthlyChartPoint"
                                                 Items="@_selectedEmployeeMonthlyPoints"
                                                 Name="المبيعات"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.WonOpps" />

                                <ApexPointSeries TItem="EmployeeMonthlyChartPoint"
                                                 Items="@_selectedEmployeeMonthlyPoints"
                                                 Name="التفاعلات"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.Interactions" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات شهرية لهذا الموظف</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>الإيراد الشهري للموظف</h3>
                                <p>قيمة الإيراد المحقق من الصفقات الرابحة لكل شهر</p>
                            </div>
                        </div>

                        @if (_selectedEmployeeRevenuePoints.Any())
                        {
                            <ApexChart TItem="EmployeeRevenueMonthlyPoint"
                                       Options="_selectedEmployeeRevenueMonthlyChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="EmployeeRevenueMonthlyPoint"
                                                 Items="@_selectedEmployeeRevenuePoints"
                                                 Name="الإيراد"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.Revenue" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات إيراد لهذا الموظف</div>
                        }
                    </div>
                </div>
            }
        </section>

        @* TABLE *@
        <section class="glass-card empx-table-card">
            <div class="card-head">
                <div>
                    <h3>تفاصيل أداء الموظفين</h3>
                    <p>عرض تفصيلي للفرص والمبيعات والإيرادات ومعدل الإغلاق والتفاعلات</p>
                </div>
            </div>

            <MudTable Items="@_employeeRows"
                      Hover="true"
                      Dense="true"
                      Elevation="0"
                      RowsPerPage="10"
                      Breakpoint="Breakpoint.Sm"
                      Class="premium-table">
                <HeaderContent>
                    <MudTh>الموظف</MudTh>
                    <MudTh>الفرص</MudTh>
                    <MudTh>المبيعات</MudTh>
                    <MudTh>الإيرادات</MudTh>
                    <MudTh>معدل الإغلاق</MudTh>
                    <MudTh>متوسط الدورة</MudTh>
                    <MudTh>التفاعلات</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="الموظف">
                        @if (context.IsTotal)
                        {
                            <strong>@context.Employee</strong>
                        }
                        else
                        {
                            @context.Employee
                        }
                    </MudTd>
                    <MudTd DataLabel="الفرص">@context.TotalOpps.ToString("N0")</MudTd>
                    <MudTd DataLabel="المبيعات">@context.WonOpps.ToString("N0")</MudTd>
                    <MudTd DataLabel="الإيرادات">@FormatMoney(context.Revenue)</MudTd>
                    <MudTd DataLabel="معدل الإغلاق">
                        <span class="rate-pill @GetRatePillClass(context.WinRate)">
                            @context.WinRate.ToString("F1")%
                        </span>
                    </MudTd>
                    <MudTd DataLabel="متوسط الدورة">@context.AvgCycle.ToString("F1")</MudTd>
                    <MudTd DataLabel="التفاعلات">@context.Interactions.ToString("N0")</MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <div class="empty-data">
                        <div class="empty-icon">📉</div>
                        <h4>لا توجد بيانات</h4>
                        <p>لا توجد نتائج مطابقة للفلاتر الحالية</p>
                    </div>
                </NoRecordsContent>
            </MudTable>
        </section>

        @* NOTE *@
        <section class="glass-card empx-note">
            <div class="note-icon">ℹ️</div>
            <div class="note-body">
                <h4>ملاحظة تحليلية مهمة</h4>
                <p>
                    يتم احتساب الإيرادات هنا من الصفقات ذات <strong>StageId = @WonStageId</strong>،
                    كما يتم احتساب متوسط دورة البيع اعتمادًا على <strong>DaysSinceFirstContact</strong>
                    للصفقات الرابحة فقط. إذا توفرت لديك لاحقًا تواريخ إغلاق فعلية أدق، يفضل استخدامها.
                </p>
            </div>
        </section>
    }
</div>

@code {
    private const int WonStageId = 3;

    private readonly CultureInfo _arCulture = new("ar-EG");

    private DateTime? _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);
    private DateTime? _toDate = DateTime.Today;
    private bool _isLoading;

    private List<OpportunitySourceRow> _currentRows = new();
    private List<EmployeePerfRow> _employeeRows = new();
    private List<TeamMonthlyChartPoint> _teamMonthlyChartPoints = new();
    private List<EmployeeRevenueChartPoint> _employeeRevenueChartPoints = new();
    private List<InsightItem> _insights = new();

    private int _activeEmpCount;
    private int _totalInteractions;
    private decimal _totalRevenue;
    private string _topEarner = "—";
    private decimal _topEarnerRevenue;
    private double _avgSalesCycle;
    private double _teamWinRate;

    private int _prevActiveEmpCount;
    private int _prevTotalInteractions;
