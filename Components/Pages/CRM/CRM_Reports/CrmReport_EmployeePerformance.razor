                {
                    var perf = _selectedEmployeeMonthlyPoints[i];
                    var rev = _selectedEmployeeRevenuePoints.ElementAtOrDefault(i)?.Revenue ?? 0m;
                    sb.AppendLine($"{perf.Month},{perf.TotalOpps:N0},{perf.WonOpps:N0},{perf.Interactions:N0},{rev:N0}");
                }
            }

            var csv = sb.ToString();
            var fileName = $"employee-performance-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

    private async Task PrintAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "window.print()");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تشغيل الطباعة: {ex.Message}", Severity.Error);
        }
    }

    private bool IsWon(int? stageId) => stageId == WonStageId;

    private string FormatMoney(decimal value) => $"{value:N0} ج.م";

    private string GetProgressBarStyle()
    {
        var safeRate = Math.Max(0, Math.Min(_teamWinRate, 100));
        return $"width:{safeRate:F0}%";
    }

    private string GetSummaryRingStyle()
    {
        var safeRate = Math.Max(0, Math.Min(_teamWinRate, 100));
        var angle = safeRate * 3.6;
        return $"background: conic-gradient(#10b981 0deg, #10b981 {angle:F1}deg, rgba(255,255,255,.12) {angle:F1}deg, rgba(255,255,255,.12) 360deg);";
    }

    private string GetTrendClass(int current, int previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(double current, double previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(decimal current, decimal previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendText(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? "0%" : "جديد";

        var change = ((double)(current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(double current, double previous)
    {
        if (Math.Abs(previous) < 0.000001)
            return Math.Abs(current) < 0.000001 ? "0%" : "جديد";

        var change = ((current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(decimal current, decimal previous)
    {
        if (previous == 0m)
            return current == 0m ? "0%" : "جديد";

        var change = (double)((current - previous) / previous * 100m);
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetCycleTrendClass(double current, double previous)
    {
        if (Math.Abs(current - previous) < 0.000001) return "trend-flat";
        return current < previous ? "trend-up" : "trend-down";
    }

    private string GetCycleTrendText(double current, double previous)
    {
        if (Math.Abs(previous) < 0.000001)
            return Math.Abs(current) < 0.000001 ? "0%" : "جديد";

        var change = Math.Abs((current - previous) / previous * 100d);

        if (Math.Abs(current - previous) < 0.000001)
            return "0%";

        return current < previous
            ? $"أسرع {change:F1}%"
            : $"أبطأ {change:F1}%";
    }

    private string GetCycleTrendBadgeClass()
        => GetCycleTrendClass(_avgSalesCycle, _prevAvgSalesCycle) switch
        {
            "trend-up" => "green",
            "trend-down" => "red",
            _ => "slate"
        };

    private string GetCycleTrendIcon()
        => GetCycleTrendClass(_avgSalesCycle, _prevAvgSalesCycle) switch
        {
            "trend-up" => "⚡",
            "trend-down" => "⏳",
            _ => "•"
        };

    private string GetRatePillClass(double rate)
    {
        if (rate >= 50) return "rate-good";
        if (rate >= 25) return "rate-mid";
        return "rate-bad";
    }

