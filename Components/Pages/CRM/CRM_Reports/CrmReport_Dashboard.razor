    private string BuildReportUrl(string baseUrl, string? extraQuery = null)
    {
        var parts = new List<string>();

        if (_fromDate.HasValue)
            parts.Add($"fromDate={Uri.EscapeDataString(_fromDate.Value.ToString("yyyy-MM-dd"))}");

        if (_toDate.HasValue)
            parts.Add($"toDate={Uri.EscapeDataString(_toDate.Value.ToString("yyyy-MM-dd"))}");

        if (_empId.HasValue)
            parts.Add($"empId={_empId.Value}");

        if (!string.IsNullOrWhiteSpace(extraQuery))
            parts.Add(extraQuery);

        return parts.Count == 0
            ? baseUrl
            : $"{baseUrl}?{string.Join("&", parts)}";
    }

    private bool TryGetPreviousRange(out DateTime previousFrom, out DateTime previousTo)
    {
        previousFrom = default;
        previousTo = default;

        if (!_fromDate.HasValue || !_toDate.HasValue)
            return false;

        var currentFrom = _fromDate.Value.Date;
        var currentTo = _toDate.Value.Date;
        var days = (currentTo - currentFrom).Days;

        previousTo = currentFrom.AddDays(-1);
        previousFrom = previousTo.AddDays(-days);

        return true;
    }

    private void NormalizeDateRange()
    {
        if (_fromDate.HasValue && _toDate.HasValue && _fromDate.Value.Date > _toDate.Value.Date)
        {
            var temp = _fromDate;
            _fromDate = _toDate;
            _toDate = temp;

            Snackbar.Add("تم تبديل تاريخ البداية والنهاية تلقائيًا لأن البداية كانت أكبر من النهاية.", Severity.Info);
        }
    }

    private List<DateTime> BuildMonthRange(DateTime from, DateTime to)
    {
        var start = new DateTime(from.Year, from.Month, 1);
        var end = new DateTime(to.Year, to.Month, 1);

        var result = new List<DateTime>();
        for (var m = start; m <= end; m = m.AddMonths(1))
            result.Add(m);

        return result;
    }

    private List<DateTime> BuildDayRange(DateTime from, DateTime to)
    {
        var result = new List<DateTime>();
        for (var d = from; d <= to; d = d.AddDays(1))
            result.Add(d);
        return result;
    }

    private string FormatMoney(decimal value) => $"{value:N0} ج.م";

    private string GetSummaryRingStyle()
    {
        var safeRate = Math.Max(0, Math.Min(_closeRate, 100));
        var angle = safeRate * 3.6;
        return $"background: conic-gradient(#10b981 0deg, #10b981 {angle:F1}deg, rgba(255,255,255,.12) {angle:F1}deg, rgba(255,255,255,.12) 360deg);";
    }

    private string GetTrendClass(int current, int previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(double current, double previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(decimal current, decimal previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendText(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? "0%" : "جديد";

        var change = ((double)(current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(double current, double previous)
    {
        if (Math.Abs(previous) < 0.000001)
            return Math.Abs(current) < 0.000001 ? "0%" : "جديد";

        var change = ((current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(decimal current, decimal previous)
    {
        if (previous == 0m)
            return current == 0m ? "0%" : "جديد";

        var change = (double)((current - previous) / previous * 100m);
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

