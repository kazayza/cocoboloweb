    private async Task LoadEmployeesAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var raw = await db.VwSalesOpportunities
            .AsNoTracking()
            .Where(o => o.EmployeeId != null && o.EmployeeName != null)
            .GroupBy(o => new { o.EmployeeId, o.EmployeeName })
            .Select(g => new
            {
                Id = g.Key.EmployeeId!.Value,
                Name = g.Key.EmployeeName!
            })
            .OrderBy(x => x.Name)
            .ToListAsync();

        _employees = raw
            .Select(x => new EmployeeItem
            {
                Id = x.Id,
                Name = x.Name
            })
            .ToList();
    }

    private async Task ResetFiltersAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-5);
        _toDate = DateTime.Today;
        _empId = null;
        _selectedStageId = null;
        await LoadData();
    }

    private async Task SetLastMonthsAsync(int months)
    {
        if (months <= 0) months = 1;

        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-(months - 1));
        _toDate = DateTime.Today;
        _selectedStageId = null;

        await LoadData();
    }

    private async Task SetCurrentYearAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _selectedStageId = null;

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            if (!_fromDate.HasValue || !_toDate.HasValue)
            {
                _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-5);
                _toDate = DateTime.Today;
            }

            var currentFrom = _fromDate.Value.Date;
            var currentTo = _toDate.Value.Date;

            if (!TryGetPreviousRange(out var prevFrom, out var prevTo))
            {
                prevFrom = currentFrom.AddMonths(-1);
                prevTo = currentFrom.AddDays(-1);
            }

            _previousPeriodLabel = $"{prevFrom:dd MMM yyyy} — {prevTo:dd MMM yyyy}";

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentSnapshot = await LoadSnapshotAsync(db, currentFrom, currentTo, _empId);
            _previousSnapshot = await LoadSnapshotAsync(db, prevFrom, prevTo, _empId);

            BuildMetrics();
            BuildPipeline();
            BuildRevenueTrend();
            BuildLeadTrend();
            BuildActivityTrend();
            BuildLostReasons();
            BuildSources();
            BuildOperationalWidgets();
            BuildPerformersAndRecentWins();
            BuildInsights();

            ResolveSelectedStage();
            BuildSelectedStageAnalytics();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل لوحة التحكم: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<DashboardSnapshot> LoadSnapshotAsync(db24804Context db, DateTime from, DateTime toInclusive, int? empId)
    {
        var toExclusive = toInclusive.AddDays(1);

        List<int>? employeeOpportunityIds = null;

        if (empId.HasValue)
        {
            employeeOpportunityIds = await db.VwSalesOpportunities
                .AsNoTracking()
                .Where(o => o.EmployeeId == empId.Value)
                .Select(o => o.OpportunityId)
                .Distinct()
                .ToListAsync();
        }

        var oppQuery = db.VwSalesOpportunities
            .AsNoTracking()
            .Where(o => o.IsActive == true && o.CreatedAt >= from && o.CreatedAt < toExclusive);

        if (empId.HasValue)
            oppQuery = oppQuery.Where(o => o.EmployeeId == empId.Value);

        var opps = await oppQuery
            .Select(o => new DashboardOpportunityRow
            {
                OpportunityId = o.OpportunityId,
                ClientName = o.ClientName ?? "—",
                EmployeeId = o.EmployeeId ?? 0,
                EmployeeName = o.EmployeeName ?? "—",
                StageId = o.StageId,
                StageName = o.StageNameAr ?? o.StageName ?? "—",
                StageColor = o.StageColor ?? "",
                StageOrder = o.StageOrder ?? 0,
                CreatedAt = o.CreatedAt,
                LastContactDate = o.LastContactDate,
                NextFollowUpDate = o.NextFollowUpDate,
                ExpectedValue = o.ExpectedValue ?? 0m,
                DaysSinceFirstContact = o.DaysSinceFirstContact ?? 0d,
                SourceName = o.SourceName ?? "غير محدد",
                LostReasonName = o.LostReasonName ?? "غير محدد"
            })
            .ToListAsync();

        List<DashboardInteractionRow> interactions;

        if (empId.HasValue && (employeeOpportunityIds == null || employeeOpportunityIds.Count == 0))
        {
            interactions = new();
        }
        else
        {
            var interactionsQuery = db.CustomerInteractions
                .AsNoTracking()
                .Where(i => i.InteractionDate >= from && i.InteractionDate < toExclusive);

            if (empId.HasValue && employeeOpportunityIds != null)
                interactionsQuery = interactionsQuery.Where(i => employeeOpportunityIds.Contains(i.OpportunityId));

            interactions = await interactionsQuery
                .Select(i => new DashboardInteractionRow
                {
                    OpportunityId = i.OpportunityId,
                    InteractionDate = i.InteractionDate
                })
                .ToListAsync();
        }

        var tasksQuery = db.CrmTasks
            .AsNoTracking()
            .Where(t => t.DueDate >= from && t.DueDate < toExclusive && t.Status == "مكتملة");

        if (empId.HasValue)
            tasksQuery = tasksQuery.Where(t => t.AssignedTo == empId.Value);

        var tasks = await tasksQuery
            .Select(t => new DashboardTaskRow
            {
                DueDate = t.DueDate
            })
            .ToListAsync();

        List<DashboardLeadRow> leads;

        var leadsQuery = db.LeadsCRMs
            .AsNoTracking()
            .Where(l => l.CreatedAt >= from && l.CreatedAt < toExclusive);

        if (empId.HasValue)
        {
            if (employeeOpportunityIds == null || employeeOpportunityIds.Count == 0)
            {
                leads = new();
                return new DashboardSnapshot
                {
                    Opportunities = opps,
                    Interactions = interactions,
                    Tasks = tasks,
                    Leads = leads
                };
            }

            leadsQuery = leadsQuery.Where(l => l.ConvertedOpportunityId != null && employeeOpportunityIds.Contains(l.ConvertedOpportunityId.Value));
        }

        var rawLeads = await leadsQuery
            .Select(l => new LeadBaseRow
            {
                CreatedAt = l.CreatedAt,
                ConvertedOpportunityId = l.ConvertedOpportunityId
            })
            .ToListAsync();

        var convertedOppIds = rawLeads
            .Where(l => l.ConvertedOpportunityId.HasValue)
            .Select(l => l.ConvertedOpportunityId!.Value)
            .Distinct()
            .ToList();

        var convertedOppMap = new Dictionary<int, ConvertedLeadOpportunityRow>();

        if (convertedOppIds.Any())
        {
            var convertedOppRows = await db.VwSalesOpportunities
                .AsNoTracking()
                .Where(o => convertedOppIds.Contains(o.OpportunityId))
                .Select(o => new ConvertedLeadOpportunityRow
                {
                    OpportunityId = o.OpportunityId,
                    StageId = o.StageId,
                    ExpectedValue = o.ExpectedValue ?? 0m
                })
                .ToListAsync();

            convertedOppMap = convertedOppRows.ToDictionary(x => x.OpportunityId, x => x);
        }

        leads = rawLeads
            .Select(l =>
            {
                ConvertedLeadOpportunityRow? opp = null;

                if (l.ConvertedOpportunityId.HasValue)
                    convertedOppMap.TryGetValue(l.ConvertedOpportunityId.Value, out opp);

                return new DashboardLeadRow
                {
                    CreatedAt = l.CreatedAt,
                    ConvertedOpportunityId = l.ConvertedOpportunityId,
                    ConvertedStageId = opp?.StageId,
                    ConvertedValue = opp?.ExpectedValue ?? 0m
                };
            })
            .ToList();

        return new DashboardSnapshot
        {
            Opportunities = opps,
            Interactions = interactions,
            Tasks = tasks,
            Leads = leads
        };
    }

    private void BuildMetrics()
    {
        var currentOpps = _currentSnapshot.Opportunities;
        var prevOpps = _previousSnapshot.Opportunities;

        var exitStages = new[] { WonStageId, LostStageId1, LostStageId2 };
        var staleCutoff = DateTime.Today.AddDays(-14);

        _revenue = currentOpps.Where(o => o.StageId == WonStageId).Sum(o => o.ExpectedValue);
        _prevRevenue = prevOpps.Where(o => o.StageId == WonStageId).Sum(o => o.ExpectedValue);

        if (_prevRevenue > 0)
        {
            var change = (_revenue - _prevRevenue) / _prevRevenue * 100m;
            _revenueChange = change >= 0
                ? $"↑ {change:F1}% مقارنة بالفترة السابقة"
                : $"↓ {Math.Abs(change):F1}% مقارنة بالفترة السابقة";
        }
        else
        {
            _revenueChange = _revenue > 0 ? "نشاط جديد مقارنة بالفترة السابقة" : "لا توجد إيرادات في الفترة السابقة";
        }

        _openOpps = currentOpps.Count(o => !exitStages.Contains(o.StageId));
        _prevOpenOpps = prevOpps.Count(o => !exitStages.Contains(o.StageId));

        _openPipelineValue = currentOpps.Where(o => !exitStages.Contains(o.StageId)).Sum(o => o.ExpectedValue);
        _prevOpenPipelineValue = prevOpps.Where(o => !exitStages.Contains(o.StageId)).Sum(o => o.ExpectedValue);

        _closeRate = currentOpps.Count > 0 ? (double)currentOpps.Count(o => o.StageId == WonStageId) / currentOpps.Count * 100d : 0d;
        _prevCloseRate = prevOpps.Count > 0 ? (double)prevOpps.Count(o => o.StageId == WonStageId) / prevOpps.Count * 100d : 0d;

        _overdueFollowups = currentOpps.Count(o =>
            o.NextFollowUpDate.HasValue &&
            o.NextFollowUpDate.Value.Date < DateTime.Today &&
            !exitStages.Contains(o.StageId));

        _periodInteractions = _currentSnapshot.Interactions.Count;
        _prevPeriodInteractions = _previousSnapshot.Interactions.Count;

        _staleOpps = currentOpps.Count(o => !exitStages.Contains(o.StageId) && (o.LastContactDate == null || o.LastContactDate < staleCutoff));
        _staleValue = currentOpps
            .Where(o => !exitStages.Contains(o.StageId) && (o.LastContactDate == null || o.LastContactDate < staleCutoff))
            .Sum(o => o.ExpectedValue);
    }

    private void BuildPipeline()
    {
        _stageRows = _currentSnapshot.Opportunities
            .GroupBy(o => new { o.StageId, o.StageName, o.StageColor, o.StageOrder })
            .Select(g =>
            {
                var count = g.Count();
                var value = g.Sum(x => x.ExpectedValue);

                return new StageSummaryRow
                {
                    StageId = g.Key.StageId,
                    StageName = g.Key.StageName,
                    StageColor = g.Key.StageColor,
                    StageOrder = g.Key.StageOrder,
                    Count = count,
                    Value = value,
                    Percent = _currentSnapshot.Opportunities.Count > 0
                        ? (double)count / _currentSnapshot.Opportunities.Count * 100d
                        : 0d,
                    AvgValue = count > 0 ? value / count : 0m
                };
            })
            .OrderBy(x => x.StageOrder)
            .ThenBy(x => x.StageId)
            .ToList();

        _pipelinePoints = _stageRows
            .Select(s => new PipelinePoint
            {
                Stage = s.StageName,
                Count = s.Count,
                Value = s.Value
            })
            .ToList();
    }

    private void BuildRevenueTrend()
    {
        _revenuePoints = BuildMonthRange(_fromDate!.Value.Date, _toDate!.Value.Date)
            .Select(m =>
            {
                var monthEnd = m.AddMonths(1);
                var value = _currentSnapshot.Opportunities
                    .Where(o => o.StageId == WonStageId && o.CreatedAt >= m && o.CreatedAt < monthEnd)
                    .Sum(o => o.ExpectedValue);

                return new RevenueTrendPoint
                {
                    Month = m.ToString("yyyy/MM"),
                    Value = value
                };
            })
            .ToList();
    }

    private void BuildLeadTrend()
    {
        _leadPoints = BuildMonthRange(_fromDate!.Value.Date, _toDate!.Value.Date)
            .Select(m =>
            {
                var monthEnd = m.AddMonths(1);
                var leads = _currentSnapshot.Leads
                    .Where(l => l.CreatedAt >= m && l.CreatedAt < monthEnd)
                    .ToList();

                return new LeadTrendPoint
                {
                    Month = m.ToString("yyyy/MM"),
                    TotalLeads = leads.Count,
                    ConvertedLeads = leads.Count(l => l.ConvertedOpportunityId.HasValue),
                    WonLeads = leads.Count(l => l.ConvertedStageId == WonStageId)
                };
            })
            .ToList();
    }

    private void BuildActivityTrend()
    {
        _activityPoints = BuildDayRange(_fromDate!.Value.Date, _toDate!.Value.Date)
            .Select(d =>
            {
                var interactions = _currentSnapshot.Interactions.Count(i => i.InteractionDate.Date == d);
                var opps = _currentSnapshot.Opportunities.Count(o => o.CreatedAt.Date == d);
                var wins = _currentSnapshot.Opportunities.Count(o => o.CreatedAt.Date == d && o.StageId == WonStageId);
                var tasks = _currentSnapshot.Tasks.Count(t => t.DueDate.Date == d);

                return new ActivityPoint
                {
                    Label = d.ToString("MM/dd"),
                    Interactions = interactions,
                    NewOpps = opps,
                    Won = wins,
                    Tasks = tasks
                };
            })
            .ToList();
    }

    private void BuildLostReasons()
    {
        _lostReasonPoints = _currentSnapshot.Opportunities
            .Where(o => o.StageId == LostStageId1 || o.StageId == LostStageId2)
            .GroupBy(o => string.IsNullOrWhiteSpace(o.LostReasonName) ? "غير محدد" : o.LostReasonName)
            .Select(g => new LostReasonPoint
            {
                Reason = g.Key,
                Count = g.Count()
            })
            .OrderByDescending(x => x.Count)
            .Take(6)
            .ToList();
    }

    private void BuildSources()
    {
        var sourceRows = _currentSnapshot.Opportunities
            .GroupBy(o => string.IsNullOrWhiteSpace(o.SourceName) ? "غير محدد" : o.SourceName)
            .Select(g => new
            {
                Source = g.Key,
                Revenue = g.Where(x => x.StageId == WonStageId).Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.Revenue)
            .ToList();

        _sourcePoints = sourceRows
            .Take(6)
            .Select(x => new SourcePoint
            {
                Source = x.Source,
                Revenue = x.Revenue
            })
            .ToList();

        _bestSource = sourceRows.FirstOrDefault()?.Source ?? "—";
    }

    private void BuildPerformersAndRecentWins()
    {
        _topPerformers = _currentSnapshot.Opportunities
            .Where(o => o.StageId == WonStageId && !string.IsNullOrWhiteSpace(o.EmployeeName))
            .GroupBy(o => o.EmployeeName)
            .Select(g => new PerformerRow
            {
                EmployeeName = g.Key,
                WonCount = g.Count(),
                Revenue = g.Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.Revenue)
            .ThenByDescending(x => x.WonCount)
            .Take(5)
            .ToList();

        for (int i = 0; i < _topPerformers.Count; i++)
            _topPerformers[i].Rank = i + 1;

        _bestPerformerName = _topPerformers.FirstOrDefault()?.EmployeeName ?? "—";

        _recentWins = _currentSnapshot.Opportunities
            .Where(o => o.StageId == WonStageId)
            .OrderByDescending(o => o.CreatedAt)
            .Take(5)
            .Select(o => new RecentWinRow
            {
                ClientName = o.ClientName,
                EmployeeName = o.EmployeeName,
                Value = o.ExpectedValue,
                CreatedAt = o.CreatedAt
            })
            .ToList();
    }

    private void BuildOperationalWidgets()
    {
        var exitStages = new[] { WonStageId, LostStageId1, LostStageId2 };
        var staleCutoff = DateTime.Today.AddDays(-14);

        _overdueRows = _currentSnapshot.Opportunities
            .Where(o => !exitStages.Contains(o.StageId) && o.NextFollowUpDate.HasValue && o.NextFollowUpDate.Value.Date < DateTime.Today)
            .Select(o => new OverdueMiniRow
            {
                ClientName = o.ClientName,
                EmployeeName = o.EmployeeName,
                DaysOverdue = (DateTime.Today - o.NextFollowUpDate!.Value.Date).Days,
                Value = o.ExpectedValue
            })
            .OrderByDescending(x => x.DaysOverdue)
            .ThenByDescending(x => x.Value)
            .Take(5)
            .ToList();

        _staleRows = _currentSnapshot.Opportunities
            .Where(o => !exitStages.Contains(o.StageId) && (o.LastContactDate == null || o.LastContactDate < staleCutoff))
            .Select(o => new StaleMiniRow
            {
                ClientName = o.ClientName,
                EmployeeName = o.EmployeeName,
                DaysStale = o.LastContactDate.HasValue
                    ? (DateTime.Today - o.LastContactDate.Value.Date).Days
                    : (DateTime.Today - o.CreatedAt.Date).Days,
                Value = o.ExpectedValue
            })
            .OrderByDescending(x => x.DaysStale)
            .ThenByDescending(x => x.Value)
            .Take(5)
            .ToList();
    }

    private void BuildInsights()
    {
        _insights = new();

        var topStage = _stageRows
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.Value)
            .FirstOrDefault();

        if (topStage != null)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.AccountTree,
                Title = "أكبر مرحلة",
                Value = topStage.StageName,
                Description = $"{topStage.Count} فرصة — {topStage.Percent:F1}% من الإجمالي",
                ToneClass = "tone-indigo"
            });
        }

        _insights.Add(new InsightItem
        {
            Icon = Icons.Material.Rounded.AttachMoney,
            Title = "إيراد الفترة",
            Value = FormatMoney(_revenue),
            Description = _revenueChange,
            ToneClass = "tone-green"
        });

        var topLossReason = _lostReasonPoints.FirstOrDefault();
        if (topLossReason != null)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.ReportProblem,
                Title = "أكثر سبب خسارة",
                Value = topLossReason.Reason,
                Description = $"{topLossReason.Count} فرصة مفقودة",
                ToneClass = "tone-red"
            });
        }

        _insights.Add(new InsightItem
        {
            Icon = Icons.Material.Rounded.Campaign,
            Title = "أفضل مصدر",
            Value = _bestSource,
            Description = $"أفضل مساهمة في الإيراد المحقق",
            ToneClass = "tone-gold"
        });

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private void ResolveSelectedStage()
    {
        var validStageIds = _stageRows.Select(x => x.StageId).Distinct().ToList();

        if (!validStageIds.Any())
        {
            _selectedStageId = null;
            return;
        }

        if (_selectedStageId.HasValue && validStageIds.Contains(_selectedStageId.Value))
            return;

        var preferred = _stageRows
            .Where(x => x.StageId != WonStageId && x.StageId != LostStageId1 && x.StageId != LostStageId2)
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.Value)
            .FirstOrDefault();

        _selectedStageId = preferred?.StageId ?? validStageIds.First();
    }

    private void BuildSelectedStageAnalytics()
    {
        _selectedStageName = "—";
        _selectedStageCount = 0;
        _selectedStageValue = 0m;
        _selectedStagePercent = 0d;
        _selectedStageAvgValue = 0m;
        _selectedStageTopEmployee = "—";
        _selectedStageEmployeePoints = new();
        _selectedStageDealPoints = new();

        if (!_selectedStageId.HasValue)
            return;

        var rows = _currentSnapshot.Opportunities
            .Where(o => o.StageId == _selectedStageId.Value)
            .ToList();

        if (!rows.Any())
            return;

        var summary = _stageRows.FirstOrDefault(x => x.StageId == _selectedStageId.Value);

        _selectedStageName = summary?.StageName ?? rows.First().StageName;
        _selectedStageCount = rows.Count;
        _selectedStageValue = rows.Sum(x => x.ExpectedValue);
        _selectedStagePercent = _currentSnapshot.Opportunities.Count > 0
            ? (double)_selectedStageCount / _currentSnapshot.Opportunities.Count * 100d
            : 0d;
        _selectedStageAvgValue = _selectedStageCount > 0 ? _selectedStageValue / _selectedStageCount : 0m;

        var topEmployee = rows
            .GroupBy(x => x.EmployeeName)
            .Select(g => new
            {
                Employee = g.Key,
                Count = g.Count(),
                Value = g.Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.Value)
            .FirstOrDefault();

        _selectedStageTopEmployee = topEmployee?.Employee ?? "—";

        _selectedStageEmployeePoints = rows
            .GroupBy(x => x.EmployeeName)
            .Select(g => new StageEmployeePoint
            {
                Employee = g.Key,
                Count = g.Count(),
                Value = g.Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.Value)
            .Take(8)
            .ToList();

        _selectedStageDealPoints = rows
            .OrderByDescending(x => x.ExpectedValue)
            .ThenByDescending(x => x.CreatedAt)
            .Take(8)
            .Select(x => new StageDealPoint
            {
                ClientName = x.ClientName,
                Value = x.ExpectedValue
            })
            .ToList();
    }

    private void SelectStage(int stageId)
    {
        _selectedStageId = _selectedStageId == stageId ? null : stageId;
        BuildSelectedStageAnalytics();
        StateHasChanged();
    }

    private void ClearSelectedStage()
    {
        _selectedStageId = null;
        BuildSelectedStageAnalytics();
        StateHasChanged();
    }

    private bool IsSelectedStage(int stageId)
        => _selectedStageId.HasValue && _selectedStageId.Value == stageId;

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("لوحة تحكم CRM");
            sb.AppendLine($"الفترة الحالية,{SelectedPeriodLabel}");
            sb.AppendLine($"الفترة السابقة,{PreviousPeriodLabel}");
            sb.AppendLine($"الموظف,{SelectedEmployeeLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"إجمالي الإيرادات,{_revenue:N0}");
            sb.AppendLine($"فرص مفتوحة,{_openOpps}");
            sb.AppendLine($"قيمة الـ Pipeline المفتوح,{_openPipelineValue:N0}");
            sb.AppendLine($"معدل الإغلاق,{_closeRate:F1}%");
            sb.AppendLine($"متابعات متأخرة,{_overdueFollowups}");
            sb.AppendLine($"تفاعلات الفترة,{_periodInteractions}");
            sb.AppendLine($"فرص راكدة,{_staleOpps}");
            sb.AppendLine($"قيمة الفرص الراكدة,{_staleValue:N0}");
            sb.AppendLine();

            sb.AppendLine("خط المبيعات");
            sb.AppendLine("المرحلة,عدد الفرص,القيمة");
            foreach (var row in _stageRows)
            {
                sb.AppendLine($"{row.StageName},{row.Count},{row.Value:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("أفضل مندوبي الفترة");
            sb.AppendLine("الترتيب,الموظف,المبيعات,الإيرادات");
            foreach (var row in _topPerformers)
            {
                sb.AppendLine($"{row.Rank},{row.EmployeeName},{row.WonCount},{row.Revenue:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("آخر المبيعات");
            sb.AppendLine("العميل,الموظف,القيمة,التاريخ");
            foreach (var row in _recentWins)
            {
                sb.AppendLine($"{row.ClientName},{row.EmployeeName},{row.Value:N0},{FDate(row.CreatedAt)}");
            }

            var csv = sb.ToString();
            var fileName = $"crm-dashboard-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

