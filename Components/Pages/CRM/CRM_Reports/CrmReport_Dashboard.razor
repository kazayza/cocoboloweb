@page "/crm/reports/dashboard"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>لوحة تحكم CRM</PageTitle>

<div class="crmx-page" dir="rtl">

    @* Background *@
    <div class="crmx-bg">
        <div class="crmx-orb orb-1"></div>
        <div class="crmx-orb orb-2"></div>
        <div class="crmx-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="crmx-hero">
        <div class="crmx-hero-grid"></div>

        <div class="crmx-hero-content">
            <div class="crmx-hero-top">
                <button class="crmx-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="crmx-badge">
                    <span class="badge-dot"></span>
                    <span>CRM Executive Command Center</span>
                </div>
            </div>

            <div class="crmx-hero-main">
                <div class="crmx-hero-text">
                    <h1>لوحة <span>تحكم</span> CRM الشاملة</h1>
                    <p>
                        مركز قيادة تنفيذي يجمع أهم مؤشرات الـ CRM في شاشة واحدة:
                        الإيرادات، خط المبيعات، التحويل، النشاط، المتابعات، الركود، أداء الفريق، وأسباب الخسارة.
                    </p>

                    <div class="crmx-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">أفضل موظف</span>
                            <span class="chip-value">@_bestPerformerName</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">أفضل مصدر</span>
                            <span class="chip-value">@_bestSource</span>
                        </div>
                    </div>
                </div>

                <div class="crmx-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_closeRate.ToString("F1")%</div>
                            <div class="summary-caption">معدل الإغلاق</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card crmx-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية والموظف أو استخدم الفلاتر السريعة</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تحديث اللوحة
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(1)">هذا الشهر</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudSelect T="int?"
                       @bind-Value="_empId"
                       Label="الموظف"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Class="filter-field">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem T="int?" Value="@((int?)emp.Id)">@emp.Name</MudSelectItem>
                }
            </MudSelect>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card crmx-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحميل لوحة التحكم...</h3>
                <p>يتم تجميع المؤشرات التنفيذية ورسوم الـ CRM</p>
            </div>
        </div>
    }
    else
    {
        <div class="crmx-content">

            @* KPI GRID *@
            <section class="crmx-kpis">
                <div class="glass-card kpi-card">
                    <div class="kpi-icon green">💰</div>
                    <div class="kpi-body">
                        <div class="kpi-head-row">
                            <div class="kpi-label">إجمالي الإيرادات</div>
                            <span class="trend-badge @GetTrendClass(_revenue, _prevRevenue)">
                                @GetTrendText(_revenue, _prevRevenue)
                            </span>
                        </div>
                        <div class="kpi-value">@FormatMoney(_revenue)</div>
                        <div class="kpi-sub">@_revenueChange</div>
                    </div>
                </div>

                <div class="glass-card kpi-card">
                    <div class="kpi-icon blue">📊</div>
                    <div class="kpi-body">
                        <div class="kpi-head-row">
                            <div class="kpi-label">فرص مفتوحة</div>
                            <span class="trend-badge @GetTrendClass(_openOpps, _prevOpenOpps)">
                                @GetTrendText(_openOpps, _prevOpenOpps)
                            </span>
                        </div>
                        <div class="kpi-value">@_openOpps.ToString("N0")</div>
                        <div class="kpi-sub">Pipeline مفتوح: @FormatMoney(_openPipelineValue)</div>
                    </div>
                </div>

                <div class="glass-card kpi-card">
                    <div class="kpi-icon purple">📈</div>
                    <div class="kpi-body">
                        <div class="kpi-head-row">
                            <div class="kpi-label">معدل الإغلاق</div>
                            <span class="trend-badge @GetTrendClass(_closeRate, _prevCloseRate)">
                                @GetTrendText(_closeRate, _prevCloseRate)
                            </span>
                        </div>
                        <div class="kpi-value">@_closeRate.ToString("F1")%</div>
                        <div class="kpi-sub">تم البيع ÷ إجمالي الفرص</div>
                    </div>
                </div>

                <div class="glass-card kpi-card">
                    <div class="kpi-icon red">⏰</div>
                    <div class="kpi-body">
                        <div class="kpi-label">متابعات متأخرة</div>
                        <div class="kpi-value">@_overdueFollowups.ToString("N0")</div>
                        <div class="kpi-sub">تحتاج تدخلًا سريعًا</div>
                    </div>
                </div>

                <div class="glass-card kpi-card">
                    <div class="kpi-icon orange">📞</div>
                    <div class="kpi-body">
                        <div class="kpi-head-row">
                            <div class="kpi-label">تفاعلات الفترة</div>
                            <span class="trend-badge @GetTrendClass(_periodInteractions, _prevPeriodInteractions)">
                                @GetTrendText(_periodInteractions, _prevPeriodInteractions)
                            </span>
                        </div>
                        <div class="kpi-value">@_periodInteractions.ToString("N0")</div>
                        <div class="kpi-sub">نشاط تشغيلي داخل الفترة المحددة</div>
                    </div>
                </div>

                <div class="glass-card kpi-card">
                    <div class="kpi-icon amber">⚠️</div>
                    <div class="kpi-body">
                        <div class="kpi-label">فرص راكدة</div>
                        <div class="kpi-value">@_staleOpps.ToString("N0")</div>
                        <div class="kpi-sub">قيمة مهددة: @FormatMoney(_staleValue)</div>
                    </div>
                </div>
            </section>

            @* INSIGHTS *@
            <section class="crmx-insights">
                @foreach (var insight in _insights)
                {
                    <div class="glass-card insight-card">
                        <div class="insight-icon @insight.ToneClass">
                            <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                        </div>
                        <div class="insight-body">
                            <div class="insight-title">@insight.Title</div>
                            <div class="insight-value">@insight.Value</div>
                            <div class="insight-desc">@insight.Description</div>
                        </div>
                    </div>
                }
            </section>

            @* MAIN CHARTS *@
            <section class="crmx-charts-grid">
                <div class="glass-card chart-card-large">
                    <div class="card-head">
                        <div>
                            <h3>خط المبيعات حسب المرحلة</h3>
                            <p>عدد الفرص وقيمتها داخل كل مرحلة</p>
                        </div>
                    </div>

                    @if (_pipelinePoints.Any())
                    {
                        <ApexChart TItem="PipelinePoint"
                                   Options="_pipelineOptions"
                                   Height="360">
                            <ApexPointSeries TItem="PipelinePoint"
                                             Items="@_pipelinePoints"
                                             Name="عدد الفرص"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Stage"
                                             YValue="x => x.Count" />

                            <ApexPointSeries TItem="PipelinePoint"
                                             Items="@_pipelinePoints"
                                             Name="القيمة"
                                             SeriesType="SeriesType.Line"
                                             XValue="x => x.Stage"
                                             YValue="x => x.Value" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty">لا توجد بيانات كافية</div>
                    }
                </div>

                <div class="glass-card chart-card-large">
                    <div class="card-head">
                        <div>
                            <h3>اتجاه الإيرادات الشهرية</h3>
                            <p>الإيرادات المحققة خلال الفترة المحددة</p>
                        </div>
                    </div>

                    @if (_revenuePoints.Any())
                    {
                        <ApexChart TItem="RevenueTrendPoint"
                                   Options="_revenueOptions"
                                   Height="360">
                            <ApexPointSeries TItem="RevenueTrendPoint"
                                             Items="@_revenuePoints"
                                             Name="الإيرادات"
                                             SeriesType="SeriesType.Line"
                                             XValue="x => x.Month"
                                             YValue="x => x.Value" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty">لا توجد بيانات كافية</div>
                    }
                </div>
            </section>

            @* SECONDARY CHARTS *@
            <section class="crmx-secondary-grid">
                <div class="glass-card chart-card">
                    <div class="card-head">
                        <div>
                            <h3>تحويل العملاء المحتملين</h3>
                            <p>Leads مقابل التحويل ثم البيع</p>
                        </div>
                    </div>

                    @if (_leadPoints.Any())
                    {
                        <ApexChart TItem="LeadTrendPoint"
                                   Options="_leadOptions"
                                   Height="320">
                            <ApexPointSeries TItem="LeadTrendPoint"
                                             Items="@_leadPoints"
                                             Name="Leads"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Month"
                                             YValue="x => x.TotalLeads" />

                            <ApexPointSeries TItem="LeadTrendPoint"
                                             Items="@_leadPoints"
                                             Name="تم التحويل"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Month"
                                             YValue="x => x.ConvertedLeads" />

                            <ApexPointSeries TItem="LeadTrendPoint"
                                             Items="@_leadPoints"
                                             Name="تم البيع"
                                             SeriesType="SeriesType.Line"
                                             XValue="x => x.Month"
                                             YValue="x => x.WonLeads" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية</div>
                    }
                </div>

                <div class="glass-card chart-card">
                    <div class="card-head">
                        <div>
                            <h3>النشاط اليومي</h3>
                            <p>التفاعلات والفرص والمبيعات داخل الفترة</p>
                        </div>
                    </div>

                    @if (_activityPoints.Any())
                    {
                        <ApexChart TItem="ActivityPoint"
                                   Options="_activityOptions"
                                   Height="320">
                            <ApexPointSeries TItem="ActivityPoint"
                                             Items="@_activityPoints"
                                             Name="التفاعلات"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Label"
                                             YValue="x => x.Interactions" />

                            <ApexPointSeries TItem="ActivityPoint"
                                             Items="@_activityPoints"
                                             Name="الفرص"
                                             SeriesType="SeriesType.Line"
                                             XValue="x => x.Label"
                                             YValue="x => x.NewOpps" />

                            <ApexPointSeries TItem="ActivityPoint"
                                             Items="@_activityPoints"
                                             Name="المبيعات"
                                             SeriesType="SeriesType.Line"
                                             XValue="x => x.Label"
                                             YValue="x => x.Won" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية</div>
                    }
                </div>

                <div class="glass-card chart-card">
                    <div class="card-head">
                        <div>
                            <h3>أسباب الخسارة</h3>
                            <p>أكثر الأسباب تكرارًا</p>
                        </div>
                    </div>

                    @if (_lostReasonPoints.Any())
                    {
                        <ApexChart TItem="LostReasonPoint"
                                   Options="_lostReasonOptions"
                                   Height="320">
                            <ApexPointSeries TItem="LostReasonPoint"
                                             Items="@_lostReasonPoints"
                                             Name="الخسائر"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Reason"
                                             YValue="x => x.Count" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية</div>
                    }
                </div>

                <div class="glass-card chart-card">
                    <div class="card-head">
                        <div>
                            <h3>مصادر العملاء</h3>
                            <p>أفضل المصادر من حيث الإيراد</p>
                        </div>
                    </div>

                    @if (_sourcePoints.Any())
                    {
                        <ApexChart TItem="SourcePoint"
                                   Options="_sourceOptions"
                                   Height="320">
                            <ApexPointSeries TItem="SourcePoint"
                                             Items="@_sourcePoints"
                                             Name="الإيراد"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Source"
                                             YValue="x => x.Revenue" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية</div>
                    }
                </div>
            </section>

            @* DRILL DOWN BY STAGE *@
            <section class="glass-card crmx-drill">
                <div class="card-head drill-head">
                    <div>
                        <h3>Drill-down حسب المرحلة</h3>
                        <p>اختر مرحلة لعرض تفاصيلها. اختيار عنصر جديد يستبدل القديم مباشرة.</p>
                    </div>

                    <div class="drill-head-actions">
                        @if (_selectedStageId.HasValue)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="@MudColor.Error"
                                       Size="@MudSize.Small"
                                       OnClick="ClearSelectedStage">
                                إلغاء اختيار المرحلة
                            </MudButton>

                            <MudButton Variant="Variant.Filled"
                                       Color="@MudColor.Primary"
                                       Size="@MudSize.Small"
                                       OnClick="@(() => Navigation.NavigateTo(BuildReportUrl("/crm/reports/pipeline", _selectedStageId.HasValue ? $"stageId={_selectedStageId.Value}" : null)))">
                                فتح تقرير Pipeline
                            </MudButton>
                        }
                    </div>
                </div>

                <div class="stage-chip-row">
                    @foreach (var stage in _stageRows)
                    {
                        <button class="stage-chip-btn @(IsSelectedStage(stage.StageId) ? "stage-chip-active" : "")"
                                @onclick="() => SelectStage(stage.StageId)">
                            <span>@stage.StageName</span>
                            <small>@stage.Count.ToString("N0") فرصة</small>
                        </button>
                    }
                </div>

                @if (_selectedStageId.HasValue)
                {
                    <div class="drill-mini-kpis">
                        <div class="mini-kpi">
                            <span class="mini-label">المرحلة المحددة</span>
                            <strong>@_selectedStageName</strong>
                        </div>
                        <div class="mini-kpi">
                            <span class="mini-label">عدد الفرص</span>
                            <strong>@_selectedStageCount.ToString("N0")</strong>
                        </div>
                        <div class="mini-kpi">
                            <span class="mini-label">إجمالي القيمة</span>
                            <strong>@FormatMoney(_selectedStageValue)</strong>
                        </div>
                        <div class="mini-kpi">
                            <span class="mini-label">نسبة من الإجمالي</span>
                            <strong>@_selectedStagePercent.ToString("F1")%</strong>
                        </div>
                        <div class="mini-kpi">
                            <span class="mini-label">متوسط الفرصة</span>
                            <strong>@FormatMoney(_selectedStageAvgValue)</strong>
                        </div>
                        <div class="mini-kpi">
                            <span class="mini-label">أفضل موظف</span>
                            <strong>@_selectedStageTopEmployee</strong>
                        </div>
                    </div>

                    <div class="drill-grid">
                        <div class="glass-inner-card">
                            <div class="card-head">
                                <div>
                                    <h3>الموظفون داخل المرحلة</h3>
                                    <p>عدد الفرص والقيمة لكل موظف داخل المرحلة المحددة</p>
                                </div>
                            </div>

                            @if (_selectedStageEmployeePoints.Any())
                            {
                                <ApexChart TItem="StageEmployeePoint"
                                           Options="_selectedStageEmployeeOptions"
                                           Height="320"
                                           @key="@_selectedStageId">
                                    <ApexPointSeries TItem="StageEmployeePoint"
                                                     Items="@_selectedStageEmployeePoints"
                                                     Name="عدد الفرص"
                                                     SeriesType="SeriesType.Bar"
                                                     XValue="x => x.Employee"
                                                     YValue="x => x.Count" />

                                    <ApexPointSeries TItem="StageEmployeePoint"
                                                     Items="@_selectedStageEmployeePoints"
                                                     Name="القيمة"
                                                     SeriesType="SeriesType.Line"
                                                     XValue="x => x.Employee"
                                                     YValue="x => x.Value" />
                                </ApexChart>
                            }
                            else
                            {
                                <div class="chart-empty small">لا توجد بيانات كافية</div>
                            }
                        </div>

                        <div class="glass-inner-card">
                            <div class="card-head">
                                <div>
                                    <h3>أكبر الفرص في المرحلة</h3>
                                    <p>أعلى الفرص قيمة داخل المرحلة المحددة</p>
                                </div>
                            </div>

                            @if (_selectedStageDealPoints.Any())
                            {
                                <ApexChart TItem="StageDealPoint"
                                           Options="_selectedStageDealsOptions"
                                           Height="320"
                                           @key="@_selectedStageId">
                                    <ApexPointSeries TItem="StageDealPoint"
                                                     Items="@_selectedStageDealPoints"
                                                     Name="القيمة"
                                                     SeriesType="SeriesType.Bar"
                                                     XValue="x => x.ClientName"
                                                     YValue="x => x.Value" />
                                </ApexChart>
                            }
                            else
                            {
                                <div class="chart-empty small">لا توجد بيانات كافية</div>
                            }
                        </div>
                    </div>
                }
            </section>

            @* OPS TABLES *@
            <section class="crmx-ops-grid">
                <div class="glass-card table-card">
                    <div class="card-head">
                        <div>
                            <h3>🏆 أفضل مندوبي الفترة</h3>
                            <p>ترتيب الموظفين حسب الإيراد المحقق داخل الفترة الحالية</p>
                        </div>
                    </div>

                    <MudTable Items="@_topPerformers"
                              Hover="true"
                              Elevation="0"
                              Dense="true"
                              RowsPerPage="5"
                              Class="compact-table">
                        <HeaderContent>
                            <MudTh>الترتيب</MudTh>
                            <MudTh>الموظف</MudTh>
                            <MudTh>المبيعات</MudTh>
                            <MudTh>الإيرادات</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <span class="rank-badge @(context.Rank <= 3 ? "rank-gold" : "")">
                                    @(context.Rank == 1 ? "🥇" : (context.Rank == 2 ? "🥈" : (context.Rank == 3 ? "🥉" : context.Rank.ToString())))
                                </span>
                            </MudTd>
                            <MudTd style="font-weight:500;">@context.EmployeeName</MudTd>
                            <MudTd>@context.WonCount</MudTd>
                            <MudTd>@FormatMoney(context.Revenue)</MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText>لا توجد بيانات</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </div>

                <div class="glass-card table-card">
                    <div class="card-head">
                        <div>
                            <h3>✅ آخر المبيعات</h3>
                            <p>أحدث الصفقات الرابحة</p>
                        </div>
                    </div>

                    <MudTable Items="@_recentWins"
                              Hover="true"
                              Elevation="0"
                              Dense="true"
                              RowsPerPage="5"
                              Class="compact-table">
                        <HeaderContent>
