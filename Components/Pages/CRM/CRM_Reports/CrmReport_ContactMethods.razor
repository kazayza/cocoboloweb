        _selectedMethodStagePoints = new();
        _detailRows = new();

        IEnumerable<MethodInteractionEvent> filteredRows = rows;

        if (_selectedMethodId.HasValue)
            filteredRows = rows.Where(x => x.MethodId == _selectedMethodId.Value);

        var filtered = filteredRows.ToList();

        if (!filtered.Any())
            return;

        _selectedMethodName = filtered.First().MethodName;
        _selectedMethodInteractionCount = filtered.Count;

        var uniqueOpps = filtered
            .GroupBy(x => x.OpportunityId)
            .Select(g => g.First())
            .ToList();

        _selectedMethodOpportunityCount = uniqueOpps.Count;
        _selectedMethodWonCount = uniqueOpps.Count(x => IsWon(x.StageId));
        _selectedMethodLostCount = uniqueOpps.Count(x => IsLost(x.StageId));
        _selectedMethodOpenCount = _selectedMethodOpportunityCount - _selectedMethodWonCount - _selectedMethodLostCount;
        _selectedMethodRevenue = uniqueOpps.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
        _selectedMethodCloseRate = _selectedMethodOpportunityCount > 0 ? (double)_selectedMethodWonCount / _selectedMethodOpportunityCount * 100d : 0d;
        _selectedMethodAvgInteractionsPerOpp = _selectedMethodOpportunityCount > 0 ? (double)_selectedMethodInteractionCount / _selectedMethodOpportunityCount : 0d;

        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var monthMap = filtered
            .GroupBy(x => new DateTime(x.InteractionDate.Year, x.InteractionDate.Month, 1))
            .ToDictionary(g => g.Key, g => g.ToList());

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthMap.TryGetValue(month, out var monthRows);
            monthRows ??= new List<MethodInteractionEvent>();

            var uniqueMonthOpps = monthRows
                .GroupBy(x => x.OpportunityId)
                .Select(g => g.First())
                .ToList();

            _selectedMethodMonthlyPoints.Add(new MethodMonthlyPoint
            {
                Month = month.ToString("MMM yyyy", _arCulture),
                InteractionCount = monthRows.Count,
                OpportunityCount = uniqueMonthOpps.Count,
                Revenue = uniqueMonthOpps.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue)
            });
        }

        var topMonth = _selectedMethodMonthlyPoints
            .OrderByDescending(x => x.Revenue)
            .ThenByDescending(x => x.InteractionCount)
            .ThenByDescending(x => x.OpportunityCount)
            .FirstOrDefault();

        _selectedMethodTopMonth = topMonth?.Month ?? "—";

        var topEmployee = uniqueOpps
            .GroupBy(x => x.EmployeeName)
            .Select(g => new
            {
                Employee = g.Key,
                Revenue = g.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue),
                Count = g.Count()
            })
            .OrderByDescending(x => x.Revenue)
            .ThenByDescending(x => x.Count)
            .FirstOrDefault();

        _selectedMethodTopEmployee = topEmployee?.Employee ?? "—";

        _selectedMethodStagePoints = uniqueOpps
            .GroupBy(x => x.StageName)
            .Select(g => new MethodStagePoint
            {
                Stage = g.Key,
                Count = g.Count()
            })
            .OrderByDescending(x => x.Count)
            .ToList();

        _detailRows = filtered
            .GroupBy(x => new { x.MethodId, x.OpportunityId })
            .Select(g =>
            {
                var first = g.First();

                return new MethodOpportunityDetailRow
                {
                    OpportunityId = first.OpportunityId,
                    MethodName = first.MethodName,
                    ClientName = first.ClientName,
                    EmployeeName = first.EmployeeName,
                    StageId = first.StageId,
                    StageName = first.StageName,
                    StageColor = first.StageColor,
                    CreatedAt = first.CreatedAt,
                    LastInteractionDate = g.Max(x => x.InteractionDate),
                    InteractionCount = g.Count(),
                    ExpectedValue = first.ExpectedValue,
                    AgeDays = first.AgeDays
                };
            })
            .OrderByDescending(x => x.ExpectedValue)
            .ThenByDescending(x => x.InteractionCount)
            .ToList();
    }

    private void BuildInsights()
    {
        _insights = new();

        if (_methodRows.Any())
        {
            var topRevenue = _methodRows
                .OrderByDescending(x => x.TotalRevenue)
                .ThenByDescending(x => x.WonCount)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.AttachMoney,
                Title = "أعلى إيراد مرتبط",
                Value = topRevenue.MethodName,
                Description = $"{FormatMoney(topRevenue.TotalRevenue)}",
                ToneClass = "tone-green"
            });

            var rateCandidates = _methodRows.Where(x => x.OpportunityCount >= 3).ToList();
            if (!rateCandidates.Any())
                rateCandidates = _methodRows.Where(x => x.OpportunityCount > 0).ToList();

            if (rateCandidates.Any())
            {
                var topRate = rateCandidates
                    .OrderByDescending(x => x.CloseRate)
                    .ThenByDescending(x => x.WonCount)
                    .First();

                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.TrendingUp,
                    Title = "أفضل إغلاق",
                    Value = topRate.MethodName,
                    Description = $"{topRate.CloseRate:F1}% من {topRate.OpportunityCount} فرصة",
                    ToneClass = "tone-indigo"
                });

                var highIntensity = rateCandidates
                    .OrderByDescending(x => x.AvgInteractionsPerOpp)
                    .ThenByDescending(x => x.InteractionCount)
                    .First();

                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.Bolt,
                    Title = "أعلى كثافة تواصل",
                    Value = highIntensity.MethodName,
                    Description = $"{highIntensity.AvgInteractionsPerOpp:F1} تفاعل/فرصة",
                    ToneClass = "tone-gold"
                });
            }

            var mostUsed = _methodRows
                .OrderByDescending(x => x.InteractionCount)
                .ThenByDescending(x => x.OpportunityCount)
                .FirstOrDefault();

            if (mostUsed != null)
            {
                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.Forum,
                    Title = "الأكثر استخداماً",
                    Value = mostUsed.MethodName,
                    Description = $"{mostUsed.InteractionCount} تفاعل",
                    ToneClass = "tone-slate"
                });
            }
        }

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("تقرير طرق التواصل الأكثر فاعلية");
            sb.AppendLine($"الفترة الحالية,{SelectedPeriodLabel}");
            sb.AppendLine($"الفترة السابقة,{PreviousPeriodLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"الطرق النشطة,{_activeMethodCount}");
            sb.AppendLine($"إجمالي التفاعلات,{_totalInteractions}");
            sb.AppendLine($"الفرص المتأثرة,{_touchedOppCount}");
            sb.AppendLine($"فرص تم البيع,{_wonOppCount}");
            sb.AppendLine($"الإيرادات المرتبطة,{_totalRevenue:N0}");
            sb.AppendLine($"معدل الإغلاق,{_overallCloseRate:F1}%");
            sb.AppendLine($"أكثر طريقة استخداماً,{_mostUsedMethod}");
            sb.AppendLine($"أعلى طريقة تحويلاً,{_bestConversionMethod}");
            sb.AppendLine();

            sb.AppendLine("تفاصيل الطرق");
            sb.AppendLine("الطريقة,التفاعلات,الفرص,تم البيع,خسارة,مفتوح,معدل الإغلاق,الإيراد,متوسط الصفقة");
            foreach (var row in _methodRows)
            {
                sb.AppendLine($"{row.MethodName},{row.InteractionCount},{row.OpportunityCount},{row.WonCount},{row.LostCount},{row.OpenCount},{row.CloseRate:F1}%,{row.TotalRevenue:N0},{row.AvgDealValue:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("الاتجاه الشهري");
            sb.AppendLine("الشهر,التفاعلات,الفرص,الإيراد");
            foreach (var row in _overallMonthlyPoints)
            {
                sb.AppendLine($"{row.Month},{row.InteractionCount},{row.OpportunityCount},{row.Revenue:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("تفاصيل الفرص المرتبطة");
            sb.AppendLine("الطريقة,العميل,الموظف,المرحلة,الحالة,عدد التفاعلات,آخر تفاعل,القيمة");
            foreach (var row in _detailRows)
            {
                sb.AppendLine($"{row.MethodName},{row.ClientName},{row.EmployeeName},{row.StageName},{GetStatusLabel(row.StageId)},{row.InteractionCount},{FormatDate(row.LastInteractionDate)},{row.ExpectedValue:N0}");
            }

            var csv = sb.ToString();
            var fileName = $"contact-methods-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

