@page "/crm/reports/contact-methods"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير طرق التواصل الأكثر فاعلية</PageTitle>

<div class="cmtx-page" dir="rtl">

    @* Background *@
    <div class="cmtx-bg">
        <div class="cmtx-orb orb-1"></div>
        <div class="cmtx-orb orb-2"></div>
        <div class="cmtx-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="cmtx-hero">
        <div class="cmtx-hero-grid"></div>

        <div class="cmtx-hero-content">
            <div class="cmtx-hero-top">
                <button class="cmtx-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="cmtx-badge">
                    <span class="badge-dot"></span>
                    <span>Contact Methods Intelligence</span>
                </div>
            </div>

            <div class="cmtx-hero-main">
                <div class="cmtx-hero-text">
                    <h1>طرق <span>التواصل</span> الأكثر فاعلية</h1>
                    <p>
                        لوحة تنفيذية لقياس أثر طرق التواصل المختلفة على الفرص،
                        من حيث كثافة الاستخدام، الفرص المتأثرة، الصفقات الرابحة، والإيرادات المرتبطة.
                    </p>

                    <div class="cmtx-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">أكثر طريقة استخداماً</span>
                            <span class="chip-value">@_mostUsedMethod</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">أفضل طريقة إيرادًا</span>
                            <span class="chip-value">@_bestRevenueMethod</span>
                        </div>
                    </div>
                </div>

                <div class="cmtx-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_overallCloseRate.ToString("F1")%</div>
                            <div class="summary-caption">معدل الإغلاق</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card cmtx-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية أو استخدم الفترات السريعة لتحليل طرق التواصل</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card cmtx-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل طرق التواصل...</h3>
                <p>يتم تجهيز المؤشرات، الرسوم البيانية، وتحليل الفاعلية</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="cmtx-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">◎</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الطرق النشطة</div>
                        <span class="trend-badge @GetTrendClass(_activeMethodCount, _prevActiveMethodCount)">
                            @GetTrendText(_activeMethodCount, _prevActiveMethodCount)
                        </span>
                    </div>
                    <div class="kpi-value">@_activeMethodCount.ToString("N0")</div>
                    <div class="kpi-sub">طرق تواصل ظهرت خلال الفترة الحالية</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon blue">💬</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي التفاعلات</div>
                        <span class="trend-badge @GetTrendClass(_totalInteractions, _prevTotalInteractions)">
                            @GetTrendText(_totalInteractions, _prevTotalInteractions)
                        </span>
                    </div>
                    <div class="kpi-value">@_totalInteractions.ToString("N0")</div>
                    <div class="kpi-sub">متوسط التفاعلات لكل فرصة: @_avgInteractionsPerOpportunity.ToString("F1")</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon teal">#</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الفرص المتأثرة</div>
                        <span class="trend-badge @GetTrendClass(_touchedOppCount, _prevTouchedOppCount)">
                            @GetTrendText(_touchedOppCount, _prevTouchedOppCount)
                        </span>
                    </div>
                    <div class="kpi-value">@_touchedOppCount.ToString("N0")</div>
                    <div class="kpi-sub">عدد الفرص التي دخلت عليها هذه الطرق</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon purple">★</div>
                <div class="kpi-body">
                    <div class="kpi-label">أكثر طريقة استخداماً</div>
                    <div class="kpi-value kpi-name">@_mostUsedMethod</div>
                    <div class="kpi-sub">@_mostUsedMethodCount.ToString("N0") تفاعل</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">%</div>
                <div class="kpi-body">
                    <div class="kpi-label">أعلى طريقة تحويلاً</div>
                    <div class="kpi-value kpi-name">@_bestConversionMethod</div>
                    <div class="kpi-sub">@_bestConversionRate.ToString("F1")% إغلاق</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon green">₪</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الإيرادات المرتبطة</div>
                        <span class="trend-badge @GetTrendClass(_totalRevenue, _prevTotalRevenue)">
                            @GetTrendText(_totalRevenue, _prevTotalRevenue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_totalRevenue)</div>
                    <div class="kpi-sub">إيراد الفرص الرابحة التي مرت بهذه التفاعلات</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="cmtx-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* MAIN DASHBOARD *@
        <section class="cmtx-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>مقارنة طرق التواصل</h3>
                        <p>عدد التفاعلات مقابل الصفقات الرابحة والإيراد المرتبط بكل طريقة</p>
                    </div>
                </div>

                @if (_methodOverviewPoints.Any())
                {
                    <ApexChart TItem="MethodOverviewPoint"
                               Options="_methodOverviewChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="MethodOverviewPoint"
                                         Items="@_methodOverviewPoints"
                                         Name="التفاعلات"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Method"
                                         YValue="x => x.InteractionCount" />

                        <ApexPointSeries TItem="MethodOverviewPoint"
                                         Items="@_methodOverviewPoints"
                                         Name="فرص تم البيع"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Method"
                                         YValue="x => x.WonCount" />

                        <ApexPointSeries TItem="MethodOverviewPoint"
                                         Items="@_methodOverviewPoints"
                                         Name="الإيراد"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Method"
                                         YValue="x => x.Revenue" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>معدل الإغلاق حسب الطريقة</h3>
                            <p>ترتيب الطرق حسب تحويل الفرص إلى صفقات رابحة</p>
                        </div>
                    </div>

                    @if (_methodRatePoints.Any())
                    {
                        <ApexChart TItem="MethodRatePoint"
                                   Options="_methodRateChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="MethodRatePoint"
                                             Items="@_methodRatePoints"
                                             Name="معدل الإغلاق %"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Method"
                                             YValue="x => x.CloseRate" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض المعدلات</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">الطرق النشطة</div>
                            <div class="compare-values">
                                <span>@_prevActiveMethodCount</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_activeMethodCount</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">التفاعلات</div>
                            <div class="compare-values">
                                <span>@_prevTotalInteractions</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_totalInteractions</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">الفرص المتأثرة</div>
                            <div class="compare-values">
                                <span>@_prevTouchedOppCount</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_touchedOppCount</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">الإيرادات</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevTotalRevenue)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_totalRevenue)</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @((_overallCloseRate >= _prevOverallCloseRate && _totalRevenue >= _prevTotalRevenue) ? "compare-good" : "compare-mid")">
                        @if (_overallCloseRate >= _prevOverallCloseRate && _totalRevenue >= _prevTotalRevenue)
                        {
                            <span>فاعلية طرق التواصل الحالية أفضل أو مساوية للفترة السابقة</span>
                        }
                        else
                        {
                            <span>بعض طرق التواصل تحتاج مراجعة وتحسين</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* ANALYTICS GRID *@
        <section class="cmtx-analytics-grid">
            <div class="glass-card side-card">
                <div class="card-head">
                    <div>
                        <h3>الاتجاه الشهري للتواصل</h3>
                        <p>التفاعلات والفرص المتأثرة والإيرادات المرتبطة عبر الشهور</p>
                    </div>
                </div>

                @if (_overallMonthlyPoints.Any())
                {
                    <ApexChart TItem="MethodMonthlyPoint"
                               Options="_overallMonthlyChartOptions"
                               Height="320">
                        <ApexPointSeries TItem="MethodMonthlyPoint"
                                         Items="@_overallMonthlyPoints"
                                         Name="التفاعلات"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.InteractionCount" />

                        <ApexPointSeries TItem="MethodMonthlyPoint"
                                         Items="@_overallMonthlyPoints"
                                         Name="الفرص"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.OpportunityCount" />

                        <ApexPointSeries TItem="MethodMonthlyPoint"
                                         Items="@_overallMonthlyPoints"
                                         Name="الإيراد"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Month"
                                         YValue="x => x.Revenue" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty small">لا توجد بيانات شهرية كافية</div>
                }
            </div>

            <div class="glass-card cmtx-method-table-card">
                <div class="card-head">
                    <div>
                        <h3>تفاصيل طرق التواصل</h3>
                        <p>ملخص كل طريقة من حيث التفاعلات والفرص والمبيعات والإيرادات</p>
                    </div>
                </div>

                <MudTable Items="@_methodRows"
                          Hover="true"
                          Dense="true"
                          Elevation="0"
                          RowsPerPage="10"
                          Breakpoint="Breakpoint.Sm"
                          Class="premium-table">
                    <HeaderContent>
                        <MudTh>طريقة التواصل</MudTh>
                        <MudTh>التفاعلات</MudTh>
                        <MudTh>الفرص</MudTh>
                        <MudTh>تم البيع</MudTh>
                        <MudTh>خسارة</MudTh>
                        <MudTh>مفتوح</MudTh>
                        <MudTh>معدل الإغلاق</MudTh>
                        <MudTh>الإيراد</MudTh>
                        <MudTh>متوسط الصفقة</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="طريقة التواصل">
                            <span class="method-label @(context.IsBestRevenue ? "method-best" : "")">
                                @context.MethodName
                                @if (context.IsBestRevenue)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Star"
                                             Color="@MudColor.Warning"
                                             Size="@MudSize.Small" />
                                }
                            </span>
                        </MudTd>
                        <MudTd DataLabel="التفاعلات">@context.InteractionCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="الفرص">@context.OpportunityCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="تم البيع">@context.WonCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="خسارة">@context.LostCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="مفتوح">@context.OpenCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="معدل الإغلاق">
                            <span class="rate-pill @GetCloseRatePillClass(context.CloseRate)">
                                @context.CloseRate.ToString("F1")%
                            </span>
                        </MudTd>
                        <MudTd DataLabel="الإيراد">@FormatMoney(context.TotalRevenue)</MudTd>
                        <MudTd DataLabel="متوسط الصفقة">@FormatMoney(context.AvgDealValue)</MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <div class="empty-data">
                            <div class="empty-icon">📉</div>
                            <h4>لا توجد بيانات</h4>
                            <p>لا توجد طرق تواصل مطابقة للفترة الحالية</p>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </section>

        @* METHOD DRILL-DOWN *@
        <section class="glass-card cmtx-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down حسب طريقة التواصل</h3>
                    <p>اختر طريقة لعرض تحليله الشهري ومراحل الفرص وأكبر الفرص المرتبطة بها</p>
                </div>

                @if (_selectedMethodId.HasValue)
                {
                    <button class="clear-method-btn" @onclick="ClearSelectedMethod">
                        إلغاء اختيار الطريقة
                    </button>
                }
            </div>

            <div class="method-chip-row">
                @foreach (var method in _methodRows)
                {
                    <button class="method-chip-btn @(IsSelectedMethod(method.MethodId) ? "method-chip-active" : "")"
                            @onclick="() => SelectMethod(method.MethodId)">
                        <span>@method.MethodName</span>
                        <small>@method.InteractionCount.ToString("N0") تفاعل</small>
                    </button>
                }
            </div>

            @if (_selectedMethodId.HasValue || _detailRows.Any())
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">الطريقة المحددة</span>
                        <strong>@_selectedMethodName</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">التفاعلات</span>
                        <strong>@_selectedMethodInteractionCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الفرص</span>
                        <strong>@_selectedMethodOpportunityCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">المبيعات</span>
                        <strong>@_selectedMethodWonCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الإيراد</span>
                        <strong>@FormatMoney(_selectedMethodRevenue)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">معدل الإغلاق</span>
                        <strong>@_selectedMethodCloseRate.ToString("F1")%</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أفضل شهر</span>
                        <strong>@_selectedMethodTopMonth</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>الاتجاه الشهري للطريقة</h3>
                                <p>التفاعلات والفرص والإيرادات عبر الشهور للطريقة المحددة</p>
                            </div>
                        </div>

                        @if (_selectedMethodMonthlyPoints.Any())
                        {
                            <ApexChart TItem="MethodMonthlyPoint"
                                       Options="_selectedMethodMonthlyChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="MethodMonthlyPoint"
                                                 Items="@_selectedMethodMonthlyPoints"
                                                 Name="التفاعلات"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.InteractionCount" />

                                <ApexPointSeries TItem="MethodMonthlyPoint"
                                                 Items="@_selectedMethodMonthlyPoints"
                                                 Name="الفرص"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.OpportunityCount" />

                                <ApexPointSeries TItem="MethodMonthlyPoint"
                                                 Items="@_selectedMethodMonthlyPoints"
                                                 Name="الإيراد"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.Revenue" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات شهرية كافية لهذه الطريقة</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>المراحل داخل الطريقة</h3>
                                <p>توزيع الفرص المرتبطة بالطريقة حسب المرحلة الحالية</p>
                            </div>
                        </div>

                        @if (_selectedMethodStagePoints.Any())
                        {
                            <ApexChart TItem="MethodStagePoint"
                                       Options="_selectedMethodStageChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="MethodStagePoint"
                                                 Items="@_selectedMethodStagePoints"
                                                 Name="عدد الفرص"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Stage"
                                                 YValue="x => x.Count" />
