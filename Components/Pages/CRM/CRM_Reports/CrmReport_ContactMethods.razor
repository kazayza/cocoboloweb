    private async Task ResetFiltersAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);
        _toDate = DateTime.Today;
        _selectedMethodId = null;
        await LoadData();
    }

    private async Task SetLastMonthsAsync(int months)
    {
        if (months <= 0) months = 12;

        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-(months - 1));
        _toDate = DateTime.Today;
        _selectedMethodId = null;

        await LoadData();
    }

    private async Task SetCurrentYearAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _selectedMethodId = null;

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentRows = await LoadPeriodRowsAsync(db, _fromDate, _toDate);

            if (TryGetPreviousRange(out var prevFrom, out var prevTo))
            {
                _previousPeriodLabel = $"{prevFrom.ToString("dd MMM yyyy", _arCulture)} — {prevTo.ToString("dd MMM yyyy", _arCulture)}";
                var previousRows = await LoadPeriodRowsAsync(db, prevFrom, prevTo);
                CalculatePreviousMetrics(previousRows);
            }
            else
            {
                _previousPeriodLabel = "غير متاح";
                ResetPreviousMetrics();
            }

            CalculateCurrentMetrics(_currentRows);
            BuildMethodSummary(_currentRows);
            BuildOverallMonthlyTrend(_currentRows);
            ResolveSelectedMethod();
            BuildSelectedMethodAnalytics(_currentRows);
            BuildInsights();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<List<MethodInteractionEvent>> LoadPeriodRowsAsync(db24804Context db, DateTime? from, DateTime? to)
    {
        var interactionQuery = db.CustomerInteractions.AsNoTracking();

        if (from.HasValue)
        {
            var fromDate = from.Value.Date;
            interactionQuery = interactionQuery.Where(i => i.InteractionDate >= fromDate);
        }

        if (to.HasValue)
        {
            var toExclusive = to.Value.Date.AddDays(1);
            interactionQuery = interactionQuery.Where(i => i.InteractionDate < toExclusive);
        }

        var interactions = await interactionQuery
            .Select(i => new InteractionRawRow
            {
                OpportunityId = i.OpportunityId,
                StatusId = i.StatusId,
                InteractionDate = i.InteractionDate
            })
            .ToListAsync();

        if (!interactions.Any())
            return new List<MethodInteractionEvent>();

        var statusIds = interactions
            .Where(x => x.StatusId.HasValue)
            .Select(x => x.StatusId!.Value)
            .Distinct()
            .ToList();

        var oppIds = interactions
            .Select(x => x.OpportunityId)
            .Distinct()
            .ToList();

        var statusMap = new Dictionary<int, MethodStatusRef>();

        if (statusIds.Any())
        {
            statusMap = await db.ContactStatuses
                .AsNoTracking()
                .Where(s => statusIds.Contains(s.StatusId))
                .Select(s => new MethodStatusRef
                {
                    StatusId = s.StatusId,
                    MethodName = s.StatusNameAr ?? s.StatusName ?? $"طريقة {s.StatusId}"
                })
                .ToDictionaryAsync(x => x.StatusId, x => x);
        }

        var opportunityMap = new Dictionary<int, OpportunityRefRow>();

        if (oppIds.Any())
        {
            var opportunities = await db.VwSalesOpportunities
                .AsNoTracking()
                .Where(o => oppIds.Contains(o.OpportunityId))
                .Select(o => new OpportunityRefRow
                {
                    OpportunityId = o.OpportunityId,
                    ClientName = o.ClientName ?? "—",
                    EmployeeName = o.EmployeeName ?? "—",
                    StageId = o.StageId,
                    StageName = o.StageNameAr ?? o.StageName ?? "—",
                    StageColor = o.StageColor ?? "",
                    CreatedAt = o.CreatedAt,
                    LastContactDate = o.LastContactDate,
                    ExpectedValue = o.ExpectedValue ?? 0m,
                    AgeDays = o.DaysSinceFirstContact ?? 0d
                })
                .ToListAsync();

            opportunityMap = opportunities.ToDictionary(x => x.OpportunityId, x => x);
        }

        var result = new List<MethodInteractionEvent>();

        foreach (var item in interactions)
        {
            if (!opportunityMap.TryGetValue(item.OpportunityId, out var opp))
                continue;

            var methodId = item.StatusId ?? 0;
            var methodName = item.StatusId.HasValue && statusMap.TryGetValue(item.StatusId.Value, out var statusRef)
                ? statusRef.MethodName
                : "غير محدد";

            result.Add(new MethodInteractionEvent
            {
                MethodId = methodId,
                MethodName = methodName,
                OpportunityId = item.OpportunityId,
                InteractionDate = item.InteractionDate,
                ClientName = opp.ClientName,
                EmployeeName = opp.EmployeeName,
                StageId = opp.StageId,
                StageName = opp.StageName,
                StageColor = opp.StageColor,
                CreatedAt = opp.CreatedAt,
                LastContactDate = opp.LastContactDate,
                ExpectedValue = opp.ExpectedValue,
                AgeDays = opp.AgeDays
            });
        }

        return result;
    }

    private void CalculateCurrentMetrics(List<MethodInteractionEvent> rows)
    {
        _totalInteractions = rows.Count;
        _activeMethodCount = rows.Select(x => x.MethodName).Distinct().Count();

        var uniqueOpps = rows
            .GroupBy(x => x.OpportunityId)
            .Select(g => g.First())
            .ToList();

        _touchedOppCount = uniqueOpps.Count;
        _wonOppCount = uniqueOpps.Count(x => IsWon(x.StageId));
        _totalRevenue = uniqueOpps.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
        _overallCloseRate = _touchedOppCount > 0 ? (double)_wonOppCount / _touchedOppCount * 100d : 0d;
        _avgInteractionsPerOpportunity = _touchedOppCount > 0 ? (double)_totalInteractions / _touchedOppCount : 0d;
    }

    private void CalculatePreviousMetrics(List<MethodInteractionEvent> rows)
    {
        _prevTotalInteractions = rows.Count;
        _prevActiveMethodCount = rows.Select(x => x.MethodName).Distinct().Count();

        var uniqueOpps = rows
            .GroupBy(x => x.OpportunityId)
            .Select(g => g.First())
            .ToList();

        _prevTouchedOppCount = uniqueOpps.Count;
        _prevWonOppCount = uniqueOpps.Count(x => IsWon(x.StageId));
        _prevTotalRevenue = uniqueOpps.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
        _prevOverallCloseRate = _prevTouchedOppCount > 0 ? (double)_prevWonOppCount / _prevTouchedOppCount * 100d : 0d;
        _prevAvgInteractionsPerOpportunity = _prevTouchedOppCount > 0 ? (double)_prevTotalInteractions / _prevTouchedOppCount : 0d;
    }

    private void ResetPreviousMetrics()
    {
        _prevTotalInteractions = 0;
        _prevActiveMethodCount = 0;
        _prevTouchedOppCount = 0;
        _prevWonOppCount = 0;
        _prevTotalRevenue = 0m;
        _prevOverallCloseRate = 0d;
        _prevAvgInteractionsPerOpportunity = 0d;
    }

    private void BuildMethodSummary(List<MethodInteractionEvent> rows)
    {
        _methodRows = rows
            .GroupBy(x => new { x.MethodId, x.MethodName })
            .Select(g =>
            {
                var interactionCount = g.Count();
                var uniqueOpps = g.GroupBy(x => x.OpportunityId).Select(x => x.First()).ToList();

                var oppCount = uniqueOpps.Count;
                var wonCount = uniqueOpps.Count(x => IsWon(x.StageId));
                var lostCount = uniqueOpps.Count(x => IsLost(x.StageId));
                var openCount = oppCount - wonCount - lostCount;
                var revenue = uniqueOpps.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);

                return new MethodSummaryRow
                {
                    MethodId = g.Key.MethodId,
                    MethodName = g.Key.MethodName,
                    InteractionCount = interactionCount,
                    OpportunityCount = oppCount,
                    WonCount = wonCount,
                    LostCount = lostCount,
                    OpenCount = openCount,
                    CloseRate = oppCount > 0 ? (double)wonCount / oppCount * 100d : 0d,
                    TotalRevenue = revenue,
                    AvgDealValue = wonCount > 0 ? revenue / wonCount : 0m,
                    AvgInteractionsPerOpp = oppCount > 0 ? (double)interactionCount / oppCount : 0d
                };
            })
            .OrderByDescending(x => x.TotalRevenue)
            .ThenByDescending(x => x.InteractionCount)
            .ToList();

        var mostUsed = _methodRows
            .OrderByDescending(x => x.InteractionCount)
            .ThenByDescending(x => x.OpportunityCount)
            .FirstOrDefault();

        _mostUsedMethod = mostUsed?.MethodName ?? "—";
        _mostUsedMethodCount = mostUsed?.InteractionCount ?? 0;

        var bestRevenue = _methodRows
            .OrderByDescending(x => x.TotalRevenue)
            .ThenByDescending(x => x.WonCount)
            .FirstOrDefault();

        if (bestRevenue != null)
        {
            bestRevenue.IsBestRevenue = true;
            _bestRevenueMethod = bestRevenue.MethodName;
            _bestRevenueValue = bestRevenue.TotalRevenue;
        }
        else
        {
            _bestRevenueMethod = "—";
            _bestRevenueValue = 0m;
        }

        var rateCandidates = _methodRows.Where(x => x.OpportunityCount >= 3).ToList();
        if (!rateCandidates.Any())
            rateCandidates = _methodRows.Where(x => x.OpportunityCount > 0).ToList();

        var bestRate = rateCandidates
            .OrderByDescending(x => x.CloseRate)
            .ThenByDescending(x => x.WonCount)
            .ThenByDescending(x => x.TotalRevenue)
            .FirstOrDefault();

        _bestConversionMethod = bestRate?.MethodName ?? "—";
        _bestConversionRate = bestRate?.CloseRate ?? 0d;

        _methodOverviewPoints = _methodRows
            .OrderByDescending(x => x.InteractionCount)
            .ThenByDescending(x => x.TotalRevenue)
            .Take(8)
            .Select(x => new MethodOverviewPoint
            {
                Method = x.MethodName,
                InteractionCount = x.InteractionCount,
                WonCount = x.WonCount,
                Revenue = x.TotalRevenue
            })
            .ToList();

        _methodRatePoints = rateCandidates
            .OrderByDescending(x => x.CloseRate)
            .ThenByDescending(x => x.WonCount)
            .ThenByDescending(x => x.OpportunityCount)
            .Take(8)
            .Select(x => new MethodRatePoint
            {
                Method = x.MethodName,
                CloseRate = (decimal)x.CloseRate
            })
            .ToList();
    }

    private void BuildOverallMonthlyTrend(List<MethodInteractionEvent> rows)
    {
        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var monthMap = rows
            .GroupBy(x => new DateTime(x.InteractionDate.Year, x.InteractionDate.Month, 1))
            .ToDictionary(g => g.Key, g => g.ToList());

        _overallMonthlyPoints = new();

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthMap.TryGetValue(month, out var monthRows);
            monthRows ??= new List<MethodInteractionEvent>();

            var uniqueOpps = monthRows
                .GroupBy(x => x.OpportunityId)
                .Select(g => g.First())
                .ToList();

            _overallMonthlyPoints.Add(new MethodMonthlyPoint
            {
                Month = month.ToString("MMM yyyy", _arCulture),
                InteractionCount = monthRows.Count,
                OpportunityCount = uniqueOpps.Count,
                Revenue = uniqueOpps.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue)
            });
        }
    }

    private void ResolveSelectedMethod()
    {
        if (!_methodRows.Any())
        {
            _selectedMethodId = null;
            return;
        }

        if (_selectedMethodId.HasValue && _methodRows.Any(x => x.MethodId == _selectedMethodId.Value))
            return;

        _selectedMethodId = _methodRows.First().MethodId;
    }

