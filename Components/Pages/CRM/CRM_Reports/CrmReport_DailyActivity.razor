@page "/crm/reports/daily-activity"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير النشاط اليومي والأسبوعي</PageTitle>

<div class="dactx-page" dir="rtl">

    @* Background *@
    <div class="dactx-bg">
        <div class="dactx-orb orb-1"></div>
        <div class="dactx-orb orb-2"></div>
        <div class="dactx-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="dactx-hero">
        <div class="dactx-hero-grid"></div>

        <div class="dactx-hero-content">
            <div class="dactx-hero-top">
                <button class="dactx-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="dactx-badge">
                    <span class="badge-dot"></span>
                    <span>Daily & Weekly Activity Intelligence</span>
                </div>
            </div>

            <div class="dactx-hero-main">
                <div class="dactx-hero-text">
                    <h1>النشاط <span>اليومي والأسبوعي</span></h1>
                    <p>
                        لوحة تنفيذية لمتابعة إيقاع العمل اليومي والأسبوعي من حيث التفاعلات،
                        الفرص الجديدة، الصفقات المكتملة، والمهام المنجزة، مع Drill-down تفصيلي لكل يوم.
                    </p>

                    <div class="dactx-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الموظف</span>
                            <span class="chip-value">@SelectedEmployeeLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">أكثر يوم نشاطًا</span>
                            <span class="chip-value">@_busiestDayLabel</span>
                        </div>
                    </div>
                </div>

                <div class="dactx-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_periodWinRate.ToString("F1")%</div>
                            <div class="summary-caption">حسم الفرص</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card dactx-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية والموظف أو استخدم الفلاتر السريعة لتحليل النشاط</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastDaysAsync(7)">آخر 7 أيام</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastDaysAsync(14)">آخر 14 يوم</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastDaysAsync(30)">آخر 30 يوم</button>
            <button class="quick-range-btn" @onclick="SetCurrentMonthAsync">الشهر الحالي</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudSelect T="int?"
                       @bind-Value="_empId"
                       Label="الموظف"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Class="filter-field">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem T="int?" Value="@((int?)emp.Id)">@emp.Name</MudSelectItem>
                }
            </MudSelect>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card dactx-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل النشاط...</h3>
                <p>يتم تجهيز المؤشرات، الرسوم البيانية، والتحليلات اليومية والأسبوعية</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="dactx-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">💬</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي التفاعلات</div>
                        <span class="trend-badge @GetTrendClass(_totalInteractions, _prevTotalInteractions)">
                            @GetTrendText(_totalInteractions, _prevTotalInteractions)
                        </span>
                    </div>
                    <div class="kpi-value">@_totalInteractions.ToString("N0")</div>
                    <div class="kpi-sub">متوسط يومي: @_avgInteractionsPerDay.ToString("F1")</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon blue">➕</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">فرص جديدة</div>
                        <span class="trend-badge @GetTrendClass(_newOpps, _prevNewOpps)">
                            @GetTrendText(_newOpps, _prevNewOpps)
                        </span>
                    </div>
                    <div class="kpi-value">@_newOpps.ToString("N0")</div>
                    <div class="kpi-sub">المتوسط اليومي: @_avgNewOppsPerDay.ToString("F1")</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon green">✓</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">مبيعات مكتملة</div>
                        <span class="trend-badge @GetTrendClass(_wonOpps, _prevWonOpps)">
                            @GetTrendText(_wonOpps, _prevWonOpps)
                        </span>
                    </div>
                    <div class="kpi-value success">@_wonOpps.ToString("N0")</div>
                    <div class="kpi-sub">نسبة الحسم من الفرص الجديدة: @_periodWinRate.ToString("F1")%</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">✔</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">مهام مكتملة</div>
                        <span class="trend-badge @GetTrendClass(_completedTasks, _prevCompletedTasks)">
                            @GetTrendText(_completedTasks, _prevCompletedTasks)
                        </span>
                    </div>
                    <div class="kpi-value">@_completedTasks.ToString("N0")</div>
                    <div class="kpi-sub">المتوسط اليومي: @_avgTasksPerDay.ToString("F1")</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon purple">📅</div>
                <div class="kpi-body">
                    <div class="kpi-label">أيام النشاط</div>
                    <div class="kpi-value">@_activeDays.ToString("N0")</div>
                    <div class="kpi-sub">أيام ظهر بها نشاط فعلي خلال الفترة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon teal">🔥</div>
                <div class="kpi-body">
                    <div class="kpi-label">أكثر يوم نشاطًا</div>
                    <div class="kpi-value kpi-name">@_busiestDayLabel</div>
                    <div class="kpi-sub">@_busiestDayInteractions.ToString("N0") تفاعل</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="dactx-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* MAIN DASHBOARD *@
        <section class="dactx-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>النشاط اليومي</h3>
                        <p>التفاعلات والفرص الجديدة والمبيعات والمهام المكتملة يومًا بيوم</p>
                    </div>
                </div>

                @if (_dailyChartPoints.Any())
                {
                    <ApexChart TItem="DailyChartPoint"
                               Options="_dailyChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="DailyChartPoint"
                                         Items="@_dailyChartPoints"
                                         Name="التفاعلات"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Label"
                                         YValue="x => x.Interactions" />

                        <ApexPointSeries TItem="DailyChartPoint"
                                         Items="@_dailyChartPoints"
                                         Name="الفرص الجديدة"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Label"
                                         YValue="x => x.NewOpps" />

                        <ApexPointSeries TItem="DailyChartPoint"
                                         Items="@_dailyChartPoints"
                                         Name="المبيعات"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Label"
                                         YValue="x => x.Won" />

                        <ApexPointSeries TItem="DailyChartPoint"
                                         Items="@_dailyChartPoints"
                                         Name="المهام المكتملة"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Label"
                                         YValue="x => x.Tasks" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>الملخص الأسبوعي</h3>
                            <p>تجميع أسبوعي للنشاط خلال الفترة</p>
                        </div>
                    </div>

                    @if (_weeklyChartPoints.Any())
                    {
                        <ApexChart TItem="WeeklyChartPoint"
                                   Options="_weeklyChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="WeeklyChartPoint"
                                             Items="@_weeklyChartPoints"
                                             Name="التفاعلات"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.WeekLabel"
                                             YValue="x => x.Interactions" />

                            <ApexPointSeries TItem="WeeklyChartPoint"
                                             Items="@_weeklyChartPoints"
                                             Name="الفرص الجديدة"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.WeekLabel"
                                             YValue="x => x.NewOpps" />

                            <ApexPointSeries TItem="WeeklyChartPoint"
                                             Items="@_weeklyChartPoints"
                                             Name="المبيعات"
                                             SeriesType="SeriesType.Line"
                                             XValue="x => x.WeekLabel"
                                             YValue="x => x.Won" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية للملخص الأسبوعي</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">التفاعلات</div>
                            <div class="compare-values">
                                <span>@_prevTotalInteractions</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_totalInteractions</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">الفرص الجديدة</div>
                            <div class="compare-values">
                                <span>@_prevNewOpps</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_newOpps</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">المبيعات</div>
                            <div class="compare-values">
                                <span>@_prevWonOpps</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_wonOpps</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">المهام المكتملة</div>
                            <div class="compare-values">
                                <span>@_prevCompletedTasks</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_completedTasks</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @((_totalInteractions >= _prevTotalInteractions && _wonOpps >= _prevWonOpps) ? "compare-good" : "compare-mid")">
                        @if (_totalInteractions >= _prevTotalInteractions && _wonOpps >= _prevWonOpps)
                        {
                            <span>النشاط الحالي أفضل أو مساوي للفترة السابقة</span>
                        }
                        else
                        {
                            <span>يوجد تراجع في بعض مؤشرات النشاط ويحتاج متابعة</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* ANALYTICS GRID *@
        <section class="dactx-analytics-grid">
            <div class="glass-card side-card">
                <div class="card-head">
                    <div>
                        <h3>التوزيع حسب أيام الأسبوع</h3>
                        <p>أي أيام الأسبوع تشهد أعلى نشاط</p>
                    </div>
                </div>

                @if (_weekdayChartPoints.Any())
                {
                    <ApexChart TItem="WeekdayChartPoint"
                               Options="_weekdayChartOptions"
                               Height="320">
                        <ApexPointSeries TItem="WeekdayChartPoint"
                                         Items="@_weekdayChartPoints"
                                         Name="التفاعلات"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.DayName"
                                         YValue="x => x.Interactions" />

                        <ApexPointSeries TItem="WeekdayChartPoint"
                                         Items="@_weekdayChartPoints"
                                         Name="المهام"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.DayName"
                                         YValue="x => x.Tasks" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty small">لا توجد بيانات كافية لأيام الأسبوع</div>
                }
            </div>

            <div class="glass-card dactx-table-wrapper">
                <div class="card-head">
                    <div>
                        <h3>تفاصيل النشاط اليومي</h3>
                        <p>تفصيل يومي للتفاعلات والفرص والمبيعات والمهام</p>
                    </div>
                </div>

                <MudTable Items="@_dailyRows"
                          Hover="true"
                          Dense="true"
                          Elevation="0"
                          RowsPerPage="10"
                          Breakpoint="Breakpoint.Sm"
                          Class="premium-table">
                    <HeaderContent>
                        <MudTh>التاريخ</MudTh>
                        <MudTh>اليوم</MudTh>
                        <MudTh>التفاعلات</MudTh>
                        <MudTh>فرص جديدة</MudTh>
                        <MudTh>مبيعات</MudTh>
                        <MudTh>مهام مكتملة</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="التاريخ">
                            <span style="font-weight:@(context.IsToday ? "700" : "400"); color:@(context.IsToday ? "#4f46e5" : "inherit");">
                                @context.DateStr
                            </span>
                        </MudTd>
                        <MudTd DataLabel="اليوم">@context.DayName</MudTd>
                        <MudTd DataLabel="التفاعلات">@context.Interactions.ToString("N0")</MudTd>
                        <MudTd DataLabel="فرص جديدة">@context.NewOpps.ToString("N0")</MudTd>
                        <MudTd DataLabel="مبيعات">@context.Won.ToString("N0")</MudTd>
                        <MudTd DataLabel="مهام مكتملة">@context.Tasks.ToString("N0")</MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <div class="empty-data">
                            <div class="empty-icon">📉</div>
                            <h4>لا توجد بيانات</h4>
                            <p>لا توجد نتائج يومية مطابقة للفلاتر الحالية</p>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </section>

        @* DAY DRILL-DOWN *@
        <section class="glass-card dactx-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down حسب اليوم</h3>
                    <p>اختر يومًا لتحليل التوزيع الساعي وأعلى الفرص التي شهدت تفاعلاً</p>
                </div>

                <div class="drill-actions">
                    <MudSelect T="DateTime?"
                               Value="_selectedDay"
                               ValueChanged="OnSelectedDayChanged"
                               Label="اختر يومًا"
                               Dense="true"
                               Variant="Variant.Outlined"
                               Class="day-select"
                               Clearable="false">
                        @foreach (var day in _dailyRows.OrderByDescending(x => x.Date))
                        {
                            <MudSelectItem T="DateTime?" Value="@((DateTime?)day.Date)">
                                @($"{day.DayName} - {day.DateStr}")
                            </MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>

            @if (_selectedDay.HasValue)
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">اليوم المحدد</span>
                        <strong>@_selectedDayLabel</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">التفاعلات</span>
                        <strong>@_selectedDayInteractions.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">فرص جديدة</span>
                        <strong>@_selectedDayNewOpps.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">مبيعات</span>
                        <strong>@_selectedDayWon.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">مهام مكتملة</span>
                        <strong>@_selectedDayTasks.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أعلى ساعة نشاط</span>
                        <strong>@_selectedDayPeakHour</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>التوزيع الساعي للتفاعلات</h3>
                                <p>عدد التفاعلات داخل اليوم المحدد حسب الساعة</p>
                            </div>
                        </div>

                        @if (_selectedDayHourlyPoints.Any())
                        {
                            <ApexChart TItem="HourlyChartPoint"
                                       Options="_hourlyChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="HourlyChartPoint"
                                                 Items="@_selectedDayHourlyPoints"
                                                 Name="التفاعلات"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.HourLabel"
                                                 YValue="x => x.Count" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات ساعية لهذا اليوم</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>أكثر الفرص تفاعلاً في اليوم</h3>
                                <p>أعلى الفرص من حيث عدد التفاعلات داخل اليوم المحدد</p>
                            </div>
                        </div>

                        @if (_selectedDayOpportunityPoints.Any())
                        {
                            <ApexChart TItem="OpportunityTouchPoint"
                                       Options="_topOpportunitiesChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="OpportunityTouchPoint"
                                                 Items="@_selectedDayOpportunityPoints"
                                                 Name="التفاعلات"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Opportunity"
                                                 YValue="x => x.Count" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد فرص متفاعلة كفاية في هذا اليوم</div>
                        }
                    </div>
                </div>
            }
        </section>

        @* NOTE *@
        <section class="glass-card dactx-note">
            <div class="note-icon">ℹ️</div>
            <div class="note-body">
                <h4>ملاحظة تحليلية مهمة</h4>
                <p>
                    هذا التقرير يعرض النشاط اليومي والأسبوعي بناءً على:
                    <strong>CustomerInteractions</strong> للتفاعلات،
