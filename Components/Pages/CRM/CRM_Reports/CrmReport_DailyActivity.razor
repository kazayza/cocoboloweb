    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            var from = _fromDate?.Date ?? DateTime.Today.AddDays(-7);
            var to = _toDate?.Date ?? DateTime.Today;
            var prevTo = from.AddDays(-1);
            var prevFrom = prevTo.AddDays(-(to - from).Days);

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentSnapshot = await LoadSnapshotAsync(db, from, to, _empId);

            var previousSnapshot = await LoadSnapshotAsync(db, prevFrom, prevTo, _empId);
            _previousPeriodLabel = $"{prevFrom.ToString("dd MMM yyyy", ArCulture)} — {prevTo.ToString("dd MMM yyyy", ArCulture)}";

            BuildMetrics(_currentSnapshot, true);
            BuildPreviousMetrics(previousSnapshot);
            BuildDailyRows(from, to);
            BuildWeeklyRows();
            BuildWeekdayRows();
            BuildInsights();
            ResolveSelectedDay();
            BuildSelectedDayAnalytics();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<PeriodActivitySnapshot> LoadSnapshotAsync(db24804Context db, DateTime from, DateTime toInclusive, int? empId)
    {
        var toExclusive = toInclusive.AddDays(1);

        List<int>? employeeOppIds = null;

        if (empId.HasValue)
        {
            employeeOppIds = await db.VwSalesOpportunities
                .AsNoTracking()
                .Where(o => o.EmployeeId == empId.Value)
                .Select(o => o.OpportunityId)
                .Distinct()
                .ToListAsync();
        }

        var newOppsQuery = db.VwSalesOpportunities
            .AsNoTracking()
            .Where(o => o.CreatedAt >= from && o.CreatedAt < toExclusive);

        if (empId.HasValue)
            newOppsQuery = newOppsQuery.Where(o => o.EmployeeId == empId.Value);

        var newOpps = await newOppsQuery
            .Select(o => new OpportunityCreatedRow
            {
                OpportunityId = o.OpportunityId,
                ClientName = o.ClientName ?? "—",
                EmployeeId = o.EmployeeId ?? 0,
                EmployeeName = o.EmployeeName ?? "—",
                StageId = o.StageId,
                CreatedAt = o.CreatedAt,
                ExpectedValue = o.ExpectedValue ?? 0m
            })
            .ToListAsync();

        List<InteractionEventRow> interactions;

        if (empId.HasValue && (employeeOppIds == null || employeeOppIds.Count == 0))
        {
            interactions = new List<InteractionEventRow>();
        }
        else
        {
            var interactionsQuery = db.CustomerInteractions
                .AsNoTracking()
                .Where(i => i.InteractionDate >= from && i.InteractionDate < toExclusive);

            if (empId.HasValue && employeeOppIds != null)
                interactionsQuery = interactionsQuery.Where(i => employeeOppIds.Contains(i.OpportunityId));

            interactions = await interactionsQuery
                .Select(i => new InteractionEventRow
                {
                    OpportunityId = i.OpportunityId,
                    InteractionDate = i.InteractionDate
                })
                .ToListAsync();
        }

        var tasksQuery = db.CrmTasks
            .AsNoTracking()
            .Where(t => t.DueDate >= from && t.DueDate < toExclusive && t.Status == "مكتملة");

        if (empId.HasValue)
            tasksQuery = tasksQuery.Where(t => t.AssignedTo == empId.Value);

        var tasks = await tasksQuery
            .Select(t => new TaskEventRow
            {
                DueDate = t.DueDate
            })
            .ToListAsync();

        var metaOppIds = newOpps.Select(x => x.OpportunityId)
            .Union(interactions.Select(x => x.OpportunityId))
            .Distinct()
            .ToList();

        var metaMap = new Dictionary<int, OpportunityMetaRow>();

        if (metaOppIds.Any())
        {
            var metaRows = await db.VwSalesOpportunities
                .AsNoTracking()
                .Where(o => metaOppIds.Contains(o.OpportunityId))
                .Select(o => new OpportunityMetaRow
                {
                    OpportunityId = o.OpportunityId,
                    ClientName = o.ClientName ?? "—",
                    EmployeeName = o.EmployeeName ?? "—",
                    StageId = o.StageId,
                    StageName = o.StageNameAr ?? o.StageName ?? "—",
                    StageColor = o.StageColor ?? "",
                    ExpectedValue = o.ExpectedValue ?? 0m,
                    CreatedAt = o.CreatedAt,
                    LastContactDate = o.LastContactDate,
                    AgeDays = o.DaysSinceFirstContact ?? 0d
                })
                .ToListAsync();

            metaMap = metaRows.ToDictionary(x => x.OpportunityId, x => x);
        }

        return new PeriodActivitySnapshot
        {
            Opportunities = newOpps,
            Interactions = interactions,
            Tasks = tasks,
            OpportunityMeta = metaMap
        };
    }

    private void BuildMetrics(PeriodActivitySnapshot snapshot, bool current)
    {
        var totalInteractions = snapshot.Interactions.Count;
        var newOpps = snapshot.Opportunities.Count;
        var wonOpps = snapshot.Opportunities.Count(x => x.StageId == WonStageId);
        var completedTasks = snapshot.Tasks.Count;

        if (current)
        {
            _totalInteractions = totalInteractions;
            _newOpps = newOpps;
            _wonOpps = wonOpps;
            _completedTasks = completedTasks;

            _periodWinRate = _newOpps > 0 ? (double)_wonOpps / _newOpps * 100d : 0d;
        }
    }

    private void BuildPreviousMetrics(PeriodActivitySnapshot snapshot)
    {
        _prevTotalInteractions = snapshot.Interactions.Count;
        _prevNewOpps = snapshot.Opportunities.Count;
        _prevWonOpps = snapshot.Opportunities.Count(x => x.StageId == WonStageId);
        _prevCompletedTasks = snapshot.Tasks.Count;
    }

    private void BuildDailyRows(DateTime from, DateTime to)
    {
        var allDates = new List<DateTime>();
        for (var d = from; d <= to; d = d.AddDays(1))
            allDates.Add(d);

        var interactionsByDay = _currentSnapshot.Interactions
            .GroupBy(x => x.InteractionDate.Date)
            .ToDictionary(g => g.Key, g => g.Count());

        var newOppsByDay = _currentSnapshot.Opportunities
            .GroupBy(x => x.CreatedAt.Date)
            .ToDictionary(g => g.Key, g => g.Count());

        var wonByDay = _currentSnapshot.Opportunities
            .Where(x => x.StageId == WonStageId)
            .GroupBy(x => x.CreatedAt.Date)
            .ToDictionary(g => g.Key, g => g.Count());

        var tasksByDay = _currentSnapshot.Tasks
            .GroupBy(x => x.DueDate.Date)
            .ToDictionary(g => g.Key, g => g.Count());

        _dailyRows = allDates
            .Select(d => new DailyRow
            {
                Date = d,
                DateStr = d.ToString("yyyy/MM/dd"),
                DayName = ArCulture.DateTimeFormat.GetDayName(d.DayOfWeek),
                Interactions = interactionsByDay.GetValueOrDefault(d, 0),
                NewOpps = newOppsByDay.GetValueOrDefault(d, 0),
                Won = wonByDay.GetValueOrDefault(d, 0),
                Tasks = tasksByDay.GetValueOrDefault(d, 0),
                IsToday = d == DateTime.Today
            })
            .OrderByDescending(x => x.Date)
            .ToList();

        _dailyChartPoints = _dailyRows
            .OrderBy(x => x.Date)
            .Select(x => new DailyChartPoint
            {
                Label = x.Date.ToString("MM/dd"),
                Interactions = x.Interactions,
                NewOpps = x.NewOpps,
                Won = x.Won,
                Tasks = x.Tasks
            })
            .ToList();

        _activeDays = _dailyRows.Count(x => x.Interactions > 0 || x.NewOpps > 0 || x.Won > 0 || x.Tasks > 0);
        _avgInteractionsPerDay = _dailyRows.Count > 0 ? (double)_totalInteractions / _dailyRows.Count : 0d;
        _avgNewOppsPerDay = _dailyRows.Count > 0 ? (double)_newOpps / _dailyRows.Count : 0d;
        _avgTasksPerDay = _dailyRows.Count > 0 ? (double)_completedTasks / _dailyRows.Count : 0d;

        var busiest = _dailyRows
            .OrderByDescending(x => x.Interactions)
            .ThenByDescending(x => x.NewOpps)
            .ThenByDescending(x => x.Date)
            .FirstOrDefault();

        _busiestDayLabel = busiest is null ? "—" : $"{busiest.DayName} {busiest.Date:dd/MM}";
        _busiestDayInteractions = busiest?.Interactions ?? 0;
    }

    private void BuildWeeklyRows()
    {
        _weeklyChartPoints = _dailyRows
            .GroupBy(x => StartOfWeek(x.Date, DayOfWeek.Saturday))
            .Select(g => new WeeklyChartPoint
            {
                WeekStart = g.Key,
                WeekLabel = $"أسبوع {g.Key:MM/dd}",
                Interactions = g.Sum(x => x.Interactions),
                NewOpps = g.Sum(x => x.NewOpps),
                Won = g.Sum(x => x.Won),
                Tasks = g.Sum(x => x.Tasks)
            })
            .OrderBy(x => x.WeekStart)
            .ToList();
    }

    private void BuildWeekdayRows()
    {
        var weekdayOrder = new[]
        {
            DayOfWeek.Saturday,
            DayOfWeek.Sunday,
            DayOfWeek.Monday,
            DayOfWeek.Tuesday,
            DayOfWeek.Wednesday,
            DayOfWeek.Thursday,
            DayOfWeek.Friday
        };

        _weekdayChartPoints = weekdayOrder
            .Select(day =>
            {
                var items = _dailyRows.Where(x => x.Date.DayOfWeek == day).ToList();

                return new WeekdayChartPoint
                {
                    DayOrder = (int)day,
                    DayName = ArCulture.DateTimeFormat.GetDayName(day),
                    Interactions = items.Sum(x => x.Interactions),
                    Tasks = items.Sum(x => x.Tasks)
                };
            })
            .ToList();
    }

    private void BuildInsights()
    {
        _insights = new();

        if (_dailyRows.Any())
        {
            var bestSalesDay = _dailyRows
                .OrderByDescending(x => x.Won)
                .ThenByDescending(x => x.NewOpps)
                .ThenByDescending(x => x.Date)
                .FirstOrDefault();

            if (bestSalesDay != null)
            {
                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.TrendingUp,
                    Title = "أفضل يوم مبيعات",
                    Value = $"{bestSalesDay.DayName} {bestSalesDay.Date:dd/MM}",
                    Description = $"{bestSalesDay.Won} عملية بيع",
                    ToneClass = "tone-green"
                });
            }

            var bestTaskDay = _dailyRows
                .OrderByDescending(x => x.Tasks)
                .ThenByDescending(x => x.Date)
                .FirstOrDefault();

            if (bestTaskDay != null)
            {
                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.TaskAlt,
                    Title = "أعلى إنجاز مهام",
                    Value = $"{bestTaskDay.DayName} {bestTaskDay.Date:dd/MM}",
                    Description = $"{bestTaskDay.Tasks} مهمة مكتملة",
                    ToneClass = "tone-gold"
                });
            }
        }

        if (_weeklyChartPoints.Any())
        {
            var bestWeek = _weeklyChartPoints
                .OrderByDescending(x => x.Interactions)
                .ThenByDescending(x => x.Won)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.DateRange,
                Title = "أفضل أسبوع نشاطًا",
                Value = bestWeek.WeekLabel,
                Description = $"{bestWeek.Interactions} تفاعل — {bestWeek.Won} مبيعات",
                ToneClass = "tone-indigo"
            });
        }

        if (_weekdayChartPoints.Any())
        {
            var topWeekday = _weekdayChartPoints
                .OrderByDescending(x => x.Interactions)
                .ThenByDescending(x => x.Tasks)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.CalendarMonth,
                Title = "أكثر أيام الأسبوع نشاطًا",
                Value = topWeekday.DayName,
                Description = $"{topWeekday.Interactions} تفاعل خلال الفترة",
                ToneClass = "tone-slate"
            });
        }

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private void ResolveSelectedDay()
    {
        if (!_dailyRows.Any())
        {
            _selectedDay = null;
            return;
        }

        if (_selectedDay.HasValue && _dailyRows.Any(x => x.Date.Date == _selectedDay.Value.Date))
            return;

        var latestWithData = _dailyRows
            .Where(x => x.Interactions > 0 || x.NewOpps > 0 || x.Won > 0 || x.Tasks > 0)
            .OrderByDescending(x => x.Date)
            .FirstOrDefault();

        _selectedDay = latestWithData?.Date ?? _dailyRows.OrderByDescending(x => x.Date).First().Date;
    }

    private void BuildSelectedDayAnalytics()
    {
        _selectedDayLabel = "—";
        _selectedDayInteractions = 0;
        _selectedDayNewOpps = 0;
        _selectedDayWon = 0;
        _selectedDayTasks = 0;
        _selectedDayPeakHour = "—";
        _selectedDayHourlyPoints = new();
        _selectedDayOpportunityPoints = new();

        if (!_selectedDay.HasValue)
            return;

        var day = _selectedDay.Value.Date;
        _selectedDayLabel = $"{ArCulture.DateTimeFormat.GetDayName(day.DayOfWeek)} — {day:yyyy/MM/dd}";

        var dayInteractions = _currentSnapshot.Interactions
            .Where(x => x.InteractionDate.Date == day)
            .ToList();

        var dayNewOpps = _currentSnapshot.Opportunities
            .Where(x => x.CreatedAt.Date == day)
            .ToList();

        var dayWon = dayNewOpps.Count(x => x.StageId == WonStageId);

        var dayTasks = _currentSnapshot.Tasks
            .Count(x => x.DueDate.Date == day);

        _selectedDayInteractions = dayInteractions.Count;
        _selectedDayNewOpps = dayNewOpps.Count;
        _selectedDayWon = dayWon;
        _selectedDayTasks = dayTasks;

        for (var hour = 0; hour < 24; hour++)
        {
            var count = dayInteractions.Count(x => x.InteractionDate.Hour == hour);

            _selectedDayHourlyPoints.Add(new HourlyChartPoint
            {
                HourLabel = hour.ToString("00"),
                Count = count
            });
        }

        var peakHour = _selectedDayHourlyPoints
            .OrderByDescending(x => x.Count)
            .ThenBy(x => x.HourLabel)
            .FirstOrDefault();

        _selectedDayPeakHour = peakHour is null || peakHour.Count == 0
            ? "—"
            : $"{peakHour.HourLabel}:00";

        _selectedDayOpportunityPoints = dayInteractions
            .GroupBy(x => x.OpportunityId)
            .Select(g =>
            {
                var meta = _currentSnapshot.OpportunityMeta.GetValueOrDefault(g.Key);

                return new OpportunityTouchPoint
                {
                    Opportunity = meta?.ClientName ?? $"فرصة {g.Key}",
                    Count = g.Count()
                };
            })
            .OrderByDescending(x => x.Count)
            .ThenBy(x => x.Opportunity)
            .Take(8)
            .ToList();
    }

    private Task OnSelectedDayChanged(DateTime? value)
    {
        _selectedDay = value;
        BuildSelectedDayAnalytics();
        return Task.CompletedTask;
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("تقرير النشاط اليومي والأسبوعي");
            sb.AppendLine($"الفترة الحالية,{SelectedPeriodLabel}");
            sb.AppendLine($"الفترة السابقة,{PreviousPeriodLabel}");
            sb.AppendLine($"الموظف,{SelectedEmployeeLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"إجمالي التفاعلات,{_totalInteractions}");
            sb.AppendLine($"فرص جديدة,{_newOpps}");
            sb.AppendLine($"مبيعات مكتملة,{_wonOpps}");
            sb.AppendLine($"مهام مكتملة,{_completedTasks}");
            sb.AppendLine($"أيام النشاط,{_activeDays}");
            sb.AppendLine($"معدل الحسم,{_periodWinRate:F1}%");
            sb.AppendLine();

            sb.AppendLine("التفاصيل اليومية");
            sb.AppendLine("التاريخ,اليوم,التفاعلات,فرص جديدة,مبيعات,مهام مكتملة");
            foreach (var row in _dailyRows.OrderBy(x => x.Date))
            {
                sb.AppendLine($"{row.DateStr},{row.DayName},{row.Interactions},{row.NewOpps},{row.Won},{row.Tasks}");
            }

            sb.AppendLine();
            sb.AppendLine("الملخص الأسبوعي");
            sb.AppendLine("الأسبوع,التفاعلات,فرص جديدة,مبيعات,مهام مكتملة");
            foreach (var row in _weeklyChartPoints)
            {
                sb.AppendLine($"{row.WeekLabel},{row.Interactions},{row.NewOpps},{row.Won},{row.Tasks}");
            }

            if (_selectedDay.HasValue)
            {
                sb.AppendLine();
                sb.AppendLine($"تفاصيل اليوم المحدد,{_selectedDayLabel}");
                sb.AppendLine("الساعة,عدد التفاعلات");
                foreach (var row in _selectedDayHourlyPoints)
                {
                    sb.AppendLine($"{row.HourLabel}:00,{row.Count}");
                }
            }

            var csv = sb.ToString();
            var fileName = $"daily-activity-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

    private async Task PrintAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "window.print()");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تشغيل الطباعة: {ex.Message}", Severity.Error);
        }
    }

    private bool TryGetPreviousRange(out DateTime previousFrom, out DateTime previousTo)
    {
        previousFrom = default;
        previousTo = default;

        if (!_fromDate.HasValue || !_toDate.HasValue)
            return false;

        var currentFrom = _fromDate.Value.Date;
        var currentTo = _toDate.Value.Date;
        var days = (currentTo - currentFrom).Days;

        previousTo = currentFrom.AddDays(-1);
        previousFrom = previousTo.AddDays(-days);
        return true;
    }

    private void NormalizeDateRange()
    {
        if (_fromDate.HasValue && _toDate.HasValue && _fromDate.Value.Date > _toDate.Value.Date)
        {
            var temp = _fromDate;
            _fromDate = _toDate;
            _toDate = temp;

            Snackbar.Add("تم تبديل تاريخ البداية والنهاية تلقائيًا لأن البداية كانت أكبر من النهاية.", Severity.Info);
        }
    }

    private static DateTime StartOfWeek(DateTime dt, DayOfWeek startOfWeek)
    {
        var diff = (7 + (dt.DayOfWeek - startOfWeek)) % 7;
        return dt.AddDays(-1 * diff).Date;
    }

    private string GetSummaryRingStyle()
    {
        var safe = Math.Max(0, Math.Min(_periodWinRate, 100));
        var angle = safe * 3.6;
        return $"background: conic-gradient(#10b981 0deg, #10b981 {angle:F1}deg, rgba(255,255,255,.12) {angle:F1}deg, rgba(255,255,255,.12) 360deg);";
    }

    private string GetTrendClass(int current, int previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendText(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? "0%" : "جديد";

        var change = ((double)(current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

