    private async Task ResetFiltersAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);
        _toDate = DateTime.Today;
        _selectedReason = null;
        await LoadData();
    }

    private async Task SetLastMonthsAsync(int months)
    {
        if (months <= 0) months = 12;

        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-(months - 1));
        _toDate = DateTime.Today;
        _selectedReason = null;

        await LoadData();
    }

    private async Task SetCurrentYearAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _selectedReason = null;

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentRows = await LoadPeriodRowsAsync(db, _fromDate, _toDate);

            if (TryGetPreviousRange(out var prevFrom, out var prevTo))
            {
                _previousPeriodLabel = $"{prevFrom.ToString("dd MMM yyyy", _arCulture)} — {prevTo.ToString("dd MMM yyyy", _arCulture)}";
                var previousRows = await LoadPeriodRowsAsync(db, prevFrom, prevTo);
                CalculatePreviousMetrics(previousRows);
            }
            else
            {
                _previousPeriodLabel = "غير متاح";
                ResetPreviousMetrics();
            }

            CalculateCurrentMetrics(_currentRows);
            BuildReasonSummary(_currentRows);
            BuildMonthlySummary(_currentRows);
            ResolveSelectedReason();
            BuildSelectedReasonAnalytics(_currentRows);
            BuildInsights();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<List<OpportunitySnapshot>> LoadPeriodRowsAsync(db24804Context db, DateTime? from, DateTime? to)
    {
        var query = db.VwSalesOpportunities.AsNoTracking().AsQueryable();

        if (from.HasValue)
        {
            var fromDate = from.Value.Date;
            query = query.Where(o => o.CreatedAt >= fromDate);
        }

        if (to.HasValue)
        {
            var toExclusive = to.Value.Date.AddDays(1);
            query = query.Where(o => o.CreatedAt < toExclusive);
        }

        return await query
            .Select(o => new OpportunitySnapshot
            {
                OpportunityId = o.OpportunityId,
                CreatedAt = o.CreatedAt,
                StageId = o.StageId,
                ExpectedValue = o.ExpectedValue ?? 0m,
                LostReasonName = o.LostReasonNameAr ?? "غير محدد",
                ClientName = o.ClientName ?? "—",
                EmployeeName = o.EmployeeName ?? "—",
                StageName = o.StageNameAr ?? o.StageName ?? "—",
                StageColor = o.StageColor ?? ""
            })
            .ToListAsync();
    }

    private void CalculateCurrentMetrics(List<OpportunitySnapshot> rows)
    {
        _totalOpps = rows.Count;

        _lostRows = rows
            .Where(x => IsLost(x.StageId))
            .Select(x => new LostDealRow
            {
                OpportunityId = x.OpportunityId,
                ClientName = x.ClientName,
                EmployeeName = x.EmployeeName,
                StageName = x.StageName,
                StageColor = x.StageColor,
                ReasonName = string.IsNullOrWhiteSpace(x.LostReasonName) ? "غير محدد" : x.LostReasonName,
                CreatedAt = x.CreatedAt,
                ExpectedValue = x.ExpectedValue
            })
            .ToList();

        _totalLostCount = _lostRows.Count;
        _totalLostValue = _lostRows.Sum(x => x.ExpectedValue);
        _lossRate = _totalOpps > 0 ? (double)_totalLostCount / _totalOpps * 100d : 0d;
        _avgLostValue = _totalLostCount > 0 ? _totalLostValue / _totalLostCount : 0m;
    }

    private void CalculatePreviousMetrics(List<OpportunitySnapshot> rows)
    {
        _prevTotalOpps = rows.Count;

        var lostRows = rows.Where(x => IsLost(x.StageId)).ToList();

        _prevTotalLostCount = lostRows.Count;
        _prevTotalLostValue = lostRows.Sum(x => x.ExpectedValue);
        _prevLossRate = _prevTotalOpps > 0 ? (double)_prevTotalLostCount / _prevTotalOpps * 100d : 0d;
        _prevAvgLostValue = _prevTotalLostCount > 0 ? _prevTotalLostValue / _prevTotalLostCount : 0m;
    }

    private void ResetPreviousMetrics()
    {
        _prevTotalOpps = 0;
        _prevTotalLostCount = 0;
        _prevTotalLostValue = 0m;
        _prevLossRate = 0d;
        _prevAvgLostValue = 0m;
    }

    private void BuildReasonSummary(List<OpportunitySnapshot> rows)
    {
        _reasonRows = _lostRows
            .GroupBy(x => string.IsNullOrWhiteSpace(x.ReasonName) ? "غير محدد" : x.ReasonName)
            .Select(g =>
            {
                var count = g.Count();
                var totalValue = g.Sum(x => x.ExpectedValue);

                return new ReasonSummaryRow
                {
                    ReasonName = g.Key,
                    Count = count,
                    TotalValue = totalValue,
                    AvgValue = count > 0 ? totalValue / count : 0m,
                    Percentage = _totalLostCount > 0 ? (double)count / _totalLostCount * 100d : 0d
                };
            })
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.TotalValue)
            .ToList();

        var top = _reasonRows.FirstOrDefault();
        _topReason = top?.ReasonName ?? "—";
        _topReasonCount = top?.Count ?? 0;
        _topReasonValue = top?.TotalValue ?? 0m;

        _reasonOverviewPoints = _reasonRows
            .Select(x => new ReasonOverviewPoint
            {
                Reason = x.ReasonName,
                Count = x.Count,
                Value = x.TotalValue
            })
            .ToList();

        _reasonPercentPoints = _reasonRows
            .Select(x => new ReasonPercentPoint
            {
                Reason = x.ReasonName,
                Percent = (decimal)x.Percentage
            })
            .OrderByDescending(x => x.Percent)
            .ToList();
    }

    private void BuildMonthlySummary(List<OpportunitySnapshot> rows)
    {
        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var allMap = rows
            .GroupBy(x => new DateTime(x.CreatedAt.Year, x.CreatedAt.Month, 1))
            .ToDictionary(g => g.Key, g => g.ToList());

        var lostMap = _lostRows
            .GroupBy(x => new DateTime(x.CreatedAt.Year, x.CreatedAt.Month, 1))
            .ToDictionary(g => g.Key, g => g.ToList());

        var list = new List<MonthlyLostRow>();

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            allMap.TryGetValue(month, out var allRows);
            lostMap.TryGetValue(month, out var lostRows);

            allRows ??= new List<OpportunitySnapshot>();
            lostRows ??= new List<LostDealRow>();

            var totalOpps = allRows.Count;
            var lostCount = lostRows.Count;
            var lostValue = lostRows.Sum(x => x.ExpectedValue);

            list.Add(new MonthlyLostRow
            {
                Year = month.Year,
                MonthNum = month.Month,
                Month = month.ToString("MMM yyyy", _arCulture),
                TotalOpps = totalOpps,
                LostCount = lostCount,
                LostValue = lostValue,
                LossRate = totalOpps > 0 ? (double)lostCount / totalOpps * 100d : 0d
            });
        }

        _monthlyRows = list
            .OrderByDescending(x => x.Year)
            .ThenByDescending(x => x.MonthNum)
            .ToList();

        _monthlyLossPoints = list
            .OrderBy(x => x.Year)
            .ThenBy(x => x.MonthNum)
            .Select(x => new MonthlyLossPoint
            {
                Month = x.Month,
                Count = x.LostCount,
                Value = x.LostValue
            })
            .ToList();
    }

    private void ResolveSelectedReason()
    {
        if (!_reasonRows.Any())
        {
            _selectedReason = null;
            return;
        }

        if (!string.IsNullOrWhiteSpace(_selectedReason) && _reasonRows.Any(x => x.ReasonName == _selectedReason))
            return;

        _selectedReason = _reasonRows.First().ReasonName;
    }

    private void BuildSelectedReasonAnalytics(List<OpportunitySnapshot> rows)
    {
        _selectedReasonName = "—";
        _selectedReasonCount = 0;
        _selectedReasonValue = 0m;
        _selectedReasonAvgValue = 0m;
        _selectedReasonPercent = 0d;
        _selectedReasonTopMonth = "—";
        _selectedReasonTopEmployee = "—";
        _selectedReasonMonthlyPoints = new();
        _selectedReasonEmployeePoints = new();
        _detailRows = new();

        if (string.IsNullOrWhiteSpace(_selectedReason))
        {
            _detailRows = _lostRows
                .OrderByDescending(x => x.ExpectedValue)
                .ThenByDescending(x => x.CreatedAt)
                .Take(25)
                .Select(MapDetailRow)
                .ToList();

            return;
        }

        var filtered = _lostRows
            .Where(x => x.ReasonName == _selectedReason)
            .ToList();

        if (!filtered.Any())
            return;

        _selectedReasonName = _selectedReason;
        _selectedReasonCount = filtered.Count;
        _selectedReasonValue = filtered.Sum(x => x.ExpectedValue);
        _selectedReasonAvgValue = _selectedReasonCount > 0 ? _selectedReasonValue / _selectedReasonCount : 0m;
        _selectedReasonPercent = _totalLostCount > 0 ? (double)_selectedReasonCount / _totalLostCount * 100d : 0d;

        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var monthMap = filtered
            .GroupBy(x => new DateTime(x.CreatedAt.Year, x.CreatedAt.Month, 1))
            .ToDictionary(g => g.Key, g => g.ToList());

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthMap.TryGetValue(month, out var monthRows);
            monthRows ??= new List<LostDealRow>();

            _selectedReasonMonthlyPoints.Add(new SelectedReasonMonthPoint
            {
                Month = month.ToString("MMM yyyy", _arCulture),
                Count = monthRows.Count,
                Value = monthRows.Sum(x => x.ExpectedValue)
            });
        }

        var topMonth = _selectedReasonMonthlyPoints
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.Value)
            .FirstOrDefault();

        _selectedReasonTopMonth = topMonth?.Month ?? "—";

        _selectedReasonEmployeePoints = filtered
            .GroupBy(x => x.EmployeeName)
            .Select(g => new SelectedReasonEmployeePoint
            {
                Employee = g.Key,
                Count = g.Count()
            })
            .OrderByDescending(x => x.Count)
            .Take(8)
            .ToList();

        _selectedReasonTopEmployee = _selectedReasonEmployeePoints.FirstOrDefault()?.Employee ?? "—";

        _detailRows = filtered
            .OrderByDescending(x => x.ExpectedValue)
            .ThenByDescending(x => x.CreatedAt)
            .Select(MapDetailRow)
            .ToList();
    }

    private LostDealDetailRow MapDetailRow(LostDealRow x) => new()
    {
        OpportunityId = x.OpportunityId,
        ClientName = x.ClientName,
        EmployeeName = x.EmployeeName,
        StageName = x.StageName,
        StageColor = x.StageColor,
        ReasonName = x.ReasonName,
        CreatedAt = x.CreatedAt,
        ExpectedValue = x.ExpectedValue
    };

    private void BuildInsights()
    {
        _insights = new();

        if (_reasonRows.Any())
        {
            var highestCount = _reasonRows
                .OrderByDescending(x => x.Count)
                .ThenByDescending(x => x.TotalValue)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.ReportProblem,
                Title = "أكثر سبب تكرارًا",
                Value = highestCount.ReasonName,
                Description = $"{highestCount.Count} خسارة — {highestCount.Percentage:F1}%",
                ToneClass = "tone-red"
            });

            var highestValue = _reasonRows
                .OrderByDescending(x => x.TotalValue)
                .ThenByDescending(x => x.Count)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.AttachMoney,
                Title = "أعلى سبب من حيث القيمة",
                Value = highestValue.ReasonName,
                Description = $"{FormatMoney(highestValue.TotalValue)}",
                ToneClass = "tone-gold"
            });
        }

        var validMonths = _monthlyRows.Where(x => x.LostCount > 0).ToList();
        if (validMonths.Any())
        {
            var worstMonth = validMonths
                .OrderByDescending(x => x.LostCount)
                .ThenByDescending(x => x.LostValue)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.CalendarMonth,
                Title = "أسوأ شهر",
                Value = worstMonth.Month,
                Description = $"{worstMonth.LostCount} خسارة — {FormatMoney(worstMonth.LostValue)}",
                ToneClass = "tone-indigo"
            });
        }

        if (_lostRows.Any())
        {
            var biggestDeal = _lostRows
                .OrderByDescending(x => x.ExpectedValue)
                .ThenByDescending(x => x.CreatedAt)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.WarningAmber,
                Title = "أكبر صفقة مفقودة",
                Value = biggestDeal.ClientName,
                Description = $"{FormatMoney(biggestDeal.ExpectedValue)} — {biggestDeal.ReasonName}",
                ToneClass = "tone-slate"
            });
        }

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private void SelectReason(string reason)
    {
        _selectedReason = reason;
        BuildSelectedReasonAnalytics(_currentRows);
    }

    private void ClearSelectedReason()
    {
        _selectedReason = null;
        BuildSelectedReasonAnalytics(_currentRows);
    }

    private bool IsSelectedReason(string reason)
        => !string.IsNullOrWhiteSpace(_selectedReason) && _selectedReason == reason;

    private bool TryGetPreviousRange(out DateTime previousFrom, out DateTime previousTo)
    {
        previousFrom = default;
        previousTo = default;

        if (!_fromDate.HasValue || !_toDate.HasValue)
            return false;

        var currentFrom = _fromDate.Value.Date;
        var currentTo = _toDate.Value.Date;
        var days = (currentTo - currentFrom).Days;

        previousTo = currentFrom.AddDays(-1);
        previousFrom = previousTo.AddDays(-days);

        return true;
    }

    private void NormalizeDateRange()
    {
        if (_fromDate.HasValue && _toDate.HasValue && _fromDate.Value.Date > _toDate.Value.Date)
        {
            var temp = _fromDate;
            _fromDate = _toDate;
            _toDate = temp;

            Snackbar.Add("تم تبديل تاريخ البداية والنهاية تلقائيًا لأن البداية كانت أكبر من النهاية.", Severity.Info);
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("تقرير أسباب الخسارة");
            sb.AppendLine($"الفترة الحالية,{SelectedPeriodLabel}");
            sb.AppendLine($"الفترة السابقة,{PreviousPeriodLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"إجمالي الفرص,{_totalOpps}");
            sb.AppendLine($"إجمالي الخسائر,{_totalLostCount}");
            sb.AppendLine($"إجمالي القيمة المفقودة,{_totalLostValue:N0}");
            sb.AppendLine($"معدل الخسارة,{_lossRate:F1}%");
            sb.AppendLine($"متوسط الخسارة,{_avgLostValue:N0}");
            sb.AppendLine($"أكثر سبب شيوعاً,{_topReason}");
            sb.AppendLine();

            sb.AppendLine("تفاصيل الأسباب");
            sb.AppendLine("السبب,العدد,النسبة,إجمالي القيمة,متوسط القيمة");
            foreach (var row in _reasonRows)
            {
                sb.AppendLine($"{row.ReasonName},{row.Count},{row.Percentage:F1}%,{row.TotalValue:N0},{row.AvgValue:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("التفاصيل الشهرية");
            sb.AppendLine("الشهر,إجمالي الفرص,إجمالي الخسائر,معدل الخسارة,القيمة المفقودة");
            foreach (var row in _monthlyRows.OrderBy(x => x.Year).ThenBy(x => x.MonthNum))
            {
                sb.AppendLine($"{row.Month},{row.TotalOpps},{row.LostCount},{row.LossRate:F1}%,{row.LostValue:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("تفاصيل الفرص المفقودة");
            sb.AppendLine("العميل,الموظف,المرحلة,تاريخ الإنشاء,السبب,القيمة");
            foreach (var row in _detailRows)
            {
                sb.AppendLine($"{row.ClientName},{row.EmployeeName},{row.StageName},{FormatDate(row.CreatedAt)},{row.ReasonName},{row.ExpectedValue:N0}");
            }

            var csv = sb.ToString();
            var fileName = $"lost-reasons-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

    private async Task PrintAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "window.print()");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تشغيل الطباعة: {ex.Message}", Severity.Error);
        }
    }

    private bool IsLost(int stageId) => stageId == LostStageId1 || stageId == LostStageId2;

    private string FormatMoney(decimal value) => $"{value:N0} ج.م";
    private string FormatDate(DateTime value) => value.ToString("yyyy/MM/dd");

    private string GetStagePillStyle(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
            return "background:#e5e7eb;color:#111827;";

        return $"background:{color};color:#fff;";
    }

    private string GetSummaryRingStyle()
    {
        var safe = Math.Max(0, Math.Min(_lossRate, 100));
        var angle = safe * 3.6;
        return $"background: conic-gradient(#ef4444 0deg, #ef4444 {angle:F1}deg, rgba(255,255,255,.12) {angle:F1}deg, rgba(255,255,255,.12) 360deg);";
    }

    private string GetLossProgressStyle()
    {
        var safe = Math.Max(0, Math.Min(_lossRate, 100));
        return $"width:{safe:F0}%";
    }

    private string GetTrendClass(int current, int previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(double current, double previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(decimal current, decimal previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendText(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? "0%" : "جديد";

        var change = ((double)(current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(double current, double previous)
    {
        if (Math.Abs(previous) < 0.000001)
            return Math.Abs(current) < 0.000001 ? "0%" : "جديد";

        var change = ((current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(decimal current, decimal previous)
    {
        if (previous == 0m)
            return current == 0m ? "0%" : "جديد";

        var change = (double)((current - previous) / previous * 100m);
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetReasonPillClass(double percent)
    {
        if (percent >= 40) return "rate-bad";
        if (percent >= 20) return "rate-mid";
        return "rate-good";
    }

