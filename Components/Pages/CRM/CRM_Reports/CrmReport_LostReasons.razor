@page "/crm/reports/lost-reasons"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير أسباب الخسارة</PageTitle>

<div class="lstr-page" dir="rtl">

    @* Background *@
    <div class="lstr-bg">
        <div class="lstr-orb orb-1"></div>
        <div class="lstr-orb orb-2"></div>
        <div class="lstr-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="lstr-hero">
        <div class="lstr-hero-grid"></div>

        <div class="lstr-hero-content">
            <div class="lstr-hero-top">
                <button class="lstr-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="lstr-badge">
                    <span class="badge-dot"></span>
                    <span>Lost Reasons Intelligence</span>
                </div>
            </div>

            <div class="lstr-hero-main">
                <div class="lstr-hero-text">
                    <h1>تحليل <span>أسباب</span> الخسارة</h1>
                    <p>
                        لوحة تنفيذية متقدمة لتحليل أسباب خسارة الفرص، قياس القيمة المفقودة،
                        اكتشاف أكثر الأسباب تكرارًا وتأثيرًا، وتحديد الشهور والعملاء الأكثر خسارة.
                    </p>

                    <div class="lstr-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">أكثر سبب شيوعًا</span>
                            <span class="chip-value">@_topReason</span>
                        </div>
                    </div>
                </div>

                <div class="lstr-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_lossRate.ToString("F1")%</div>
                            <div class="summary-caption">معدل الخسارة</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card lstr-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية أو استخدم الفترات السريعة لتحليل أسباب الخسارة</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card lstr-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل أسباب الخسارة...</h3>
                <p>يتم تجهيز المؤشرات والرسوم البيانية وتحليل الأسباب</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="lstr-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon red">✕</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي الخسائر</div>
                        <span class="trend-badge @GetTrendClass(_totalLostCount, _prevTotalLostCount)">
                            @GetTrendText(_totalLostCount, _prevTotalLostCount)
                        </span>
                    </div>
                    <div class="kpi-value danger">@_totalLostCount.ToString("N0")</div>
                    <div class="kpi-sub">عدد الفرص التي انتهت بخسارة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon orange">₪</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي القيمة المفقودة</div>
                        <span class="trend-badge @GetTrendClass(_totalLostValue, _prevTotalLostValue)">
                            @GetTrendText(_totalLostValue, _prevTotalLostValue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_totalLostValue)</div>
                    <div class="kpi-sub">إجمالي قيمة الصفقات المفقودة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">%</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">معدل الخسارة</div>
                        <span class="trend-badge @GetTrendClass(_lossRate, _prevLossRate)">
                            @GetTrendText(_lossRate, _prevLossRate)
                        </span>
                    </div>
                    <div class="kpi-value">@_lossRate.ToString("F1")%</div>
                    <div class="kpi-progress">
                        <div class="kpi-progress-bar" style="@GetLossProgressStyle()"></div>
                    </div>
                    <div class="kpi-sub">الخسائر ÷ إجمالي الفرص × 100</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon purple">📌</div>
                <div class="kpi-body">
                    <div class="kpi-label">أكثر سبب شيوعًا</div>
                    <div class="kpi-value kpi-name">@_topReason</div>
                    <div class="kpi-sub">@_topReasonCount.ToString("N0") خسارة — @FormatMoney(_topReasonValue)</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon teal">◎</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">متوسط قيمة الخسارة</div>
                        <span class="trend-badge @GetTrendClass(_avgLostValue, _prevAvgLostValue)">
                            @GetTrendText(_avgLostValue, _prevAvgLostValue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_avgLostValue)</div>
                    <div class="kpi-sub">متوسط قيمة الفرصة المفقودة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">#</div>
                <div class="kpi-body">
                    <div class="kpi-label">إجمالي الفرص</div>
                    <div class="kpi-value">@_totalOpps.ToString("N0")</div>
                    <div class="kpi-sub">كل الفرص داخل الفترة المحددة</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="lstr-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* DASHBOARD *@
        <section class="lstr-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>توزيع أسباب الخسارة</h3>
                        <p>عدد الخسائر مقابل القيمة المفقودة لكل سبب</p>
                    </div>
                </div>

                @if (_reasonOverviewPoints.Any())
                {
                    <ApexChart TItem="ReasonOverviewPoint"
                               Options="_reasonOverviewChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="ReasonOverviewPoint"
                                         Items="@_reasonOverviewPoints"
                                         Name="عدد الخسائر"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Reason"
                                         YValue="x => x.Count" />

                        <ApexPointSeries TItem="ReasonOverviewPoint"
                                         Items="@_reasonOverviewPoints"
                                         Name="القيمة المفقودة"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Reason"
                                         YValue="x => x.Value" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>الاتجاه الشهري للخسائر</h3>
                            <p>عدد الخسائر وقيمتها على مستوى الشهور</p>
                        </div>
                    </div>

                    @if (_monthlyLossPoints.Any())
                    {
                        <ApexChart TItem="MonthlyLossPoint"
                                   Options="_monthlyLossChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="MonthlyLossPoint"
                                             Items="@_monthlyLossPoints"
                                             Name="عدد الخسائر"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Month"
                                             YValue="x => x.Count" />

                            <ApexPointSeries TItem="MonthlyLossPoint"
                                             Items="@_monthlyLossPoints"
                                             Name="القيمة المفقودة"
                                             SeriesType="SeriesType.Line"
                                             XValue="x => x.Month"
                                             YValue="x => x.Value" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض الاتجاه الشهري</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">إجمالي الخسائر</div>
                            <div class="compare-values">
                                <span>@_prevTotalLostCount</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_totalLostCount</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">القيمة المفقودة</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevTotalLostValue)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_totalLostValue)</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">معدل الخسارة</div>
                            <div class="compare-values">
                                <span>@_prevLossRate.ToString("F1")%</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_lossRate.ToString("F1")%</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">متوسط الخسارة</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevAvgLostValue)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_avgLostValue)</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @(_lossRate <= _prevLossRate ? "compare-good" : "compare-bad")">
                        @if (_lossRate <= _prevLossRate)
                        {
                            <span>معدل الخسارة الحالي أفضل أو مساوي للفترة السابقة</span>
                        }
                        else
                        {
                            <span>معدل الخسارة الحالي أعلى من الفترة السابقة ويحتاج معالجة</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* ANALYTICS GRID *@
        <section class="lstr-analytics-grid">
            <div class="glass-card side-card">
                <div class="card-head">
                    <div>
                        <h3>حصة كل سبب من إجمالي الخسائر</h3>
                        <p>النسبة المئوية لكل سبب من العدد الكلي</p>
                    </div>
                </div>

                @if (_reasonPercentPoints.Any())
                {
                    <ApexChart TItem="ReasonPercentPoint"
                               Options="_reasonPercentChartOptions"
                               Height="320">
                        <ApexPointSeries TItem="ReasonPercentPoint"
                                         Items="@_reasonPercentPoints"
                                         Name="النسبة %"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Reason"
                                         YValue="x => x.Percent" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty small">لا توجد بيانات كافية لعرض النسب</div>
                }
            </div>

            <div class="glass-card lstr-reason-table-card">
                <div class="card-head">
                    <div>
                        <h3>تفاصيل الأسباب</h3>
                        <p>ملخص لكل سبب من حيث العدد والنسبة والقيمة ومتوسط الخسارة</p>
                    </div>
                </div>

                <MudTable Items="@_reasonRows"
                          Hover="true"
                          Dense="true"
                          Elevation="0"
                          RowsPerPage="10"
                          Breakpoint="Breakpoint.Sm"
                          Class="premium-table">
                    <HeaderContent>
                        <MudTh>السبب</MudTh>
                        <MudTh>العدد</MudTh>
                        <MudTh>النسبة</MudTh>
                        <MudTh>القيمة المفقودة</MudTh>
                        <MudTh>متوسط القيمة</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="السبب">@context.ReasonName</MudTd>
                        <MudTd DataLabel="العدد">@context.Count.ToString("N0")</MudTd>
                        <MudTd DataLabel="النسبة">
                            <span class="rate-pill @GetReasonPillClass(context.Percentage)">
                                @context.Percentage.ToString("F1")%
                            </span>
                        </MudTd>
                        <MudTd DataLabel="القيمة المفقودة">@FormatMoney(context.TotalValue)</MudTd>
                        <MudTd DataLabel="متوسط القيمة">@FormatMoney(context.AvgValue)</MudTd>
                    </RowTemplate>

                    <FooterContent>
                        <MudTd style="font-weight:700;">الإجمالي</MudTd>
                        <MudTd style="font-weight:700;">@_totalLostCount.ToString("N0")</MudTd>
                        <MudTd style="font-weight:700;">100.0%</MudTd>
                        <MudTd style="font-weight:700;">@FormatMoney(_totalLostValue)</MudTd>
                        <MudTd style="font-weight:700;">@FormatMoney(_avgLostValue)</MudTd>
                    </FooterContent>

                    <NoRecordsContent>
                        <div class="empty-data">
                            <div class="empty-icon">📉</div>
                            <h4>لا توجد بيانات</h4>
                            <p>لا توجد أسباب خسارة مطابقة للفترة الحالية</p>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </section>

        @* REASON DRILL-DOWN *@
        <section class="glass-card lstr-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down حسب السبب</h3>
                    <p>اختر سببًا لعرض تحليله الشهري وأكبر الفرص المرتبطة به</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(_selectedReason))
                {
                    <button class="clear-reason-btn" @onclick="ClearSelectedReason">
                        إلغاء اختيار السبب
                    </button>
                }
            </div>

            <div class="reason-chip-row">
                @foreach (var reason in _reasonRows)
                {
                    <button class="reason-chip-btn @(IsSelectedReason(reason.ReasonName) ? "reason-chip-active" : "")"
                            @onclick="() => SelectReason(reason.ReasonName)">
                        <span>@reason.ReasonName</span>
                        <small>@reason.Count.ToString("N0") خسارة</small>
                    </button>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_selectedReason) || _detailRows.Any())
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">السبب المحدد</span>
                        <strong>@_selectedReasonName</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">عدد الخسائر</span>
                        <strong>@_selectedReasonCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">القيمة المفقودة</span>
                        <strong>@FormatMoney(_selectedReasonValue)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">متوسط الخسارة</span>
                        <strong>@FormatMoney(_selectedReasonAvgValue)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">النسبة</span>
                        <strong>@_selectedReasonPercent.ToString("F1")%</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أعلى شهر</span>
                        <strong>@_selectedReasonTopMonth</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أكثر موظف</span>
                        <strong>@_selectedReasonTopEmployee</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>الاتجاه الشهري للسبب المحدد</h3>
                                <p>عدد الخسائر والقيمة المفقودة لنفس السبب عبر الشهور</p>
                            </div>
                        </div>

                        @if (_selectedReasonMonthlyPoints.Any())
                        {
                            <ApexChart TItem="SelectedReasonMonthPoint"
                                       Options="_selectedReasonMonthlyChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="SelectedReasonMonthPoint"
                                                 Items="@_selectedReasonMonthlyPoints"
                                                 Name="عدد الخسائر"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.Count" />

                                <ApexPointSeries TItem="SelectedReasonMonthPoint"
                                                 Items="@_selectedReasonMonthlyPoints"
                                                 Name="القيمة"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.Value" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات كافية لهذا السبب</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>الموظفون المتأثرون بهذا السبب</h3>
                                <p>الترتيب حسب عدد الخسائر لنفس السبب</p>
                            </div>
                        </div>

                        @if (_selectedReasonEmployeePoints.Any())
                        {
                            <ApexChart TItem="SelectedReasonEmployeePoint"
                                       Options="_selectedReasonEmployeeChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="SelectedReasonEmployeePoint"
                                                 Items="@_selectedReasonEmployeePoints"
                                                 Name="عدد الخسائر"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Employee"
                                                 YValue="x => x.Count" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات موظفين لهذا السبب</div>
                        }
                    </div>
                </div>
            }
        </section>

        @* DETAILS TABLE *@
        <section class="glass-card lstr-table-card">
            <div class="card-head">
                <div>
                    <h3>تفاصيل الفرص المفقودة</h3>
                    <p>
                        @if (!string.IsNullOrWhiteSpace(_selectedReason))
                        {
                            <span>عرض الفرص المفقودة للسبب: @_selectedReasonName</span>
                        }
                        else
                        {
                            <span>عرض أعلى الفرص المفقودة حسب القيمة</span>
                        }
                    </p>
                </div>
            </div>

            <MudTable Items="@_detailRows"
                      Hover="true"
                      Dense="true"
                      Elevation="0"
                      RowsPerPage="10"
                      Breakpoint="Breakpoint.Sm"
                      Class="premium-table">
                <HeaderContent>
                    <MudTh>العميل</MudTh>
                    <MudTh>الموظف</MudTh>
                    <MudTh>المرحلة</MudTh>
                    <MudTh>تاريخ الإنشاء</MudTh>
                    <MudTh>السبب</MudTh>
                    <MudTh>القيمة</MudTh>
                    <MudTh>إجراء</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="العميل">@context.ClientName</MudTd>
                    <MudTd DataLabel="الموظف">@context.EmployeeName</MudTd>
