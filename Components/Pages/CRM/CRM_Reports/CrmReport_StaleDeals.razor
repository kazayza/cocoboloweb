@page "/crm/reports/stale-deals"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير الفرص الراكدة</PageTitle>

<div class="stlx-page" dir="rtl">

    @* Background *@
    <div class="stlx-bg">
        <div class="stlx-orb orb-1"></div>
        <div class="stlx-orb orb-2"></div>
        <div class="stlx-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="stlx-hero">
        <div class="stlx-hero-grid"></div>

        <div class="stlx-hero-content">
            <div class="stlx-hero-top">
                <button class="stlx-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="stlx-badge">
                    <span class="badge-dot"></span>
                    <span>Stale Deals Intelligence</span>
                </div>
            </div>

            <div class="stlx-hero-main">
                <div class="stlx-hero-text">
                    <h1>تقرير <span>الفرص</span> الراكدة</h1>
                    <p>
                        لوحة تنفيذية متقدمة لاكتشاف الفرص المتوقفة، قياس حجم القيمة المهددة،
                        معرفة أكثر الموظفين والمراحل تعرضًا للركود، وتحديد أولويات المتابعة.
                    </p>

                    <div class="stlx-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">حتى تاريخ</span>
                            <span class="chip-value">@AsOfDateLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الحد الأدنى للركود</span>
                            <span class="chip-value">@SelectedThresholdLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الموظف</span>
                            <span class="chip-value">@SelectedEmployeeLabel</span>
                        </div>
                    </div>
                </div>

                <div class="stlx-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_criticalRatio.ToString("F1")%</div>
                            <div class="summary-caption">نسبة الحرجة</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card stlx-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>حدد الموظف، حد الركود بالأيام، وتاريخ القياس أو استخدم الفلاتر السريعة</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetThresholdAsync(7)">7 أيام</button>
            <button class="quick-range-btn" @onclick="async () => await SetThresholdAsync(14)">14 يوم</button>
            <button class="quick-range-btn" @onclick="async () => await SetThresholdAsync(30)">30 يوم</button>
            <button class="quick-range-btn" @onclick="async () => await SetThresholdAsync(60)">60 يوم</button>
        </div>

        <div class="filters-grid">
            <MudSelect T="int?"
                       @bind-Value="_empId"
                       Label="الموظف"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Class="filter-field">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem T="int?" Value="@((int?)emp.Id)">@emp.Name</MudSelectItem>
                }
            </MudSelect>

            <MudNumericField T="int"
                             @bind-Value="_minDays"
                             Label="الحد الأدنى للأيام بدون نشاط"
                             Variant="Variant.Outlined"
                             Dense="true"
                             Min="1"
                             Class="filter-field" />

            <MudDatePicker @bind-Date="_asOfDate"
                           Label="حتى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card stlx-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل الركود...</h3>
                <p>يتم تجهيز الفرص الراكدة والمؤشرات التحليلية</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="stlx-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon orange">⏸</div>
                <div class="kpi-body">
                    <div class="kpi-label">الفرص الراكدة</div>
                    <div class="kpi-value">@_staleCount.ToString("N0")</div>
                    <div class="kpi-sub">عدد الفرص التي تجاوزت الحد الأدنى المحدد</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon red">₪</div>
                <div class="kpi-body">
                    <div class="kpi-label">القيمة المهددة</div>
                    <div class="kpi-value">@FormatMoney(_threatenedValue)</div>
                    <div class="kpi-sub">إجمالي القيمة المتوقعة المعرضة للتأخر</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon purple">⌛</div>
                <div class="kpi-body">
                    <div class="kpi-label">أطول ركود</div>
                    <div class="kpi-value">@_maxDays.ToString("N0") يوم</div>
                    <div class="kpi-sub">أعلى عدد أيام بدون نشاط داخل القائمة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">📊</div>
                <div class="kpi-body">
                    <div class="kpi-label">متوسط الركود</div>
                    <div class="kpi-value">@_avgDaysInactive.ToString("F1") يوم</div>
                    <div class="kpi-sub">متوسط عدد الأيام بدون نشاط</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon crimson">⚠</div>
                <div class="kpi-body">
                    <div class="kpi-label">فرص حرجة</div>
                    <div class="kpi-value">@_criticalCount.ToString("N0")</div>
                    <div class="kpi-progress">
                        <div class="kpi-progress-bar critical" style="@GetCriticalProgressStyle()"></div>
                    </div>
                    <div class="kpi-sub">الفرص التي تجاوزت 30 يومًا بدون نشاط</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">👤</div>
                <div class="kpi-body">
                    <div class="kpi-label">أعلى موظف تهديدًا</div>
                    <div class="kpi-value kpi-name">@_topRiskEmployee</div>
                    <div class="kpi-sub">قيمة مهددة: @FormatMoney(_topRiskEmployeeValue)</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="stlx-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* DASHBOARD *@
        <section class="stlx-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>توزيع الركود حسب الفئات الزمنية</h3>
                        <p>عدد الفرص الراكدة مقابل القيمة المهددة داخل كل نطاق زمني</p>
                    </div>
                </div>

                @if (_agingChartPoints.Any())
                {
                    <ApexChart TItem="AgingBucketChartPoint"
                               Options="_agingChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="AgingBucketChartPoint"
                                         Items="@_agingChartPoints"
                                         Name="عدد الفرص"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Band"
                                         YValue="x => x.Count" />

                        <ApexPointSeries TItem="AgingBucketChartPoint"
                                         Items="@_agingChartPoints"
                                         Name="القيمة المهددة"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Band"
                                         YValue="x => x.ThreatenedValue" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>أعلى الموظفين تهديدًا</h3>
                            <p>الترتيب حسب إجمالي القيمة المهددة</p>
                        </div>
                    </div>

                    @if (_employeeRiskChartPoints.Any())
                    {
                        <ApexChart TItem="EmployeeRiskChartPoint"
                                   Options="_employeeRiskChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="EmployeeRiskChartPoint"
                                             Items="@_employeeRiskChartPoints"
                                             Name="القيمة المهددة"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Employee"
                                             YValue="x => x.ThreatenedValue" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض الموظفين</div>
                    }
                </div>

                <div class="glass-card side-card summary-card">
                    <div class="card-head">
                        <div>
                            <h3>ملخص صحة القائمة</h3>
                            <p>نظرة سريعة على حالة الركود الحالية</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">حتى تاريخ</div>
                            <div class="compare-values">
                                <strong>@AsOfDateLabel</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">الحد الأدنى</div>
                            <div class="compare-values">
                                <strong>@SelectedThresholdLabel</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">القيمة المتوسطة للفرصة</div>
                            <div class="compare-values">
                                <strong>@FormatMoney(_avgThreatenedValue)</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">بدون آخر تواصل</div>
                            <div class="compare-values">
                                <strong>@_missingActivityCount.ToString("N0")</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">أكثر مرحلة تعثرًا</div>
                            <div class="compare-values">
                                <strong>@_topRiskStage</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @(_criticalRatio >= 50 ? "compare-bad" : _criticalRatio >= 25 ? "compare-mid" : "compare-good")">
                        @if (_criticalRatio >= 50)
                        {
                            <span>نسبة الفرص الحرجة مرتفعة وتحتاج تدخل فوري</span>
                        }
                        else if (_criticalRatio >= 25)
                        {
                            <span>الركود متوسط ويحتاج متابعة مركزة</span>
                        }
                        else
                        {
                            <span>مستوى الركود تحت السيطرة نسبيًا</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* ANALYTICS GRID *@
        <section class="stlx-analytics-grid">
            <div class="glass-card side-card">
                <div class="card-head">
                    <div>
                        <h3>الركود حسب المرحلة</h3>
                        <p>عدد الفرص الراكدة داخل كل مرحلة</p>
                    </div>
                </div>

                @if (_stageRiskChartPoints.Any())
                {
                    <ApexChart TItem="StageRiskChartPoint"
                               Options="_stageRiskChartOptions"
                               Height="320">
                        <ApexPointSeries TItem="StageRiskChartPoint"
                                         Items="@_stageRiskChartPoints"
                                         Name="عدد الفرص"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Stage"
                                         YValue="x => x.Count" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty small">لا توجد بيانات كافية لعرض المراحل</div>
                }
            </div>

            <div class="glass-card stlx-employee-table-card">
                <div class="card-head">
                    <div>
                        <h3>ملخص حسب الموظف</h3>
                        <p>عدد الفرص الراكدة والقيمة المهددة ومتوسط الركود لكل موظف</p>
                    </div>
                </div>

                <MudTable Items="@_employeeRows"
                          Hover="true"
                          Dense="true"
                          Elevation="0"
                          RowsPerPage="8"
                          Breakpoint="Breakpoint.Sm"
                          Class="premium-table">
                    <HeaderContent>
                        <MudTh>الموظف</MudTh>
                        <MudTh>الفرص</MudTh>
                        <MudTh>القيمة المهددة</MudTh>
                        <MudTh>متوسط الركود</MudTh>
                        <MudTh>أطول ركود</MudTh>
                        <MudTh>حرجة</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="الموظف">@context.Employee</MudTd>
                        <MudTd DataLabel="الفرص">@context.Count.ToString("N0")</MudTd>
                        <MudTd DataLabel="القيمة المهددة">@FormatMoney(context.ThreatenedValue)</MudTd>
                        <MudTd DataLabel="متوسط الركود">@context.AvgDays.ToString("F1") يوم</MudTd>
                        <MudTd DataLabel="أطول ركود">@context.MaxDays.ToString("N0") يوم</MudTd>
                        <MudTd DataLabel="حرجة">
                            <span class="rate-pill @GetCriticalPillClass(context.CriticalCount, context.Count)">
                                @context.CriticalCount.ToString("N0")
                            </span>
                        </MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <div class="empty-data">
                            <div class="empty-icon">📉</div>
                            <h4>لا توجد بيانات</h4>
                            <p>لا يوجد ملخص متاح حسب الموظف</p>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </section>

        @* EMPLOYEE DRILL-DOWN *@
        <section class="glass-card stlx-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down حسب الموظف</h3>
                    <p>اختر موظفًا لعرض أخطر الفرص الراكدة لديه وتوزيعها حسب المرحلة</p>
                </div>

                @if (_selectedEmployeeId.HasValue)
                {
                    <button class="clear-emp-btn" @onclick="ClearSelectedEmployee">
                        إلغاء اختيار الموظف
                    </button>
                }
            </div>

            <div class="employee-chip-row">
                @foreach (var emp in _employeeRows)
                {
                    <button class="employee-chip-btn @(IsSelectedEmployee(emp.EmpId) ? "employee-chip-active" : "")"
                            @onclick="() => SelectEmployee(emp.EmpId)">
                        <span>@emp.Employee</span>
                        <small>@emp.Count.ToString("N0") فرصة</small>
                    </button>
                }
            </div>

            @if (_selectedEmployeeId.HasValue)
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">الموظف المحدد</span>
                        <strong>@_selectedEmployeeName</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الفرص الراكدة</span>
                        <strong>@_selectedEmployeeCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">القيمة المهددة</span>
                        <strong>@FormatMoney(_selectedEmployeeThreatenedValue)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">متوسط الركود</span>
                        <strong>@_selectedEmployeeAvgDays.ToString("F1") يوم</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أطول ركود</span>
                        <strong>@_selectedEmployeeMaxDays.ToString("N0") يوم</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أكثر مرحلة</span>
                        <strong>@_selectedEmployeeTopStage</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>أخطر فرص الموظف</h3>
                                <p>الترتيب حسب عدد الأيام بدون نشاط</p>
                            </div>
                        </div>

                        @if (_selectedEmployeeDealPoints.Any())
                        {
                            <ApexChart TItem="SelectedEmployeeDealPoint"
                                       Options="_selectedEmployeeDealChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="SelectedEmployeeDealPoint"
                                                 Items="@_selectedEmployeeDealPoints"
                                                 Name="أيام بدون نشاط"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Deal"
                                                 YValue="x => x.DaysInactive" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد فرص كافية لهذا الموظف</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>توزيع حسب المرحلة</h3>
                                <p>مراحل الفرص الراكدة للموظف المحدد</p>
                            </div>
                        </div>

                        @if (_selectedEmployeeStagePoints.Any())
                        {
                            <ApexChart TItem="SelectedEmployeeStagePoint"
                                       Options="_selectedEmployeeStageChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="SelectedEmployeeStagePoint"
                                                 Items="@_selectedEmployeeStagePoints"
                                                 Name="عدد الفرص"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Stage"
                                                 YValue="x => x.Count" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات مراحل لهذا الموظف</div>
                        }
                    </div>
                </div>
            }
        </section>

        @* STALE DEALS TABLE *@
        <section class="glass-card stlx-table-card">
            <div class="card-head">
                <div>
                    <h3>تفاصيل الفرص الراكدة</h3>
                    <p>الفرص المفتوحة التي تجاوزت الحد الأدنى المحدد بدون نشاط كافٍ</p>
                </div>
            </div>

            <MudTable Items="@_staleDeals"
                      Hover="true"
                      Dense="true"
                      Elevation="0"
                      RowsPerPage="10"
                      Breakpoint="Breakpoint.Sm"
                      Class="premium-table">
                <HeaderContent>
                    <MudTh>العميل</MudTh>
                    <MudTh>الموظف</MudTh>
                    <MudTh>المرحلة</MudTh>
                    <MudTh>آخر نشاط</MudTh>
                    <MudTh>المرجع</MudTh>
                    <MudTh>أيام بدون نشاط</MudTh>
                    <MudTh>القيمة</MudTh>
                    <MudTh>الخطر</MudTh>
                    <MudTh>إجراء</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="العميل" Style="@($"background:{context.RowTint};")">@context.ClientName</MudTd>
                    <MudTd DataLabel="الموظف" Style="@($"background:{context.RowTint};")">@context.EmployeeName</MudTd>
                    <MudTd DataLabel="المرحلة" Style="@($"background:{context.RowTint};")">
                        <span class="stage-pill" style="@GetStagePillStyle(context.StageColor)">
                            @context.StageName
                        </span>
                    </MudTd>
                    <MudTd DataLabel="آخر نشاط" Style="@($"background:{context.RowTint};")">@FormatDate(context.LastActivityDate)</MudTd>
                    <MudTd DataLabel="المرجع" Style="@($"background:{context.RowTint};")">@context.ActivitySource</MudTd>
                    <MudTd DataLabel="أيام بدون نشاط" Style="@($"background:{context.RowTint};")">
                        <span class="rate-pill @GetDaysPillClass(context.DaysInactive)">
                            @context.DaysInactive.ToString("N0")
                        </span>
                    </MudTd>
                    <MudTd DataLabel="القيمة" Style="@($"background:{context.RowTint};")">@FormatMoney(context.ExpectedValue)</MudTd>
                    <MudTd DataLabel="الخطر" Style="@($"background:{context.RowTint};")">
                        <span class="rate-pill @GetRiskPillClass(context.DaysInactive)">
                            @GetRiskLabel(context.DaysInactive)
                        </span>
                    </MudTd>
                    <MudTd DataLabel="إجراء" Style="@($"background:{context.RowTint};")">
                        <MudIconButton Icon="@Icons.Material.Rounded.OpenInNew"
                                       Color="@MudColor.Primary"
                                       Size="@MudSize.Small"
