            await JS.InvokeVoidAsync("eval", "window.print()");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تشغيل الطباعة: {ex.Message}", Severity.Error);
        }
    }

    private void SelectEmployee(int empId)
    {
        _selectedEmployeeId = empId;
        BuildSelectedEmployeeAnalytics();
    }

    private void ClearSelectedEmployee()
    {
        _selectedEmployeeId = null;
        BuildSelectedEmployeeAnalytics();
    }

    private bool IsSelectedEmployee(int empId)
        => _selectedEmployeeId.HasValue && _selectedEmployeeId.Value == empId;

    private void GoBack()
        => Navigation.NavigateTo("/crm/reports");

    private void OpenOpportunity(int id)
        => Navigation.NavigateTo($"/crm/opportunities/{id}");

    private string FormatDate(DateTime? d)
        => d?.ToString("yyyy/MM/dd") ?? "—";

    private string GetStagePillStyle(string? stageColor)
    {
        if (string.IsNullOrWhiteSpace(stageColor))
            return "background:#e5e7eb;color:#111827;";

        return $"background:{stageColor};color:#fff;";
    }

    private string GetRowTint(int days)
    {
        if (days > 60) return "#fef2f2";
        if (days > 30) return "#fff7ed";
        if (days > 14) return "#fffbeb";
        return "";
    }

    private string GetRiskLabel(int days)
    {
        if (days > 60) return "حرج جدًا";
        if (days > 30) return "حرج";
        if (days > 14) return "مرتفع";
        return "متوسط";
    }

    private string GetRiskPillClass(int days)
    {
        if (days > 60) return "rate-bad";
        if (days > 30) return "rate-critical";
        if (days > 14) return "rate-mid";
        return "rate-good";
    }

    private string GetDaysPillClass(int days)
    {
        if (days > 60) return "rate-bad";
        if (days > 30) return "rate-critical";
        if (days > 14) return "rate-mid";
        return "rate-good";
    }

    private string GetCriticalPillClass(int critical, int total)
    {
        if (total <= 0) return "rate-good";

        var ratio = (double)critical / total * 100d;
        if (ratio >= 50) return "rate-bad";
        if (ratio >= 25) return "rate-mid";
        return "rate-good";
    }

    private string FormatMoney(decimal value)
        => $"{value:N0} ج.م";

    private string GetCriticalProgressStyle()
    {
        var safe = Math.Max(0, Math.Min(_criticalRatio, 100));
        return $"width:{safe:F0}%";
    }

    private string GetSummaryRingStyle()
    {
        var safe = Math.Max(0, Math.Min(_criticalRatio, 100));
        var angle = safe * 3.6;
        return $"background: conic-gradient(#ef4444 0deg, #ef4444 {angle:F1}deg, rgba(255,255,255,.12) {angle:F1}deg, rgba(255,255,255,.12) 360deg);";
    }

