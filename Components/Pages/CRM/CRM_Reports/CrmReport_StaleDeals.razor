    private async Task LoadEmployeesAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            _employees = await db.VwSalesOpportunities
                .AsNoTracking()
                .Where(o => o.EmployeeId != null && o.EmployeeName != null)
                .GroupBy(o => new { o.EmployeeId, o.EmployeeName })
                .Select(g => new EmployeeInfo
                {
                    Id = g.Key.EmployeeId!.Value,
                    Name = g.Key.EmployeeName!
                })
                .OrderBy(x => x.Name)
                .ToListAsync();
        }
        catch
        {
        }
    }

    private async Task ResetFiltersAsync()
    {
        _empId = null;
        _minDays = 7;
        _asOfDate = DateTime.Today;
        _selectedEmployeeId = null;
        await LoadData();
    }

    private async Task SetThresholdAsync(int days)
    {
        _minDays = days <= 0 ? 7 : days;
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            if (_minDays < 1)
                _minDays = 1;

            await using var db = await DbFactory.CreateDbContextAsync();

            var asOf = (_asOfDate ?? DateTime.Today).Date;

            var query = db.VwSalesOpportunities
                .AsNoTracking()
                .Where(o => o.IsActive == true && o.StageId != 3 && o.StageId != 4 && o.StageId != 5);

            if (_empId.HasValue)
                query = query.Where(o => o.EmployeeId == _empId.Value);

            var allOpenDeals = await query
                .Select(o => new RawDealRow
                {
                    OpportunityId = o.OpportunityId,
                    ClientName = o.ClientName ?? "—",
                    EmployeeName = o.EmployeeName ?? "—",
                    EmpId = o.EmployeeId ?? 0,
                    StageName = o.StageName ?? "—",
                    StageColor = o.StageColor ?? "",
                    LastContactDate = o.LastContactDate,
                    CreatedAt = o.CreatedAt,
                    ExpectedValue = o.ExpectedValue ?? 0m
                })
                .ToListAsync();

            _missingActivityCount = allOpenDeals.Count(x => !x.LastContactDate.HasValue);

            _staleDeals = allOpenDeals
                .Select(x =>
                {
                    var anchor = (x.LastContactDate ?? x.CreatedAt).Date;
                    var daysInactive = Math.Max(0, (asOf - anchor).Days);

                    return new StaleDealRow
                    {
                        OpportunityId = x.OpportunityId,
                        ClientName = x.ClientName,
                        EmployeeName = x.EmployeeName,
                        EmpId = x.EmpId,
                        StageName = x.StageName,
                        StageColor = x.StageColor,
                        LastActivityDate = anchor,
                        ActivitySource = x.LastContactDate.HasValue ? "آخر تواصل" : "تاريخ الإنشاء",
                        DaysInactive = daysInactive,
                        ExpectedValue = x.ExpectedValue,
                        RowTint = GetRowTint(daysInactive)
                    };
                })
                .Where(x => x.DaysInactive >= _minDays)
                .OrderByDescending(x => x.DaysInactive)
                .ThenByDescending(x => x.ExpectedValue)
                .ToList();

            CalculateKpis();
            BuildAgingChart();
            BuildEmployeeAnalytics();
            BuildStageAnalytics();
            ResolveSelectedEmployee();
            BuildSelectedEmployeeAnalytics();
            BuildInsights();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void CalculateKpis()
    {
        _staleCount = _staleDeals.Count;
        _threatenedValue = _staleDeals.Sum(x => x.ExpectedValue);
        _maxDays = _staleDeals.Any() ? _staleDeals.Max(x => x.DaysInactive) : 0;
        _avgDaysInactive = _staleDeals.Any() ? _staleDeals.Average(x => x.DaysInactive) : 0d;
        _criticalCount = _staleDeals.Count(x => x.DaysInactive > 30);
        _criticalRatio = _staleCount > 0 ? (double)_criticalCount / _staleCount * 100d : 0d;
        _avgThreatenedValue = _staleCount > 0 ? _threatenedValue / _staleCount : 0m;
    }

    private void BuildAgingChart()
    {
        var bands = new List<AgingBucketChartPoint>
        {
            CreateAgingPoint("7 - 14", x => x.DaysInactive >= 7 && x.DaysInactive <= 14),
            CreateAgingPoint("15 - 30", x => x.DaysInactive >= 15 && x.DaysInactive <= 30),
            CreateAgingPoint("31 - 60", x => x.DaysInactive >= 31 && x.DaysInactive <= 60),
            CreateAgingPoint("61+", x => x.DaysInactive >= 61)
        };

        _agingChartPoints = bands;
    }

    private AgingBucketChartPoint CreateAgingPoint(string label, Func<StaleDealRow, bool> predicate)
    {
        var rows = _staleDeals.Where(predicate).ToList();

        return new AgingBucketChartPoint
        {
            Band = label,
            Count = rows.Count,
            ThreatenedValue = rows.Sum(x => x.ExpectedValue)
        };
    }

    private void BuildEmployeeAnalytics()
    {
        _employeeRows = _staleDeals
            .GroupBy(x => new { x.EmpId, x.EmployeeName })
            .Select(g => new EmployeeRiskRow
            {
                EmpId = g.Key.EmpId,
                Employee = g.Key.EmployeeName,
                Count = g.Count(),
                ThreatenedValue = g.Sum(x => x.ExpectedValue),
                AvgDays = g.Any() ? g.Average(x => x.DaysInactive) : 0d,
                MaxDays = g.Any() ? g.Max(x => x.DaysInactive) : 0,
                CriticalCount = g.Count(x => x.DaysInactive > 30)
            })
            .OrderByDescending(x => x.ThreatenedValue)
            .ThenByDescending(x => x.Count)
            .ThenByDescending(x => x.MaxDays)
            .ToList();

        _employeeRiskChartPoints = _employeeRows
            .Take(8)
            .Select(x => new EmployeeRiskChartPoint
            {
                Employee = x.Employee,
                ThreatenedValue = x.ThreatenedValue
            })
            .ToList();

        var top = _employeeRows.FirstOrDefault();
        _topRiskEmployee = top?.Employee ?? "—";
        _topRiskEmployeeValue = top?.ThreatenedValue ?? 0m;
    }

    private void BuildStageAnalytics()
    {
        _stageRiskChartPoints = _staleDeals
            .GroupBy(x => x.StageName)
            .Select(g => new StageRiskChartPoint
            {
                Stage = g.Key,
                Count = g.Count()
            })
            .OrderByDescending(x => x.Count)
            .Take(8)
            .ToList();

        _topRiskStage = _stageRiskChartPoints.FirstOrDefault()?.Stage ?? "—";
    }

    private void ResolveSelectedEmployee()
    {
        if (!_employeeRows.Any())
        {
            _selectedEmployeeId = null;
            return;
        }

        if (_selectedEmployeeId.HasValue && _employeeRows.Any(x => x.EmpId == _selectedEmployeeId.Value))
            return;

        _selectedEmployeeId = _employeeRows.First().EmpId;
    }

    private void BuildSelectedEmployeeAnalytics()
    {
        _selectedEmployeeName = "—";
        _selectedEmployeeCount = 0;
        _selectedEmployeeThreatenedValue = 0m;
        _selectedEmployeeAvgDays = 0d;
        _selectedEmployeeMaxDays = 0;
        _selectedEmployeeTopStage = "—";
        _selectedEmployeeDealPoints = new();
        _selectedEmployeeStagePoints = new();

        if (!_selectedEmployeeId.HasValue)
            return;

        var rows = _staleDeals
            .Where(x => x.EmpId == _selectedEmployeeId.Value)
            .ToList();

        if (!rows.Any())
            return;

        _selectedEmployeeName = rows.First().EmployeeName;
        _selectedEmployeeCount = rows.Count;
        _selectedEmployeeThreatenedValue = rows.Sum(x => x.ExpectedValue);
        _selectedEmployeeAvgDays = rows.Average(x => x.DaysInactive);
        _selectedEmployeeMaxDays = rows.Max(x => x.DaysInactive);

        _selectedEmployeeDealPoints = rows
            .OrderByDescending(x => x.DaysInactive)
            .ThenByDescending(x => x.ExpectedValue)
            .Take(8)
            .Select(x => new SelectedEmployeeDealPoint
            {
                Deal = x.ClientName,
                DaysInactive = x.DaysInactive
            })
            .ToList();

        _selectedEmployeeStagePoints = rows
            .GroupBy(x => x.StageName)
            .Select(g => new SelectedEmployeeStagePoint
            {
                Stage = g.Key,
                Count = g.Count()
            })
            .OrderByDescending(x => x.Count)
            .ToList();

        _selectedEmployeeTopStage = _selectedEmployeeStagePoints.FirstOrDefault()?.Stage ?? "—";
    }

    private void BuildInsights()
    {
        _insights = new();

        if (_staleDeals.Any())
        {
            var largest = _staleDeals
                .OrderByDescending(x => x.ExpectedValue)
                .ThenByDescending(x => x.DaysInactive)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.AttachMoney,
                Title = "أعلى قيمة مهددة",
                Value = largest.ClientName,
                Description = $"{FormatMoney(largest.ExpectedValue)} — {largest.DaysInactive} يوم",
                ToneClass = "tone-red"
            });

            var oldest = _staleDeals
                .OrderByDescending(x => x.DaysInactive)
                .ThenByDescending(x => x.ExpectedValue)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Timer,
                Title = "أقدم فرصة راكدة",
                Value = oldest.ClientName,
                Description = $"{oldest.DaysInactive} يوم بدون نشاط",
                ToneClass = "tone-gold"
            });
        }

        if (_employeeRows.Any())
        {
            var topEmp = _employeeRows.First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Person,
                Title = "أخطر موظف حاليًا",
                Value = topEmp.Employee,
                Description = $"{topEmp.Count} فرصة — {FormatMoney(topEmp.ThreatenedValue)}",
                ToneClass = "tone-indigo"
            });
        }

        _insights.Add(new InsightItem
        {
            Icon = _missingActivityCount > 0 ? Icons.Material.Rounded.ReportProblem : Icons.Material.Rounded.TaskAlt,
            Title = "جودة البيانات",
            Value = _missingActivityCount.ToString("N0"),
            Description = _missingActivityCount > 0
                ? "فرص بدون LastContactDate وتم الاعتماد على تاريخ الإنشاء"
                : "لا توجد فرص ناقصة تاريخ آخر تواصل",
            ToneClass = _missingActivityCount > 0 ? "tone-slate" : "tone-green"
        });

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("تقرير الفرص الراكدة");
            sb.AppendLine($"حتى تاريخ,{AsOfDateLabel}");
            sb.AppendLine($"الحد الأدنى,{SelectedThresholdLabel}");
            sb.AppendLine($"الموظف,{SelectedEmployeeLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"فرص راكدة,{_staleCount}");
            sb.AppendLine($"القيمة المهددة,{_threatenedValue:N0}");
            sb.AppendLine($"أطول ركود,{_maxDays}");
            sb.AppendLine($"متوسط الركود,{_avgDaysInactive:F1}");
            sb.AppendLine($"فرص حرجة,{_criticalCount}");
            sb.AppendLine($"أعلى موظف تهديدًا,{_topRiskEmployee}");
            sb.AppendLine();

            sb.AppendLine("ملخص حسب الموظف");
            sb.AppendLine("الموظف,الفرص,القيمة المهددة,متوسط الركود,أطول ركود,حرجة");
            foreach (var row in _employeeRows)
            {
                sb.AppendLine($"{row.Employee},{row.Count},{row.ThreatenedValue:N0},{row.AvgDays:F1},{row.MaxDays},{row.CriticalCount}");
            }

            sb.AppendLine();
            sb.AppendLine("تفاصيل الفرص الراكدة");
            sb.AppendLine("العميل,الموظف,المرحلة,آخر نشاط,المرجع,أيام بدون نشاط,القيمة,الخطر");
            foreach (var row in _staleDeals)
            {
                sb.AppendLine($"{row.ClientName},{row.EmployeeName},{row.StageName},{FormatDate(row.LastActivityDate)},{row.ActivitySource},{row.DaysInactive},{row.ExpectedValue:N0},{GetRiskLabel(row.DaysInactive)}");
            }

            var csv = sb.ToString();
            var fileName = $"stale-deals-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

