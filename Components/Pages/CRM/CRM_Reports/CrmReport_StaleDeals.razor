    private sealed class RawDealRow
    {
        public int OpportunityId { get; set; }
        public string ClientName { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public int EmpId { get; set; }
        public string StageName { get; set; } = "";
        public string StageColor { get; set; } = "";
        public DateTime? LastContactDate { get; set; }
        public DateTime CreatedAt { get; set; }
        public decimal ExpectedValue { get; set; }
    }

    private sealed class StaleDealRow
    {
        public int OpportunityId { get; set; }
        public string ClientName { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public int EmpId { get; set; }
        public string StageName { get; set; } = "";
        public string StageColor { get; set; } = "";
        public DateTime? LastActivityDate { get; set; }
        public string ActivitySource { get; set; } = "";
        public int DaysInactive { get; set; }
        public decimal ExpectedValue { get; set; }
        public string RowTint { get; set; } = "";
    }

    private sealed class EmployeeRiskRow
    {
        public int EmpId { get; set; }
        public string Employee { get; set; } = "";
        public int Count { get; set; }
        public decimal ThreatenedValue { get; set; }
        public double AvgDays { get; set; }
        public int MaxDays { get; set; }
        public int CriticalCount { get; set; }
    }

    private sealed class AgingBucketChartPoint
    {
        public string Band { get; set; } = "";
        public decimal Count { get; set; }
        public decimal ThreatenedValue { get; set; }
    }

    private sealed class EmployeeRiskChartPoint
    {
        public string Employee { get; set; } = "";
        public decimal ThreatenedValue { get; set; }
    }

    private sealed class StageRiskChartPoint
    {
        public string Stage { get; set; } = "";
        public decimal Count { get; set; }
    }

    private sealed class SelectedEmployeeDealPoint
    {
        public string Deal { get; set; } = "";
        public decimal DaysInactive { get; set; }
    }

    private sealed class SelectedEmployeeStagePoint
    {
        public string Stage { get; set; } = "";
        public decimal Count { get; set; }
    }

    private sealed class InsightItem
    {
        public string Icon { get; set; } = "";
        public string Title { get; set; } = "";
        public string Value { get; set; } = "";
        public string Description { get; set; } = "";
        public string ToneClass { get; set; } = "";
    }
}

<style>
    .stlx-page {
        --text: #0f172a;
        --muted: #64748b;
        --line: rgba(148, 163, 184, .16);
        --glass: rgba(255,255,255,.72);
        --shadow: 0 20px 50px rgba(15, 23, 42, .06);

        max-width: 1460px;
        margin: 0 auto;
        padding: 1.25rem 1.25rem 3rem;
        position: relative;
        min-height: 100vh;
    }

    .stlx-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .stlx-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: .16;
    }

    .orb-1 {
        width: 420px;
        height: 420px;
        background: #f97316;
        top: -120px;
        right: -120px;
        animation: stlxFloat 12s ease-in-out infinite;
    }

    .orb-2 {
        width: 360px;
        height: 360px;
        background: #ef4444;
        bottom: -80px;
        left: -80px;
        animation: stlxFloat 18s ease-in-out infinite reverse;
    }

    .orb-3 {
        width: 280px;
        height: 280px;
        background: #8b5cf6;
        top: 30%;
        left: 45%;
        animation: stlxFloat 16s ease-in-out infinite;
    }

    @@keyframes stlxFloat {
        0%,100% { transform: translate(0,0) scale(1); }
        50% { transform: translate(20px,-20px) scale(1.08); }
    }

    .glass-card {
        position: relative;
        z-index: 1;
        background: var(--glass);
        backdrop-filter: blur(20px) saturate(1.5);
        -webkit-backdrop-filter: blur(20px) saturate(1.5);
        border: 1px solid rgba(255,255,255,.48);
        box-shadow: var(--shadow);
        border-radius: 1.35rem;
    }

    .glass-inner-card {
        background: rgba(255,255,255,.45);
        border: 1px solid rgba(255,255,255,.4);
        border-radius: 1.2rem;
        padding: 1rem;
    }

    /* HERO */
    .stlx-hero {
        position: relative;
        overflow: hidden;
        border-radius: 1.8rem;
        margin-bottom: 1.25rem;
        background: linear-gradient(135deg, #111827 0%, #7c2d12 45%, #b91c1c 100%);
        padding: 2rem;
        color: #fff;
        z-index: 1;
    }

    .stlx-hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
        background-size: 50px 50px;
        mask-image: radial-gradient(circle at center, black 45%, transparent 100%);
        pointer-events: none;
    }

    .stlx-hero-content {
        position: relative;
        z-index: 2;
    }

    .stlx-hero-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .stlx-back {
        width: 2.6rem;
        height: 2.6rem;
        border: 1px solid rgba(255,255,255,.18);
        background: rgba(255,255,255,.08);
        color: #fff;
        border-radius: .9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: .25s ease;
        backdrop-filter: blur(10px);
    }

    .stlx-back:hover {
        transform: translateX(-3px);
        background: rgba(255,255,255,.15);
    }

    .stlx-badge {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .45rem .9rem;
        border-radius: 999px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.16);
        color: #fee2e2;
        font-size: .8rem;
        font-weight: 700;
    }

    .badge-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #fdba74;
        box-shadow: 0 0 12px #fdba74;
        animation: badgePulse 2s infinite;
    }

    @@keyframes badgePulse {
        0%,100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.35); opacity: .6; }
    }

    .stlx-hero-main {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .stlx-hero-text {
        flex: 1;
    }

    .stlx-hero-text h1 {
        margin: 0 0 .6rem;
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -.02em;
    }

    .stlx-hero-text h1 span {
        color: #fdba74;
    }

    .stlx-hero-text p {
        margin: 0 0 1rem;
        color: rgba(255,255,255,.76);
        max-width: 760px;
        line-height: 1.8;
    }

    .stlx-hero-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .hero-chip {
        display: flex;
        flex-direction: column;
        gap: .15rem;
        padding: .85rem 1rem;
        border-radius: 1rem;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        min-width: 210px;
    }

    .chip-label {
        font-size: .72rem;
        color: rgba(255,255,255,.6);
    }

    .chip-value {
        font-size: .85rem;
        font-weight: 700;
        color: #fff;
    }

    .summary-ring {
        width: 170px;
        height: 170px;
        border-radius: 50%;
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: inset 0 0 30px rgba(255,255,255,.08);
    }

    .summary-ring-inner {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: rgba(15,23,42,.92);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255,255,255,.08);
    }

    .summary-percent {
        font-size: 2rem;
        font-weight: 900;
        line-height: 1;
        color: #fff;
    }

    .summary-caption {
        margin-top: .35rem;
        font-size: .78rem;
        color: rgba(255,255,255,.62);
    }

    /* FILTERS */
    .stlx-filters {
        padding: 1.15rem;
        margin-bottom: 1.25rem;
    }

    .filters-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        margin-bottom: 1rem;
    }

    .filters-head h3 {
        margin: 0 0 .2rem;
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
    }

    .filters-head p {
        margin: 0;
        color: var(--muted);
        font-size: .83rem;
    }

    .filters-actions {
        display: flex;
        gap: .65rem;
        flex-wrap: wrap;
    }

    .quick-range-row {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .quick-range-btn {
        border: 1px solid var(--line);
        background: rgba(255,255,255,.65);
        color: var(--text);
        border-radius: 999px;
        padding: .45rem .85rem;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: .2s ease;
    }

    .quick-range-btn:hover {
        background: rgba(249,115,22,.08);
        color: #c2410c;
        border-color: rgba(249,115,22,.22);
    }

    .filters-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(180px, 1fr));
        gap: .9rem;
    }

    .filter-field {
        background: rgba(255,255,255,.55);
        border-radius: .9rem;
    }

    /* LOADING */
    .stlx-loading {
        min-height: 320px;
        display: flex;
        gap: 1rem;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        text-align: center;
        padding: 2rem;
    }

    .loading-text h3 {
        margin: 0 0 .35rem;
        font-size: 1rem;
        color: var(--text);
    }

    .loading-text p {
        margin: 0;
        color: var(--muted);
        font-size: .85rem;
    }

    /* KPI */
    .stlx-kpis {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .kpi-card {
        padding: 1.1rem;
        display: flex;
        gap: .9rem;
        align-items: flex-start;
    }

    .kpi-icon {
        width: 3rem;
        height: 3rem;
        border-radius: .95rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 900;
        flex-shrink: 0;
    }

    .kpi-icon.orange { background: rgba(249,115,22,.12); color: #f97316; }
    .kpi-icon.red { background: rgba(239,68,68,.12); color: #ef4444; }
    .kpi-icon.purple { background: rgba(124,58,237,.12); color: #7c3aed; }
    .kpi-icon.amber { background: rgba(245,158,11,.12); color: #f59e0b; }
    .kpi-icon.crimson { background: rgba(220,38,38,.12); color: #dc2626; }
    .kpi-icon.indigo { background: rgba(99,102,241,.12); color: #6366f1; }

    .kpi-body {
        flex: 1;
        min-width: 0;
    }

    .kpi-label {
        color: var(--muted);
        font-size: .8rem;
        margin-bottom: .3rem;
    }

    .kpi-value {
        color: var(--text);
        font-size: 1.45rem;
        font-weight: 900;
        line-height: 1.2;
        margin-bottom: .35rem;
    }

    .kpi-name {
        font-size: 1.05rem;
    }

    .kpi-sub {
        color: var(--muted);
        font-size: .76rem;
        line-height: 1.5;
    }

    .kpi-progress {
        height: 8px;
        border-radius: 999px;
        background: rgba(148,163,184,.15);
        overflow: hidden;
        margin: .35rem 0 .45rem;
    }

    .kpi-progress-bar {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #f59e0b, #fbbf24);
    }

    .kpi-progress-bar.critical {
        background: linear-gradient(90deg, #ef4444, #f97316);
    }

    /* INSIGHTS */
    .stlx-insights {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .insight-card {
        padding: 1rem;
        display: flex;
        gap: .85rem;
        align-items: flex-start;
    }

    .insight-icon {
        width: 2.6rem;
        height: 2.6rem;
        border-radius: .85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .tone-gold { background: rgba(245,158,11,.12); color: #d97706; }
    .tone-green { background: rgba(16,185,129,.12); color: #059669; }
    .tone-red { background: rgba(239,68,68,.12); color: #dc2626; }
    .tone-indigo { background: rgba(99,102,241,.12); color: #4f46e5; }
    .tone-slate { background: rgba(148,163,184,.14); color: #475569; }

    .insight-body {
        min-width: 0;
        flex: 1;
    }

    .insight-title {
        color: var(--muted);
        font-size: .75rem;
        margin-bottom: .2rem;
    }

    .insight-value {
        color: var(--text);
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: .25rem;
    }

    .insight-desc {
        color: var(--muted);
        font-size: .74rem;
        line-height: 1.45;
    }

    /* DASHBOARD */
    .stlx-dashboard {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .stlx-analytics-grid {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 1rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .main-chart-card,
    .side-card,
    .stlx-employee-table-card,
    .stlx-table-card,
    .stlx-note,
    .stlx-drill {
        padding: 1rem;
    }

    .side-stack {
        display: grid;
        gap: 1rem;
    }

    .card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .75rem;
    }

    .card-head h3 {
        margin: 0 0 .2rem;
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
    }

    .card-head p {
        margin: 0;
        color: var(--muted);
        font-size: .8rem;
    }

    .chart-empty {
        min-height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .88rem;
    }

    .chart-empty.small {
        min-height: 180px;
    }

    /* SUMMARY CARD */
    .compare-list {
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }

    .compare-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: .75rem .85rem;
        border-radius: 1rem;
        background: rgba(255,255,255,.45);
        border: 1px solid var(--line);
    }

    .compare-label {
        font-size: .8rem;
        font-weight: 700;
        color: var(--text);
    }

    .compare-values {
        display: flex;
        align-items: center;
        gap: .55rem;
        color: var(--muted);
        font-size: .8rem;
        flex-wrap: wrap;
    }

    .compare-values strong {
        color: var(--text);
        font-size: .85rem;
    }

    .compare-summary {
        margin-top: .85rem;
        border-radius: 1rem;
        padding: .8rem .9rem;
        font-size: .8rem;
        font-weight: 700;
    }

    .compare-good {
        background: rgba(16,185,129,.12);
        color: #059669;
    }

    .compare-mid {
        background: rgba(245,158,11,.12);
        color: #d97706;
    }

    .compare-bad {
        background: rgba(239,68,68,.12);
        color: #dc2626;
    }

    /* DRILL */
    .drill-head {
        align-items: center;
    }

    .clear-emp-btn {
        border: 1px solid var(--line);
        background: rgba(255,255,255,.65);
        color: var(--text);
        border-radius: 999px;
        padding: .45rem .9rem;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: .2s ease;
    }

    .clear-emp-btn:hover {
        background: rgba(239,68,68,.08);
        color: #dc2626;
    }

    .employee-chip-row {
        display: flex;
        gap: .55rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .employee-chip-btn {
        border: 1px solid var(--line);
        background: rgba(255,255,255,.55);
        color: var(--text);
        border-radius: 1rem;
        padding: .55rem .8rem;
        min-width: 120px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .1rem;
        cursor: pointer;
        transition: .2s ease;
        font-weight: 700;
    }

    .employee-chip-btn small {
        color: var(--muted);
        font-size: .7rem;
        font-weight: 700;
    }

    .employee-chip-btn:hover {
        border-color: rgba(79,70,229,.25);
        background: rgba(99,102,241,.06);
        color: #4f46e5;
    }

    .employee-chip-active {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #fff;
        border-color: transparent;
        box-shadow: 0 10px 20px rgba(99,102,241,.22);
    }

    .employee-chip-active small {
        color: rgba(255,255,255,.85);
    }

    .drill-mini-kpis {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .mini-kpi {
        background: rgba(255,255,255,.45);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: .85rem;
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

    .mini-label {
        font-size: .72rem;
        color: var(--muted);
    }

    .mini-kpi strong {
        color: var(--text);
        font-size: .92rem;
    }

    .drill-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 1rem;
    }

    /* TABLES */
    .premium-table {
        background: transparent;
    }

    .rate-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: .3rem .7rem;
        font-size: .74rem;
        font-weight: 700;
    }

    .rate-good {
        background: rgba(16,185,129,.12);
        color: #059669;
    }

    .rate-mid {
        background: rgba(245,158,11,.12);
        color: #d97706;
    }

    .rate-critical {
        background: rgba(249,115,22,.12);
        color: #c2410c;
    }

    .rate-bad {
        background: rgba(239,68,68,.12);
        color: #dc2626;
    }

    .stage-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: .32rem .7rem;
        font-size: .72rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .empty-data {
        text-align: center;
        padding: 2rem 1rem;
    }

    .empty-icon {
        font-size: 2rem;
        margin-bottom: .5rem;
    }

    .empty-data h4 {
        margin: 0 0 .35rem;
        color: var(--text);
    }

    .empty-data p {
        margin: 0;
        color: var(--muted);
        font-size: .85rem;
    }

    /* NOTE */
    .stlx-note {
        display: flex;
        gap: .9rem;
        align-items: flex-start;
        margin-top: 1rem;
    }

    .note-icon {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: .85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(99,102,241,.10);
        color: #4f46e5;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .note-body h4 {
        margin: 0 0 .3rem;
        color: var(--text);
        font-size: .95rem;
        font-weight: 800;
    }

    .note-body p {
        margin: 0;
        color: var(--muted);
        font-size: .82rem;
        line-height: 1.7;
    }

    /* RESPONSIVE */
    @@media (max-width: 1300px) {
        .stlx-kpis {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .drill-mini-kpis {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 1200px) {
        .stlx-insights {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .stlx-dashboard,
        .stlx-analytics-grid,
        .drill-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 900px) {
        .stlx-hero-main,
        .filters-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .filters-grid {
            grid-template-columns: 1fr;
        }

        .drill-mini-kpis {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .stlx-page {
            padding: .8rem .8rem 2rem;
        }

        .stlx-hero {
            padding: 1.25rem;
            border-radius: 1.2rem;
        }

        .stlx-hero-text h1 {
            font-size: 1.7rem;
        }

        .summary-ring {
            width: 140px;
            height: 140px;
        }

        .hero-chip {
            min-width: 100%;
        }

        .stlx-kpis,
        .stlx-insights,
        .drill-mini-kpis {
            grid-template-columns: 1fr;
        }

        .compare-row {
            flex-direction: column;
            align-items: flex-start;
