    private async Task LoadEmployeesAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var raw = await db.VwSalesOpportunities
            .AsNoTracking()
            .Where(o => o.EmployeeId != null && o.EmployeeName != null)
            .GroupBy(o => new { o.EmployeeId, o.EmployeeName })
            .Select(g => new
            {
                Id = g.Key.EmployeeId!.Value,
                Name = g.Key.EmployeeName!
            })
            .OrderBy(x => x.Name)
            .ToListAsync();

        _employees = raw
            .Select(x => new EmployeeItem
            {
                Id = x.Id,
                Name = x.Name
            })
            .ToList();
    }

    private async Task ResetFiltersAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);
        _toDate = DateTime.Today;
        _empId = null;
        _selectedMonthKey = null;
        await LoadData();
    }

    private async Task SetLastMonthsAsync(int months)
    {
        if (months <= 0) months = 12;

        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-(months - 1));
        _toDate = DateTime.Today;
        _selectedMonthKey = null;

        await LoadData();
    }

    private async Task SetCurrentYearAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _selectedMonthKey = null;

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentRows = await LoadPeriodRowsAsync(db, _fromDate, _toDate);

            if (TryGetPreviousRange(out var prevFrom, out var prevTo))
            {
                _previousPeriodLabel = $"{prevFrom.ToString("dd MMM yyyy", _arCulture)} — {prevTo.ToString("dd MMM yyyy", _arCulture)}";
                var previousRows = await LoadPeriodRowsAsync(db, prevFrom, prevTo);
                CalculatePreviousMetrics(previousRows);
            }
            else
            {
                _previousPeriodLabel = "غير متاح";
                ResetPreviousMetrics();
            }

            CalculateCurrentMetrics(_currentRows);
            BuildMonthlyData(_currentRows);
            BuildEmployeeData(_currentRows);
            ResolveSelectedMonth();
            BuildSelectedMonthAnalytics(_currentRows);
            BuildInsights();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<List<OpportunitySourceRow>> LoadPeriodRowsAsync(db24804Context db, DateTime? from, DateTime? to)
    {
        var query = db.VwSalesOpportunities
            .AsNoTracking()
            .Where(o => o.IsActive == true);

        if (from.HasValue)
        {
            var fromDate = from.Value.Date;
            query = query.Where(o => o.CreatedAt >= fromDate);
        }

        if (to.HasValue)
        {
            var toExclusive = to.Value.Date.AddDays(1);
            query = query.Where(o => o.CreatedAt < toExclusive);
        }

        if (_empId.HasValue)
        {
            query = query.Where(o => o.EmployeeId == _empId.Value);
        }

        return await query
            .Select(o => new OpportunitySourceRow
            {
                CreatedAt = o.CreatedAt,
                StageId = o.StageId,
                EmployeeName = o.EmployeeName
            })
            .ToListAsync();
    }

    private void CalculateCurrentMetrics(List<OpportunitySourceRow> rows)
    {
        _totalOpps = rows.Count;
        _wonCount = rows.Count(x => IsWon(x.StageId));
        _lostCount = rows.Count(x => IsLost(x.StageId));
        _openCount = rows.Count - _wonCount - _lostCount;
        _winRate = CalculateRate(_totalOpps, _wonCount);
    }

    private void CalculatePreviousMetrics(List<OpportunitySourceRow> rows)
    {
        _prevTotalOpps = rows.Count;
        _prevWonCount = rows.Count(x => IsWon(x.StageId));
        _prevLostCount = rows.Count(x => IsLost(x.StageId));
        _prevOpenCount = rows.Count - _prevWonCount - _prevLostCount;
        _prevWinRate = CalculateRate(_prevTotalOpps, _prevWonCount);
    }

    private void ResetPreviousMetrics()
    {
        _prevTotalOpps = 0;
        _prevWonCount = 0;
        _prevLostCount = 0;
        _prevOpenCount = 0;
        _prevWinRate = 0;
    }

    private void BuildMonthlyData(List<OpportunitySourceRow> rows)
    {
        var monthBuckets = new Dictionary<DateTime, MonthlyAggregate>();

        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        foreach (var row in rows)
        {
            var key = new DateTime(row.CreatedAt.Year, row.CreatedAt.Month, 1);

            if (!monthBuckets.TryGetValue(key, out var aggregate))
            {
                aggregate = new MonthlyAggregate();
                monthBuckets[key] = aggregate;
            }

            aggregate.Total++;

            if (IsWon(row.StageId))
                aggregate.Won++;
            else if (IsLost(row.StageId))
                aggregate.Lost++;
            else
                aggregate.Open++;
        }

        var list = new List<MonthlyWinRow>();

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthBuckets.TryGetValue(month, out var aggregate);
            aggregate ??= new MonthlyAggregate();

            list.Add(new MonthlyWinRow
            {
                Year = month.Year,
                MonthNum = month.Month,
                Month = month.ToString("MMM yyyy", _arCulture),
                Total = aggregate.Total,
                Won = aggregate.Won,
                Lost = aggregate.Lost,
                Open = aggregate.Open,
                WinRate = CalculateRate(aggregate.Total, aggregate.Won)
            });
        }

        _monthlyRows = list
            .OrderByDescending(x => x.Year)
            .ThenByDescending(x => x.MonthNum)
            .ToList();

        _monthlyChartPoints = list
            .OrderBy(x => x.Year)
            .ThenBy(x => x.MonthNum)
            .Select(x => new MonthlyChartPoint
            {
                Month = x.Month,
                Total = x.Total,
                Won = x.Won,
                Lost = x.Lost
            })
            .ToList();
    }

    private void BuildEmployeeData(List<OpportunitySourceRow> rows)
    {
        var grouped = rows
            .GroupBy(x => string.IsNullOrWhiteSpace(x.EmployeeName) ? "غير محدد" : x.EmployeeName!)
            .Select(g =>
            {
                var total = g.Count();
                var won = g.Count(x => IsWon(x.StageId));
                var lost = g.Count(x => IsLost(x.StageId));
                var open = total - won - lost;

                return new EmployeeWinRow
                {
                    Employee = g.Key,
                    Total = total,
                    Won = won,
                    Lost = lost,
                    Open = open,
                    WinRate = CalculateRate(total, won),
                    IsTotal = false
                };
            })
            .OrderByDescending(x => x.WinRate)
            .ThenByDescending(x => x.Won)
            .ThenByDescending(x => x.Total)
            .ToList();

        _employeeRows = grouped.ToList();

        _employeeRows.Add(new EmployeeWinRow
        {
            Employee = "الإجمالي",
            Total = _totalOpps,
            Won = _wonCount,
            Lost = _lostCount,
            Open = _openCount,
            WinRate = _winRate,
            IsTotal = true
        });

        var rankedSource = grouped.Where(x => x.Total >= 3).ToList();
        if (!rankedSource.Any())
            rankedSource = grouped.Where(x => x.Total > 0).ToList();

        _employeeRateChartPoints = rankedSource
            .OrderByDescending(x => x.WinRate)
            .ThenByDescending(x => x.Won)
            .ThenByDescending(x => x.Total)
            .Take(8)
            .Select(x => new EmployeeRateChartPoint
            {
                Employee = x.Employee,
                WinRate = (decimal)x.WinRate
            })
            .ToList();
    }

    private void ResolveSelectedMonth()
    {
        if (_monthlyRows.Count == 0)
        {
            _selectedMonthKey = null;
            return;
        }

        if (_selectedMonthKey.HasValue)
        {
            var selected = new DateTime(_selectedMonthKey.Value.Year, _selectedMonthKey.Value.Month, 1);
            var exists = _monthlyRows.Any(x => x.Year == selected.Year && x.MonthNum == selected.Month);

            if (exists)
            {
                _selectedMonthKey = selected;
                return;
            }
        }

        var latestWithData = _monthlyRows
            .Where(x => x.Total > 0)
            .OrderByDescending(x => x.Year)
            .ThenByDescending(x => x.MonthNum)
            .FirstOrDefault();

        if (latestWithData != null)
        {
            _selectedMonthKey = new DateTime(latestWithData.Year, latestWithData.MonthNum, 1);
        }
        else
        {
            var latestAny = _monthlyRows
                .OrderByDescending(x => x.Year)
                .ThenByDescending(x => x.MonthNum)
                .First();

            _selectedMonthKey = new DateTime(latestAny.Year, latestAny.MonthNum, 1);
        }
    }

    private void BuildSelectedMonthAnalytics(List<OpportunitySourceRow> rows)
    {
        _selectedMonthDailyPoints = new();
        _selectedMonthEmployeeRatePoints = new();
        _selectedMonthLabel = "—";
        _selectedMonthTotal = 0;
        _selectedMonthWon = 0;
        _selectedMonthLost = 0;
        _selectedMonthOpen = 0;
        _selectedMonthWinRate = 0;

        if (!_selectedMonthKey.HasValue)
            return;

        var month = _selectedMonthKey.Value;
        _selectedMonthLabel = month.ToString("MMMM yyyy", _arCulture);

        var monthRows = rows
            .Where(x => x.CreatedAt.Year == month.Year && x.CreatedAt.Month == month.Month)
            .ToList();

        _selectedMonthTotal = monthRows.Count;
        _selectedMonthWon = monthRows.Count(x => IsWon(x.StageId));
        _selectedMonthLost = monthRows.Count(x => IsLost(x.StageId));
        _selectedMonthOpen = monthRows.Count - _selectedMonthWon - _selectedMonthLost;
        _selectedMonthWinRate = CalculateRate(_selectedMonthTotal, _selectedMonthWon);

        var days = DateTime.DaysInMonth(month.Year, month.Month);
        var dailyMap = monthRows
            .GroupBy(x => x.CreatedAt.Day)
            .ToDictionary(
                g => g.Key,
                g => new DailyAggregate
                {
                    Total = g.Count(),
                    Won = g.Count(x => IsWon(x.StageId))
                });

        for (var day = 1; day <= days; day++)
        {
            dailyMap.TryGetValue(day, out var aggregate);
            aggregate ??= new DailyAggregate();

            _selectedMonthDailyPoints.Add(new DailyChartPoint
            {
                Day = day.ToString(),
                Total = aggregate.Total,
                Won = aggregate.Won
            });
        }

        var grouped = monthRows
            .GroupBy(x => string.IsNullOrWhiteSpace(x.EmployeeName) ? "غير محدد" : x.EmployeeName!)
            .Select(g =>
            {
                var total = g.Count();
                var won = g.Count(x => IsWon(x.StageId));

                return new EmployeeWinRow
                {
                    Employee = g.Key,
                    Total = total,
                    Won = won,
                    Lost = g.Count(x => IsLost(x.StageId)),
                    Open = total - won - g.Count(x => IsLost(x.StageId)),
                    WinRate = CalculateRate(total, won),
                    IsTotal = false
                };
            })
            .ToList();

        var rankedSource = grouped.Where(x => x.Total >= 2).ToList();
        if (!rankedSource.Any())
            rankedSource = grouped.Where(x => x.Total > 0).ToList();

        _selectedMonthEmployeeRatePoints = rankedSource
            .OrderByDescending(x => x.WinRate)
            .ThenByDescending(x => x.Won)
            .ThenByDescending(x => x.Total)
            .Take(8)
            .Select(x => new EmployeeRateChartPoint
            {
                Employee = x.Employee,
                WinRate = (decimal)x.WinRate
            })
            .ToList();
    }

    private void BuildInsights()
    {
        _insights = new List<InsightItem>();

        var validMonths = _monthlyRows.Where(x => x.Total > 0).ToList();
        if (validMonths.Any())
        {
            var bestRateMonth = validMonths
                .OrderByDescending(x => x.WinRate)
                .ThenByDescending(x => x.Won)
                .First();

            var worstLossMonth = validMonths
                .OrderByDescending(x => x.Lost)
                .ThenByDescending(x => x.Total)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.TrendingUp,
                Title = "أفضل شهر إغلاقًا",
                Value = bestRateMonth.Month,
                Description = $"{bestRateMonth.WinRate:F1}% — تم البيع {bestRateMonth.Won} من {bestRateMonth.Total}",
                ToneClass = "tone-green"
            });

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.WarningAmber,
                Title = "أعلى خسارة شهرية",
                Value = worstLossMonth.Month,
                Description = $"عدد الخسائر {worstLossMonth.Lost}",
                ToneClass = "tone-red"
            });
        }

        var employeeCandidates = _employeeRows.Where(x => !x.IsTotal).ToList();
        if (employeeCandidates.Any())
        {
            var rankedSource = employeeCandidates.Where(x => x.Total >= 3).ToList();
            if (!rankedSource.Any())
                rankedSource = employeeCandidates.Where(x => x.Total > 0).ToList();

            if (rankedSource.Any())
            {
                var topEmployee = rankedSource
                    .OrderByDescending(x => x.WinRate)
                    .ThenByDescending(x => x.Won)
                    .ThenByDescending(x => x.Total)
                    .First();

                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.Person,
                    Title = "أفضل موظف",
                    Value = topEmployee.Employee,
                    Description = $"{topEmployee.WinRate:F1}% — تم البيع {topEmployee.Won} من {topEmployee.Total}",
                    ToneClass = "tone-indigo"
                });
            }
        }

        var delta = _winRate - _prevWinRate;
        _insights.Add(new InsightItem
        {
            Icon = delta >= 0 ? Icons.Material.Rounded.Insights : Icons.Material.Rounded.ReportProblem,
            Title = "مقارنة بالفترة السابقة",
            Value = $"{(delta >= 0 ? "+" : "")}{delta:F1} نقطة",
            Description = delta >= 0 ? "تحسن في معدل الإغلاق" : "تراجع في معدل الإغلاق",
            ToneClass = delta >= 0 ? "tone-gold" : "tone-slate"
        });

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private void SelectMonth(int year, int month)
    {
        _selectedMonthKey = new DateTime(year, month, 1);
        BuildSelectedMonthAnalytics(_currentRows);
    }

    private void ClearSelectedMonth()
    {
        _selectedMonthKey = null;
        BuildSelectedMonthAnalytics(_currentRows);
    }

    private bool IsSelectedMonth(int year, int month)
        => _selectedMonthKey.HasValue
           && _selectedMonthKey.Value.Year == year
           && _selectedMonthKey.Value.Month == month;

    private bool TryGetPreviousRange(out DateTime previousFrom, out DateTime previousTo)
    {
        previousFrom = default;
        previousTo = default;

        if (!_fromDate.HasValue || !_toDate.HasValue)
            return false;

        var currentFrom = _fromDate.Value.Date;
        var currentTo = _toDate.Value.Date;

        var days = (currentTo - currentFrom).Days;
        previousTo = currentFrom.AddDays(-1);
        previousFrom = previousTo.AddDays(-days);

        return true;
    }

    private void NormalizeDateRange()
    {
        if (_fromDate.HasValue && _toDate.HasValue && _fromDate.Value.Date > _toDate.Value.Date)
        {
            var temp = _fromDate;
            _fromDate = _toDate;
            _toDate = temp;

            Snackbar.Add("تم تبديل تاريخ البداية والنهاية تلقائيًا لأن البداية كانت أكبر من النهاية.", Severity.Info);
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("تقرير معدل إغلاق الصفقات");
            sb.AppendLine($"الفترة الحالية,{SelectedPeriodLabel}");
            sb.AppendLine($"الفترة السابقة,{PreviousPeriodLabel}");
            sb.AppendLine($"الموظف,{SelectedEmployeeLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"إجمالي الفرص,{_totalOpps}");
            sb.AppendLine($"تم البيع,{_wonCount}");
            sb.AppendLine($"خسارة,{_lostCount}");
            sb.AppendLine($"قيد التنفيذ,{_openCount}");
            sb.AppendLine($"معدل الإغلاق,{_winRate:F1}%");
            sb.AppendLine();

            sb.AppendLine("الملخص الشهري");
            sb.AppendLine("الشهر,الإجمالي,تم البيع,خسارة,قيد التنفيذ,معدل الإغلاق");
            foreach (var row in _monthlyRows.OrderBy(x => x.Year).ThenBy(x => x.MonthNum))
            {
                sb.AppendLine($"{row.Month},{row.Total},{row.Won},{row.Lost},{row.Open},{row.WinRate:F1}%");
            }

            sb.AppendLine();
            sb.AppendLine("تفاصيل حسب الموظف");
            sb.AppendLine("الموظف,الإجمالي,تم البيع,خسارة,قيد التنفيذ,معدل الإغلاق");
            foreach (var row in _employeeRows)
            {
                sb.AppendLine($"{row.Employee},{row.Total},{row.Won},{row.Lost},{row.Open},{row.WinRate:F1}%");
            }

            var csv = sb.ToString();
            var fileName = $"win-rate-report-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

