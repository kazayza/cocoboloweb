<style>
    .winx-page {
        --text: #0f172a;
        --muted: #64748b;
        --line: rgba(148, 163, 184, .16);
        --glass: rgba(255,255,255,.72);
        --shadow: 0 20px 50px rgba(15, 23, 42, .06);

        max-width: 1460px;
        margin: 0 auto;
        padding: 1.25rem 1.25rem 3rem;
        position: relative;
        min-height: 100vh;
    }

    .winx-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .winx-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: .16;
    }

    .orb-1 {
        width: 420px;
        height: 420px;
        background: #6366f1;
        top: -120px;
        right: -120px;
        animation: winxFloat 12s ease-in-out infinite;
    }

    .orb-2 {
        width: 360px;
        height: 360px;
        background: #10b981;
        bottom: -80px;
        left: -80px;
        animation: winxFloat 18s ease-in-out infinite reverse;
    }

    .orb-3 {
        width: 280px;
        height: 280px;
        background: #f59e0b;
        top: 30%;
        left: 45%;
        animation: winxFloat 16s ease-in-out infinite;
    }

    @@keyframes winxFloat {
        0%,100% { transform: translate(0,0) scale(1); }
        50% { transform: translate(20px,-20px) scale(1.08); }
    }

    .glass-card {
        position: relative;
        z-index: 1;
        background: var(--glass);
        backdrop-filter: blur(20px) saturate(1.5);
        -webkit-backdrop-filter: blur(20px) saturate(1.5);
        border: 1px solid rgba(255,255,255,.48);
        box-shadow: var(--shadow);
        border-radius: 1.35rem;
    }

    .glass-inner-card {
        background: rgba(255,255,255,.45);
        border: 1px solid rgba(255,255,255,.4);
        border-radius: 1.2rem;
        padding: 1rem;
    }

    /* HERO */
    .winx-hero {
        position: relative;
        overflow: hidden;
        border-radius: 1.8rem;
        margin-bottom: 1.25rem;
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 45%, #4338ca 100%);
        padding: 2rem;
        color: #fff;
        z-index: 1;
    }

    .winx-hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
        background-size: 50px 50px;
        mask-image: radial-gradient(circle at center, black 45%, transparent 100%);
        pointer-events: none;
    }

    .winx-hero-content {
        position: relative;
        z-index: 2;
    }

    .winx-hero-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .winx-back {
        width: 2.6rem;
        height: 2.6rem;
        border: 1px solid rgba(255,255,255,.18);
        background: rgba(255,255,255,.08);
        color: #fff;
        border-radius: .9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: .25s ease;
        backdrop-filter: blur(10px);
    }

    .winx-back:hover {
        transform: translateX(-3px);
        background: rgba(255,255,255,.15);
    }

    .winx-badge {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .45rem .9rem;
        border-radius: 999px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.16);
        color: #dbeafe;
        font-size: .8rem;
        font-weight: 700;
    }

    .badge-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #93c5fd;
        box-shadow: 0 0 12px #93c5fd;
        animation: badgePulse 2s infinite;
    }

    @@keyframes badgePulse {
        0%,100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.35); opacity: .6; }
    }

    .winx-hero-main {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .winx-hero-text {
