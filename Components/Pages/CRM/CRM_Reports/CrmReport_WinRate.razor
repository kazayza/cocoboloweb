@page "/crm/reports/win-rate"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير معدل إغلاق الصفقات</PageTitle>

<div class="winx-page" dir="rtl">

    @* Background *@
    <div class="winx-bg">
        <div class="winx-orb orb-1"></div>
        <div class="winx-orb orb-2"></div>
        <div class="winx-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="winx-hero">
        <div class="winx-hero-grid"></div>

        <div class="winx-hero-content">
            <div class="winx-hero-top">
                <button class="winx-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="winx-badge">
                    <span class="badge-dot"></span>
                    <span>Win Rate Intelligence</span>
                </div>
            </div>

            <div class="winx-hero-main">
                <div class="winx-hero-text">
                    <h1>معدل <span>إغلاق</span> الصفقات</h1>
                    <p>
                        لوحة تنفيذية متقدمة لتحليل فرص البيع، معدلات الفوز والخسارة،
                        مقارنة الأداء بين الفترات والموظفين، مع Drill-down شهري ويومي احترافي.
                    </p>

                    <div class="winx-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الموظف</span>
                            <span class="chip-value">@SelectedEmployeeLabel</span>
                        </div>
                    </div>
                </div>

                <div class="winx-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_winRate.ToString("F1")%</div>
                            <div class="summary-caption">معدل الإغلاق</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card winx-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية والموظف أو استخدم الفلاتر السريعة</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudSelect T="int?"
                       @bind-Value="_empId"
                       Label="الموظف"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Class="filter-field">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem T="int?" Value="@((int?)emp.Id)">@emp.Name</MudSelectItem>
                }
            </MudSelect>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card winx-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل التقرير...</h3>
                <p>يتم تجهيز المؤشرات، الرسوم البيانية، والمقارنات الذكية</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="winx-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">#</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي الفرص</div>
                        <span class="trend-badge @GetTrendClass(_totalOpps, _prevTotalOpps)">
                            @GetTrendText(_totalOpps, _prevTotalOpps)
                        </span>
                    </div>
                    <div class="kpi-value">@_totalOpps.ToString("N0")</div>
                    <div class="kpi-sub">عدد الفرص خلال الفترة الحالية</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon green">✓</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">تم البيع</div>
                        <span class="trend-badge @GetTrendClass(_wonCount, _prevWonCount)">
                            @GetTrendText(_wonCount, _prevWonCount)
                        </span>
                    </div>
                    <div class="kpi-value success">@_wonCount.ToString("N0")</div>
                    <div class="kpi-sub">الفرص المغلقة بنجاح</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon red">✕</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">خسارة</div>
                        <span class="trend-badge @GetTrendClass(_lostCount, _prevLostCount)">
                            @GetTrendText(_lostCount, _prevLostCount)
                        </span>
                    </div>
                    <div class="kpi-value danger">@_lostCount.ToString("N0")</div>
                    <div class="kpi-sub">الفرص التي انتهت بخسارة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon slate">…</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">قيد التنفيذ</div>
                        <span class="trend-badge @GetTrendClass(_openCount, _prevOpenCount)">
                            @GetTrendText(_openCount, _prevOpenCount)
                        </span>
                    </div>
                    <div class="kpi-value">@_openCount.ToString("N0")</div>
                    <div class="kpi-sub">الفرص غير المحسومة حتى الآن</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">%</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">معدل الإغلاق</div>
                        <span class="trend-badge @GetTrendClass(_winRate, _prevWinRate)">
                            @GetTrendText(_winRate, _prevWinRate)
                        </span>
                    </div>
                    <div class="kpi-value">@_winRate.ToString("F1")%</div>
                    <div class="kpi-progress">
                        <div class="kpi-progress-bar" style="@GetProgressBarStyle()"></div>
                    </div>
                    <div class="kpi-sub">تم البيع ÷ إجمالي الفرص × 100</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="winx-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* DASHBOARD *@
        <section class="winx-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>الاتجاه الشهري للفرص</h3>
                        <p>إجمالي الفرص مقابل الفرص الرابحة والخاسرة على مستوى الشهور</p>
                    </div>
                </div>

                @if (_monthlyChartPoints.Any())
                {
                    <ApexChart TItem="MonthlyChartPoint"
                               Options="_monthlyChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="MonthlyChartPoint"
                                         Items="@_monthlyChartPoints"
                                         Name="إجمالي الفرص"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.Total" />

                        <ApexPointSeries TItem="MonthlyChartPoint"
                                         Items="@_monthlyChartPoints"
                                         Name="تم البيع"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.Won" />

                        <ApexPointSeries TItem="MonthlyChartPoint"
                                         Items="@_monthlyChartPoints"
                                         Name="خسارة"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Month"
                                         YValue="x => x.Lost" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>معدل الإغلاق حسب الموظف</h3>
                            <p>ترتيب الموظفين حسب معدل الفوز</p>
                        </div>
                    </div>

                    @if (_employeeRateChartPoints.Any())
                    {
                        <ApexChart TItem="EmployeeRateChartPoint"
                                   Options="_employeeRateChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="EmployeeRateChartPoint"
                                             Items="@_employeeRateChartPoints"
                                             Name="معدل الإغلاق %"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Employee"
                                             YValue="x => x.WinRate" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض أداء الموظفين</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">إجمالي الفرص</div>
                            <div class="compare-values">
                                <span>@_prevTotalOpps</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_totalOpps</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">تم البيع</div>
                            <div class="compare-values">
                                <span>@_prevWonCount</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_wonCount</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">خسارة</div>
                            <div class="compare-values">
                                <span>@_prevLostCount</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_lostCount</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">معدل الإغلاق</div>
                            <div class="compare-values">
                                <span>@_prevWinRate.ToString("F1")%</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_winRate.ToString("F1")%</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @(_winRate >= _prevWinRate ? "compare-good" : "compare-bad")">
                        @if (_winRate >= _prevWinRate)
                        {
                            <span>الأداء الحالي أفضل أو مساوي للفترة السابقة</span>
                        }
                        else
                        {
                            <span>الأداء الحالي أقل من الفترة السابقة ويحتاج تحسين</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* DRILL DOWN *@
        <section class="glass-card winx-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down شهري</h3>
                    <p>اختر شهرًا لعرض التحليل اليومي وأداء الموظفين داخله</p>
                </div>

                @if (_selectedMonthKey.HasValue)
                {
                    <button class="clear-month-btn" @onclick="ClearSelectedMonth">
                        إلغاء اختيار الشهر
                    </button>
                }
            </div>

            <div class="month-chip-row">
                @foreach (var month in _monthlyRows.OrderBy(x => x.Year).ThenBy(x => x.MonthNum))
                {
                    <button class="month-chip-btn @(IsSelectedMonth(month.Year, month.MonthNum) ? "month-chip-active" : "")"
                            @onclick="() => SelectMonth(month.Year, month.MonthNum)">
                        <span>@month.Month</span>
                        <small>@month.WinRate.ToString("F0")%</small>
                    </button>
                }
            </div>

            @if (_selectedMonthKey.HasValue)
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">الشهر المحدد</span>
                        <strong>@_selectedMonthLabel</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">إجمالي الفرص</span>
                        <strong>@_selectedMonthTotal</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">تم البيع</span>
                        <strong>@_selectedMonthWon</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">خسارة</span>
                        <strong>@_selectedMonthLost</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">قيد التنفيذ</span>
                        <strong>@_selectedMonthOpen</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">معدل الإغلاق</span>
                        <strong>@_selectedMonthWinRate.ToString("F1")%</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>التحليل اليومي — @_selectedMonthLabel</h3>
                                <p>إجمالي الفرص مقابل الفرص الرابحة على مستوى الأيام</p>
                            </div>
                        </div>

                        @if (_selectedMonthDailyPoints.Any())
                        {
                            <ApexChart TItem="DailyChartPoint"
                                       Options="_dailyChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="DailyChartPoint"
                                                 Items="@_selectedMonthDailyPoints"
                                                 Name="إجمالي الفرص"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Day"
                                                 YValue="x => x.Total" />

                                <ApexPointSeries TItem="DailyChartPoint"
                                                 Items="@_selectedMonthDailyPoints"
                                                 Name="تم البيع"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="x => x.Day"
                                                 YValue="x => x.Won" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات يومية للشهر المحدد</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>معدل الإغلاق للموظفين — @_selectedMonthLabel</h3>
                                <p>أفضل الموظفين داخل الشهر المحدد</p>
                            </div>
                        </div>

                        @if (_selectedMonthEmployeeRatePoints.Any())
                        {
                            <ApexChart TItem="EmployeeRateChartPoint"
                                       Options="_selectedMonthEmployeeRateChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="EmployeeRateChartPoint"
                                                 Items="@_selectedMonthEmployeeRatePoints"
                                                 Name="معدل الإغلاق %"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Employee"
                                                 YValue="x => x.WinRate" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات كافية لعرض الموظفين داخل هذا الشهر</div>
                        }
                    </div>
                </div>
            }
        </section>

        @* EMPLOYEE TABLE *@
        <section class="glass-card winx-table-card">
            <div class="card-head">
                <div>
                    <h3>تفاصيل حسب الموظف</h3>
                    <p>عرض تفصيلي لمعدلات الإغلاق وحالات الفرص لكل موظف</p>
                </div>
            </div>

            <MudTable Items="@_employeeRows"
                      Hover="true"
                      Dense="true"
                      Elevation="0"
                      RowsPerPage="10"
                      Breakpoint="Breakpoint.Sm"
                      Class="premium-table">
                <HeaderContent>
                    <MudTh>الموظف</MudTh>
                    <MudTh>الإجمالي</MudTh>
                    <MudTh>تم البيع</MudTh>
                    <MudTh>خسارة</MudTh>
                    <MudTh>قيد التنفيذ</MudTh>
                    <MudTh>معدل الإغلاق</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="الموظف">
                        @if (context.IsTotal)
                        {
                            <strong>@context.Employee</strong>
                        }
                        else
                        {
                            @context.Employee
                        }
                    </MudTd>
                    <MudTd DataLabel="الإجمالي">@context.Total.ToString("N0")</MudTd>
                    <MudTd DataLabel="تم البيع">@context.Won.ToString("N0")</MudTd>
                    <MudTd DataLabel="خسارة">@context.Lost.ToString("N0")</MudTd>
                    <MudTd DataLabel="قيد التنفيذ">@context.Open.ToString("N0")</MudTd>
                    <MudTd DataLabel="معدل الإغلاق">
                        <span class="rate-pill @GetRatePillClass(context.WinRate)">
                            @context.WinRate.ToString("F1")%
                        </span>
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <div class="empty-data">
                        <div class="empty-icon">📉</div>
                        <h4>لا توجد بيانات</h4>
                        <p>لا توجد نتائج مطابقة للفلاتر الحالية</p>
                    </div>
                </NoRecordsContent>
            </MudTable>
        </section>

        @* NOTE *@
        <section class="glass-card winx-note">
            <div class="note-icon">ℹ️</div>
            <div class="note-body">
                <h4>ملاحظة تحليلية مهمة</h4>
                <p>
                    في هذا التقرير يتم اعتبار الفرصة <strong>مغلقة بنجاح</strong> عندما تكون
                    <strong>StageId = @WonStageId</strong>،
                    واعتبارها <strong>خسارة</strong> عندما تكون
                    <strong>StageId ضمن @string.Join(", ", LostStageIds)</strong>.
                    ويتم التحليل هنا على أساس <strong>CreatedAt</strong>.
                </p>
            </div>
        </section>
    }
</div>

@code {
    private const int WonStageId = 3;
    private static readonly int[] LostStageIds = new[] { 4, 5 };

    private readonly CultureInfo _arCulture = new("ar-EG");

    private DateTime? _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);
    private DateTime? _toDate = DateTime.Today;
    private int? _empId;
    private bool _isLoading;

    private List<EmployeeItem> _employees = new();
    private List<OpportunitySourceRow> _currentRows = new();

    private List<EmployeeWinRow> _employeeRows = new();
    private List<MonthlyWinRow> _monthlyRows = new();
    private List<MonthlyChartPoint> _monthlyChartPoints = new();
    private List<EmployeeRateChartPoint> _employeeRateChartPoints = new();
    private List<InsightItem> _insights = new();

    private int _totalOpps;
    private int _wonCount;
    private int _lostCount;
    private int _openCount;
    private double _winRate;

    private int _prevTotalOpps;
    private int _prevWonCount;
    private int _prevLostCount;
    private int _prevOpenCount;
    private double _prevWinRate;

    private string _previousPeriodLabel = "غير متاح";

    private DateTime? _selectedMonthKey;
    private string _selectedMonthLabel = "—";
    private int _selectedMonthTotal;
    private int _selectedMonthWon;
    private int _selectedMonthLost;
    private int _selectedMonthOpen;
    private double _selectedMonthWinRate;
    private List<DailyChartPoint> _selectedMonthDailyPoints = new();
    private List<EmployeeRateChartPoint> _selectedMonthEmployeeRatePoints = new();

    private ApexChartOptions<MonthlyChartPoint> _monthlyChartOptions = new();
    private ApexChartOptions<EmployeeRateChartPoint> _employeeRateChartOptions = new();
    private ApexChartOptions<DailyChartPoint> _dailyChartOptions = new();
    private ApexChartOptions<EmployeeRateChartPoint> _selectedMonthEmployeeRateChartOptions = new();

    private string SelectedEmployeeLabel =>
        _empId.HasValue
            ? _employees.FirstOrDefault(x => x.Id == _empId.Value)?.Name ?? "موظف محدد"
            : "كل الموظفين";

    private string SelectedPeriodLabel =>
        $"{(_fromDate.HasValue ? _fromDate.Value.ToString("dd MMM yyyy", _arCulture) : "البداية")} — {(_toDate.HasValue ? _toDate.Value.ToString("dd MMM yyyy", _arCulture) : "اليوم")}";

