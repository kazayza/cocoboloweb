@page "/crm/reports/source-roi"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير مصادر العملاء</PageTitle>

<div class="srcx-page" dir="rtl">

    @* Background *@
    <div class="srcx-bg">
        <div class="srcx-orb orb-1"></div>
        <div class="srcx-orb orb-2"></div>
        <div class="srcx-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="srcx-hero">
        <div class="srcx-hero-grid"></div>

        <div class="srcx-hero-content">
            <div class="srcx-hero-top">
                <button class="srcx-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="srcx-badge">
                    <span class="badge-dot"></span>
                    <span>Source Performance Intelligence</span>
                </div>
            </div>

            <div class="srcx-hero-main">
                <div class="srcx-hero-text">
                    <h1>مصادر <span>العملاء</span> وفعالية التحويل</h1>
                    <p>
                        لوحة تنفيذية لتحليل أداء مصادر العملاء من حيث حجم الفرص،
                        نسب الإغلاق، الإيرادات، وقيمة الـ Pipeline المفتوح، مع Drill-down تفصيلي لكل مصدر.
                    </p>

                    <div class="srcx-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">أفضل مصدر</span>
                            <span class="chip-value">@_bestSource</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">أعلى مصدر تحويلاً</span>
                            <span class="chip-value">@_topConversionSource</span>
                        </div>
                    </div>
                </div>

                <div class="srcx-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_bestSourceRevenueShare.ToString("F1")%</div>
                            <div class="summary-caption">مساهمة أفضل مصدر</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card srcx-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية أو استخدم الفترات السريعة لتحليل أداء المصادر</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card srcx-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل المصادر...</h3>
                <p>يتم تجهيز المؤشرات والرسوم البيانية وتحليل فعالية المصادر</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="srcx-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">◎</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">عدد المصادر النشطة</div>
                        <span class="trend-badge @GetTrendClass(_activeSourceCount, _prevActiveSourceCount)">
                            @GetTrendText(_activeSourceCount, _prevActiveSourceCount)
                        </span>
                    </div>
                    <div class="kpi-value">@_activeSourceCount.ToString("N0")</div>
                    <div class="kpi-sub">المصادر التي لديها فرص خلال الفترة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon blue">#</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي الفرص</div>
                        <span class="trend-badge @GetTrendClass(_totalOpps, _prevTotalOpps)">
                            @GetTrendText(_totalOpps, _prevTotalOpps)
                        </span>
                    </div>
                    <div class="kpi-value">@_totalOpps.ToString("N0")</div>
                    <div class="kpi-sub">كل الفرص القادمة من مختلف المصادر</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon green">₪</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي الإيرادات المحققة</div>
                        <span class="trend-badge @GetTrendClass(_totalRevenue, _prevTotalRevenue)">
                            @GetTrendText(_totalRevenue, _prevTotalRevenue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_totalRevenue)</div>
                    <div class="kpi-sub">من الصفقات الرابحة فقط</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon teal">💼</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">Pipeline مفتوح</div>
                        <span class="trend-badge @GetTrendClass(_openPipelineValue, _prevOpenPipelineValue)">
                            @GetTrendText(_openPipelineValue, _prevOpenPipelineValue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_openPipelineValue)</div>
                    <div class="kpi-sub">قيمة الفرص المفتوحة من جميع المصادر</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon purple">★</div>
                <div class="kpi-body">
                    <div class="kpi-label">أفضل مصدر</div>
                    <div class="kpi-value kpi-name">@_bestSource</div>
                    <div class="kpi-sub">@FormatMoney(_bestSourceRevenue) — @_bestSourceRevenueShare.ToString("F1")% من الإيراد</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">%</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">معدل الإغلاق الكلي</div>
                        <span class="trend-badge @GetTrendClass(_overallCloseRate, _prevOverallCloseRate)">
                            @GetTrendText(_overallCloseRate, _prevOverallCloseRate)
                        </span>
                    </div>
                    <div class="kpi-value">@_overallCloseRate.ToString("F1")%</div>
                    <div class="kpi-progress">
                        <div class="kpi-progress-bar" style="@GetCloseRateProgressStyle()"></div>
                    </div>
                    <div class="kpi-sub">تم البيع ÷ إجمالي الفرص × 100</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="srcx-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* MAIN DASHBOARD *@
        <section class="srcx-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>مقارنة أداء المصادر</h3>
                        <p>عدد الفرص مقابل الصفقات الرابحة والإيراد لكل مصدر</p>
                    </div>
                </div>

                @if (_sourceOverviewPoints.Any())
                {
                    <ApexChart TItem="SourceOverviewPoint"
                               Options="_sourceOverviewChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="SourceOverviewPoint"
                                         Items="@_sourceOverviewPoints"
                                         Name="الفرص"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Source"
                                         YValue="x => x.TotalCount" />

                        <ApexPointSeries TItem="SourceOverviewPoint"
                                         Items="@_sourceOverviewPoints"
                                         Name="المبيعات"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Source"
                                         YValue="x => x.WonCount" />

                        <ApexPointSeries TItem="SourceOverviewPoint"
                                         Items="@_sourceOverviewPoints"
                                         Name="الإيراد"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Source"
                                         YValue="x => x.Revenue" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>معدل الإغلاق حسب المصدر</h3>
                            <p>ترتيب المصادر حسب كفاءة التحويل إلى صفقات رابحة</p>
                        </div>
                    </div>

                    @if (_sourceRatePoints.Any())
                    {
                        <ApexChart TItem="SourceRatePoint"
                                   Options="_sourceRateChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="SourceRatePoint"
                                             Items="@_sourceRatePoints"
                                             Name="معدل الإغلاق %"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Source"
                                             YValue="x => x.CloseRate" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض معدلات الإغلاق</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">المصادر النشطة</div>
                            <div class="compare-values">
                                <span>@_prevActiveSourceCount</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_activeSourceCount</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">إجمالي الفرص</div>
                            <div class="compare-values">
                                <span>@_prevTotalOpps</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_totalOpps</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">الإيرادات</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevTotalRevenue)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_totalRevenue)</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">معدل الإغلاق</div>
                            <div class="compare-values">
                                <span>@_prevOverallCloseRate.ToString("F1")%</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_overallCloseRate.ToString("F1")%</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @((_overallCloseRate >= _prevOverallCloseRate && _totalRevenue >= _prevTotalRevenue) ? "compare-good" : "compare-mid")">
                        @if (_overallCloseRate >= _prevOverallCloseRate && _totalRevenue >= _prevTotalRevenue)
                        {
                            <span>أداء المصادر الحالي أفضل أو مساوي للفترة السابقة</span>
                        }
                        else
                        {
                            <span>بعض مؤشرات أداء المصادر تحتاج تحسين ومراجعة</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* ANALYTICS GRID *@
        <section class="srcx-analytics-grid">
            <div class="glass-card side-card">
                <div class="card-head">
                    <div>
                        <h3>الاتجاه الشهري للمصادر</h3>
                        <p>إجمالي الفرص والمبيعات والإيراد عبر الشهور</p>
                    </div>
                </div>

                @if (_overallMonthlyPoints.Any())
                {
                    <ApexChart TItem="SourceMonthlyPoint"
                               Options="_overallMonthlyChartOptions"
                               Height="320">
                        <ApexPointSeries TItem="SourceMonthlyPoint"
                                         Items="@_overallMonthlyPoints"
                                         Name="الفرص"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.TotalCount" />

                        <ApexPointSeries TItem="SourceMonthlyPoint"
                                         Items="@_overallMonthlyPoints"
                                         Name="المبيعات"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.WonCount" />

                        <ApexPointSeries TItem="SourceMonthlyPoint"
                                         Items="@_overallMonthlyPoints"
                                         Name="الإيراد"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Month"
                                         YValue="x => x.Revenue" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty small">لا توجد بيانات شهرية كافية</div>
                }
            </div>

            <div class="glass-card srcx-source-table-card">
                <div class="card-head">
                    <div>
                        <h3>تفاصيل المصادر</h3>
                        <p>ملخص كل مصدر من حيث الفرص والمبيعات والإيراد والمتوسط والنسبة</p>
                    </div>
                </div>

                <MudTable Items="@_sourceRows"
                          Hover="true"
                          Dense="true"
                          Elevation="0"
                          RowsPerPage="10"
                          Breakpoint="Breakpoint.Sm"
                          Class="premium-table">
                    <HeaderContent>
                        <MudTh>المصدر</MudTh>
                        <MudTh>الفرص</MudTh>
                        <MudTh>المبيعات</MudTh>
                        <MudTh>الخسائر</MudTh>
                        <MudTh>المفتوح</MudTh>
                        <MudTh>معدل الإغلاق</MudTh>
                        <MudTh>الإيراد</MudTh>
                        <MudTh>متوسط الصفقة</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="المصدر">
                            <span class="source-label @(context.IsBest ? "source-best" : "")">
                                @context.SourceName
                                @if (context.IsBest)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Star"
                                             Color="@MudColor.Warning"
                                             Size="@MudSize.Small" />
                                }
                            </span>
                        </MudTd>
                        <MudTd DataLabel="الفرص">@context.TotalCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="المبيعات">@context.WonCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="الخسائر">@context.LostCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="المفتوح">@context.OpenCount.ToString("N0")</MudTd>
                        <MudTd DataLabel="معدل الإغلاق">
                            <span class="rate-pill @GetCloseRatePillClass(context.CloseRate)">
                                @context.CloseRate.ToString("F1")%
                            </span>
                        </MudTd>
                        <MudTd DataLabel="الإيراد">@FormatMoney(context.TotalRevenue)</MudTd>
                        <MudTd DataLabel="متوسط الصفقة">@FormatMoney(context.AvgDealValue)</MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <div class="empty-data">
                            <div class="empty-icon">📉</div>
                            <h4>لا توجد بيانات</h4>
                            <p>لا توجد مصادر مطابقة للفترة الحالية</p>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </section>

        @* SOURCE DRILL-DOWN *@
        <section class="glass-card srcx-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down حسب المصدر</h3>
                    <p>اختر مصدرًا لعرض تحليله الشهري ومراحله وأكبر الفرص الناتجة منه</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(_selectedSource))
                {
                    <button class="clear-source-btn" @onclick="ClearSelectedSource">
                        إلغاء اختيار المصدر
                    </button>
                }
            </div>

            <div class="source-chip-row">
                @foreach (var source in _sourceRows)
                {
                    <button class="source-chip-btn @(IsSelectedSource(source.SourceName) ? "source-chip-active" : "")"
                            @onclick="() => SelectSource(source.SourceName)">
                        <span>@source.SourceName</span>
                        <small>@source.TotalCount.ToString("N0") فرصة</small>
                    </button>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(_selectedSource) || _detailRows.Any())
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">المصدر المحدد</span>
                        <strong>@_selectedSourceName</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الفرص</span>
                        <strong>@_selectedSourceTotalCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">المبيعات</span>
                        <strong>@_selectedSourceWonCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">المفتوح</span>
                        <strong>@_selectedSourceOpenCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الإيراد</span>
                        <strong>@FormatMoney(_selectedSourceRevenue)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">معدل الإغلاق</span>
                        <strong>@_selectedSourceCloseRate.ToString("F1")%</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أفضل شهر</span>
                        <strong>@_selectedSourceTopMonth</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>الاتجاه الشهري للمصدر</h3>
                                <p>الفرص والمبيعات والإيراد عبر الشهور للمصدر المحدد</p>
                            </div>
                        </div>

                        @if (_selectedSourceMonthlyPoints.Any())
                        {
                            <ApexChart TItem="SourceMonthlyPoint"
                                       Options="_selectedSourceMonthlyChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="SourceMonthlyPoint"
                                                 Items="@_selectedSourceMonthlyPoints"
                                                 Name="الفرص"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.TotalCount" />

                                <ApexPointSeries TItem="SourceMonthlyPoint"
                                                 Items="@_selectedSourceMonthlyPoints"
                                                 Name="المبيعات"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.WonCount" />

                                <ApexPointSeries TItem="SourceMonthlyPoint"
                                                 Items="@_selectedSourceMonthlyPoints"
                                                 Name="الإيراد"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="x => x.Month"
                                                 YValue="x => x.Revenue" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات شهرية كافية لهذا المصدر</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>المراحل داخل المصدر</h3>
                                <p>توزيع الفرص لهذا المصدر حسب المرحلة الحالية</p>
                            </div>
                        </div>

                        @if (_selectedSourceStagePoints.Any())
                        {
                            <ApexChart TItem="SourceStagePoint"
                                       Options="_selectedSourceStageChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="SourceStagePoint"
                                                 Items="@_selectedSourceStagePoints"
                                                 Name="عدد الفرص"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Stage"
                                                 YValue="x => x.Count" />
                            </ApexChart>
                        }
                        else
                        {
