    private async Task ResetFiltersAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);
        _toDate = DateTime.Today;
        _selectedSource = null;
        await LoadData();
    }

    private async Task SetLastMonthsAsync(int months)
    {
        if (months <= 0) months = 12;

        _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-(months - 1));
        _toDate = DateTime.Today;
        _selectedSource = null;

        await LoadData();
    }

    private async Task SetCurrentYearAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _selectedSource = null;

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentRows = await LoadPeriodRowsAsync(db, _fromDate, _toDate);

            if (TryGetPreviousRange(out var prevFrom, out var prevTo))
            {
                _previousPeriodLabel = $"{prevFrom.ToString("dd MMM yyyy", _arCulture)} — {prevTo.ToString("dd MMM yyyy", _arCulture)}";
                var previousRows = await LoadPeriodRowsAsync(db, prevFrom, prevTo);
                CalculatePreviousMetrics(previousRows);
            }
            else
            {
                _previousPeriodLabel = "غير متاح";
                ResetPreviousMetrics();
            }

            CalculateCurrentMetrics(_currentRows);
            BuildSourceSummary(_currentRows);
            BuildOverallMonthlyTrend(_currentRows);
            ResolveSelectedSource();
            BuildSelectedSourceAnalytics(_currentRows);
            BuildInsights();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<List<OpportunitySourceRow>> LoadPeriodRowsAsync(db24804Context db, DateTime? from, DateTime? to)
    {
        var query = db.VwSalesOpportunities
            .AsNoTracking()
            .Where(o => o.IsActive == true);

        if (from.HasValue)
        {
            var fromDate = from.Value.Date;
            query = query.Where(o => o.CreatedAt >= fromDate);
        }

        if (to.HasValue)
        {
            var toExclusive = to.Value.Date.AddDays(1);
            query = query.Where(o => o.CreatedAt < toExclusive);
        }

        return await query
            .Select(o => new OpportunitySourceRow
            {
                OpportunityId = o.OpportunityId,
                ClientName = o.ClientName ?? "—",
                EmployeeName = o.EmployeeName ?? "—",
                SourceName = string.IsNullOrWhiteSpace(o.SourceName) ? "غير محدد" : o.SourceName!,
                StageId = o.StageId,
                StageName = o.StageNameAr ?? o.StageName ?? "—",
                StageColor = o.StageColor ?? "",
                CreatedAt = o.CreatedAt,
                LastContactDate = o.LastContactDate,
                ExpectedValue = o.ExpectedValue ?? 0m,
                AgeDays = o.DaysSinceFirstContact ?? 0d
            })
            .ToListAsync();
    }

    private void CalculateCurrentMetrics(List<OpportunitySourceRow> rows)
    {
        _activeSourceCount = rows
            .Select(x => x.SourceName)
            .Distinct()
            .Count();

        _totalOpps = rows.Count;
        _wonCount = rows.Count(x => IsWon(x.StageId));
        _totalRevenue = rows.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
        _openPipelineValue = rows.Where(x => IsOpenStage(x.StageId)).Sum(x => x.ExpectedValue);
        _overallCloseRate = _totalOpps > 0 ? (double)_wonCount / _totalOpps * 100d : 0d;
        _avgWonDealValue = _wonCount > 0 ? _totalRevenue / _wonCount : 0m;
    }

    private void CalculatePreviousMetrics(List<OpportunitySourceRow> rows)
    {
        _prevActiveSourceCount = rows
            .Select(x => x.SourceName)
            .Distinct()
            .Count();

        _prevTotalOpps = rows.Count;
        _prevWonCount = rows.Count(x => IsWon(x.StageId));
        _prevTotalRevenue = rows.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
        _prevOpenPipelineValue = rows.Where(x => IsOpenStage(x.StageId)).Sum(x => x.ExpectedValue);
        _prevOverallCloseRate = _prevTotalOpps > 0 ? (double)_prevWonCount / _prevTotalOpps * 100d : 0d;
        _prevAvgWonDealValue = _prevWonCount > 0 ? _prevTotalRevenue / _prevWonCount : 0m;
    }

    private void ResetPreviousMetrics()
    {
        _prevActiveSourceCount = 0;
        _prevTotalOpps = 0;
        _prevWonCount = 0;
        _prevTotalRevenue = 0m;
        _prevOpenPipelineValue = 0m;
        _prevOverallCloseRate = 0d;
        _prevAvgWonDealValue = 0m;
    }

    private void BuildSourceSummary(List<OpportunitySourceRow> rows)
    {
        _sourceRows = rows
            .GroupBy(x => x.SourceName)
            .Select(g =>
            {
                var total = g.Count();
                var wonCount = g.Count(x => IsWon(x.StageId));
                var lostCount = g.Count(x => IsLost(x.StageId));
                var openCount = total - wonCount - lostCount;
                var revenue = g.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
                var openValue = g.Where(x => IsOpenStage(x.StageId)).Sum(x => x.ExpectedValue);

                return new SourceSummaryRow
                {
                    SourceName = g.Key,
                    TotalCount = total,
                    WonCount = wonCount,
                    LostCount = lostCount,
                    OpenCount = openCount,
                    CloseRate = total > 0 ? (double)wonCount / total * 100d : 0d,
                    TotalRevenue = revenue,
                    OpenValue = openValue,
                    AvgDealValue = wonCount > 0 ? revenue / wonCount : 0m,
                    RevenueShare = _totalRevenue > 0 ? (double)(revenue / _totalRevenue * 100m) : 0d
                };
            })
            .OrderByDescending(x => x.TotalRevenue)
            .ThenByDescending(x => x.TotalCount)
            .ToList();

        var bestByRevenue = _sourceRows.FirstOrDefault();
        if (bestByRevenue != null)
        {
            bestByRevenue.IsBest = true;
            _bestSource = bestByRevenue.SourceName;
            _bestSourceRevenue = bestByRevenue.TotalRevenue;
            _bestSourceRevenueShare = bestByRevenue.RevenueShare;
        }
        else
        {
            _bestSource = "—";
            _bestSourceRevenue = 0m;
            _bestSourceRevenueShare = 0d;
        }

        var rateCandidates = _sourceRows.Where(x => x.TotalCount >= 3).ToList();
        if (!rateCandidates.Any())
            rateCandidates = _sourceRows.Where(x => x.TotalCount > 0).ToList();

        var topRate = rateCandidates
            .OrderByDescending(x => x.CloseRate)
            .ThenByDescending(x => x.WonCount)
            .ThenByDescending(x => x.TotalRevenue)
            .FirstOrDefault();

        _topConversionSource = topRate?.SourceName ?? "—";
        _topConversionRate = topRate?.CloseRate ?? 0d;

        _sourceOverviewPoints = _sourceRows
            .OrderByDescending(x => x.TotalCount)
            .ThenByDescending(x => x.TotalRevenue)
            .Take(8)
            .Select(x => new SourceOverviewPoint
            {
                Source = x.SourceName,
                TotalCount = x.TotalCount,
                WonCount = x.WonCount,
                Revenue = x.TotalRevenue
            })
            .ToList();

        _sourceRatePoints = rateCandidates
            .OrderByDescending(x => x.CloseRate)
            .ThenByDescending(x => x.WonCount)
            .ThenByDescending(x => x.TotalCount)
            .Take(8)
            .Select(x => new SourceRatePoint
            {
                Source = x.SourceName,
                CloseRate = (decimal)x.CloseRate
            })
            .ToList();
    }

    private void BuildOverallMonthlyTrend(List<OpportunitySourceRow> rows)
    {
        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var monthMap = rows
            .GroupBy(x => new DateTime(x.CreatedAt.Year, x.CreatedAt.Month, 1))
            .ToDictionary(g => g.Key, g => g.ToList());

        _overallMonthlyPoints = new();

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthMap.TryGetValue(month, out var monthRows);
            monthRows ??= new List<OpportunitySourceRow>();

            _overallMonthlyPoints.Add(new SourceMonthlyPoint
            {
                Month = month.ToString("MMM yyyy", _arCulture),
                TotalCount = monthRows.Count,
                WonCount = monthRows.Count(x => IsWon(x.StageId)),
                Revenue = monthRows.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue)
            });
        }
    }

    private void ResolveSelectedSource()
    {
        if (!_sourceRows.Any())
        {
            _selectedSource = null;
            return;
        }

        if (!string.IsNullOrWhiteSpace(_selectedSource) && _sourceRows.Any(x => x.SourceName == _selectedSource))
            return;

        _selectedSource = _sourceRows.First().SourceName;
    }

    private void BuildSelectedSourceAnalytics(List<OpportunitySourceRow> rows)
    {
        _selectedSourceName = "—";
        _selectedSourceTotalCount = 0;
        _selectedSourceWonCount = 0;
        _selectedSourceOpenCount = 0;
        _selectedSourceLostCount = 0;
        _selectedSourceRevenue = 0m;
        _selectedSourceOpenValue = 0m;
        _selectedSourceCloseRate = 0d;
        _selectedSourceAvgDealValue = 0m;
        _selectedSourceTopMonth = "—";
        _selectedSourceTopEmployee = "—";
        _selectedSourceMonthlyPoints = new();
        _selectedSourceStagePoints = new();
        _detailRows = new();

        if (string.IsNullOrWhiteSpace(_selectedSource))
        {
            _detailRows = rows
                .OrderByDescending(x => x.ExpectedValue)
                .ThenByDescending(x => x.CreatedAt)
                .Take(25)
                .Select(MapDetailRow)
                .ToList();

            return;
        }

        var filtered = rows
            .Where(x => x.SourceName == _selectedSource)
            .ToList();

        if (!filtered.Any())
            return;

        _selectedSourceName = _selectedSource;
        _selectedSourceTotalCount = filtered.Count;
        _selectedSourceWonCount = filtered.Count(x => IsWon(x.StageId));
        _selectedSourceLostCount = filtered.Count(x => IsLost(x.StageId));
        _selectedSourceOpenCount = _selectedSourceTotalCount - _selectedSourceWonCount - _selectedSourceLostCount;
        _selectedSourceRevenue = filtered.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
        _selectedSourceOpenValue = filtered.Where(x => IsOpenStage(x.StageId)).Sum(x => x.ExpectedValue);
        _selectedSourceCloseRate = _selectedSourceTotalCount > 0 ? (double)_selectedSourceWonCount / _selectedSourceTotalCount * 100d : 0d;
        _selectedSourceAvgDealValue = _selectedSourceWonCount > 0 ? _selectedSourceRevenue / _selectedSourceWonCount : 0m;

        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var monthMap = filtered
            .GroupBy(x => new DateTime(x.CreatedAt.Year, x.CreatedAt.Month, 1))
            .ToDictionary(g => g.Key, g => g.ToList());

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthMap.TryGetValue(month, out var monthRows);
            monthRows ??= new List<OpportunitySourceRow>();

            _selectedSourceMonthlyPoints.Add(new SourceMonthlyPoint
            {
                Month = month.ToString("MMM yyyy", _arCulture),
                TotalCount = monthRows.Count,
                WonCount = monthRows.Count(x => IsWon(x.StageId)),
                Revenue = monthRows.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue)
            });
        }

        var topMonth = _selectedSourceMonthlyPoints
            .OrderByDescending(x => x.Revenue)
            .ThenByDescending(x => x.WonCount)
            .ThenByDescending(x => x.TotalCount)
            .FirstOrDefault();

        _selectedSourceTopMonth = topMonth?.Month ?? "—";

        var topEmployee = filtered
            .GroupBy(x => x.EmployeeName)
            .Select(g => new
            {
                Employee = g.Key,
                Total = g.Count(),
                Revenue = g.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.Revenue)
            .ThenByDescending(x => x.Total)
            .FirstOrDefault();

        _selectedSourceTopEmployee = topEmployee?.Employee ?? "—";

        _selectedSourceStagePoints = filtered
            .GroupBy(x => x.StageName)
            .Select(g => new SourceStagePoint
            {
                Stage = g.Key,
                Count = g.Count()
            })
            .OrderByDescending(x => x.Count)
            .ToList();

        _detailRows = filtered
            .OrderByDescending(x => x.ExpectedValue)
            .ThenByDescending(x => x.CreatedAt)
            .Select(MapDetailRow)
            .ToList();
    }

    private SourceOpportunityDetailRow MapDetailRow(OpportunitySourceRow x) => new()
    {
        OpportunityId = x.OpportunityId,
        ClientName = x.ClientName,
        EmployeeName = x.EmployeeName,
        StageId = x.StageId,
        StageName = x.StageName,
        StageColor = x.StageColor,
        CreatedAt = x.CreatedAt,
        LastContactDate = x.LastContactDate,
        AgeDays = x.AgeDays,
        ExpectedValue = x.ExpectedValue
    };

    private void BuildInsights()
    {
        _insights = new();

        if (_sourceRows.Any())
        {
            var topRevenue = _sourceRows
                .OrderByDescending(x => x.TotalRevenue)
                .ThenByDescending(x => x.TotalCount)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.AttachMoney,
                Title = "أعلى مصدر إيرادًا",
                Value = topRevenue.SourceName,
                Description = $"{FormatMoney(topRevenue.TotalRevenue)}",
                ToneClass = "tone-green"
            });

            var rateCandidates = _sourceRows.Where(x => x.TotalCount >= 3).ToList();
            if (!rateCandidates.Any())
                rateCandidates = _sourceRows.Where(x => x.TotalCount > 0).ToList();

            if (rateCandidates.Any())
            {
                var topRate = rateCandidates
                    .OrderByDescending(x => x.CloseRate)
                    .ThenByDescending(x => x.WonCount)
                    .First();

                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.TrendingUp,
                    Title = "أفضل معدل إغلاق",
                    Value = topRate.SourceName,
                    Description = $"{topRate.CloseRate:F1}% من {topRate.TotalCount} فرصة",
                    ToneClass = "tone-indigo"
                });

                var lowestRate = rateCandidates
                    .OrderBy(x => x.CloseRate)
                    .ThenByDescending(x => x.TotalCount)
                    .First();

                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.ReportProblem,
                    Title = "أضعف معدل إغلاق",
                    Value = lowestRate.SourceName,
                    Description = $"{lowestRate.CloseRate:F1}% من {lowestRate.TotalCount} فرصة",
                    ToneClass = "tone-red"
                });
            }

            var topOpen = _sourceRows
                .OrderByDescending(x => x.OpenValue)
                .ThenByDescending(x => x.OpenCount)
                .FirstOrDefault();

            if (topOpen != null)
            {
                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.HourglassTop,
                    Title = "أكبر Pipeline مفتوح",
                    Value = topOpen.SourceName,
                    Description = $"{FormatMoney(topOpen.OpenValue)}",
                    ToneClass = "tone-gold"
                });
            }
        }

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private void SelectSource(string sourceName)
    {
        _selectedSource = sourceName;
        BuildSelectedSourceAnalytics(_currentRows);
    }

    private void ClearSelectedSource()
    {
        _selectedSource = null;
        BuildSelectedSourceAnalytics(_currentRows);
    }

    private bool IsSelectedSource(string sourceName)
        => !string.IsNullOrWhiteSpace(_selectedSource) && _selectedSource == sourceName;

    private bool TryGetPreviousRange(out DateTime previousFrom, out DateTime previousTo)
    {
        previousFrom = default;
        previousTo = default;

        if (!_fromDate.HasValue || !_toDate.HasValue)
            return false;

        var currentFrom = _fromDate.Value.Date;
        var currentTo = _toDate.Value.Date;
        var days = (currentTo - currentFrom).Days;

        previousTo = currentFrom.AddDays(-1);
        previousFrom = previousTo.AddDays(-days);

        return true;
    }

    private void NormalizeDateRange()
    {
        if (_fromDate.HasValue && _toDate.HasValue && _fromDate.Value.Date > _toDate.Value.Date)
        {
            var temp = _fromDate;
            _fromDate = _toDate;
            _toDate = temp;

            Snackbar.Add("تم تبديل تاريخ البداية والنهاية تلقائيًا لأن البداية كانت أكبر من النهاية.", Severity.Info);
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("تقرير مصادر العملاء");
            sb.AppendLine($"الفترة الحالية,{SelectedPeriodLabel}");
            sb.AppendLine($"الفترة السابقة,{PreviousPeriodLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"عدد المصادر النشطة,{_activeSourceCount}");
            sb.AppendLine($"إجمالي الفرص,{_totalOpps}");
            sb.AppendLine($"المبيعات الرابحة,{_wonCount}");
            sb.AppendLine($"الإيرادات المحققة,{_totalRevenue:N0}");
            sb.AppendLine($"Pipeline المفتوح,{_openPipelineValue:N0}");
            sb.AppendLine($"معدل الإغلاق,{_overallCloseRate:F1}%");
            sb.AppendLine($"أفضل مصدر,{_bestSource}");
            sb.AppendLine($"أعلى مصدر تحويلاً,{_topConversionSource}");
            sb.AppendLine();

            sb.AppendLine("تفاصيل المصادر");
            sb.AppendLine("المصدر,الفرص,المبيعات,الخسائر,المفتوح,معدل الإغلاق,الإيراد,متوسط الصفقة");
            foreach (var row in _sourceRows)
            {
                sb.AppendLine($"{row.SourceName},{row.TotalCount},{row.WonCount},{row.LostCount},{row.OpenCount},{row.CloseRate:F1}%,{row.TotalRevenue:N0},{row.AvgDealValue:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("الاتجاه الشهري");
            sb.AppendLine("الشهر,الفرص,المبيعات,الإيراد");
            foreach (var row in _overallMonthlyPoints)
            {
                sb.AppendLine($"{row.Month},{row.TotalCount},{row.WonCount},{row.Revenue:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("تفاصيل الفرص");
            sb.AppendLine("العميل,الموظف,المرحلة,الحالة,تاريخ الإنشاء,آخر تواصل,العمر,القيمة");
            foreach (var row in _detailRows)
            {
                sb.AppendLine($"{row.ClientName},{row.EmployeeName},{row.StageName},{GetStatusLabel(row.StageId)},{FormatDate(row.CreatedAt)},{FormatDate(row.LastContactDate)},{row.AgeDays:F0},{row.ExpectedValue:N0}");
            }

            var csv = sb.ToString();
            var fileName = $"source-performance-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

    private async Task PrintAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "window.print()");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تشغيل الطباعة: {ex.Message}", Severity.Error);
        }
    }

    private bool IsWon(int stageId) => stageId == WonStageId;
    private bool IsLost(int stageId) => stageId == LostStageId1 || stageId == LostStageId2;
    private bool IsOpenStage(int stageId) => !IsWon(stageId) && !IsLost(stageId);

    private string FormatMoney(decimal value) => $"{value:N0} ج.م";
    private string FormatDate(DateTime? value) => value?.ToString("yyyy/MM/dd") ?? "—";

    private string GetStagePillStyle(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
            return "background:#e5e7eb;color:#111827;";

        return $"background:{color};color:#fff;";
    }

    private string GetStatusLabel(int stageId)
    {
        if (IsWon(stageId)) return "تم البيع";
        if (IsLost(stageId)) return "خسارة";
        return "مفتوح";
    }

    private string GetStatusPillClass(int stageId)
    {
        if (IsWon(stageId)) return "rate-good";
        if (IsLost(stageId)) return "rate-bad";
        return "rate-mid";
    }

    private string GetCloseRatePillClass(double rate)
    {
        if (rate >= 50) return "rate-good";
        if (rate >= 25) return "rate-mid";
        return "rate-bad";
    }

    private string GetAgePillClass(double days)
    {
        if (days >= 60) return "rate-bad";
        if (days >= 30) return "rate-mid";
        return "rate-good";
    }

    private string GetSummaryRingStyle()
    {
        var safe = Math.Max(0, Math.Min(_bestSourceRevenueShare, 100));
        var angle = safe * 3.6;
        return $"background: conic-gradient(#10b981 0deg, #10b981 {angle:F1}deg, rgba(255,255,255,.12) {angle:F1}deg, rgba(255,255,255,.12) 360deg);";
    }

    private string GetCloseRateProgressStyle()
    {
        var safe = Math.Max(0, Math.Min(_overallCloseRate, 100));
        return $"width:{safe:F0}%";
    }

    private string GetTrendClass(int current, int previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(double current, double previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(decimal current, decimal previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendText(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? "0%" : "جديد";

        var change = ((double)(current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(double current, double previous)
    {
        if (Math.Abs(previous) < 0.000001)
            return Math.Abs(current) < 0.000001 ? "0%" : "جديد";

        var change = ((current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(decimal current, decimal previous)
    {
        if (previous == 0m)
            return current == 0m ? "0%" : "جديد";

        var change = (double)((current - previous) / previous * 100m);
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

