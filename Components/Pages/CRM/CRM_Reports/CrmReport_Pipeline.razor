@page "/crm/reports/pipeline"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير خط مراحل المبيعات</PageTitle>

<div class="pipx-page" dir="rtl">

    @* Background *@
    <div class="pipx-bg">
        <div class="pipx-orb orb-1"></div>
        <div class="pipx-orb orb-2"></div>
        <div class="pipx-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="pipx-hero">
        <div class="pipx-hero-grid"></div>

        <div class="pipx-hero-content">
            <div class="pipx-hero-top">
                <button class="pipx-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="pipx-badge">
                    <span class="badge-dot"></span>
                    <span>Pipeline Intelligence</span>
                </div>
            </div>

            <div class="pipx-hero-main">
                <div class="pipx-hero-text">
                    <h1>خط <span>مراحل</span> المبيعات</h1>
                    <p>
                        لوحة تنفيذية لقياس توزيع الفرص عبر مراحل البيع، متابعة القيمة داخل الـ Pipeline،
                        اكتشاف الاختناقات، وتحليل المراحل والموظفين والفرص الأعلى تأثيرًا.
                    </p>

                    <div class="pipx-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الموظف</span>
                            <span class="chip-value">@SelectedEmployeeLabel</span>
                        </div>
                    </div>
                </div>

                <div class="pipx-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_closeRate.ToString("F1")%</div>
                            <div class="summary-caption">نسبة الحسم</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card pipx-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>حدد الفترة الزمنية والموظف أو استخدم الفترات السريعة لتحليل الـ Pipeline</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudSelect T="int?"
                       @bind-Value="_empId"
                       Label="الموظف"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Class="filter-field">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem T="int?" Value="@((int?)emp.Id)">@emp.Name</MudSelectItem>
                }
            </MudSelect>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card pipx-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل خط الأنابيب...</h3>
                <p>يتم تجهيز المؤشرات والرسوم البيانية وتحليل المراحل</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="pipx-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">#</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي الفرص</div>
                        <span class="trend-badge @GetTrendClass(_totalOpps, _prevTotalOpps)">
                            @GetTrendText(_totalOpps, _prevTotalOpps)
                        </span>
                    </div>
                    <div class="kpi-value">@_totalOpps.ToString("N0")</div>
                    <div class="kpi-sub">كل الفرص داخل الفترة المحددة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon blue">₪</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي القيمة المتوقعة</div>
                        <span class="trend-badge @GetTrendClass(_totalExpectedValue, _prevTotalExpectedValue)">
                            @GetTrendText(_totalExpectedValue, _prevTotalExpectedValue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_totalExpectedValue)</div>
                    <div class="kpi-sub">القيمة الإجمالية لجميع الفرص</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon teal">◎</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الفرص المفتوحة</div>
                        <span class="trend-badge @GetTrendClass(_openCount, _prevOpenCount)">
                            @GetTrendText(_openCount, _prevOpenCount)
                        </span>
                    </div>
                    <div class="kpi-value">@_openCount.ToString("N0")</div>
                    <div class="kpi-sub">الفرص التي ما زالت داخل الـ Pipeline</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon purple">⟐</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">قيمة الـ Pipeline المفتوح</div>
                        <span class="trend-badge @GetTrendClass(_openPipelineValue, _prevOpenPipelineValue)">
                            @GetTrendText(_openPipelineValue, _prevOpenPipelineValue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_openPipelineValue)</div>
                    <div class="kpi-sub">القيمة المتبقية في المراحل غير المغلقة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon green">✓</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الفرص المكتملة</div>
                        <span class="trend-badge @GetTrendClass(_wonCount, _prevWonCount)">
                            @GetTrendText(_wonCount, _prevWonCount)
                        </span>
                    </div>
                    <div class="kpi-value success">@_wonCount.ToString("N0")</div>
                    <div class="kpi-sub">عدد الصفقات الرابحة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">💰</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">قيمة المبيعات</div>
                        <span class="trend-badge @GetTrendClass(_wonValue, _prevWonValue)">
                            @GetTrendText(_wonValue, _prevWonValue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_wonValue)</div>
                    <div class="kpi-sub">الإيراد المتوقع من الصفقات الرابحة</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="pipx-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* MAIN DASHBOARD *@
        <section class="pipx-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>توزيع الفرص والقيمة حسب المرحلة</h3>
                        <p>عدد الفرص داخل كل مرحلة مقابل القيمة الإجمالية لها</p>
                    </div>
                </div>

                @if (_stageOverviewPoints.Any())
                {
                    <ApexChart TItem="StageOverviewPoint"
                               Options="_stageOverviewChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="StageOverviewPoint"
                                         Items="@_stageOverviewPoints"
                                         Name="عدد الفرص"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Stage"
                                         YValue="x => x.Count" />

                        <ApexPointSeries TItem="StageOverviewPoint"
                                         Items="@_stageOverviewPoints"
                                         Name="القيمة"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Stage"
                                         YValue="x => x.Value" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>أعلى الموظفين في الـ Pipeline المفتوح</h3>
                            <p>ترتيب الموظفين حسب قيمة الفرص المفتوحة</p>
                        </div>
                    </div>

                    @if (_employeeOpenPoints.Any())
                    {
                        <ApexChart TItem="EmployeeOpenPoint"
                                   Options="_employeeOpenChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="EmployeeOpenPoint"
                                             Items="@_employeeOpenPoints"
                                             Name="القيمة المفتوحة"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Employee"
                                             YValue="x => x.OpenValue" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض الموظفين</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">إجمالي الفرص</div>
                            <div class="compare-values">
                                <span>@_prevTotalOpps</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_totalOpps</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">إجمالي القيمة</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevTotalExpectedValue)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_totalExpectedValue)</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">Pipeline المفتوح</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevOpenPipelineValue)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_openPipelineValue)</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">قيمة المبيعات</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevWonValue)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_wonValue)</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @(_openPipelineValue >= _prevOpenPipelineValue ? "compare-good" : "compare-mid")">
                        @if (_openPipelineValue >= _prevOpenPipelineValue)
                        {
                            <span>الـ Pipeline الحالي أكبر أو مساوي للفترة السابقة</span>
                        }
                        else
                        {
                            <span>الـ Pipeline الحالي أقل من الفترة السابقة ويحتاج تغذية جديدة</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* ANALYTICS GRID *@
        <section class="pipx-analytics-grid">
            <div class="glass-card side-card">
                <div class="card-head">
                    <div>
                        <h3>النسبة المئوية لكل مرحلة</h3>
                        <p>حصة كل مرحلة من إجمالي الفرص</p>
                    </div>
                </div>

                @if (_stagePercentPoints.Any())
                {
                    <ApexChart TItem="StagePercentPoint"
                               Options="_stagePercentChartOptions"
                               Height="320">
                        <ApexPointSeries TItem="StagePercentPoint"
                                         Items="@_stagePercentPoints"
                                         Name="النسبة %"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Stage"
                                         YValue="x => x.Percent" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty small">لا توجد بيانات كافية لعرض النسب</div>
                }
            </div>

            <div class="glass-card pipx-stage-table-card">
                <div class="card-head">
                    <div>
                        <h3>تفاصيل المراحل</h3>
                        <p>ملخص كل مرحلة من حيث العدد والقيمة والمتوسط والنسبة</p>
                    </div>
                </div>

                <MudTable Items="@_stageRows"
                          Hover="true"
                          Dense="true"
                          Elevation="0"
                          RowsPerPage="10"
                          Breakpoint="Breakpoint.Sm"
                          Class="premium-table">
                    <HeaderContent>
                        <MudTh>المرحلة</MudTh>
                        <MudTh>العدد</MudTh>
                        <MudTh>القيمة</MudTh>
                        <MudTh>النسبة</MudTh>
                        <MudTh>متوسط الفرصة</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="المرحلة">
                            <span class="stage-pill" style="@GetStagePillStyle(context.Color)">
                                @context.Name
                            </span>
                        </MudTd>
                        <MudTd DataLabel="العدد">@context.Count.ToString("N0")</MudTd>
                        <MudTd DataLabel="القيمة">@FormatMoney(context.Value)</MudTd>
                        <MudTd DataLabel="النسبة">
                            <span class="rate-pill @GetStagePercentPillClass(context.Percent)">
                                @context.Percent.ToString("F1")%
                            </span>
                        </MudTd>
                        <MudTd DataLabel="متوسط الفرصة">@FormatMoney(context.AvgValue)</MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <div class="empty-data">
                            <div class="empty-icon">📉</div>
                            <h4>لا توجد بيانات</h4>
                            <p>لا توجد مراحل مطابقة للفلاتر الحالية</p>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </section>

        @* STAGE DRILL-DOWN *@
        <section class="glass-card pipx-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down حسب المرحلة</h3>
                    <p>اختر مرحلة لعرض موظفيها وأكبر الفرص بداخلها</p>
                </div>

                @if (_selectedStageId.HasValue)
                {
                    <button class="clear-stage-btn" @onclick="ClearSelectedStage">
                        إلغاء اختيار المرحلة
                    </button>
                }
            </div>

            <div class="stage-chip-row">
                @foreach (var stage in _stageRows)
                {
                    <button class="stage-chip-btn @(IsSelectedStage(stage.StageId) ? "stage-chip-active" : "")"
                            @onclick="() => SelectStage(stage.StageId)">
                        <span>@stage.Name</span>
                        <small>@stage.Count.ToString("N0") فرصة</small>
                    </button>
                }
            </div>

            @if (_selectedStageId.HasValue || _detailRows.Any())
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">المرحلة المحددة</span>
                        <strong>@_selectedStageName</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">عدد الفرص</span>
                        <strong>@_selectedStageCount.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">إجمالي القيمة</span>
                        <strong>@FormatMoney(_selectedStageValue)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">النسبة</span>
                        <strong>@_selectedStagePercent.ToString("F1")%</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">متوسط الفرصة</span>
                        <strong>@FormatMoney(_selectedStageAvgValue)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أعلى موظف</span>
                        <strong>@_selectedStageTopEmployee</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>الموظفون داخل المرحلة</h3>
                                <p>عدد الفرص والقيمة لكل موظف داخل المرحلة المحددة</p>
                            </div>
                        </div>

                        @if (_selectedStageEmployeePoints.Any())
                        {
                            <ApexChart TItem="StageEmployeePoint"
                                       Options="_selectedStageEmployeeChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="StageEmployeePoint"
                                                 Items="@_selectedStageEmployeePoints"
                                                 Name="عدد الفرص"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Employee"
                                                 YValue="x => x.Count" />

                                <ApexPointSeries TItem="StageEmployeePoint"
                                                 Items="@_selectedStageEmployeePoints"
                                                 Name="القيمة"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="x => x.Employee"
                                                 YValue="x => x.Value" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات كافية لهذا القسم</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>أكبر الفرص داخل المرحلة</h3>
                                <p>الفرص الأعلى قيمة في المرحلة المحددة</p>
                            </div>
                        </div>

                        @if (_selectedStageDealPoints.Any())
                        {
                            <ApexChart TItem="StageDealPoint"
                                       Options="_selectedStageDealsChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="StageDealPoint"
                                                 Items="@_selectedStageDealPoints"
                                                 Name="القيمة"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Deal"
                                                 YValue="x => x.Value" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد فرص كافية داخل المرحلة المحددة</div>
                        }
                    </div>
                </div>
            }
        </section>

        @* OPPORTUNITY DETAILS *@
        <section class="glass-card pipx-table-card">
            <div class="card-head">
                <div>
                    <h3>تفاصيل الفرص</h3>
                    <p>
                        @if (_selectedStageId.HasValue)
                        {
                            <span>عرض الفرص داخل مرحلة: @_selectedStageName</span>
                        }
                        else
                        {
                            <span>عرض أعلى الفرص حسب القيمة</span>
                        }
                    </p>
                </div>
            </div>

            <MudTable Items="@_detailRows"
                      Hover="true"
                      Dense="true"
                      Elevation="0"
                      RowsPerPage="10"
                      Breakpoint="Breakpoint.Sm"
                      Class="premium-table">
                <HeaderContent>
                    <MudTh>العميل</MudTh>
                    <MudTh>الموظف</MudTh>
                    <MudTh>المرحلة</MudTh>
                    <MudTh>تاريخ الإنشاء</MudTh>
                    <MudTh>آخر تواصل</MudTh>
                    <MudTh>العمر</MudTh>
                    <MudTh>القيمة</MudTh>
                    <MudTh>إجراء</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="العميل">@context.ClientName</MudTd>
                    <MudTd DataLabel="الموظف">@context.EmployeeName</MudTd>
                    <MudTd DataLabel="المرحلة">
                        <span class="stage-pill" style="@GetStagePillStyle(context.StageColor)">
                            @context.StageName
                        </span>
                    </MudTd>
                    <MudTd DataLabel="تاريخ الإنشاء">@FormatDate(context.CreatedAt)</MudTd>
