    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentRows = await LoadPeriodRowsAsync(db, _fromDate, _toDate);

            if (TryGetPreviousRange(out var prevFrom, out var prevTo))
            {
                _previousPeriodLabel = $"{prevFrom.ToString("dd MMM yyyy", _arCulture)} — {prevTo.ToString("dd MMM yyyy", _arCulture)}";
                var previousRows = await LoadPeriodRowsAsync(db, prevFrom, prevTo);
                CalculatePreviousMetrics(previousRows);
            }
            else
            {
                _previousPeriodLabel = "غير متاح";
                ResetPreviousMetrics();
            }

            CalculateCurrentMetrics(_currentRows);
            BuildStageSummary(_currentRows);
            BuildEmployeeOpenPipeline(_currentRows);
            ResolveSelectedStage();
            BuildSelectedStageAnalytics(_currentRows);
            BuildInsights();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<List<OpportunitySourceRow>> LoadPeriodRowsAsync(db24804Context db, DateTime? from, DateTime? to)
    {
        var query = db.VwSalesOpportunities
            .AsNoTracking()
            .Where(o => o.IsActive == true);

        if (from.HasValue)
        {
            var fromDate = from.Value.Date;
            query = query.Where(o => o.CreatedAt >= fromDate);
        }

        if (to.HasValue)
        {
            var toExclusive = to.Value.Date.AddDays(1);
            query = query.Where(o => o.CreatedAt < toExclusive);
        }

        if (_empId.HasValue)
        {
            query = query.Where(o => o.EmployeeId == _empId.Value);
        }

        return await query
            .Select(o => new OpportunitySourceRow
            {
                OpportunityId = o.OpportunityId,
                ClientName = o.ClientName ?? "—",
                EmployeeId = o.EmployeeId ?? 0,
                EmployeeName = o.EmployeeName ?? "—",
                StageId = o.StageId,
                StageName = o.StageNameAr ?? o.StageName ?? "غير محدد",
                StageColor = o.StageColor ?? "",
                StageOrder = o.StageOrder ?? 0,
                CreatedAt = o.CreatedAt,
                LastContactDate = o.LastContactDate,
                ExpectedValue = o.ExpectedValue ?? 0m,
                AgeDays = o.DaysSinceFirstContact ?? 0d
            })
            .ToListAsync();
    }

    private void CalculateCurrentMetrics(List<OpportunitySourceRow> rows)
    {
        _totalOpps = rows.Count;
        _totalExpectedValue = rows.Sum(x => x.ExpectedValue);
        _openCount = rows.Count(x => IsOpenStage(x.StageId));
        _openPipelineValue = rows.Where(x => IsOpenStage(x.StageId)).Sum(x => x.ExpectedValue);
        _wonCount = rows.Count(x => IsWon(x.StageId));
        _wonValue = rows.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
        _closeRate = _totalOpps > 0 ? (double)_wonCount / _totalOpps * 100d : 0d;
    }

    private void CalculatePreviousMetrics(List<OpportunitySourceRow> rows)
    {
        _prevTotalOpps = rows.Count;
        _prevTotalExpectedValue = rows.Sum(x => x.ExpectedValue);
        _prevOpenCount = rows.Count(x => IsOpenStage(x.StageId));
        _prevOpenPipelineValue = rows.Where(x => IsOpenStage(x.StageId)).Sum(x => x.ExpectedValue);
        _prevWonCount = rows.Count(x => IsWon(x.StageId));
        _prevWonValue = rows.Where(x => IsWon(x.StageId)).Sum(x => x.ExpectedValue);
    }

    private void ResetPreviousMetrics()
    {
        _prevTotalOpps = 0;
        _prevTotalExpectedValue = 0m;
        _prevOpenCount = 0;
        _prevOpenPipelineValue = 0m;
        _prevWonCount = 0;
        _prevWonValue = 0m;
    }

    private void BuildStageSummary(List<OpportunitySourceRow> rows)
    {
        _stageRows = rows
            .GroupBy(x => new { x.StageId, x.StageName, x.StageColor, x.StageOrder })
            .Select(g =>
            {
                var count = g.Count();
                var value = g.Sum(x => x.ExpectedValue);

                return new StageSummaryRow
                {
                    StageId = g.Key.StageId,
                    Name = g.Key.StageName,
                    Color = g.Key.StageColor,
                    Order = g.Key.StageOrder,
                    Count = count,
                    Value = value,
                    Percent = _totalOpps > 0 ? (double)count / _totalOpps * 100d : 0d,
                    AvgValue = count > 0 ? value / count : 0m
                };
            })
            .OrderBy(x => x.Order)
            .ThenBy(x => x.StageId)
            .ToList();

        _stageOverviewPoints = _stageRows
            .Select(x => new StageOverviewPoint
            {
                Stage = x.Name,
                Count = x.Count,
                Value = x.Value
            })
            .ToList();

        _stagePercentPoints = _stageRows
            .Select(x => new StagePercentPoint
            {
                Stage = x.Name,
                Percent = (decimal)x.Percent
            })
            .OrderByDescending(x => x.Percent)
            .ToList();
    }

    private void BuildEmployeeOpenPipeline(List<OpportunitySourceRow> rows)
    {
        _employeeOpenPoints = rows
            .Where(x => IsOpenStage(x.StageId))
            .GroupBy(x => new { x.EmployeeId, x.EmployeeName })
            .Select(g => new EmployeeOpenPoint
            {
                Employee = g.Key.EmployeeName,
                OpenValue = g.Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.OpenValue)
            .Take(8)
            .ToList();
    }

    private void ResolveSelectedStage()
    {
        if (!_stageRows.Any())
        {
            _selectedStageId = null;
            return;
        }

        if (_selectedStageId.HasValue && _stageRows.Any(x => x.StageId == _selectedStageId.Value))
            return;

        var openPreferred = _stageRows
            .Where(x => IsOpenStage(x.StageId))
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.Value)
            .FirstOrDefault();

        _selectedStageId = openPreferred?.StageId ?? _stageRows.First().StageId;
    }

    private void BuildSelectedStageAnalytics(List<OpportunitySourceRow> rows)
    {
        _selectedStageName = "—";
        _selectedStageCount = 0;
        _selectedStageValue = 0m;
        _selectedStagePercent = 0d;
        _selectedStageAvgValue = 0m;
        _selectedStageTopEmployee = "—";
        _selectedStageEmployeePoints = new();
        _selectedStageDealPoints = new();
        _detailRows = new();

        if (!_selectedStageId.HasValue)
        {
            _detailRows = rows
                .OrderByDescending(x => x.ExpectedValue)
                .ThenByDescending(x => x.CreatedAt)
                .Take(25)
                .Select(MapDetailRow)
                .ToList();

            return;
        }

        var stageRows = rows
            .Where(x => x.StageId == _selectedStageId.Value)
            .ToList();

        if (!stageRows.Any())
            return;

        var summary = _stageRows.FirstOrDefault(x => x.StageId == _selectedStageId.Value);

        _selectedStageName = summary?.Name ?? stageRows.First().StageName;
        _selectedStageCount = stageRows.Count;
        _selectedStageValue = stageRows.Sum(x => x.ExpectedValue);
        _selectedStagePercent = _totalOpps > 0 ? (double)_selectedStageCount / _totalOpps * 100d : 0d;
        _selectedStageAvgValue = _selectedStageCount > 0 ? _selectedStageValue / _selectedStageCount : 0m;

        var topEmployee = stageRows
            .GroupBy(x => x.EmployeeName)
            .Select(g => new
            {
                Employee = g.Key,
                Count = g.Count(),
                Value = g.Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.Value)
            .FirstOrDefault();

        _selectedStageTopEmployee = topEmployee?.Employee ?? "—";

        _selectedStageEmployeePoints = stageRows
            .GroupBy(x => x.EmployeeName)
            .Select(g => new StageEmployeePoint
            {
                Employee = g.Key,
                Count = g.Count(),
                Value = g.Sum(x => x.ExpectedValue)
            })
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.Value)
            .Take(8)
            .ToList();

        _selectedStageDealPoints = stageRows
            .OrderByDescending(x => x.ExpectedValue)
            .ThenByDescending(x => x.CreatedAt)
            .Take(8)
            .Select(x => new StageDealPoint
            {
                Deal = x.ClientName,
                Value = x.ExpectedValue
            })
            .ToList();

        _detailRows = stageRows
            .OrderByDescending(x => x.ExpectedValue)
            .ThenByDescending(x => x.CreatedAt)
            .Select(MapDetailRow)
            .ToList();
    }

    private StageDetailRow MapDetailRow(OpportunitySourceRow x) => new()
    {
        OpportunityId = x.OpportunityId,
        ClientName = x.ClientName,
        EmployeeName = x.EmployeeName,
        StageName = x.StageName,
        StageColor = x.StageColor,
        CreatedAt = x.CreatedAt,
        LastContactDate = x.LastContactDate,
        AgeDays = x.AgeDays,
        ExpectedValue = x.ExpectedValue
    };

    private void BuildInsights()
    {
        _insights = new();

        if (_stageRows.Any())
        {
            var highestCount = _stageRows
                .OrderByDescending(x => x.Count)
                .ThenByDescending(x => x.Value)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.AccountTree,
                Title = "أكبر مرحلة من حيث العدد",
                Value = highestCount.Name,
                Description = $"{highestCount.Count} فرصة — {highestCount.Percent:F1}% من الإجمالي",
                ToneClass = "tone-indigo"
            });

            var highestValue = _stageRows
                .OrderByDescending(x => x.Value)
                .ThenByDescending(x => x.Count)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.AttachMoney,
                Title = "أعلى مرحلة من حيث القيمة",
                Value = highestValue.Name,
                Description = $"{FormatMoney(highestValue.Value)}",
                ToneClass = "tone-green"
            });

            var bottleneck = _stageRows
                .Where(x => IsOpenStage(x.StageId))
                .OrderByDescending(x => x.Count)
                .ThenByDescending(x => x.Value)
                .FirstOrDefault();

            if (bottleneck != null)
            {
                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.ReportProblem,
                    Title = "أكبر اختناق مفتوح",
                    Value = bottleneck.Name,
                    Description = $"{bottleneck.Count} فرصة ما زالت معلقة",
                    ToneClass = "tone-red"
                });
            }

            var avgBest = _stageRows
                .Where(x => x.Count > 0)
                .OrderByDescending(x => x.AvgValue)
                .FirstOrDefault();

            if (avgBest != null)
            {
                _insights.Add(new InsightItem
                {
                    Icon = Icons.Material.Rounded.Insights,
                    Title = "أعلى متوسط فرصة",
                    Value = avgBest.Name,
                    Description = $"{FormatMoney(avgBest.AvgValue)} لكل فرصة",
                    ToneClass = "tone-gold"
                });
            }
        }

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private void SelectStage(int stageId)
    {
        _selectedStageId = stageId;
        BuildSelectedStageAnalytics(_currentRows);
    }

    private void ClearSelectedStage()
    {
        _selectedStageId = null;
        BuildSelectedStageAnalytics(_currentRows);
    }

    private bool IsSelectedStage(int stageId)
        => _selectedStageId.HasValue && _selectedStageId.Value == stageId;

    private bool TryGetPreviousRange(out DateTime previousFrom, out DateTime previousTo)
    {
        previousFrom = default;
        previousTo = default;

        if (!_fromDate.HasValue || !_toDate.HasValue)
            return false;

        var currentFrom = _fromDate.Value.Date;
        var currentTo = _toDate.Value.Date;
        var days = (currentTo - currentFrom).Days;

        previousTo = currentFrom.AddDays(-1);
        previousFrom = previousTo.AddDays(-days);

        return true;
    }

    private void NormalizeDateRange()
    {
        if (_fromDate.HasValue && _toDate.HasValue && _fromDate.Value.Date > _toDate.Value.Date)
        {
            var temp = _fromDate;
            _fromDate = _toDate;
            _toDate = temp;

            Snackbar.Add("تم تبديل تاريخ البداية والنهاية تلقائيًا لأن البداية كانت أكبر من النهاية.", Severity.Info);
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("تقرير  مراحل المبيعات ");
            sb.AppendLine($"الفترة الحالية,{SelectedPeriodLabel}");
            sb.AppendLine($"الفترة السابقة,{PreviousPeriodLabel}");
            sb.AppendLine($"الموظف,{SelectedEmployeeLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"إجمالي الفرص,{_totalOpps}");
            sb.AppendLine($"إجمالي القيمة المتوقعة,{_totalExpectedValue:N0}");
            sb.AppendLine($"الفرص المفتوحة,{_openCount}");
            sb.AppendLine($"قيمة الـ Pipeline المفتوح,{_openPipelineValue:N0}");
            sb.AppendLine($"الفرص المكتملة,{_wonCount}");
            sb.AppendLine($"قيمة المبيعات,{_wonValue:N0}");
            sb.AppendLine();

            sb.AppendLine("تفاصيل المراحل");
            sb.AppendLine("المرحلة,العدد,القيمة,النسبة,متوسط الفرصة");
            foreach (var row in _stageRows)
            {
                sb.AppendLine($"{row.Name},{row.Count},{row.Value:N0},{row.Percent:F1}%,{row.AvgValue:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("تفاصيل الفرص");
            sb.AppendLine("العميل,الموظف,المرحلة,تاريخ الإنشاء,آخر تواصل,العمر,القيمة");
            foreach (var row in _detailRows)
            {
                sb.AppendLine($"{row.ClientName},{row.EmployeeName},{row.StageName},{FormatDate(row.CreatedAt)},{FormatDate(row.LastContactDate)},{row.AgeDays:F0},{row.ExpectedValue:N0}");
            }

            var csv = sb.ToString();
            var fileName = $"pipeline-report-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

    private async Task PrintAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "window.print()");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تشغيل الطباعة: {ex.Message}", Severity.Error);
        }
    }

    private bool IsWon(int stageId) => stageId == WonStageId;
    private bool IsLost(int stageId) => stageId == LostStageId1 || stageId == LostStageId2;
    private bool IsOpenStage(int stageId) => !IsWon(stageId) && !IsLost(stageId);

    private string FormatMoney(decimal value) => $"{value:N0} ج.م";
    private string FormatDate(DateTime? date) => date?.ToString("yyyy/MM/dd") ?? "—";

    private string GetStagePillStyle(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
            return "background:#e5e7eb;color:#111827;";

        return $"background:{color};color:#fff;";
    }

    private string GetStagePercentPillClass(double percent)
    {
        if (percent >= 40) return "rate-bad";
        if (percent >= 20) return "rate-mid";
        return "rate-good";
    }

    private string GetAgePillClass(double days)
    {
        if (days >= 60) return "rate-bad";
        if (days >= 30) return "rate-mid";
        return "rate-good";
    }

    private string GetTrendClass(int current, int previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(decimal current, decimal previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendText(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? "0%" : "جديد";

        var change = ((double)(current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(decimal current, decimal previous)
    {
        if (previous == 0m)
            return current == 0m ? "0%" : "جديد";

        var change = (double)((current - previous) / previous * 100m);
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetSummaryRingStyle()
    {
        var safe = Math.Max(0, Math.Min(_closeRate, 100));
        var angle = safe * 3.6;
        return $"background: conic-gradient(#10b981 0deg, #10b981 {angle:F1}deg, rgba(255,255,255,.12) {angle:F1}deg, rgba(255,255,255,.12) 360deg);";
    }

    private void GoBack() => Navigation.NavigateTo("/crm/reports");
    private void OpenOpportunity(int id) => Navigation.NavigateTo($"/crm/opportunities/{id}");

