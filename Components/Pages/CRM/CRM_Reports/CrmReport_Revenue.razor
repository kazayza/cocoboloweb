    private sealed class EmployeeItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }

    private sealed class RevenueSourceRow
    {
        public DateTime CreatedAt { get; set; }
        public decimal ExpectedValue { get; set; }
        public int? StageId { get; set; }
        public string? EmployeeName { get; set; }
    }

    private sealed class MonthlyAggregate
    {
        public decimal Expected { get; set; }
        public decimal Actual { get; set; }
    }

    private sealed class DailyAggregate
    {
        public decimal Expected { get; set; }
        public decimal Actual { get; set; }
    }

    private sealed class MonthlyRow
    {
        public int Year { get; set; }
        public int MonthNum { get; set; }
        public string Month { get; set; } = "";
        public decimal Expected { get; set; }
        public decimal Actual { get; set; }
        public decimal Variance { get; set; }
        public double AchievementRate { get; set; }
    }

    private sealed class RevenueTrendPoint
    {
        public string Month { get; set; } = "";
        public decimal Expected { get; set; }
        public decimal Actual { get; set; }
        public decimal Variance { get; set; }
    }

    private sealed class DailyTrendPoint
    {
        public string Day { get; set; } = "";
        public decimal Expected { get; set; }
        public decimal Actual { get; set; }
    }

    private sealed class EmployeeChartPoint
    {
        public string Employee { get; set; } = "";
        public decimal Expected { get; set; }
        public decimal Actual { get; set; }
    }

    private sealed class InsightItem
    {
        public string Icon { get; set; } = "";
        public string Title { get; set; } = "";
        public string Value { get; set; } = "";
        public string Description { get; set; } = "";
        public string ToneClass { get; set; } = "";
    }
}

<style>
    .rev3-page {
        --text: #0f172a;
        --muted: #64748b;
        --line: rgba(148, 163, 184, .16);
        --glass: rgba(255,255,255,.72);
        --shadow: 0 20px 50px rgba(15, 23, 42, .06);

        max-width: 1460px;
        margin: 0 auto;
        padding: 1.25rem 1.25rem 3rem;
        position: relative;
        min-height: 100vh;
    }

    .rev3-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .rev3-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: .16;
    }

    .orb-1 {
        width: 420px;
        height: 420px;
        background: #6366f1;
        top: -120px;
        right: -120px;
        animation: rev3Float 12s ease-in-out infinite;
    }

    .orb-2 {
        width: 360px;
        height: 360px;
        background: #10b981;
        bottom: -80px;
        left: -80px;
        animation: rev3Float 18s ease-in-out infinite reverse;
    }

    .orb-3 {
        width: 280px;
        height: 280px;
        background: #f59e0b;
        top: 30%;
        left: 45%;
        animation: rev3Float 16s ease-in-out infinite;
    }

    @@keyframes rev3Float {
        0%,100% { transform: translate(0,0) scale(1); }
        50% { transform: translate(20px,-20px) scale(1.08); }
    }

    .glass-card {
        position: relative;
        z-index: 1;
        background: var(--glass);
        backdrop-filter: blur(20px) saturate(1.5);
        -webkit-backdrop-filter: blur(20px) saturate(1.5);
        border: 1px solid rgba(255,255,255,.48);
        box-shadow: var(--shadow);
        border-radius: 1.35rem;
    }

    .glass-inner-card {
        background: rgba(255,255,255,.45);
        border: 1px solid rgba(255,255,255,.4);
        border-radius: 1.2rem;
        padding: 1rem;
    }

    /* HERO */
    .rev3-hero {
        position: relative;
        overflow: hidden;
        border-radius: 1.8rem;
        margin-bottom: 1.25rem;
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 45%, #4338ca 100%);
        padding: 2rem;
        color: #fff;
        z-index: 1;
    }

    .rev3-hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
        background-size: 50px 50px;
        mask-image: radial-gradient(circle at center, black 45%, transparent 100%);
        pointer-events: none;
    }

    .rev3-hero-content {
        position: relative;
        z-index: 2;
    }

    .rev3-hero-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .rev3-back {
        width: 2.6rem;
        height: 2.6rem;
        border: 1px solid rgba(255,255,255,.18);
        background: rgba(255,255,255,.08);
        color: #fff;
        border-radius: .9rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: .25s ease;
        backdrop-filter: blur(10px);
    }

    .rev3-back:hover {
        transform: translateX(-3px);
        background: rgba(255,255,255,.15);
    }

    .rev3-badge {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .45rem .9rem;
        border-radius: 999px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.16);
        color: #dbeafe;
        font-size: .8rem;
        font-weight: 700;
    }

    .badge-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #93c5fd;
        box-shadow: 0 0 12px #93c5fd;
        animation: badgePulse 2s infinite;
    }

    @@keyframes badgePulse {
        0%,100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.35); opacity: .6; }
    }

    .rev3-hero-main {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .rev3-hero-text {
        flex: 1;
    }

    .rev3-hero-text h1 {
        margin: 0 0 .6rem;
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -.02em;
    }

    .rev3-hero-text h1 span {
        color: #c4b5fd;
    }

    .rev3-hero-text p {
        margin: 0 0 1rem;
        color: rgba(255,255,255,.72);
        max-width: 760px;
        line-height: 1.8;
    }

    .rev3-hero-chips {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .hero-chip {
        display: flex;
        flex-direction: column;
        gap: .15rem;
        padding: .85rem 1rem;
        border-radius: 1rem;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        min-width: 210px;
    }

    .chip-label {
        font-size: .72rem;
        color: rgba(255,255,255,.6);
    }

    .chip-value {
        font-size: .85rem;
        font-weight: 700;
        color: #fff;
    }

    .summary-ring {
        width: 170px;
        height: 170px;
        border-radius: 50%;
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: inset 0 0 30px rgba(255,255,255,.08);
    }

    .summary-ring-inner {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: rgba(15,23,42,.92);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255,255,255,.08);
    }

    .summary-percent {
        font-size: 2rem;
        font-weight: 900;
        line-height: 1;
        color: #fff;
    }

    .summary-caption {
        margin-top: .35rem;
        font-size: .78rem;
        color: rgba(255,255,255,.62);
    }

    /* FILTERS */
    .rev3-filters {
        padding: 1.15rem;
        margin-bottom: 1.25rem;
    }

    .filters-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        margin-bottom: 1rem;
    }

    .filters-head h3 {
        margin: 0 0 .2rem;
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
    }

    .filters-head p {
        margin: 0;
        color: var(--muted);
        font-size: .83rem;
    }

    .filters-actions {
        display: flex;
        gap: .65rem;
        flex-wrap: wrap;
    }

    .quick-range-row {
        display: flex;
        gap: .5rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .quick-range-btn {
        border: 1px solid var(--line);
        background: rgba(255,255,255,.65);
        color: var(--text);
        border-radius: 999px;
        padding: .45rem .85rem;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: .2s ease;
    }

    .quick-range-btn:hover {
        background: rgba(99,102,241,.08);
        color: #4f46e5;
        border-color: rgba(99,102,241,.22);
    }

    .filters-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(180px, 1fr));
        gap: .9rem;
    }

    .filter-field {
        background: rgba(255,255,255,.55);
        border-radius: .9rem;
    }

    /* LOADING */
    .rev3-loading {
        min-height: 320px;
        display: flex;
        gap: 1rem;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        text-align: center;
        padding: 2rem;
    }

    .loading-text h3 {
        margin: 0 0 .35rem;
        font-size: 1rem;
        color: var(--text);
    }

    .loading-text p {
        margin: 0;
        color: var(--muted);
        font-size: .85rem;
    }

    /* KPI */
    .rev3-kpis {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .kpi-card {
        padding: 1.1rem;
        display: flex;
        gap: .9rem;
        align-items: flex-start;
    }

    .kpi-icon {
        width: 3rem;
        height: 3rem;
        border-radius: .95rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 900;
        flex-shrink: 0;
    }

    .kpi-icon.indigo { background: rgba(99,102,241,.12); color: #6366f1; }
    .kpi-icon.green { background: rgba(16,185,129,.12); color: #10b981; }
    .kpi-icon.amber { background: rgba(245,158,11,.12); color: #f59e0b; }
    .kpi-icon.emerald { background: rgba(5,150,105,.12); color: #059669; }
    .kpi-icon.red { background: rgba(239,68,68,.12); color: #ef4444; }

    .kpi-body {
        flex: 1;
        min-width: 0;
    }

    .kpi-head-row {
        display: flex;
        justify-content: space-between;
        gap: .5rem;
        align-items: center;
        margin-bottom: .35rem;
    }

    .kpi-label {
        color: var(--muted);
        font-size: .8rem;
    }

    .kpi-value {
        color: var(--text);
        font-size: 1.45rem;
        font-weight: 900;
        line-height: 1.2;
        margin-bottom: .35rem;
    }

    .kpi-value.pos { color: #059669; }
    .kpi-value.neg { color: #dc2626; }

    .kpi-sub {
        color: var(--muted);
        font-size: .76rem;
        line-height: 1.5;
    }

    .trend-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: .2rem .55rem;
        font-size: .68rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .trend-up {
        background: rgba(16,185,129,.12);
        color: #059669;
    }

    .trend-down {
        background: rgba(239,68,68,.12);
        color: #dc2626;
    }

    .trend-flat {
        background: rgba(148,163,184,.14);
        color: #475569;
    }

    .kpi-progress {
        height: 8px;
        border-radius: 999px;
        background: rgba(148,163,184,.15);
        overflow: hidden;
        margin: .35rem 0 .45rem;
    }

    .kpi-progress-bar {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #f59e0b, #fbbf24);
    }

    /* INSIGHTS */
    .rev3-insights {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .insight-card {
        padding: 1rem;
        display: flex;
        gap: .85rem;
        align-items: flex-start;
    }

    .insight-icon {
        width: 2.6rem;
        height: 2.6rem;
        border-radius: .85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .tone-gold { background: rgba(245,158,11,.12); color: #d97706; }
    .tone-green { background: rgba(16,185,129,.12); color: #059669; }
    .tone-red { background: rgba(239,68,68,.12); color: #dc2626; }
    .tone-indigo { background: rgba(99,102,241,.12); color: #4f46e5; }
    .tone-slate { background: rgba(148,163,184,.14); color: #475569; }

    .insight-body {
        min-width: 0;
        flex: 1;
    }

    .insight-title {
        color: var(--muted);
        font-size: .75rem;
        margin-bottom: .2rem;
    }

    .insight-value {
        color: var(--text);
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: .25rem;
    }

    .insight-desc {
        color: var(--muted);
        font-size: .74rem;
        line-height: 1.45;
    }

    /* DASHBOARD */
    .rev3-dashboard {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .main-chart-card,
    .side-card,
    .rev3-table-card,
    .rev3-note,
    .rev3-drill {
        padding: 1rem;
    }

    .side-stack {
        display: grid;
        gap: 1rem;
    }

    .card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .75rem;
    }

    .card-head h3 {
        margin: 0 0 .2rem;
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
    }

    .card-head p {
        margin: 0;
        color: var(--muted);
        font-size: .8rem;
    }

    .chart-empty {
        min-height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: .88rem;
    }

    .chart-empty.small {
        min-height: 180px;
    }

    /* COMPARE */
    .compare-list {
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }

    .compare-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: .75rem .85rem;
        border-radius: 1rem;
        background: rgba(255,255,255,.45);
        border: 1px solid var(--line);
    }

    .compare-label {
        font-size: .8rem;
        font-weight: 700;
        color: var(--text);
    }

    .compare-values {
        display: flex;
        align-items: center;
        gap: .55rem;
        color: var(--muted);
        font-size: .8rem;
        flex-wrap: wrap;
    }

    .compare-values strong {
        color: var(--text);
        font-size: .85rem;
    }

    .compare-arrow {
        color: #94a3b8;
        font-weight: 900;
    }

    .compare-summary {
        margin-top: .85rem;
        border-radius: 1rem;
        padding: .8rem .9rem;
        font-size: .8rem;
        font-weight: 700;
    }

    .compare-good {
        background: rgba(16,185,129,.12);
        color: #059669;
    }

    .compare-bad {
        background: rgba(239,68,68,.12);
        color: #dc2626;
    }

    /* DRILL */
    .drill-head {
        align-items: center;
    }

    .clear-month-btn {
        border: 1px solid var(--line);
        background: rgba(255,255,255,.65);
        color: var(--text);
        border-radius: 999px;
        padding: .45rem .9rem;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        transition: .2s ease;
    }

    .clear-month-btn:hover {
        background: rgba(239,68,68,.08);
        color: #dc2626;
    }

    .month-chip-row {
        display: flex;
        gap: .55rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .month-chip-btn {
        border: 1px solid var(--line);
        background: rgba(255,255,255,.55);
        color: var(--text);
        border-radius: 1rem;
        padding: .55rem .8rem;
        min-width: 110px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .1rem;
        cursor: pointer;
        transition: .2s ease;
        font-weight: 700;
    }

    .month-chip-btn small {
        color: var(--muted);
        font-size: .7rem;
        font-weight: 700;
    }

    .month-chip-btn:hover {
        border-color: rgba(79,70,229,.25);
        background: rgba(99,102,241,.06);
        color: #4f46e5;
    }

    .month-chip-active {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #fff;
        border-color: transparent;
        box-shadow: 0 10px 20px rgba(99,102,241,.22);
    }

    .month-chip-active small {
        color: rgba(255,255,255,.85);
    }

    .drill-mini-kpis {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .mini-kpi {
        background: rgba(255,255,255,.45);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: .85rem;
        display: flex;
        flex-direction: column;
        gap: .25rem;
    }

    .mini-label {
        font-size: .72rem;
        color: var(--muted);
    }

    .mini-kpi strong {
        color: var(--text);
        font-size: .92rem;
    }

    .drill-grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 1rem;
    }

    /* TABLE */
    .premium-table {
        background: transparent;
    }

    .variance-pill,
    .rate-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: .3rem .7rem;
        font-size: .74rem;
        font-weight: 700;
    }

    .variance-pos {
        background: rgba(16,185,129,.12);
        color: #059669;
    }

    .variance-neg {
        background: rgba(239,68,68,.12);
        color: #dc2626;
    }

    .rate-pill {
        background: rgba(99,102,241,.10);
        color: #4f46e5;
    }

    .empty-data {
        text-align: center;
        padding: 2rem 1rem;
    }

    .empty-icon {
        font-size: 2rem;
        margin-bottom: .5rem;
    }

    .empty-data h4 {
        margin: 0 0 .35rem;
        color: var(--text);
    }

    .empty-data p {
        margin: 0;
        color: var(--muted);
        font-size: .85rem;
    }

    /* NOTE */
    .rev3-note {
        display: flex;
        gap: .9rem;
        align-items: flex-start;
        margin-top: 1rem;
    }

    .note-icon {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: .85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(99,102,241,.10);
        color: #4f46e5;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .note-body h4 {
        margin: 0 0 .3rem;
        color: var(--text);
        font-size: .95rem;
        font-weight: 800;
    }

    .note-body p {
        margin: 0;
        color: var(--muted);
        font-size: .82rem;
        line-height: 1.7;
    }

    /* RESPONSIVE */
    @@media (max-width: 1200px) {
        .rev3-kpis,
        .rev3-insights {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .rev3-dashboard,
        .drill-grid {
            grid-template-columns: 1fr;
        }

        .drill-mini-kpis {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 900px) {
        .rev3-hero-main,
        .filters-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .filters-grid {
            grid-template-columns: 1fr;
        }

        .drill-mini-kpis {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .rev3-page {
            padding: .8rem .8rem 2rem;
        }

        .rev3-hero {
            padding: 1.25rem;
            border-radius: 1.2rem;
        }

        .rev3-hero-text h1 {
            font-size: 1.7rem;
        }

        .summary-ring {
            width: 140px;
            height: 140px;
        }

        .hero-chip {
            min-width: 100%;
        }

        .rev3-kpis,
        .rev3-insights,
        .drill-mini-kpis {
            grid-template-columns: 1fr;
        }

        .compare-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .filters-actions {
            width: 100%;
        }
    }

    /* DARK MODE */
    .mud-theme-dark .glass-card,
    .mud-theme-dark .glass-inner-card {
        background: rgba(17,24,39,.66);
        border-color: rgba(255,255,255,.06);
        box-shadow: 0 20px 50px rgba(0,0,0,.22);
    }

    .mud-theme-dark .filters-head h3,
    .mud-theme-dark .card-head h3,
    .mud-theme-dark .loading-text h3,
    .mud-theme-dark .empty-data h4,
    .mud-theme-dark .note-body h4,
    .mud-theme-dark .kpi-value,
    .mud-theme-dark .insight-value,
    .mud-theme-dark .compare-label,
    .mud-theme-dark .compare-values strong,
    .mud-theme-dark .mini-kpi strong {
        color: #f8fafc;
    }

    .mud-theme-dark .filters-head p,
    .mud-theme-dark .card-head p,
    .mud-theme-dark .loading-text p,
    .mud-theme-dark .empty-data p,
    .mud-theme-dark .note-body p,
    .mud-theme-dark .kpi-label,
    .mud-theme-dark .kpi-sub,
    .mud-theme-dark .insight-title,
    .mud-theme-dark .insight-desc,
    .mud-theme-dark .compare-values,
