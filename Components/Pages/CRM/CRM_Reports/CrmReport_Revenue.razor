@page "/crm/reports/revenue"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير الإيرادات المتوقعة vs الفعلية</PageTitle>

<div class="rev3-page" dir="rtl">

    @* Background *@
    <div class="rev3-bg">
        <div class="rev3-orb orb-1"></div>
        <div class="rev3-orb orb-2"></div>
        <div class="rev3-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="rev3-hero">
        <div class="rev3-hero-grid"></div>

        <div class="rev3-hero-content">
            <div class="rev3-hero-top">
                <button class="rev3-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="rev3-badge">
                    <span class="badge-dot"></span>
                    <span>Revenue Intelligence V3</span>
                </div>
            </div>

            <div class="rev3-hero-main">
                <div class="rev3-hero-text">
                    <h1>الإيرادات المتوقعة <span>vs</span> الفعلية</h1>
                    <p>
                        لوحة تنفيذية احترافية لتحليل الإيرادات، الفجوة بين المتوقع والمحقق،
                        مقارنة الفترات، وتحليل شهري تفصيلي مع Drill-down ذكي.
                    </p>

                    <div class="rev3-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الموظف</span>
                            <span class="chip-value">@SelectedEmployeeLabel</span>
                        </div>
                    </div>
                </div>

                <div class="rev3-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_achievementRate.ToString("F1")%</div>
                            <div class="summary-caption">نسبة تحقيق الإيراد</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card rev3-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية والموظف أو استخدم اختصارات الفترات السريعة</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudSelect T="int?"
                       @bind-Value="_empId"
                       Label="الموظف"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Class="filter-field">
                @foreach (var emp in _employees)
                {
                    <MudSelectItem T="int?" Value="@((int?)emp.Id)">@emp.Name</MudSelectItem>
                }
            </MudSelect>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card rev3-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل التقرير...</h3>
                <p>يتم تجهيز المؤشرات، الرسوم البيانية، والمقارنات الذكية</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="rev3-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon indigo">₪</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الإيرادات المتوقعة</div>
                        <span class="trend-badge @GetTrendClass(_totalExpected, _prevExpected)">
                            @GetTrendText(_totalExpected, _prevExpected)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_totalExpected)</div>
                    <div class="kpi-sub">إجمالي المتوقع خلال الفترة الحالية</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon green">✓</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الإيرادات الفعلية</div>
                        <span class="trend-badge @GetTrendClass(_totalActual, _prevActual)">
                            @GetTrendText(_totalActual, _prevActual)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_totalActual)</div>
                    <div class="kpi-sub">القيمة المحققة من الصفقات الرابحة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">%</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">نسبة تحقيق الإيراد</div>
                        <span class="trend-badge @GetTrendClass(_achievementRate, _prevAchievementRate)">
                            @GetTrendText(_achievementRate, _prevAchievementRate)
                        </span>
                    </div>
                    <div class="kpi-value">@_achievementRate.ToString("F1")%</div>
                    <div class="kpi-progress">
                        <div class="kpi-progress-bar" style="@GetProgressBarStyle()"></div>
                    </div>
                    <div class="kpi-sub">الفعلي ÷ المتوقع × 100</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon @(_gapValue >= 0 ? "emerald" : "red")">
                    @(_gapValue >= 0 ? "+" : "−")
                </div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">الفجوة الحالية</div>
                        <span class="trend-badge @GetTrendClass(_wonCount, _prevWonCount)">
                            @GetTrendText(_wonCount, _prevWonCount)
                        </span>
                    </div>
                    <div class="kpi-value @(_gapValue >= 0 ? "pos" : "neg")">@FormatSignedMoney(_gapValue)</div>
                    <div class="kpi-sub">صفقات رابحة: @_wonCount — متوسط الصفقة: @FormatMoney(_avgDealValue)</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="rev3-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* MAIN DASHBOARD *@
        <section class="rev3-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>المتوقع / الفعلي / الفجوة الشهرية</h3>
                        <p>تحليل شهري يوضح قيمة المتوقع والفعلي والفارق بينهما</p>
                    </div>
                </div>

                @if (_trendPoints.Any())
                {
                    <ApexChart TItem="RevenueTrendPoint"
                               Options="_trendChartOptions"
                               Height="370">
                        <ApexPointSeries TItem="RevenueTrendPoint"
                                         Items="@_trendPoints"
                                         Name="المتوقع"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.Expected" />

                        <ApexPointSeries TItem="RevenueTrendPoint"
                                         Items="@_trendPoints"
                                         Name="الفعلي"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.Actual" />

                        <ApexPointSeries TItem="RevenueTrendPoint"
                                         Items="@_trendPoints"
                                         Name="الفجوة"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Month"
                                         YValue="x => x.Variance" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>أفضل الموظفين</h3>
                            <p>أعلى الموظفين من حيث المتوقع والفعلي</p>
                        </div>
                    </div>

                    @if (_employeeChartPoints.Any())
                    {
                        <ApexChart TItem="EmployeeChartPoint"
                                   Options="_employeeChartOptions"
                                   Height="300">
                            <ApexPointSeries TItem="EmployeeChartPoint"
                                             Items="@_employeeChartPoints"
                                             Name="المتوقع"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Employee"
                                             YValue="x => x.Expected" />

                            <ApexPointSeries TItem="EmployeeChartPoint"
                                             Items="@_employeeChartPoints"
                                             Name="الفعلي"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Employee"
                                             YValue="x => x.Actual" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض أداء الموظفين</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">المتوقع</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevExpected)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_totalExpected)</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">الفعلي</div>
                            <div class="compare-values">
                                <span>@FormatMoney(_prevActual)</span>
                                <span class="compare-arrow">←</span>
                                <strong>@FormatMoney(_totalActual)</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">نسبة التحقيق</div>
                            <div class="compare-values">
                                <span>@_prevAchievementRate.ToString("F1")%</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_achievementRate.ToString("F1")%</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">الصفقات الرابحة</div>
                            <div class="compare-values">
                                <span>@_prevWonCount</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_wonCount</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @(_achievementRate >= _prevAchievementRate ? "compare-good" : "compare-bad")">
                        @if (_achievementRate >= _prevAchievementRate)
                        {
                            <span>الأداء الحالي أفضل أو مساوي للفترة السابقة</span>
                        }
                        else
                        {
                            <span>الأداء الحالي أقل من الفترة السابقة ويحتاج مراجعة</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* MONTH DRILL-DOWN *@
        <section class="glass-card rev3-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down شهري</h3>
                    <p>اختر شهرًا لعرض التحليل التفصيلي اليومي وأداء الموظفين خلاله</p>
                </div>

                @if (_selectedMonthKey.HasValue)
                {
                    <button class="clear-month-btn" @onclick="ClearSelectedMonth">
                        إلغاء اختيار الشهر
                    </button>
                }
            </div>

            <div class="month-chip-row">
                @foreach (var month in _monthlyRows.OrderBy(x => x.Year).ThenBy(x => x.MonthNum))
                {
                    <button class="month-chip-btn @(IsSelectedMonth(month.Year, month.MonthNum) ? "month-chip-active" : "")"
                            @onclick="() => SelectMonth(month.Year, month.MonthNum)">
                        <span>@month.Month</span>
                        <small>@month.AchievementRate.ToString("F0")%</small>
                    </button>
                }
            </div>

            @if (_selectedMonthKey.HasValue)
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">الشهر المحدد</span>
                        <strong>@_selectedMonthLabel</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">المتوقع</span>
                        <strong>@FormatMoney(_selectedMonthExpected)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الفعلي</span>
                        <strong>@FormatMoney(_selectedMonthActual)</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">نسبة التحقيق</span>
                        <strong>@_selectedMonthRate.ToString("F1")%</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">الصفقات الرابحة</span>
                        <strong>@_selectedMonthWonCount</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">أفضل موظف</span>
                        <strong>@_selectedMonthTopEmployee</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>التحليل اليومي — @_selectedMonthLabel</h3>
                                <p>المتوقع والفعلي على مستوى الأيام داخل الشهر</p>
                            </div>
                        </div>

                        @if (_selectedMonthDailyPoints.Any())
                        {
                            <ApexChart TItem="DailyTrendPoint"
                                       Options="_dailyChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="DailyTrendPoint"
                                                 Items="@_selectedMonthDailyPoints"
                                                 Name="المتوقع"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Day"
                                                 YValue="x => x.Expected" />

                                <ApexPointSeries TItem="DailyTrendPoint"
                                                 Items="@_selectedMonthDailyPoints"
                                                 Name="الفعلي"
                                                 SeriesType="SeriesType.Line"
                                                 XValue="x => x.Day"
                                                 YValue="x => x.Actual" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات يومية للشهر المحدد</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>أفضل الموظفين في الشهر</h3>
                                <p>مقارنة المتوقع والفعلي للموظفين داخل الشهر المحدد</p>
                            </div>
                        </div>

                        @if (_selectedMonthEmployeePoints.Any())
                        {
                            <ApexChart TItem="EmployeeChartPoint"
                                       Options="_selectedMonthEmployeeChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="EmployeeChartPoint"
                                                 Items="@_selectedMonthEmployeePoints"
                                                 Name="المتوقع"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Employee"
                                                 YValue="x => x.Expected" />

                                <ApexPointSeries TItem="EmployeeChartPoint"
                                                 Items="@_selectedMonthEmployeePoints"
                                                 Name="الفعلي"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Employee"
                                                 YValue="x => x.Actual" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات كافية لعرض الموظفين في هذا الشهر</div>
                        }
                    </div>
                </div>
            }
        </section>

        @* TABLE *@
        <section class="glass-card rev3-table-card">
            <div class="card-head">
                <div>
                    <h3>التفاصيل الشهرية</h3>
                    <p>تفصيل شهري يوضح المتوقع والفعلي والفجوة ونسبة التحقيق</p>
                </div>
            </div>

            <MudTable Items="@_monthlyRows"
                      Hover="true"
                      Dense="true"
                      Elevation="0"
                      RowsPerPage="12"
                      Breakpoint="Breakpoint.Sm"
                      Class="premium-table">
                <HeaderContent>
                    <MudTh>الشهر</MudTh>
                    <MudTh>المتوقع</MudTh>
                    <MudTh>الفعلي</MudTh>
                    <MudTh>الفجوة</MudTh>
                    <MudTh>نسبة التحقيق</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="الشهر">@context.Month</MudTd>
                    <MudTd DataLabel="المتوقع">@FormatMoney(context.Expected)</MudTd>
                    <MudTd DataLabel="الفعلي">@FormatMoney(context.Actual)</MudTd>
                    <MudTd DataLabel="الفجوة">
                        <span class="variance-pill @(context.Variance >= 0 ? "variance-pos" : "variance-neg")">
                            @FormatSignedMoney(context.Variance)
                        </span>
                    </MudTd>
                    <MudTd DataLabel="نسبة التحقيق">
                        <span class="rate-pill">@context.AchievementRate.ToString("F1")%</span>
                    </MudTd>
                </RowTemplate>

                <NoRecordsContent>
                    <div class="empty-data">
                        <div class="empty-icon">📉</div>
                        <h4>لا توجد بيانات</h4>
                        <p>لا توجد نتائج مطابقة للفلاتر الحالية</p>
                    </div>
                </NoRecordsContent>
            </MudTable>
        </section>

        @* NOTE *@
        <section class="glass-card rev3-note">
            <div class="note-icon">ℹ️</div>
            <div class="note-body">
                <h4>ملاحظة تحليلية مهمة</h4>
                <p>
                    هذه النسخة تحسب الإيراد الفعلي من الصفقات ذات
                    <strong>StageId = @WonStageId</strong>
                    وتربطه بـ <strong>CreatedAt</strong>.
                    إذا كان لديك لاحقًا <strong>WonAt</strong> أو <strong>InvoiceDate</strong> أو <strong>PaymentDate</strong>،
                    فالأفضل استخدامه لرفع الدقة المالية للتقرير.
                </p>
            </div>
        </section>
    }
</div>

@code {
    private const int WonStageId = 3;

    private readonly CultureInfo _arCulture = new("ar-EG");

    private DateTime? _fromDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);
    private DateTime? _toDate = DateTime.Today;
    private int? _empId;
    private bool _isLoading;

    private List<EmployeeItem> _employees = new();
    private List<RevenueSourceRow> _currentRows = new();

    private List<MonthlyRow> _monthlyRows = new();
    private List<RevenueTrendPoint> _trendPoints = new();
    private List<EmployeeChartPoint> _employeeChartPoints = new();
    private List<InsightItem> _insights = new();

    private decimal _totalExpected;
    private decimal _totalActual;
    private decimal _gapValue;
    private double _achievementRate;
    private decimal _avgDealValue;
    private int _wonCount;

    private decimal _prevExpected;
    private decimal _prevActual;
    private double _prevAchievementRate;
    private int _prevWonCount;

    private string _previousPeriodLabel = "غير متاح";

    private DateTime? _selectedMonthKey;
    private string _selectedMonthLabel = "—";
    private decimal _selectedMonthExpected;
    private decimal _selectedMonthActual;
    private double _selectedMonthRate;
    private int _selectedMonthWonCount;
    private string _selectedMonthTopEmployee = "—";
    private List<DailyTrendPoint> _selectedMonthDailyPoints = new();
    private List<EmployeeChartPoint> _selectedMonthEmployeePoints = new();

    private ApexChartOptions<RevenueTrendPoint> _trendChartOptions = new();
    private ApexChartOptions<EmployeeChartPoint> _employeeChartOptions = new();
    private ApexChartOptions<DailyTrendPoint> _dailyChartOptions = new();
    private ApexChartOptions<EmployeeChartPoint> _selectedMonthEmployeeChartOptions = new();

    private string SelectedEmployeeLabel =>
        _empId.HasValue
            ? _employees.FirstOrDefault(x => x.Id == _empId.Value)?.Name ?? "موظف محدد"
            : "كل الموظفين";

    private string SelectedPeriodLabel =>
        $"{(_fromDate.HasValue ? _fromDate.Value.ToString("dd MMM yyyy", _arCulture) : "البداية")} — {(_toDate.HasValue ? _toDate.Value.ToString("dd MMM yyyy", _arCulture) : "اليوم")}";

    private string PreviousPeriodLabel => _previousPeriodLabel;

    protected override async Task OnInitializedAsync()
    {
        ConfigureCharts();
        await LoadEmployeesAsync();
        await LoadData();
    }

    private void ConfigureCharts()
    {
