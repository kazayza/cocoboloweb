    private void BuildMonthlyRows(List<LeadAnalysisRow> rows)
    {
        var startMonth = _fromDate.HasValue
            ? new DateTime(_fromDate.Value.Year, _fromDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-11);

        var endMonth = _toDate.HasValue
            ? new DateTime(_toDate.Value.Year, _toDate.Value.Month, 1)
            : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        var monthMap = rows
            .GroupBy(x => new DateTime(x.CreatedAt.Year, x.CreatedAt.Month, 1))
            .ToDictionary(g => g.Key, g => g.ToList());

        var list = new List<MonthlySummaryRow>();

        for (var month = startMonth; month <= endMonth; month = month.AddMonths(1))
        {
            monthMap.TryGetValue(month, out var monthRows);
            monthRows ??= new List<LeadAnalysisRow>();

            var total = monthRows.Count;
            var converted = monthRows.Count(x => x.IsConverted);
            var open = monthRows.Count(x => x.IsOpen);
            var won = monthRows.Count(x => x.IsWon);
            var lost = monthRows.Count(x => x.IsLost);

            list.Add(new MonthlySummaryRow
            {
                Year = month.Year,
                MonthNum = month.Month,
                Month = month.ToString("MMM yyyy", _arCulture),
                TotalLeads = total,
                ConvertedLeads = converted,
                OpenLeads = open,
                WonLeads = won,
                LostLeads = lost,
                ConversionRate = total > 0 ? (double)converted / total * 100d : 0d,
                SaleRate = total > 0 ? (double)won / total * 100d : 0d,
                OpenValue = monthRows.Where(x => x.IsOpen).Sum(x => x.ExpectedValue),
                WonValue = monthRows.Where(x => x.IsWon).Sum(x => x.ExpectedValue)
            });
        }

        _monthlyRows = list
            .OrderByDescending(x => x.Year)
            .ThenByDescending(x => x.MonthNum)
            .ToList();

        _monthlyTrendPoints = list
            .OrderBy(x => x.Year)
            .ThenBy(x => x.MonthNum)
            .Select(x => new MonthlyTrendPoint
            {
                Month = x.Month,
                TotalLeads = x.TotalLeads,
                ConvertedLeads = x.ConvertedLeads,
                WonLeads = x.WonLeads
            })
            .ToList();

        _monthlyRatePoints = list
            .OrderBy(x => x.Year)
            .ThenBy(x => x.MonthNum)
            .Select(x => new MonthlyRatePoint
            {
                Month = x.Month,
                ConversionRate = (decimal)x.ConversionRate,
                SaleRate = (decimal)x.SaleRate
            })
            .ToList();
    }

    private void ResolveSelectedMonth()
    {
        if (!_monthlyRows.Any())
        {
            _selectedMonthKey = null;
            return;
        }

        if (_selectedMonthKey.HasValue)
        {
            var selected = new DateTime(_selectedMonthKey.Value.Year, _selectedMonthKey.Value.Month, 1);
            var exists = _monthlyRows.Any(x => x.Year == selected.Year && x.MonthNum == selected.Month);

            if (exists)
            {
                _selectedMonthKey = selected;
                return;
            }
        }

        var latestWithData = _monthlyRows
            .Where(x => x.TotalLeads > 0)
            .OrderByDescending(x => x.Year)
            .ThenByDescending(x => x.MonthNum)
            .FirstOrDefault();

        if (latestWithData != null)
            _selectedMonthKey = new DateTime(latestWithData.Year, latestWithData.MonthNum, 1);
        else
            _selectedMonthKey = new DateTime(_monthlyRows.First().Year, _monthlyRows.First().MonthNum, 1);
    }

    private void BuildSelectedMonthAnalytics(List<LeadAnalysisRow> rows)
    {
        _selectedMonthLabel = "—";
        _selectedMonthTotalLeads = 0;
        _selectedMonthConverted = 0;
        _selectedMonthOpen = 0;
        _selectedMonthWon = 0;
        _selectedMonthLost = 0;
        _selectedMonthConversionRate = 0d;
        _selectedMonthSaleRate = 0d;
        _selectedMonthFunnelPoints = new();
        _selectedMonthDealPoints = new();
        _detailRows = new();

        if (!_selectedMonthKey.HasValue)
        {
            _detailRows = rows
                .Where(x => x.IsConverted)
                .OrderByDescending(x => x.ExpectedValue)
                .ThenByDescending(x => x.CreatedAt)
                .Take(25)
                .Select(MapDetailRow)
                .ToList();

            return;
        }

        var month = _selectedMonthKey.Value;
        _selectedMonthLabel = month.ToString("MMMM yyyy", _arCulture);

        var monthRows = rows
            .Where(x => x.CreatedAt.Year == month.Year && x.CreatedAt.Month == month.Month)
            .ToList();

        _selectedMonthTotalLeads = monthRows.Count;
        _selectedMonthConverted = monthRows.Count(x => x.IsConverted);
        _selectedMonthOpen = monthRows.Count(x => x.IsOpen);
        _selectedMonthWon = monthRows.Count(x => x.IsWon);
        _selectedMonthLost = monthRows.Count(x => x.IsLost);

        _selectedMonthConversionRate = _selectedMonthTotalLeads > 0
            ? (double)_selectedMonthConverted / _selectedMonthTotalLeads * 100d
            : 0d;

        _selectedMonthSaleRate = _selectedMonthTotalLeads > 0
            ? (double)_selectedMonthWon / _selectedMonthTotalLeads * 100d
            : 0d;

        _selectedMonthFunnelPoints = new List<SelectedMonthFunnelPoint>
        {
            new() { Stage = "Leads", Count = _selectedMonthTotalLeads },
            new() { Stage = "تم التحويل", Count = _selectedMonthConverted },
            new() { Stage = "قيد التنفيذ", Count = _selectedMonthOpen },
            new() { Stage = "تم البيع", Count = _selectedMonthWon },
            new() { Stage = "مفقودة", Count = _selectedMonthLost }
        };

        _selectedMonthDealPoints = monthRows
            .Where(x => x.IsConverted)
            .OrderByDescending(x => x.ExpectedValue)
            .ThenByDescending(x => x.CreatedAt)
            .Take(8)
            .Select(x => new SelectedMonthDealPoint
            {
                Deal = x.ClientName,
                Value = x.ExpectedValue
            })
            .ToList();

        _detailRows = monthRows
            .Where(x => x.IsConverted)
            .OrderByDescending(x => x.ExpectedValue)
            .ThenByDescending(x => x.CreatedAt)
            .Select(MapDetailRow)
            .ToList();
    }

    private LeadDealDetailRow MapDetailRow(LeadAnalysisRow x) => new()
    {
        ClientName = x.ClientName,
        StageName = x.StageName,
        StageColor = x.StageColor,
        CreatedAt = x.CreatedAt,
        ExpectedValue = x.ExpectedValue,
        Status = x.IsWon ? "تم البيع" : x.IsLost ? "مفقودة" : x.IsOpen ? "قيد التنفيذ" : "تم التحويل"
    };

    private void BuildInsights()
    {
        _insights = new();

        var validMonths = _monthlyRows.Where(x => x.TotalLeads > 0).ToList();

        if (validMonths.Any())
        {
            var bestConversion = validMonths
                .OrderByDescending(x => x.ConversionRate)
                .ThenByDescending(x => x.ConvertedLeads)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.TrendingUp,
                Title = "أفضل شهر تحويل",
                Value = bestConversion.Month,
                Description = $"{bestConversion.ConversionRate:F1}% — {bestConversion.ConvertedLeads} Lead",
                ToneClass = "tone-indigo"
            });

            var bestSales = validMonths
                .OrderByDescending(x => x.WonLeads)
                .ThenByDescending(x => x.WonValue)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.EmojiEvents,
                Title = "أفضل شهر بيع",
                Value = bestSales.Month,
                Description = $"{bestSales.WonLeads} فوز — {FormatMoney(bestSales.WonValue)}",
                ToneClass = "tone-green"
            });

            var highestOpen = validMonths
                .OrderByDescending(x => x.OpenValue)
                .ThenByDescending(x => x.OpenLeads)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.HourglassTop,
                Title = "أكبر Pipeline مفتوح",
                Value = highestOpen.Month,
                Description = $"{FormatMoney(highestOpen.OpenValue)} من Leads الشهر",
                ToneClass = "tone-gold"
            });

            var highestLoss = validMonths
                .OrderByDescending(x => x.LostLeads)
                .ThenByDescending(x => x.TotalLeads)
                .First();

            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.ReportProblem,
                Title = "أعلى تسرب",
                Value = highestLoss.Month,
                Description = $"{highestLoss.LostLeads} Lead مفقودة بعد التحويل",
                ToneClass = "tone-red"
            });
        }

        while (_insights.Count < 4)
        {
            _insights.Add(new InsightItem
            {
                Icon = Icons.Material.Rounded.Insights,
                Title = "معلومة",
                Value = "—",
                Description = "لا توجد بيانات كافية لهذا المؤشر",
                ToneClass = "tone-slate"
            });
        }
    }

    private void SelectMonth(int year, int month)
    {
        _selectedMonthKey = new DateTime(year, month, 1);
        BuildSelectedMonthAnalytics(_currentRows);
    }

    private void ClearSelectedMonth()
    {
        _selectedMonthKey = null;
        BuildSelectedMonthAnalytics(_currentRows);
    }

    private bool IsSelectedMonth(int year, int month)
        => _selectedMonthKey.HasValue
           && _selectedMonthKey.Value.Year == year
           && _selectedMonthKey.Value.Month == month;

    private bool TryGetPreviousRange(out DateTime previousFrom, out DateTime previousTo)
    {
        previousFrom = default;
        previousTo = default;

        if (!_fromDate.HasValue || !_toDate.HasValue)
            return false;

        var currentFrom = _fromDate.Value.Date;
        var currentTo = _toDate.Value.Date;
        var days = (currentTo - currentFrom).Days;

        previousTo = currentFrom.AddDays(-1);
        previousFrom = previousTo.AddDays(-days);

        return true;
    }

    private void NormalizeDateRange()
    {
        if (_fromDate.HasValue && _toDate.HasValue && _fromDate.Value.Date > _toDate.Value.Date)
        {
            var temp = _fromDate;
            _fromDate = _toDate;
            _toDate = temp;

            Snackbar.Add("تم تبديل تاريخ البداية والنهاية تلقائيًا لأن البداية كانت أكبر من النهاية.", Severity.Info);
        }
    }

    private async Task ExportCsvAsync()
    {
        try
        {
            var sb = new StringBuilder();

            sb.AppendLine("تقرير تحويل العملاء المحتملين");
            sb.AppendLine($"الفترة الحالية,{SelectedPeriodLabel}");
            sb.AppendLine($"الفترة السابقة,{PreviousPeriodLabel}");
            sb.AppendLine();

            sb.AppendLine("المؤشرات الرئيسية");
            sb.AppendLine("المؤشر,القيمة");
            sb.AppendLine($"إجمالي العملاء المحتملين,{_totalLeads}");
            sb.AppendLine($"تم التحويل,{_convertedLeads}");
            sb.AppendLine($"قيد التنفيذ,{_openLeads}");
            sb.AppendLine($"تم البيع,{_wonLeads}");
            sb.AppendLine($"مفقودة,{_lostLeads}");
            sb.AppendLine($"نسبة التحويل,{_conversionRate:F1}%");
            sb.AppendLine($"نسبة البيع,{_saleRate:F1}%");
            sb.AppendLine($"قيمة الفرص المفتوحة,{_openValue:N0}");
            sb.AppendLine($"قيمة البيع,{_wonValue:N0}");
            sb.AppendLine();

            sb.AppendLine("مراحل الـ Funnel");
            sb.AppendLine("المرحلة,العدد,النسبة,القيمة");
            foreach (var row in _funnelRows.OrderBy(x => x.Sort))
            {
                sb.AppendLine($"{row.Stage},{row.Count},{row.Percent:F1}%,{row.Value:N0}");
            }

            sb.AppendLine();
            sb.AppendLine("التفاصيل الشهرية");
            sb.AppendLine("الشهر,Leads,تم التحويل,قيد التنفيذ,تم البيع,مفقودة,نسبة التحويل,نسبة البيع");
            foreach (var row in _monthlyRows.OrderBy(x => x.Year).ThenBy(x => x.MonthNum))
            {
                sb.AppendLine($"{row.Month},{row.TotalLeads},{row.ConvertedLeads},{row.OpenLeads},{row.WonLeads},{row.LostLeads},{row.ConversionRate:F1}%,{row.SaleRate:F1}%");
            }

            sb.AppendLine();
            sb.AppendLine("تفاصيل الفرص المحولة");
            sb.AppendLine("العميل,الحالة,المرحلة,تاريخ إنشاء الـ Lead,القيمة");
            foreach (var row in _detailRows)
            {
                sb.AppendLine($"{row.ClientName},{row.Status},{row.StageName},{FormatDate(row.CreatedAt)},{row.ExpectedValue:N0}");
            }

            var csv = sb.ToString();
            var fileName = $"lead-conversion-{DateTime.Now:yyyyMMdd-HHmm}.csv";
            var dataUrl = "data:text/csv;charset=utf-8,\uFEFF" + Uri.EscapeDataString(csv);

            var script = $@"
                (function() {{
                    const link = document.createElement('a');
                    link.href = '{dataUrl}';
                    link.download = '{fileName}';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }})();";

            await JS.InvokeVoidAsync("eval", script);
            Snackbar.Add("تم تصدير الملف بنجاح. يمكنك فتحه مباشرة في Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تصدير الملف: {ex.Message}", Severity.Error);
        }
    }

    private async Task PrintAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "window.print()");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"تعذر تشغيل الطباعة: {ex.Message}", Severity.Error);
        }
    }

    private string FormatMoney(decimal value) => $"{value:N0} ج.م";
    private string FormatDate(DateTime? value) => value?.ToString("yyyy/MM/dd") ?? "—";

    private string GetSummaryRingStyle()
    {
        var safe = Math.Max(0, Math.Min(_conversionRate, 100));
        var angle = safe * 3.6;
        return $"background: conic-gradient(#8b5cf6 0deg, #8b5cf6 {angle:F1}deg, rgba(255,255,255,.12) {angle:F1}deg, rgba(255,255,255,.12) 360deg);";
    }

    private string GetConversionProgressStyle()
    {
        var safe = Math.Max(0, Math.Min(_conversionRate, 100));
        return $"width:{safe:F0}%";
    }

    private string GetTrendClass(int current, int previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(double current, double previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendClass(decimal current, decimal previous)
    {
        if (current > previous) return "trend-up";
        if (current < previous) return "trend-down";
        return "trend-flat";
    }

    private string GetTrendText(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? "0%" : "جديد";

        var change = ((double)(current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(double current, double previous)
    {
        if (Math.Abs(previous) < 0.000001)
            return Math.Abs(current) < 0.000001 ? "0%" : "جديد";

        var change = ((current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetTrendText(decimal current, decimal previous)
    {
        if (previous == 0m)
            return current == 0m ? "0%" : "جديد";

        var change = (double)((current - previous) / previous * 100m);
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string GetRatePillClass(double rate)
    {
        if (rate >= 50) return "rate-good";
        if (rate >= 25) return "rate-mid";
        return "rate-bad";
    }

    private string GetSalePillClass(double rate)
    {
        if (rate >= 20) return "rate-good";
        if (rate >= 10) return "rate-mid";
        return "rate-bad";
    }

