        _prevWonLeads = rows.Count(x => x.IsWon);
        _prevLostLeads = rows.Count(x => x.IsLost);

        _prevConversionRate = _prevTotalLeads > 0 ? (double)_prevConvertedLeads / _prevTotalLeads * 100d : 0d;
        _prevSaleRate = _prevTotalLeads > 0 ? (double)_prevWonLeads / _prevTotalLeads * 100d : 0d;

        _prevConvertedValue = rows.Where(x => x.IsConverted).Sum(x => x.ExpectedValue);
        _prevOpenValue = rows.Where(x => x.IsOpen).Sum(x => x.ExpectedValue);
        _prevWonValue = rows.Where(x => x.IsWon).Sum(x => x.ExpectedValue);
        _prevLostValue = rows.Where(x => x.IsLost).Sum(x => x.ExpectedValue);
    }

