    private async Task SetCurrentYearAsync()
    {
        _fromDate = new DateTime(DateTime.Today.Year, 1, 1);
        _toDate = DateTime.Today;
        _selectedMonthKey = null;

        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;

        try
        {
            NormalizeDateRange();

            await using var db = await DbFactory.CreateDbContextAsync();

            _currentRows = await LoadLeadSnapshotAsync(db, _fromDate, _toDate);

            if (TryGetPreviousRange(out var prevFrom, out var prevTo))
            {
                _previousPeriodLabel = $"{prevFrom.ToString("dd MMM yyyy", _arCulture)} — {prevTo.ToString("dd MMM yyyy", _arCulture)}";
                var previousRows = await LoadLeadSnapshotAsync(db, prevFrom, prevTo);
                CalculatePreviousMetrics(previousRows);
            }
            else
            {
                _previousPeriodLabel = "غير متاح";
                ResetPreviousMetrics();
            }

            CalculateCurrentMetrics(_currentRows);
            BuildFunnelRows(_currentRows);
            BuildMonthlyRows(_currentRows);
            ResolveSelectedMonth();
            BuildSelectedMonthAnalytics(_currentRows);
            BuildInsights();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"حدث خطأ أثناء تحميل التقرير: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<List<LeadAnalysisRow>> LoadLeadSnapshotAsync(db24804Context db, DateTime? from, DateTime? to)
    {
        var query = db.LeadsCRMs.AsNoTracking().AsQueryable();

        if (from.HasValue)
        {
            var fromDate = from.Value.Date;
            query = query.Where(l => l.CreatedAt >= fromDate);
        }

        if (to.HasValue)
        {
            var toExclusive = to.Value.Date.AddDays(1);
            query = query.Where(l => l.CreatedAt < toExclusive);
        }

        var leads = await query
            .Select(l => new LeadSourceRow
            {
                CreatedAt = l.CreatedAt,
                ConvertedOpportunityId = l.ConvertedOpportunityId
            })
            .ToListAsync();

        var oppIds = leads
            .Where(x => x.ConvertedOpportunityId.HasValue)
            .Select(x => x.ConvertedOpportunityId!.Value)
            .Distinct()
            .ToList();

        var oppMap = new Dictionary<int, OpportunityRefRow>();

        if (oppIds.Any())
        {
            var opportunities = await db.VwSalesOpportunities
                .AsNoTracking()
                .Where(o => oppIds.Contains(o.OpportunityId))
                .Select(o => new OpportunityRefRow
                {
                    OpportunityId = o.OpportunityId,
                    StageId = o.StageId,
                    ExpectedValue = o.ExpectedValue ?? 0m,
                    ClientName = o.ClientName ?? "—",
                    StageName = o.StageNameAr ?? o.StageName ?? "—",
                    StageColor = o.StageColor ?? ""
                })
                .ToListAsync();

            oppMap = opportunities.ToDictionary(x => x.OpportunityId, x => x);
        }

        var result = new List<LeadAnalysisRow>(leads.Count);

        foreach (var lead in leads)
        {
            OpportunityRefRow? opp = null;

            if (lead.ConvertedOpportunityId.HasValue)
                oppMap.TryGetValue(lead.ConvertedOpportunityId.Value, out opp);

            var isConverted = lead.ConvertedOpportunityId.HasValue;
            var isWon = opp is not null && opp.StageId == WonStageId;
            var isLost = opp is not null && (opp.StageId == LostStageId1 || opp.StageId == LostStageId2);
            var isOpen = opp is not null && !isWon && !isLost;

            result.Add(new LeadAnalysisRow
            {
                CreatedAt = lead.CreatedAt,
                ConvertedOpportunityId = lead.ConvertedOpportunityId,
                IsConverted = isConverted,
                IsWon = isWon,
                IsLost = isLost,
                IsOpen = isOpen,
                ExpectedValue = opp?.ExpectedValue ?? 0m,
                ClientName = opp?.ClientName ?? "—",
                StageName = opp?.StageName ?? "—",
                StageColor = opp?.StageColor ?? ""
            });
        }

        return result;
    }

    private void CalculateCurrentMetrics(List<LeadAnalysisRow> rows)
    {
        _totalLeads = rows.Count;
        _convertedLeads = rows.Count(x => x.IsConverted);
        _openLeads = rows.Count(x => x.IsOpen);
        _wonLeads = rows.Count(x => x.IsWon);
        _lostLeads = rows.Count(x => x.IsLost);

        _conversionRate = _totalLeads > 0 ? (double)_convertedLeads / _totalLeads * 100d : 0d;
        _saleRate = _totalLeads > 0 ? (double)_wonLeads / _totalLeads * 100d : 0d;

        _convertedValue = rows.Where(x => x.IsConverted).Sum(x => x.ExpectedValue);
        _openValue = rows.Where(x => x.IsOpen).Sum(x => x.ExpectedValue);
        _wonValue = rows.Where(x => x.IsWon).Sum(x => x.ExpectedValue);
        _lostValue = rows.Where(x => x.IsLost).Sum(x => x.ExpectedValue);
    }

    private void CalculatePreviousMetrics(List<LeadAnalysisRow> rows)
