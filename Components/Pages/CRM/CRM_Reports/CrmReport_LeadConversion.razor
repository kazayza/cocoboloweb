@page "/crm/reports/lead-conversion"

@using System.Globalization
@using System.Text
@using ApexCharts
@using COCOBOLOERPNEW.Models
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject IDbContextFactory<db24804Context> DbFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>تقرير تحويل العملاء المحتملين</PageTitle>

<div class="ldcv-page" dir="rtl">

    @* Background *@
    <div class="ldcv-bg">
        <div class="ldcv-orb orb-1"></div>
        <div class="ldcv-orb orb-2"></div>
        <div class="ldcv-orb orb-3"></div>
    </div>

    @* HERO *@
    <section class="ldcv-hero">
        <div class="ldcv-hero-grid"></div>

        <div class="ldcv-hero-content">
            <div class="ldcv-hero-top">
                <button class="ldcv-back" @onclick="GoBack" title="رجوع">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>

                <div class="ldcv-badge">
                    <span class="badge-dot"></span>
                    <span>Lead Conversion Intelligence</span>
                </div>
            </div>

            <div class="ldcv-hero-main">
                <div class="ldcv-hero-text">
                    <h1>تحويل <span>العملاء المحتملين</span></h1>
                    <p>
                        لوحة تنفيذية متقدمة لتحليل رحلة الـ Leads من الإنشاء وحتى التحويل إلى فرص،
                        ثم الوصول للبيع أو التعثر، مع قياس نسب التحويل والقيم الناتجة عبر الزمن.
                    </p>

                    <div class="ldcv-hero-chips">
                        <div class="hero-chip">
                            <span class="chip-label">الفترة الحالية</span>
                            <span class="chip-value">@SelectedPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">الفترة السابقة</span>
                            <span class="chip-value">@PreviousPeriodLabel</span>
                        </div>

                        <div class="hero-chip">
                            <span class="chip-label">قيمة البيع من الـ Leads</span>
                            <span class="chip-value">@FormatMoney(_wonValue)</span>
                        </div>
                    </div>
                </div>

                <div class="ldcv-hero-side">
                    <div class="summary-ring" style="@GetSummaryRingStyle()">
                        <div class="summary-ring-inner">
                            <div class="summary-percent">@_conversionRate.ToString("F1")%</div>
                            <div class="summary-caption">نسبة التحويل</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* FILTERS / ACTIONS *@
    <section class="glass-card ldcv-filters">
        <div class="filters-head">
            <div>
                <h3>الفلاتر والتحكم</h3>
                <p>اختر الفترة الزمنية أو استخدم الفترات السريعة لتحليل الـ Funnel</p>
            </div>

            <div class="filters-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Default"
                           StartIcon="@Icons.Material.Rounded.RestartAlt"
                           OnClick="ResetFiltersAsync"
                           Disabled="_isLoading">
                    إعادة ضبط
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="@MudColor.Primary"
                           StartIcon="@Icons.Material.Rounded.FilterAlt"
                           OnClick="LoadData"
                           Disabled="_isLoading">
                    تطبيق التحليل
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Success"
                           StartIcon="@Icons.Material.Rounded.FileDownload"
                           OnClick="ExportCsvAsync"
                           Disabled="_isLoading">
                    تصدير CSV
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="@MudColor.Info"
                           StartIcon="@Icons.Material.Rounded.Print"
                           OnClick="PrintAsync"
                           Disabled="_isLoading">
                    طباعة / PDF
                </MudButton>
            </div>
        </div>

        <div class="quick-range-row">
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(3)">آخر 3 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(6)">آخر 6 شهور</button>
            <button class="quick-range-btn" @onclick="async () => await SetLastMonthsAsync(12)">آخر 12 شهر</button>
            <button class="quick-range-btn" @onclick="SetCurrentYearAsync">السنة الحالية</button>
        </div>

        <div class="filters-grid">
            <MudDatePicker @bind-Date="_fromDate"
                           Label="من تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />

            <MudDatePicker @bind-Date="_toDate"
                           Label="إلى تاريخ"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Editable="true"
                           Class="filter-field" />
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="glass-card ldcv-loading">
            <MudProgressCircular Indeterminate="true"
                                 Size="@MudSize.Large"
                                 Color="@MudColor.Primary" />
            <div class="loading-text">
                <h3>جاري تحليل التحويل...</h3>
                <p>يتم تجهيز المؤشرات، الرسوم البيانية، ومسار الـ Funnel</p>
            </div>
        </div>
    }
    else
    {
        @* KPI *@
        <section class="ldcv-kpis">
            <div class="glass-card kpi-card">
                <div class="kpi-icon blue">#</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">إجمالي العملاء المحتملين</div>
                        <span class="trend-badge @GetTrendClass(_totalLeads, _prevTotalLeads)">
                            @GetTrendText(_totalLeads, _prevTotalLeads)
                        </span>
                    </div>
                    <div class="kpi-value">@_totalLeads.ToString("N0")</div>
                    <div class="kpi-sub">كل الـ Leads التي تم إنشاؤها خلال الفترة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon purple">⇢</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">تم التحويل إلى فرص</div>
                        <span class="trend-badge @GetTrendClass(_convertedLeads, _prevConvertedLeads)">
                            @GetTrendText(_convertedLeads, _prevConvertedLeads)
                        </span>
                    </div>
                    <div class="kpi-value">@_convertedLeads.ToString("N0")</div>
                    <div class="kpi-sub">Leads مرتبطة بفرص بيع فعلية</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon orange">◎</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">فرص مفتوحة من الـ Leads</div>
                        <span class="trend-badge @GetTrendClass(_openLeads, _prevOpenLeads)">
                            @GetTrendText(_openLeads, _prevOpenLeads)
                        </span>
                    </div>
                    <div class="kpi-value">@_openLeads.ToString("N0")</div>
                    <div class="kpi-sub">Leads تحولت وما زالت قيد التنفيذ</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon green">✓</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">تم البيع</div>
                        <span class="trend-badge @GetTrendClass(_wonLeads, _prevWonLeads)">
                            @GetTrendText(_wonLeads, _prevWonLeads)
                        </span>
                    </div>
                    <div class="kpi-value success">@_wonLeads.ToString("N0")</div>
                    <div class="kpi-sub">Leads انتهت إلى صفقات رابحة</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon amber">%</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">نسبة التحويل إلى فرص</div>
                        <span class="trend-badge @GetTrendClass(_conversionRate, _prevConversionRate)">
                            @GetTrendText(_conversionRate, _prevConversionRate)
                        </span>
                    </div>
                    <div class="kpi-value">@_conversionRate.ToString("F1")%</div>
                    <div class="kpi-progress">
                        <div class="kpi-progress-bar" style="@GetConversionProgressStyle()"></div>
                    </div>
                    <div class="kpi-sub">تم التحويل ÷ إجمالي Leads × 100</div>
                </div>
            </div>

            <div class="glass-card kpi-card">
                <div class="kpi-icon teal">₪</div>
                <div class="kpi-body">
                    <div class="kpi-head-row">
                        <div class="kpi-label">Pipeline مفتوح من الـ Leads</div>
                        <span class="trend-badge @GetTrendClass(_openValue, _prevOpenValue)">
                            @GetTrendText(_openValue, _prevOpenValue)
                        </span>
                    </div>
                    <div class="kpi-value">@FormatMoney(_openValue)</div>
                    <div class="kpi-sub">قيمة الفرص المفتوحة الناتجة من الـ Leads</div>
                </div>
            </div>
        </section>

        @* INSIGHTS *@
        <section class="ldcv-insights">
            @foreach (var insight in _insights)
            {
                <div class="glass-card insight-card">
                    <div class="insight-icon @insight.ToneClass">
                        <MudIcon Icon="@insight.Icon" Size="@MudSize.Small" />
                    </div>
                    <div class="insight-body">
                        <div class="insight-title">@insight.Title</div>
                        <div class="insight-value">@insight.Value</div>
                        <div class="insight-desc">@insight.Description</div>
                    </div>
                </div>
            }
        </section>

        @* MAIN DASHBOARD *@
        <section class="ldcv-dashboard">
            <div class="glass-card main-chart-card">
                <div class="card-head">
                    <div>
                        <h3>الاتجاه الشهري للتحويل</h3>
                        <p>إجمالي Leads مقابل المحول منها والمكتمل بيعها حسب شهر إنشاء الـ Lead</p>
                    </div>
                </div>

                @if (_monthlyTrendPoints.Any())
                {
                    <ApexChart TItem="MonthlyTrendPoint"
                               Options="_monthlyTrendChartOptions"
                               Height="380">
                        <ApexPointSeries TItem="MonthlyTrendPoint"
                                         Items="@_monthlyTrendPoints"
                                         Name="Leads"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.TotalLeads" />

                        <ApexPointSeries TItem="MonthlyTrendPoint"
                                         Items="@_monthlyTrendPoints"
                                         Name="تم التحويل"
                                         SeriesType="SeriesType.Bar"
                                         XValue="x => x.Month"
                                         YValue="x => x.ConvertedLeads" />

                        <ApexPointSeries TItem="MonthlyTrendPoint"
                                         Items="@_monthlyTrendPoints"
                                         Name="تم البيع"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Month"
                                         YValue="x => x.WonLeads" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="side-stack">
                <div class="glass-card side-card">
                    <div class="card-head">
                        <div>
                            <h3>توزيع مراحل الـ Funnel</h3>
                            <p>عدد الحالات داخل كل مرحلة من رحلة التحويل</p>
                        </div>
                    </div>

                    @if (_funnelStagePoints.Any())
                    {
                        <ApexChart TItem="FunnelStagePoint"
                                   Options="_funnelStageChartOptions"
                                   Height="320">
                            <ApexPointSeries TItem="FunnelStagePoint"
                                             Items="@_funnelStagePoints"
                                             Name="العدد"
                                             SeriesType="SeriesType.Bar"
                                             XValue="x => x.Stage"
                                             YValue="x => x.Count" />
                        </ApexChart>
                    }
                    else
                    {
                        <div class="chart-empty small">لا توجد بيانات كافية لعرض المراحل</div>
                    }
                </div>

                <div class="glass-card side-card compare-card">
                    <div class="card-head">
                        <div>
                            <h3>مقارنة بالفترة السابقة</h3>
                            <p>@PreviousPeriodLabel</p>
                        </div>
                    </div>

                    <div class="compare-list">
                        <div class="compare-row">
                            <div class="compare-label">إجمالي Leads</div>
                            <div class="compare-values">
                                <span>@_prevTotalLeads</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_totalLeads</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">تم التحويل</div>
                            <div class="compare-values">
                                <span>@_prevConvertedLeads</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_convertedLeads</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">تم البيع</div>
                            <div class="compare-values">
                                <span>@_prevWonLeads</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_wonLeads</strong>
                            </div>
                        </div>

                        <div class="compare-row">
                            <div class="compare-label">نسبة التحويل</div>
                            <div class="compare-values">
                                <span>@_prevConversionRate.ToString("F1")%</span>
                                <span class="compare-arrow">←</span>
                                <strong>@_conversionRate.ToString("F1")%</strong>
                            </div>
                        </div>
                    </div>

                    <div class="compare-summary @(_conversionRate >= _prevConversionRate ? "compare-good" : "compare-mid")">
                        @if (_conversionRate >= _prevConversionRate)
                        {
                            <span>معدل التحويل الحالي أفضل أو مساوي للفترة السابقة</span>
                        }
                        else
                        {
                            <span>معدل التحويل الحالي أقل من الفترة السابقة ويحتاج تحسين</span>
                        }
                    </div>
                </div>
            </div>
        </section>

        @* ANALYTICS GRID *@
        <section class="ldcv-analytics-grid">
            <div class="glass-card side-card">
                <div class="card-head">
                    <div>
                        <h3>اتجاه نسب التحويل</h3>
                        <p>نسبة التحويل إلى فرص ونسبة البيع من الـ Leads عبر الشهور</p>
                    </div>
                </div>

                @if (_monthlyRatePoints.Any())
                {
                    <ApexChart TItem="MonthlyRatePoint"
                               Options="_monthlyRateChartOptions"
                               Height="320">
                        <ApexPointSeries TItem="MonthlyRatePoint"
                                         Items="@_monthlyRatePoints"
                                         Name="تحويل إلى فرص %"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Month"
                                         YValue="x => x.ConversionRate" />

                        <ApexPointSeries TItem="MonthlyRatePoint"
                                         Items="@_monthlyRatePoints"
                                         Name="تحويل إلى بيع %"
                                         SeriesType="SeriesType.Line"
                                         XValue="x => x.Month"
                                         YValue="x => x.SaleRate" />
                    </ApexChart>
                }
                else
                {
                    <div class="chart-empty small">لا توجد بيانات كافية لعرض النسب</div>
                }
            </div>

            <div class="glass-card ldcv-stage-table-card">
                <div class="card-head">
                    <div>
                        <h3>تفاصيل مراحل الـ Funnel</h3>
                        <p>عدد الحالات والنسب والقيم في كل خطوة من رحلة التحويل</p>
                    </div>
                </div>

                <MudTable Items="@_funnelRows"
                          Hover="true"
                          Dense="true"
                          Elevation="0"
                          RowsPerPage="10"
                          Breakpoint="Breakpoint.Sm"
                          Class="premium-table">
                    <HeaderContent>
                        <MudTh>المرحلة</MudTh>
                        <MudTh>العدد</MudTh>
                        <MudTh>النسبة</MudTh>
                        <MudTh>القيمة</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="المرحلة">
                            <span class="stage-pill" style="@($"background:{context.Color};color:#fff;")">
                                @context.Stage
                            </span>
                        </MudTd>
                        <MudTd DataLabel="العدد">@context.Count.ToString("N0")</MudTd>
                        <MudTd DataLabel="النسبة">
                            <span class="rate-pill @GetRatePillClass(context.Percent)">
                                @context.Percent.ToString("F1")%
                            </span>
                        </MudTd>
                        <MudTd DataLabel="القيمة">@FormatMoney(context.Value)</MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <div class="empty-data">
                            <div class="empty-icon">📉</div>
                            <h4>لا توجد بيانات</h4>
                            <p>لا توجد مراحل مطابقة للفلاتر الحالية</p>
                        </div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </section>

        @* MONTH DRILL-DOWN *@
        <section class="glass-card ldcv-drill">
            <div class="card-head drill-head">
                <div>
                    <h3>Drill-down حسب الشهر</h3>
                    <p>اختر شهرًا لتحليل مسار التحويل الخاص بالـ Leads التي أُنشئت خلاله</p>
                </div>

                @if (_selectedMonthKey.HasValue)
                {
                    <button class="clear-month-btn" @onclick="ClearSelectedMonth">
                        إلغاء اختيار الشهر
                    </button>
                }
            </div>

            <div class="month-chip-row">
                @foreach (var month in _monthlyRows.OrderBy(x => x.Year).ThenBy(x => x.MonthNum))
                {
                    <button class="month-chip-btn @(IsSelectedMonth(month.Year, month.MonthNum) ? "month-chip-active" : "")"
                            @onclick="() => SelectMonth(month.Year, month.MonthNum)">
                        <span>@month.Month</span>
                        <small>@month.ConversionRate.ToString("F0")%</small>
                    </button>
                }
            </div>

            @if (_selectedMonthKey.HasValue || _detailRows.Any())
            {
                <div class="drill-mini-kpis">
                    <div class="mini-kpi">
                        <span class="mini-label">الشهر المحدد</span>
                        <strong>@_selectedMonthLabel</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">Leads</span>
                        <strong>@_selectedMonthTotalLeads.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">تم التحويل</span>
                        <strong>@_selectedMonthConverted.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">قيد التنفيذ</span>
                        <strong>@_selectedMonthOpen.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">تم البيع</span>
                        <strong>@_selectedMonthWon.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">مفقودة</span>
                        <strong>@_selectedMonthLost.ToString("N0")</strong>
                    </div>
                    <div class="mini-kpi">
                        <span class="mini-label">نسبة التحويل</span>
                        <strong>@_selectedMonthConversionRate.ToString("F1")%</strong>
                    </div>
                </div>

                <div class="drill-grid">
                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>Funnel الشهر المحدد</h3>
                                <p>التوزيع المرحلي للـ Leads في الشهر المحدد</p>
                            </div>
                        </div>

                        @if (_selectedMonthFunnelPoints.Any())
                        {
                            <ApexChart TItem="SelectedMonthFunnelPoint"
                                       Options="_selectedMonthFunnelChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="SelectedMonthFunnelPoint"
                                                 Items="@_selectedMonthFunnelPoints"
                                                 Name="العدد"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Stage"
                                                 YValue="x => x.Count" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد بيانات كافية لهذا الشهر</div>
                        }
                    </div>

                    <div class="glass-inner-card">
                        <div class="card-head">
                            <div>
                                <h3>أكبر الفرص المحولة في الشهر</h3>
                                <p>أعلى الفرص الناتجة من Leads الشهر المحدد حسب القيمة</p>
                            </div>
                        </div>

                        @if (_selectedMonthDealPoints.Any())
                        {
                            <ApexChart TItem="SelectedMonthDealPoint"
                                       Options="_selectedMonthDealsChartOptions"
                                       Height="320">
                                <ApexPointSeries TItem="SelectedMonthDealPoint"
                                                 Items="@_selectedMonthDealPoints"
                                                 Name="القيمة"
                                                 SeriesType="SeriesType.Bar"
                                                 XValue="x => x.Deal"
                                                 YValue="x => x.Value" />
                            </ApexChart>
                        }
                        else
                        {
                            <div class="chart-empty small">لا توجد فرص محولة كافية داخل الشهر المحدد</div>
                        }
                    </div>
                </div>
            }
        </section>

        @* MONTHLY DETAILS TABLE *@
        <section class="glass-card ldcv-table-card">
            <div class="card-head">
                <div>
                    <h3>التفاصيل الشهرية</h3>
                    <p>ملخص شهري لرحلة التحويل من Lead إلى Opportunity ثم إلى Sale</p>
                </div>
            </div>

            <MudTable Items="@_monthlyRows"
                      Hover="true"
                      Dense="true"
                      Elevation="0"
                      RowsPerPage="12"
                      Breakpoint="Breakpoint.Sm"
                      Class="premium-table">
                <HeaderContent>
                    <MudTh>الشهر</MudTh>
                    <MudTh>Leads</MudTh>
                    <MudTh>تم التحويل</MudTh>
                    <MudTh>قيد التنفيذ</MudTh>
                    <MudTh>تم البيع</MudTh>
                    <MudTh>مفقودة</MudTh>
                    <MudTh>نسبة التحويل</MudTh>
                    <MudTh>نسبة البيع</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="الشهر">@context.Month</MudTd>
                    <MudTd DataLabel="Leads">@context.TotalLeads.ToString("N0")</MudTd>
                    <MudTd DataLabel="تم التحويل">@context.ConvertedLeads.ToString("N0")</MudTd>
