    private async Task LoadLookupOptionsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _employees = await db.Employees
            .AsNoTracking()
            .Where(e => e.Status == "نشط")
            .OrderBy(e => e.FullName)
            .Select(e => new Employee { EmployeeId = e.EmployeeId, FullName = e.FullName })
            .ToListAsync();

        var baseLeadQuery = db.LeadsCRMs.AsNoTracking().AsQueryable();

        _availableCities = await baseLeadQuery
            .Where(l => l.City != null && l.City != "")
            .Select(l => l.City!)
            .Distinct()
            .OrderBy(x => x)
            .ToListAsync();

        _availableProjectTypes = await baseLeadQuery
            .Where(l => l.ProjectType != null && l.ProjectType != "")
            .Select(l => l.ProjectType!)
            .Distinct()
            .OrderBy(x => x)
            .ToListAsync();

        _availableProjectStages = await baseLeadQuery
            .Where(l => l.ProjectStage != null && l.ProjectStage != "")
            .Select(l => l.ProjectStage!)
            .Distinct()
            .OrderBy(x => x)
            .ToListAsync();

        _availableCampaigns = await baseLeadQuery
            .Where(l => l.CampaignName != null && l.CampaignName != "")
            .Select(l => l.CampaignName!)
            .Distinct()
            .OrderBy(x => x)
            .ToListAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _loadError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var current = await LoadSnapshotAsync(_filter);
            var previous = await LoadSnapshotAsync(_filter.GetPreviousPeriod());

            _currentRows = current;
            _journeyRows = current
                .OrderByDescending(x => x.IsInvoiced)
                .ThenByDescending(x => x.InvoiceValue)
                .ThenByDescending(x => x.QuotationValue)
                .ThenByDescending(x => x.CreatedAt)
                .ToList();

            ComputeCurrentMetrics(current);
            ComputePreviousMetrics(previous);
            BuildPhaseCharts(current);
            BuildCampaignRows(current);
            BuildEmployeeRows(current);
        }
        catch (Exception ex)
        {
            _loadError = ex.GetBaseException().Message;
            Snackbar.Add("تعذّر تحميل بيانات التحليل المتقدم: " + _loadError, Severity.Error);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<List<LeadJourneyRow>> LoadSnapshotAsync(LeadsDashboardFilterDto filter)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var leadQuery = ApplyLeadFilter(db.LeadsCRMs.AsNoTracking(), filter);

        var leads = await leadQuery
            .Select(l => new LeadSourceRow
            {
                LeadId = l.LeadId,
                FullName = l.FullName,
                Phone = l.Phone,
                CampaignName = l.CampaignName,
                Platform = l.Platform,
                City = l.City,
                ProjectType = l.ProjectType,
                ProjectStage = l.ProjectStage,
                CreatedAt = l.CreatedAt,
                ConvertedDate = l.ConvertedDate,
                LeadStatus = l.LeadStatus,
                IsDuplicate = l.IsDuplicate,
                RejectedReason = l.RejectedReason,
                AssignedEmployeeId = l.AssignedEmployeeId,
                ConvertedOpportunityId = l.ConvertedOpportunityId
            })
            .ToListAsync();

        var oppIds = leads.Where(x => x.ConvertedOpportunityId.HasValue)
            .Select(x => x.ConvertedOpportunityId!.Value)
            .Distinct()
            .ToList();

        var oppMap = new Dictionary<int, OpportunityMiniRow>();
        var quoteMap = new Dictionary<int, QuotationMiniRow>();
        var invoiceMap = new Dictionary<int, InvoiceMiniRow>();
        var employeeMap = new Dictionary<int, string>();

        var employeeIds = leads.Where(x => x.AssignedEmployeeId.HasValue)
            .Select(x => x.AssignedEmployeeId!.Value)
            .Distinct()
            .ToList();

        if (employeeIds.Any())
        {
            employeeMap = await db.Employees.AsNoTracking()
                .Where(e => employeeIds.Contains(e.EmployeeId))
                .Select(e => new { e.EmployeeId, e.FullName })
                .ToDictionaryAsync(x => x.EmployeeId, x => x.FullName ?? "—");
        }

        if (oppIds.Any())
        {
            var oppRows = await db.VwSalesOpportunities.AsNoTracking()
                .Where(o => oppIds.Contains(o.OpportunityId))
                .Select(o => new OpportunityMiniRow
                {
                    OpportunityId = o.OpportunityId,
                    StageId = o.StageId,
                    StageName = o.StageNameAr ?? o.StageName ?? "—",
                    StageColor = o.StageColor ?? "#64748b",
                    ExpectedValue = o.ExpectedValue ?? 0m,
                    ClientName = o.ClientName ?? "—",
                    EmployeeId = o.EmployeeId,
                    EmployeeName = o.EmployeeName,
                    QuotationId = o.QuotationId,
                    TransactionId = o.TransactionId,
                    LostReasonName = o.LostReasonNameAr ?? o.LostReasonName
                })
                .ToListAsync();

            oppMap = oppRows.ToDictionary(x => x.OpportunityId, x => x);

            var quotationIds = oppRows.Where(x => x.QuotationId.HasValue)
                .Select(x => x.QuotationId!.Value)
                .Distinct()
                .ToList();

            if (quotationIds.Any())
            {
                var quoteRows = await db.Quotations.AsNoTracking()
                    .Where(q => quotationIds.Contains(q.QuotationId))
                    .Select(q => new QuotationMiniRow
                    {
                        QuotationId = q.QuotationId,
                        ReferenceNumber = q.ReferenceNumber,
                        Status = q.Status,
                        GrandTotal = q.GrandTotal ?? q.TotalAmount
                    })
                    .ToListAsync();

                quoteMap = quoteRows.ToDictionary(x => x.QuotationId, x => x);
            }

            var invoiceIds = oppRows.Where(x => x.TransactionId.HasValue)
                .Select(x => x.TransactionId!.Value)
                .Distinct()
                .ToList();

            if (invoiceIds.Any())
            {
                var invoiceRows = await db.Transactions.AsNoTracking()
                    .Where(t => invoiceIds.Contains(t.TransactionId) && t.TransactionType == TransactionTypes.Sale)
                    .Select(t => new InvoiceMiniRow
                    {
                        TransactionId = t.TransactionId,
                        ReferenceNumber = t.ReferenceNumber,
                        InvoiceStatus = t.InvoiceStatus,
                        GrandTotal = t.GrandTotal
                    })
                    .ToListAsync();

                invoiceMap = invoiceRows.ToDictionary(x => x.TransactionId, x => x);
            }
        }

        var rows = new List<LeadJourneyRow>(leads.Count);

        foreach (var lead in leads)
        {
            OpportunityMiniRow? opp = null;
            QuotationMiniRow? quote = null;
            InvoiceMiniRow? invoice = null;

            if (lead.ConvertedOpportunityId.HasValue)
            {
                oppMap.TryGetValue(lead.ConvertedOpportunityId.Value, out opp);
                if (opp?.QuotationId is int qid)
                    quoteMap.TryGetValue(qid, out quote);
                if (opp?.TransactionId is int tid)
                    invoiceMap.TryGetValue(tid, out invoice);
            }

            var effectiveEmployeeName = opp?.EmployeeName;
            if (string.IsNullOrWhiteSpace(effectiveEmployeeName) && lead.AssignedEmployeeId.HasValue && employeeMap.TryGetValue(lead.AssignedEmployeeId.Value, out var empName))
                effectiveEmployeeName = empName;

            var isPreRejected = !lead.ConvertedOpportunityId.HasValue &&
                                (!string.IsNullOrWhiteSpace(lead.RejectedReason) || string.Equals(lead.LeadStatus, "مرفوض", StringComparison.OrdinalIgnoreCase));
            var isConverted = lead.ConvertedOpportunityId.HasValue;
            var isQuoted = quote is not null;
            var isInvoiced = invoice is not null;
            var isRejectedAfterQuote = isQuoted && string.Equals(quote!.Status, "Rejected", StringComparison.OrdinalIgnoreCase);
            var isLostAfterConversion = opp is not null && (opp.StageId == 4 || opp.StageId == 5);
            var isOpenOpportunity = opp is not null && !isLostAfterConversion && !isInvoiced && opp.StageId != 3;
            var isWon = opp is not null && (opp.StageId == 3 || isInvoiced);

            var conversionDays = lead.ConvertedDate.HasValue
                ? (lead.ConvertedDate.Value.Date - lead.CreatedAt.Date).TotalDays
                : (double?)null;

            rows.Add(new LeadJourneyRow
            {
                LeadId = lead.LeadId,
                ClientName = !string.IsNullOrWhiteSpace(opp?.ClientName) ? opp!.ClientName : lead.FullName,
                Phone = lead.Phone,
                CampaignName = lead.CampaignName,
                Platform = lead.Platform,
                City = lead.City,
                ProjectType = lead.ProjectType,
                ProjectStage = lead.ProjectStage,
                CreatedAt = lead.CreatedAt,
                ConvertedDate = lead.ConvertedDate,
                LeadStatus = lead.LeadStatus,
                RejectedReason = lead.RejectedReason,
                AssignedEmployeeId = lead.AssignedEmployeeId,
                EmployeeId = opp?.EmployeeId,
                EmployeeName = effectiveEmployeeName,
                OpportunityId = opp?.OpportunityId,
                StageId = opp?.StageId,
                StageName = opp?.StageName,
                StageColor = opp?.StageColor,
                QuotationId = quote?.QuotationId,
                QuotationReference = quote?.ReferenceNumber,
                QuotationStatus = quote?.Status,
                TransactionId = invoice?.TransactionId,
                InvoiceReference = invoice?.ReferenceNumber,
                InvoiceStatus = invoice?.InvoiceStatus,
                IsDuplicate = lead.IsDuplicate,
                IsPreRejected = isPreRejected,
                IsConverted = isConverted,
                IsQuoted = isQuoted,
                IsRejectedAfterQuote = isRejectedAfterQuote,
                IsLostAfterConversion = isLostAfterConversion,
                IsOpenOpportunity = isOpenOpportunity,
                IsWon = isWon,
                IsInvoiced = isInvoiced,
                ConversionDays = conversionDays,
                ExpectedValue = opp?.ExpectedValue ?? 0m,
                QuotationValue = quote?.GrandTotal ?? 0m,
                InvoiceValue = invoice?.GrandTotal ?? 0m,
                LostReasonName = opp?.LostReasonName
            });
        }

        if (filter.EmployeeId.HasValue)
        {
            rows = rows
                .Where(x => x.AssignedEmployeeId == filter.EmployeeId.Value || x.EmployeeId == filter.EmployeeId.Value)
                .ToList();
        }

        return rows;
    }

    private static IQueryable<LeadsCrm> ApplyLeadFilter(IQueryable<LeadsCrm> q, LeadsDashboardFilterDto filter)
    {
        if (filter.DateFrom.HasValue)
            q = q.Where(l => l.CreatedAt >= filter.DateFrom.Value);
        if (filter.DateTo.HasValue)
            q = q.Where(l => l.CreatedAt <= filter.DateTo.Value.AddDays(1));
        if (!string.IsNullOrWhiteSpace(filter.Platform))
            q = q.Where(l => l.Platform == filter.Platform);
        if (!string.IsNullOrWhiteSpace(filter.City))
            q = q.Where(l => l.City == filter.City);
        if (!string.IsNullOrWhiteSpace(filter.ProjectType))
            q = q.Where(l => l.ProjectType == filter.ProjectType);
        if (!string.IsNullOrWhiteSpace(filter.ProjectStage))
            q = q.Where(l => l.ProjectStage == filter.ProjectStage);
        if (!string.IsNullOrWhiteSpace(filter.CampaignName))
            q = q.Where(l => l.CampaignName == filter.CampaignName);
        return q;
    }

    private void ComputeCurrentMetrics(List<LeadJourneyRow> rows)
    {
        _totalLeads = rows.Count;
        _rejectedLeadsBeforeConversion = rows.Count(x => x.IsPreRejected);
        _duplicateLeads = rows.Count(x => x.IsDuplicate);
        _convertedLeads = rows.Count(x => x.IsConverted);
        _quotedLeads = rows.Count(x => x.IsQuoted);
        _rejectedAfterQuoteCount = rows.Count(x => x.IsRejectedAfterQuote);
        _lostAfterConversionCount = rows.Count(x => x.IsLostAfterConversion);
        _openOpportunityCount = rows.Count(x => x.IsOpenOpportunity);
        _wonLeadCount = rows.Count(x => x.IsWon);
        _invoicedLeads = rows.Count(x => x.IsInvoiced);

        _leadToOpportunityRate = _totalLeads > 0 ? (double)_convertedLeads / _totalLeads * 100d : 0d;
        _opportunityToQuotationRate = _convertedLeads > 0 ? (double)_quotedLeads / _convertedLeads * 100d : 0d;
        _quotationToInvoiceRate = _quotedLeads > 0 ? (double)_invoicedLeads / _quotedLeads * 100d : 0d;
        _avgConversionDays = rows.Where(x => x.ConversionDays.HasValue).Select(x => x.ConversionDays!.Value).DefaultIfEmpty(0).Average();

        _quotationValue = rows.Where(x => x.IsQuoted).Sum(x => x.QuotationValue);
        _invoiceValue = rows.Where(x => x.IsInvoiced).Sum(x => x.InvoiceValue);
        _wonExpectedValue = rows.Where(x => x.IsWon).Sum(x => x.ExpectedValue);
    }

    private void ComputePreviousMetrics(List<LeadJourneyRow> rows)
    {
        _prevConvertedLeads = rows.Count(x => x.IsConverted);
        _prevQuotedLeads = rows.Count(x => x.IsQuoted);
        _prevRejectedAfterQuoteCount = rows.Count(x => x.IsRejectedAfterQuote);
        _prevLostAfterConversionCount = rows.Count(x => x.IsLostAfterConversion);
        _prevOpenOpportunityCount = rows.Count(x => x.IsOpenOpportunity);
        _prevWonLeadCount = rows.Count(x => x.IsWon);
        _prevInvoicedLeads = rows.Count(x => x.IsInvoiced);

        var prevTotalLeads = rows.Count;
        _prevLeadToOpportunityRate = prevTotalLeads > 0 ? (double)_prevConvertedLeads / prevTotalLeads * 100d : 0d;
        _prevOpportunityToQuotationRate = _prevConvertedLeads > 0 ? (double)_prevQuotedLeads / _prevConvertedLeads * 100d : 0d;
        _prevQuotationToInvoiceRate = _prevQuotedLeads > 0 ? (double)_prevInvoicedLeads / _prevQuotedLeads * 100d : 0d;
        _prevAvgConversionDays = rows.Where(x => x.ConversionDays.HasValue).Select(x => x.ConversionDays!.Value).DefaultIfEmpty(0).Average();

        _prevQuotationValue = rows.Where(x => x.IsQuoted).Sum(x => x.QuotationValue);
        _prevInvoiceValue = rows.Where(x => x.IsInvoiced).Sum(x => x.InvoiceValue);
        _prevWonExpectedValue = rows.Where(x => x.IsWon).Sum(x => x.ExpectedValue);
    }

    private void BuildPhaseCharts(List<LeadJourneyRow> rows)
    {
        var grouped = rows
            .GroupBy(x => new DateTime(x.CreatedAt.Year, x.CreatedAt.Month, 1))
            .OrderBy(x => x.Key)
            .ToList();

        _phase1Points = grouped.Select(g => new Phase1Point
        {
            Month = g.Key.ToString("MMM yyyy", _arCulture),
            Leads = g.Count(),
            RejectedBeforeConversion = g.Count(x => x.IsPreRejected),
            Converted = g.Count(x => x.IsConverted)
        }).ToList();

        _phase2Points = grouped.Select(g => new Phase2Point
        {
            Month = g.Key.ToString("MMM yyyy", _arCulture),
            Quoted = g.Count(x => x.IsQuoted),
            RejectedAfterQuote = g.Count(x => x.IsRejectedAfterQuote),
            LostAfterConversion = g.Count(x => x.IsLostAfterConversion)
        }).ToList();

        _phase3Points = grouped.Select(g => new Phase3Point
        {
            Month = g.Key.ToString("MMM yyyy", _arCulture),
            InvoicedCount = g.Count(x => x.IsInvoiced),
            QuotationValue = g.Where(x => x.IsQuoted).Sum(x => x.QuotationValue),
            InvoiceValue = g.Where(x => x.IsInvoiced).Sum(x => x.InvoiceValue)
        }).ToList();
    }

    private void BuildCampaignRows(List<LeadJourneyRow> rows)
    {
        _campaignRows = rows
            .GroupBy(x => new { Campaign = string.IsNullOrWhiteSpace(x.CampaignName) ? "بدون حملة" : x.CampaignName!, Platform = NormalizePlatform(x.Platform) })
            .Select(g => new CampaignJourneyRow
            {
                CampaignName = g.Key.Campaign,
                Platform = g.Key.Platform,
                TotalLeads = g.Count(),
                QuotedLeads = g.Count(x => x.IsQuoted),
                InvoicedLeads = g.Count(x => x.IsInvoiced),
                InvoiceValue = g.Where(x => x.IsInvoiced).Sum(x => x.InvoiceValue)
            })
            .OrderByDescending(x => x.InvoiceValue)
            .ThenByDescending(x => x.InvoicedLeads)
            .Take(10)
            .ToList();
    }

    private void BuildEmployeeRows(List<LeadJourneyRow> rows)
    {
        _employeeRows = rows
            .GroupBy(x => string.IsNullOrWhiteSpace(x.EmployeeName) ? "غير محدد" : x.EmployeeName!)
            .Select(g => new EmployeeJourneyRow
            {
                EmployeeName = g.Key,
                TotalLeads = g.Count(),
                QuotedLeads = g.Count(x => x.IsQuoted),
                InvoicedLeads = g.Count(x => x.IsInvoiced),
                LostLeads = g.Count(x => x.IsLostAfterConversion),
                InvoiceValue = g.Where(x => x.IsInvoiced).Sum(x => x.InvoiceValue)
            })
            .OrderByDescending(x => x.InvoiceValue)
            .ThenByDescending(x => x.InvoicedLeads)
            .Take(10)
            .ToList();
    }

    private async Task SelectPeriodAsync(string period)
    {
        _selectedPeriod = period;
        var today = DateTime.Today;

        switch (period)
        {
            case "today":
                _filter.DateFrom = today;
                _filter.DateTo = today;
                break;
            case "week":
                _filter.DateFrom = today.AddDays(-(int)today.DayOfWeek);
                _filter.DateTo = today;
                break;
            case "month":
                _filter.DateFrom = new DateTime(today.Year, today.Month, 1);
                _filter.DateTo = today;
                break;
            case "quarter":
                var qMonth = ((today.Month - 1) / 3) * 3 + 1;
                _filter.DateFrom = new DateTime(today.Year, qMonth, 1);
                _filter.DateTo = today;
                break;
            case "year":
                _filter.DateFrom = new DateTime(today.Year, 1, 1);
                _filter.DateTo = today;
                break;
            case "all":
                _filter.DateFrom = null;
                _filter.DateTo = null;
                break;
            case "custom":
                return;
        }

        await LoadDataAsync();
    }

    private async Task ApplyCustomPeriodAsync() => await LoadDataAsync();

    private async Task SetPlatformAsync(string? platform)
    {
        _filter.Platform = platform;
        await LoadDataAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _filter = new LeadsDashboardFilterDto();
        _showAdvanced = false;
        await SelectPeriodAsync("month");
    }

