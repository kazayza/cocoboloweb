    private static string NormalizePlatform(string? platform) => platform?.ToLowerInvariant() switch
    {
        "fb" => "Facebook",
        "ig" => "Instagram",
        _ => "أخرى"
    };

    private string? GetDeltaText(int current, int previous)
    {
        if (previous == 0)
            return current == 0 ? null : "جديد";
        var change = ((double)(current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string? GetDeltaText(double current, double previous)
    {
        if (Math.Abs(previous) < 0.000001)
            return Math.Abs(current) < 0.000001 ? null : "جديد";
        var change = ((current - previous) / previous) * 100d;
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string? GetDeltaText(decimal current, decimal previous)
    {
        if (previous == 0m)
            return current == 0m ? null : "جديد";
        var change = (double)((current - previous) / previous * 100m);
        return $"{(change > 0 ? "+" : "")}{change:F1}%";
    }

    private string? GetDeltaTextInverse(double current, double previous)
    {
        if (Math.Abs(previous) < 0.000001)
            return Math.Abs(current) < 0.000001 ? null : "جديد";
        var change = ((current - previous) / previous) * 100d;
        return $"{(change <= 0 ? "↓" : "↑")} {Math.Abs(change):F1}%";
    }

    private static string FormatMoney(decimal value)
    {
        if (value >= 1_000_000m) return $"{(value / 1_000_000m):F1}M ج.م";
        if (value >= 1_000m) return $"{(value / 1_000m):F1}K ج.م";
        return $"{value:N0} ج.م";
    }

    private static Chart MakeChart(string fontFamily) => new()
    {
        FontFamily = fontFamily,
        Background = "transparent",
        Toolbar = new Toolbar { Show = false }
    };

    private static Grid MakeGrid() => new()
    {
        BorderColor = "rgba(148,163,184,.18)"
    };

    private static Legend MakeLegend() => new()
    {
        Position = LegendPosition.Top,
        HorizontalAlign = ApexCharts.Align.Right,
        FontSize = "12px",
        FontWeight = "600"
    };

