@page "/crm/leads/intelligence"

@using global::COCOBOLOERPNEW.DTOs
@using global::COCOBOLOERPNEW.Models
@using global::COCOBOLOERPNEW.Services
@using ApexCharts
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@attribute [Authorize]

@inject IDbContextFactory<db24804Context> DbFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar

<PageTitle>Lead Intelligence 360</PageTitle>

@if (_unauthorized)
{
    <div class="l360-empty-page" dir="rtl">
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="ma-4">
            غير مصرح لك بالوصول إلى شاشة التحليل المتقدم للـ Leads.
        </MudAlert>
    </div>
}
else if (_isLoading)
{
    <div class="l360-loading" dir="rtl">
        <MudProgressCircular Color="MudColor.Primary" Size="MudSize.Large" Indeterminate="true" />
        <MudText Typo="Typo.h6" Class="mt-4">جاري تجهيز التحليل التجاري المتقدم...</MudText>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="l360-empty-page" dir="rtl">
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="ma-4">
            حدث خطأ أثناء تحميل الشاشة:
            <br />
            @_loadError
        </MudAlert>
        <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary" Class="ma-4" OnClick="LoadDataAsync">
            إعادة المحاولة
        </MudButton>
    </div>
}
else
{
<div class="l360-page" dir="rtl">

    <div class="l360-hero">
        <div class="l360-hero-bg"></div>
        <div class="l360-hero-grid"></div>

        <div class="l360-hero-body">
            <div class="l360-hero-top">
                <div class="l360-title-wrap">
                    <div class="l360-title-icon">
                        <MudIcon Icon="@Icons.Material.Rounded.AutoGraph" Style="font-size:1.5rem" />
                    </div>
                    <div>
                        <h1>Lead Intelligence 360</h1>
                        <p>ربط احترافي بين الـ Leads والـ CRM وعروض الأسعار والفواتير في شاشة واحدة</p>
                    </div>
                </div>

                <div class="l360-hero-actions">
                    <button class="hero-btn" @onclick="GoToClassicDashboard">
                        <MudIcon Icon="@Icons.Material.Rounded.Dashboard" Size="MudSize.Small" />
                        لوحة Leads الأساسية
                    </button>
                    <button class="hero-btn hero-btn-ghost" @onclick="GoBack">
                        <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="MudSize.Small" />
                        رجوع
                    </button>
                </div>
            </div>

            <div class="l360-period-row">
                @foreach (var p in _periods)
                {
                    <button class="period-chip @(_selectedPeriod == p.Key ? "on" : "")"
                            @onclick="@(async () => await SelectPeriodAsync(p.Key))">
                        @p.Value
                    </button>
                }

                @if (_selectedPeriod == "custom")
                {
                    <MudDatePicker Label="من" Variant="MudVariant.Outlined" @bind-Date="_filter.DateFrom" Dense="true" Class="period-date" />
                    <MudDatePicker Label="إلى" Variant="MudVariant.Outlined" @bind-Date="_filter.DateTo" Dense="true" Class="period-date" />
                    <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary" OnClick="ApplyCustomPeriodAsync" Size="MudSize.Small">تطبيق</MudButton>
                }
            </div>

            <div class="l360-quick-filters">
                <div class="qf-group">
                    <span class="qf-label">المنصة:</span>
                    <button class="qf-btn @(_filter.Platform == null ? "on" : "")" @onclick="@(async () => await SetPlatformAsync(null))">الكل</button>
                    <button class="qf-btn @(_filter.Platform == "fb" ? "on" : "")" @onclick="@(async () => await SetPlatformAsync("fb"))">Facebook</button>
                    <button class="qf-btn @(_filter.Platform == "ig" ? "on" : "")" @onclick="@(async () => await SetPlatformAsync("ig"))">Instagram</button>
                </div>

                <div class="qf-group qf-group-select">
                    <span class="qf-label">الموظف:</span>
                    <MudSelect T="int?" Value="_filter.EmployeeId"
                               ValueChanged="@(async (int? v) => { _filter.EmployeeId = v; await LoadDataAsync(); })"
                               Dense="true" Clearable="true" Placeholder="الكل" Class="qf-select">
                        @foreach (var emp in _employees)
                        {
                            <MudSelectItem Value="@((int?)emp.EmployeeId)">@emp.FullName</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <button class="adv-toggle" @onclick="@(() => _showAdvanced = !_showAdvanced)">
                    <MudIcon Icon="@(_showAdvanced ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)" Size="MudSize.Small" />
                    فلاتر متقدمة
                </button>
            </div>

            @if (_showAdvanced)
            {
                <div class="advanced-panel">
                    <div class="advanced-head">
                        <h3>الفلاتر المتقدمة</h3>
                        <p>اضبط المدينة، نوع المشروع، مرحلته، والحملة لربط رحلة الـ Lead بالكامل.</p>
                    </div>

                    <div class="advanced-grid">
                        <MudSelect T="string" Label="المدينة" Variant="MudVariant.Outlined" @bind-Value="_filter.City" Dense="true" Class="adv-item" Clearable="true" Placeholder="الكل">
                            @foreach (var c in _availableCities)
                            {
                                <MudSelectItem Value="@c">@c</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="string" Label="نوع المشروع" Variant="MudVariant.Outlined" @bind-Value="_filter.ProjectType" Dense="true" Class="adv-item" Clearable="true" Placeholder="الكل">
                            @foreach (var p in _availableProjectTypes)
                            {
                                <MudSelectItem Value="@p">@p</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="string" Label="مرحلة المشروع" Variant="MudVariant.Outlined" @bind-Value="_filter.ProjectStage" Dense="true" Class="adv-item" Clearable="true" Placeholder="الكل">
                            @foreach (var s in _availableProjectStages)
                            {
                                <MudSelectItem Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="string" Label="الحملة" Variant="MudVariant.Outlined" @bind-Value="_filter.CampaignName" Dense="true" Class="adv-item" Clearable="true" Placeholder="الكل">
                            @foreach (var c in _availableCampaigns)
                            {
                                <MudSelectItem Value="@c">@c</MudSelectItem>
                            }
                        </MudSelect>
                    </div>

                    <div class="advanced-actions">
                        <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary" OnClick="LoadDataAsync" StartIcon="@Icons.Material.Rounded.FilterAlt">تطبيق التحليل</MudButton>
                        <MudButton Variant="MudVariant.Outlined" Color="MudColor.Error" OnClick="ResetFiltersAsync" StartIcon="@Icons.Material.Rounded.FilterAltOff">مسح الكل</MudButton>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="phase-strip">
        <div class="phase-step active">
            <span class="phase-no">1</span>
            <div>
                <strong>مرحلة الـ Lead</strong>
                <small>الجودة والرفض والتحويل الأولي</small>
            </div>
        </div>
        <div class="phase-arrow">←</div>
        <div class="phase-step active">
            <span class="phase-no">2</span>
            <div>
                <strong>مرحلة الـ CRM والعروض</strong>
                <small>الفرصة، عرض السعر، والرفض بعد العرض</small>
            </div>
        </div>
        <div class="phase-arrow">←</div>
        <div class="phase-step active">
            <span class="phase-no">3</span>
            <div>
                <strong>مرحلة الفاتورة والإيراد</strong>
                <small>الفاتورة الفعلية والقيمة النهائية</small>
            </div>
        </div>
    </div>

    <section class="phase-card">
        <div class="phase-header">
            <div>
                <h2>المرحلة الأولى: جودة الـ Leads والتحويل الأولي</h2>
                <p>منشأ الرحلة: كم Lead دخل، كم تم رفضه قبل التحويل، وكم تم تحويله فعليًا إلى فرصة.</p>
            </div>
        </div>

        <div class="kpi-grid">
            @RenderKpiCard("إجمالي Leads", _totalLeads.ToString("N0"), "#2563eb", "#dbeafe", null)
            @RenderKpiCard("مرفوض قبل التحويل", _rejectedLeadsBeforeConversion.ToString("N0"), "#dc2626", "#fee2e2", null)
            @RenderKpiCard("مكرر", _duplicateLeads.ToString("N0"), "#d97706", "#fef3c7", null)
            @RenderKpiCard("تم التحويل إلى فرص", _convertedLeads.ToString("N0"), "#7c3aed", "#ede9fe", GetDeltaText(_convertedLeads, _prevConvertedLeads))
            @RenderKpiCard("معدل التحويل إلى فرص", _leadToOpportunityRate.ToString("F1") + "%", "#0f766e", "#ccfbf1", GetDeltaText(_leadToOpportunityRate, _prevLeadToOpportunityRate))
            @RenderKpiCard("متوسط أيام التحويل", _avgConversionDays.ToString("F1"), "#475569", "#e2e8f0", GetDeltaTextInverse(_avgConversionDays, _prevAvgConversionDays))
        </div>

        <div class="chart-card">
            <div class="chart-title-wrap">
                <h3>الاتجاه الشهري للـ Leads</h3>
                <p>إجمالي الـ Leads مقابل المرفوض قبل التحويل والمحول إلى فرصة</p>
            </div>
            @if (_phase1Points.Any())
            {
                <div class="chart-shell" dir="ltr">
                    <ApexChart TItem="Phase1Point" Options="_phase1ChartOptions" Height="320">
                        <ApexPointSeries TItem="Phase1Point" Items="@_phase1Points" Name="Leads" SeriesType="SeriesType.Bar" XValue="x => x.Month" YValue="x => x.Leads" />
                        <ApexPointSeries TItem="Phase1Point" Items="@_phase1Points" Name="مرفوض قبل التحويل" SeriesType="SeriesType.Bar" XValue="x => x.Month" YValue="x => x.RejectedBeforeConversion" />
                        <ApexPointSeries TItem="Phase1Point" Items="@_phase1Points" Name="تم التحويل" SeriesType="SeriesType.Line" XValue="x => x.Month" YValue="x => x.Converted" />
                    </ApexChart>
                </div>
            }
            else
            {
                <div class="empty-box">لا توجد بيانات للرسم البياني</div>
            }
        </div>
    </section>

    <section class="phase-card">
        <div class="phase-header">
            <div>
                <h2>المرحلة الثانية: الفرص وعروض الأسعار</h2>
                <p>ما الذي حصل بعد دخول الـ Lead إلى CRM؟ هل خرج له عرض؟ هل رُفض العرض؟ وهل الفرصة ما زالت مفتوحة أم خسرناها؟</p>
            </div>
        </div>

        <div class="kpi-grid">
            @RenderKpiCard("Leads خرج لها عرض سعر", _quotedLeads.ToString("N0"), "#b45309", "#ffedd5", GetDeltaText(_quotedLeads, _prevQuotedLeads))
            @RenderKpiCard("معدل التحويل إلى عروض", _opportunityToQuotationRate.ToString("F1") + "%", "#7c3aed", "#ede9fe", GetDeltaText(_opportunityToQuotationRate, _prevOpportunityToQuotationRate))
            @RenderKpiCard("مرفوض بعد العرض", _rejectedAfterQuoteCount.ToString("N0"), "#dc2626", "#fee2e2", GetDeltaText(_rejectedAfterQuoteCount, _prevRejectedAfterQuoteCount))
            @RenderKpiCard("خسارة بعد التحويل", _lostAfterConversionCount.ToString("N0"), "#ef4444", "#fee2e2", GetDeltaText(_lostAfterConversionCount, _prevLostAfterConversionCount))
            @RenderKpiCard("فرص مفتوحة", _openOpportunityCount.ToString("N0"), "#0ea5e9", "#e0f2fe", GetDeltaText(_openOpportunityCount, _prevOpenOpportunityCount))
            @RenderKpiCard("إجمالي قيمة العروض", FormatMoney(_quotationValue), "#8b5cf6", "#ede9fe", GetDeltaText(_quotationValue, _prevQuotationValue))
        </div>

        <div class="two-col-grid">
            <div class="chart-card">
                <div class="chart-title-wrap">
                    <h3>الاتجاه الشهري للعروض والرفض والخسارة</h3>
                    <p>عدد الـ Leads التي خرج منها عرض، وما رفضه العميل، وما انتهى إلى خسارة بعد التحويل</p>
                </div>
                @if (_phase2Points.Any())
                {
                    <div class="chart-shell" dir="ltr">
                        <ApexChart TItem="Phase2Point" Options="_phase2ChartOptions" Height="320">
                            <ApexPointSeries TItem="Phase2Point" Items="@_phase2Points" Name="عروض أسعار" SeriesType="SeriesType.Bar" XValue="x => x.Month" YValue="x => x.Quoted" />
                            <ApexPointSeries TItem="Phase2Point" Items="@_phase2Points" Name="مرفوض بعد العرض" SeriesType="SeriesType.Bar" XValue="x => x.Month" YValue="x => x.RejectedAfterQuote" />
                            <ApexPointSeries TItem="Phase2Point" Items="@_phase2Points" Name="خسارة بعد التحويل" SeriesType="SeriesType.Line" XValue="x => x.Month" YValue="x => x.LostAfterConversion" />
                        </ApexChart>
                    </div>
                }
                else
                {
                    <div class="empty-box">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="table-card">
                <div class="chart-title-wrap">
                    <h3>أقوى الحملات تجاريًا</h3>
                    <p>من الـ Lead إلى العرض ثم الفاتورة</p>
                </div>
                <MudTable Items="@_campaignRows" Hover="true" Dense="true" Elevation="0" RowsPerPage="8" Breakpoint="Breakpoint.Sm" Class="premium-table">
                    <HeaderContent>
                        <MudTh>الحملة</MudTh>
                        <MudTh>المنصة</MudTh>
                        <MudTh>Leads</MudTh>
                        <MudTh>عروض</MudTh>
                        <MudTh>فواتير</MudTh>
                        <MudTh>قيمة الفواتير</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="الحملة">@context.CampaignName</MudTd>
                        <MudTd DataLabel="المنصة">@context.PlatformDisplay</MudTd>
                        <MudTd DataLabel="Leads"><bdi>@context.TotalLeads</bdi></MudTd>
                        <MudTd DataLabel="عروض"><bdi>@context.QuotedLeads</bdi></MudTd>
                        <MudTd DataLabel="فواتير"><bdi>@context.InvoicedLeads</bdi></MudTd>
                        <MudTd DataLabel="قيمة الفواتير">@FormatMoney(context.InvoiceValue)</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="empty-box small">لا توجد بيانات للحملات</div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </section>

    <section class="phase-card">
        <div class="phase-header">
            <div>
                <h2>المرحلة الثالثة: الفواتير والإيراد</h2>
                <p>هنا نرى الـ Leads التي وصلت فعليًا إلى فاتورة بيع، وما القيمة الفعلية المحققة، وهل هناك فجوة عن المتوقع؟</p>
            </div>
        </div>

        <div class="kpi-grid">
            @RenderKpiCard("Leads وصلت لفاتورة", _invoicedLeads.ToString("N0"), "#059669", "#d1fae5", GetDeltaText(_invoicedLeads, _prevInvoicedLeads))
            @RenderKpiCard("معدل التحويل إلى فواتير", _quotationToInvoiceRate.ToString("F1") + "%", "#0f766e", "#ccfbf1", GetDeltaText(_quotationToInvoiceRate, _prevQuotationToInvoiceRate))
            @RenderKpiCard("إجمالي قيمة الفواتير", FormatMoney(_invoiceValue), "#16a34a", "#dcfce7", GetDeltaText(_invoiceValue, _prevInvoiceValue))
            @RenderKpiCard("فرص رابحة", _wonLeadCount.ToString("N0"), "#15803d", "#dcfce7", GetDeltaText(_wonLeadCount, _prevWonLeadCount))
            @RenderKpiCard("القيمة المتوقعة للصفقات الرابحة", FormatMoney(_wonExpectedValue), "#7c3aed", "#ede9fe", GetDeltaText(_wonExpectedValue, _prevWonExpectedValue))
            @RenderKpiCard("الفرق بين المتوقع والفاتورة", FormatMoney(_invoiceValue - _wonExpectedValue), "#475569", "#e2e8f0", null)
        </div>

        <div class="two-col-grid">
            <div class="chart-card">
                <div class="chart-title-wrap">
                    <h3>الاتجاه الشهري للعروض والفواتير بالقيمة</h3>
                    <p>قيمة عروض الأسعار مقابل قيمة الفواتير الفعلية الخارجة من الـ Leads</p>
                </div>
                @if (_phase3Points.Any())
                {
                    <div class="chart-shell" dir="ltr">
                        <ApexChart TItem="Phase3Point" Options="_phase3ChartOptions" Height="320">
                            <ApexPointSeries TItem="Phase3Point" Items="@_phase3Points" Name="قيمة عروض الأسعار" SeriesType="SeriesType.Bar" XValue="x => x.Month" YValue="x => x.QuotationValue" />
                            <ApexPointSeries TItem="Phase3Point" Items="@_phase3Points" Name="قيمة الفواتير" SeriesType="SeriesType.Bar" XValue="x => x.Month" YValue="x => x.InvoiceValue" />
                            <ApexPointSeries TItem="Phase3Point" Items="@_phase3Points" Name="عدد الفواتير" SeriesType="SeriesType.Line" XValue="x => x.Month" YValue="x => x.InvoicedCount" />
                        </ApexChart>
                    </div>
                }
                else
                {
                    <div class="empty-box">لا توجد بيانات للرسم البياني</div>
                }
            </div>

            <div class="table-card">
                <div class="chart-title-wrap">
                    <h3>أفضل الموظفين من الـ Lead إلى الإيراد</h3>
                    <p>عدد الـ Leads والعروض والفواتير وقيمة الفواتير لكل موظف</p>
                </div>
                <MudTable Items="@_employeeRows" Hover="true" Dense="true" Elevation="0" RowsPerPage="8" Breakpoint="Breakpoint.Sm" Class="premium-table">
                    <HeaderContent>
                        <MudTh>الموظف</MudTh>
                        <MudTh>Leads</MudTh>
                        <MudTh>عروض</MudTh>
                        <MudTh>فواتير</MudTh>
                        <MudTh>خسارة</MudTh>
                        <MudTh>قيمة الفواتير</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="الموظف">@context.EmployeeName</MudTd>
                        <MudTd DataLabel="Leads"><bdi>@context.TotalLeads</bdi></MudTd>
                        <MudTd DataLabel="عروض"><bdi>@context.QuotedLeads</bdi></MudTd>
                        <MudTd DataLabel="فواتير"><bdi>@context.InvoicedLeads</bdi></MudTd>
                        <MudTd DataLabel="خسارة"><bdi>@context.LostLeads</bdi></MudTd>
                        <MudTd DataLabel="قيمة الفواتير">@FormatMoney(context.InvoiceValue)</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="empty-box small">لا توجد بيانات للموظفين</div>
                    </NoRecordsContent>
                </MudTable>
            </div>
        </div>
    </section>

    <section class="phase-card">
        <div class="phase-header">
            <div>
                <h2>جدول الربط الكامل لرحلة الـ Lead</h2>
                <p>تفصيل مباشر يوضح العميل، الفرصة، حالة العرض، الفاتورة، والقيم الحالية طبقًا للربط الموجود الآن في النظام.</p>
            </div>
        </div>

        <MudTable Items="@_journeyRows" Hover="true" Dense="true" Elevation="0" RowsPerPage="15" Breakpoint="Breakpoint.Sm" Class="premium-table">
            <HeaderContent>
                <MudTh>العميل</MudTh>
                <MudTh>التاريخ</MudTh>
                <MudTh>الحالة</MudTh>
                <MudTh>المرحلة</MudTh>
                <MudTh>العرض</MudTh>
                <MudTh>الفاتورة</MudTh>
                <MudTh>قيمة العرض</MudTh>
                <MudTh>قيمة الفاتورة</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="العميل">@context.ClientName</MudTd>
                <MudTd DataLabel="التاريخ"><bdi>@context.CreatedAt.ToString("yyyy/MM/dd")</bdi></MudTd>
                <MudTd DataLabel="الحالة">@context.Status</MudTd>
                <MudTd DataLabel="المرحلة">
                    <span class="stage-pill" style="@($"background:{(string.IsNullOrWhiteSpace(context.StageColor) ? "#64748b" : context.StageColor)};color:#fff;")">@context.StageName</span>
                </MudTd>
                <MudTd DataLabel="العرض">@(context.QuotationReference ?? "—")</MudTd>
                <MudTd DataLabel="الفاتورة">@(context.InvoiceReference ?? "—")</MudTd>
                <MudTd DataLabel="قيمة العرض">@FormatMoney(context.QuotationValue)</MudTd>
                <MudTd DataLabel="قيمة الفاتورة">@FormatMoney(context.InvoiceValue)</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="empty-box">لا توجد حالات مطابقة للفلاتر الحالية</div>
            </NoRecordsContent>
        </MudTable>
    </section>

    <section class="journey-note">
        <div class="note-icon">ℹ️</div>
        <div>
            <h4>ملاحظة تشغيلية مهمة</h4>
            <p>
                هذا التحليل يعتمد حاليًا على الربط المتاح في النظام: <strong>Lead → ConvertedOpportunityId → Opportunity.QuotationId / TransactionId</strong>.
                لذلك فهو دقيق جدًا مع الفرص التي لها عرض رئيسي وفاتورة رئيسية واحدة. وعند تفعيل الربط المباشر لاحقًا بين الفرص وكل من عروض الأسعار والفواتير، ستصبح القراءة أدق في حالات تعدد العروض أو تعدد الفواتير.
            </p>
        </div>
    </section>

</div>
}

@code {
    private readonly CultureInfo _arCulture = new("ar-EG");

    private bool _isLoading = true;
    private bool _unauthorized;
    private string? _loadError;
    private bool _showAdvanced;
    private string _selectedPeriod = "month";

    private LeadsDashboardFilterDto _filter = new();
    private List<Employee> _employees = new();
    private List<string> _availableCities = new();
    private List<string> _availableProjectTypes = new();
    private List<string> _availableProjectStages = new();
    private List<string> _availableCampaigns = new();

    private int _totalLeads;
    private int _rejectedLeadsBeforeConversion;
