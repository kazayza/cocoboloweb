    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            if (!LeadsCrmPermissions.CanViewDashboard(auth.User))
            {
                _unauthorized = true;
                return;
            }

            InitChartOptions();
            await LoadLookupOptionsAsync();
            await SelectPeriodAsync("month");
        }
        catch (Exception ex)
        {
            _loadError = ex.GetBaseException().Message;
            Snackbar.Add("تعذّر تحميل شاشة Lead Intelligence 360: " + _loadError, Severity.Error);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

