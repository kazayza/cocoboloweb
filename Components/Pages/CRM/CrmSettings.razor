<style>
    .category-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
        border: 1px solid #3b82f6 !important;
    }
</style>

@code {
    bool _ok; string _user = ""; Dictionary<string, int> _usage = new();
    List<ContactSource> _src = new(); List<SalesStage> _stg = new(); List<LostReason> _lost = new();
    List<InterestCategory> _cat = new(); List<TaskType> _task = new(); List<AdType> _ad = new();

    bool _dlgSrc, _dlgStg, _dlgLost, _dlgCat, _dlgTask, _dlgAd;
    DialogOptions _dlgOpt = new() { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
    ContactSource _srcEdit = new(); SalesStage _stgEdit = new(); LostReason _lostEdit = new();
    InterestCategory _catEdit = new(); TaskType _taskEdit = new(); AdType _adEdit = new();

    protected override async Task OnInitializedAsync()
    {
        var a = await Auth.GetAuthenticationStateAsync(); var u = a.User;
        _user = u.Identity?.Name ?? "System"; _ok = u.IsInRole("Admin") || u.IsInRole("Social");
        if (!_ok) { Nav.NavigateTo("/"); return; }
        await Load();
    }

    async Task Load()
    {
        _src = await Svc.GetSourcesAsync(true);
        _stg = await Svc.GetStagesAsync(true);
        _lost = await Svc.GetLostReasonsAsync(true);
        _cat = await Svc.GetCategoriesAsync(true);
        _task = await Svc.GetTaskTypesAsync(true);
        _ad = await Svc.GetAdTypesAsync(true);
        _usage = await Svc.GetUsageCountsAsync();
    }

    async Task ToggleSrc(ContactSource s)
    {
        var r = await Svc.ToggleSourceAsync(s.SourceId, !s.IsActive, _user);
        Snack.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
        if (r.Success) await Load();
    }

    void AddNewSource()
    {
        EditSource(new ContactSource { IsActive = true, SourceIcon = "📱" });
    }

    void AddNewStage()
    {
        var newStage = new SalesStage();
        newStage.IsActive = true;
        newStage.StageOrder = _stg.Count + 1;
        newStage.StageColor = "#3b82f6";
        EditStage(newStage);
    }

    void AddNewLostReason()
    {
        EditLost(new LostReason { IsActive = true });
    }

    void AddNewCategory()
    {
        EditCat(new InterestCategory { IsActive = true });
    }

    void AddNewTaskType()
    {
        EditTask(new TaskType { IsActive = true });
    }

    void AddNewAdType()
    {
        EditAd(new AdType { IsActive = true });
    }

    void EditSource(ContactSource s)
    {
        _srcEdit = new ContactSource 
        { 
            SourceId = s.SourceId, 
            SourceName = s.SourceName, 
            SourceNameAr = s.SourceNameAr, 
            SourceIcon = string.IsNullOrEmpty(s.SourceIcon) ? "📱" : s.SourceIcon, 
            IsActive = s.IsActive 
        };
        _dlgSrc = true;
    }
    
    async Task SaveSrc()
    {
        var r = await Svc.SaveSourceAsync(_srcEdit, _user);
        Snack.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
        _dlgSrc = false;
        if (r.Success) await Load();
    }

    void EditStage(SalesStage s)
    {
        _stgEdit = new SalesStage { StageId = s.StageId, StageName = s.StageName, StageNameAr = s.StageNameAr, StageColor = string.IsNullOrEmpty(s.StageColor) ? "#3b82f6" : s.StageColor, StageOrder = s.StageOrder, IsActive = s.IsActive };
        _dlgStg = true;
    }
    
    async Task SaveStg()
    {
        var r = await Svc.SaveStageAsync(_stgEdit, _user);
        Snack.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
        _dlgStg = false;
        if (r.Success) await Load();
    }

    void EditLost(LostReason l)
    {
        _lostEdit = new LostReason { LostReasonId = l.LostReasonId, ReasonName = l.ReasonName, ReasonNameAr = l.ReasonNameAr, IsActive = l.IsActive };
        _dlgLost = true;
    }
    
    async Task SaveLost()
    {
        var r = await Svc.SaveLostReasonAsync(_lostEdit, _user);
        Snack.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
        _dlgLost = false;
        if (r.Success) await Load();
    }

    void EditCat(InterestCategory c)
    {
        _catEdit = new InterestCategory { CategoryId = c.CategoryId, CategoryName = c.CategoryName, CategoryNameAr = c.CategoryNameAr, IsActive = c.IsActive };
        _dlgCat = true;
    }
    
    async Task SaveCat()
    {
        var r = await Svc.SaveCategoryAsync(_catEdit, _user);
        Snack.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
        _dlgCat = false;
        if (r.Success) await Load();
    }

    void EditTask(TaskType t)
    {
        _taskEdit = new TaskType { TaskTypeId = t.TaskTypeId, TaskTypeName = t.TaskTypeName, TaskTypeNameAr = t.TaskTypeNameAr, IsActive = t.IsActive };
        _dlgTask = true;
    }
    
    async Task SaveTask()
    {
        var r = await Svc.SaveTaskTypeAsync(_taskEdit, _user);
        Snack.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
        _dlgTask = false;
        if (r.Success) await Load();
    }

    void EditAd(AdType a)
    {
        _adEdit = new AdType { AdTypeId = a.AdTypeId, AdTypeName = a.AdTypeName, AdTypeNameAr = a.AdTypeNameAr, IsActive = a.IsActive };
        _dlgAd = true;
    }
    
    async Task SaveAd()
    {
        var r = await Svc.SaveAdTypeAsync(_adEdit, _user);
        Snack.Add(r.Message, r.Success ? Severity.Success : Severity.Error);
        _dlgAd = false;
        if (r.Success) await Load();
    }
}