@page "/crm/settings"
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@inject ICrmSettingsService Svc
@inject ISnackbar Snack
@inject IDialogService Dialog
@inject AuthenticationStateProvider Auth
@inject NavigationManager Nav

<PageTitle>⚙️ إعدادات CRM</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8" dir="rtl">

    @* Header *@
    <MudCard Elevation="4" Class="mb-6" Style="border-radius:20px; overflow:hidden; background:linear-gradient(135deg,#0f172a,#1e3a8a,#3b82f6);">
        <MudCardContent Class="pa-6">
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h4" Style="font-weight:800; color:#f8fafc;">⚙️ الإعدادات المتقدمة</MudText>
                        <MudText Typo="Typo.body1" Style="color:#e2e8f0;">إدارة جميع إعدادات نظام CRM من لوحة تحكم واحدة</MudText>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudStack Align="AlignItems.End" Justify="Justify.Center" Style="height:100%;">
                        <MudChip T="string" Color="Color.Warning" Size="Size.Large" Style="font-weight:700; font-size:1.2rem;">
                            @(_src.Count + _stg.Count + _lost.Count + _cat.Count + _task.Count + _ad.Count) عنصر
                        </MudChip>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    @if (!_ok)
    {
        <MudAlert Severity="Severity.Error" Class="rounded-xl" Style="border:2px solid #ef4444;">
            <MudStack Row Align="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Rounded.Lock" />
                <MudText Style="font-weight:600;">عفواً، لا تملك صلاحية الوصول لهذه الصفحة</MudText>
            </MudStack>
        </MudAlert>
    }
    else
    {
        <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="false" PanelClass="pa-4" Style="background:white;">

            @* ============ SOURCES TAB ============ *@
            <MudTabPanel Text="المصادر" TabIcon="@Icons.Material.Filled.Source">
                <MudPaper Elevation="0" Class="pa-4" Style="background:#fafbfc;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:700; color:#1e293b;">📋 إدارة مصادر التواصل</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Rounded.AddCircleOutline"
                                   OnClick="AddNewSource"
                                   Style="border-radius:12px; font-weight:600;">
                            إضافة مصدر
                        </MudButton>
                    </div>
                    <MudTable Items="_src" Dense Hover Striped Elevation="0" Style="border:1px solid #e2e8f0; border-radius:12px; overflow:hidden;">
                        <HeaderContent>
                            <MudTh Style="font-weight:600;">أيقونة</MudTh>
                            <MudTh Style="font-weight:600;">عربي</MudTh>
                            <MudTh Style="font-weight:600;">EN</MudTh>
                            <MudTh Style="font-weight:600;">استخدام</MudTh>
                            <MudTh Style="font-weight:600;">حالة</MudTh>
                            <MudTh Style="font-weight:600;">إجراءات</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><span style="font-size:1.5rem;">@context.SourceIcon</span></MudTd>
                            <MudTd><b>@context.SourceNameAr</b></MudTd>
                            <MudTd>@context.SourceName</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Style="border-radius:8px; font-weight:600;">
                                    @(_usage.GetValueOrDefault($"source_{context.SourceId}", 0))
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Error)" Variant="Variant.Text">
                                    <MudIcon Icon="@(context.IsActive ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.Cancel)" Size="Size.Small" Class="me-1" />
                                    @(context.IsActive ? "نشط" : "معطل")
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudStack Row Spacing="0">
                                    <MudTooltip Text="تعديل">
                                        <MudIconButton Icon="@Icons.Material.Rounded.EditNote" Size="Size.Small" Color="Color.Primary" OnClick="() => EditSource(context)" />
                                    </MudTooltip>
                                    <MudTooltip Text="@(context.IsActive ? "تعطيل" : "تفعيل")">
                                        <MudIconButton Icon="@(context.IsActive ? Icons.Material.Rounded.ToggleOff : Icons.Material.Rounded.ToggleOn)" Size="Size.Small" Color="Color.Warning" OnClick="() => ToggleSrc(context)" />
                                    </MudTooltip>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>

            @* ============ STAGES TAB ============ *@
            <MudTabPanel Text="المراحل" TabIcon="@Icons.Material.Filled.Timeline">
                <MudPaper Elevation="0" Class="pa-4" Style="background:#fafbfc;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:700; color:#1e293b;">📊 مراحل المبيعات</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Rounded.AddCircleOutline"
                                   OnClick="AddNewStage"
                                   Style="border-radius:12px; font-weight:600;">
                            إضافة مرحلة
                        </MudButton>
                    </div>
                    <MudTable Items="_stg.OrderBy(s => s.StageOrder)" Dense Hover Elevation="0" Style="border:1px solid #e2e8f0; border-radius:12px; overflow:hidden;">
                        <HeaderContent>
                            <MudTh>#</MudTh>
                            <MudTh>عربي</MudTh>
                            <MudTh>EN</MudTh>
                            <MudTh>لون</MudTh>
                            <MudTh>استخدام</MudTh>
                            <MudTh>حالة</MudTh>
                            <MudTh>إجراءات</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.StageOrder</b></MudTd>
                            <MudTd><b>@context.StageNameAr</b></MudTd>
                            <MudTd>@context.StageName</MudTd>
                            <MudTd>
                                <div style="width:32px;height:32px;background:@context.StageColor;border-radius:8px;"></div>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                    @(_usage.GetValueOrDefault($"stage_{context.StageId}", 0))
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Error)" Variant="Variant.Text">
                                    @(context.IsActive ? "نشط" : "معطل")
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Rounded.EditNote" Size="Size.Small" Color="Color.Primary" OnClick="() => EditStage(context)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>

            @* ============ LOST REASONS TAB ============ *@
            <MudTabPanel Text="أسباب الخسارة" TabIcon="@Icons.Material.Filled.HeartBroken">
                <MudPaper Elevation="0" Class="pa-4" Style="background:#fafbfc;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:700; color:#1e293b;">💔 أسباب خسارة الفرص</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Error"
                                   StartIcon="@Icons.Material.Rounded.AddCircleOutline"
                                   OnClick="AddNewLostReason"
                                   Style="border-radius:12px; font-weight:600;">
                            إضافة سبب
                        </MudButton>
                    </div>
                    <MudTable Items="_lost" Dense Hover Elevation="0" Style="border:1px solid #e2e8f0; border-radius:12px; overflow:hidden;">
                        <HeaderContent>
                            <MudTh>عربي</MudTh>
                            <MudTh>EN</MudTh>
                            <MudTh>حالة</MudTh>
                            <MudTh>إجراءات</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.ReasonNameAr</b></MudTd>
                            <MudTd>@context.ReasonName</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Error)" Variant="Variant.Text">
                                    @(context.IsActive ? "نشط" : "معطل")
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Rounded.EditNote" Size="Size.Small" Color="Color.Primary" OnClick="() => EditLost(context)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>

            @* ============ CATEGORIES TAB ============ *@
            <MudTabPanel Text="الفئات" TabIcon="@Icons.Material.Filled.Category">
                <MudPaper Elevation="0" Class="pa-4" Style="background:#fafbfc;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:700; color:#1e293b;">🏷️ فئات الاهتمامات</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Info"
                                   StartIcon="@Icons.Material.Rounded.AddCircleOutline"
                                   OnClick="AddNewCategory"
                                   Style="border-radius:12px; font-weight:600;">
                            إضافة فئة
                        </MudButton>
                    </div>
                    <MudGrid Spacing="3">
                        @foreach (var c in _cat)
                        {
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <MudCard Elevation="2" Class="category-card" Style="border-radius:16px; transition:all 0.3s ease;">
                                    <MudCardContent Class="pa-4">
                                        <MudStack Spacing="2">
                                            <div class="d-flex justify-space-between align-start">
                                                <div>
                                                    <MudText Typo="Typo.body1" Style="font-weight:700;">@c.CategoryNameAr</MudText>
                                                    <MudText Typo="Typo.caption" Style="color:#64748b;">@c.CategoryName</MudText>
                                                </div>
                                                <MudIconButton Icon="@Icons.Material.Rounded.EditNote" Size="Size.Small" Color="Color.Primary" OnClick="() => EditCat(c)" />
                                            </div>
                                            <MudChip T="string" Size="Size.Small" Color="@(c.IsActive ? Color.Success : Color.Error)" Variant="Variant.Text">
                                                @(c.IsActive ? "✅ نشط" : "⛔ معطل")
                                            </MudChip>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            </MudTabPanel>

            @* ============ TASKS TAB ============ *@
            <MudTabPanel Text="المهام" TabIcon="@Icons.Material.Filled.TaskAlt">
                <MudPaper Elevation="0" Class="pa-4" Style="background:#fafbfc;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:700; color:#1e293b;">✅ أنواع المهام</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Rounded.AddCircleOutline"
                                   OnClick="AddNewTaskType"
                                   Style="border-radius:12px; font-weight:600;">
                            إضافة نوع
                        </MudButton>
                    </div>
                    <MudTable Items="_task" Dense Hover Elevation="0" Style="border:1px solid #e2e8f0; border-radius:12px; overflow:hidden;">
                        <HeaderContent>
                            <MudTh>عربي</MudTh>
                            <MudTh>EN</MudTh>
                            <MudTh>حالة</MudTh>
                            <MudTh>إجراءات</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.TaskTypeNameAr</b></MudTd>
                            <MudTd>@context.TaskTypeName</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Error)" Variant="Variant.Text">
                                    @(context.IsActive ? "نشط" : "معطل")
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Rounded.EditNote" Size="Size.Small" Color="Color.Primary" OnClick="() => EditTask(context)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>

            @* ============ ADS TAB ============ *@
            <MudTabPanel Text="الحملات" TabIcon="@Icons.Material.Filled.Campaign">
                <MudPaper Elevation="0" Class="pa-4" Style="background:#fafbfc;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight:700; color:#1e293b;">📢 الحملات الإعلانية</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Rounded.AddCircleOutline"
                                   OnClick="AddNewAdType"
                                   Style="border-radius:12px; font-weight:600;">
                            إضافة حملة
                        </MudButton>
                    </div>
                    <MudTable Items="_ad" Dense Hover Elevation="0" Style="border:1px solid #e2e8f0; border-radius:12px; overflow:hidden;">
                        <HeaderContent>
                            <MudTh>عربي</MudTh>
                            <MudTh>EN</MudTh>
                            <MudTh>استخدام</MudTh>
                            <MudTh>حالة</MudTh>
                            <MudTh>إجراءات</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><b>@context.AdTypeNameAr</b></MudTd>
                            <MudTd>@context.AdTypeName</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                    @(_usage.GetValueOrDefault($"ad_{context.AdTypeId}", 0))
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Error)" Variant="Variant.Text">
                                    @(context.IsActive ? "نشط" : "معطل")
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Rounded.EditNote" Size="Size.Small" Color="Color.Primary" OnClick="() => EditAd(context)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@* ============ SOURCE DIALOG ============ *@
<MudDialog @bind-Visible="_dlgSrc" Options="_dlgOpt">
    <TitleContent>
        <MudStack Row Align="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Rounded.Source" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">
                @(_srcEdit.SourceId == 0 ? "✨ إضافة مصدر جديد" : "📝 تعديل المصدر")
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudCard Elevation="0" Style="background:#f8fafc; border-radius:16px;">
            <MudStack Spacing="3" Class="pa-4">
                <div style="background:linear-gradient(135deg,#667eea,#764ba2); border-radius:16px; padding:24px; text-align:center;">
                    <span style="font-size:3rem;">@(!string.IsNullOrEmpty(_srcEdit.SourceIcon) ? _srcEdit.SourceIcon : "📱")</span>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8);">معاينة الأيقونة</MudText>
                </div>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_srcEdit.SourceNameAr" Label="الاسم العربي *" Variant="Variant.Outlined" Required="true" RequiredError="مطلوب" Style="direction:rtl;" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_srcEdit.SourceName" Label="English Name *" Variant="Variant.Outlined" Required="true" RequiredError="Required" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_srcEdit.SourceIcon" Label="الأيقونة" Variant="Variant.Outlined" Placeholder="مثال: 📱 📞 💬 📧" HelperText="انسخ والصق الإيموجي المناسب من أي مكان" />
                    </MudItem>
                </MudGrid>
                <MudSwitch @bind-Value="_srcEdit.IsActive" Color="Color.Success" Label="✅ نشط" />
            </MudStack>
        </MudCard>
    </DialogContent>
    <DialogActions>
        <MudStack Row Spacing="2" Justify="Justify.FlexEnd" Class="w-100 pa-3">
            <MudButton OnClick="() => _dlgSrc = false" Variant="Variant.Text" StartIcon="@Icons.Material.Rounded.Close" Style="border-radius:10px;">إلغاء</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveSrc" StartIcon="@Icons.Material.Rounded.Save" Style="border-radius:10px; font-weight:600;">حفظ</MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>

@* ============ STAGE DIALOG ============ *@
<MudDialog @bind-Visible="_dlgStg" Options="_dlgOpt">
    <TitleContent>
        <MudStack Row Align="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Rounded.Timeline" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">
                @(_stgEdit.StageId == 0 ? "🎯 إضافة مرحلة جديدة" : "📝 تعديل المرحلة")
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudCard Elevation="0" Style="background:#f8fafc; border-radius:16px;">
            <MudStack Spacing="3" Class="pa-4">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_stgEdit.StageNameAr" Label="الاسم العربي *" Variant="Variant.Outlined" Required="true" Style="direction:rtl;" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_stgEdit.StageName" Label="English Name *" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudNumericField @bind-Value="_stgEdit.StageOrder" Label="الترتيب" Variant="Variant.Outlined" Min="1" Max="20" />
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">🎨 اختر لون المرحلة</MudText>

                <div style="background:@_stgEdit.StageColor; border-radius:16px; padding:24px; text-align:center;">
                    <MudText Typo="Typo.h5" Style="color:white; font-weight:700;">@_stgEdit.StageColor</MudText>
                </div>

                <div style="display:grid; grid-template-columns:repeat(8,1fr); gap:8px;">
                    @foreach (var color in new[] {
                        "#ef4444","#f97316","#f59e0b","#eab308","#84cc16","#22c55e","#10b981","#14b8a6",
                        "#06b6d4","#0ea5e9","#3b82f6","#6366f1","#8b5cf6","#a855f7","#d946ef","#ec4899",
                        "#f43f5e","#dc2626","#ea580c","#ca8a04","#65a30d","#16a34a","#0891b2","#2563eb",
                        "#4f46e5","#7c3aed","#9333ea","#c026d3","#be123c","#9d174d","#334155","#1e293b"
                    })
                    {
                        <div @onclick="() => _stgEdit.StageColor = color"
                             style="background:@color; aspect-ratio:1; border-radius:10px; cursor:pointer; border:3px solid @(_stgEdit.StageColor == color ? "#1e293b" : "transparent");">
                            @if (_stgEdit.StageColor == color)
                            {
                                <div style="display:flex; align-items:center; justify-content:center; height:100%;">
                                    <MudIcon Icon="@Icons.Material.Rounded.Check" Style="color:white;" Size="Size.Small" />
                                </div>
                            }
                        </div>
                    }
                </div>

                <MudTextField @bind-Value="_stgEdit.StageColor" Label="أو أدخل كود HEX" Variant="Variant.Outlined" Placeholder="#3b82f6" />
                <MudSwitch @bind-Value="_stgEdit.IsActive" Color="Color.Success" Label="✅ نشط" />
            </MudStack>
        </MudCard>
    </DialogContent>
    <DialogActions>
        <MudStack Row Spacing="2" Justify="Justify.FlexEnd" Class="w-100 pa-3">
            <MudButton OnClick="() => _dlgStg = false" Variant="Variant.Text" StartIcon="@Icons.Material.Rounded.Close">إلغاء</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveStg" StartIcon="@Icons.Material.Rounded.Save">حفظ</MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>

@* ============ LOST REASON DIALOG ============ *@
<MudDialog @bind-Visible="_dlgLost" Options="_dlgOpt">
    <TitleContent>
        <MudStack Row Align="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Rounded.HeartBroken" Color="Color.Error" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">
                @(_lostEdit.LostReasonId == 0 ? "💔 إضافة سبب خسارة" : "📝 تعديل سبب الخسارة")
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudCard Elevation="0" Style="background:#f8fafc; border-radius:16px;">
            <MudStack Spacing="3" Class="pa-4">
                <MudTextField @bind-Value="_lostEdit.ReasonNameAr" Label="الاسم العربي *" Variant="Variant.Outlined" Required="true" Style="direction:rtl;" />
                <MudTextField @bind-Value="_lostEdit.ReasonName" Label="English Name *" Variant="Variant.Outlined" Required="true" />
                <MudSwitch @bind-Value="_lostEdit.IsActive" Color="Color.Success" Label="✅ نشط" />
            </MudStack>
        </MudCard>
    </DialogContent>
    <DialogActions>
        <MudStack Row Spacing="2" Justify="Justify.FlexEnd" Class="w-100 pa-3">
            <MudButton OnClick="() => _dlgLost = false" Variant="Variant.Text" StartIcon="@Icons.Material.Rounded.Close">إلغاء</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="SaveLost" StartIcon="@Icons.Material.Rounded.Save">حفظ</MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>

@* ============ CATEGORY DIALOG ============ *@
<MudDialog @bind-Visible="_dlgCat" Options="_dlgOpt">
    <TitleContent>
        <MudStack Row Align="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Rounded.Category" Color="Color.Info" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">
                @(_catEdit.CategoryId == 0 ? "🏷️ إضافة فئة جديدة" : "📝 تعديل الفئة")
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudCard Elevation="0" Style="background:#f8fafc; border-radius:16px;">
            <MudStack Spacing="3" Class="pa-4">
                <MudTextField @bind-Value="_catEdit.CategoryNameAr" Label="الاسم العربي *" Variant="Variant.Outlined" Required="true" Style="direction:rtl;" />
                <MudTextField @bind-Value="_catEdit.CategoryName" Label="English Name *" Variant="Variant.Outlined" Required="true" />
                <MudSwitch @bind-Value="_catEdit.IsActive" Color="Color.Success" Label="✅ نشط" />
            </MudStack>
