@page "/crm/opportunities/{Id:int}"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Services
@using COCOBOLOERPNEW.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size
@using MudVariant = MudBlazor.Variant

@inject IOpportunityService OppService
@inject IInteractionService InteractionService
@inject ITaskService TaskService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider
@inject IDbContextFactory<db24804Context> DbFactory

<PageTitle>تفاصيل الفرصة — CRM</PageTitle>

@if (_isLoading)
{
    <div class="loading-screen">
        <div class="loading-inner">
            <MudProgressCircular Color="MudColor.Secondary" Size="MudSize.Large" Indeterminate="true" />
            <MudText Typo="Typo.h6" Style="color:var(--mud-palette-text-secondary);margin-top:1rem">جاري تحميل التفاصيل...</MudText>
        </div>
    </div>
}
else
{
<div dir="rtl" class="det-page">

    @* ════════════════════════════════════════════════════════════════ *@
    @*                     HEADER (STAGE COLOR)                       *@
    @* ════════════════════════════════════════════════════════════════ *@
    <div class="det-header" style="--stage:@StageColor">
        <div class="hdr-bg">
            <div class="hdr-grad"></div>
            <div class="hdr-dots"></div>
            <div class="hdr-glow1"></div>
            <div class="hdr-glow2"></div>
        </div>

        <div class="hdr-body">
            <div class="hdr-row1">
                <div class="hdr-left">
                    <button class="back-btn" @onclick="GoBack" title="رجوع">
                        <MudIcon Icon="@Icons.Material.Rounded.ArrowForward" Style="font-size:1.1rem" />
                    </button>
                    <div class="hdr-icon">
                        <MudIcon Icon="@Icons.Material.Rounded.TrackChanges" Style="font-size:1.4rem" />
                    </div>
                    <div class="hdr-title">
                        <h1>@_opp.ClientName</h1>
                    </div>
                    <span class="hdr-stage"
                          style="background:#ffffff25;color:#fff;border:1px solid #ffffff35">
                        @(_opp.StageNameAr ?? _opp.StageName)
                    </span>
                </div>

                <div class="hdr-actions">
                    @if (!string.IsNullOrWhiteSpace(_opp.Phone))
                    {
                        <button class="qa-btn" @onclick="() => CallPhone(_opp.Phone)" title="اتصال">
                            <MudIcon Icon="@Icons.Material.Rounded.Phone" Style="font-size:1rem" />
                        </button>
                        <button class="qa-btn" @onclick="() => OpenWhatsApp(_opp.Phone)" title="واتساب">
                            <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Style="font-size:1rem" />
                        </button>
                    }
                </div>
            </div>

            <div class="hdr-row2">
                <span class="hdr-meta">📞 @(_opp.Phone ?? "—")</span>
                <span class="hdr-meta">👤 @(_opp.EmployeeName ?? "—")</span>
                <span class="hdr-meta">📡 @(_opp.SourceName ?? "—")</span>
                <span class="hdr-meta">📅 @_opp.CreatedAt.ToString("yyyy/MM/dd")</span>
                @if (_opp.LastContactDate.HasValue)
                {
                    <span class="hdr-meta">آخر تواصل: @FormatRelativeDate(_opp.LastContactDate)</span>
                }
            </div>

            <div class="hdr-cards">
                <div class="sc-card sc-important">
                    <span class="sc-label">💰 القيمة المتوقعة</span>
                    <span class="sc-value sc-big">@(_opp.ExpectedValue?.ToString("N0") ?? "—") ج.م</span>
                </div>
                <div class="sc-card sc-important">
                    <span class="sc-label">📅 المتابعة القادمة</span>
                    <span class="sc-value @(_opp.NextFollowUpDate.HasValue && _opp.NextFollowUpDate.Value < DateTime.Today ? "val-danger" : "")">
                        @if (_opp.NextFollowUpDate.HasValue)
                        {
                            @FormatRelativeDate(_opp.NextFollowUpDate)
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                    @if (_opp.NextFollowUpDate.HasValue)
                    {
                        <span class="sc-badge @GetFollowUpClass(_opp.NextFollowUpDate)">@GetFollowUpText(_opp.NextFollowUpDate)</span>
                    }
                </div>
                <div class="sc-card">
                    <span class="sc-label">المنتج</span>
                    <span class="sc-value">@(_opp.InterestedProduct ?? "—")</span>
                </div>
                <div class="sc-card">
                    <span class="sc-label">التفاعلات</span>
                    <span class="sc-value">@_interactions.Count</span>
                </div>
                <div class="sc-card">
                    <span class="sc-label">مهام مفتوحة</span>
                    <span class="sc-value">@_tasks.Count(t => t.Status != "Completed")</span>
                </div>
                <div class="sc-card">
                    <span class="sc-label">أيام منذ أول تواصل</span>
                    <span class="sc-value">@_opp.DaysSinceFirstContact</span>
                </div>
            </div>
            @if (_opp.SourceLeadId.HasValue)
{
    <MudPaper Class="source-lead-card" Elevation="0">
        <div class="slc-icon">
            <MudIcon Icon="@Icons.Material.Rounded.Campaign" />
        </div>

        <div class="slc-content">
            <div class="slc-title">مصدر الفرصة: Lead من Meta</div>
            <div class="slc-meta">
                <span>الاسم: @_opp.SourceLeadName</span>
                @if (!string.IsNullOrWhiteSpace(_opp.SourceLeadPhone))
                {
                    <span>الهاتف: @_opp.SourceLeadPhone</span>
                }
                @if (!string.IsNullOrWhiteSpace(_opp.SourceLeadCampaign))
                {
                    <span>الحملة: @_opp.SourceLeadCampaign</span>
                }
                @if (!string.IsNullOrWhiteSpace(_opp.SourceLeadPlatform))
                {
                    <span>المنصة: @(_opp.SourceLeadPlatform == "fb" ? "Facebook" : _opp.SourceLeadPlatform == "ig" ? "Instagram" : _opp.SourceLeadPlatform)</span>
                }
            </div>
        </div>

        <MudButton Variant="MudVariant.Outlined"
                   Color="MudColor.Primary"
                   Size="MudSize.Small"
                   StartIcon="@Icons.Material.Rounded.OpenInNew"
                   OnClick="@(() => Navigation.NavigateTo($"/crm/leads/{_opp.SourceLeadId.Value}"))">
            فتح الـ Lead
        </MudButton>
    </MudPaper>
}

            @if (!string.IsNullOrWhiteSpace(_opp.Notes))
            {
                <div class="hdr-note">
                    <MudIcon Icon="@Icons.Material.Rounded.StickyNote2" Size="MudSize.Small" Style="opacity:0.7" />
                    <span>@_opp.Notes</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(_opp.Guidance))
            {
                <div class="hdr-note hdr-guidance">
                    <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="MudSize.Small" Style="opacity:0.7" />
                    <span>@_opp.Guidance</span>
                </div>
            }
        </div>
    </div>

    @* ════════════════════════════════════════════════════════════════ *@
    @*                   STAGE PIPELINE (STICKY)                      *@
    @* ════════════════════════════════════════════════════════════════ *@
    <div class="pipeline-bar">
        <div class="pipeline-main">
            @foreach (var stage in MainStages)
            {
                var isCurrent = stage.StageId == _opp.StageId;
                var isPast = IsStagePast(stage.StageId);
                var isWon = stage.StageId == 3;

                <div class="pipe-node @(isCurrent ? "pipe-active" : "") @(isPast ? "pipe-done" : "")"
                     @onclick="() => ChangeStageQuick(stage.StageId)">
                    <div class="pipe-circle"
                         style="@(isCurrent
                            ? $"background:{stage.StageColor ?? "#94a3b8"};border-color:{stage.StageColor ?? "#94a3b8"};color:#fff;box-shadow:0 0 0 4px {stage.StageColor ?? "#94a3b8"}25"
                            : isPast
                                ? $"background:{stage.StageColor ?? "#94a3b8"};border-color:{stage.StageColor ?? "#94a3b8"};color:#fff"
                                : $"background:transparent;border-color:{stage.StageColor ?? "#94a3b8"}60;color:{stage.StageColor ?? "#94a3b8"}")">
                        @if (isPast && !isCurrent)
                        {
                            <MudIcon Icon="@Icons.Material.Rounded.Check" Style="font-size:0.85rem" />
                        }
                        else if (isWon)
                        {
                            <MudIcon Icon="@Icons.Material.Rounded.EmojiEvents" Style="font-size:0.85rem" />
                        }
                        else
                        {
                            <span>@(stage.StageOrder)</span>
                        }
                    </div>
                    <span class="pipe-label" style="color:@(isCurrent ? stage.StageColor ?? "#94a3b8" : "var(--mud-palette-text-secondary)")">
                        @(stage.StageNameAr ?? stage.StageName)
                    </span>
                </div>

                @if (stage != MainStages.Last())
                {
                    <div class="pipe-connector @(isPast ? "conn-done" : "")">
                        <div class="conn-line" style="background:@(isPast ? stage.StageColor ?? "#94a3b8" : "var(--mud-palette-lines-default)")"></div>
                    </div>
                }
            }
        </div>

        <div class="pipeline-exit">
            @foreach (var stage in ExitStages)
            {
                var isCurrent = stage.StageId == _opp.StageId;
                var isDisabled = IsFirstInteraction && !isCurrent;

                <button class="exit-chip @(isCurrent ? "exit-active" : "") @(isDisabled ? "exit-disabled" : "")"
                        style="@(isCurrent
                            ? $"background:{stage.StageColor ?? "#94a3b8"};color:#fff;border-color:{stage.StageColor ?? "#94a3b8"}"
                            : $"border-color:{stage.StageColor ?? "#94a3b8"}50;color:{stage.StageColor ?? "#94a3b8"}")"
                        @onclick="() => ChangeStageQuick(stage.StageId)"
                        disabled="@isDisabled"
                        title="@(isDisabled ? "غير مسموح في أول تواصل — يجب المرور بمرحلة عميل محتمل أولاً" : "")">
                    <MudIcon Icon="@Icons.Material.Rounded.Close" Style="font-size:0.8rem" />
                    @(stage.StageNameAr ?? stage.StageName)
                </button>
            }
        </div>

        @if (IsFirstInteraction)
        {
            <div class="pipeline-hint">
                <MudIcon Icon="@Icons.Material.Rounded.Info" Size="MudSize.Small" Style="opacity:0.5" />
                <span>أول تواصل — يجب اختيار مرحلة "عميل محتمل" أو أحدث</span>
            </div>
        }
    </div>
    @if (_sourceLead != null)
{
    <MudPaper Class="source-lead-card" Elevation="0">
        <div class="slc-icon">
            <MudIcon Icon="@Icons.Material.Rounded.Campaign" />
        </div>

        <div class="slc-content">
            <div class="slc-title">مصدر الفرصة: Lead من Meta</div>
            <div class="slc-meta">
                <span>الاسم: @_sourceLead.FullName</span>

                @if (!string.IsNullOrWhiteSpace(_sourceLead.Phone))
                {
                    <span>الهاتف: @_sourceLead.Phone</span>
                }

                @if (!string.IsNullOrWhiteSpace(_sourceLead.CampaignName))
                {
                    <span>الحملة: @_sourceLead.CampaignName</span>
                }

                @if (!string.IsNullOrWhiteSpace(_sourceLead.Platform))
                {
                    <span>المنصة: @GetLeadPlatformText(_sourceLead.Platform)</span>
                }
            </div>
        </div>

        <MudButton Variant="MudVariant.Outlined"
                   Color="MudColor.Primary"
                   Size="MudSize.Small"
                   StartIcon="@Icons.Material.Rounded.OpenInNew"
                   OnClick="@(() => Navigation.NavigateTo($"/crm/leads/{_sourceLead.LeadId}"))">
            فتح الـ Lead
        </MudButton>
    </MudPaper>
}

    @* ════════════════════════════════════════════════════════════════ *@
    @*                     2-COLUMN LAYOUT                           *@
    @* ════════════════════════════════════════════════════════════════ *@
    <div class="det-layout">

        @* ═══ MAIN COLUMN ═══ *@
        <div class="det-main">

            @* ─── Lost Banner ─── *@
            @if (_opp.StageId == 4 || _opp.StageId == 5)
            {
                <div class="lost-banner" style="--stage:@StageColor">
                    <div class="lost-icon">
                        <MudIcon Icon="@Icons.Material.Rounded.Warning" Style="font-size:1.2rem" />
                    </div>
                    <div class="lost-info">
                        <strong>هذه الفرصة مغلقة — @(_opp.StageNameAr ?? _opp.StageName)</strong>
                        @if (!string.IsNullOrWhiteSpace(_opp.LostReasonName))
                        {
                            <span>سبب الخسارة: @_opp.LostReasonName</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(_opp.LostNotes))
                        {
                            <span>@_opp.LostNotes</span>
                        }
                    </div>
                </div>
            }
            @if (_sourceLead != null && _sourceLeadInteractions.Any())
{
    <div class="det-card source-history-card">
        <div class="card-head">
            <h3>
                <MudIcon Icon="@Icons.Material.Rounded.Timeline" Size="MudSize.Small" />
                تاريخ الـ Lead قبل التحويل
            </h3>
            <span class="count-badge">@_sourceLeadInteractions.Count</span>
        </div>

        <div class="source-history-body">
            @foreach (var item in _sourceLeadInteractions)
            {
                <div class="source-history-item">
                    <div class="shi-icon" style="background:@GetLeadInteractionBg(item.InteractionType);color:@GetLeadInteractionColor(item.InteractionType)">
                        <MudIcon Icon="@GetLeadInteractionIcon(item.InteractionType)" Size="MudSize.Small" />
                    </div>

                    <div class="shi-content">
                        <div class="shi-top">
                            <strong>@item.InteractionType</strong>
                            <span>@item.InteractionDate.ToString("yyyy/MM/dd HH:mm")</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(item.Summary))
                        {
                            <p>@item.Summary</p>
                        }
                        else if (!string.IsNullOrWhiteSpace(item.Notes))
                        {
                            <p>@item.Notes</p>
                        }

                        <div class="shi-meta">
                            @if (!string.IsNullOrWhiteSpace(item.CreatedBy))
                            {
                                <span>بواسطة: @item.CreatedBy</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(item.OldLeadStatus) ||
                                 !string.IsNullOrWhiteSpace(item.NewLeadStatus))
                            {
                                <span>
                                    الحالة:
                                    @(item.OldLeadStatus ?? "—")
                                    ←
                                    @(item.NewLeadStatus ?? "—")
                                </span>
                            }

                            @if (item.NextFollowUpDate.HasValue)
                            {
                                <span>متابعة: @item.NextFollowUpDate.Value.ToString("yyyy/MM/dd")</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

            @* ─── Quick Add Interaction ─── *@
            <div class="det-card card-accent" style="--stage:@StageColor">
                <div class="card-head accent-head">
                    <h3>
                        <MudIcon Icon="@Icons.Material.Rounded.AddComment" Size="MudSize.Small" />
                        إضافة تفاعل
                    </h3>
                    @if (IsFirstInteraction)
                    {
                        <span class="first-badge">أول تواصل</span>
                    }
                </div>
                <div class="card-body">
                    @if (!ShowLostFields)
                    {
                        <div class="qf-row">
                            <MudTextField T="string" Label="ملخص التفاعل"
                                          Variant="MudVariant.Outlined"
                                          @bind-Value="_newInteraction.Summary"
                                          Lines="2" Class="qf-full" />
                        </div>
                    }

                    <div class="qf-row">
                        <MudSelect T="int?" Label="طريقة التواصل"
                                   Variant="MudVariant.Outlined"
                                   @bind-Value="_newInteraction.StatusId"
                                   Dense="true" Class="qf-field" Clearable="true">
                            @foreach (var s in _statuses)
                            {
                                <MudSelectItem Value="@((int?)s.StatusId)">@(s.StatusNameAr ?? s.StatusName)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="int?" Label="المصدر"
                                   Variant="MudVariant.Outlined"
                                   @bind-Value="_newInteraction.SourceId"
                                   Dense="true" Class="qf-field" Clearable="true">
                            @foreach (var s in _sources)
                            {
                                <MudSelectItem Value="@((int?)s.SourceId)">
                                    @if (!string.IsNullOrWhiteSpace(s.SourceIcon))
                                    {
                                        <span>@s.SourceIcon</span>
                                    }
                                    @(s.SourceNameAr ?? s.SourceName)
                                </MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="int?" Label="الموظف"
                                   Variant="MudVariant.Outlined"
                                   @bind-Value="_newInteraction.EmployeeId"
                                   Dense="true" Class="qf-field" Clearable="true">
                            @foreach (var e in _employees)
                            {
                                <MudSelectItem Value="@((int?)e.EmployeeId)">@e.FullName</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="int?" Label="المرحلة بعد التفاعل"
                                   Variant="MudVariant.Outlined"
                                   @bind-Value="_newInteraction.StageAfterId"
                                   Dense="true" Class="qf-field">
                            @foreach (var s in _stages.OrderBy(s => s.StageOrder))
                            {
                                var isDisabledStage = IsFirstInteraction && (s.StageId == 4 || s.StageId == 5);
                                if (!isDisabledStage)
                                {
                                    <MudSelectItem Value="@((int?)s.StageId)">
                                        <span style="color:@(s.StageColor ?? "#666")">●</span>
                                        @(s.StageNameAr ?? s.StageName)
                                    </MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </div>

                    @if (!ShowLostFields)
                    {
                        <div class="qf-row">
                            <MudTextField T="string" Label="توجيه / ملاحظات للمتابعة"
                                          Variant="MudVariant.Outlined"
                                          @bind-Value="_guidanceText"
                                          Class="qf-full" />
                        </div>
                        <div class="qf-row">
                            <MudDatePicker T="DateTime?" Label="المتابعة القادمة"
                                           Variant="MudVariant.Outlined"
                                           Date="_newInteraction.NextFollowUpDate"
                                           DateChanged="d => _newInteraction.NextFollowUpDate = d ?? _newInteraction.NextFollowUpDate"
                                           Dense="true" Class="qf-field" />
                            <MudSelect T="int?" Label="نوع المهمة"
                                       Variant="MudVariant.Outlined"
                                       @bind-Value="_selectedTaskTypeId"
                                       Dense="true" Class="qf-field" Clearable="true">
                                @foreach (var tt in _taskTypes)
                                {
                                    <MudSelectItem Value="@((int?)tt.TaskTypeId)">@(tt.TaskTypeNameAr ?? tt.TaskTypeName)</MudSelectItem>
                                }
                            </MudSelect>
                            <MudSelect T="string" Label="أولوية المهمة"
                                       Variant="MudVariant.Outlined"
                                       @bind-Value="_selectedTaskPriority"
                                       Dense="true" Class="qf-field">
                                <MudSelectItem Value="@("High")">🔴 عالية</MudSelectItem>
                                <MudSelectItem Value="@("Medium")">🟡 متوسطة</MudSelectItem>
                                <MudSelectItem Value="@("Low")">🔵 منخفضة</MudSelectItem>
                            </MudSelect>
                            <MudButton Variant="MudVariant.Filled" Color="MudColor.Primary"
                                       OnClick="AddInteraction"
                                       StartIcon="@Icons.Material.Rounded.Send"
                                       Disabled="_addingInteraction"
                                       Class="qf-btn">
                                @(_addingInteraction ? "جاري..." : "حفظ")
                            </MudButton>
                        </div>
                    }

                    @if (ShowLostFields)
                    {
                        <div class="qf-row">
                            <MudSelect T="int?" Label="⚠️ سبب الخسارة"
                                       Variant="MudVariant.Outlined"
                                       @bind-Value="_newInteraction.LostReasonId"
                                       Dense="true" Class="qf-field-lost" Required="true">
                                @foreach (var lr in _lostReasons)
                                {
                                    <MudSelectItem Value="@((int?)lr.LostReasonId)">@(lr.ReasonNameAr ?? lr.ReasonName)</MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                        <div class="qf-row">
                            <MudTextField T="string" Label="ملاحظات الخسارة"
                                          Variant="MudVariant.Outlined"
                                          @bind-Value="_newInteraction.LostNotes"
                                          Lines="2" Class="qf-full" />
                        </div>
                        <div class="qf-row">
                            <div class="qf-spacer"></div>
                            <MudButton Variant="MudVariant.Filled" Color="MudColor.Error"
                                       OnClick="AddInteraction"
                                       StartIcon="@Icons.Material.Rounded.Report"
                                       Disabled="_addingInteraction"
                                       Class="qf-btn">
                                @(_addingInteraction ? "جاري..." : "تسجيل خسارة")
                            </MudButton>
                        </div>
                    }
                </div>
            </div>

            @* ─── Interactions Timeline ─── *@
            <div class="det-card">
                <div class="card-head">
                    <h3>
                        <MudIcon Icon="@Icons.Material.Rounded.History" Size="MudSize.Small" />
                        سجل التفاعلات
                        <span class="count-badge">@_interactions.Count</span>
                    </h3>
                </div>
                <div class="card-body">
                    @if (_interactions.Any())
                    {
                        <div class="timeline">
                            @foreach (var i in _interactions)
                            {
                                var stageColor = i.StageAfterId.HasValue
                                    ? _stages.FirstOrDefault(s => s.StageId == i.StageAfterId)?.StageColor ?? "#94a3b8"
                                    : "#94a3b8";
                                var hasStageChange = i.StageBeforeId != i.StageAfterId
                                                     && i.StageBeforeId.HasValue
                                                     && i.StageAfterId.HasValue;

                                <div class="tl-item">
                                    <div class="tl-rail">
                                        <div class="tl-dot" style="background:@stageColor; box-shadow:0 0 0 3px @(stageColor)25"></div>
                                        <div class="tl-line"></div>
                                    </div>
                                    <div class="tl-body">
                                    <div class="tl-top">
    <div class="tl-person-row">
        <strong class="tl-person">@(i.EmployeeName ?? i.CreatedBy ?? "—")</strong>
        @if (i.SourceName != null)
        {
            <span class="tl-chip tl-source">@i.SourceName</span>
        }
    </div>
</div>

@* Method + Date row *@
<div class="tl-date-row">
    @if (i.StatusName != null)
    {
        var (mIcon, mColor) = GetMethodInfo(i.StatusName);
        <span class="tl-method" style="--mcolor:@mColor">
            <MudIcon Icon="@mIcon" Style="font-size:0.9rem" />
            @i.StatusName
        </span>
        <span class="tl-date-sep">·</span>
    }
    <MudIcon Icon="@Icons.Material.Rounded.Schedule" Size="MudSize.Small" Style="opacity:0.4;font-size:0.8rem" />
    <span class="tl-date-text">
        تواصل في @FormatDateAr(i.InteractionDate)
    </span>
</div>

                                        @if (hasStageChange)
                                        {
                                            var fromColor = _stages.FirstOrDefault(s => s.StageId == i.StageBeforeId)?.StageColor ?? "#94a3b8";
                                            <div class="tl-stage-change">
                                                <span class="tl-stage-from" style="color:@fromColor">@(i.StageBeforeName ?? "—")</span>
                                                <MudIcon Icon="@Icons.Material.Rounded.ArrowLeft" Size="MudSize.Small"
                                                         Style="font-size:0.75rem;opacity:0.4" />
                                                <span class="tl-stage-to" style="color:@stageColor">@(i.StageAfterName ?? "—")</span>
                                            </div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(i.Summary))
                                        {
                                            <div class="tl-summary">@i.Summary</div>
                                        }

                                        <div class="tl-extras">
                                            @if (!string.IsNullOrWhiteSpace(i.Notes))
                                            {
                                                <span class="tl-note">📌 @i.Notes</span>
                                            }
                                            @if (i.NextFollowUpDate.HasValue)
                                            {
                                                var fuClass = i.NextFollowUpDate.Value < DateTime.Today ? "fu-overdue" : "fu-normal";
                                                <span class="tl-followup @fuClass">📅 متابعة: @FormatDateAr(i.NextFollowUpDate.Value)</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-box">
                            <MudIcon Icon="@Icons.Material.Rounded.ChatBubbleOutline" Size="MudSize.Large"
                                     Style="opacity:0.3" />
                            <span>لا توجد تفاعلات بعد</span>
                            <span class="empty-hint">أضف أول تفاعل أعلاه</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ═══ SIDEBAR ═══ *@
        <div class="det-side">

            @* ─── Last Activity Card ─── *@
            <div class="det-card card-activity" style="--stage:@StageColor">
                <div class="card-body activity-body">
                    <div class="act-item">
                        <div class="act-icon">
                            <MudIcon Icon="@Icons.Material.Rounded.LastPage" Style="font-size:1rem" />
                        </div>
                        <div class="act-info">
                            <span class="act-label">آخر نشاط</span>
                            <span class="act-val">
                                @if (_interactions.Any())
                                {
                                    var last = _interactions.First();
                                    <text>تواصل في @FormatDateAr(last.InteractionDate)</text>
                                }
                                else
                                {
                                    <text>لا يوجد بعد</text>
                                }
                            </span>
                        </div>
                    </div>
                    <div class="act-divider"></div>
                    <div class="act-item">
                        <div class="act-icon act-next @(_opp.NextFollowUpDate.HasValue && _opp.NextFollowUpDate.Value < DateTime.Today ? "act-overdue" : "")">
                            <MudIcon Icon="@Icons.Material.Rounded.Upcoming" Style="font-size:1rem" />
                        </div>
                        <div class="act-info">
                            <span class="act-label">المتابعة القادمة</span>
                            <span class="act-val @(_opp.NextFollowUpDate.HasValue && _opp.NextFollowUpDate.Value < DateTime.Today ? "val-danger" : "")">
                                @if (_opp.NextFollowUpDate.HasValue)
                                {
                                    @FormatRelativeDate(_opp.NextFollowUpDate)
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            @* ─── Opportunity Summary ─── *@
            <div class="det-card" style="--stage:@StageColor">
                <div class="card-head">
                    <h3>
                        <MudIcon Icon="@Icons.Material.Rounded.Info" Size="MudSize.Small" />
                        ملخص الفرصة
                    </h3>
                </div>
                <div class="card-body">
                    <div class="info-grid">
                        <div class="info-item info-highlight">
                            <span class="info-label">💰 القيمة</span>
                            <span class="info-val info-big">@(_opp.ExpectedValue?.ToString("N0") ?? "—") ج.م</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">الموظف</span>
                            <span class="info-val">@(_opp.EmployeeName ?? "—")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">المصدر</span>
                            <span class="info-val">@(_opp.SourceName ?? "—")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">المنتج</span>
                            <span class="info-val">@(_opp.InterestedProduct ?? "—")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">أول تواصل</span>
                            <span class="info-val">@FormatDateAr(_opp.FirstContactDate)</span>
                        </div>
                        <div class="info-item @(_opp.NextFollowUpDate.HasValue && _opp.NextFollowUpDate.Value < DateTime.Today ? "info-danger" : "")">
                            <span class="info-label">المتابعة</span>
                            <span class="info-val">
                                @if (_opp.NextFollowUpDate.HasValue)
                                {
                                    @FormatDateAr(_opp.NextFollowUpDate.Value)
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </span>
                        </div>
                        @if (_opp.LostReasonId.HasValue)
                        {
                            <div class="info-item full-width info-danger">
                                <span class="info-label">⚠️ سبب الخسارة</span>
                                <span class="info-val">@(_opp.LostReasonName ?? "—")</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_opp.LostNotes))
                        {
                            <div class="info-item full-width">
                                <span class="info-label">ملاحظات الخسارة</span>
                                <span class="info-val">@_opp.LostNotes</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_opp.Address))
                        {
                            <div class="info-item full-width">
                                <span class="info-label">العنوان</span>
                                <span class="info-val">@_opp.Address</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* ─── Tasks (with inline quick add) ─── *@
            <div class="det-card" style="--stage:@StageColor">
                <div class="card-head">
                    <h3>
                        <MudIcon Icon="@Icons.Material.Rounded.Assignment" Size="MudSize.Small" />
                        المهام
                        <span class="count-badge">@_tasks.Count</span>
                    </h3>
                    @if (_canEdit)
                    {
                        <button class="task-add-btn" @onclick="ToggleQuickTask">
                            <MudIcon Icon="@(_showQuickTask ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.Add)" Style="font-size:1.1rem" />
                        </button>
                    }
                </div>
                <div class="card-body">
                    @if (_showQuickTask)
                    {
                        <div class="quick-task-form">
                            <div class="qf-row">
                                <MudTextField T="string" Label="وصف المهمة"
                                              Variant="MudVariant.Outlined"
                                              @bind-Value="_newTask.TaskDescription"
                                              Class="qf-full" Dense="true" />
                            </div>
                            <div class="qf-row">
                                <MudDatePicker T="DateTime?" Label="الاستحقاق"
                                               Variant="MudVariant.Outlined"
                                               Date="_newTask.DueDate"
                                               DateChanged="d => _newTask.DueDate = d ?? _newTask.DueDate"
                                               Dense="true" Class="qf-field" />
                                <MudSelect T="int" Label="أسند إلى"
                                           Variant="MudVariant.Outlined"
                                           @bind-Value="_newTask.AssignedTo"
                                           Dense="true" Class="qf-field">
                                    @foreach (var e in _employees)
                                    {
                                        <MudSelectItem Value="@(e.EmployeeId)">@e.FullName</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="qf-row">
                                <MudSelect T="int?" Label="نوع المهمة"
                                           Variant="MudVariant.Outlined"
                                           @bind-Value="_newTask.TaskTypeId"
                                           Dense="true" Class="qf-field" Clearable="true">
                                    @foreach (var tt in _taskTypes)
                                    {
                                        <MudSelectItem Value="@((int?)tt.TaskTypeId)">@(tt.TaskTypeNameAr ?? tt.TaskTypeName)</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudSelect T="string" Label="الأولوية"
                                           Variant="MudVariant.Outlined"
                                           @bind-Value="_newTask.Priority"
                                           Dense="true" Class="qf-field">
                                    <MudSelectItem Value="@("High")">🔴 عالية</MudSelectItem>
                                    <MudSelectItem Value="@("Medium")">🟡 متوسطة</MudSelectItem>
                                    <MudSelectItem Value="@("Low")">🔵 منخفضة</MudSelectItem>
                                </MudSelect>
                            </div>
                            <div class="qf-row">
                                <div class="qf-spacer"></div>
                                <MudButton Variant="MudVariant.Filled" Color="MudColor.Success"
                                           OnClick="AddTask"
                                           StartIcon="@Icons.Material.Rounded.Add"
                                           Disabled="_addingTask"
                                           Size="MudSize.Small">
                                    @(_addingTask ? "جاري..." : "إضافة")
                                </MudButton>
                            </div>
                        </div>
                    }

                    @if (_tasks.Any())
                    {
                        <div class="task-list">
                            @foreach (var t in _tasks.Where(t => t.Status != "Completed"))
                            {
                                var priColor = t.Priority switch { "High" => "#ef4444", "Medium" => "#f59e0b", _ => "#3b82f6" };
                                var priLabel = t.Priority switch { "High" => "عالية", "Medium" => "متوسطة", _ => "منخفضة" };
                                <div class="task-row @(t.TaskDueStatus == "Overdue" ? "task-overdue" : "")">
                                    <div class="task-pri" style="background:@priColor"></div>
                                    <div class="task-content">
                                        <span class="task-desc">@t.TaskDescription</span>
                                        <div class="task-chips">
                                            <span class="task-chip" style="background:@(priColor)15;color:@(priColor)">@priLabel</span>
                                            @if (t.TaskTypeName != null)
                                            {
                                                <span class="task-chip task-type-chip">@t.TaskTypeName</span>
                                            }
                                            @if (t.TaskDueStatus == "Overdue")
                                            {
                                                <span class="task-chip task-overdue-chip">⚠️ متأخرة</span>
                                            }
                                            <span class="task-meta-inline">👤 @t.AssignedToName · 📅 @FormatDateAr(t.DueDate)</span>
                                        </div>
                                    </div>
                                    <button class="task-complete" @onclick="() => CompleteTask(t.TaskId)" title="إكمال">
                                        <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Style="font-size:1.1rem" />
                                    </button>
                                </div>
                            }

                            @foreach (var t in _tasks.Where(t => t.Status == "Completed"))
                            {
                                <div class="task-row task-done">
                                    <div class="task-pri" style="background:#10b981"></div>
                                    <div class="task-content">
                                        <span class="task-desc">@t.TaskDescription</span>
                                        <span class="task-meta-inline">
                                            <span class="task-chip task-done-chip">✅ مكتملة</span>
                                            @if (!string.IsNullOrWhiteSpace(t.CompletedBy))
                                            {
                                                <span>بواسطة @t.CompletedBy ·</span>
                                            }
                                            @if (t.CompletedDate.HasValue)
                                            {
                                                <span>@FormatDateAr(t.CompletedDate.Value)</span>
                                            }
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else if (!_showQuickTask)
                    {
                        <div class="empty-box small">
                            <span>لا توجد مهام</span>
                            <span class="empty-hint">أنشئ أول مهمة من الزر أعلاه</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
}

<style>
    /* ════════════════════════════════════ */
    /*            PAGE BASE                */
    /* ════════════════════════════════════ */
    .det-page { padding: 0 1.5rem 3rem; }
    .loading-screen { display: flex; align-items: center; justify-content: center; min-height: 60vh; }
    .loading-inner { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }

    /* ════════════════════════════════════ */
    /*      HEADER (CSS VARIABLE)          */
    /* ════════════════════════════════════ */
    .det-header {
        position: relative; border-radius: 20px; overflow: hidden; margin-bottom: 0.75rem;
        box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    }
    .hdr-bg { position: absolute; inset: 0; }
    .hdr-grad {
        position: absolute; inset: 0;
        background: var(--stage, #7c3aed);
    }
    .hdr-dots {
        position: absolute; inset: 0;
        background-image: radial-gradient(rgba(255,255,255,0.07) 1px, transparent 1px);
        background-size: 18px 18px;
    }
    .hdr-glow1 {
        position: absolute; width: 200px; height: 200px;
        border-radius: 50%; filter: blur(65px);
        top: -60px; right: -40px;
        background: #fff; opacity: 0.15;
    }
    .hdr-glow2 {
        position: absolute; width: 140px; height: 140px;
        border-radius: 50%; filter: blur(50px);
        bottom: -30px; left: 10%;
        background: #fff; opacity: 0.1;
    }
    .hdr-body { position: relative; z-index: 1; padding: 1.5rem 1.75rem 1.25rem; color: #fff; }

    .hdr-row1 { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.65rem; }
    .hdr-left { display: flex; align-items: center; gap: 0.65rem; }
    .back-btn {
        width: 36px; height: 36px; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.15);
        border-radius: 10px; color: #fff; display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all 0.2s;
    }
    .back-btn:hover { background: rgba(255,255,255,0.22); transform: scale(1.05); }
    .hdr-icon {
        width: 46px; height: 46px; background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.18);
        border-radius: 13px; display: flex; align-items: center; justify-content: center;
        backdrop-filter: blur(4px);
    }
    .hdr-title h1 { margin: 0; font-size: 1.45rem; font-weight: 800; letter-spacing: -0.3px; text-shadow: 0 1px 3px rgba(0,0,0,0.15); }
    .hdr-stage { padding: 4px 14px; border-radius: 8px; font-size: 0.9rem; font-weight: 800; white-space: nowrap; backdrop-filter: blur(4px); }
    .hdr-actions { display: flex; gap: 0.35rem; }
    .qa-btn {
        width: 38px; height: 38px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
        border-radius: 10px; color: #fff; display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all 0.2s;
    }
    .qa-btn:hover { background: rgba(255,255,255,0.22); transform: scale(1.08); }

    .hdr-row2 { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 0.7rem; }
    .hdr-meta { font-size: 0.92rem; opacity: 0.95; font-weight: 600; }

    .hdr-cards { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0.5rem; margin-top: 1rem; }
    .sc-card {
        background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
        border-radius: 12px; padding: 0.65rem 0.8rem; position: relative;
        transition: all 0.2s; backdrop-filter: blur(2px);
    }
    .sc-card:hover { transform: translateY(-1px); background: rgba(255,255,255,0.12); }
    .sc-important { background: rgba(255,255,255,0.14); border-color: rgba(255,255,255,0.2); }
    .sc-label { font-size: 0.82rem; opacity: 0.9; display: block; margin-bottom: 0.15rem; font-weight: 600; }
.sc-value { font-size: 1.1rem; font-weight: 800; display: block; line-height: 1.3; }
.sc-big { font-size: 1.3rem; }
    .val-danger { color: #fca5a5 !important; }
    .sc-badge { position: absolute; top: 6px; left: 6px; padding: 1px 6px; border-radius: 5px; font-size: 0.6rem; font-weight: 700; }
    .fu-overdue-badge { background: #ef4444; color: #fff; }
    .fu-today-badge { background: #f59e0b; color: #fff; }
    .fu-soon-badge { background: #10b981; color: #fff; }

    .hdr-note { margin-top: 0.75rem; padding: 0.55rem 0.8rem; background: rgba(255,255,255,0.06); border-radius: 8px; font-size: 0.92rem; font-weight: 600; display: flex; align-items: flex-start; gap: 0.4rem; }
    .hdr-guidance { background: rgba(251,191,36,0.12); }

    /* ════════════════════════════════════ */
    /*       STAGE PIPELINE (STICKY)       */
    /* ════════════════════════════════════ */
    .pipeline-bar {
        position: sticky; top: 8px; z-index: 15;
        padding: 0.85rem 1.25rem;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 16px; margin-bottom: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }
    .pipeline-main { display: flex; align-items: flex-start; gap: 0; justify-content: center; flex-wrap: wrap; }
    .pipe-node {
        display: flex; flex-direction: column; align-items: center; gap: 5px;
        cursor: pointer; transition: all 0.2s; padding: 0 2px;
    }
    .pipe-node:hover { transform: translateY(-2px); }
    .pipe-circle {
        width: 36px; height: 36px; border-radius: 50%; border: 2.5px solid;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.78rem; font-weight: 800; transition: all 0.25s;
