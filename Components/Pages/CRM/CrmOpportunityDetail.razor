    private async Task AddInteraction()
    {
        if (IsFirstInteraction && (_newInteraction.StageAfterId == 4 || _newInteraction.StageAfterId == 5))
        {
            Snackbar.Add("غير مسموح بتسجيل خسارة في أول تواصل — يجب المرور بمرحلة عميل محتمل أولاً", Severity.Warning);
            return;
        }

        if (ShowLostFields)
        {
            if (!_newInteraction.LostReasonId.HasValue) { Snackbar.Add("اختر سبب الخسارة", Severity.Warning); return; }
            if (string.IsNullOrWhiteSpace(_newInteraction.LostNotes)) { Snackbar.Add("اكتب ملاحظات الخسارة", Severity.Warning); return; }
            _newInteraction.Summary = _newInteraction.LostNotes;
        }
        else
        {
            if (string.IsNullOrWhiteSpace(_newInteraction.Summary)) { Snackbar.Add("اكتب ملخص التفاعل", Severity.Warning); return; }
        }

        if (!_newInteraction.StageAfterId.HasValue) { Snackbar.Add("اختر المرحلة", Severity.Warning); return; }

        _addingInteraction = true;
        try
        {
            _newInteraction.StageBeforeId = _stageBeforeId;
            _newInteraction.Notes = _guidanceText;

            var (ok, msg) = await InteractionService.AddQuickAsync(_newInteraction, _currentUserName!);
            if (!ok) { Snackbar.Add(msg, Severity.Error); return; }

            var formDto = await OppService.GetOpportunityForEditAsync(Id);
            if (formDto != null)
            {
                formDto.StageId = _newInteraction.StageAfterId.Value;
                formDto.NextFollowUpDate = ShowLostFields ? null : _newInteraction.NextFollowUpDate;
                formDto.LostReasonId = _newInteraction.LostReasonId;
                formDto.LostNotes = _newInteraction.LostNotes;
                formDto.Notes = _newInteraction.Summary;
                formDto.Guidance = _guidanceText;
                await OppService.SaveOpportunityAsync(formDto, _currentUserName!);
            }

            var stageId = _newInteraction.StageAfterId.Value;

            if (stageId == 4 || stageId == 5)
            {
                var label = stageId == 4 ? "خسارة" : "غير مهتم";
                await TaskService.CloseAllTasksForOpportunityAsync(Id, "Completed", $"تم الإلغاء تلقائياً - العميل {label}", _currentUserName!);
            }
            else if (stageId == 3)
            {
                await TaskService.CloseAllTasksForOpportunityAsync(Id, "Completed", "تم الإغلاق تلقائياً - تم البيع بنجاح", _currentUserName!);
            }
            else if (_newInteraction.NextFollowUpDate.HasValue)
            {
                await TaskService.CloseAllTasksForOpportunityAsync(Id, "Completed", "تم المتابعة وجدولة موعد جديد", _currentUserName!);
                var autoTask = new QuickTaskDto
                {
                    OpportunityId = Id,
                    PartyId = _opp.PartyId,
                    AssignedTo = _newInteraction.EmployeeId ?? _opp.EmployeeId ?? 0,
                    TaskTypeId = _selectedTaskTypeId,
                    TaskDescription = _guidanceText ?? "متابعة",
                    DueDate = _newInteraction.NextFollowUpDate.Value,
                    Priority = _selectedTaskPriority
                };
                await TaskService.AddQuickAsync(autoTask, _currentUserName!);
            }

            await ReloadData();
            _stageBeforeId = _opp.StageId;
            InitInteractionForm();
            Snackbar.Add("تم حفظ التفاعل بنجاح", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _addingInteraction = false;
        }
    }

    // ═══════════════════════════════════════════
    //        QUICK STAGE CHANGE (PIPELINE)
    // ═══════════════════════════════════════════
    private async Task ChangeStageQuick(int newStageId)
    {
        if (_opp.StageId == newStageId) return;
        if (IsFirstInteraction && (newStageId == 4 || newStageId == 5))
        {
            Snackbar.Add("غير مسموح في أول تواصل — يجب المرور بمرحلة عميل محتمل أولاً", Severity.Warning);
            return;
        }
        var (ok, msg) = await OppService.MoveStageAsync(Id, newStageId, _currentUserName!);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) { await ReloadData(); _stageBeforeId = _opp.StageId; }
    }

    // ═══════════════════════════════════════════
    //               TASKS
    // ═══════════════════════════════════════════
    private async Task AddTask()
    {
        if (string.IsNullOrWhiteSpace(_newTask.TaskDescription)) { Snackbar.Add("اكتب وصف المهمة", Severity.Warning); return; }
        if (_newTask.AssignedTo == 0) { Snackbar.Add("اختر المسؤول", Severity.Warning); return; }

        _addingTask = true;
        try
        {
            var (ok, msg) = await TaskService.AddQuickAsync(_newTask, _currentUserName!);
            Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
            if (ok) { await ReloadData(); InitTaskForm(); _showQuickTask = false; }
        }
        finally
        {
            _addingTask = false;
        }
    }

    private async Task CompleteTask(int taskId)
    {
        var (ok, msg) = await TaskService.CompleteAsync(taskId, "", _currentUserName!);
        Snackbar.Add(msg, ok ? Severity.Success : Severity.Error);
        if (ok) await ReloadData();
    }

