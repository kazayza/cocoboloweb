    // ═══════════════════════════════════════════
    private string StageColor => _opp.StageColor ?? "#7c3aed";

    private bool IsFirstInteraction => _interactions.Count == 0;
    private bool ShowLostFields => _newInteraction.StageAfterId == 4 || _newInteraction.StageAfterId == 5;

    private List<SalesStage> MainStages => _stages.Where(s => s.StageId != 4 && s.StageId != 5).OrderBy(s => s.StageOrder).ToList();
    private List<SalesStage> ExitStages => _stages.Where(s => s.StageId == 4 || s.StageId == 5).OrderBy(s => s.StageOrder).ToList();

    private bool IsStagePast(int stageId)
    {
        var currentOrder = _stages.FirstOrDefault(s => s.StageId == _opp.StageId)?.StageOrder ?? 0;
        var stageOrder = _stages.FirstOrDefault(s => s.StageId == stageId)?.StageOrder ?? 0;
        return stageOrder < currentOrder;
    }

    // ═══════════════════════════════════════════
    //           DATE HELPERS
    // ═══════════════════════════════════════════
    private static string FormatDateAr(DateTime date)
    {
        var months = new[] { "", "يناير", "فبراير", "مارس", "أبريل", "مايو", "يونيو", "يوليو", "أغسطس", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر" };
        var h = date.Hour;
        var period = h >= 12 ? "م" : "ص";
        var h12 = h > 12 ? h - 12 : (h == 0 ? 12 : h);
        return $"{date.Day} {months[date.Month]} {date.Year} — {h12}:{date.Minute:D2} {period}";
    }

    private static string FormatRelativeDate(DateTime? date)
    {
        if (!date.HasValue) return "—";
        var diff = (date.Value.Date - DateTime.Today).Days;
        if (diff < -7) return $"منذ {Math.Abs(diff)} يوم";
        if (diff < -1) return $"منذ {Math.Abs(diff)} أيام";
        if (diff == -1) return "أمس";
        if (diff == 0) return "اليوم";
        if (diff == 1) return "غدًا";
        if (diff <= 7) return $"بعد {diff} أيام";
        return $"بعد {diff} يوم";
    }
    private static (string Icon, string Color) GetMethodInfo(string? statusName)
{
    if (string.IsNullOrWhiteSpace(statusName)) return (Icons.Material.Rounded.HelpOutline, "#94a3b8");
    
    // أول تواصل
    if (statusName.Contains("أول تواصل") || statusName.Contains("First Contact"))
        return (Icons.Material.Rounded.NewReleases, "#8b5cf6");
    
    // تم الاتصال
    if (statusName.Contains("تم الاتصال") || statusName.Contains("Called"))
        return (Icons.Material.Rounded.Phone, "#3b82f6");
    
    // رسالة (عادية)
    if (statusName.Contains("رسالة") && !statusName.Contains("واتس"))
        return (Icons.Material.Rounded.Sms, "#06b6d4");
    
    // عميل قديم
    if (statusName.Contains("عميل قديم") || statusName.Contains("Old Client"))
        return (Icons.Material.Rounded.Person, "#f59e0b");
    
    // زيارة للمعرض
    if (statusName.Contains("زيارة") || statusName.Contains("Visit"))
        return (Icons.Material.Rounded.Store, "#10b981");
    
    // رساله واتس
    if (statusName.Contains("واتس") || statusName.Contains("Whats"))
        return (Icons.Custom.Brands.WhatsApp, "#25d366");
    
    return (Icons.Material.Rounded.QuestionMark, "#94a3b8");
}

    // ═══════════════════════════════════════════
    //               LIFECYCLE
    // ═══════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUserName = user.Identity?.Name ?? "System";

            _canView = user.HasClaim("Permission", "frmNewInteraction:View") || user.IsInRole("Admin");
            _canEdit = user.HasClaim("Permission", "frmNewInteraction:Edit") || user.IsInRole("Admin");
            _canDelete = user.HasClaim("Permission", "frmNewInteraction:Delete") || user.IsInRole("Admin");

            if (!_canView) { Navigation.NavigateTo("/"); return; }

            _stages = await OppService.GetStagesAsync();
            _sources = await OppService.GetSourcesAsync();
            _statuses = await OppService.GetContactStatusesAsync();
            _lostReasons = await OppService.GetLostReasonsAsync();
            _taskTypes = await OppService.GetTaskTypesAsync();
            _employees = await OppService.GetActiveEmployeesAsync();

            var detail = await OppService.GetOpportunityDetailAsync(Id);
            if (detail == null || detail.OpportunityId == 0)
            {
                Navigation.NavigateTo("/crm/opportunities");
                return;
            }
            _opp = detail;
            _stageBeforeId = _opp.StageId;

            _interactions = await InteractionService.GetByOpportunityAsync(Id);
            _tasks = await TaskService.GetByOpportunityAsync(Id);
            await LoadSourceLeadAsync();

            InitInteractionForm();
            InitTaskForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطأ: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void InitInteractionForm()
    {
        _newInteraction = new()
        {
            OpportunityId = Id,
            PartyId = _opp.PartyId,
            StageAfterId = _opp.StageId,
            EmployeeId = _opp.EmployeeId,
            SourceId = _opp.SourceId
        };
        _guidanceText = null;
        _selectedTaskTypeId = null;
        _selectedTaskPriority = "Medium";
    }

    private void InitTaskForm()
    {
        _newTask = new()
        {
            OpportunityId = Id,
            PartyId = _opp.PartyId,
            DueDate = DateTime.Today.AddDays(1),
            Priority = "Medium",
            AssignedTo = _opp.EmployeeId ?? 0
        };
    }

