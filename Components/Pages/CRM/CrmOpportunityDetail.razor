    private string GetFollowUpText(DateTime? date)
    {
        if (!date.HasValue) return "";
        var d = date.Value.Date; var today = DateTime.Today;
        if (d < today) return "متأخرة";
        if (d == today) return "اليوم";
        if (d == today.AddDays(1)) return "غدًا";
        if (d < today.AddDays(7)) return "هذا الأسبوع";
        return "مجدولة";
    }

    private string GetFollowUpClass(DateTime? date)
    {
        if (!date.HasValue) return "";
        var d = date.Value.Date; var today = DateTime.Today;
        if (d < today) return "fu-overdue-badge";
        if (d == today) return "fu-today-badge";
        return "fu-soon-badge";
    }
