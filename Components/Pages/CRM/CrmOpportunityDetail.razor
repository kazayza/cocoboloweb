    private async Task LoadSourceLeadAsync()
{
    await using var db = await DbFactory.CreateDbContextAsync();

    _sourceLead = await db.LeadsCRMs
        .AsNoTracking()
        .Where(l => l.ConvertedOpportunityId == Id)
        .Select(l => new SourceLeadInfo
        {
            LeadId = l.LeadId,
            FullName = l.FullName,
            Phone = l.Phone,
            CampaignName = l.CampaignName,
            Platform = l.Platform
        })
        .FirstOrDefaultAsync();

    if (_sourceLead == null)
    {
        _sourceLeadInteractions = new();
        return;
    }

    _sourceLeadInteractions = await db.LeadInteractions
        .AsNoTracking()
        .Where(i => i.LeadId == _sourceLead.LeadId)
        .OrderByDescending(i => i.InteractionDate)
        .Select(i => new SourceLeadInteractionRow
        {
            LeadInteractionId = i.LeadInteractionId,
            LeadId = i.LeadId,
            InteractionType = i.InteractionType,
            InteractionDate = i.InteractionDate,
            Summary = i.Summary,
            Notes = i.Notes,
            OldLeadStatus = i.OldLeadStatus,
            NewLeadStatus = i.NewLeadStatus,
            NextFollowUpDate = i.NextFollowUpDate,
            CreatedBy = i.CreatedBy,
            CreatedAt = i.CreatedAt
        })
        .ToListAsync();
}

    // ═══════════════════════════════════════════
