<div class="info-item @(Wide ? "wide" : "")">
    <span class="info-label">@Label</span>
    <span class="info-value @(Ltr ? "ltr" : "")">@(string.IsNullOrWhiteSpace(Value) ? "—" : Value)</span>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool Wide { get; set; }
    [Parameter] public bool Ltr { get; set; }
}