    // ═══ AUTO REFRESH ═══
    private void StartAutoRefresh()
    {
        _lastRefreshTime = DateTime.Now;
        _autoRefreshTimer = new System.Timers.Timer(60000);
        _autoRefreshTimer.Elapsed += async (_, _) =>
        {
            var diff = DateTime.Now - _lastRefreshTime;
            await InvokeAsync(async () =>
            {
                _refreshLabel = diff.TotalMinutes < 1 ? "الآن" : $"منذ {(int)diff.TotalMinutes} دقيقة";
                if (diff.TotalMinutes >= 5)
                {
                    await LoadData();
                    _lastRefreshTime = DateTime.Now;
                    _refreshLabel = "الآن";
                }
                StateHasChanged();
            });
        };
        _autoRefreshTimer.Start();
    }

    private async Task ManualRefresh()
    {
        _lastRefreshTime = DateTime.Now;
        _refreshLabel = "الآن";
        await LoadData();
    }

    // ═══ PREFS ═══
    private async Task LoadPrefs()
    {
        try
        {
            var view = await JS.InvokeAsync<string?>("loadTasksPrefs", "viewMode");
            if (view != null && Enum.TryParse<ViewMode>(view, out var vm)) _viewMode = vm;
            var chip = await JS.InvokeAsync<string?>("loadTasksPrefs", "quickFilter");
            if (chip != null) _quickFilter = chip;
            var ps = await JS.InvokeAsync<int?>("loadTasksPrefs", "pageSize");
            if (ps.HasValue) _filter.PageSize = ps.Value;
            var gm = await JS.InvokeAsync<string?>("loadTasksPrefs", "groupMode");
            if (gm != null && Enum.TryParse<GroupMode>(gm, out var g)) _groupMode = g;

            // ✅ تثبيت الفلتر - نفس فكرة شاشة المنتجات
            var filterJson = await JS.InvokeAsync<string?>("loadTasksPrefs", "filterState");
            if (!string.IsNullOrEmpty(filterJson))
            {
                try
                {
                    var saved = System.Text.Json.JsonSerializer.Deserialize<TaskFilterState>(filterJson);
                    if (saved != null)
                    {
                        if (saved.SearchText != null) _filter.SearchText = saved.SearchText;
                        if (saved.AssignedTo.HasValue) _filter.AssignedTo = saved.AssignedTo;
                        if (saved.TaskTypeId.HasValue) _filter.TaskTypeId = saved.TaskTypeId;
                        if (saved.Priority != null) _filter.Priority = saved.Priority;
                        if (saved.Status != null) _filter.Status = saved.Status;
                        if (saved.DateFrom.HasValue) _filter.DateFrom = saved.DateFrom;
                        if (saved.DateTo.HasValue) _filter.DateTo = saved.DateTo;
                    }
                }
                catch { /* ignore bad JSON */ }
            }
        }
        catch { }
    }

    private async Task SavePrefs()
    {
        try
        {
            await JS.InvokeVoidAsync("saveTasksPrefs", "viewMode", _viewMode.ToString());
            await JS.InvokeVoidAsync("saveTasksPrefs", "quickFilter", _quickFilter);
            await JS.InvokeVoidAsync("saveTasksPrefs", "pageSize", _filter.PageSize);
            await JS.InvokeVoidAsync("saveTasksPrefs", "groupMode", _groupMode.ToString());

            // ✅ تثبيت الفلتر
            var filterState = new TaskFilterState
            {
                SearchText = _filter.SearchText,
                AssignedTo = _filter.AssignedTo,
                TaskTypeId = _filter.TaskTypeId,
                Priority = _filter.Priority,
                Status = _filter.Status,
                DateFrom = _filter.DateFrom,
                DateTo = _filter.DateTo
            };
            var filterJson = System.Text.Json.JsonSerializer.Serialize(filterState);
            await JS.InvokeVoidAsync("saveTasksPrefs", "filterState", filterJson);
        }
        catch { }
    }

