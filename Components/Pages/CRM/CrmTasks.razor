    [JSInvokable]
    public async Task OnKeyboardShortcut(string action)
    {
        switch (action)
        {
            case "all": await SetQuickFilter("all"); break;
            case "overdue": await SetQuickFilter("overdue"); break;
            case "today": await SetQuickFilter("today"); break;
            case "tomorrow": await SetQuickFilter("tomorrow"); break;
            case "upcoming": await SetQuickFilter("upcoming"); break;
            case "board": SetView(ViewMode.Board); StateHasChanged(); break;
            case "list": SetView(ViewMode.List); StateHasChanged(); break;
            case "table": SetView(ViewMode.Table); StateHasChanged(); break;
            case "export": await ExportExcel(); break;
        }
    }

