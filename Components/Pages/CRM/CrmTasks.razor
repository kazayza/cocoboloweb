@page "/crm/tasks"

@using COCOBOLOERPNEW.DTOs
@using COCOBOLOERPNEW.Models
@using COCOBOLOERPNEW.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using ClosedXML.Excel
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

@inject ITaskService TaskService
@inject IOpportunityService OppService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider

@implements IAsyncDisposable

<PageTitle>إدارة المهام — CRM</PageTitle>

<script suppress-error="BL9992">
(function () {
    if (window.__crmTasksReady) return;
    window.__crmTasksReady = true;

    var _ref = null, _fn = null, _tm = null;
    window.setupTasksScrollWatcher = function (dotNetRef) {
        _ref = dotNetRef;
        if (_fn) window.removeEventListener('scroll', _fn);
        _fn = function () {
            clearTimeout(_tm);
            _tm = setTimeout(function () {
                if (_ref) { try { _ref.invokeMethodAsync('OnScrollChanged', window.pageYOffset || document.documentElement.scrollTop || 0); } catch (e) { } }
            }, 80);
        };
        window.addEventListener('scroll', _fn, { passive: true });
        setTimeout(_fn, 200);
    };
    window.removeTasksScrollWatcher = function () { if (_fn) window.removeEventListener('scroll', _fn); _ref = null; _fn = null; };

    window.setupTasksKeyboard = function (dotNetRef) {
        var handler = function (e) {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT' || e.target.isContentEditable) return;
            var map = { '1': 'all', '2': 'overdue', '3': 'today', '4': 'tomorrow', '5': 'upcoming' };
            if (map[e.key]) { e.preventDefault(); dotNetRef.invokeMethodAsync('OnKeyboardShortcut', map[e.key]); }
            else if (e.key.toLowerCase() === 'b') { e.preventDefault(); dotNetRef.invokeMethodAsync('OnKeyboardShortcut', 'board'); }
            else if (e.key.toLowerCase() === 'l') { e.preventDefault(); dotNetRef.invokeMethodAsync('OnKeyboardShortcut', 'list'); }
            else if (e.key.toLowerCase() === 't') { e.preventDefault(); dotNetRef.invokeMethodAsync('OnKeyboardShortcut', 'table'); }
            else if (e.key.toLowerCase() === 'e' && e.ctrlKey) { e.preventDefault(); dotNetRef.invokeMethodAsync('OnKeyboardShortcut', 'export'); }
        };
        window.addEventListener('keydown', handler);
        window.__tasksKeyHandler = handler;
    };
    window.removeTasksKeyboard = function () { if (window.__tasksKeyHandler) { window.removeEventListener('keydown', window.__tasksKeyHandler); window.__tasksKeyHandler = null; } };

    window.saveTasksPrefs = function (k, v) { try { localStorage.setItem('crm_tasks_' + k, JSON.stringify(v)); } catch (e) { } };
    window.loadTasksPrefs = function (k) { try { var v = localStorage.getItem('crm_tasks_' + k); return v ? JSON.parse(v) : null; } catch (e) { return null; } };

    window.updateTasksTabBadge = function (count) {
        document.title = count > 0 ? '(' + count + ') \u26A0\uFE0F \u0625\u062F\u0627\u0631\u0629 \u0627\u0644\u0645\u0647\u0627\u0645 \u2014 CRM' : '\u0625\u062F\u0627\u0631\u0629 \u0627\u0644\u0645\u0647\u0627\u0645 \u2014 CRM';
    };

    window.scrollTasksToTop = function () { window.scrollTo({ top: 0, behavior: 'smooth' }); };
    window.printTasks = function () { window.print(); };

    window.downloadTasksFile = function (fileName, base64, contentType) {
        try {
            var raw = atob(base64), len = raw.length, u8 = new Uint8Array(len);
            for (var i = 0; i < len; i++) u8[i] = raw.charCodeAt(i);
            var blob = new Blob([u8], { type: contentType || 'application/octet-stream' });
            var url = URL.createObjectURL(blob), a = document.createElement('a');
            a.href = url; a.download = fileName; document.body.appendChild(a); a.click();
            setTimeout(function () { document.body.removeChild(a); URL.revokeObjectURL(url); }, 300);
            return true;
        } catch (e) { console.error(e); return false; }
    };
})();
</script>

@if (_loading)
{
    <div class="loading-screen">
        <div class="loading-content">
            <div class="loading-logo">
                <MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Size="MudSize.Large" />
                <div class="loading-ring"></div>
                <div class="loading-ring ring-2"></div>
            </div>
            <MudText Typo="Typo.h5" Class="mt-4" Style="font-weight:800">جاري تحميل المهام</MudText>
            <MudProgressLinear Color="MudColor.Primary" Indeterminate="true" Class="mt-4" Style="max-width:300px;border-radius:8px" />
        </div>
    </div>
}
else
{
<div dir="rtl" class="tasks-page">
   
    @* ═══ 1. ALERT BAR ═══ *@
    @if (_stats.Overdue > 0)
    {
        <div class="alert-bar" @onclick="@(() => SetQuickFilter("overdue"))">
            <div class="alert-content">
                <div class="alert-pulse"></div>
                <span class="alert-icon">⚠️</span>
                <span class="alert-text">تنبيه: لديك <strong>@_stats.Overdue</strong> مهام متأخرة!</span>
            </div>
            <span class="alert-action">عرض المتأخرات ←</span>
        </div>
    }
    

    @* ═══ HEADER ═══ *@
    <div class="premium-header">
        <div class="header-bg">
            <div class="header-gradient"></div>
            <div class="header-pattern"></div>
            <div class="header-orb orb-1"></div>
            <div class="header-orb orb-2"></div>
            <div class="header-orb orb-3"></div>
        </div>
        <div class="header-content">
            <div class="header-top">
                <div class="header-title">
                    <div class="title-icon-box">
                        <MudIcon Icon="@Icons.Material.Rounded.TaskAlt" Size="MudSize.Large" />
                        <div class="icon-pulse-ring"></div>
                    </div>
                    <div class="title-text">
                        <div class="title-badge-row">
                            <span class="live-dot"></span>
                            <span class="badge-text">CRM</span>
                        </div>
                        <h1>إدارة المهام</h1>
                        <p>متابعة وعرض جميع المهام • @_displayItems.Count مهمة نشطة</p>
                    </div>
                </div>
                <div class="header-btns">
                    @if (_canExport)
                    {
                        <button class="export-btn" @onclick="ExportExcel" disabled="@_isExporting">
                            @if (_isExporting)
                            { <div class="btn-spinner"></div> <span>جاري التصدير...</span> }
                            else
                            { <MudIcon Icon="@Icons.Material.Rounded.FileDownload" Size="MudSize.Small" /> <span>تصدير Excel</span> }
                        </button>
                    }
                    <button class="print-btn-header" @onclick="PrintPage">
                        <MudIcon Icon="@Icons.Material.Rounded.Print" Size="MudSize.Small" /> <span>طباعة</span>
                    </button>
                    @if (_crmAccessFrom.HasValue)
                    {
                        <div class="access-badge">
                            <MudIcon Icon="@Icons.Material.Rounded.Lock" Size="MudSize.Small" />
                            <span>من @_crmAccessFrom.Value.ToString("yyyy/MM/dd")</span>
                        </div>
                    }
                </div>
            </div>

            @* KPI - Clickable Filter Cards *@
            <div class="kpi-grid">
                <button type="button" class="kpi-card kpi-clickable @(_stats.Overdue > 0 ? "kpi-alert" : "") @(_quickFilter == "overdue" ? "kpi-selected" : "")"
                        @onclick="@(() => SetQuickFilter("overdue"))">
                    <div class="kpi-icon" style="background:rgba(248,113,113,.15);color:#f87171">
                        <MudIcon Icon="@Icons.Material.Rounded.Warning" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.Overdue</span>
                        <span class="kpi-label">⚠️ متأخرة</span>
                    </div>
                    @if (_stats.Overdue > 0) { <span class="kpi-live-dot" style="background:#f87171;box-shadow:0 0 8px #f87171"></span> }
                </button>
                <button type="button" class="kpi-card kpi-clickable @(_quickFilter == "today" ? "kpi-selected" : "")"
                        @onclick="@(() => SetQuickFilter("today"))">
                    <div class="kpi-icon" style="background:rgba(251,191,36,.15);color:#fbbf24">
                        <MudIcon Icon="@Icons.Material.Rounded.Today" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.DueToday</span>
                        <span class="kpi-label">🕐 اليوم</span>
                    </div>
                </button>
                <button type="button" class="kpi-card kpi-clickable @(_quickFilter == "tomorrow" ? "kpi-selected" : "")"
                        @onclick="@(() => SetQuickFilter("tomorrow"))">
                    <div class="kpi-icon" style="background:rgba(96,165,250,.15);color:#60a5fa">
                        <MudIcon Icon="@Icons.Material.Rounded.Event" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.DueTomorrow</span>
                        <span class="kpi-label">📅 غداً</span>
                    </div>
                </button>
                <button type="button" class="kpi-card kpi-clickable @(_quickFilter == "upcoming" ? "kpi-selected" : "")"
                        @onclick="@(() => SetQuickFilter("upcoming"))">
                    <div class="kpi-icon" style="background:rgba(52,211,153,.15);color:#34d399">
                        <MudIcon Icon="@Icons.Material.Rounded.Upcoming" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.Upcoming</span>
                        <span class="kpi-label">🟢 قادمة</span>
                    </div>
                </button>
                <button type="button" class="kpi-card kpi-clickable @(_quickFilter == "all" ? "kpi-selected" : "")"
                        @onclick="@(() => SetQuickFilter("all"))">
                    <div class="kpi-icon" style="background:rgba(99,102,241,.15);color:#818cf8">
                        <MudIcon Icon="@Icons.Material.Rounded.Inventory2" Size="MudSize.Small" />
                    </div>
                    <div class="kpi-data">
                        <span class="kpi-value">@_stats.TotalActive</span>
                        <span class="kpi-label">إجمالي النشطة</span>
                    </div>
                </button>
            </div>

            @* ═══ 5. MINI PROGRESS ═══ *@
            @if (_stats.TotalToday > 0)
            {
                <div class="progress-section">
                    <span class="progress-label">إنجاز اليوم</span>
                    <div class="progress-track">
                        <div class="progress-fill @(_todayProgressPercent >= 100 ? "progress-done" : "")" style="width:@Math.Min(_todayProgressPercent, 100)%"></div>
                    </div>
                    <span class="progress-text">@_stats.CompletedToday/@_stats.TotalToday (@_todayProgressPercent%)</span>
                </div>
            }
        </div>
    </div>

    @* ═══ FILTERS ═══ *@
    <MudPaper Class="filter-paper" Elevation="0">
        <div class="filter-header" @onclick="ToggleFilters">
            <div class="filter-title">
                <div class="filter-icon-box"><MudIcon Icon="@Icons.Material.Rounded.FilterAlt" Size="MudSize.Small" /></div>
                <span>فلاتر متقدمة</span>
                @if (_hasActiveFilters)
                { <MudChip T="string" Size="MudSize.Small" Color="MudColor.Primary" Variant="Variant.Filled" Class="active-chip">@_activeFilterCount نشط</MudChip> }
            </div>
            <div class="@GetFilterToggleClass()">
                <MudIcon Icon="@Icons.Material.Rounded.KeyboardArrowDown" Size="MudSize.Small" />
            </div>
        </div>

        @if (_filtersExpanded)
        {
            <div class="filter-body animate-in">
                <div class="filter-section">
                    <div class="section-label"><MudIcon Icon="@Icons.Material.Rounded.Search" Size="MudSize.Small" /> البحث</div>
                    <div class="filter-grid cols-1">
                        <MudTextField T="string" Label="🔍 بحث في الوصف أو اسم العميل" Variant="Variant.Outlined"
                                      @bind-Value="_filter.SearchText" Dense="true"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                                      Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="ApplyFilters" />
                    </div>
                </div>
                <div class="filter-section">
                    <div class="section-label"><MudIcon Icon="@Icons.Material.Rounded.Tune" Size="MudSize.Small" /> التصنيف</div>
                    <div class="filter-grid cols-3">
                        <MudSelect T="string" Label="الأولوية" Variant="Variant.Outlined" @bind-Value="_filter.Priority" Dense="true" Clearable="true">
                            <MudSelectItem Value="@("High")"><div style="display:flex;align-items:center;gap:6px"><span class="priority-dot high"></span> عالية</div></MudSelectItem>
                            <MudSelectItem Value="@("Medium")"><div style="display:flex;align-items:center;gap:6px"><span class="priority-dot medium"></span> متوسطة</div></MudSelectItem>
                            <MudSelectItem Value="@("Low")"><div style="display:flex;align-items:center;gap:6px"><span class="priority-dot low"></span> منخفضة</div></MudSelectItem>
                        </MudSelect>
                        <MudSelect T="int?" Label="الموظف المسؤول" Variant="Variant.Outlined" @bind-Value="_filter.AssignedTo" Dense="true" Clearable="true">
                            @foreach (var e in _employees) { <MudSelectItem Value="@((int?)e.EmployeeId)">@e.FullName</MudSelectItem> }
                        </MudSelect>
                        <MudSelect T="int?" Label="نوع المهمة" Variant="Variant.Outlined" @bind-Value="_filter.TaskTypeId" Dense="true" Clearable="true">
                            @foreach (var t in _taskTypes) { <MudSelectItem Value="@((int?)t.TaskTypeId)">@(t.TaskTypeNameAr ?? t.TaskTypeName)</MudSelectItem> }
                        </MudSelect>
                    </div>
                </div>
                <div class="filter-actions">
                    <div class="quick-filters">
                        <span class="quick-label">اختصارات:</span>
                        <MudChip T="string" OnClick="@(() => SetQuickFilter("all"))" Variant="@(_quickFilter=="all"?Variant.Filled:Variant.Outlined)" Color="MudColor.Default" Size="MudSize.Small">الكل</MudChip>
                        <MudChip T="string" OnClick="@(() => SetQuickFilter("overdue"))" Variant="@(_quickFilter=="overdue"?Variant.Filled:Variant.Outlined)" Color="MudColor.Error" Size="MudSize.Small">🔴 متأخر</MudChip>
                        <MudChip T="string" OnClick="@(() => SetQuickFilter("today"))" Variant="@(_quickFilter=="today"?Variant.Filled:Variant.Outlined)" Color="MudColor.Warning" Size="MudSize.Small">🟡 اليوم</MudChip>
                        <MudChip T="string" OnClick="@(() => SetQuickFilter("tomorrow"))" Variant="@(_quickFilter=="tomorrow"?Variant.Filled:Variant.Outlined)" Color="MudColor.Info" Size="MudSize.Small">🔵 غداً</MudChip>
                        <MudChip T="string" OnClick="@(() => SetQuickFilter("upcoming"))" Variant="@(_quickFilter=="upcoming"?Variant.Filled:Variant.Outlined)" Color="MudColor.Success" Size="MudSize.Small">🟢قادم</MudChip>
                    </div>
                    <div class="filter-btns">
                        <MudButton Variant="Variant.Filled" Color="MudColor.Primary" OnClick="ApplyFilters" StartIcon="@Icons.Material.Rounded.Search" Class="btn-action">بحث</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="MudColor.Default" OnClick="ResetFilters" StartIcon="@Icons.Material.Rounded.RestartAlt">إعادة تعيين</MudButton>
                    </div>
                </div>
            </div>
        }
    </MudPaper>

    @* ═══ VIEW TOOLBAR ═══ *@
    <div class="view-toolbar">
        <div class="toolbar-left">
            <div class="view-tabs">
                <button class="@GetViewTabClass(ViewMode.Board)" @onclick="@(() => SetView(ViewMode.Board))">
                    <MudIcon Icon="@Icons.Material.Rounded.ViewKanban" Size="MudSize.Small" /> كانبان <span class="shortcut-hint">B</span>
                </button>
                <button class="@GetViewTabClass(ViewMode.List)" @onclick="@(() => SetView(ViewMode.List))">
                    <MudIcon Icon="@Icons.Material.Rounded.ViewList" Size="MudSize.Small" /> قائمة <span class="shortcut-hint">L</span>
                </button>
                <button class="@GetViewTabClass(ViewMode.Table)" @onclick="@(() => SetView(ViewMode.Table))">
                    <MudIcon Icon="@Icons.Material.Rounded.TableRows" Size="MudSize.Small" /> جدول <span class="shortcut-hint">T</span>
                </button>
            </div>
            @if (_viewMode == ViewMode.List)
            {
                <div class="group-toggle-wrap">
                    <button class="@(_groupMode == GroupMode.ByTime ? "grp-btn active" : "grp-btn")" @onclick="@(() => SetGroupMode(GroupMode.ByTime))">
                        <MudIcon Icon="@Icons.Material.Rounded.Schedule" Size="MudSize.Small" /> حسب الوقت
                    </button>
                    <button class="@(_groupMode == GroupMode.ByEmployee ? "grp-btn active" : "grp-btn")" @onclick="@(() => SetGroupMode(GroupMode.ByEmployee))">
                        <MudIcon Icon="@Icons.Material.Rounded.People" Size="MudSize.Small" /> حسب الموظف
                    </button>
                </div>
            }
        </div>
        <div class="toolbar-right">
            <div class="refresh-wrap">
                <span class="refresh-label">🔄 @_refreshLabel</span>
                <button class="refresh-btn" @onclick="ManualRefresh">
                    <MudIcon Icon="@Icons.Material.Rounded.Refresh" Size="MudSize.Small" />
                </button>
            </div>
            <span class="total-label"><strong>@_displayItems.Count</strong> مهمة</span>
            <MudSelect T="int" Value="_filter.PageSize" ValueChanged="ChangePageSize" Dense="true" Variant="Variant.Outlined" Class="page-size-sel" Label="صفوف">
                <MudSelectItem Value="25">25</MudSelectItem>
                <MudSelectItem Value="50">50</MudSelectItem>
                <MudSelectItem Value="100">100</MudSelectItem>
            </MudSelect>
            <MudTooltip Text="اختصارات: 1-5 شيبس | B كانبان | L قائمة | T جدول | Ctrl+E تصدير" Arrow="true" Placement="Placement.Top">
                <div class="shortcuts-icon"><MudIcon Icon="@Icons.Material.Rounded.Keyboard" Size="MudSize.Small" /></div>
            </MudTooltip>
        </div>
    </div>

    @if (_isLoadingData) { <MudProgressLinear Color="MudColor.Primary" Indeterminate="true" Class="mb-3" Style="border-radius:4px" /> }

        @* ═══ KANBAN ═══ *@
    @if (_viewMode == ViewMode.Board)
    {
        <div class="kanban-board">
            @foreach (var col in _kanbanColumns)
            {
                var colTasks = GetColumnTasks(col.Key);
                <div class="kanban-col">
                    <div class="kanban-col-header" style="@($"border-top:3px solid {col.Color}")">
                        <div class="col-title">
                            <span class="col-icon">@col.Emoji</span>
                            <span>@col.Title</span>
                        </div>
                        <span class="col-count" style="@($"background:{col.Color}18;color:{col.Color}")">@colTasks.Count</span>
                    </div>
                    <div class="kanban-col-body">
                        @foreach (var task in colTasks)
                        {
                            var cat = GetSmartCategory(task);
                            <div class="kanban-card premium-card @GetOverdueSeverityClass(task)"
                                 @onclick="@(() => OpenTask(task))">

                                @* ROW 1: Type Badge (Lead vs Client) + Priority Pill *@
                                <div class="kc-top-bar">
                                    @if (task.IsLeadTask)
                                    {
                                        <span class="kc-pill pill-lead">📣 متابعة Lead جديد</span>
                                    }
                                    else
                                    {
                                        <span class="kc-pill pill-client">👤 متابعة عميل</span>
                                    }
                                    <span class="kc-priority-pill @GetPriorityClass(task.Priority)">@GetPriorityIcon(task.Priority) @GetPriorityLabel(task.Priority)</span>
                                </div>

                                @* ROW 2: Client Box + Phone + WhatsApp Quick Action *@
                                <div class="kc-client-box">
                                    <div class="kc-client-info">
                                        <div class="avatar sm gradient-avatar">@GetInitials(task.ClientName)</div>
                                        <div class="kc-client-text">
                                            <div class="kc-client-name">@(task.ClientName ?? "—")</div>
                                            @if (!string.IsNullOrWhiteSpace(task.Phone))
                                            {
                                                <div class="kc-client-phone" @onclick:stopPropagation="true">
                                                    <a href="https://wa.me/@(CleanPhoneForWhatsApp(task.Phone))" target="_blank" class="wa-quick-link">
                                                        <MudIcon Icon="@Icons.Custom.Brands.WhatsApp" Size="MudSize.Small" Color="Color.Success" />
                                                        <span>@task.Phone</span>
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(task.TaskTypeName))
                                    {
                                        <span class="kc-type-tag">📋 @(task.TaskTypeNameAr ?? task.TaskTypeName)</span>
                                    }
                                </div>

                                @* ROW 3: Task Description *@
                                <div class="kc-desc-rich">@Truncate(task.TaskDescription ?? "بدون وصف", 120)</div>

                                @* ROW 4: Campaign / Platform Meta Tags (For Leads) *@
                                @if (task.IsLeadTask && (!string.IsNullOrWhiteSpace(task.CampaignName) || !string.IsNullOrWhiteSpace(task.Platform)))
                                {
                                    <div class="kc-meta-row">
                                        @if (!string.IsNullOrWhiteSpace(task.Platform))
                                        {
                                            <span class="kc-meta-tag platform">📱 @task.Platform</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(task.CampaignName))
                                        {
                                            <span class="kc-meta-tag campaign">🎯 @task.CampaignName</span>
                                        }
                                    </div>
                                }

                                @* ROW 5: Footer *@
                                <div class="kc-footer-rich">
                                    <div class="kc-due-part">
                                        <MudIcon Icon="@Icons.Material.Rounded.Schedule" Size="MudSize.Small" />
                                        <span>@task.DueDate.ToString("dd/MM/yyyy")</span>
                                        @if (task.DueTime.HasValue) { <span class="kc-time">@task.DueTime.Value.ToString(@"HH\:mm")</span> }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(task.AssignedToName))
                                    {
                                        <div class="kc-user-part">
                                            <MudIcon Icon="@Icons.Material.Rounded.PersonOutline" Size="MudSize.Small" />
                                            <span>@task.AssignedToName</span>
                                        </div>
                                    }
                                </div>

                                @* ROW 6: Dynamic Urgency Banner *@
                                @if (cat == "overdue")
                                {
                                    <div class="kc-urgency-banner overdue">@GetOverdueBadgeText(task)</div>
                                }
                                else if (cat == "today")
                                {
                                    <div class="kc-urgency-banner today">⏰ مستحق اليوم @(task.DueTime.HasValue ? task.DueTime.Value.ToString(@"HH\:mm") : "")</div>
                                }
                                else if (cat == "tomorrow")
                                {
                                    <div class="kc-urgency-banner tomorrow">📅 مستحق غداً</div>
                                }
                            </div>
                        }
                        @if (!colTasks.Any())
                        {
                            <div class="kanban-empty">
                                <span>@col.Emoji</span>
                                <span>@GetEmptySubtitle()</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @* ═══ SMART LIST ═══ *@
    @if (_viewMode == ViewMode.List)
    {
        <div class="smart-list">
            @if (_groupMode == GroupMode.ByTime)
            {
                @foreach (var group in _smartGroups)
                {
                    <div class="group-header">
                        <span class="gh-dot" style="@($"background:{GetGroupColor(group.Key)}")"></span>
                        <span class="gh-label" style="@($"color:{GetGroupColor(group.Key)}")">@GetGroupTitle(group.Key)</span>
                        <span class="gh-count" style="@($"background:{GetGroupColor(group.Key)}18;color:{GetGroupColor(group.Key)}")">@group.Count()</span>
                        <span class="gh-line"></span>
                    </div>
                    @foreach (var task in group)
                    {
                        var cat = GetSmartCategory(task);
                        <div class="task-item @GetOverdueSeverityClass(task) @(cat == "today" ? "item-today" : "") @(cat == "tomorrow" ? "item-tomorrow" : "")"
                             @onclick="@(() => OpenTask(task))">
                            <div class="ti-border" style="@($"background:{GetGroupColor(cat)}")"></div>
                            <div class="ti-right">
                                <span class="ti-priority @GetPriorityClass(task.Priority)">@GetPriorityIcon(task.Priority)</span>
                                <div class="ti-content">
                                    <div class="ti-desc">@(task.TaskDescription ?? "بدون وصف")</div>
                                    <div class="ti-meta">
                                        @if (!string.IsNullOrWhiteSpace(task.ClientName))
                                        { <span class="ti-tag client">@(task.IsLeadTask ? "📣" : "👤") @task.ClientName</span> }
                                        @if (!string.IsNullOrWhiteSpace(task.TaskTypeName))
                                        { <span class="ti-tag type">📋 @(task.TaskTypeNameAr ?? task.TaskTypeName)</span> }
                                        <span class="ti-tag due">📅 @task.DueDate.ToString("dd/MM/yyyy")@if (task.DueTime.HasValue) { @task.DueTime.Value.ToString(@" HH\:mm") }</span>
                                        @if (cat == "overdue")
                                        { <span class="ti-tag @GetOverdueTagClass(task)">@GetOverdueBadgeText(task)</span> }
                                        else if (cat == "today")
                                        { <span class="ti-tag today-tag">🕐 اليوم</span> }
                                        else if (cat == "tomorrow")
                                        { <span class="ti-tag tomorrow-tag">📅 غداً</span> }
                                        else
                                        { <span class="ti-tag upcoming-tag">بعد @GetDaysUntilDue(task) يوم</span> }
                                    </div>
                                </div>
                            </div>
                            <div class="ti-left">
                                <span class="ti-status @GetStatusClass(task.Status)">@GetStatusLabel(task.Status)</span>
                                @if (!string.IsNullOrWhiteSpace(task.AssignedToName))
                                { <span class="ti-assignee">@task.AssignedToName</span> }
                                <MudIcon Icon="@Icons.Material.Rounded.OpenInNew" Size="MudSize.Small" Style="color:var(--mud-palette-text-disabled)" />
                            </div>
                        </div>
                    }
                }
            }
            else @* GROUP BY EMPLOYEE *@
            {
                @foreach (var empGroup in _employeeGroups)
                {
                    <div class="group-header emp-header">
                        <div class="avatar sm" style="@GetTaskAvatarStyle()">@GetInitials(empGroup.Key)</div>
                        <span class="gh-label emp-name">@(empGroup.Key ?? "غير معين")</span>
                        <span class="gh-count emp-count">@empGroup.Count()</span>
                        <span class="gh-line"></span>
                    </div>
                    @foreach (var task in empGroup.OrderBy(t => GetSmartSortKey(t).Group).ThenBy(t => GetSmartSortKey(t).PriorityVal).ThenBy(t => GetSmartSortKey(t).DaysVal))
                    {
                        var cat = GetSmartCategory(task);
                        <div class="task-item @GetOverdueSeverityClass(task) @(cat == "today" ? "item-today" : "") @(cat == "tomorrow" ? "item-tomorrow" : "")"
                             @onclick="@(() => OpenTask(task))">
                            <div class="ti-border" style="@($"background:{GetGroupColor(cat)}")"></div>
                            <div class="ti-right">
                                <span class="ti-priority @GetPriorityClass(task.Priority)">@GetPriorityIcon(task.Priority)</span>
                                <div class="ti-content">
                                    <div class="ti-desc">@(task.TaskDescription ?? "بدون وصف")</div>
                                    <div class="ti-meta">
                                        @if (!string.IsNullOrWhiteSpace(task.ClientName))
                                        { <span class="ti-tag client">@(task.IsLeadTask ? "📣" : "👤") @task.ClientName</span> }
                                        <span class="ti-tag due">📅 @task.DueDate.ToString("dd/MM/yyyy")</span>
                                        @if (cat == "overdue")
                                        { <span class="ti-tag @GetOverdueTagClass(task)">@GetOverdueBadgeText(task)</span> }
                                        else if (cat == "today")
                                        { <span class="ti-tag today-tag">🕐 اليوم</span> }
                                        else if (cat == "tomorrow")
                                        { <span class="ti-tag tomorrow-tag">📅 غداً</span> }
                                        else
                                        { <span class="ti-tag upcoming-tag">بعد @GetDaysUntilDue(task) يوم</span> }
                                    </div>
                                </div>
                            </div>
                            <div class="ti-left">
                                <span class="ti-status @GetStatusClass(task.Status)">@GetStatusLabel(task.Status)</span>
                                <MudIcon Icon="@Icons.Material.Rounded.OpenInNew" Size="MudSize.Small" Style="color:var(--mud-palette-text-disabled)" />
                            </div>
                        </div>
                    }
                }
            }

            @if (!_displayItems.Any())
            {
                <div class="empty-box">
                    <div class="empty-circle"><MudIcon Icon="@GetEmptyIcon()" Size="MudSize.Large" /></div>
                    <h3>@GetEmptyTitle()</h3>
                    <p>@GetEmptySubtitle()</p>
                </div>
            }
        </div>
    }

    @* ═══ TABLE ═══ *@
    @if (_viewMode == ViewMode.Table)
    {
        <MudPaper Class="tbl-paper" Elevation="0">
            <div class="tbl-scroll">
                <table class="tbl">
                    <thead>
                        <tr>
                            <th>الحالة</th><th>الأولوية</th><th>الوصف</th><th>العميل</th><th>النوع</th>
                            <th>الاستحقاق</th><th>الموعد</th><th>المسؤول</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in _smartSortedItems)
                        {
                            var cat = GetSmartCategory(task);
                            <tr class="@GetOverdueSeverityClass(task) @(cat == "today" ? "row-today" : "")"
                                @onclick="@(() => OpenTask(task))">
                                <td>
                                    <div class="td-status-cell">
                                        <span class="status-dot" style="@($"background:{GetSmartStatusColor(task)}")"></span>
                                        <span class="td-status-text" style="@($"color:{GetSmartStatusColor(task)}")">@GetGroupTitle(cat)</span>
                                    </div>
                                </td>
                                <td><span class="priority-badge @GetPriorityClass(task.Priority)">@GetPriorityIcon(task.Priority) @GetPriorityLabel(task.Priority)</span></td>
                                <td><div class="td-desc">@Truncate(task.TaskDescription, 50)</div></td>
                                <td><strong>@(task.IsLeadTask ? "📣" : "👤") @(task.ClientName ?? "—")</strong></td>
                                <td>@(task.TaskTypeNameAr ?? task.TaskTypeName ?? "—")</td>
                                <td><div class="@("due-text " + (cat == "overdue" ? "due-overdue" : cat == "today" ? "due-today" : ""))">@task.DueDate.ToString("dd/MM/yyyy")</div></td>
                                <td>@(task.DueTime?.ToString(@"HH\:mm") ?? "—")</td>
                                <td>@(task.AssignedToName ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!_displayItems.Any())
            { <div class="empty-box sm"><MudIcon Icon="@GetEmptyIcon()" Size="MudSize.Large" /><h3>@GetEmptyTitle()</h3></div> }
        </MudPaper>
    }

    @* PAGINATION *@
    @if (_paged.TotalPages > 1)
    {
        <div class="paging">
            <MudPagination Count="_paged.TotalPages" Selected="_filter.PageNumber" SelectedChanged="GoToPage"
                           Color="MudColor.Primary" Size="MudSize.Medium" ShowFirstButton="true" ShowLastButton="true" />
        </div>
    }

    @* SCROLL TOP *@
    <div class="@GetScrollTopClass()" @onclick="ScrollToTop">
        <div class="scroll-btn"><MudIcon Icon="@Icons.Material.Rounded.KeyboardArrowUp" /></div>
    </div>
</div>
}

<style>
    :root{--page-max:1440px;--radius-lg:22px;--radius-md:14px;--radius-sm:8px}
    .tasks-page{padding:0 1.5rem 3rem;max-width:var(--page-max);margin:0 auto;font-size:.9rem;line-height:1.6}

    .loading-screen{display:flex;align-items:center;justify-content:center;min-height:80vh}
    .loading-content{display:flex;flex-direction:column;align-items:center;text-align:center}
    .loading-logo{position:relative;width:80px;height:80px;display:flex;align-items:center;justify-content:center;color:var(--mud-palette-primary)}
    .loading-ring{position:absolute;inset:-8px;border:3px solid transparent;border-top-color:var(--mud-palette-primary);border-radius:50%;animation:spin 1.2s linear infinite}
    .loading-ring.ring-2{inset:-16px;border-top-color:var(--mud-palette-secondary);animation-duration:1.8s;animation-direction:reverse}
    @@keyframes spin{to{transform:rotate(360deg)}}

    .alert-bar{background:linear-gradient(90deg,#fef2f2,#fff1f2);border:1px solid rgba(239,68,68,.25);border-radius:var(--radius-md);padding:.7rem 1.25rem;margin-bottom:1rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:all .25s;animation:alertSlide .4s ease-out}
    .alert-bar:hover{background:linear-gradient(90deg,#fee2e2,#ffe4e6);box-shadow:0 2px 12px rgba(239,68,68,.15)}
    .alert-content{display:flex;align-items:center;gap:.6rem}
    .alert-pulse{width:10px;height:10px;border-radius:50%;background:#ef4444;animation:alertPulse 1.5s ease-in-out infinite}
    .alert-icon{font-size:1.2rem}
    .alert-text{font-weight:600;font-size:.9rem;color:#991b1b}
    .alert-action{font-size:.82rem;font-weight:700;color:#ef4444;white-space:nowrap}
    @@keyframes alertSlide{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
    @@keyframes alertPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.3)}}

    .premium-header{position:relative;border-radius:var(--radius-lg);overflow:hidden;margin-bottom:1.5rem;box-shadow:0 12px 40px rgba(37,99,235,.22)}
    .header-bg{position:absolute;inset:0}
    .header-gradient{position:absolute;inset:0;background:linear-gradient(135deg,#1e3a5f 0%,#1e40af 30%,#2563eb 60%,#3b82f6 85%,#60a5fa 100%)}
    .header-pattern{position:absolute;inset:0;opacity:.06;background-image:radial-gradient(circle at 1px 1px,rgba(255,255,255,.5) 1px,transparent 0);background-size:28px 28px}
    .header-orb{position:absolute;border-radius:50%;filter:blur(70px);animation:orb-float 10s ease-in-out infinite}
    .orb-1{width:260px;height:260px;background:rgba(147,197,253,.2);top:-80px;right:-40px}
    .orb-2{width:180px;height:180px;background:rgba(99,102,241,.18);bottom:-50px;left:8%;animation-delay:-4s}
    .orb-3{width:120px;height:120px;background:rgba(52,211,153,.12);top:40%;left:55%;animation-delay:-7s}
    @@keyframes orb-float{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(15px,-10px) scale(1.08)}}
    .header-content{position:relative;z-index:2;padding:1.75rem 2rem;color:#fff}
    .header-top{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap}
    .header-title{display:flex;gap:1rem;align-items:center}
    .title-icon-box{position:relative;width:52px;height:52px;background:rgba(255,255,255,.13);backdrop-filter:blur(12px);border-radius:16px;display:flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.18);flex-shrink:0}
    .icon-pulse-ring{position:absolute;inset:-5px;border-radius:19px;border:2px solid rgba(255,255,255,.25);animation:pulse-ring 2.5s ease-out infinite}
    @@keyframes pulse-ring{0%{transform:scale(1);opacity:.6}100%{transform:scale(1.25);opacity:0}}
    .title-text h1{margin:0;font-size:1.65rem;font-weight:900;line-height:1.2}
    .title-text p{margin:.2rem 0 0;opacity:.85;font-size:.88rem}
    .title-badge-row{display:flex;align-items:center;gap:6px;margin-bottom:.25rem}
    .live-dot{width:7px;height:7px;border-radius:50%;background:#34d399;box-shadow:0 0 8px #34d399;animation:blink 2s infinite}
    .badge-text{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;opacity:.8}
    @@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
    .header-btns{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
    .export-btn,.print-btn-header{display:inline-flex;align-items:center;gap:6px;padding:8px 18px;background:rgba(255,255,255,.13);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.22);border-radius:10px;color:#fff;font-weight:700;font-size:.84rem;cursor:pointer;transition:all .25s;font-family:inherit}
    .export-btn:hover:not(:disabled),.print-btn-header:hover{background:rgba(255,255,255,.22);transform:translateY(-1px)}
    .export-btn:disabled{opacity:.5;cursor:not-allowed}
    .btn-spinner{width:18px;height:18px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite}
    .access-badge{display:flex;align-items:center;gap:4px;font-size:.7rem;opacity:.7;padding:3px 10px;background:rgba(255,255,255,.08);border-radius:6px}

    .progress-section{display:flex;align-items:center;gap:.75rem;margin-top:1.25rem;padding:.6rem 1rem;background:rgba(255,255,255,.08);border-radius:10px;border:1px solid rgba(255,255,255,.1)}
    .progress-label{font-size:.78rem;font-weight:600;white-space:nowrap;opacity:.9}
    .progress-track{flex:1;height:8px;background:rgba(255,255,255,.15);border-radius:4px;overflow:hidden}
    .progress-fill{height:100%;background:linear-gradient(90deg,#34d399,#22c55e);border-radius:4px;transition:width .8s ease}
    .progress-fill.progress-done{background:linear-gradient(90deg,#34d399,#10b981);box-shadow:0 0 10px rgba(34,197,94,.5)}
    .progress-text{font-size:.78rem;font-weight:700;white-space:nowrap;opacity:.9}

    .kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:.65rem}
    .kpi-card{position:relative;background:rgba(255,255,255,.09);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.1);border-radius:var(--radius-md);padding:.85rem;display:flex;align-items:center;gap:.65rem;transition:all .25s;overflow:hidden}
    .kpi-card:hover{background:rgba(255,255,255,.15);transform:translateY(-2px)}
    .kpi-clickable{cursor:pointer;border:none;width:100%;text-align:right;color:inherit;font:inherit}
    .kpi-clickable:focus-visible{outline:2px solid var(--gold);outline-offset:2px}
    .kpi-selected{background:rgba(212,175,55,.22)!important;border-color:rgba(212,175,55,.55)!important;box-shadow:0 0 18px rgba(212,175,55,.18)}
    .kpi-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .kpi-data{display:flex;flex-direction:column;min-width:0}
    .kpi-value{font-size:1.35rem;font-weight:900;line-height:1}
    .kpi-label{font-size:.7rem;opacity:.75;margin-top:.15rem;white-space:nowrap}
    .kpi-live-dot{position:absolute;top:6px;left:6px;width:7px;height:7px;border-radius:50%;animation:blink 1.5s infinite}
    .kpi-alert{border-color:rgba(248,113,113,.3)!important}

    .filter-paper{border-radius:var(--radius-md);border:1px solid var(--mud-palette-lines-default);margin-bottom:1rem;overflow:hidden;background:var(--mud-palette-surface)}
    .filter-header{padding:.85rem 1.25rem;display:flex;justify-content:space-between;align-items:center;cursor:pointer;user-select:none;transition:background .2s}
    .filter-header:hover{background:var(--mud-palette-action-hover)}
    .filter-title{display:flex;align-items:center;gap:.5rem;font-weight:700;font-size:.92rem}
    .filter-icon-box{width:28px;height:28px;border-radius:7px;background:var(--mud-palette-primary);color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .active-chip{font-size:.65rem!important;height:20px!important}
    .filter-toggle-btn{width:26px;height:26px;border-radius:50%;background:var(--mud-palette-action-hover);display:flex;align-items:center;justify-content:center;transition:transform .3s}
    .filter-toggle-btn.expanded{transform:rotate(180deg)}
    .filter-body{padding:0 1.25rem 1.25rem}
    .animate-in{animation:fadeSlide .25s ease-out}
    @@keyframes fadeSlide{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
    .filter-section{margin-bottom:.85rem}
    .section-label{display:flex;align-items:center;gap:.35rem;font-size:.76rem;font-weight:700;color:var(--mud-palette-text-secondary);margin-bottom:.45rem;text-transform:uppercase;letter-spacing:.5px}
    .filter-grid{display:grid;gap:.75rem}
    .cols-1{grid-template-columns:1fr}
    .cols-3{grid-template-columns:repeat(3,1fr)}
