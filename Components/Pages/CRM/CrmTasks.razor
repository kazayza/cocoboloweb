    .view-tab.active{background:var(--mud-palette-primary);color:#fff;box-shadow:0 2px 8px rgba(37,99,235,.3)}
    .shortcut-hint{font-size:.6rem;opacity:.5;font-weight:400;margin-right:2px}
    .view-tab.active .shortcut-hint{opacity:.7}
    .group-toggle-wrap{display:flex;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-lines-default);border-radius:10px;padding:3px;gap:3px}
    .grp-btn{display:flex;align-items:center;gap:4px;padding:6px 12px;border:none;background:transparent;border-radius:7px;font-size:.78rem;font-weight:600;cursor:pointer;color:var(--mud-palette-text-secondary);transition:all .2s;font-family:inherit}
    .grp-btn:hover{background:var(--mud-palette-action-hover)}
    .grp-btn.active{background:var(--mud-palette-secondary);color:#fff}
    .refresh-wrap{display:flex;align-items:center;gap:.3rem}
    .refresh-label{font-size:.72rem;color:var(--mud-palette-text-disabled);white-space:nowrap}
    .refresh-btn{width:28px;height:28px;border:1px solid var(--mud-palette-lines-default);border-radius:7px;background:var(--mud-palette-surface);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--mud-palette-text-secondary);transition:all .2s}
    .refresh-btn:hover{background:var(--mud-palette-primary);color:#fff;border-color:var(--mud-palette-primary)}
    .total-label{font-size:.84rem;color:var(--mud-palette-text-secondary)}
    .page-size-sel{width:82px}
    .shortcuts-icon{width:28px;height:28px;border-radius:7px;background:var(--mud-palette-action-hover);display:flex;align-items:center;justify-content:center;color:var(--mud-palette-text-disabled);cursor:help}

        /* ★ احذف القديم وحط ده بداله */
