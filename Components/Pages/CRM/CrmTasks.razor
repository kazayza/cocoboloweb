</style>

@code {
    // ═══ STATE ═══
    private bool _loading = true;
    private bool _isLoadingData;
    private bool _isExporting;
    private bool _filtersExpanded = true;
    private bool _canExport;
    private bool _showScrollTop;
    private string? _currentUser;
    private DateTime? _crmAccessFrom;
    private DotNetObjectReference<CrmTasks>? _dotNetRef;
    private System.Timers.Timer? _autoRefreshTimer;
    private DateTime _lastRefreshTime;
    private string _refreshLabel = "الآن";

    private TaskFilterDto _filter = new() { PageSize = 5000, SortBy = "DueDate" };
    private PagedResult<TaskListDto> _paged = new();
    private TaskStats _stats = new();

    private List<Employee> _employees = new();
    private List<TaskTypeItem> _taskTypes = new();

    private string _quickFilter = "all";

    private enum ViewMode { Board, List, Table }
    private ViewMode _viewMode = ViewMode.List;

    private enum GroupMode { ByTime, ByEmployee }
    private GroupMode _groupMode = GroupMode.ByTime;

    private readonly KanbanCol[] _kanbanColumns = new[]
    {
        new KanbanCol("overdue", "⚠️ متأخرة", "#ef4444", "⚠️"),
        new KanbanCol("today", "🕐 اليوم", "#f59e0b", "🕐"),
        new KanbanCol("tomorrow", "📅 غداً", "#3b82f6", "📅"),
        new KanbanCol("upcoming", "🟢 قادمة", "#22c55e", "🟢")
    };

    private record KanbanCol(string Key, string Title, string Color, string Emoji);
    private record TaskTypeItem(int TaskTypeId, string TaskTypeName, string? TaskTypeNameAr);

    // ═══════════════════════════════════════════════════════
    // ★ الحساب من DueDate مباشرة (مش من TaskDueStatus)
    // ═══════════════════════════════════════════════════════

    private static string GetSmartCategory(TaskListDto t)
    {
        var today = DateTime.Today;
        if (t.DueDate.Date < today) return "overdue";
        if (t.DueDate.Date == today) return "today";
        if (t.DueDate.Date == today.AddDays(1)) return "tomorrow";
        return "upcoming";
    }

    private static int GetDaysUntilDue(TaskListDto t)
    {
        var diff = (t.DueDate.Date - DateTime.Today).Days;
        return diff < 0 ? Math.Abs(diff) : diff;
    }

    // ═══ FILTERING ═══
    private List<TaskListDto> _activeItems =>
        _paged.Items.Where(t => t.Status != "Completed" && t.Status != "Cancelled").ToList();

    private List<TaskListDto> _displayItems => _quickFilter switch
    {
        "overdue"   => _activeItems.Where(t => GetSmartCategory(t) == "overdue").ToList(),
        "today"     => _activeItems.Where(t => GetSmartCategory(t) == "today").ToList(),
        "tomorrow"  => _activeItems.Where(t => GetSmartCategory(t) == "tomorrow").ToList(),
        "upcoming"  => _activeItems.Where(t => GetSmartCategory(t) == "upcoming").ToList(),
        _           => _activeItems
    };

    // ═══ SMART SORT ═══
    private static (int Group, int PriorityVal, int DaysVal) GetSmartSortKey(TaskListDto t)
    {
        int group = GetSmartCategory(t) switch { "overdue" => 1, "today" => 2, "tomorrow" => 3, _ => 4 };
        int pri = NormalizePriority(t.Priority) switch { "High" => 1, "Medium" => 2, "Low" => 3, _ => 4 };
        int days = GetDaysUntilDue(t);
        return (group, pri, days);
    }

    private List<TaskListDto> _smartSortedItems =>
        _displayItems.Select(t => new { Task = t, Key = GetSmartSortKey(t) })
            .OrderBy(x => x.Key.Group).ThenBy(x => x.Key.PriorityVal).ThenBy(x => x.Key.DaysVal)
            .Select(x => x.Task).ToList();

    private List<IGrouping<string, TaskListDto>> _smartGroups =>
        _smartSortedItems.GroupBy(t => GetSmartCategory(t))
            .OrderBy(g => g.Key switch { "overdue" => 1, "today" => 2, "tomorrow" => 3, "upcoming" => 4, _ => 5 }).ToList();

    private IEnumerable<IGrouping<string?, TaskListDto>> _employeeGroups =>
        _displayItems.GroupBy(t => t.AssignedToName).OrderByDescending(g => g.Count());

    private List<TaskListDto> GetColumnTasks(string key) =>
        _displayItems.Where(t => GetSmartCategory(t) == key).ToList();

    // ═══ PRIORITY ═══
    private static string NormalizePriority(string? p) => p switch
    { "High" => "High", "Medium" => "Medium", "Normal" => "Medium", "Low" => "Low", _ => "Medium" };

    private static string GetPriorityClass(string? p) => NormalizePriority(p) switch
    { "High" => "p-high", "Medium" => "p-medium", "Low" => "p-low", _ => "" };

    private static string GetPriorityIcon(string? p) => NormalizePriority(p) switch
    { "High" => "🔴", "Medium" => "🟡", "Low" => "🟢", _ => "⚪" };

    private static string GetPriorityLabel(string? p) => NormalizePriority(p) switch
    { "High" => "عالية", "Medium" => "متوسطة", "Low" => "منخفضة", _ => "—" };

    // ═══ GRADUATED OVERDUE ═══
    private static string GetOverdueSeverity(TaskListDto t)
    {
        if (GetSmartCategory(t) != "overdue") return "";
        var d = GetDaysUntilDue(t);
        if (d <= 1) return "low";
        if (d <= 6) return "med";
        return "high";
    }

    private static string GetOverdueSeverityClass(TaskListDto t) => GetOverdueSeverity(t) switch
    { "low" => "sev-low", "med" => "sev-med", "high" => "sev-high", _ => "" };

    private static string GetOverdueBadgeClass(TaskListDto t) => GetOverdueSeverity(t) switch
    { "low" => "badge-low", "med" => "badge-med", "high" => "badge-high", _ => "" };

    private static string GetOverdueTagClass(TaskListDto t) => GetOverdueSeverity(t) switch
    { "low" => "overdue-low", "med" => "overdue-med", "high" => "overdue-high", _ => "" };

    private static string GetOverdueBadgeText(TaskListDto t)
    {
        if (GetSmartCategory(t) != "overdue") return "";
        var d = GetDaysUntilDue(t);
        if (d == 1) return "⚠️ متأخرة يوم";
        if (d == 2) return "⚠️ متأخرة يومين";
        if (d <= 6) return $"⚠️ متأخرة {d} أيام";
        return $"🟣 متأخرة {d} يوم – حرج!";
    }

    // ═══ HELPERS ═══
    private bool _hasActiveFilters =>
        !string.IsNullOrWhiteSpace(_filter.Priority) || _filter.AssignedTo.HasValue ||
        _filter.TaskTypeId.HasValue || !string.IsNullOrWhiteSpace(_filter.SearchText);

    private int _activeFilterCount
    {
        get { int c = 0; if (!string.IsNullOrWhiteSpace(_filter.Priority)) c++; if (_filter.AssignedTo.HasValue) c++; if (_filter.TaskTypeId.HasValue) c++; if (!string.IsNullOrWhiteSpace(_filter.SearchText)) c++; return c; }
    }

    private string GetFilterToggleClass() => _filtersExpanded ? "filter-toggle-btn expanded" : "filter-toggle-btn";
    private string GetViewTabClass(ViewMode m) => _viewMode == m ? "view-tab active" : "view-tab";
    private string GetScrollTopClass() => _showScrollTop ? "scroll-top-fab visible" : "scroll-top-fab";

    private static string GetStatusClass(string? s) => s switch { "Pending" => "status-pending", "In Progress" => "status-inprogress", _ => "" };
    private static string GetStatusLabel(string? s) => s switch { "Pending" => "قيد الانتظار", "In Progress" => "جاري التنفيذ", _ => s ?? "—" };

    private static string GetSmartStatusColor(TaskListDto t) => GetSmartCategory(t) switch
    { "overdue" => "#ef4444", "today" => "#f59e0b", "tomorrow" => "#3b82f6", "upcoming" => "#22c55e", _ => "#94a3b8" };

    private static string GetGroupColor(string key) => key switch
    { "overdue" => "#ef4444", "today" => "#f59e0b", "tomorrow" => "#3b82f6", "upcoming" => "#22c55e", _ => "#94a3b8" };

    private static string GetGroupTitle(string key) => key switch
    { "overdue" => "⚠️ متأخرة", "today" => "🕐 اليوم", "tomorrow" => "📅 غداً", "upcoming" => "🟢 قادمة", _ => "أخرى" };

    private static string GetTaskAvatarStyle() => "background:linear-gradient(135deg,#2563eb,#7c3aed)";
    private static string GetInitials(string? n) => string.IsNullOrWhiteSpace(n) ? "?" : string.Join("", n.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();
    private static string Truncate(string? s, int m) => string.IsNullOrEmpty(s) ? "" : s.Length <= m ? s : s[..m] + "...";

    // ═══ PROGRESS ═══
    private int _todayProgressPercent => _stats.TotalToday > 0 ? (int)Math.Round((double)_stats.CompletedToday / _stats.TotalToday * 100) : 0;

    // ═══ SMART EMPTY ═══
    private string GetEmptyTitle() => _quickFilter switch
    { "overdue" => "✅ لا توجد مهام متأخرة – أحسنت!", "today" => "😊 لا توجد مهام مستحقة اليوم", "tomorrow" => "📅 لا توجد مهام غداً", "upcoming" => "🎯 لا توجد مهام قادمة", _ => "🎉 ممتاز! لا توجد مهام معلقة" };
    private string GetEmptySubtitle() => _quickFilter switch
    { "overdue" => "جميع المهام في موعدها", "today" => "استمتع ببقية اليوم!", "tomorrow" => "يمكنك التخطيط لغداً", "upcoming" => "أضف مهام جديدة للتخطيط", _ => "أضف مهام جديدة للبدء" };
    private string GetEmptyIcon() => _quickFilter switch
    { "overdue" => Icons.Material.Rounded.CheckCircle, "today" => Icons.Material.Rounded.EmojiEmotions, _ => Icons.Material.Rounded.Celebration };

    // ═══ LIFECYCLE ═══
    [Parameter][SupplyParameterFromQuery(Name = "assignedTo")] public int? QsAssignedTo { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            _currentUser = user.Identity?.Name;
            _canExport = user.HasClaim("Permission", "frmTasks:Export") || user.IsInRole("Admin");
            _crmAccessFrom = user.GetAccessFromDate();
            _employees = await OppService.GetActiveEmployeesAsync();
            // ✅ فلتر الموظفين: إدارة المبيعات أو إدارة العلاقات العامة فقط
            _employees = _employees
                .Where(e => e.Department == "المبيعات" || e.Department == "إدارة العلاقات العامة")
                .OrderBy(e => e.FullName)
                .ToList();
            // _taskTypes = await TaskService.GetTaskTypesAsync();

            // لو جاى من MyLeads ومفلتر بموظف
            if (QsAssignedTo.HasValue)
                _filter.AssignedTo = QsAssignedTo;

            await LoadPrefs();
            await LoadData();
            StartAutoRefresh();
        }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _loading = false; StateHasChanged(); }
    }

