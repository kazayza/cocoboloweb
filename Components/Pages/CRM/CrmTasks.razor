    .quick-filters{display:flex;gap:.3rem;align-items:center;flex-wrap:wrap}
    .quick-label{font-size:.72rem;font-weight:600;color:var(--mud-palette-text-secondary)}
    .filter-btns{display:flex;gap:.4rem}
    .btn-action{font-weight:700!important}
    .priority-dot{width:10px;height:10px;border-radius:50%;display:inline-block}
