    .row-sev-med{background:rgba(239,68,68,.02)!important}
    .row-sev-high{background:rgba(168,85,247,.02)!important}

        .kanban-board{display:grid;grid-template-columns:repeat(4,minmax(330px,1fr));gap:1.25rem;align-items:flex-start;overflow-x:auto;padding-bottom:1.5rem}
    .kanban-col{background:var(--mud-palette-background);border-radius:16px;overflow:hidden;border:1px solid var(--mud-palette-lines-default);box-shadow:0 4px 20px rgba(0,0,0,.03)}
    .kanban-col-header{padding:1.1rem 1.4rem;display:flex;justify-content:space-between;align-items:center;background:var(--mud-palette-surface);border-bottom:1px solid var(--mud-palette-lines-default)}
    .col-title{display:flex;align-items:center;gap:.6rem;font-weight:800;font-size:1.05rem}
    .col-icon{font-size:1.25rem}
    .col-count{font-size:.78rem;font-weight:800;padding:3px 12px;border-radius:14px}
    .kanban-col-body{padding:1rem .85rem;display:flex;flex-direction:column;gap:1rem;min-height:160px;max-height:72vh;overflow-y:auto}
    .kanban-card.premium-card{background:var(--mud-palette-surface);border:1px solid var(--mud-palette-lines-default);border-radius:16px;padding:1.4rem;cursor:pointer;transition:all .3s cubic-bezier(.4,0,.2,1);position:relative;display:flex;flex-direction:column;gap:1rem}
    .kanban-card.premium-card:hover{box-shadow:0 12px 32px rgba(0,0,0,.12);transform:translateY(-4px);border-color:var(--mud-palette-primary)}
    .kc-top-bar{display:flex;justify-content:space-between;align-items:center}
    .kc-pill{font-size:.74rem;font-weight:800;padding:4px 10px;border-radius:20px;display:inline-flex;align-items:center;gap:4px}
    .pill-lead{background:rgba(236,72,153,.12);color:#db2777;border:1px solid rgba(236,72,153,.25)}
    .pill-client{background:rgba(59,130,246,.12);color:#2563eb;border:1px solid rgba(59,130,246,.25)}
    .kc-priority-pill{font-size:.74rem;font-weight:700;padding:3px 10px;border-radius:10px}
