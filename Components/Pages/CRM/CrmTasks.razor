    .toolbar-right{display:flex;align-items:center;gap:.6rem;flex-wrap:wrap}
    .view-tabs{display:flex;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-lines-default);border-radius:10px;padding:3px;gap:3px}
