    private static string CleanPhoneForWhatsApp(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return "";
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        if (digits.StartsWith("01") && digits.Length == 11) return "2" + digits;
        return digits;
    }

    // ═══ EXPORT ═══
    private async Task ExportExcel()
    {
        if (_isExporting || !_canExport) return;
        _isExporting = true; StateHasChanged();
        try
        {
            var ef = new TaskFilterDto
            {
                PageSize = 50000, SearchText = _filter.SearchText,
                Priority = _filter.Priority, AssignedTo = _filter.AssignedTo,
                TaskTypeId = _filter.TaskTypeId
            };
            var data = await TaskService.GetTasksAsync(ef);
            var active = data.Items.Where(t => t.Status != "Completed" && t.Status != "Cancelled").ToList();
            if (!active.Any()) { Snackbar.Add("لا توجد بيانات", Severity.Warning); return; }

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("المهام");
            var hdrs = new[] { "الحالة الزمنية", "الوصف", "العميل", "النوع", "الأولوية", "الحالة", "تاريخ الاستحقاق", "الوقت", "المسؤول" };
            for (int i = 0; i < hdrs.Length; i++)
            {
                var c = ws.Cell(1, i + 1); c.Value = hdrs[i]; c.Style.Font.Bold = true;
                c.Style.Fill.BackgroundColor = XLColor.FromHtml("#1e40af"); c.Style.Font.FontColor = XLColor.White;
            }
            int row = 2;
            foreach (var t in _smartSortedItems)
            {
                ws.Cell(row, 1).Value = GetGroupTitle(GetSmartCategory(t));
                ws.Cell(row, 2).Value = t.TaskDescription ?? "";
                ws.Cell(row, 3).Value = t.ClientName ?? "";
                ws.Cell(row, 4).Value = t.TaskTypeNameAr ?? t.TaskTypeName ?? "";
                ws.Cell(row, 5).Value = GetPriorityLabel(t.Priority);
                ws.Cell(row, 6).Value = GetStatusLabel(t.Status);
                ws.Cell(row, 7).Value = t.DueDate.ToString("yyyy/MM/dd");
                ws.Cell(row, 8).Value = t.DueTime?.ToString(@"HH\:mm") ?? "";
                ws.Cell(row, 9).Value = t.AssignedToName ?? "";
                var cat = GetSmartCategory(t);
                if (cat == "overdue") ws.Range(row, 1, row, hdrs.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#fef2f2");
                else if (cat == "today") ws.Range(row, 1, row, hdrs.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#fffbeb");
                else if (row % 2 == 0) ws.Range(row, 1, row, hdrs.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#eff6ff");
                row++;
            }
            ws.Columns().AdjustToContents(); ws.RightToLeft = true; ws.SheetView.FreezeRows(1);

            using var ms = new MemoryStream(); wb.SaveAs(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var ok = await JS.InvokeAsync<bool>("downloadTasksFile",
                $"Tasks_{DateTime.Now:yyyyMMdd_HHmm}.xlsx", b64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            if (ok) Snackbar.Add($"تم تصدير {active.Count} مهمة ✓", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"فشل: {ex.Message}", Severity.Error); }
        finally { _isExporting = false; StateHasChanged(); }
    }

