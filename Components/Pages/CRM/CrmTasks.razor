    // ═══ DATA ═══
    private async Task LoadData()
    {
        _isLoadingData = true; StateHasChanged();
        try
        {
            _paged = await TaskService.GetTasksAsync(_filter);
            CalcStats();
            await UpdateTabBadge();
        }
        catch (Exception ex) { Snackbar.Add($"خطأ: {ex.Message}", Severity.Error); }
        finally { _isLoadingData = false; StateHasChanged(); }
    }

    private void CalcStats()
    {
        var active = _activeItems;
        var today = DateTime.Today;
        var completedToday = _paged.Items.Count(t => t.Status == "Completed" && t.DueDate.Date == today);

        _stats = new TaskStats
        {
            TotalActive = active.Count,
            Overdue = active.Count(t => GetSmartCategory(t) == "overdue"),
            DueToday = active.Count(t => GetSmartCategory(t) == "today"),
            DueTomorrow = active.Count(t => GetSmartCategory(t) == "tomorrow"),
            Upcoming = active.Count(t => GetSmartCategory(t) == "upcoming"),
            CompletedToday = completedToday,
            TotalToday = active.Count(t => GetSmartCategory(t) == "today") + completedToday
        };
    }

